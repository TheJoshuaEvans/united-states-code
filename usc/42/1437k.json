{"tag":"section","attrib":{"id":"idbafe456d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437k"},"text":"§ 1437k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia, joint ventures, affiliates, and subsidiaries of public housing agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbafe456e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbafe456f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any 2 or more public housing agencies may participate in a consortium for the purpose of administering any or all of the housing programs of those public housing agencies in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafe4570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any consortium described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbafe4571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any assistance made available under this subchapter to each of the public housing agencies participating in the consortium shall be paid to the consortium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbafe4572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all planning and reporting requirements imposed upon each public housing agency participating in the consortium with respect to the programs operated by the consortium shall be consolidated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafe4573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbafe4574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each consortium described in paragraph (1) shall be formed and operated in accordance with a consortium agreement, and shall be subject to the requirements of a joint public housing agency plan, which shall be submitted by the consortium in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c–1"},"text":"section 1437c–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbafe4575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall specify minimum requirements relating to the formation and operation of consortia and the minimum contents of consortium agreements under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbafe4576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint ventures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbafe4577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a public housing agency, in accordance with the public housing agency plan, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbafe4578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" form and operate wholly owned or controlled subsidiaries (which may be nonprofit corporations) and other affiliates, any of which may be directed, managed, or controlled by the same persons who constitute the board of directors or similar governing body of the public housing agency, or who serve as employees or staff of the public housing agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbafe4579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into joint ventures, partnerships, or other business arrangements with, or contract with, any person, organization, entity, or governmental unit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbafe457a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the administration of the programs of the public housing agency, including any program that is subject to this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbafe457b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of providing or arranging for the provision of supportive or social services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafe457c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use and treatment of income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any income generated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbafe457d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used for low-income housing or to benefit the residents assisted by the public housing agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbafe457e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not result in any decrease in any amount provided to the public housing agency under this subchapter, except as otherwise provided under the formulas established under section 1437g(d)(2) and 1437g(e)(2) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafe457f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States, the Secretary, or the Inspector General of the Department of Housing and Urban Development may conduct an audit of any activity undertaken under paragraph (1) at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbafe4580-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tII/s209"},"text":"Pub. L. 96–153, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1109"},"text":"93 Stat. 1109","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tII/s202/b"},"text":"Pub. L. 96–399, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1629"},"text":"94 Stat. 1629","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/100/358/s5"},"text":"Pub. L. 100–358, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-29"},"text":"June 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/681"},"text":"102 Stat. 681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s515"},"text":"Pub. L. 105–276, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2549"},"text":"112 Stat. 2549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbafe4581-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbafe4582-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbafe4583-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/894"},"text":"50 Stat. 894","children":[],"tail":", as amended, enumerated powers of the Authority and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1413"},"text":"section 1413 of this title","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbafe4584-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" amended section catchline and text of section generally. Prior to amendment, text read as follows: “The Secretary shall, to the maximum extent practicable, require that newly constructed and substantially rehabilitated projects assisted under this chapter with authority provided on or after "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", shall be equipped with heating and cooling systems selected on the basis of criteria which include a life-cycle cost analysis of such systems.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" struck out subsec. (a) which related to consideration by the Secretary, in utilizing contract authority, of projects which will be modernized to a substantial extent with weatherization materials as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6862/9"},"text":"section 6862(9) of this title","children":[],"tail":", and redesignated former subsec. (b) as entire section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbafe4585-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbafe4586-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" effective and applicable beginning upon "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement amendment before such date, except to extent that such amendment provides otherwise, and with savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbafe4587-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting by Agencies Operating in Consortia","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s209/c"},"text":"Pub. L. 115–174, title II, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1316"},"text":"132 Stat. 1316","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/174/tII/s209/c"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":"], the Secretary of Housing and Urban Development shall develop and deploy all electronic information systems necessary to accommodate full consolidated reporting by public housing agencies, as defined in section 3(b)(6) of the United States Housing Act of 1937 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/6"},"text":"42 U.S.C. 1437a(b)(6)","children":[],"tail":"), electing to operate in consortia under section 13(a) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437k/a"},"text":"42 U.S.C. 1437k(a)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbafe4588-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Energy Efficient Public Housing Demonstration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tI/s125"},"text":"Pub. L. 100–242, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1847"},"text":"101 Stat. 1847","children":[],"tail":", provided that the Secretary of Housing and Urban Development would establish a demonstration program through the assistance of an appropriate technology transfer organization specializing in producing detailed energy-efficient designs and in conducting local and statewide public participation tests for energy efficient, needs-oriented housing, provided the appropriate technology organization would carry out the demonstration working with public housing agencies to build and test energy-efficient housing designs in 100 separate housing units in 4 different States meeting local lower income housing needs through a composite ranging from single to 12-plex units in the cluster approach on vacant lots and open areas, provided that as soon as practicable following "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"Sept. 30, 1988","children":[],"tail":", the Secretary would submit to the Congress a report setting forth the findings and recommendations of the program, and authorized $4,700,000 for fiscal year 1988 for the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
