{"tag":"section","attrib":{"id":"idbfc801c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526"},"text":null,"children":[{"tag":"num","attrib":{"value":"13526"},"text":"§ 13526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uncosted obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc801c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Along with the submission of each of the President’s annual budget requests to Congress, the Secretary shall submit to Congress a report which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc801c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies the amount of Department of Energy funds that were, as of the end of the previous fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc801c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed uncosted obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc801c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uncommitted uncosted obligations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc801c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically describes the purposes for which all such funds are intended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc801c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains the effect that information contained in the report has had on the annual budget request for the Department of Energy being simultaneously submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc801c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 90 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit a report to the Congress containing definitions of the terms “uncosted obligation”, “committed uncosted obligation”, and “uncommitted uncosted obligation” for purposes of reports to be submitted under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc801c9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXIII/s2307"},"text":"Pub. L. 102–486, title XXIII, § 2307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3096"},"text":"106 Stat. 3096","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
