{"tag":"section","attrib":{"id":"idbfb73a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263"},"text":null,"children":[{"tag":"num","attrib":{"value":"13263"},"text":"§ 13263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out subchapter I, subchapter II, this subchapter, and subchapter IV, the Secretary, or the duly designated agent of the Secretary, may hold such hearings, take such testimony, sit and act at such times and places, administer such oaths, and require, by subpena, the attendance and testimony of such witnesses and the production of such books, papers, correspondence, memorandums, contracts, agreements, or other records as the Secretary of Transportation is authorized to do under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32910/a/1"},"text":"section 32910(a)(1) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfb73a26-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s513"},"text":"Pub. L. 102–486, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2899"},"text":"106 Stat. 2899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb73a27-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb73a28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb73a29-3a70-11f1-ae07-e4213316