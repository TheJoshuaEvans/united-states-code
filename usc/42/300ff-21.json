{"tag":"section","attrib":{"id":"idb69434a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–21"},"text":"§ 300ff–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to the availability of appropriations, make grants to States to enable such States to improve the quality, availability and organization of health care and support services for individuals and families with HIV/AIDS. The authority of the Secretary to provide grants under this section is subject to section 300ff–34(e)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002427"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002427"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (relating to the decrease in perinatal transmission of HIV/AIDS)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb69434a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2611, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tII/s201"},"text":"Pub. L. 101–381, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/586"},"text":"104 Stat. 586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":", §§ 3(c)(1), 7(b)(2), "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1353"},"text":"110 Stat. 1353","child