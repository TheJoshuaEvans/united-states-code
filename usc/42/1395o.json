{"tag":"section","attrib":{"id":"idb8e5c51d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395o"},"text":"§ 1395o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8e5c51e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e5c51f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to hospital insurance benefits under part A, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e5c520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has attained age 65 and is a resident of the United States, and is either (A) a citizen or (B) an alien lawfully admitted for permanent residence who has resided in the United States continuously during the 5 years immediately preceding the month in which he applies for enrollment under this part,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is eligible to enroll in the insurance program established by this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e5c521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals eligible for immunosuppressive drug coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e5c522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under paragraph (2), every individual whose entitlement to insurance benefits under part A ends (whether before, on, or after ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":") by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s426–1/b/2"},"text":"section 426–1(b)(2) of this title","children":[],"tail":" is eligible to enroll or to be deemed to have enrolled in the medical insurance program established by this part solely for purposes of coverage of immunosuppressive drugs in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395p/n"},"text":"section 1395p(n) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e5c523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception if other coverage is available","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8e5c524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in paragraph (1) shall not be eligible for enrollment in the program for purposes of coverage described in such paragraph with respect to any period in which the individual, as determined in accordance with subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8e5c525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in a group health plan or group or individual health insurance coverage, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91"},"text":"section 300gg–91 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e5c526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled for coverage under the TRICARE for Life program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086/d"},"text":"section 1086(d) of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e5c527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled under a State plan (or waiver of such plan) under subchapter XIX and is eligible to receive benefits for immunosuppressive drugs described in this subsection under such plan (or such waiver);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e5c528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled under a State child health plan (or waiver of such plan) under subchapter XXI and is eligible to receive benefits for such drugs under such plan (or such waiver); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e5c529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8e5c52a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled in the patient enrollment system of the Department of Veterans Affairs established and operated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of title 38","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8e5c52b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required to enroll under section 1705 of such title to receive immunosuppressive drugs described in this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8e5c52c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise eligible under a provision of title 38, other than section 1710 of such title to receive immunosuppressive drugs described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8e5c52d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8e5c52e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Commissioner of Social Security, shall establish a process for determining whether an individual described in paragraph (1) who is to be enrolled or deemed to be enrolled in the medical insurance program described in such paragraph meets the requirements for such enrollment under this subsection, including the requirement that the individual not be enrolled in other coverage as described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e5c52f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attestation regarding other coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process established under clause (i) shall include, at a minimum, a requirement that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8e5c530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual provide to the Commissioner an attestation that the individual is not enrolled and does not expect to enroll in such other coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8e5c531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395o/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual notify the Commissioner within 60 days of enrollment in such other coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8e5c532-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1836, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/304"},"text":"79 Stat. 304","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tII/s201/c/1"},"text":"Pub. L. 92–603, title II, § 201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1372"},"text":"86 Stat. 1372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/tIV/s402/a/2/A"},"text":"Pub. L. 116–260, div. CC, title IV, § 402(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2998"},"text":"134 Stat. 2998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e5c533-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e5c534-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e5c535-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/603"},"text":"Pub. L. 92–603","children":[],"tail":" designed former par. (2)(B) as par. (1), former par. (1) as introductory clause in par. (2), and former pars. (2)(A)(i) and (ii) as pars. (2)(A) and (B), and struck out “(A)” after “(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8e5c536-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8e5c537-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persons Convicted of Subversive Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s104/b/2"},"text":"Pub. L. 89–97, title I, § 104(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/334"},"text":"79 Stat. 334","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/97/tI/s104/b/2"},"text":"“An individual who has been convicted of any offense under (A) chapter 37 [section 792 et seq. of Title 18, Crimes and Criminal Procedure] (relating to espionage and censorship), chapter 105 [section 2151 et seq. of Title 18] (relating to sabotage), or chapter 115 [section 2381 et seq. of Title 18] (relating to treason, sedition, and subversive activities) of title 18 of the United States Code, or (B) section 4, 112, or 113 of the Internal Security Act of 1950, as amended [section 783, 822, or 823 of Title 50, War and National Defense], may not enroll under part B of title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
