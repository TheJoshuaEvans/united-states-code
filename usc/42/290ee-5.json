{"tag":"section","attrib":{"id":"idb5bff45b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–5"},"text":"§ 290ee–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National recovery housing best practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bff45c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices for operating recovery housing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff45d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the individuals and entities specified in paragraph (2), shall continue activities to identify, facilitate the development of, and periodically update consensus-based best practices, which may include model laws for implementing suggested minimum standards for operating, and promoting the availability of, high-quality recovery housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities described in paragraph (1), the Secretary shall consult with, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officials representing the agencies described in subsection (e)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directors or commissioners, as applicable, of State health departments, Tribal health departments, State Medicaid programs, and State insurance agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of health insurance issuers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national accrediting entities and reputable providers of, and analysts of, recovery housing services, including Indian Tribes, Tribal organizations, and Tribally designated housing entities that provide recovery housing services, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with a history of substance use disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other stakeholders identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The best practices referred to in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" published on the public website of the Substance Abuse and Mental Health Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of guideline on treatment services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In facilitating the development of best practices under paragraph (1), the Secretary may not include any best practices with respect to substance use disorder treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of fraudulent recovery housing operators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the individuals and entities described in paragraph (2), shall identify or facilitate the development of common indicators that could be used to identify potentially fraudulent recovery housing operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities described in paragraph (1), the Secretary shall consult with, as appropriate, the individuals and entities specified in subsection (a)(2) and the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practices for identification and reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities described in paragraph (1), the Secretary shall consider how law enforcement, public and private payers, and the public can best identify and report fraudulent recovery housing operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities described in paragraph (1), the Secretary shall identify or develop indicators, which may include indicators related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5bff46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unusual billing practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average lengths of stays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excessive levels of drug testing (in terms of cost or frequency); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unusually high levels of recidivism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, as appropriate, disseminate the best practices identified or developed under subsection (a) and the common indicators identified or developed under subsection (b) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies, which may include the provision of technical assistance to State agencies seeking to adopt or implement such best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribes, Tribal organizations, and tribally designated housing entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health insurance issuers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff47b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery housing entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff47c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities described in subsections (a) and (b), the Secretary, in consultation with appropriate individuals and entities described in subsections (a)(2) and (b)(2), shall consider how recovery housing is able to support recovery and prevent relapse, recidivism, or overdose (including overdose death), including by improving access and adherence to treatment, including medication-assisted treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Federal activities to promote the availability of housing for individuals experiencing homelessness, individuals with a mental illness, and individuals with a substance use disorder","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Assistant Secretary, and the Secretary of Housing and Urban Development shall convene an interagency working group for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase collaboration, cooperation, and consultation among the Department of Health and Human Services, the Department of Housing and Urban Development, and the Federal agencies listed in paragraph (2)(B), with respect to promoting the availability of housing, including high-quality recovery housing, for individuals experiencing homelessness, individuals with mental illnesses, and individuals with substance use disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To align the efforts of such agencies and avoid duplication of such efforts by such agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop objectives, priorities, and a long-term plan for supporting State, Tribal, and local efforts with respect to the operation of high-quality recovery housing that is consistent with the best practices developed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve information on the quality of recovery housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group under paragraph (1) shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, acting through the Assistant Secretary, and the Secretary of Housing and Urban Development, who shall serve as the co-chairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives of each of the following Federal agencies:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5bff487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Substance Abuse and Mental Health Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Inspector General of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of National Drug Control Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/2/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other Federal agency as the co-chairs determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The working group shall meet on a quarterly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the working group shall submit to the Committee on Health, Education, Labor, and Pensions, the Committee on Agriculture, Nutrition, and Forestry, and the Committee on Finance of the Senate and the Committee on Energy and Commerce, the Committee on Ways and Means, the Committee on Agriculture, and the Committee on Financial Services of the House of Representatives a report describing the work of the working group and any recommendations of the working group to improve Federal, State, and local coordination with respect to recovery housing and other housing resources and operations for individuals experiencing homelessness, individuals with a mental illness, and individuals with a substance use disorder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for implementing national recovery housing best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to States (and political subdivisions thereof), Indian Tribes, and territories—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of technical assistance to implement the guidelines and recommendations developed under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5bff499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of recovery housing for individuals with a substance use disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5bff49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of recovery housing in accordance with best practices developed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State promotion plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after receipt of a grant under paragraph (1), and every 2 years thereafter, each State (or political subdivisions thereof,) ","children":[{"tag":"ref","attrib":{"idref":"fn002242"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002242"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should follow the closing parenthesis."}],"tail":" Indian Tribe, or territory receiving a grant under paragraph (1) shall submit to the Secretary, and publish on a publicly accessible internet website of the State (or political subdivisions thereof), Indian Tribe, or territory—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bff49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan of the State (or political subdivisions thereof), Indian Tribe, or territory, with respect to the promotion of recovery housing for individuals with a substance use disorder located within the jurisdiction of such State (or political subdivisions thereof), Indian Tribe, or territory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bff49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how such plan is consistent with the best practices developed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to provide the Secretary with the authority to require States to adhere to minimum standards in the State oversight of recovery housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff49f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff4a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recovery housing” means a shared living environment free from alcohol and illicit drug use and centered on peer support and connection to services that promote sustained recovery from substance use disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff4a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Indian Tribe” and “Tribal organization” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff4a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tribally designated housing entity” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4103"},"text":"section 4103 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff4a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $5,000,000 for the period of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bff4a4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 550, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7031"},"text":"Pub. L. 115–271, title VII, § 7031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4014"},"text":"132 Stat. 4014","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI"},"text":"Pub. L. 117–328, div. FF, title I","children":[],"tail":", §§ 1232, 1233, 1235, 1236, "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5674"},"text":"136 Stat. 5674","children":[],"tail":", 5676, 5677.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bff4a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bff4a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5bff4a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", referred to in subsec. (e)(4), was in the original “the date of the enactment of this section”, and was translated as reading “the date of the enactment of this subsection”, meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", which enacted subsec. (e), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5bff4a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 550 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 550A of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–5a"},"text":"section 290ee–5a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bff4a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/1"},"text":"Pub. L. 117–328, § 1232(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “The Secretary, in consultation with the individuals and entities specified in paragraph (2), shall identify or facilitate the development of best practices, which may include model laws for implementing suggested minimum standards, for operating recovery housing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/2/A"},"text":"Pub. L. 117–328, § 1232(2)(A)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “relevant divisions of the Department of Health and Human Services, including the Substance Abuse and Mental Health Services Administration, the Office of Inspector General, the Indian Health Service, and the Centers for Medicare & Medicaid Services;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/2/A"},"text":"Pub. L. 117–328, § 1232(2)(A)","children":[],"tail":"–(C), redesignated subpar. (C) as (B), substituted “Tribal” for “tribal”, and struck out former subpar. (B) which read as follows: “the Secretary of Housing and Urban Development;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/2/B"},"text":"Pub. L. 117–328, § 1232(2)(B)","children":[],"tail":", redesignated subpar. (D) as (C). Former subpar. (C) redesignated (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/2/B"},"text":"Pub. L. 117–328, § 1232(2)(B)","children":[],"tail":", (D), redesignated subpar. (E) as (D) and substituted “Tribes, Tribal organizations, and Tribally” for “tribes, tribal organizations, and tribally”. Former subpar. (D) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/2/B"},"text":"Pub. L. 117–328, § 1232(2)(B)","children":[],"tail":", redesignated subpars. (F) and (G) as (E) and (F), respectively. Former subpar. (E) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1232/3"},"text":"Pub. L. 117–328, § 1232(3)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/2"},"text":"Pub. L. 117–328, § 1233(2)","children":[],"tail":", substituted “Indian Tribes, Tribal” for “Indian tribes, tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/4"},"text":"Pub. L. 117–328, § 1233(4)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1235"},"text":"Pub. L. 117–328, § 1235","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/1"},"text":"Pub. L. 117–328, § 1233(1)","children":[],"tail":", redesignated subsec. (e) as (g). Former subsec. (g) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/1"},"text":"Pub. L. 117–328, § 1233(1)","children":[],"tail":", redesignated subsec. (f) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/3"},"text":"Pub. L. 117–328, § 1233(3)","children":[],"tail":", substituted “Indian Tribe” for “Indian tribe” and “Tribal organization” for “tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1236"},"text":"Pub. L. 117–328, § 1236","children":[],"tail":", substituted “$5,000,000 for the period of fiscal years 2023 through 2027” for “$3,000,000 for the period of fiscal years 2019 through 2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1233/1"},"text":"Pub. L. 117–328, § 1233(1)","children":[],"tail":", redesignated subsec. (g) as (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
