{"tag":"section","attrib":{"id":"idb6ac0289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–15a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–15a"},"text":"§ 300gg–15a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A group health plan and a health insurance issuer offering group or individual health insurance coverage shall comply with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18031/e/3"},"text":"section 18031(e)(3) of this title","children":[],"tail":", except that a plan or coverage that is not offered through an Exchange shall only be required to submit the information required to the Secretary and the State insurance commissioner, and make such information available to the public."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6ac028a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2715A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10101/c"},"text":"Pub. L. 111–148, title X, § 10101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/884"},"text":"124 Stat. 884","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
