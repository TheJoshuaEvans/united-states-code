{"tag":"section","attrib":{"id":"idbf5a4c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903"},"text":null,"children":[{"tag":"num","attrib":{"value":"11903"},"text":"§ 11903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and assisted housing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this subchapter may be used in public housing or other federally assisted low-income housing projects for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of security personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement of local law enforcement agencies for additional security and protective services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical improvements which are specifically designed to enhance security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employment of one or more individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5a4c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to investigate drug-related or violent crime in and around the real property comprising any public or other federally assisted low-income housing project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5a4c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide evidence relating to such crime in any administrative or judicial proceeding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of training, communications equipment, and other related equipment for use by voluntary tenant patrols acting in cooperation with local law enforcement officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs designed to reduce use of drugs in and around public or other federally assisted low-income housing projects, including drug-abuse prevention, intervention, referral, and treatment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where a public housing agency, an Indian tribe, or recipient of assistance under the Native American Housing Assistance and Self-Determination Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.] receives a grant, providing funding to nonprofit resident management corporations and resident councils to develop security and drug abuse prevention programs involving site residents; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sports programs and sports activities that serve primarily youths from public or other federally assisted low-income housing projects and are operated in conjunction with, or in furtherance of, an organized program or plan designed to reduce or eliminate drugs and drug-related problems in and around such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other PHA-owned housing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, grants under this subchapter may be used to eliminate drug-related crime in and around housing owned by public housing agencies that is not public housing assisted under the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.] and is not otherwise federally assisted, for the activities described in paragraphs (1) through (7) of subsection (a), but only if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the housing is located in a high intensity drug trafficking area designated pursuant to section 1504 ","children":[{"tag":"ref","attrib":{"idref":"fn004020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 21; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public housing agency owning the housing demonstrates, to the satisfaction of the Secretary, that drug-related or violent activity in or around the housing has a detrimental effect on or about the real property comprising any public or other federally assisted low-income housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c29-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5124"},"text":"Pub. L. 100–690, title V, § 5124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4301"},"text":"102 Stat. 4301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4246"},"text":"104 Stat. 4246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s161/c"},"text":"Pub. L. 102–550, title I, § 161(c)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3718"},"text":"106 Stat. 3718","children":[],"tail":", 3719; "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVII/s704/2"},"text":"Pub. L. 104–330, title VII, § 704(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4051"},"text":"110 Stat. 4051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tII/s220/2"},"text":"Pub. L. 105–276, title II, § 220(2)","children":[],"tail":", title V, § 586(d), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2488"},"text":"112 Stat. 2488","children":[],"tail":", 2647.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5a4c2c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Native American Housing Assistance and Self-Determination Act of 1996, referred to in subsec. (a)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", which is classified principally to chapter 43 (§ 4101 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1504"},"text":"Section 1504 of title 21","children":[],"tail":", referred to in subsec. (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tI/s1009"},"text":"Pub. L. 100–690, title I, § 1009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4188"},"text":"102 Stat. 4188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5a4c2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/d/1/A"},"text":"Pub. L. 105–276, § 586(d)(1)(A)","children":[],"tail":", substituted “drug-related or violent crime in and around” for “drug-related crime on or about”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/d/1/C/i"},"text":"Pub. L. 105–276, § 586(d)(1)(C)(i)","children":[],"tail":", substituted “recipient of assistance under the Native American Housing Assistance and Self-Determination Act of 1996” for “tribally designated housing entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s220/2"},"text":"Pub. L. 105–276, § 220(2)","children":[],"tail":", inserted “, an Indian tribe,” after “public housing agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/d/1/B"},"text":"Pub. L. 105–276, § 586(d)(1)(B)","children":[],"tail":", (C)(ii), (8)[(D)], added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/d/2/A"},"text":"Pub. L. 105–276, § 586(d)(2)(A)","children":[],"tail":", substituted “drug-related crime in and around” for “drug-related crime in” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/d/2/B"},"text":"Pub. L. 105–276, § 586(d)(2)(B)","children":[],"tail":", substituted “drug-related or violent activity in or around” for “drug-related activity at”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":" inserted “or tribally designated housing entity” after “public housing agency” and struck out “public housing” after “nonprofit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, inserted “where a public housing agency receives a grant,” in par. (7), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “A public housing agency may use a grant under this subchapter for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the employment of security personnel in public housing projects;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) reimbursement of local law enforcement agencies for additional security and protective services for public housing projects;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) physical improvements in public housing projects which are specifically designed to enhance security;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the employment of 1 or more individuals—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) to investigate drug-related crime on or about the real property comprising any public housing project; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) to provide evidence relating to any such crime in any administrative or judicial proceeding;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) the provision of training, communications equipment, and other related equipment for use by voluntary public housing tenant patrols acting in cooperation with local law enforcement officials;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) innovative programs designed to reduce use of drugs in and around public housing projects; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) providing funding to nonprofit public housing resident management corporation and tenant councils to develop security and drug abuse prevention programs involving site residents.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5a4c2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5a4c2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" effective and applicable beginning upon "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement amendment before such date, except to extent that such amendment provides otherwise, and with savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5a4c30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
