{"tag":"section","attrib":{"id":"idbf5a4c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11902"},"text":null,"children":[{"tag":"num","attrib":{"value":"11902"},"text":"§ 11902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development, in accordance with the provisions of this subchapter, may make grants to public housing agencies, public housing resident management corporations that are principally managing, as determined by the Secretary, public housing projects owned by public housing agencies, recipients of assistance under the Native American Housing Assistance and Self-Determination Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.], Indian tribes "},{"tag":"ref","attrib":{"idref":"fn004019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" and private, for-profit and nonprofit owners of federally assisted low-income housing for use in eliminating drug-related and violent crime."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to terms and conditions established by the Secretary, public housing agencies may form consortia for purposes of applying for grants under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c12-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5123"},"text":"Pub. L. 100–690, title V, § 5123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4301"},"text":"102 Stat. 4301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4246"},"text":"104 Stat. 4246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s161/d/1"},"text":"Pub. L. 102–550, title I, § 161(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3719"},"text":"106 Stat. 3719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tVII/s704/1"},"text":"Pub. L. 104–330, title VII, § 704(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4051"},"text":"110 Stat. 4051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tII/s220/1"},"text":"Pub. L. 105–276, title II, § 220(1)","children":[],"tail":", title V, § 586(c), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2488"},"text":"112 Stat. 2488","children":[],"tail":", 2647.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c13-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c14-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5a4c15-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Native American Housing Assistance and Self-Determination Act of 1996, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", which is classified principally to chapter 43 (§ 4101 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5a4c16-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/c"},"text":"Pub. L. 105–276, § 586(c)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, substituted “recipients of assistance under the Native American Housing Assistance and Self-Determination Act of 1996” for “tribally designated housing entities”, inserted “and violent” after “drug-related”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s220/1"},"text":"Pub. L. 105–276, § 220(1)","children":[],"tail":", inserted “Indian tribes” before “and private”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":" struck out “(including Indian Housing Authorities)” after “grants to public housing agencies” and inserted “tribally designated housing entities,” before “and private”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted “, public housing resident management corporations that are principally managing, as determined by the Secretary, public housing projects owned by public housing agencies,” after “Authorities)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary of Housing and Urban Development, in accordance with the provisions of this subchapter, may make grants to public housing agencies (including Indian housing authorities) for use in eliminating drug-related crime in public housing projects.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5a4c17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5a4c18-3a70-11f1-ae07-e4213316b5fa"},