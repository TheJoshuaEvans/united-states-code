{"tag":"section","attrib":{"id":"idbc17a4f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296b–5"},"text":"§ 2296b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uranium inventory study","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit to the Congress a study and report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc17a4f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive inventory of all Government owned uranium or uranium equivalents, including natural uranium, depleted tailings, low-enriched uranium, and highly enriched uranium available for conversion to commercial use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the conversion of inventories of foreign and domestic highly enriched uranium to low-enriched uranium for commercial use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the potential need of the United States for inventories of highly enriched uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis and summary of technological requirements and costs associated with converting highly enriched uranium to low-enriched uranium, including the construction of facilities if necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of potential net proceeds from the conversion and sale of highly enriched uranium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for implementing a plan to convert highly enriched uranium to low-enriched uranium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–5/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for the future use and disposition of such inventories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a4fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1016"},"text":"Pub. L. 102–486, title X, § 1016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2949"},"text":"106 Stat. 2949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
