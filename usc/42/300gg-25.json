{"tag":"section","attrib":{"id":"idb6b0bca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–25"},"text":"§ 300gg–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards relating to benefits for mothers and newborns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b0bca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for minimum hospital stay following birth","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A group health plan, and a health insurance issuer offering group or individual health insurance coverage, may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict benefits for any hospital length of stay in connection with childbirth for the mother or newborn child, following a normal vaginal delivery, to less than 48 hours, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrict benefits for any hospital length of stay in connection with childbirth for the mother or newborn child, following a cesarean section, to less than 96 hours, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a provider obtain authorization from the plan or the issuer for prescribing any length of stay required under subparagraph (A) (without regard to paragraph (2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(A) shall not apply in connection with any group health plan or health insurance issuer in any case in which the decision to discharge the mother or her newborn child prior to the expiration of the minimum length of stay otherwise required under paragraph (1)(A) is made by an attending provider in consultation with the mother.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bcaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A group health plan, and a health insurance issuer offering group or individual health insurance coverage, may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bcab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to the mother or her newborn child eligibility, or continued eligibility, to enroll or to renew coverage under the terms of the plan or coverage, solely for the purpose of avoiding the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide monetary payments or rebates to mothers to encourage such mothers to accept less than the minimum protections available under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penalize or otherwise reduce or limit the reimbursement of an attending provider because such provider provided care to an individual participant or beneficiary in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives (monetary or otherwise) to an attending provider to induce such provider to provide care to an individual participant or beneficiary in a manner inconsistent with this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (c)(3), restrict benefits for any portion of a period within a hospital length of stay required under subsection (a) in a manner which is less favorable than the benefits provided for any preceding portion of such stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bcb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bcb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall be construed to require a mother who is a participant or beneficiary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bcb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to give birth in a hospital; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bcb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stay in the hospital for a fixed period of time following the birth of her child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to any group health plan, or any health insurance issuer offering group or individual health insurance coverage, which does not provide benefits for hospital lengths of stay in connection with childbirth for a mother or her newborn child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed as preventing a group health plan or health insurance issuer from imposing deductibles, coinsurance, or other cost-sharing in relation to benefits for hospital lengths of stay in connection with childbirth for a mother or newborn child under the plan (or under health insurance coverage offered in connection with a group health plan), except that such coinsurance or other cost-sharing for any portion of a period within a hospital length of stay required under subsection (a) may not be greater than such coinsurance or cost-sharing for any preceding portion of such stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bcb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan under this part shall comply with the notice requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1185/d"},"text":"section 1185(d) of title 29","children":[],"tail":" with respect to the requirements of this section as if such section applied to such plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bcb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level and type of reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent a group health plan or a health insurance issuer offering group or individual health insurance coverage from negotiating the level and type of reimbursement with a provider for care provided in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bcb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption; exception for health insurance coverage in certain States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bcb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this section shall not apply with respect to health insurance coverage if there is a State law (as defined in section 300gg–23(d)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002469"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002469"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) for a State that regulates such coverage that is described in any of the following subparagraphs:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bcba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires such coverage to provide for at least a 48-hour hospital length of stay following a normal vaginal delivery and at least a 96-hour hospital length of stay following a cesarean section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bcbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires such coverage to provide for maternity and pediatric care in accordance with guidelines established by the American College of Obstetricians and Gynecologists, the American Academy of Pediatrics, or other established professional medical associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bcbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such State law requires, in connection with such coverage for maternity care, that the hospital length of stay for such care is left to the decision of (or required to be made by) the attending provider in consultation with the mother.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bcbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–25/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 300gg–23(a)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title shall not be construed as superseding a State law described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b0bcbe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2725, formerly § 2704, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s604/a/3"},"text":"Pub. L. 104–204, title VI, § 604(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2939"},"text":"110 Stat. 2939","children":[],"tail":"; renumbered § 2725 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(2), 1563(c)(3), formerly § 1562(c)(3), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 265, 911.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b0bcbf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b0bcc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6b0bcc1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–23"},"text":"Section 300gg–23 of this title","children":[],"tail":", referred to in subsec. (f), was in the original section “2723”, and was translated as meaning section 2724 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", to reflect the probable intent of Congress and the renumbering of section 2723 as 2724 by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(4), 1563(c)(14)(B), formerly § 1562(c)(14)(B), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 269, 911."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6b0bcc2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–4"},"text":"section 300gg–4 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6b0bcc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/A"},"text":"Pub. L. 111–148, § 1563(c)(3)(A)","children":[],"tail":", formerly § 1562(c)(3)(A), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “group or individual health insurance coverage” for “group health insurance coverage” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/B/i"},"text":"Pub. L. 111–148, § 1563(c)(3)(B)(i)","children":[],"tail":", formerly § 1562(c)(3)(B)(i), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “group or individual health insurance coverage” for “group health insurance coverage in connection with a group health plan” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/B/ii"},"text":"Pub. L. 111–148, § 1563(c)(3)(B)(ii)","children":[],"tail":", formerly § 1562(c)(3)(B)(ii), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “plan or coverage” for “plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/C/i"},"text":"Pub. L. 111–148, § 1563(c)(3)(C)(i)","children":[],"tail":", formerly § 1562(c)(3)(C)(i), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “health insurance issuer offering group or individual health insurance coverage” for “group health insurance coverage offered by a health insurance issuer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/C/ii"},"text":"Pub. L. 111–148, § 1563(c)(3)(C)(ii)","children":[],"tail":", formerly § 1562(c)(3)(C)(ii), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “health insurance issuer” for “issuer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/3/D"},"text":"Pub. L. 111–148, § 1563(c)(3)(D)","children":[],"tail":", formerly § 1562(c)(3)(D), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “group or individual health insurance coverage” for “group health insurance coverage”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6b0bcc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6b0bcc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s604/c"},"text":"Pub. L. 104–204, title VI, § 604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2941"},"text":"110 Stat. 2941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/204/tVI/s604/c"},"text":"“The amendments made by this section [enacting this section and amending sections 300gg–21 and 300gg–23 of this title] shall apply with respect to group health plans for plan years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6b0bcc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s602"},"text":"Pub. L. 104–204, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2935"},"text":"110 Stat. 2935","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/204/tVI/s602"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of post-delivery hospital stay should be based on the unique characteristics of each mother and her newborn child, taking into consideration the health of the mother, the health and stability of the newborn, the ability and confidence of the mother and the father to care for their newborn, the adequacy of support systems at home, and the access of the mother and her newborn to appropriate follow-up health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timing of the discharge of a mother and her newborn child from the hospital should be made by the attending provider in consultation with the mother.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
