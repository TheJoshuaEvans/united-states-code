{"tag":"section","attrib":{"id":"idbc094bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2210e"},"text":"§ 2210e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design basis threat rulemaking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc094bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc094bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after the date of enactment of this section, initiate a rulemaking proceeding, including notice and opportunity for public comment, to be completed not later than 18 months after that date, to revise the design basis threats of the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 18 months after the date of enactment of this section, complete any ongoing rulemaking to revise the design basis threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc094c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When conducting its rulemaking, the Commission shall consider the following, but not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc094c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the events of ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of physical, cyber, biochemical, and other terrorist threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for attack on facilities by multiple coordinated teams of a large number of individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for assistance in an attack from several persons employed at the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for suicide attacks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for water-based and air-based threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential use of explosive devices of considerable size and other modern weaponry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for attacks by persons with a sophisticated knowledge of facility operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for fires, especially fires of long duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for attacks on spent fuel shipments by multiple coordinated teams of a large number of individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of planning to protect the public health and safety at and around nuclear facilities, as appropriate, in the event of a terrorist attack against a nuclear facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210e/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for theft and diversion of nuclear materials from such facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc0bbd0e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 170E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s651/a/1"},"text":"Pub. L. 109–58, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/799"},"text":"119 Stat. 799","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc0bbd0f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc0bbd10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc0bbd11-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
