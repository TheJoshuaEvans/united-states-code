:"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “requirements” for “requirement” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/1"},"text":"Pub. L. 101–239, § 6503(b)(1)","children":[],"tail":", substituted “Application for block grant funds” for “Description of intended expenditures and statement of assurances” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/2"},"text":"Pub. L. 101–239, § 6503(b)(2)","children":[],"tail":", (3), inserted “(a)” before “In order to be entitled” and “an application (in a standardized form specified by the Secretary) that” after “must prepare and transmit to the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/4"},"text":"Pub. L. 101–239, § 6503(b)(4)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “a report describing the intended use of payments the State is to receive under this subchapter for the fiscal year, including (A) a description of those populations, areas, and localities in the State which the State has identified as needing maternal and child health services, (B) a statement of goals and objectives for meeting those needs, (C) information on the types of services to be provided and the categories or characteristics of individuals to be served, and (D) data the State intends to collect respecting activities conducted with such payments; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/4"},"text":"Pub. L. 101–239, § 6503(b)(4)","children":[],"tail":", added pars. (2) to (4) and redesignated former par. (2) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/A"},"text":"Pub. L. 101–239, § 6503(b)(5)(A)","children":[],"tail":", (6), in introductory provisions, substituted “provides” for “a statement of assurances that represents to the Secretary”, and in concluding provisions, substituted “The application shall be developed by, or in consultation with, the State maternal and child health agency and shall be made public within the State in such manner as to facilitate comment from any person (including any Federal or other public agency) during its development and after its transmittal.” for “The description and statement shall be made public within the State in such manner as to facilitate comment from any person (including any Federal or other public agency) during development of the description and statement and after its transmittal. The description and statement shall be revised (consistent with this section) throughout the year as may be necessary to reflect substantial changes in any element of such description or statement, and any revision shall be subject to the requirements of the preceding sentence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/4"},"text":"Pub. L. 101–239, § 6503(b)(4)","children":[],"tail":", redesignated former par. (2) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/B"},"text":"Pub. L. 101–239, § 6503(b)(5)(B)","children":[],"tail":", substituted “will establish” for “will provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/C"},"text":"Pub. L. 101–239, § 6503(b)(5)(C)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “a substantial proportion of the sums expended by the State for carrying out this subchapter for the provision of health services to mothers and children, with special consideration given (where appropriate) to the continuation of the funding of special projects in the State previously funded under this subchapter (as in effect before "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":"), and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6501/b"},"text":"Pub. L. 101–239, § 6501(b)","children":[],"tail":", substituted “subparagraphs (A) through (D) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a/1"},"text":"section 701(a)(1) of this title","children":[],"tail":"” for “paragraphs (1) through (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a"},"text":"section 701(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/D"},"text":"Pub. L. 101–239, § 6503(b)(5)(D)","children":[],"tail":", (E), added subpar. (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/F/i"},"text":"Pub. L. 101–239, § 6503(b)(5)(F)(i)","children":[],"tail":", struck out “participate” after “under this subchapter will” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/E"},"text":"Pub. L. 101–239, § 6503(b)(5)(E)","children":[],"tail":", redesignated subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(F)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/F/ii"},"text":"Pub. L. 101–239, § 6503(b)(5)(F)(ii)","children":[],"tail":"–(iv), inserted “participate” before “in the coordination” and substituted “diagnostic” for “diagnosis” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/a/4/B"},"text":"section 1396d(a)(4)(B) of this title","children":[],"tail":" (including the establishment of periodicity and content standards for early and periodic screening, diagnostic, and treatment services)” for “subchapter XIX of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(F)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/F/iv"},"text":"Pub. L. 101–239, § 6503(b)(5)(F)(iv)","children":[],"tail":", inserted “participate” before “in the arrangement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(F)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/F/iv"},"text":"Pub. L. 101–239, § 6503(b)(5)(F)(iv)","children":[],"tail":", inserted “participate” before “in the coordination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(F)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/5/F/v"},"text":"Pub. L. 101–239, § 6503(b)(5)(F)(v)","children":[],"tail":"–(vii), added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/b/7"},"text":"Pub. L. 101–239, § 6503(b)(7)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s137/b/3"},"text":"Pub. L. 97–248, § 137(b)(3)","children":[],"tail":", substituted “section 701(b)(1)” for “section 702(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/s137/b/4"},"text":"Pub. L. 97–248, § 137(b)(4)","children":[],"tail":", substituted “any charges are imposed” for “the State imposes any charges”."}],"tail":"\n"}],"tail":"\n"},{"ta