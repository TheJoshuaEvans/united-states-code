{"tag":"section","attrib":{"id":"idb7edd09b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705"},"text":null,"children":[{"tag":"num","attrib":{"value":"705"},"text":"§ 705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for block grant funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7edd09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to be entitled to payments for allotments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s702"},"text":"section 702 of this title","children":[],"tail":" for a fiscal year, a State must prepare and transmit to the Secretary an application (in a standardized form specified by the Secretary) that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7edd09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains a statewide needs assessment (to be conducted every 5 years) that shall identify (consistent with the health status goals and national health objectives referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a"},"text":"section 701(a) of this title","children":[],"tail":") the need for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7edd09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventive and primary care services for pregnant women, mothers, and infants up to age one;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventive and primary care services for children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for children with special health care needs (as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a/1/D"},"text":"section 701(a)(1)(D) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7edd0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes for each fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7edd0a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for meeting the needs identified by the statewide needs assessment under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the funds allotted to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/c"},"text":"section 702(c) of this title","children":[],"tail":" will be used for the provision and coordination of services to carry out such plan that shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb7edd0a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (3), a statement of the goals and objectives consistent with the health status goals and national health objectives referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a"},"text":"section 701(a) of this title","children":[],"tail":" for meeting the needs specified in the State plan described in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the areas and localities in the State in which services are to be provided and coordinated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the types of services to be provided and the categories or characteristics of individuals to be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information the State will collect in order to prepare reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s706/a"},"text":"section 706(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7edd0a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided under subsection (b), provides that the State will use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7edd0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 percent of such payment amounts for preventive and primary care services for children, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 percent of such payment amounts for services for children with special health care needs (as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a/1/D"},"text":"section 701(a)(1)(D) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7edd0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that a State receiving funds for maternal and child health services under this subchapter shall maintain the level of funds being provided solely by such State for maternal and child health programs at a level at least equal to the level that such State provided for such programs in fiscal year 1989; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7edd0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7edd0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will establish a fair method (as determined by the State) for allocating funds allotted to the State under this subchapter among such individuals, areas, and localities identified under paragraph (1)(A) as needing maternal and child health services, and the State will identify and apply guidelines for the appropriate frequency and content of, and appropriate referral and followup with respect to, health care assessments and services financially assisted by the State under this subchapter and methods for assuring quality assessments and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds allotted to the State under this subchapter will only be used, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s708"},"text":"section 708 of this title","children":[],"tail":", to carry out the purposes of this subchapter or to continue activities previously conducted under the consolidated health programs (described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/b/1"},"text":"section 701(b)(1) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State will use—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7edd0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special consideration (where appropriate) for the continuation of the funding of special projects in the State previously funded under this subchapter (as in effect before ","children":[{"tag":"date","attrib":{"date":"1981-08-31"},"text":"August 31, 1981","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable proportion (based upon the State’s previous use of funds under this subchapter) of such sums to carry out the purposes described in subparagraphs (A) through (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/a/1"},"text":"section 701(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if any charges are imposed for the provision of health services assisted by the State under this subchapter, such charges (i) will be pursuant to a public schedule of charges, (ii) will not be imposed with respect to services provided to low income mothers or children, and (iii) will be adjusted to reflect the income, resources, and family size of the individual provided the services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agency (or agencies) administering the State’s program under this subchapter will provide for a toll-free telephone number (and other appropriate methods) for the use of parents to access information about health care providers and practitioners who provide health care services under this subchapter and subchapter XIX and about other relevant health and health-related providers and practitioners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State agency (or agencies) administering the State’s program under this subchapter will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7edd0b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the coordination of activities between such program and the early and periodic screening, diagnostic, and treatment program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d/a/4/B"},"text":"section 1396d(a)(4)(B) of this title","children":[],"tail":" (including the establishment of periodicity and content standards for early and periodic screening, diagnostic, and treatment services), to ensure that such programs are carried out without duplication of effort,"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the arrangement and carrying out of coordination agreements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/a/11"},"text":"section 1396a(a)(11) of this title","children":[],"tail":" (relating to coordination of care and services available under this subchapter and subchapter XIX),"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the coordination of activities within the State with programs carried out under this subchapter and related Federal grant programs (including supplemental food programs for mothers, infants, and children, related education programs, and other health, developmental disability, and family planning programs), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7edd0b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/a/5/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, directly and through their providers and institutional contractors, for services to identify pregnant women and infants who are eligible for medical assistance under subparagraph (A) or (B) of section 1396a(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1) of this title and, once identified, to assist them in applying for such assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The application shall be developed by, or in consultation with, the State maternal and child health agency and shall be made public within the State in such manner as to facilitate comment from any person (including any Federal or other public agency) during its development and after its transmittal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7edd0b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may waive the requirements under subsection (a)(3) that a State’s application for a fiscal year provide for the use of funds for specific activities if for that fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7edd0ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7edd0bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of information provided in the State’s most recent annual report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s706/a/1"},"text":"section 706(a)(1) of this title","children":[],"tail":", that the State has demonstrated an extraordinary unmet need for one of the activities described in subsection (a)(3), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7edd0bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the granting of the waiver is justified and will assist in carrying out the purposes of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7edd0bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State provides assurances to the Secretary that the State will provide for the use of some amounts paid to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s703"},"text":"section 703 of this title","children":[],"tail":" for the activities described in subparagraphs (A) and (B) of subsection (a)(3) and specifies the percentages to be substituted in each of such subparagraphs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7edd0be-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 505, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2192/a"},"text":"Pub. L. 97–35, title XXI, § 2192(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/822"},"text":"95 Stat. 822","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tI/s137/b/3"},"text":"Pub. L. 97–248, title I, § 137(b)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/377"},"text":"96 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI"},"text":"Pub. L. 101–239, title VI","children":[],"tail":", §§ 6501(b), 6503(b), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2275"},"text":"103 Stat. 2275","children":[],"tail":", 2276; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4755/c/3"},"text":"