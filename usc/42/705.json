9(c), "},{"tag":"ref","attrib":{"href":"/us/stat/86/1389"},"text":"86 Stat. 1389","children":[],"tail":", 1411, 1417; "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/53/s4/a/3"},"text":"Pub. L. 93–53, § 4(a)(3)","children":[],"tail":"–(5), "},{"tag":"ref","attrib":{"href":"/us/stat/87/135"},"text":"87 Stat. 135","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/tIX/s914/c/1"},"text":"Pub. L. 96–499, title IX, § 914(c)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2622"},"text":"94 Stat. 2622","children":[],"tail":", related to contents of State plans, approval by Secretary, etc., prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2192/a"},"text":"section 2192(a) of Pub. L. 97–35","children":[],"tail":". For effective date, savings, and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2194"},"text":"section 2194 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"section 701 of this title","children":[],"tail":". For effective dates of prior amendments, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/s304/b"},"text":"section 304(b) of Pub. L. 90–248","children":[],"tail":", sections 232(c) and 239(d) of "},{"tag":"ref","attrib":{"href":"/us/pl/92/603"},"text":"Pub. L. 92–603","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/s914/c/2"},"text":"section 914(c)(2) of Pub. L. 96–499","children":[],"tail":" as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s137/c/2"},"text":"section 137(c)(2) of Pub. L. 97–248","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 705, acts ","children":[{"tag":"ref","attrib":{"hr