{"tag":"section","attrib":{"id":"idb5275e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274l"},"text":null,"children":[{"tag":"num","attrib":{"value":"274l"},"text":"§ 274l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stem cell therapeutic outcomes database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5275e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by contract establish and maintain a scientific database of information relating to patients who have been recipients of a stem cell therapeutics product (including bone marrow, cord blood, or other such product) from a donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5275e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The outcomes database shall include information in a standardized electronic format with respect to patients described in subsection (a), diagnosis, transplant procedures, results, long-term follow-up, and such other information as the Secretary determines to be appropriate, to conduct an ongoing evaluation of the scientific and clinical status of transplantation involving recipients of a stem cell therapeutics product from a donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5275e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on patient outcomes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require the entity awarded a contract under this section to submit to the Secretary an annual report concerning patient outcomes with respect to each transplant center, based on data collected and maintained by the entity pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5275e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly available data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The outcomes database shall make relevant scientific information not containing individually identifiable information available to the public in the form of summaries and data sets to encourage medical research and to provide information to transplant programs, physicians, patients, entities awarded a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274k"},"text":"section 274k of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" donor registries, and cord blood banks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5275e08-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 379A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/196/s3"},"text":"Pub. L. 105–196, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/635"},"text":"112 Stat. 635","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/129/s3/b"},"text":"Pub. L. 109–129, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-20"},"text":"Dec. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2561"},"text":"119 Stat. 2561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5275e09-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5275e0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5275e0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 274","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s379A"},"text":"act July 1, 1944, ch. 373, title III, § 379A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/616/tI/s101/a/2"},"text":"Pub. L. 101–616, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3282"},"text":"104 Stat. 3282","children":[],"tail":", related to study by General Accounting Office, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/196"},"text":"Pub. L. 105–196","children":[],"tail":", §§ 3, 7, "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/635"},"text":"112 Stat. 635","children":[],"tail":", 637, effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5275e0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/129"},"text":"Pub. L. 109–129","children":[],"tail":", amended section generally, substituting provisions relating to the stem cell therapeutic outcomes database for provisions relating to the bone marrow scientific registry."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5275e0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5275e0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/196/s7"},"text":"section 7 of Pub. L. 105–196","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s274k"},"text":"section 274k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
