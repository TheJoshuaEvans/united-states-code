{"tag":"section","attrib":{"id":"idb505f2ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d"},"text":null,"children":[{"tag":"num","attrib":{"value":"256d"},"text":"§ 256d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breast and cervical cancer information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb505f2ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving grants, cooperative agreements, or contracts under this chapter, each of the entities specified in subsection (c) shall, to the extent determined to be appropriate by the Secretary, make available information concerning breast and cervical cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505f2f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), an entity specified in subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505f2f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make the information involved available to such individuals as the entity determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, as appropriate, provide information under subsection (a) on the need for self-examination of the breasts and on the skills for such self-examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide information under subsection (a) in the language and cultural context most appropriate to the individuals to whom the information is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall refer such clients as the entities determine appropriate for breast and cervical cancer screening, treatment, or other appropriate services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505f2f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entities specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505f2f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entities receiving assistance under section 247b–7 ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (relating to tuberculosis)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entities receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247c"},"text":"section 247c of this title","children":[],"tail":" (relating to sexually transmitted diseases)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Migrant health centers receiving assistance under section 254b ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community health centers receiving assistance under section 254c ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505f2fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256d/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entities receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/h"},"tex