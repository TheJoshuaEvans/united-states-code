{"tag":"section","attrib":{"id":"idb42cf879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s216"},"text":null,"children":[{"tag":"num","attrib":{"value":"216"},"text":"§ 216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb42cf87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription by President: appointments, retirement, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall from time to time prescribe regulations with respect to the appointment, promotion, retirement, termination of commission, titles, pay, uniforms, allowances (including increased allowances for foreign service), and discipline of the commissioned corps of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42cf87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation by Surgeon General; administration of Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Surgeon General, with the approval of the Secretary, unless specifically otherwise provided, shall promulgate all other regulations necessary to the administration of the Service, including regulations with respect to uniforms for employees, and regulations with respect to the custody, use, and preservation of the records, papers, and property of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42cf87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference to school of medicine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No regulation relating to qualifications for appointment of medical officers or employees shall give preference to any school of medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb42cf87d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 215, "},{"tag":"ref","attrib":{"href":"/us/stat/58/690"},"text":"58 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681"},"text":"Oct. 12, 1949, ch. 681","children":[],"tail":", title V, § 521(f), "},{"tag":"ref","attrib":{"href":"/us/stat/63/835"},"text":"63 Stat. 835","children":[],"tail":"; 1953 Reorg. Plan No. 1, §§ 5, 8, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb42cf87e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb42cf87f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb42cf880-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Subsec. (b). Act ","children":[{"tag":"date","attrib