{"tag":"section","attrib":{"id":"idbfb73a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13262"},"text":null,"children":[{"tag":"num","attrib":{"value":"13262"},"text":"§ 13262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb73a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13261"},"text":"section 13261 of this title","children":[],"tail":" shall be subject to a civil penalty of not more than $5,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Willful violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever willfully violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13261"},"text":"section 13261 of this title","children":[],"tail":" shall be fined not more than $10,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowing and willful violation following prior violation and penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":