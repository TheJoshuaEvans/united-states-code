{"tag":"section","attrib":{"id":"idbbc1bbc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000e–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000e–11"},"text":"§ 2000e–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans’ special rights or preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this subchapter shall be construed to repeal or modify any Federal, State, territorial, or local law creating special rights or preference for veterans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbc1bbc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tVII/s712"},"text":"Pub. L. 88–352, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/265"},"text":"78 Stat. 265","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
