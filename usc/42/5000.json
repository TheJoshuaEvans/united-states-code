{"tag":"section","attrib":{"id":"idbcee5564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000"},"text":null,"children":[{"tag":"num","attrib":{"value":"5000"},"text":"§ 5000.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcee5565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for senior service to meet unmet local, State, and national needs in the areas of education, public safety, emergency and disaster preparedness, relief, and recovery, health and human needs, and the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcee5566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the National Senior Service Corps, comprised of the Retired and Senior Volunteer Program, the Foster Grandparent Program, and the Senior Companion Program, and demonstration and other programs, to empower people 55 years of age or older to contribute to their communities through service, enhance the lives of those who serve and those whom they serve, and provide communities with valuable services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcee5567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for people 55 years of age or older, through the Retired and Senior Volunteer Program, to share their knowledge, experiences, abilities, and skills for the betterment of their communities and themselves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcee5568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for low-income people 55 years of age or older, through the Foster Grandparents Program, to have a positive impact on the lives of children in need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcee5569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5000/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for low-income people 55 years of age or older, through the Senior Companion Program, to provide support services and companionship to other older individuals through volunteer service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcee556a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s200"},"text":"Pub. L. 93–113, title II, § 200","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tV/s501"},"text":"Pub. L. 101–204, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1815"},"text":"103 Stat. 1815","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII"},"text":"Pub. L. 103–82, title III","children":[],"tail":", §§ 341(b)(1), 342(b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/904"},"text":"107 Stat. 904","children":[],"tail":"; "},{"tag":"ref","attri