{"tag":"section","attrib":{"id":"idbf82bc64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626"},"text":null,"children":[{"tag":"num","attrib":{"value":"12626"},"text":"§ 12626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this division:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Board of Directors of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Campus director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “campus director”, with respect to a Corps campus, means the head of the campus under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12615/d"},"text":"section 12615(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corps” means the National Civilian Community Corps required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12615"},"text":"section 12615 of this title","children":[],"tail":" as part of the National Civilian Community Corps Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps campus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corps campus” means the facility or central location established as the operational headquarters and boarding place for particular Corps units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Corps members” means persons receiving training and participating in projects under the National Civilian Community Corps Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the National Civilian Community Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the National Civilian Community Corps Program established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12612"},"text":"section 12612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service-learning","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “service-learning”, with respect to Corps members, means a method—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf82bc6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which Corps members learn and develop through active participation in thoughtfully organized service experiences that meet actual community needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bc6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides structured time for a Corps member to think, talk, or write about what the Corps member did and saw during an actual service activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bc70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides Corps members with opportunities to use newly acquired skills and knowledge in real life situations in their own communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bc71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that helps to foster the development of a sense of caring for others, good citizenship, and civic responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12626/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit” means a unit of the Corps referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12615/c"},"text":"section 12615(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bc73-3a70-11f1-ae07-e4213