4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/A"},"text":"Pub. L. 111–13, § 1516(2)(A)","children":[],"tail":", (C), added pars. (2) to (4) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Corps","children":[],"tail":".—The terms ‘Civilian Community Corps’ and ‘Corps’ mean the Civilian Community Corps required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12615"},"text":"section 12615 of this title","children":[],"tail":" as part of the Civilian Community Corps Demonstration Program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Corps camp","children":[],"tail":".—The term ‘Corps camp’ means the facility or central location established as the operational headquarters and boarding place for particular Corps units.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former par. (4) redesignated (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/B"},"text":"Pub. L. 111–13, § 1516(2)(B)","children":[],"tail":", (D), redesignated par. (4) as (5) and substituted “National Civilian Community Corps Program” for “Civilian Community Corps Demonstration Program”. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/B"},"text":"Pub. L. 111–13, § 1516(2)(B)","children":[],"tail":", (E), redesignated par. (5) as (6) and inserted “National” before “Civilian Community Corps”. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/B"},"text":"Pub. L. 111–13, § 1516(2)(B)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/F"},"text":"Pub. L. 111–13, § 1516(2)(F)","children":[],"tail":", which directed substitution of “The term ‘Program’ means the National Civilian Community Corps Program” for “ ‘The terms’ and all that follows through ‘Demonstration Program’ ”, was executed by making the substitution for “The terms ‘Civilian Community Corps Demonstration Program’ and ‘Program’ mean the Civilian Community Corps Demonstration Program” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/B"},"text":"Pub. L. 111–13, § 1516(2)(B)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/G"},"text":"Pub. L. 111–13, § 1516(2)(G)","children":[],"tail":", substituted “Service-learning” for “Service learning” in heading and “service-learning” for “service learning” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1516/2/A"},"text":"Pub. L. 111–13, § 1516(2)(A)","children":[],"tail":", (B), redesignated par. (8) as (9) and struck out former par. (9). Text read as follows: “The term ‘superintendent’, with respect to a Corps camp, means the head of the camp under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12615/d"},"text":"section 12615(d) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “section 1001” for “section 1141(a)”."}],"t