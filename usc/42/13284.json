{"tag":"section","attrib":{"id":"idbfb9aa84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13284"},"text":null,"children":[{"tag":"num","attrib":{"value":"13284"},"text":"§ 13284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aa85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13284/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require at least 50 percent of the costs directly and specifically related to any project under this part to be from non-Federal sources. Such share may be in the form of cash, personnel, services, equipment, and other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13284/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reduce the amount of costs required to be provided by non-Federal sources under subsection (a) if the Secretary determines that the reduction is necessary and appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aa87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13284/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the technological risks involved in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13284/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to meet the objectives of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aa89-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s614"},"text":"Pub. L. 102–486, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2903"},"text":"106 Stat. 2903","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
