{"tag":"section","attrib":{"id":"idb610f9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–11"},"text":"§ 300b–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse of newborn screening information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb610f9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration (referred to in this part as the “Administrator”), in consultation with the Director of the Centers for Disease Control and Prevention and the Director of the National Institutes of Health, shall establish and maintain a central clearinghouse of current educational and family support and services information, materials, resources, research, and data on newborn screening to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb610f9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable parents and family members of newborns, health professionals, industry representatives, and other members of the public to increase their awareness, knowledge, and understanding of newborn screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness, knowledge, and understanding of newborn diseases and screening services for expectant individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain current information on quality indicators to measure performance of newborn screening, such as false-positive rates and other quality indicators as determined by the Advisory Committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300b–10"},"text":"section 300b–10 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain current information on the number of conditions for which screening is conducted in each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate available evidence-based guidelines related to diagnosis, counseling, and treatment with respect to conditions detected by newborn screening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb610f9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Administrator, shall ensure that the clearinghouse described under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb610f9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available on the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an interactive forum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is updated on a regular basis, but not less than quarterly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb610f9c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" links to Government-sponsored, non-profit, and other Internet websites of laboratories that have demonstrated expertise in newborn screening that supply research-based information on newborn screening tests currently available throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610f9c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about newborn conditions and screening services available in each State from laboratories certified under subpart 2 of part F of subchapter II, including information about supplemental screening that is available but not required, in the State where the infant is born;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610f9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current research on both treatable and not-yet treatable conditions for which newborn screening tests are available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610f9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Federal funding for newborn and child screening for heritable disorders including grants authorized under the Newborn Screening Saves Lives Reauthorization Act of 2014; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610f9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant information as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb610f9cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities under this section, the Secretary shall ensure that such activities minimize duplication and supplement, not supplant, existing information sharing efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb610f9ce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1112, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/204/s5"},"text":"Pub. L. 110–204, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-24"},"text":"Apr. 24, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/708"},"text":"122 Stat. 708","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/237/s1/a/4"},"text":"Pub. L. 110–237, § 1(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-27"},"text":"May 27, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1557"},"text":"122 Stat. 1557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5"},"text":"Pub. L. 113–240, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2854"},"text":"128 Stat. 2854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb610f9cf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb610f9d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb610f9d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Newborn Screening Saves Lives Reauthorization Act of 2014, referred to in subsec. (b)(4)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240"},"text":"Pub. L. 113–240","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2851"},"text":"128 Stat. 2851","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2014 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb610f9d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5/1/B/i"},"text":"Pub. L. 113–240, § 5(1)(B)(i)","children":[],"tail":", substituted “information” for “data”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5/1/A"},"text":"Pub. L. 113–240, § 5(1)(A)","children":[],"tail":", (B)(ii), (C), added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5/2"},"text":"Pub. L. 113–240, § 5(2)","children":[],"tail":", substituted “Newborn Screening Saves Lives Reauthorization Act of 2014” for “Newborn Screening Saves Lives Act of 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5/3"},"text":"Pub. L. 113–240, § 5(3)","children":[],"tail":", substituted “carrying out activities” for “developing the clearinghouse” and “activities minimize duplication and supplement, not supplant” for “clearinghouse minimizes duplication and supplements, not supplants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s5/4"},"text":"Pub. L. 113–240, § 5(4)","children":[],"tail":", struck out subsec. (d). Text read as follows: “There are authorized to be appropriated to carry out this section, $2,500,000 for fiscal year 2009, $2,531,250 for fiscal year 2010, $2,562,500 for fiscal year 2011, $2,593,750 for fiscal year 2012, and $2,625,000 for fiscal year 2013.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/237/s1/a/4/A"},"text":"Pub. L. 110–237, § 1(a)(4)(A)","children":[],"tail":", substituted “2008” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/237/s1/a/4/B"},"text":"Pub. L. 110–237, § 1(a)(4)(B)","children":[],"tail":", substituted “2009, $2,531,250 for fiscal year 2010, $2,562,500 for fiscal year 2011, $2,593,750 for fiscal year 2012, and $2,625,000 for fiscal year 2013.” for “2008, $2,531,250 for fiscal year 2009, $2,562,500 for fiscal year 2010, $2,593,750 for fiscal year 2011, and $2,625,000 for fiscal year 2012.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
