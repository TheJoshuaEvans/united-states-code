{"tag":"section","attrib":{"id":"idb8080f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1010a"},"text":"§ 1010a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional Federal administration of State recognition payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8080f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security may enter into an agreement with any State (or political subdivision thereof) that provides cash payments on a regular basis to individuals entitled to benefits under this subchapter under which the Commissioner of Social Security shall make such payments on behalf of such State (or subdivision).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8080f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8080f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such agreement shall include such terms as the Commissioner of Social Security finds necessary to achieve efficient and effective administration of both this subchapter and the State program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such agreement shall provide for the State to pay the Commissioner of Social Security, at such times and in such installments as the parties may specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8080f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the expenditures made by the Commissioner of Social Security pursuant to such agreement as payments to individuals on behalf of such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8080f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administration fee to reimburse the administrative expenses incurred by the Commissioner of Social Security in making payments to individuals on behalf of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8080f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1010a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special disposition of administration fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Administration fees, upon collection, shall be credited to a special fund established in the Treasury of the United States for State recognition payments for certain World War II veterans. The amounts so credited, to the extent and in the amounts provided in advance in appropriations Acts, shall be available to defray expenses incurred in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8080f9a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 810A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s518/a"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 518(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–73.)"}],"tail":"\n"}],"tail":null}
