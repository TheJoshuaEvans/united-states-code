{"tag":"section","attrib":{"id":"idb653cfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r"},"text":null,"children":[{"tag":"num","attrib":{"value":"300r"},"text":"§ 300r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for construction or modernization proj­ects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb653cfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority; objectives; eligible grantees; maximum amounts; authorization of appropriations; availability of unobligated funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb653cfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb653cfb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may make grants for construction or modernization projects designed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb653cfba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate or prevent in medical facilities imminent safety hazards as defined by Federal, State, or local fire, building, or life safety codes or regulations, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb653cfbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid noncompliance by medical facilities with State or voluntary licensure or accreditation standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb653cfbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A grant under subparagraph (A) may only be made to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb653cfbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision of a State, including any city, town, county, borough, hospital district authority, or public or quasi-public corporation, for any medical facility owned or operated by the State or political subdivision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb653cfbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a nonprofit private entity for any medical facility owned or operated by the entity but only if the Secretary determines—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb653cfbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of community service provided by the facility and the proportion of its patients who are unable to pay for services rendered in the facility is similar to such level and proportion in a medical facility of a State or political subdivision, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb653cfc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that without a grant under subparagraph (A) there would be a disruption of the provision of health care to low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb653cfc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant under paragraph (1) may not exceed 75 per centum of the cost of the project for which the grant is made unless the project is located in an area determined by the Secretary to be an urban or rural poverty area, in which case the grant may cover up to 100 per centum of such costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb653cfc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated for grants under paragraph (1) $40,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", $50,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and $50,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":". Funds available for obligation under this subsection (as in effect before "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"October 4, 1979","children":[],"tail":") in the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", shall remain available for obligation under this subsection in the succeeding fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb653cfc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects for medically underserved populations; eligible grantees; maximum amounts; authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb653cfc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants to public and nonprofit private entities for projects for (A) construction or modernization of outpatient medical facilities which are located apart from hospitals and which will provide services for medically underserved populations, and (B) conversion of existing facilities into outpatient medical facilities or facilities for long-term care to provide services for such populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb653cfc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any grant under paragraph (1) may not exceed 80 per centum of the cost of the project for which the grant is made unless the project is located in an area determined by the Secretary to be an urban or rural poverty area, in which case the grant may cover up to 100 per centum of such costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb653cfc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated for grants under paragraph (1) $15,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and $15,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb653cfc7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1610, formerly § 1625, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s4"},"text":"Pub. L. 93–641, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2268"},"text":"88 Stat. 2268","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tI/s103/b"},"text":"Pub. L. 95–83, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/383"},"text":"91 Stat. 383","children":[],"tail":"; renumbered § 1610 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tII"},"text":"Pub. L. 96–79, title II","children":[],"tail":", §§ 201(c), 203(b), "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/631"},"text":"93 Stat. 631","children":[],"tail":", 635.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb653cfc8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb653cfc9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb653cfca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1610 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXVI"},"text":"act July 1, 1944, ch. 373, title XVI","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s4"},"text":"Pub. L. 93–641, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2262"},"text":"88 Stat. 2262","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tI/s106/w"},"text":"Pub. L. 95–83, title I, § 106(w)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/385"},"text":"91 Stat. 385","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300p"},"text":"section 300p of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tII/s201/a"},"text":"Pub. L. 96–79, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/630"},"text":"93 Stat. 630","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb653cfcb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/79/s201/c"},"text":"Pub. L. 96–79, § 201(c)","children":[],"tail":", incorporated existing provisions in par. (1); inserted in subpar. (A) in cls. (i) and (ii) the phrases “in medical facilities” and “by medical facilities”; substituted in subpar. (B)(i) “for any medical facility owned or operated by the State or political subdivision” for “for a project described in the preceding sentence for any medical facility owned or operated by it”; added cl. (a)(1)(B)(ii); redesignated former subsec. (c) as par. (2); and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/79/s201/c"},"text":"Pub. L. 96–79, § 201(c)","children":[],"tail":", inserted provisions respecting projects for medically underserved populations and struck out provisions respecting criteria for approval of applications under former section 300"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–3 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/79/s201/c"},"text":"Pub. L. 96–79, § 201(c)","children":[],"tail":", redesignated subsec. (c) as par. (2) of subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/79/s201/c"},"text":"Pub. L. 96–79, § 201(c)","children":[],"tail":", struck out subsec. (d) which related to provisions making available 22 per centum of sums appropriated under former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300p–3"},"text":"section 300p–3 of this title","children":[],"tail":" for subsec. (a) grants, including an additional appropriations authorization of $67,500,000 for such grants for fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/83"},"text":"Pub. L. 95–83","children":[],"tail":" authorized additional grant appropriations of $67,500,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb653cfcc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb653cfcd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/79"},"text":"Pub. L. 96–79","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/s204"},"text":"section 204 of Pub. L. 96–79","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300q"},"text":"section 300q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
