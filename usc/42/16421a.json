{"tag":"section","attrib":{"id":"idc0144e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16421a"},"text":"§ 16421a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western Area Power Administration borrowing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Western Area Power Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, subject to paragraphs (2) through (5)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Western Area Power Administration may borrow funds from the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall, without further appropriation and without fiscal year limitation, loan to the Western Area Power Administration, on such terms as may be fixed by the Administrator and the Secretary, such sums (not to exceed, in the aggregate (including deferred interest), $3,250,000,000 in outstanding repayable balances at any one time) as, in the judgment of the Administrator, are from time to time required for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0144e0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructing, financing, facilitating, planning, operating, maintaining, or studying construction of new or upgraded electric power transmission lines and related facilities with at least one terminus within the area served by the Western Area Power Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0144e0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering or facilitating the delivery of power generated by renewable energy resources constructed or reasonably expected to be constructed after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of interest to be charged in connection with any loan made pursuant to this subsection shall be fixed by the Secretary, taking into consideration market yields on outstanding marketable obligations of the United States of comparable maturities as of the date of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refinancing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Western Area Power Administration may refinance loans taken pursuant to this section within the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may permit other entities to participate in the financing, construction and ownership projects financed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review of disbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective upon ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Administrator shall have the authority to have utilized $1,750,000,000 at any one time. If the Administrator seeks to borrow funds above $1,750,000,000, the funds will be disbursed unless there is enacted, within 90 calendar days of the first such request, a joint resolution that rescinds the remainder of the balance of the borrowing authority provided in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission line and related facility projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For repayment purposes, each transmission line and related facility project in which the Western Area Power Administration participates pursuant to this section shall be treated as separate and distinct from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each other such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other Western Area Power Administration power and transmission facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Western Area Power Administration shall apply the proceeds from the use of the transmission capacity from an individual project under this section to the repayment of the principal and interest of the loan from the Treasury attributable to that project, after reserving such funds as the Western Area Power Administration determines are necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay for any ancillary services that are provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the costs of operating and maintaining the new project from which the revenues are derived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of revenue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Revenue from the use of projects under this section shall be the only source of revenue for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayment of the associated loan for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of expenses for ancillary services and operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section confers on the Administrator any additional authority or obligation to provide ancillary services to users of transmission facilities developed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Revenue from ancillary services provided by existing Federal power systems to users of transmission projects funded pursuant to this section shall be treated as revenue to the existing power system that provided the ancillary services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each project in which the Western Area Power Administration participates pursuant to this section, the Administrator shall certify, prior to committing funds for any such project, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will not adversely impact system reliability or operations, or other statutory obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is reasonable to expect that the proceeds from the project shall be adequate to make repayment of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forgiveness of balances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at the end of the useful life of a project, there is a remaining balance owed to the Treasury under this section, the balance shall be forgiven.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unconstructed projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds expended to study projects that are considered pursuant to this section but that are not constructed shall be forgiven.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall notify the Secretary of such amounts as are to be forgiven under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public processes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies and practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to requesting any loans under this section, the Administrator shall use a public process to develop practices and policies that implement the authority granted by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16421a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the course of selecting potential projects to be funded under this section, the Administrator shall seek Requests For Interest from entities interested in identifying potential projects through one or more notices published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144e2a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/381/tIII/s301"},"text":"Pub. L. 98–381, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tIV/s402"},"text":"Pub. L. 111–5, div. A, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/141"},"text":"123 Stat. 141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0144e2b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0144e2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0144e2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Hoover Power Plant Act of 1984, and not as part of the Electricity Modernization Act of 2005, which comprises this subchapter, or the Energy Policy Act of 2005, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
