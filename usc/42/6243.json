{"tag":"section","attrib":{"id":"idbd73d921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6243"},"text":null,"children":[{"tag":"num","attrib":{"value":"6243"},"text":"§ 6243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd73d922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require any person to prepare and maintain such records or accounts as the Secretary, by rule, determines necessary to carry out the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd73d923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of operations of storage facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may audit the operations of any storage facility in which any petroleum product is stored or required to be stored pursuant to the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd73d924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to and inspection of records or accounts and storage facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require access to, and the right to inspect and examine, at reasonable times, (1) any records or accounts required to be prepared or maintained pursuant to subsection (a) and (2) any storage facilities subject to audit by the United States under the authority of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd73d925-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s163"},"text":"Pub. L. 94–163, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/889"},"text":"89 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd73d926-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd73d927-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd73d928-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration, wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
