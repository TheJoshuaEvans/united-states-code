{"tag":"section","attrib":{"id":"idbc31e28a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2992a–1"},"text":"§ 2992a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all personnel actions of the Administration, preference shall be given to individuals who are eligible for assistance under this subchapter. Such preference shall be implemented in the same fashion as the preference given to veterans referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108/3/C"},"text":"section 2108(3)(C) of title 5","children":[],"tail":". The Commissioner shall take such additional actions as may be necessary to promote recruitment of such individuals for employment in the Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc31e28b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s812A"},"text":"Pub. L. 88–452, title VIII, § 812A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/13"},"text":"Pub. L. 102–375, title VIII, § 822(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1299"},"text":"106 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
