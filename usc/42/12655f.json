{"tag":"section","attrib":{"id":"idbf938569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655f"},"text":"§ 12655f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and education services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf93856a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of skills","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each program agency shall assess the educational level of participants at the time of their entrance into the program, using any available records or simplified assessment means or methodology and shall, where appropriate, refer such participants for testing for specific learning disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93856b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of skills","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each program agency shall, through the programs and activities administered under this division, enhance the educational skills of participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93856c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of pre-service and in-service training and education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf93856d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each program agency shall use not less than 10 percent of the assistance made available to such agency under this division in each fiscal year to provide pre-service and in-service training and educational materials and services for participants in such a program. Program participants shall be provided with information concerning the benefits to the community that result from the activities undertaken by such participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf93856e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for academic study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program agency may enter into arrangements with academic institutions or education providers, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf93856f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local education agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4-year colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" area vocational-technical schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community based organizations;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to evaluate the basic skills of participants and to make academic study available to participants to enable such participants to upgrade literacy skills, to obtain high school diplomas or the equivalent of such diplomas, to obtain college degrees, or to enhance employable skills.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Career and educational guidance and counseling shall be provided to a participant during a period of in-service training as described in this subsection. Each graduating participant shall be provided with counseling with respect to additional study, job skills training or employment and shall be provided job placement assistance where appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for participants without high school diplomas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A program agency shall give priority to participants who have not obtained a high school diploma or the equivalent of such diploma, in providing services under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with State and local requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate State and local officials shall certify that standards and procedures with respect to the awarding of academic credit and the certification of educational attainment in programs conducted under subsection (c) are consistent with the requirements of applicable State and local law and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The standards and procedures described in paragraph (1) shall provide that an individual serving in a program that receives assistance under this division—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf938579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not a high school graduate, participate in an educational curriculum so that such individual can earn a high school diploma or the equivalent of such diploma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93857a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655f/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may arrange to receive academic credit in recognition of the education and skills obtained from service satisfactorily completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf93857b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199G"},"text":"Pub. L. 101–610, title I, § 199G","children":[],"tail":", formerly § 127, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3145"},"text":"104 Stat. 3145","children":[],"tail":"; renumbered § 199G, "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf93857c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf93857d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf93857e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12547"},"text":"section 12547 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/a"},"text":"Pub. L. 103–82, § 101(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
