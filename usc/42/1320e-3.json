{"tag":"section","attrib":{"id":"idb8628be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320e–3"},"text":"§ 1320e–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information exchange with payroll data providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8628be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of Social Security may enter into an information exchange with a payroll data provider for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" efficiently administering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monthly insurance benefits under subsections (d)(1)(B)(ii), (d)(6)(A)(ii), (d)(6)(B), (e)(1)(B)(ii), and (f)(1)(B)(ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s402"},"text":"section 402 of this title","children":[],"tail":" and subsection (a)(1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s423"},"text":"section 423 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplemental security income benefits under subchapter XVI; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing improper payments of such benefits without the need for verification by independent or collateral sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8628beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before entering into an information exchange pursuant to subsection (a), the Commissioner shall publish in the Federal Register a notice describing the information exchange and the extent to which the information received through such exchange is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant and necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8628bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately determine entitlement to, and the amount of, benefits described under subparagraph (A) of subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately determine eligibility for, and the amount of, benefits described in subparagraph (B) of such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8628bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent improper payment of such benefits; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficiently accurate, up-to-date, and complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8628bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8628bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payroll data provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payroll data provider” means payroll providers, wage verification companies, and other commercial or non-commercial entities that collect and maintain data regarding employment and wages, without regard to whether the entity provides such data for a fee or without cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8628bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320e–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “information exchange” means the automated comparison of a system of records maintained by the Commissioner of Social Security with records maintained by a payroll data provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8628bf4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1184, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tVIII/s824/a"},"text":"Pub. L. 114–74, title VIII, § 824(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/607"},"text":"129 Stat. 607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8628bf5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8628bf6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8628bf7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective one year after ","children":[{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/s824/e"},"text":"section 824(e) of Pub. L. 114–74","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s425"},"text":"section 425 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8628bf8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/74/tVIII/s824/d"},"text":"Pub. L. 114–74, title VIII, § 824(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/610"},"text":"129 Stat. 610","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/74/tVIII/s824/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":"], the Commissioner of Social Security shall prescribe by regulation procedures for implementing the Commissioner’s access to and use of information held by payroll providers, including—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines for establishing and maintaining information exchanges with payroll providers, pursuant to section 1184 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320e–3"},"text":"42 U.S.C. 1320e–3","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beneficiary authorizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced wage reporting responsibilities for individuals who authorize the Commissioner to access information held by payroll data providers through an information exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for notifying individuals in writing when they become subject to such reduced wage reporting requirements and when such reduced wage reporting requirements no longer apply to them.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
