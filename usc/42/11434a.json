{"tag":"section","attrib":{"id":"idbf50afdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11434a"},"text":"§ 11434a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf50afde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “enroll” and “enrollment” include attending classes and participating fully in school activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “homeless children and youths”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf50afe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means individuals who lack a fixed, regular, and adequate nighttime residence (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302/a/1"},"text":"section 11302(a)(1) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf50afe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf50afe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and youths who are sharing the housing of other persons due to loss of housing, economic hardship, or a similar reason; are living in motels, hotels, trailer parks, or camping grounds due to the lack of alternative adequate accommodations; are living in emergency or transitional shelters; or are abandoned in hospitals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf50afe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and youths who have a primary nighttime residence that is a public or private place not designed for or ordinarily used as a regular sleeping accommodation for human beings (within the meaning of section 11302(a)(2)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn004009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf50afe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children and youths who are living in cars, parks, public spaces, abandoned buildings, substandard housing, bus or train stations, or similar settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf50afe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" migratory children (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6399"},"text":"section 6399 of title 20","children":[],"tail":") who qualify as homeless for the purposes of this part because the children are living in circumstances described in clauses (i) through (iii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “local educational agency” and “State educational agency” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unaccompanied youth” includes a homeless child or youth not in the physical custody of a parent or guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf50afea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s725"},"text":"Pub. L. 100–77, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1032"},"text":"Pub. L. 107–110, title X, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2005"},"text":"115 Stat. 2005","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX"},"text":"Pub. L. 114–95, title IX","children":[],"tail":", §§ 9105(a), 9215(zz), "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2136"},"text":"129 Stat. 2136","children":[],"tail":", 2184.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf50afeb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf50afec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf50afed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"Section 11302 of this title","children":[],"tail":", referred to in par. (2)(B)(ii), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/s1003/a/2"},"text":"Pub. L. 111–22, div. B, § 1003(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1664"},"text":"123 Stat. 1664","children":[],"tail":", and, as so amended, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302/a/2"},"text":"section 11302(a)(2) of this title","children":[],"tail":" no longer contains a subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf50afee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11434a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s725"},"text":"Pub. L. 100–77, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s323"},"text":"Pub. L. 103–382, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3965"},"text":"108 Stat. 3965","children":[],"tail":", defined terms, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 11434a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s725"},"text":"Pub. L. 100–77, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tVI/s613/2"},"text":"Pub. L. 101–645, title VI, § 613(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4743"},"text":"104 Stat. 4743","children":[],"tail":", related to reports by Comptroller General, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/s725"},"text":"section 725 of Pub. L. 100–77","children":[],"tail":" was renumbered section 726 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11435"},"text":"section 11435 of this title","children":[],"tail":", prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf50afef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9105/a/1"},"text":"Pub. L. 114–95, § 9105(a)(1)","children":[],"tail":", inserted “or” before “are abandoned” and struck out “or are awaiting foster care placement;” after “hospitals;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/zz"},"text":"Pub. L. 114–95, § 9215(zz)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9105/a/2"},"text":"Pub. L. 114–95, § 9105(a)(2)","children":[],"tail":", which directed technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":", could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/zz"},"text":"Pub. L. 114–95, § 9215(zz)","children":[],"tail":". See above and Effective Date of 2015 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9105/a/3"},"text":"Pub. L. 114–95, § 9105(a)(3)","children":[],"tail":", substituted “homeless child or youth not” for “youth not”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf50aff0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf50aff1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9215/zz"},"text":"section 9215(zz) of Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9105/b"},"text":"Pub. L. 114–95, title IX, § 9105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2137"},"text":"129 Stat. 2137","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/95/tIX/s9105/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a State that is not a covered State, the amendment made by subsection (a)(1) [amending this section] shall take effect on the date that is 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a covered State, the amendment made by subsection (a)(1) shall take effect on the date that is 2 years after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9105/a"},"text":"section 9105(a) of Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2016-10-01"},"text":"Oct. 1, 2016","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9105/b"},"text":"section 9105(b) of Pub. L. 114–95","children":[],"tail":" (set out above), see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9107"},"text":"section 9107 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"section 11431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf50aff2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbf50aff3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of Covered State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9105/c"},"text":"Pub. L. 114–95, title IX, § 9105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2137"},"text":"129 Stat. 2137","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/95/tIX/s9105/c"},"text":"“For purposes of this section [amending this section and enacting provisions set out as a note above] the term ‘covered State’ means a State that has a statutory law that defines or describes the phrase ‘awaiting foster care placement’, for purposes of a program under subtitle B of title VII of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"42 U.S.C. 11431","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
