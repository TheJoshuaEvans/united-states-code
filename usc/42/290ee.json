{"tag":"section","attrib":{"id":"idb5bd8354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee"},"text":"§ 290ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opioid overdose reversal medication access, education, and co-prescribing grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bd8355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to States, localities, Indian Tribes, and Tribal organizations (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement strategies that increase access to drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.] for emergency treatment of known or suspected opioid overdose, as appropriate, pursuant to a standing order;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage pharmacies to dispense opioid overdose reversal medication pursuant to a standing order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage health care providers to co-prescribe, as appropriate, drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop or provide training materials that persons authorized to prescribe or dispense a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose may use to educate the public concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd835a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when and how to safely administer such drug or device; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd835b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps to be taken after administering such drug or device; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd835c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate the public concerning the availability of drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose without a person-specific prescription.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd835d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant may be made under this section only if the State involved has authorized standing orders to be issued for drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd835e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in making grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary may give preference to States that have a significantly higher rate of opioid overdoses than the national average, and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd835f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not implemented standing orders regarding drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize standing orders to be issued that permit community-based organizations, substance abuse programs, or other nonprofit entities to acquire, dispense, or administer drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize standing orders to be issued that permit police, fire, or emergency medical services agencies to acquire and administer drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd8363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not receive more than one grant under this section at a time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be for a period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd8365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5bd8366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not more than 10 percent of a grant under this section for educating the public pursuant to subsection (a)(5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5bd8367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use not less than 20 percent of a grant under this section to offset cost-sharing for distribution and dispensing of drugs or devices approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a State shall submit an application to the Secretary in such form and manner and containing such information as the Secretary may reasonably require, including detailed proposed expenditures of grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd8369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section shall, at least annually for the duration of the grant, submit a report to the Secretary evaluating the progress of the activities supported through the grant. Such reports shall include information on the number of pharmacies in the State that dispense a drug or device approved, cleared, or otherwise legally marketed under the Federal Food, Drug, and Cosmetic Act for emergency treatment of known or suspected opioid overdose under a standing order, and other information as the Secretary determines appropriate to evaluate the use of grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd836a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section the term “standing order” means a document prepared by a person authorized to prescribe medication that permits another person to acquire, dispense, or administer medication without a person-specific prescription.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bd836b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bd836c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $5,000,000 for the period of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bd836d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 3 percent of the amounts made available to carry out this section may be used by the Secretary for administrative expenses of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bd836e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 545, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tI/s110/a"},"text":"Pub. L. 114–198, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/709"},"text":"130 Stat. 709","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1220"},"text":"Pub. L. 117–328, div. FF, title I, § 1220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5672"},"text":"136 Stat. 5672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bd836f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bd8370-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5bd8371-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5bd8372-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290ee, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s545"},"text":"act July 1, 1944, ch. 373, title V, § 545","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/92/255/tV/s502"},"text":"Pub. L. 92–255, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/237/s12/b/1"},"text":"Pub. L. 94–237, § 12(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-19"},"text":"Mar. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/247"},"text":"90 Stat. 247","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/461/s5"},"text":"Pub. L. 95–461, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1269"},"text":"92 Stat. 1269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/181/s11"},"text":"Pub. L. 96–181, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-02"},"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1315"},"text":"93 Stat. 1315","children":[],"tail":"; renumbered § 524 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/15"},"text":"Pub. L. 98–24, § 2(b)(15)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/181"},"text":"97 Stat. 181","children":[],"tail":"; renumbered § 545, "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/2"},"text":"Pub. L. 100–77, title VI, § 611(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/516"},"text":"101 Stat. 516","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVIII/s813/3"},"text":"Pub. L. 100–607, title VIII, § 813(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3170"},"text":"102 Stat. 3170","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVI/s613/3"},"text":"Pub. L. 100–628, title VI, § 613(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3243"},"text":"102 Stat. 3243","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/t/1"},"text":"Pub. L. 101–93, § 5(t)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/615"},"text":"103 Stat. 615","children":[],"tail":", which related to technical assistance to State and local agencies by the National Institute on Drug Abuse, was omitted in the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bd8373-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/e"},"text":"Pub. L. 117–328, § 1220(e)","children":[],"tail":", substituted “approved, cleared, or otherwise legally marketed” for “approved or cleared” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/a/1"},"text":"Pub. L. 117–328, § 1220(a)(1)","children":[],"tail":", substituted “access, education, and co-prescribing grant programs” for “access and education grant programs” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/a/2"},"text":"Pub. L. 117–328, § 1220(a)(2)","children":[],"tail":", (3), substituted “Grants” for “Grants to States” in heading and “shall make grants to States, localities, Indian Tribes, and Tribal organizations (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")” for “shall make grants to States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/a/4"},"text":"Pub. L. 117–328, § 1220(a)(4)","children":[],"tail":", substituted “implement strategies that increase access to drugs or devices” for “implement strategies for pharmacists to dispense a drug or device”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/a/5"},"text":"Pub. L. 117–328, § 1220(a)(5)","children":[],"tail":", (6), added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/b"},"text":"Pub. L. 117–328, § 1220(b)","children":[],"tail":", substituted “5 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/c"},"text":"Pub. L. 117–328, § 1220(c)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “A State may use not more than 20 percent of a grant under this section for educating the public pursuant to subsection (a)(4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1220/d"},"text":"Pub. L. 117–328, § 1220(d)","children":[],"tail":", substituted “fiscal years 2023 through 2027” for “fiscal years 2017 through 2019”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5bd8374-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5bd8375-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Opioid Overdose Reversal Agents in HHS Grant Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/tII/s210"},"text":"Pub. L. 119–44, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/682"},"text":"139 Stat. 682","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/44/tII/s210"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services shall ensure that, as appropriate, whenever the Department of Health and Human Services issues a regulation or guidance for any grant program addressing opioid misuse and use disorders, any reference to an opioid overdose reversal drug (such as a reference to naloxone) is inclusive of any opioid overdose reversal drug that has been approved under section 505 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"21 U.S.C. 355","children":[],"tail":") for emergency treatment of a known or suspected opioid overdose."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing References.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":"], the Secretary of Health and Human Services shall update all references described in paragraph (2) to be inclusive of any opioid overdose reversal drug that has been approved or otherwise authorized for use by the Food and Drug Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A reference described in this paragraph is any reference to an opioid overdose reversal drug (such as naloxone) in any regulation or guidance of the Department of Health and Human Services that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was issued before the date of enactment of this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is included in—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant program for State and Tribal response to opioid use disorders under section 1003 of the 21st Century Cures Act [former] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–3"},"text":"42 U.S.C. 290ee–3","children":[],"tail":" note) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–3a"},"text":"42 U.S.C. 290ee–3a","children":[],"tail":"] (commonly referred to as ‘State Opioid Response Grants’ and ‘Tribal Opioid Response Grants’); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant program for priority substance use disorder prevention needs of regional and national significance under section 516 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–22"},"text":"42 U.S.C. 290bb–22","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
