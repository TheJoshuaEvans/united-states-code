{"tag":"section","attrib":{"id":"idb5e88b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b"},"text":null,"children":[{"tag":"num","attrib":{"value":"295b"},"text":"§ 295b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health traineeships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to accredited schools of public health, and to other public or nonprofit private institutions accredited for the provision of graduate or specialized training in public health, for the purpose of assisting such schools and institutions in providing traineeships to individuals described in subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any grant under this section shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Traineeships awarded under grants made under subsection (a) shall provide for tuition and fees and such stipends and allowances (including travel and subsistence expenses and dependency allowances) for the trainees as the Secretary may deem necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individuals referred to in subsection (a) are individuals who are pursuing a course of study in a health professions field in which there is a severe shortage of health professionals (which fields include the fields of epidemiology, environmental health, biostatistics, toxicology, nutrition, and maternal and child health).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b27-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 767, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s105"},"text":"Pub. L. 105–392, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3555"},"text":"112 Stat. 3555","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88b28-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e88b29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e88b2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 295b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s763"},"text":"act July 1, 1944, ch. 373, title VII, § 763","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1970-12-25"},"text":"Dec. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/696/s101"},"text":"Pub. L. 91–696, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2080-2"},"text":"84 Stat. 2080–2","children":[],"tail":", authorized Secretary to make grants and to set limitations and conditions on grants, required applications for grants, limited use of grant funds, set forth method of payment of grants, and provided for protection of financial interests of the United States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s220/c"},"text":"Pub. L. 99–129, title II, § 220(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/544"},"text":"99 Stat. 544","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 295b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s763"},"text":"act July 1, 1944, ch. 373, title VII, § 763","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1963-10-31"},"text":"Oct. 31, 1963","children":[],