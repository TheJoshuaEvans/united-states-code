{"tag":"section","attrib":{"id":"idb85b86db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d"},"text":"§ 1320d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85b86dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code set","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “code set” means any set of codes used for encoding data elements, such as tables of terms, medical concepts, medical diagnostic codes, or medical procedure codes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care clearinghouse” means a public or private entity that processes or facilitates the processing of nonstandard data elements of health information into standard data elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care provider” includes a provider of services (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/u"},"text":"section 1395x(u) of this title","children":[],"tail":"), a provider of medical or other health services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/s"},"text":"section 1395x(s) of this title","children":[],"tail":"), and any other person furnishing health care services or supplies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health information” means any information, whether oral or recorded in any form or medium, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85b86e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is created or received by a health care provider, health plan, public health authority, employer, life insurer, school or university, or health care clearinghouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to the past, present, or future physical or mental health or condition of an individual, the provision of health care to an individual, or the past, present, or future payment for the provision of health care to an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health plan” means an individual or group plan that provides, or pays the cost of, medical care (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91"},"text":"section 300gg–91 of this title","children":[],"tail":"). Such term includes the following, and any combination thereof:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85b86e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A group health plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/a"},"text":"section 300gg–91(a) of this title","children":[],"tail":"), but only if the plan—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb85b86e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has 50 or more participants (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/7"},"text":"section 1002(7) of title 29","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b86e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is administered by an entity other than the employer who established and maintains the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health insurance issuer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/b"},"text":"section 300gg–91(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health maintenance organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–91/b"},"text":"section 300gg–91(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parts ","children":[{"tag":"ref","attrib":{"idref":"fn002726"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002726"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Part”."}],"tail":" A, B, C, or D of the Medicare program under subchapter XVIII."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The medicaid program under subchapter XIX.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Medicare supplemental policy (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ss/g/1"},"text":"section 1395ss(g)(1) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A long-term care policy, including a nursing home fixed indemnity policy (unless the Secretary determines that such a policy does not provide sufficiently comprehensive coverage of a benefit so that the policy should be treated as a health plan).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee welfare benefit plan or any other arrangement which is established or maintained for the purpose of offering or providing health benefits to the employees of 2 or more employers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health care program for active military personnel under title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The veterans health care program under chapter 17 of title 38.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Civilian Health and Medical Program of the Uniformed Services (CHAMPUS), as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/4"},"text":"section 1072(4) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian health service program under the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"25 U.S.C. 1601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/5/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Employees Health Benefit Plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individually identifiable health information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “individually identifiable health information” means any information, including demographic information collected from an individual, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85b86f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is created or received by a health care provider, health plan, employer, or health care clearinghouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b86f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relates to the past, present, or future physical or mental health or condition of an individual, the provision of health care to an individual, or the past, present, or future payment for the provision of health care to an individual, and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85b86f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b86f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which there is a reasonable basis to believe that the information can be used to identify the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standard”, when used with reference to a data element of health information or a transaction referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2/a/1"},"text":"section 1320d–2(a)(1) of this title","children":[],"tail":", means any such data element or transaction that meets each of the standards and implementation specifications adopted or established by the Secretary with respect to the data element or transaction under sections 1320d–1 through 1320d–3 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard setting organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “standard setting organization” means a standard setting organization accredited by the American National Standards Institute, including the National Council for Prescription Drug Programs, that develops standards for information transactions, data elements, or any other standard that is necessary to, or will facilitate, the implementation of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operating rules” means the necessary business rules and guidelines for the electronic exchange of information that are not defined by a standard or its implementation specifications as adopted for purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85b86fa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1171, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2021"},"text":"110 Stat. 2021","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/105/s4"},"text":"Pub. L. 107–105, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1007"},"text":"115 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13102"},"text":"Pub. L. 111–5, div. A, title XIII, § 13102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/242"},"text":"123 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1104/b/1"},"text":"Pub. L. 111–148, title I, § 1104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/146"},"text":"124 Stat. 146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85b86fb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85b86fc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85b86fd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Health Care Improvement Act, referred to in par. (5)(L), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":", which is classified principally to chapter 18 (§ 1601 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb85b86fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1171 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320c–20"},"text":"section 1320c–20 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85b86ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Par. (5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" substituted “C, or D” for “or C”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/105"},"text":"Pub. L. 107–105","children":[],"tail":" substituted “Parts A, B, or C” for “Part A or part B”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85b8700-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85b8701-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1105"},"text":"Pub. L. 111–148, title I, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tI/s1105"},"text":"“This subtitle [subtitle B (§§ 1101–1105) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", enacting subchapter I of chapter 157 of this title, amending this section and sections 1320d–2 and 1395y of this title, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","child