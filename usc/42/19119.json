{"tag":"section","attrib":{"id":"idc07f929b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119"},"text":null,"children":[{"tag":"num","attrib":{"value":"19119"},"text":"§ 19119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and roadmaps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07f929c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide to the relevant authorizing and appropriations committees of Congress an annual report describing projects supported by the Directorate during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f929d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roadmap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall provide to the relevant authorizing and appropriations committees of Congress a roadmap describing the strategic vision that the Directorate will use to guide investment decisions over the following 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f929e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and every 3 years thereafter, the Director, in consultation with the heads of relevant Federal agencies, shall prepare and submit to Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07f929f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic vision for the next 5 years for the Directorate, including a description of how the Foundation will increase funding for research and education for populations underrepresented in STEM and geographic areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f92a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the planned activities of the Directorate to secure federally funded science and technology pursuant to section 1746 of the National Defense Authorization Act for Fiscal Year 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6601"},"text":"42 U.S.C. 6601","children":[],"tail":" note) and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6605"},"text":"section 6605 of this title","children":[],"tail":" and the requirements under part D of this subchapter and subtitle E of title VI."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f92a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after the establishment of the Directorate, the Director shall prepare and submit a report to Congress regarding the use of alternative methods for the selection of award recipients and the distribution of funding to recipients, as compared to the traditional peer review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07f92a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10399"},"text":"Pub. L. 117–167, div. B, title III, § 10399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1598"},"text":"136 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc07f92a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc07f92a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc07f92a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subtitle E of title VI, referred to in subsec. (c)(2), is subtitle E (§§ 10641–10649) of title VI of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1672"},"text":"136 Stat. 1672","children":[],"tail":", known as the Coastal and Ocean Acidification Research and Innovation Act of 2021. For complete classification of subtitle E to the Code, see Short Title of 2022 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3701"},"text":"section 3701 of Title 33","children":[],"tail":", Navigation and Navigable Waters, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
