{"tag":"section","attrib":{"id":"idb54d8344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m"},"text":null,"children":[{"tag":"num","attrib":{"value":"280m"},"text":"§ 280m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Young women’s breast health awareness and support of young women diagnosed with breast cancer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54d8345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public education campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall conduct a national evidence-based education campaign to increase awareness of young women’s knowledge regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d8347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breast health in young women of all racial, ethnic, and cultural backgrounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" breast awareness and good breast health habits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occurrence of breast cancer and the general and specific risk factors in women who may be at high risk for breast cancer based on familial, racial, ethnic, and cultural backgrounds such as Ashkenazi Jewish populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d834a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence-based information that would encourage young women and their health care professional to increase early detection of breast cancers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d834b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of health information and other resources for young women diagnosed with breast cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d834c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based, age appropriate messages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campaign shall provide evidence-based, age-appropriate messages and materials as developed by the Centers for Disease Control and Prevention and the Advisory Committee established under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d834d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media campaign","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the education campaign under paragraph (1), the Secretary shall award grants to entities to establish national multimedia campaigns oriented to young women that may include advertising through television, radio, print media, billboards, posters, all forms of existing and especially emerging social networking media, other Internet media, and any other medium determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d834e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d834f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall establish an advisory committee to assist in creating and conducting the education campaigns under paragraph (1) and subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall appoint to the advisory committee under subparagraph (A) such members as deemed necessary to properly advise the Secretary, and shall include organizations and individuals with expertise in breast cancer, disease prevention, early detection, diagnosis, public health, social marketing, genetic screening and counseling, treatment, rehabilitation, palliative care, and survivorship in young women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care professional education campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, and in consultation with the Administrator of the Health Resources and Services Administration, shall conduct an education campaign among physicians and other health care professionals to increase awareness—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of breast health, symptoms, and early diagnosis and treatment of breast cancer in young women, including specific risk factors such as family history of cancer and women that may be at high risk for breast cancer, such as Ashkenazi Jewish population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how to provide counseling to young women about their breast health, including knowledge of their family cancer history and importance of providing regular clinical breast examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerning the importance of discussing healthy behaviors, and increasing awareness of services and programs available to address overall health and wellness, and making patient referrals to address tobacco cessation, good nutrition, and physical activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on when to refer patients to a health care provider with genetics expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how to provide counseling that addresses long-term survivorship and health concerns of young women diagnosed with breast cancer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on when to provide referrals to organizations and institutions that provide credible health information and substantive assistance and support to young women diagnosed with breast cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention research activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Centers for Disease Control and Prevention, shall conduct prevention research on breast cancer in younger women, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d835a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavioral, survivorship studies, and other research on the impact of breast cancer diagnosis on young women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d835b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formative research to assist with the development of educational messages and information for the public, targeted populations, and their families about breast health, breast cancer, and healthy lifestyles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d835c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing and evaluating existing and new social marketing strategies targeted at young women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d835d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveys of health care providers and the public regarding knowledge, attitudes, and practices related to breast health and breast cancer prevention and control in high-risk populations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d835e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institutes of Health, shall conduct research to develop and validate new screening tests and methods for prevention and early detection of breast cancer in young women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d835f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for young women diagnosed with breast cancer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to organizations and institutions to provide health information from credible sources and substantive assistance directed to young women diagnosed with breast cancer and pre-neoplastic breast diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under paragraph (1), the Secretary shall give priority to applicants that deal specifically with young women diagnosed with breast cancer and pre-neoplastic breast disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No duplication of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting an education campaign or other program under subsections (a), (b), (c), or (d), the Secretary shall avoid duplicating other existing Federal breast cancer education efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurement; reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d8365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" young women’s awareness regarding breast health, including knowledge of family cancer history, specific risk factors and early warning signs, and young women’s proactive efforts at early detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number or percentage of young women utilizing information regarding lifestyle interventions that foster healthy behaviors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number or percentage of young women receiving regular clinical breast exams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number or percentage of young women who perform breast self exams, and the frequency of such exams, before the implementation of this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than every 3 years, measure the impact of such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d836a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit reports to the Congress on the results of such measurements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d836b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “young women” means women 15 to 44 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d836c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280m/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out subsections (a), (b), (c)(1), and (d), there are authorized to be appropriated $9,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54d836d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399NN, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10413/b"},"text":"Pub. L. 111–148, title X, § 10413(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/991"},"text":"124 Stat. 991","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/265/s2"},"text":"Pub. L. 113–265, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2942"},"text":"128 Stat. 2942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s316"},"text":"Pub. L. 116–260, div. BB, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2932"},"text":"134 Stat. 2932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54d836e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54d836f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54d8370-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “$9,000,000 for each of fiscal years 2022 through 2026” for “$4,900,000 for each of fiscal years 2015 through 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/265"},"text":"Pub. L. 113–265","children":[],"tail":" substituted “$4,900,000 for each of fiscal years 2015 through 2019” for “$9,000,000 for each of the fiscal years 2010 through 2014”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
