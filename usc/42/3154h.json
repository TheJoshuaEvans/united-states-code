{"tag":"section","attrib":{"id":"idbc770224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154h"},"text":"§ 3154h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical Supply Chain Site Development grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc770225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants under the “Critical Supply Chain Site Development grant program” (referred to in this section as the “grant program”) to carry out site development or expansion projects for the purpose of making the site ready for manufacturing projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing a grant to an eligible recipient under the grant program, the Secretary may consider whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed improvements to the site will improve economic conditions for rural areas, Tribal communities, or areas that meet 1 or more of the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is consistent with regional economic development plans, which may include a comprehensive economic development strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible recipient has initiatives to prioritize job training and workforce development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77022a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project supports industries determined by the Secretary to be of strategic importance to the national or economic security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc77022b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants to eligible recipients under the grant program, the Secretary shall give priority to eligible recipients that propose to carry out a project that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc77022c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has State, local, private, or nonprofit funds being contributed to assist with site development efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77022d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the site development or expansion project is carried out, will result in a demonstrated interest in the site by commercial entities or other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc77022e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant provided under the grant program may be used for the following activities relating to the development or expansion of a site:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc77022f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Investments in site utility readiness, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of on-site utility infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of last-mile infrastructure, including road infrastructure, water infrastructure, power infrastructure, broadband infrastructure, and other physical last-mile infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" site grading; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities to extend public utilities or services to a site, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Investments in site readiness, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land assembly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zoning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc77023a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77023b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investments in workforce development and sustainability programs, including job training and retraining programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77023c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investments to ensure that disadvantaged communities have access to on-site jobs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc77023d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc77023e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in awarding grants under the grant program, the Secretary shall not require an eligible recipient to demonstrate that a private company or investment has selected the site for development or expansion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77023f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under the grant program, the Secretary shall include necessary safeguards to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the site development is fully completed within a reasonable timeframe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154h/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible recipient has sufficiently demonstrated private sector interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc770242-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s222"},"text":"Pub. L. 89–136, title II, § 222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2224"},"text":"Pub. L. 118–272, div. B, title II, § 2224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3189"},"text":"138 Stat. 3189","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
