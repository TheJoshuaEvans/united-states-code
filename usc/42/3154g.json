{"tag":"section","attrib":{"id":"idbc77020b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154g"},"text":"§ 3154g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-speed broadband deployment initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc77020c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc77020d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “broadband project” means, for the purposes of providing, extending, expanding, or improving high-speed broadband service to further the goals of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc77020e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, technical assistance, or training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc77020f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or development of land; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, design and engineering, construction, rehabilitation, alteration, expansion, or improvement of facilities, including related machinery, equipment, contractual rights, and intangible property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible recipient” means an eligible recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc770214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc770215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium formed for the purpose of providing, extending, expanding, or improving high-speed broadband service between 1 or more eligible recipients and 1 or more for-profit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-speed broadband","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-speed broadband” means the provision of 2-way data transmission with sufficient downstream and upstream speeds to end users to permit effective participation in the economy and to support economic growth, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants under this subchapter for broadband projects, which shall be subject to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing applications submitted under paragraph (1), the Secretary shall take into consideration geographic diversity of grants provided, including consideration of underserved markets, in addition to data requested in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77021a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data requested","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing an application submitted under paragraph (1), the Secretary shall request from the Federal Communications Commission, the Administrator of the National Telecommunications and Information Administration, the Secretary of Agriculture, and the Appalachian Regional Commission data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc77021b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level and extent of broadband service that exists in the area proposed to be served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc77021c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level and extent of broadband service that will be deployed in the area proposed to be served pursuant to another Federal program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77021d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest in real or personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any broadband project carried out by an eligible recipient that is a public-private partnership or consortium, the Secretary shall require that title to any real or personal property acquired or improved with grant funds, or if the recipient will not acquire title, another possessory interest acceptable to the Secretary, be vested in a public partner or eligible nonprofit organization or association for the useful life of the project, after which title may be transferred to any member of the public-private partnership or consortium in accordance with regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77021e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no person or entity shall be disqualified from competing to provide goods or services related to a broadband project on the basis that the person or entity participated in the development of the broadband project or in the drafting of specifications, requirements, statements of work, or similar documents related to the goods or services to be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77021f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadband project property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit a recipient of a grant for a broadband project to grant an option to acquire real or personal property (including contractual rights and intangible property) related to that project to a third party on such terms as the Secretary determines to be appropriate, subject to the condition that the option may only be exercised after the Secretary releases the Federal interest in the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grant or exercise of an option described in subparagraph (A) shall not constitute a redistribution of grant funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3154c"},"text":"section 3154c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of the non-Federal share of the cost of a broadband project, the Secretary may provide credit toward the non-Federal share for the present value of allowable contributions over the useful life of the broadband project, subject to the condition that the Secretary may require such assurances of the value of the rights and of the commitment of the rights as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc770223-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s221"},"text":"Pub. L. 89–136, title II, § 221","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2223"},"text":"Pub. L. 118–272, div. B, title II, § 2223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3188"},"text":"138 Stat. 3188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
