{"tag":"section","attrib":{"id":"idbf5a4c8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11922"},"text":null,"children":[{"tag":"num","attrib":{"value":"11922"},"text":"§ 11922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse on drug abuse in public housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf5a4c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall establish, in the Office of Public Housing in the Department of Housing and Urban Development, a clearinghouse to receive, collect, process, and assemble information regarding the abuse of controlled substances in public housing projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf5a4c91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The clearinghouse established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4c92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to inquiries by members of the public requesting assistance in investigating, studying, and working on the problem of the abuse of controlled substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, collect, process, assemble, and provide information on programs, authorities, institutions, and agencies, that may further assist members of the public requesting information from the clearinghouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c94-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5143"},"text":"Pub. L. 100–690, title V, § 5143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4303"},"text":"102 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
