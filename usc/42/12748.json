{"tag":"section","attrib":{"id":"idbf9f6b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748"},"text":null,"children":[{"tag":"num","attrib":{"value":"12748"},"text":"§ 12748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HOME Investment Trust Funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9f6b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish for each participating jurisdiction a HOME Investment Trust Fund, which shall be an account (or accounts as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12749/c"},"text":"section 12749(c) of this title","children":[],"tail":") for use solely to invest in affordable housing within the participating jurisdiction’s boundaries or within the boundaries of contiguous jurisdictions in joint projects which serve residents from both jurisdictions in accordance with the provisions of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Line of credit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a line of credit in the HOME Investment Trust Fund of each participating jurisdiction, which line of credit shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9f6b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds allocated or reallocated to the participating jurisdiction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12747"},"text":"section 12747 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any payment or repayment made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12749"},"text":"section 12749 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participating jurisdiction’s line of credit shall be reduced by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9f6b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds drawn from the HOME Investment Trust Fund by the participating jurisdiction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds expiring under subsection (g), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9f6b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any penalties assessed by the Secretary under section 12754 ","children":[{"tag":"ref","attrib":{"idref":"fn004111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “12753”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating jurisdiction may draw funds from its HOME Investment Trust Fund, but not to exceed the remaining line of credit, only after providing certification that the funds shall be used pursuant to the participating jurisdiction’s approved housing strategy and in compliance with all requirements of this subchapter. When such certification is received, the Secretary shall immediately disburse such funds in accordance with the form of the assistance determined by the participating jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment within 15 days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The participating jurisdiction shall, not later than 15 days after funds are drawn from the jurisdiction’s HOME Investment Trust Fund, invest such funds, together with any interest earned thereon, in the affordable housing for which the funds were withdrawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interest or fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not charge any interest or levy any other fee with regard to funds in a HOME Investment Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of right to draw funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any funds becoming available to a participating jurisdiction under this subchapter are not placed under binding commitment to affordable housing within 24 months after the last day of the month in which such funds are deposited in the jurisdiction’s HOME Investment Trust Fund, the jurisdiction’s right to draw such funds from the HOME Investment Trust Fund shall expire. The Secretary shall reduce the line of credit in the participating jurisdiction’s HOME Investment Trust Fund by the expiring amount and shall reallocate the funds by formula in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12747/d"},"text":"section 12747(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9f6ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12748/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall keep each participating jurisdiction informed of the status of its HOME Investment Trust Fund, including the status of amounts under various stages of commitment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9f6ba2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s218"},"text":"Pub. L. 101–625, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4109"},"text":"104 Stat. 4109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tII"},"text":"Pub. L. 102–550, title II","children":[],"tail":", §§ 203(c), 221, "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3752"},"text":"106 Stat. 3752","children":[],"tail":", 3762.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9f6ba3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf9f6ba4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf9f6ba5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s221"},"text":"Pub. L. 102–550, § 221","children":[],"tail":", inserted “or within the boundaries of contiguous jurisdictions in joint projects which serve residents from both jurisdictions” after “boundaries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s203/c"},"text":"Pub. L. 102–550, § 203(c)","children":[],"tail":", substituted “If” for “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12747/b/1/A/ii"},"text":"section 12747(b)(1)(A)(ii) of this title","children":[],"tail":", if”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf9f6ba6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf9f6ba7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" applicable to unexpended funds allocated under subchapter II of this chapter in fiscal year 1992, except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s223"},"text":"section 223 of Pub. L. 102–550","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12704"},"text":"section 12704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
