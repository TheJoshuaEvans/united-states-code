{"tag":"section","attrib":{"id":"idb5da3321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e"},"text":null,"children":[{"tag":"num","attrib":{"value":"293e"},"text":"§ 293e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for health professions education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5da3322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural competency, prevention, and public health and individuals with disability grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da3323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, may make awards of grants, contracts, or cooperative agreements to public and nonprofit private entities (including tribal entities) for the development, evaluation, and dissemination of research, demonstration projects, and model curricula for cultural competency, prevention, public health proficiency, reducing health disparities, and aptitude for working with individuals with disabilities training for use in health professions schools and continuing education programs, and for other purposes determined as appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da3324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless specifically required otherwise in this subchapter, the Secretary shall accept applications for grants or contracts under this section from health professions schools, academic health centers, State or local governments, or other appropriate public or private nonprofit entities (or consortia of entities, including entities promoting multidisciplinary approaches) for funding and participation in health professions training activities. The Secretary may accept applications from for-profit private entities as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary shall collaborate with health professional societies, licensing and accreditation entities, health professions schools, and experts in minority health and cultural competency, prevention, and public health and disability groups, community-based organizations, and other organizations as determined appropriate by the Secretary. The Secretary shall coordinate with curricula and research and demonstration projects developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s296e–1"},"text":"section 296e–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da3327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Model curricula developed under this section shall be disseminated through the Internet Clearinghouse under section 270 ","children":[{"tag":"ref","attrib":{"idref":"fn002263"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002263"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", does not contain a section 270."}],"tail":" and such other means as determined appropriate by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da3328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate the adoption and the implementation of cultural competency, prevention, and public health, and working with individuals with a disability training curricula, and the facilitate ","children":[{"tag":"ref","attrib":{"idref":"fn002264"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" inclusion of these competency measures in quality measurement systems as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2010 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5da332a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 741, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/525/tIV/s401/a"},"text":"Pub. L. 106–525, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2508"},"text":"114 Stat. 2508","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5307/a"},"text":"Pub. L. 111–148, title V, § 5307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/628"},"text":"124 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5da332b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5da332c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"