84","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293f"},"text":"section 293f of this title","children":[],"tail":", and subsequently omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5da332e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5307/a/1/A"},"text":"Pub. L. 111–148, § 5307(a)(1)(A)","children":[],"tail":", substituted “Cultural competency, prevention, and public health and individuals with disability grants” for “Grants for health professions education in health disparities and cultural competency” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5307/a/1/B"},"text":"Pub. L. 111–148, § 5307(a)(1)(B)","children":[],"tail":", substituted “for the development, evaluation, and dissemination of research, demonstration projects, and model curricula for cultural competency, prevention, public health proficiency, reducing health disparities, and aptitude for working with individuals with disabilities training for use in health professions schools and continuing education programs, and for other purposes determined as appropriate by the Secretary” for “for the purpose of carrying out research and demonstration projects (including research and demonstration projects for continuing health professions education) for training and education of health professionals for the reduction of disparities in health care outcomes and the provision of culturally competent health care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5307/a/2"},"text":"Pub. L. 111–148, § 5307(a)(2)","children":[],"tail":", added subsecs. (b) to (d) and struck out former subsec. (b). Prior to amendment, text of subsec. (b) read as follows: “There are authorized to be appropriated to carry out subsection (a) of this section, $3,500,000 for fiscal year 2001, $7,000,000 for fiscal year 2002, $7,000,000 for fiscal year 2003, and $3,500,000 for fiscal year 2004.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5da332f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5da3330-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Conference on Health Professions Education and Health Disparities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/525/tIV/s402"},"text":"Pub. L. 106–525, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2509"},"text":"114 Stat. 2509","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/525/tIV/s402"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":"], the Secretary of Health and Human Services (in this section referred to as the ‘Secretary’), acting through the Administrator of the Health Resources and Services Administration, shall convene a national conference on health professions education as a method for reducing disparities in health outcomes."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in the national conference convened under subsection (a) advocacy groups and educational entities as described in section 741 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s293e"},"text":"42 U.S.C. 293e","children":[],"tail":"] (as added by section 401), tribal health programs, health centers under section 330 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"42 U.S.C. 254b","children":[],"tail":"], and other interested parties."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issues","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national conference convened under subsection (a) shall include, but is not limited to, issues that address the role and impact of health professions education on the reduction of disparities in health outcomes, including the role of education on cultural competency. The conference shall focus on methods to achieve reductions in disparities in health outcomes through health professions education (including continuing education programs) and strategies for outcomes measurement to assess the effectiveness of education in reducing disparities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Findings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the national conference under subsection (a) has convened, the Secretary shall publish in the Federal Register a summary of the proceedings and findings of the conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
