{"tag":"section","attrib":{"id":"idbf1ea22f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302"},"text":null,"children":[{"tag":"num","attrib":{"value":"10302"},"text":"§ 10302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to assist the Nation and the States in augmenting their water resources science and technology as a way to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1ea230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure supplies of water sufficient in quantity and quality to meet the Nation’s expanding needs for the production of food, materials, and energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discover practical solutions to the Nation’s water and water resources related problems, particularly those problems related to impaired water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure the protection and enhancement of environmental and social values in connection with water resources management and utilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the interest of State and local governments as well as private industry in research and the development of technology that will reclaim waste water and to convert saline and other impaired waters to waters suitable for municipal, industrial, agricultural, recreational, and other beneficial uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote more effective coordination of the Nation’s water resources research program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the development of a cadre of trained research scientists, engineers, and technicians for future water resources problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1ea236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage long-term planning and research to meet future water management, quality, and supply challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1ea237-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/242/tI/s103"},"text":"Pub. L. 98–242, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-22"},"text":"Mar. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/97"},"text":"98 Stat. 97","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/397/s1/a"},"text":"Pub. L. 101–397, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-28"},"text":"Sept. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/852"},"text":"104 Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/147/s2"},"text":"Pub. L. 104–147, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-24"},"text":"May 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1375"},"text":"110 Stat. 1375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1ea238-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1ea239-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf1ea23a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/242"},"text":"Pub. L. 98–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-22"},"text":"Mar. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/97"},"text":"98 Stat. 97","children":[],"tail":", known as the Water Resources Research Act of 1984. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10301"},"text":"section 10301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf1ea23b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/147/s2/1"},"text":"Pub. L. 104–147, § 2(1)","children":[],"tail":", struck out “to” before “promote” and “and” after “program;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/147/s2/2"},"text":"Pub. L. 104–147, § 2(2)","children":[],"tail":", substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/147/s2/3"},"text":"Pub. L. 104–147, § 2(3)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/397"},"text":"Pub. L. 101–397","children":[],"tail":" substituted “to promote more effective coordination of” for “coordinate more effectively”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
