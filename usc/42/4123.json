{"tag":"section","attrib":{"id":"idbcb9d763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4123"},"text":null,"children":[{"tag":"num","attrib":{"value":"4123"},"text":"§ 4123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any payments under this chapter may be made (after necessary adjustment on account of previously made underpayments or overpayments) in advance or by way of reimbursement, and in such installments and on such conditions, as the Administrator may determine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcb9d764-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIII/s1372"},"text":"Pub. L. 90–448, title XIII, § 1372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/589"},"text":"82 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title IV, § 451(d)(1)], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1229"},"text":"97 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100238/b/1"},"text":"Pub. L. 112–141, div. F, title II, § 100238(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/958"},"text":"126 Stat. 958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb9d765-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb9d766-3a70-