{"tag":"section","attrib":{"id":"idbd1df06c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189"},"text":null,"children":[{"tag":"num","attrib":{"value":"5189"},"text":"§ 5189.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df06d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Federal estimate of the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df06e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repairing, restoring, reconstructing, or replacing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":" any damaged or destroyed public facility or private nonprofit facility,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df06f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency assistance under section 5170b or 5192 of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debris removed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5173"},"text":"section 5173 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is less than $1,000,000 (or, if the Administrator has established a threshold under subsection (b), the amount established under subsection (b)), the President (on application of the State or local government or the owner or operator of the private nonprofit facility) may make the contribution to such State or local government or owner or operator under section 5170b, 5172, 5173, or 5192 of this title, as the case may be, on the basis of such Federal estimate. Such $1,000,000 amount or, if applicable, the amount established under subsection (b), shall be adjusted annually to reflect changes in the Consumer Price Index for All Urban Consumers published by the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2013-01-29"},"text":"January 29, 2013","children":[],"tail":", the President, acting through the Administrator of the Federal Emergency Management Agency (in this section referred to as the “Administrator”), shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete an analysis to determine whether an increase in the threshold for eligibility under subsection (a) is appropriate, which shall include consideration of cost-effectiveness, speed of recovery, capacity of grantees, past performance, and accountability measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report regarding the analysis conducted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the Administrator submits the report required under paragraph (1), the President shall direct the Administrator to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately establish a threshold for eligibility under this section in an appropriate amount, without regard to chapter 5 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust the threshold annually to reflect changes in the Consumer Price Index for all Urban Consumers published by the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which the Administrator establishes a threshold under paragraph (2), and every 3 years thereafter, the President, acting through the Administrator, shall review the threshold for eligibility under this section and submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report regarding such review, including any recommendations developed pursuant to such review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df079-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s422"},"text":"Pub. L. 93–288, title IV, § 422","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/k"},"text":"Pub. L. 100–707, title I, § 106(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1107"},"text":"Pub. L. 113–2, div. B, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/46"},"text":"127 Stat. 46","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/189/s2/a"},"text":"Pub. L. 117–189, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-10"},"text":"Oct. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2204"},"text":"136 Stat. 2204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df07a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df07b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd1df07c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5189, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s419"},"text":"Pub. L. 93–288, title IV, § 419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/159"},"text":"88 Stat. 159","children":[],"tail":", related to alternate contributions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/s106/k"},"text":"Pub. L. 100–707, § 106(k)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1df07d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/189/s2/a/1"},"text":"Pub. L. 117–189, § 2(a)(1)","children":[],"tail":", substituted “$1,000,000” for “$35,000” in two places in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/189/s2/a/2"},"text":"Pub. L. 117–189, § 2(a)(2)","children":[],"tail":", inserted “and report” after “Review” in heading and “and submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report regarding such review, including any recommendations developed pursuant to such review” after “under this section” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/2/s1107/3"},"text":"Pub. L. 113–2, § 1107(3)","children":[],"tail":", which directed insertion of “or, if applicable, the amount established under subsection (b),” after “$35,000 amount” the second place appearing, was executed by making the insertion after “$35,000 amount” the only place that phrase appeared, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/2/s1107/1"},"text":"Pub. L. 113–2, § 1107(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a), inserted heading, and inserted “(or, if the Administrator has established a threshold under subsection (b), the amount established under subsection (b))” after “less than $35,000” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/2/s1107/4"},"text":"Pub. L. 113–2, § 1107(4)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1df07e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1df07f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/189/s2/b"},"text":"Pub. L. 117–189, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-10"},"text":"Oct. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2204"},"text":"136 Stat. 2204","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/189/s2/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to any amounts appropriated after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-10-10"},"text":"Oct. 10, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
