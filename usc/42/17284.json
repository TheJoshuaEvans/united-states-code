{"tag":"section","attrib":{"id":"idc03347b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284"},"text":null,"children":[{"tag":"num","attrib":{"value":"17284"},"text":"§ 17284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03347b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5-year plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03347b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Energy Information Administration (referred to in this section as the “Administrator”) shall establish a 5-year plan to enhance the quality and scope of the data collection necessary to ensure the scope, accuracy, and timeliness of the information needed for efficient functioning of energy markets and related financial operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the plan under paragraph (1), the Administrator shall pay particular attention to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03347b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data series terminated because of budget constraints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on demand response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely data series of State-level information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in the area of oil and gas data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in data on solid byproducts from coal-based energy-producing facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to meet applicable deadlines under Federal law (including regulations) to provide data required by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03347bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to Congress the plan established under subsection (a), including a description of any improvements needed to enhance the ability of the Administrator to collect and process energy information in a manner consistent with the needs of energy markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03347bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03347bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03347be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidelines to ensure the quality, comparability, and scope of State energy data, including data on energy production and consumption by product and sector and renewable and alternative sources, required to provide a comprehensive, accurate energy profile at the State level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share company-level data collected at the State level with each State involved, in a manner consistent with the legal authorities, confidentiality protections, and stated uses in effect at the time the data were collected, subject to the condition that the State shall agree to reasonable requirements for use of the data, as the Administrator may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess any existing gaps in data obtained and compiled by the Energy Information Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the most cost-effective ways to address any data quality and quantity issues in conjunction with State officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall consult with State officials and the Federal Energy Regulatory Commission on a regular basis in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03347c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing guidelines and determining the scope of State-level data under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03347c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring ways to address data needs and serve data uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03347c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of State data needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator shall submit to Congress an assessment of State-level data needs, including a plan to address the needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03347c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other amounts made available to the Administrator, there are authorized to be appropriated to the Administrator to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03347c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03347cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17284/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03347cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s805"},"text":"Pub. L. 110–140, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1721"},"text":"121 Stat. 1721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03347ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03347cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03347d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
