{"tag":"section","attrib":{"id":"idbe2dda83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426"},"text":null,"children":[{"tag":"num","attrib":{"value":"7426"},"text":"§ 7426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate pollution abatement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe2dda84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written notice to all nearby States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each applicable implementation plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe2dda85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require each major proposed new (or modified) source—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe2dda86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to part C (relating to significant deterioration of air quality) or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe2dda87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which may significantly contribute to levels of air pollution in excess of the national ambient air quality standards in any air quality control region outside the State in which such source intends to locate (or make such modification),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to provide written notice to all nearby States the air pollution levels of which may be affected by such source at least sixty days prior to the date on which commencement of construction is to be permitted by the State providing notice, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe2dda88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify all major existing stationary sources which may have the impact described in paragraph (1) with respect to new or modified sources and provide notice to all nearby States of the identity of such sources not later than three months after ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe2dda89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition for finding that major sources emit or would emit prohibited air pollutants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State or political subdivision may petition the Administrator for a finding that any major source or group of stationary sources emits or would emit any air pollutant in violation of the prohibition of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/D/ii"},"text":"section 7410(a)(2)(D)(ii) of this title","children":[],"tail":" or this section. Within 60 days after receipt of any petition under this subsection and after public hearing, the Administrator shall make such a finding or deny the petition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe2dda8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; allowable continued operation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any permit which may have been granted by the State in which the source is located (or intends to locate), it shall be a violation of this section and the applicable implementation plan in such State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe2dda8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any major proposed new (or modified) source with respect to which a finding has been made under subsection (b) to be constructed or to operate in violation of the prohibition of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/D/ii"},"text":"section 7410(a)(2)(D)(ii) of this title","children":[],"tail":" or this section, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe2dda8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7426/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any major existing source to operate more than three months after such finding has been made with respect to it.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator may permit the continued operation of a source referred to in paragraph (2) beyond the expiration of such three-month period if such source complies with such emission limitations and compliance schedules (containing increments of progress) as may be provided by the Administrator to bring about compliance with the requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/D/ii"},"text":"section 7410(a)(2)(D)(ii) of this title","children":[],"tail":" or this section as expeditiously as practicable, but in no case later than three years after the date of such finding. Nothing in the preceding sentence shall be construed to preclude any such source from being eligible for an enforcement order under section 7413(d) "},{"tag":"ref","attrib":{"idref":"fn003620"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003620"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title after the expiration of such period during which the Administrator has permitted continuous operation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe2dda8d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 126, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s123"},"text":"Pub. L. 95–95, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/724"},"text":"91 Stat. 724","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/190/s14/a/39"},"text":"Pub. L. 95–190, § 14(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-16"},"text":"Nov. 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1401"},"text":"91 Stat. 1401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tI/s109/a"},"text":"Pub. L. 101–549, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2469"},"text":"104 Stat. 2469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe2dda8e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe2dda8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe2dda90-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7413/d"},"text":"Section 7413(d) of this title","children":[],"tail":", referred to in subsec. (c), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVII/s701"},"text":"Pub. L. 101–549, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2672"},"text":"104 Stat. 2672","children":[],"tail":", and, as so amended, no longer relates to final compliance orders."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe2dda91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s109/a/1"},"text":"Pub. L. 101–549, § 109(a)(1)","children":[],"tail":", inserted “or group of stationary sources” after “any major source” and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/D/ii"},"text":"section 7410(a)(2)(D)(ii) of this title","children":[],"tail":" or this section” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/E/i"},"text":"section 7410(a)(2)(E)(i) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s109/a/2/A"},"text":"Pub. L. 101–549, § 109(a)(2)(A)","children":[],"tail":", which directed the insertion of “this section and” after “violation of”, was executed by making the insertion after first reference to “violation of” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s109/a/2/B"},"text":"Pub. L. 101–549, § 109(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/D/ii"},"text":"section 7410(a)(2)(D)(ii) of this title","children":[],"tail":" or this section” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/a/2/E/i"},"text":"section 7410(a)(2)(E)(i) of this title","children":[],"tail":"” in par. (1) and penultimate sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/190"},"text":"Pub. L. 95–190","children":[],"tail":" substituted “(relating to significant deterioration of air quality)” for “, relating to significant deterioration of air quality”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe2dda92-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe2dda93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
