{"tag":"section","attrib":{"id":"idc0169769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503"},"text":null,"children":[{"tag":"num","attrib":{"value":"16503"},"text":"§ 16503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugar ethanol loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc016976a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds may be provided for the cost (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":") of loan guarantees issued under title XIV "},{"tag":"ref","attrib":{"idref":"fn004229"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004229"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to carry out commercial demonstration projects for ethanol derived from sugarcane, bagasse, and other sugarcane byproducts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016976b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue loan guarantees under this section to projects to demonstrate commercially the feasibility and viability of producing ethanol using sugarcane, sugarcane bagasse, and other sugarcane byproducts as a feedstock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016976c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant for a loan guarantee under this section may provide assurances, satisfactory to the Secretary, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016976d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project design has been validated through the operation of a continuous process facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016976e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project has been subject to a full technical review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016976f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project, with the loan guarantee, is economically viable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable assurance of repayment of the guaranteed loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum guarantee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), a loan guarantee under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be issued for up to 80 percent of the estimated cost of a project; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed $50,000,000 for any 1 project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional guarantees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0169776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue additional loan guarantees for a project to cover—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0169777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 80 percent of the excess of actual project costs; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0169778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed 15 percent of the amount of the original loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16503/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal and interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (A), the Secretary shall guarantee 100 percent of the principal and interest of a loan guarantee made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc016977a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1516"},"text":"Pub. L. 109–58, title XV, § 1516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1091"},"text":"119 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc016977b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc016977c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc016977d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title XIV, referred to in subsec. (a), is title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1061"},"text":"119 Stat. 1061","children":[],"tail":", which enacted subchapter XIII of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13557"},"text":"section 13557 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
