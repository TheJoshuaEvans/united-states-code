{"tag":"section","attrib":{"id":"idbd120a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5161"},"text":null,"children":[{"tag":"num","attrib":{"value":"5161"},"text":"§ 5161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits and investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of chapter 75 of title 31, relating to requirements for single audits, the President shall conduct audits and investigations as necessary to assure compliance with this chapter, and in connection therewith may question such persons as may be necessary to carry out such audits and investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of audits and investigations under this section, the President and Comptroller General may inspect any books, documents, papers, and records of any person relating to any activity undertaken or funded under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may require audits by State and local governments in connection with assistance under this chapter when necessary to assure compliance with this chapter or related regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120a41-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s318"},"text":"Pub. L. 93–288, title III, § 318","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/m/1"},"text":"Pub. L. 100–707, title I, § 105(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4695"},"text":"102 Stat. 4695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a42-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a43-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120a44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd120a45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s318"},"text":"section 318 of Pub. L. 93–288","children":[],"tail":" was renumbered section 315 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5158"},"text":"section 5158 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
