{"tag":"section","attrib":{"id":"idb888b128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395a"},"text":"§ 1395a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free choice by patient guaranteed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb888b129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic freedom of choice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual entitled to insurance benefits under this subchapter may obtain health services from any institution, agency, or person qualified to participate under this subchapter if such institution, agency, or person undertakes to provide him such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb888b12a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of private contracts by medicare beneficiaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb888b12b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this subsection, nothing in this subchapter shall prohibit a physician or practitioner from entering into a private contract with a medicare beneficiary for any item or service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb888b12c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which no claim for payment is to be submitted under this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b12d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which the physician or practitioner receives—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b12e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no reimbursement under this subchapter directly or on a capitated basis, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b12f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives no amount for such item or service from an organization which receives reimbursement for such item or service under this subchapter directly or on a capitated basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb888b130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary protections","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb888b131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to any contract unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract is in writing and is signed by the medicare beneficiary before any item or service is provided pursuant to the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract contains the items described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract is not entered into at a time when the medicare beneficiary is facing an emergency or urgent health care situation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items required to be included in contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract to provide items and services to which paragraph (1) applies shall clearly indicate to the medicare beneficiary that by signing such contract the beneficiary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees not to submit a claim (or to request that the physician or practitioner submit a claim) under this subchapter for such items or services even if such items or services are otherwise covered by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to be responsible, whether through insurance or otherwise, for payment of such items or services and understands that no reimbursement will be provided under this subchapter for such items or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges that no limits under this subchapter (including the limits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/g"},"text":"section 1395w–4(g) of this title","children":[],"tail":") apply to amounts that may be charged for such items or services;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges that Medigap plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ss"},"text":"section 1395ss of this title","children":[],"tail":" do not, and other supplemental insurance plans may elect not to, make payments for such items and services because payment is not made under this subchapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b13a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges that the medicare beneficiary has the right to have such items or services provided by other physicians or practitioners for whom payment would be made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such contract shall also clearly indicate whether the physician or practitioner is excluded from participation under the medicare program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7"},"text":"section 1320a–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb888b13b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician or practitioner requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb888b13c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any contract entered into by a physician or practitioner unless an affidavit described in subparagraph (B) is in effect during the period any item or service is to be provided pursuant to the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b13d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An affidavit is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b13e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affidavit identifies the physician or practitioner and is in writing and is signed by the physician or practitioner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b13f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affidavit provides that the physician or practitioner will not submit any claim under this subchapter for any item or service provided to any medicare beneficiary (and will not receive any reimbursement or amount described in paragraph (1)(B) for any such item or service) during the applicable 2-year period (as defined in subparagraph (D)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the affidavit is filed with the Secretary no later than 10 days after the first contract to which such affidavit applies is entered into.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a physician or practitioner signing an affidavit under subparagraph (B) knowingly and willfully submits a claim under this subchapter for any item or service provided during the applicable 2-year period (or receives any reimbursement or amount described in paragraph (1)(B) for any such item or service) with respect to such affidavit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subsection shall not apply with respect to any items and services provided by the physician or practitioner pursuant to any contract on and after the date of such submission and before the end of such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no payment shall be made under this subchapter for any item or service furnished by the physician or practitioner during the period described in clause (i) (and no reimbursement or payment of any amount described in paragraph (1)(B) shall be made for any such item or service).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable 2-year periods for effectiveness of affidavits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “applicable 2-year period” means, with respect to an affidavit of a physician or practitioner under subparagraph (B), the 2-year period beginning on the date the affidavit is signed and includes each subsequent 2-year period unless the physician or practitioner involved provides notice to the Secretary (in a form and manner specified by the Secretary), not later than 30 days before the end of the previous 2-year period, that the physician or practitioner does not want to extend the application of the affidavit for such subsequent 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb888b145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on actual charge and claim submission requirement not applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/g"},"text":"Section 1395w–4(g) of this title","children":[],"tail":" shall not apply with respect to any item or service provided to a medicare beneficiary under a contract described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb888b146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting of information on opt-out physicians and practitioners","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb888b147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than ","children":[{"tag":"date","attrib":{"date":"2016-02-01"},"text":"February 1, 2016","children":[],"tail":", the Secretary shall make publicly available through an appropriate publicly accessible website of the Department of Health and Human Services information on the number and characteristics of opt-out physicians and practitioners and shall update such information on such website not less often than annually."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information to be made available under subparagraph (A) shall include at least the following with respect to opt-out physicians and practitioners:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb888b149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Their number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b14a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Their physician or professional specialty or other designation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b14b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Their geographic distribution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b14c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The timing of their becoming opt-out physicians and practitioners, relative, to the extent feasible, to when they first enrolled in the program under this subchapter and with respect to applicable 2-year periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb888b14d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proportion of such physicians and practitioners who billed for emergency or urgent care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb888b14e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb888b14f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare beneficiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medicare beneficiary” means an individual who is entitled to benefits under part A or enrolled under part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “physician” has the meaning given such term by paragraphs (1), (2), (3), and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/r"},"text":"section 1395x(r) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “practitioner” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u/b/18/C"},"text":"section 1395u(b)(18)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb888b152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395a/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opt-out physician or practitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “opt-out physician or practitioner” means a physician or practitioner who has in effect an affidavit under paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb888b153-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1802, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s102/a"},"text":"Pub. L. 89–97, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/291"},"text":"79 Stat. 291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4507/a/1"},"text":"Pub. L. 105–33, title IV, § 4507(a)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/439"},"text":"111 Stat. 439","children":[],"tail":", 441; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tVI/s603"},"text":"Pub. L. 108–173, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2301"},"text":"117 Stat. 2301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tI/s106/a/1/A"},"text":"Pub. L. 114–10, title I, § 106(a)(1)(A)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/137"},"text":"129 Stat. 137","children":[],"tail":", 138.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb888b154-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb888b155-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"t