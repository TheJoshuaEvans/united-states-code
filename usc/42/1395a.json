"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" substituted “paragraphs (1), (2), (3), and (4) of section 1395x(r)” for “section 1395x(r)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb888b157-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb888b158-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/tI/s106/a/1/B"},"text":"Pub. L. 114–10, title I, § 106(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/138"},"text":"129 Stat. 138","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/10/tI/s106/a/1/B"},"text":"“The amendments made by subparagraph (A) [amending this section] shall apply to affidavits entered into on or after the date that is 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb888b159-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4507/c"},"text":"Pub. L. 105–33, title IV, § 4507(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/442"},"text":"111 Stat. 442","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tIV/s4507/c"},"text":"“The amendment made by subsection (a) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395y"},"text":"section 1395y of this title","children":[],"tail":"] shall apply with respect to contracts entered into on and after "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb888b15a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Updating the Welcome to Medicare Package","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dC/tXVII/s17003"},"text":"Pub. L. 114–255, div. C, title XVII, § 17003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1331"},"text":"130 Stat. 1331","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/255/dC/tXVII/s17003"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 12 months after the last day of the period for the request of information described in subsection (b), the Secretary of Health and Human Services shall, taking into consideration information collected pursuant to subsection (b), update the information included in the Welcome to Medicare package to include information, presented in a clear and simple manner, about options for receiving benefits under the Medicare program under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.), including through the original medicare fee-for-service program under parts A and B of such title ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.), Medicare Advantage plans under part C of such title ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21"},"text":"42 U.S.C. 1395w–21","children":[],"tail":" et seq.), and prescription drug plans under part D of such title ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–101"},"text":"42 U.S.C. 1395w–101","children":[],"tail":" et seq.)). The Secretary shall make subsequent updates to the information included in the Welcome to Medicare package as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":"], the Secretary of Health and Human Services shall request information, including recommendations, from stakeholders (including patient advocates, issuers, and employers) on information included in the Welcome to Medicare package, including pertinent data and information regarding enrollment and coverage for Medicare eligible individuals.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb888b15b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Effect of Private Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4507/b"},"text":"Pub. L. 105–33, title IV, § 4507(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/441"},"text":"111 Stat. 441","children":[],"tail":", required a report to be submitted to Congress, no later than "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"Oct. 1, 2001","children":[],"tail":", on the effect on the program under title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" of certain private contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
