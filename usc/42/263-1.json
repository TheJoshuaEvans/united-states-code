{"tag":"section","attrib":{"id":"idb511d9a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"263–1"},"text":"§ 263–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education on biological products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb511d9a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet website","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb511d9a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may maintain and operate an internet website to provide educational materials for health care providers, patients, and caregivers, regarding the meaning of the terms, and the standards for review and licensing of, biological products, including biosimilar biological products and interchangeable biosimilar biological products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511d9a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Educational materials provided under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511d9a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explanations of key statutory and regulatory terms, including “biosimilar” and “interchangeable”, and clarification regarding the use of interchangeable biosimilar biological products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511d9a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information related to development programs for biological products, including biosimilar biological products and interchangeable biosimilar biological products and relevant clinical considerations for prescribers, which may include, as appropriate and applicable, information related to the comparability of such biological products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511d9a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the process for reporting adverse events for biological products, including biosimilar biological products and interchangeable biosimilar biological products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511d9aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the relationship between biosimilar biological products and interchangeable biosimilar biological products licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/k"},"text":"section 262(k) of this title","children":[],"tail":" and reference products (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s262/i"},"text":"section 262(i) of this title","children":[],"tail":"), including the standards for review and licensing of each such type of biological product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511d9ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The educational materials provided under paragraph (1) may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511d9ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in formats such as webinars, continuing education modules, videos, fact sheets, infographics, stakeholder toolkits, or other formats as appropriate and applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511d9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tailored for the unique needs of health care providers, patients, caregivers, and other audiences, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511d9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the information described in paragraph (2), the Secretary shall continue to publish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511d9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action package of each biological product licensed under subsection (a) or (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511d9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the summary review of each biological product licensed under subsection (a) or (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511d9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential and trade secret information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection does not authorize the disclosure of any trade secret, confidential commercial or financial information, or other matter described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb511d9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall advance education and awareness among health care providers regarding biological products, including biosimilar biological products and interchangeable biosimilar biological products, as appropriate, including by developing or improving continuing education programs that advance the education of such providers on the prescribing of, and relevant clinical considerations with respect to, biological products, including biosimilar biological products and interchangeable biosimilar biological products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb511d9b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 352A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/8/s2"},"text":"Pub. L. 117–8, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-04-23"},"text":"Apr. 23, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/254"},"text":"135 Stat. 254","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
