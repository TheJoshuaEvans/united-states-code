{"tag":"section","attrib":{"id":"idbc79739b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215"},"text":null,"children":[{"tag":"num","attrib":{"value":"3215"},"text":"§ 3215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc79739c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements; security overvaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person that makes any statement that the person knows to be false, or willfully overvalues any security, for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc79739d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining for the person or for any applicant any financial assistance under this chapter or any extension of the assistance by renewal, deferment, or action, or by any other means, or the acceptance, release, or substitution of security for the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79739e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" influencing in any manner the action of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79739f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining money, property, or any thing of value, under this chapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under title 18, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7973a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Embezzlement and fraud-related crimes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person that is connected in any capacity with the Secretary in the administration of this chapter and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embezzles, abstracts, purloins, or willfully misapplies any funds, securities, or other thing of value, that is pledged or otherwise entrusted to the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with intent to defraud the Secretary or any other person or entity, or to deceive any officer, auditor, or examiner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7973a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any false entry in any book, report, or statement of or to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7973a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without being duly authorized, draws any order or issue, puts forth, or assigns any note, debenture, bond, or other obligation, or draft, bill of exchange, mortgage, judgment, or decree thereof;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, participates or shares in or receives directly or indirectly any money, profit, property, or benefit through any transaction, loan, grant, commission, contract, or any other act of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3215/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives any unauthorized information concerning any future action or plan of the Secretary that might affect the value of securities, or having such knowledge invests or speculates, directly or indirectly, in the securities or property of any company or corporation receiving loans, grants, or other assistance from the Secretary;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under title 18, imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7973a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s605"},"text":"Pub. L. 89–136, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3614"},"text":"112 Stat. 3614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7973aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3215, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s705"},"text":"Pub. L. 89–136, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/573"},"text":"79 Stat. 573","children":[],"tail":", related to separability of provisions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7973ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7973ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
