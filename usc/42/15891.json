{"tag":"section","attrib":{"id":"idbfe6fb64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891"},"text":null,"children":[{"tag":"num","attrib":{"value":"15891"},"text":"§ 15891.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects enhancing insular energy independence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe6fb65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project feasibility studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On a request described in paragraph (2), the Secretary shall conduct a feasibility study of a project to implement a strategy or project identified in the plans submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1492"},"text":"section 1492 of title 48","children":[],"tail":" as having the potential to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly reduce the dependence of an insular area on imported fossil fuels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide needed distributed generation to an insular area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a feasibility study under paragraph (1) on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request of an electric utility located in an insular area that commits to fund at least 10 percent of the cost of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the electric utility is located in the Federated States of Micronesia, the Republic of the Marshall Islands, or the Republic of Palau, written support for that request by the President or the Ambassador of the affected freely associated state.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consult with regional utility organizations in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting feasibility studies under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the feasibility of potential projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of a feasibility study under paragraph (1), a project shall be determined to be feasible if the project would significantly reduce the dependence of an insular area on imported fossil fuels, or provide needed distributed generation to an insular area, at a reasonable cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a determination by the Secretary (in consultation with the Secretary of the Interior) that a project is feasible under subsection (a) and a commitment by an electric utility to operate and maintain the project, the Secretary may provide such technical and financial assistance as the Secretary determines is appropriate for the implementation of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional utility organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under paragraph (1), the Secretary shall consider providing the assistance through regional utility organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe6fb73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe6fb74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe6fb75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000 for each fiscal year for project feasibility studies under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe6fb76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for each fiscal year for project implementation under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe6fb77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15891/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of funds received by insular areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No insular area may receive, during any 3-year period, more than 20 percent of the total funds made available during that 3-year period under subparagraphs (A) and (B) of paragraph (1) unless the Secretary determines that providing funding in excess of that percentage best advances existing opportunities to meet the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe6fb78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s252"},"text":"Pub. L. 109–58, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/682"},"text":"119 Stat. 682","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
