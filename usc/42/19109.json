{"tag":"section","attrib":{"id":"idc07ad7c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109"},"text":null,"children":[{"tag":"num","attrib":{"value":"19109"},"text":"§ 19109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translation Accelerator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07ad7c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish Translation Accelerators to further the research, development, and commercialization of innovation in the key technology focus areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07ad7ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad7cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Translation Accelerator shall be comprised of a partnership including 2 or more of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc07ad7cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A for-profit company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc07ad7d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Another entity, if that entity is determined by the Director to be vital to the success of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutional or organizational level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall work to ensure that such partnerships exist at the institutional or organization level, rather than solely at the principal investigator level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 25 percent of the funding for an institute shall be provided by non-Federal entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad7d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of centers and institutes established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall endeavor to establish a balance in the number of Regional Innovation Engines and Translation Accelerators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07d20c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From within funds authorized for the Directorate for Technology, Innovation, and Partnerships, there are authorized to carry out the activities under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19108"},"text":"section 19108 of this title","children":[],"tail":" $6,500,000,000 for fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07d20c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10389"},"text":"Pub. L. 117–167, div. B, title III, § 10389","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1584"},"text":"136 Stat. 1584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
