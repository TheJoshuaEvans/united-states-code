illicitly use drugs” for “individuals who abuse drugs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/c/2/D"},"text":"Pub. L. 114–255, § 6007(c)(2)(D)","children":[],"tail":", struck out “carried out by the Director” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6007/c/2"},"text":"Pub. L. 114–255, § 6007(c)(2)","children":[],"tail":"E–(H), added pars. (13) and (14), redesignated pars. (11) to (14) as (10) to (13), respectively, struck out former par. (10), which related to encouraging the States to expand the availability (relative to fiscal year 1992) of programs providing treatment services, and struck out par. (13), as redesignated, which related to assessing the quality, appropriateness, and costs of various treatment forms."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/a/1"},"text":"Pub. L. 106–310, § 3112(a)(1)","children":[],"tail":", (2), added pars. (2) and (3) and redesignated former pars. (2) to (4) as (4) to (6), respectively. Former pars. (5) and (6) redesignated (7) and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/a/1"},"text":"Pub. L. 106–310, § 3112(a)(1)","children":[],"tail":", (3), redesignated par. (5) as (7) and substituted “services” for “services, and monitor the use of revolving loan funds pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–25"},"text":"section 300x–25 of this title","children":[],"tail":"”. Former par. (7) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/a/1"},"text":"Pub. L. 106–310, § 3112(a)(1)","children":[],"tail":", redesignated pars. (6) to (10) as (8) to (12), respectively. Former pars. (11) and (12) redesignated (13) and (14), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/a/1"},"text":"Pub. L. 106–310, § 3112(a)(1)","children":[],"tail":", (4), redesignated par. (11) as (13) and substituted “treatment, which shall” for “treatment, including the effect of living in housing provided by programs established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–25"},"text":"section 300x–25 of this title","children":[],"tail":", which shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3112/a/1"},"text":"Pub. L. 106–310, § 3112(a)(1)","children":[],"tail":", (5), redesignated par. (12) as (14) and substituted “paragraph (13)” for “paragraph (11)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5a0fac6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5a0fac7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
