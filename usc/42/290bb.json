{"tag":"section","attrib":{"id":"idb5a0faad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb"},"text":"§ 290bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Substance Abuse Treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a0faae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Administration a Center for Substance Abuse Treatment (hereafter in this section referred to as the “Center”). The Center shall be headed by a Director (hereafter in this section referred to as the “Director”) appointed by the Secretary from among individuals with extensive experience or academic qualifications in the treatment of substance use disorders or in the evaluation of substance use disorder treatment systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a0faaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a0fab0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the substance use disorder treatment block grant program authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that emphasis is placed on children and adolescents in the development of treatment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Attorney General to develop programs to provide substance use disorder treatment services to individuals who have had contact with the Justice system, especially adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Director of the Center for Substance Abuse Prevention in order to provide outreach services to identify individuals in need of treatment services, with emphasis on the provision of such services to pregnant and postpartum women and their infants and to individuals who illicitly use drugs intravenously;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Director of the National Institute on Drug Abuse, with the Director of the National Institute on Alcohol Abuse and Alcoholism, and with the States to promote the study, dissemination, and implementation of research findings that will improve the delivery and effectiveness of treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the Administrator of the Health Resources and Services Administration and the Administrator of the Centers for Medicare & Medicaid Services to promote the increased integration into the mainstream of the health care system of the United States of programs for providing treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate plans submitted by the States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/a/6"},"text":"section 300x–32(a)(6) of this title","children":[],"tail":" in order to determine whether the plans adequately provide for the availability, allocation, and effectiveness of treatment services;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor regional workshops on improving the quality and availability of treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to public and nonprofit private entities that provide treatment services, including technical assistance with respect to the process of submitting to the Director applications for any program of grants or contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out activities to educate individuals on the need for establishing treatment facilities within their communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0faba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage public and private entities that provide health insurance to provide benefits for outpatient treatment services and other nonhospital-based treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fabb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate treatment programs to determine the quality and appropriateness of various forms of treatment, which shall be carried out through grants, contracts, or cooperative agreements provided to public or nonprofit private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fabc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the consistent documentation of the application of criteria when awarding grants and the ongoing oversight of grantees after such grants are awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fabd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States, providers, and individuals in recovery, and their families, to promote the expansion of recovery support services and systems of care oriented toward recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fabe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Secretary, implement and disseminate, as appropriate, the recommendations in the report entitled “Protecting Our Infants Act: Final Strategy” issued by the Department of Health and Human Services in 2017; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a0fabf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with relevant stakeholders, and through public-private partnerships, encourage education about substance use disorders for pregnant women and health care providers who treat pregnant women and babies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a0fac0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties established in subsection (b), the Director may make grants to and enter into contracts and cooperative agreements with public and nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a0fac1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s107/2"},"text":"Pub. L. 102–321, title I, § 107(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/335"},"text":"106 Stat. 335","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXI/s3112/a"},"text":"Pub. L. 106–310, div. B, title XXXI, § 3112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1188"},"text":"114 Stat. 1188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/e/2/B"},"text":"Pub. L. 108–173, title IX, § 900(e)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2372"},"text":"117 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVI/s6007/c"},"text":"Pub. L. 114–255, div. B, title VI, § 6007(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1214"},"text":"130 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/2