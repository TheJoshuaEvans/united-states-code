{"tag":"section","attrib":{"id":"idbb8639f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862e"},"text":"§ 1862e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations of research centers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out performance reviews of research centers by the Foundation, the Director shall take such action as may be necessary, consistent with the merit review process of the Foundation, to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8639fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of review panels are free from any conflict of interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8639fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions of each award to such centers have been fulfilled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8639fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tI/s109"},"text":"Pub. L. 100–570, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2869"},"text":"102 Stat. 2869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8639fd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8639fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8639ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1988, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
