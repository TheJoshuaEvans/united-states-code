{"tag":"section","attrib":{"id":"idc07866d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083"},"text":null,"children":[{"tag":"num","attrib":{"value":"19083"},"text":"§ 19083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helium conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07866d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major research instrumentation support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall support, through the Major Research Instrumentation program, proposal requests that include the purchase, installation, operation, and maintenance of equipment and instrumentation to reduce consumption of helium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may waive the cost-sharing requirement for helium conservation measures for non-Ph.D.-granting institutions of higher education and Ph.D.-granting institutions of higher education that are not ranked among the top 100 institutions receiving Federal research and development funding, as documented by the National Center for Science and Engineering Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and annually for the subsequent two years, the Director shall submit an annual report to Congress on the use of funding awarded by the Foundation for the purchase and conservation of helium. The report should include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07866d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume and price of helium purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in pricing and availability of helium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07866da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19083/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any supply disruptions impacting a substantial number of institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07866db-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10373"},"text":"Pub. L. 117–167, div. B, title III, § 10373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1571"},"text":"136 Stat. 1571","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
