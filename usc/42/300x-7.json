{"tag":"section","attrib":{"id":"idb666e30b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–7"},"text":"§ 300x–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb666e30c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e30d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary shall determine the amount of the allotment required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a State for a fiscal year in accordance with the following formula:"},{"tag":"html:table","attrib":{"width":"50%","id":"idb666e30e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"A","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"A","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"X","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"U","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e30f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “A”","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “A” means the difference between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–9/a"},"text":"section 300x–9(a) of this title","children":[],"tail":" for allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for the fiscal year involved; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 1.5 percent of the amount referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “U”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “U” means the sum of the respective terms “X” determined for the States under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “X”","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “X” means the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount equal to the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “P”, as determined for the State involved under paragraph (5); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factor determined under paragraph (8) for the State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.4; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to an amount determined for the State in accordance with the following formula:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb666e31a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1−.35","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"A","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R%","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{"rowspan":"2"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"P%","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e31b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “P”","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e31c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (4), the term “P” means the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e31d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the product of 0.107 and the number of individuals in the State who are between 18 and 24 years of age (inclusive);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e31e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the product of 0.166 and the number of individuals in the State who are between 25 and 44 years of age (inclusive);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e31f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the product of 0.099 and the number of individuals in the State who are between 45 and 64 years of age (inclusive); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the product of 0.082 and the number of individuals in the State who are 65 years of age or older.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to data on population that is necessary for purposes of making a determination under subparagraph (A), the Secretary shall use the most recent data that is available from the Secretary of Commerce pursuant to the decennial census and pursuant to reasonable estimates by such Secretary of changes occurring in the data in the ensuing period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “R%”","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (4), the term “R%”, except as provided in subparagraph (D), means the percentage constituted by the ratio of the amount determined under subparagraph (B) for the State involved to the amount determined under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount determined under this subparagraph for the State involved is the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent 3-year arithmetic mean of the total taxable resources of the State, as determined by the Secretary of the Treasury; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factor determined under paragraph (8) for the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount determined under this subparagraph is the sum of the respective amounts determined for the States under subparagraph (B) (including the District of Columbia).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of the District of Columbia, for purposes of paragraph (4), the term “R%” means the percentage constituted by the ratio of the amount determined under clause (ii) for such District to the amount determined under clause (iii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e32a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount determined under this clause for the District of Columbia is the quotient of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb666e32b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent 3-year arithmetic mean of total personal income in such District, as determined by the Secretary of Commerce; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb666e32c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factor determined under paragraph (8) for the District.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e32d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/6/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount determined under this clause is the sum of the respective amounts determined for the States (including the District of Columbia) by making, for each State, the same determination as is described in clause (ii) for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e32e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of term “P%”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (4), the term “P%” means the percentage constituted by the ratio of the term “P” determined under paragraph (5) for the State involved to the sum of the respective terms “P” determined for the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e32f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of certain factor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The factor determined under this paragraph for the State involved is a factor whose purpose is to adjust the amount determined under clause (i) of paragraph (4)(A), and the amounts determined under each of subparagraphs (B)(i) and (D)(ii)(I) of paragraph (6), to reflect the differences that exist between the State and other States in the costs of providing comprehensive community mental health services to adults with a serious mental illness and to children with a serious emotional disturbance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (C), the factor determined under this paragraph and in effect for the fiscal year involved shall be determined according to the methodology described in the report entitled “Adjusting the Alcohol, Drug Abuse and Mental Health Services Block Grant Allocations for Poverty Populations and Cost of Service”, dated ","children":[{"tag":"date","attrib":{"date":"1990-03-30"},"text":"March 30, 1990","children":[],"tail":", and prepared by Health Economics Research, a corporation, pursuant to a contract with the National Institute on Drug Abuse."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The factor determined under this paragraph for the State involved may not for any fiscal year be greater than 1.1 or less than 0.9.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", the Secretary, after consultation with the Comptroller General, shall in accordance with this section make a determination for each State of the factor that is to be in effect for the State under this paragraph. The factor so determined shall remain in effect through fiscal year 1994, and shall be recalculated every third fiscal year thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/a/8/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consultation with the Comptroller General, the Secretary shall, through publication in the Federal Register, periodically make such refinements in the methodology referred to in subparagraph (B) as are consistent with the purpose described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments for States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to fiscal year 2000, and subsequent fiscal years, the amount of the allotment of a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" shall not be less than the amount the State received under such section for fiscal year 1998."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (4), the amount of an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a territory of the United States for a fiscal year shall be the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amounts reserved under paragraph (3) for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e33a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e33b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civilian population of the territory, as indicated by the most recently available data; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e33c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate civilian population of the territories of the United States, as indicated by such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e33d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment for territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a territory of the United States for a fiscal year shall be the greater of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e33e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (1) for the territory for the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e33f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to fiscal years 1993 and 1994, an amount equal to 20.6 percent of the amount received by the territory from allotments made pursuant to this part for fiscal year 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall each fiscal year reserve for the territories of the United States 1.5 percent of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–9/a"},"text":"section 300x–9(a) of this title","children":[],"tail":" for allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of data on population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to data on the civilian population of the territories of the United States, if the Secretary determines for a fiscal year that recent such data for purposes of paragraph (1)(B) do not exist regarding a territory, the Secretary shall for such purposes estimate the civilian population of the territory by modifying the data on the territory to reflect the average extent of change occurring during the ensuing period in the population of all territories with respect to which recent such data do exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–7/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the term “State” does not include the territories of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb666e344-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1918, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/385"},"text":"106 Stat. 385","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/8"},"text":"Pub. L. 102–352, § 2(a)(8)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/938"},"text":"106 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tII/s218/a"},"text":"Pub. L. 105–277, div. A, § 101(f) [title II, § 218(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–362; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/4/tII/s212/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(4) [title II, § 212(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–239; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3205"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb666e345-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb666e346-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb666e347-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300x–7, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIX/s1919"},"text":"act July 1, 1944, ch. 373, title XIX, § 1919","children":[],"tail":", formerly § 1918, as added "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/551"},"text":"95 Stat. 551","children":[],"tail":"; renumbered § 1919 and amended "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/509/tI/s106/a"},"text":"Pub. L. 98–509, title I, § 106(a)","children":[],"tail":", (g), "},{"tag":"ref","attrib":{"href":"/us/stat/98/2358"},"text":"98 Stat. 2358","children":[],"tail":", 2359, related to nondiscrimination provisions with respect to alcohol, drug abuse, and mental health programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/s201/2"},"text":"Pub. L. 102–321, § 201(2)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1918 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–6"},"text":"section 300x–6 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb666e348-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “With respect to fiscal year 2000, the amount of the allotment of a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" shall not be less than the amount the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for fiscal year 1998.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “For each of the fiscal years 1993 and 1994, the amount of the allotment required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a State for the fiscal year involved shall be the greater of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the amount determined under subsection (a) of this section for the State for the fiscal year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) an amount equal to 20.6 percent of the amount received by the State from allotments made pursuant to this part for fiscal year 1992 (including reallotments under section 205(a) of the ADAMHA Reorganization Act).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", temporarily amended subsec. (b) to read as follows: “(b) "},{"tag":"inline","attrib":{},"text":"Minimum allotments for States.—","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—With respect to fiscal year 1999, the amount of the allotment of a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" shall not be less than the amount the State received under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for fiscal year 1998.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See Effective and Termination Dates of 1998 Amendment note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(5)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/8"},"text":"Pub. L. 102–352, § 2(a)(8)","children":[],"tail":", substituted “45” for “25”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/9"},"text":"Pub. L. 102–352, § 2(a)(9)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb666e349-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb669534a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tII/s218/c"},"text":"Pub. L. 105–277, div. A, § 101(f) [title II, § 218(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–363, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/f/tII/s218/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–33"},"text":"section 300x–33 of this title","children":[],"tail":"] shall become effective as if enacted on "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":" and shall only apply during fiscal year 1999."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the expiration of the fiscal year described in paragraph (1), the provisions of sections 1918(b) and 1933(b) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–7/b"},"text":"42 U.S.C. 300x–7(b)","children":[],"tail":" and 300x–33(b)), as in effect on "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", shall be applied as if the amendments made by this section had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb669534b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" effective immediately upon effectuation of amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s3/1"},"text":"section 3(1) of Pub. L. 102–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
