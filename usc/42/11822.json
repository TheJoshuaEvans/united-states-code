{"tag":"section","attrib":{"id":"idbf57db6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11822"},"text":null,"children":[{"tag":"num","attrib":{"value":"11822"},"text":"§ 11822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the end of a fiscal year for which funds are appropriated to carry out this subchapter, the Secretary shall submit to the President, the Speaker of the House of Representatives, and the President pro tempore of the Senate a report that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11822/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of projects and activities for which grants were made under this subchapter for such fiscal year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11822/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the number and characteristics of the youth and families served by such projects and activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11822/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of exemplary projects and activities for which grants were made under this subchapter for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57db72-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3512"},"text":"Pub. L. 100–690, title III, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4256"},"text":"102 Stat. 4256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57db73-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf57db74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf57db75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under this section is listed as the 12th item on page 92), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
