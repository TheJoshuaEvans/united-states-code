{"tag":"section","attrib":{"id":"idbff52c87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153"},"text":null,"children":[{"tag":"num","attrib":{"value":"16153"},"text":"§ 16153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall transmit to Congress a coordinated plan for the programs described in this subchapter and any other programs of the Department that are directly related to fuel cells or hydrogen. The plan shall describe, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agenda for the next 5 years for the programs authorized under this subchapter, including the agenda for each activity enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16154/e"},"text":"section 16154(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of entities that will carry out the activities under this subchapter and what role each entity is expected to play;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the milestones that will be used to evaluate the programs for the next 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most significant technical and nontechnical hurdles that stand in the way of achieving the goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16154"},"text":"section 16154 of this title","children":[],"tail":", and how the programs will address those hurdles; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16153/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policy assumptions that are implicit in the plan, including any assumptions that would affect the sources of hydrogen or the marketability of hydrogen-related products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c8d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s804"},"text":"Pub. L. 109–58, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/845"},"text":"119 Stat. 845","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
