{"tag":"section","attrib":{"id":"idbe9b694a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532"},"text":null,"children":[{"tag":"num","attrib":{"value":"8532"},"text":"§ 8532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Middle distillate monitoring program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe9b694b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe9b694c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1979-11-05"},"text":"November 5, 1979","children":[],"tail":", the Secretary shall establish and maintain a data collection program for monitoring, at the refining, wholesale, and retail levels, the supply and demand levels of middle distillates on a periodic basis in each State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9b694d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The program to be established under paragraph (1) shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe9b694e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prompt collection of relevant demand and supply data under the authority available to the Secretary under other law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe9b694f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission to Congress of periodic reports each containing a concise narrative analysis of the most recent data which the Secretary determines are accurate, and a discussion on a State-by-State basis of trends in such data which the Secretary determines are significant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9b6950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All data and information collected under this program shall be available to the Congress and committees of the Congress, and, in accordance with otherwise applicable law, to appropriate State and Federal agencies and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9b6951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection authorizes the direct or indirect regulation of the price of any middle distillate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9b6952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “middle distillate” has the same meaning as given that term in section 211.51 of title 10, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1979-11-05"},"text":"November 5, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe9b6953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"1979-12-31"},"text":"December 31, 1979","children":[],"tail":", the President shall submit a report to Congress in which the President shall examine the middle distillate situation, summarizing the data, information, and analyses described in subsection (a) and discussing in detail matters required to be addressed in findings made pursuant to section 760a(d)(1) "},{"tag":"ref","attrib":{"idref":"fn003846"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003846"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 15."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe9b6954-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tII/s242"},"text":"Pub. L. 96–102, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/768"},"text":"93 Stat. 768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe9b6955-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe9b6956-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe9b6957-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s760a"},"text":"Section 760a of title 15","children":[],"tail":", referred to in subsec. (b), was omitted from the Code pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s760g"},"text":"section 760g of Title 15","children":[],"tail":", Commerce and Trade, which provided for the expiration of the President’s authority under that section on "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
