{"tag":"section","attrib":{"id":"idbb9491ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862q"},"text":"§ 1862q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informal STEM education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb9491ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation, through the Directorate for Education and Human Resources, shall continue to award competitive, merit-reviewed grants to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9491af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development of innovative out-of-school STEM learning and emerging STEM learning environments in order to improve STEM learning outcomes and engagement in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research that advances the field of informal STEM education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national partnership of institutions involved in informal STEM learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of art and design in STEM educational programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9491b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities supported by grants under this section may encompass a single STEM discipline, multiple STEM disciplines, or integrative STEM initiatives and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9491b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development that improves our understanding of learning and engagement in informal environments, including the role of informal environments in broadening participation in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and testing of innovative STEM learning models, programs, and other resources for informal learning environments to improve STEM learning outcomes and increase engagement for K–12 students, K–12 teachers, and the general public, including design and testing of the scalability of models, programs, and other resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering on-going partnerships between institutions involved in informal STEM learning, institutions of higher education, and education research centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, and making available informal STEM education activities and educational materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and testing of programming that integrates art and design in STEM education to promote creativity and innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9491b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PreK–12 informal STEM","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9491ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall make awards, through existing programs where appropriate to institutions of higher education and nonprofit organizations (or consortia of such intuitions ","children":[{"tag":"ref","attrib":{"idref":"fn003217"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003217"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “institutions”."}],"tail":" or organizations) on a merit-reviewed, competitive basis for research on effective approaches to engaging students in PreK–12, including students from groups historically underrepresented in STEM and rural students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subsection are to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide effective, compelling, and engaging means for teaching and reinforcing fundamental STEM concepts to PreK–12 students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the STEM workforce pipeline by increasing the number of youth in the United States exposed to STEM from an early age and encourage them to pursue careers in STEM-related fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broaden participation of groups historically underrepresented in STEM and rural students, in the STEM workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards made under this subsection shall support research and development on innovative before-school, after-school, out-of-school, or summer activities that are designed to encourage interest, engagement, and skills development in STEM, including for students from groups historically underrepresented in STEM and rural students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research and development activities described in subparagraph (A) may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb9491c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of programming described in such subparagraph for the purpose of research described in such subparagraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a variety of engagement methods, including cooperative and hands-on learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exposure of students to role models in the fields of STEM and near-peer mentors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of informal learning educators, youth-serving professionals, and volunteers who lead informal STEM programs in using evidence-based methods consistent with the target student population being served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education of students on the relevance and significance of STEM careers, provision of academic advice and assistance, and activities designed to help students make real-world connections to STEM content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of students to attend events, competitions, and academic programs that provide content expertise and encourage career exposure in STEM, which may include the purchase of parts and supplies needed to prepare for participation in such competitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities designed to engage parents and families of students in PreK–12 in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative strategies to engage students, such as using leadership skills and outcome measures to impart youth with the confidence to pursue STEM coursework and academic study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with STEM-rich environments, including other nonprofit, nongovernmental organizations, out-of- ","children":[{"tag":"ref","attrib":{"idref":"fn003218"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003218"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" classroom settings, institutions of higher education, vocational facilities, corporations, museums, or science centers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/3/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of instructional materials or technology-based tools to conduct applicable award activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant seeking funding under this subsection shall submit an application at such time, in such manner, and containing such information as may be required by the Director. Applications that include or partner with a nonprofit, nongovernmental organization that has extensive experience and expertise in increasing the participation of students in PreK–12 in STEM are encouraged. At a minimum, the application shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the target audience to be served by the research activity or activities for which such funding is sought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the process for recruitment and selection of students to participate in such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how such activity or activities may inform programming that engages students in PreK–12 in STEM.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how such activity or activities may inform programming that promotes student academic achievement in STEM.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation plan that includes, at a minimum, the use of outcome-oriented measures to determine the impact and efficacy of programming being researched.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of an award under this subsection shall provide, at the conclusion of every year during which the award funds are received, a report in a form prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encourage applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this subsection, the Director shall encourage applications which, for the purpose of the activity or activities funded through the award, are from or include eligible nonprofit programs serving students that attend elementary schools or secondary schools (including high schools) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are implementing comprehensive support and improvement activities or targeted support and improvement activities under paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/d"},"text":"section 6311(d) of title 20","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve high percentages of students who are eligible for a free or reduced-price lunch under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) (which, in the case of a high school, may be calculated using comparable data from the schools that feed into the high school)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and dissemination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb9491d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall evaluate the activities established under this subsection. Such evaluation shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb9491d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a common set of benchmarks and tools to assess the results of research conducted under such awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, integrate the findings of the research resulting from the activity or activities funded through the award with the current research on serving students with respect to the pursuit of degrees or careers in STEM, including underrepresented and rural students, in PreK–12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb9491da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the completion of the evaluation under subparagraph (A), the Director shall submit to Congress and make widely available to the public a report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb9491db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb9491dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for administrative and legislative action that could optimize the effectiveness of the program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9491dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862q/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall, for purposes of enhancing program effectiveness and avoiding duplication of activities, consult, and coordinate with other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9491de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/59/s3"},"text":"Pub. L. 114–59, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-10-07"},"text":"Oct. 7, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/540"},"text":"129 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s311"},"text":"Pub. L. 114–329, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3013"},"text":"130 Stat. 3013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII"},"text":"Pub. L. 117–167, div. B, title III","children":[],"tail":", §§ 10311(b), 10319(b), "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1511"},"text":"136 Stat. 1511","children":[],"tail":", 1536.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9491df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9491e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb9491e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (c)(6)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9491e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the STEM Education Act of 2015, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb9491e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10319/b/1"},"text":"Pub. L. 117–167, § 10319(b)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10319/b/2"},"text":"Pub. L. 117–167, § 10319(b)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10311/b"},"text":"Pub. L. 117–167, § 10311(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s311/a"},"text":"Pub. L. 114–329, § 311(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)