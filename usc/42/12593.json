{"tag":"section","attrib":{"id":"idbf7b9036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593"},"text":null,"children":[{"tag":"num","attrib":{"value":"12593"},"text":"§ 12593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7b9037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a national service education award under division D, a participant in an approved national service position shall be required to perform full- or part-time national service for at least one term of service specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b9039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual performing full-time national service in an approved national service position shall agree to participate in the program sponsoring the position for not less than 1,700 hours during a period of not more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b903a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part-time service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), an individual performing part-time national service in an approved national service position shall agree to participate in the program sponsoring the position for not less than 900 hours during a period of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b903b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction in hours of part-time service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may reduce the number of hours required to be served to successfully complete part-time national service to a level determined by the Corporation, except that any reduction in the required term of service shall include a corresponding reduction in the amount of any national service educational award that may be available under division D with regard to that service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b903c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of term for disaster purposes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b903d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual in an approved national service position performing service directly related to disaster relief efforts may continue in a term of service for a period of 90 days beyond the period otherwise specified in, as appropriate, this subsection or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12613/d"},"text":"section 12613(d) of this title","children":[],"tail":" or in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4954"},"text":"section 4954 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b903e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single term of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A period of service performed by an individual in an originally-agreed to ","children":[{"tag":"ref","attrib":{"idref":"fn004065"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004065"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “originally-agreed-to”."}],"tail":" term of service and service performed under this paragraph shall constitute a single term of service for purposes of subsections (b)(1) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602"},"text":"section 12602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b903f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual performing service under this paragraph may continue to receive a living allowance and other benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594"},"text":"section 12594 of this title","children":[],"tail":" but may not receive an additional national service educational award under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12595"},"text":"section 12595 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release from completing term of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b9041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or a program sponsoring an approved national service position may release a participant from completing a term of service in the position—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b9042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for compelling personal circumstances as determined by the organization responsible for granting the release, if the participant has otherwise performed satisfactorily and has completed at least 15 percent of the term of service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b9043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b9044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of release for compelling circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a participant eligible for release under paragraph (1)(A) is serving in an approved national service position, the recipient of assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or a program sponsoring an approved national service position may elect—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b9045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grant such release and certify the participant’s eligibility for that portion of the national service educational award corresponding to the portion of the term of service actually completed, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12603/c"},"text":"section 12603(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b9046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the participant to temporarily suspend performance of the term of service for a period of up to 2 years (and such additional period as the Corporation may allow for extenuating circumstances) and, upon completion of such period, to complete the remainder of the term of service and obtain the entire national service educational award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b9047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12593/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of release for cause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant released for cause may not receive any portion of the national service educational award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7b9048-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s139"},"text":"Pub. L. 101–610, title I, § 139","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/810"},"text":"107 Stat. 810","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1314"},"text":"Pub. L. 111–13, title I, § 1314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1510"},"text":"123 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7b9049-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7b904a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf7b904b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/1/A"},"text":"Pub. L. 111–13, § 1314(1)(A)","children":[],"tail":", struck out “not less than 9 months and” before “not more than 1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/1/B"},"text":"Pub. L. 111–13, § 1314(1)(B)","children":[],"tail":", substituted “during a period of not more than 2 years.” for “during a period of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) not more than 2 years; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not more than 3 years if the individual is enrolled in an institute of higher education while preforming all or a portion of the service.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/1/C"},"text":"Pub. L. 111–13, § 1314(1)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/2/A"},"text":"Pub. L. 111–13, § 1314(2)(A)","children":[],"tail":", substituted “as determined by the organization responsible for granting the release, if the participant has otherwise performed satisfactorily and has completed at least 15 percent of the term of service” for “as demonstrated by the participant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/2/B/i"},"text":"Pub. L. 111–13, § 1314(2)(B)(i)","children":[],"tail":", substituted “certify the participant’s eligibility for that portion of the national service educational award” for “provide to the participant that portion of the national service educational award”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1314/2/B/ii"},"text":"Pub. L. 111–13, § 1314(2)(B)(ii)","children":[],"tail":", struck out “to allow return to the program with which the individual was serving in order” before “to complete the remainder”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7b904c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf7b904d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7b904e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
