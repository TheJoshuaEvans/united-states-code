{"tag":"section","attrib":{"id":"idbfdfd00a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101"},"text":null,"children":[{"tag":"num","attrib":{"value":"15101"},"text":"§ 15101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd00b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter such sums as may be necessary for each of fiscal years 2001 through 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd00c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd00d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reserve for each fiscal year 10 percent, or $400,000 (whichever is greater), of the amount appropriated pursuant to subsection (a) to carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd00e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15098"},"text":"section 15098 of this title","children":[],"tail":" (relating to the provision of technical assistance and information to States); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd00f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15099"},"text":"section 15099 of this title","children":[],"tail":" (relating to the conduct of evaluations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year that the amount appropriated pursuant to subsection (a) is $10,000,000 or greater, the Secretary may reserve 5 percent of such amount to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15100"},"text":"section 15100 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd011-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s212"},"text":"Pub. L. 106–402, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1734"},"text":"114 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
