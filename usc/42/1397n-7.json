{"tag":"section","attrib":{"id":"idbaaf8939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397n–7"},"text":"§ 1397n–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available to carry out this division, the Secretary may not use more than $2,000,000 in any fiscal year to support the review, approval, and oversight of social impact partnership projects, including activities conducted by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf893a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–7/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Interagency Council on Social Impact Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf893b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–7/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other agency consulted by the Secretary before approving a social impact partnership project or a feasibility study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397n–3"},"text":"section 1397n–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf893c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2058, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVIII/s50802/2"},"text":"Pub. L. 115–123, div. E, title VIII, § 50802(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":