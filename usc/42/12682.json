{"tag":"section","attrib":{"id":"idbf95ce7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12682"},"text":null,"children":[{"tag":"num","attrib":{"value":"12682"},"text":"§ 12682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under national service laws to be subject to availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No action involving the obligation or expenditure of funds may be taken under one of the national service laws (as defined in section 12511(15) ","children":[{"tag":"ref","attrib":{"idref":"fn004098"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) unless and until the Corporation for National and Community Service has sufficient appropriations available at the time such action is taken to satisfy the obligation to be incurred or make the expenditure to be made."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf95ce7d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII/s205"},"text":"Pub. L. 103–82, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/897"},"text":"107 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf95ce7e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf95ce7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf95ce80-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511/15"},"text":"Section 12511(15) of this title","children":[],"tail":", referred to in text, was redesignated section 12511(26) by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1102/b/1"},"text":"Pub. L. 111–13, title I, § 1102(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1467"},"text":"123 Stat. 1467","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf95ce81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section enacted as part of the National and Community Service Trust Act of 1993, and not as part of the National and Community Service Act of 1990 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
