{"tag":"section","attrib":{"id":"idbfdd5f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066"},"text":null,"children":[{"tag":"num","attrib":{"value":"15066"},"text":"§ 15066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdd5f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization and reservations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c/4"},"text":"section 15063(c)(4) of this title","children":[],"tail":") $30,000,000 for fiscal year 2001 and such sums as may be necessary for each of fiscal years 2002 through 2007."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for training initiatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From any amount appropriated for a fiscal year under paragraph (1) and remaining after each Center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15062/a"},"text":"section 15062(a) of this title","children":[],"tail":" has received a grant award of not less than $500,000, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15062"},"text":"section 15062 of this title","children":[],"tail":", the Secretary shall reserve funds for the training initiatives authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/b"},"text":"section 15063(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Years before appropriation trigger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any covered year, the Secretary shall reserve funds in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15083/c"},"text":"section 15083(c) of this title","children":[],"tail":" to fund technical assistance activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c"},"text":"section 15063(c) of this title","children":[],"tail":" (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c/4"},"text":"section 15063(c)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Years after appropriation trigger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year that is not a covered year, the Secretary shall reserve not less than $300,000 and not more than 2 percent of the amount appropriated under paragraph (1) to fund technical assistance activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c"},"text":"section 15063(c) of this title","children":[],"tail":" (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15063/c/4"},"text":"section 15063(c)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “covered year” means a fiscal year prior to the first fiscal year for which the amount appropriated under paragraph (1) is not less than $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not use, for peer review or other activities directly related to peer review conducted under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2001, more than $300,000 of the funds made available under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15066/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any succeeding fiscal year, more than the amount of funds used for the peer review and related activities in fiscal year 2001, adjusted to take into account the most recent percentage change in the Consumer Price Index published by the Secretary of Labor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s720/c/1"},"text":"section 720(c)(1) of title 29","children":[],"tail":" (if the percentage change indicates an increase)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f6d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s156"},"text":"Pub. L. 106–402, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1725"},"text":"114 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
