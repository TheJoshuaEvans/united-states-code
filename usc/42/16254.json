{"tag":"section","attrib":{"id":"idbffc59eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254"},"text":null,"children":[{"tag":"num","attrib":{"value":"16254"},"text":"§ 16254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional bioeconomy development grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffc59ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using amounts made available under subsection (g), the Secretary of Agriculture (referred to in this section as the “Secretary”) shall make available on a competitive basis grants to eligible entities described in subsection (b) for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible for a grant under this section is any regional bioeconomy development association, agricultural or energy trade association, or Land Grant institution that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes to use the grant for the purposes described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not previously received a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional bioeconomy development association grant purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under this section shall be used to support and promote the growth and development of the bioeconomy within the region served by the eligible entity, through coordination, education, outreach, and other endeavors by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant recipients shall provide matching non-Federal funds equal to the amount of the grant received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Matching funds shall be expended in advance of grant funding, so that for every dollar of grant that is advanced, an equal amount of matching funds shall have been funded prior to submitting the request for reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish such administrative requirements for grants under this section, including requirements for applications for the grants, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under this section shall not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to make grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16254/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2007 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffc59f9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s945"},"text":"Pub. L. 109–58, title IX, § 945","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/882"},"text":"119 Stat. 882","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
