{"tag":"section","attrib":{"id":"idbc770270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171"},"text":null,"children":[{"tag":"num","attrib":{"value":"3171"},"text":"§ 3171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of economic development districts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc770271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order that economic development projects of broad geographic significance may be planned and carried out, the Secretary may designate appropriate economic development districts in the United States, with the concurrence of the States in which the districts will be wholly or partially located, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed district is of sufficient size or population, and contains sufficient resources, to foster economic development on a scale involving more than a single area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed district contains at least 1 area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed district has a comprehensive economic development strategy that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc770275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a specific program for intra-district cooperation, self-help, and public investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc770276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by each affected State and by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, under regulations promulgated by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invite the States to determine boundaries for proposed economic development districts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cooperate with the States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc77027a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in sponsoring and assisting district economic planning and economic development groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc77027b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in assisting the district groups in formulating comprehensive economic development strategies for districts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77027c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3171/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage participation by appropriate local government entities in the economic development districts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc77027d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIV/s401"},"text":"Pub. L. 89–136, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3608"},"text":"112 Stat. 3608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc77027e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc77027f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc770280-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3171, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIV/s403"},"text":"Pub. L. 89–136, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/562"},"text":"79 Stat. 562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/304/s1/d"},"text":"Pub. L. 91–304, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-06"},"text":"July 6, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/375"},"text":"84 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/65/tI/s108"},"text":"Pub. L. 92–65, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-05"},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/167"},"text":"85 Stat. 167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/46/s4"},"text":"Pub. L. 93–46, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/96"},"text":"87 Stat. 96","children":[],"tail":"; 