{"tag":"section","attrib":{"id":"idbff2e3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132"},"text":null,"children":[{"tag":"num","attrib":{"value":"16132"},"text":"§ 16132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National grant, rebate, and loan programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff2e3bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall use 70 percent of the funds made available to carry out this part for each fiscal year to provide grants, rebates, or low-cost revolving loans, as determined by the Administrator, on a competitive basis, to eligible entities, including through contracts entered into under subsection (e) of this section, to achieve significant reductions in diesel emissions in terms of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pollution produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diesel emissions exposure, particularly from fleets operating in areas designated by the Administrator as poor air quality areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall distribute funds made available for a fiscal year under this part in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engine configurations and technologies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified engine configurations and verified technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall provide not less than 95 percent of funds available for a fiscal year under this section to eligible entities for projects using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified engine configuration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verified technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging technologies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide not more than 5 percent of funds available for a fiscal year under this section to eligible entities for the development and commercialization of emerging technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and test plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive funds under clause (i), a manufacturer, in consultation with an eligible entity, shall submit for verification to the Administrator or the California Air Resources Board a test plan for the emerging technology, together with a verification application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop a simplified application process for all applicants under this section to expedite the provision of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the expedited process under subparagraph (A), the Administrator—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take into consideration the special circumstances affecting small fleet owners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid duplicative procedures, may require applicants to include in an application under this section the results of a competitive bidding process for equipment and installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebates and low-cost loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a rebate or a low-cost loan under this section, an eligible entity shall submit an application in accordance with such guidance as the Administrator may establish—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an entity that has entered into a contract under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the air quality of the area served by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of air pollution produced by the diesel fleets in the area served by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the project proposed by the eligible entity, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any certified engine configuration, verified technology, or emerging technology to be used or funded by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means by which the project will achieve a significant reduction in diesel emissions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation (using methodology approved by the Administrator or the National Academy of Sciences) of the quantifiable and unquantifiable benefits of the emissions reductions of the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost of the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the age and expected lifetime control of the equipment used or funded by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application relating to nonroad engines or vehicles, a description of the diesel fuel available in the areas to be served by the eligible entity, including the sulfur content of the fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for the monitoring and verification of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing a grant, rebate, or loan under this section, the Administrator shall give highest priority to proposed projects that, as determined by the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize public health benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are the most cost-effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve areas—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the highest population density;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are poor air quality areas, including areas identified by the Administrator as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff2e3e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in nonattainment or maintenance of national ambient air quality standards for a criteria pollutant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Class I areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas with toxic air pollutant concerns;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that receive a disproportionate quantity of air pollution from diesel fleets, including truckstops, ports, rail yards, terminals, construction sites, schools, and distribution centers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that use a community-based multistakeholder collaborative process to reduce toxic emissions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a certified engine configuration, verified technology, or emerging technology that has a long expected useful life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will maximize the useful life of any certified engine configuration, verified technology, or emerging technology used or funded by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/c/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserve diesel fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e3ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use a grant, rebate, or loan provided under this section to fund the costs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a retrofit technology (including any incremental costs of a repowered or new diesel engine) that significantly reduces emissions through development and implementation of a certified engine configuration, verified technology, or emerging technology for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff2e3f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medium-duty truck or a heavy-duty truck;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a marine engine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a locomotive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff2e3f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a nonroad engine or vehicle used in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff2e3f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" handling of cargo (including at a port or airport);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mining; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff2e3f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/A/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy production; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs or projects to reduce long-duration idling using verified technology involving a vehicle or equipment described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e3fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e3fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), no grant, rebate, or loan provided, or contract entered into, under this section shall be used to fund the costs of emissions reductions that are mandated under any Federal law, except that this subparagraph shall not apply to a mandate in a State implementation plan approved by the Administrator under the Clean Air Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e3fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), voluntary or elective emission reduction measures shall not be considered “mandated”, regardless of whether the reductions are included in the State implementation plan of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e3fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e3ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the use of contracting authority otherwise available to the Administrator, the Administrator may enter into contracts with eligible contractors described in paragraph (2) for the administration of programs for providing rebates or loans, subject to the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible contractors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may enter into a contract under this subsection with a for-profit or nonprofit entity that has the capacity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell diesel vehicles or equipment to, or to arrange financing for, individuals or entities that own a diesel vehicle or fleet; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to upgrade diesel vehicles or equipment with verified or Environmental Protection Agency-certified engines or technologies, or to arrange financing for such upgrades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff2e403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of the award of a grant, rebate, or loan, the Administrator shall publish on the website of the Environmental Protection Agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for rebates and loans provided to the owner of a diesel vehicle or fleet, the total number and dollar amount of rebates or loans provided, as well as a breakdown of the technologies funded through the rebates or loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16132/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other rebates and loans, and for grants, a description of each application for which the grant, rebate, or loan is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff2e406-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s792"},"text":"Pub. L. 109–58, title VII, § 792","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/839"},"text":"119 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b"},"text":"Pub. L. 111–364, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4056"},"text":"124 Stat. 4056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff2e407-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff2e408-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbff2e409-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (d)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff2e40a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/1"},"text":"Pub. L. 111–364, § 2(b)(1)","children":[],"tail":", inserted “, rebate,” after “grant” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/2/A"},"text":"Pub. L. 111–364, § 2(b)(2)(A)","children":[],"tail":", substituted “to provide grants, rebates, or low-cost revolving loans, as determined by the Administrator, on a competitive basis, to eligible entities, including through contracts entered into under subsection (e) of this section,” for “to provide grants and low-cost revolving loans, as determined by the Administrator, on a competitive basis, to eligible entities” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/2/B"},"text":"Pub. L. 111–364, § 2(b)(2)(B)","children":[],"tail":", struck out “tons of” before “pollution produced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/3/A"},"text":"Pub. L. 111–364, § 2(b)(3)(A)","children":[],"tail":", (B), redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text read as follows: “The Administrator shall provide not less than 50 percent of funds available for a fiscal year under this section to eligible entities for the benefit of public fleets.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/3/C/i"},"text":"Pub. L. 111–364, § 2(b)(3)(C)(i)","children":[],"tail":", substituted “95” for “90” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/3/C/ii"},"text":"Pub. L. 111–364, § 2(b)(3)(C)(ii)","children":[],"tail":", substituted “5 percent” for “10 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/3/C/iii"},"text":"Pub. L. 111–364, § 2(b)(3)(C)(iii)","children":[],"tail":", substituted “a verification application” for “the application under subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/3/B"},"text":"Pub. L. 111–364, § 2(b)(3)(B)","children":[],"tail":", redesignated par. (3) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/4/A"},"text":"Pub. L. 111–364, § 2(b)(4)(A)","children":[],"tail":", (B), added pars. (1) and (2), redesignated former pars. (2) and (3) as (3) and (4), respectively, and struck out former par. (1). Prior to amendment, text of par. (1) read as follows: “To receive a grant or loan under this section, an eligible entity shall submit to the Administrator an application at a time, in a manner, and including such information as the Administrator may require.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/4/C"},"text":"Pub. L. 111–364, § 2(b)(4)(C)","children":[],"tail":", inserted “in the case of an application relating to nonroad engines or vehicles,” before “a description of the diesel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/4/D/i"},"text":"Pub. L. 111–364, § 2(b)(4)(D)(i)","children":[],"tail":", inserted “, rebate,” after “grant” and “highest” before “priority” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/4/D/ii"},"text":"Pub. L. 111–364, § 2(b)(4)(D)(ii)","children":[],"tail":", substituted “diesel fleets” for “a diesel fleets” and inserted “construction sites, schools,” after “terminals,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/4/D/iii"},"text":"Pub. L. 111–364, § 2(b)(4)(D)(iii)","children":[],"tail":"–(v), inserted “and” at end of subpar. (E), substituted a period for “; and” in subpar. (F), and struck out subpar. (G) which read as follows: “use diesel fuel with a sulfur content of less than or equal to 15 parts per million, as the Administrator determines to be appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/5/A"},"text":"Pub. L. 111–364, § 2(b)(5)(A)","children":[],"tail":", inserted “, rebate,” after “grant” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/5/B"},"text":"Pub. L. 111–364, § 2(b)(5)(B)","children":[],"tail":", substituted “grant, rebate, or loan provided, or contract entered into,” for “grant or loan provided” and “any Federal law, except that this subparagraph shall not apply to a mandate in a State implementation plan approved by the Administrator under the Clean Air Act” for “Federal, State or local law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364/s2/b/6"},"text":"Pub. L. 111–364, § 2(b)(6)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff2e40b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbff2e40c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/364"},"text":"Pub. L. 111–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"Oct. 1, 2011","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/364/s4"},"text":"section 4 of Pub. L. 111–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
