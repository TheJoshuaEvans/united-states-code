{"tag":"section","attrib":{"id":"idc06553d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725"},"text":null,"children":[{"tag":"num","attrib":{"value":"18725"},"text":"§ 18725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06553d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require, as the Secretary determines appropriate, a recipient of any award or other funding under this division—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary, prior to the issuance of the award or other funding, a cybersecurity plan that demonstrates the cybersecurity maturity of the recipient in the context of the project for which that award or other funding was provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a plan for maintaining and improving cybersecurity throughout the life of the proposed solution of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of cybersecurity plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cybersecurity plan described in subsection (a) shall, at a minimum, describe how the recipient described in that subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plans to maintain cybersecurity between networks, systems, devices, applications, or components—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the proposed solution of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the necessary external interfaces at the proposed solution boundaries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will perform ongoing evaluation of cybersecurity risks to address issues as the issues arise throughout the life of the proposed solution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will report known or suspected network or system compromises of the project to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will leverage applicable cybersecurity programs of the Department, including cyber vulnerability testing and security engineering evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient described in subsection (a) should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maximize the use of open guidance and standards, including, wherever possible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Cybersecurity Capability Maturity Model of the Department (or a successor model); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Framework for Improving Critical Infrastructure Cybersecurity of the National Institute of Standards and Technology; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" document—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deviation from open standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utilization of proprietary standards where the recipient determines that such deviation necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Cybersecurity, Energy Security, and Emergency Response of the Department shall review each cybersecurity plan submitted under subsection (a) to ensure integration with Department research, development, and demonstration programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information provided to, or collected by, the Federal Government pursuant to this section the disclosure of which the Secretary reasonably foresees could be detrimental to the physical security or cybersecurity of any electric utility or the bulk-power system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18725/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made available by any Federal agency, State, political subdivision of a State, or Tribal authority pursuant to any Federal, State, political subdivision of a State, or Tribal law, respectively, requiring public disclosure of information or records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06553ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40126"},"text":"Pub. L. 117–58, div. D, title I, § 40126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/956"},"text":"135 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06553ed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06553ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc06553ef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (a), is div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/923"},"text":"135 Stat. 923","children":[],"tail":", which enacted this chapter and enacted and amended numerous other sections and notes in the Code. For complete classification of div. D to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06553f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06553f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
