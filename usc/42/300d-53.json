{"tag":"section","attrib":{"id":"idb6182663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–53"},"text":"§ 300d–53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grants for protection and advocacy services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6182664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator for the Administration for Community Living, shall make grants to protection and advocacy systems for the purpose of enabling such systems to provide services to individuals with traumatic brain injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6182665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Services provided under this section may include the provision of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6182666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, referrals, and advice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual and family advocacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal representation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific assistance in self-advocacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618266a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a protection and advocacy system shall submit an application to the Secretary at such time, in such form and manner, and accompanied by such information and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618266b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations less than $2,700,000","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb618266c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any fiscal year in which the amount appropriated under subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") to carry out this section is less than $2,700,000, the Secretary shall make grants from such amount to individual protection and advocacy systems within States to enable such systems to plan for, develop outreach strategies for, and carry out services authorized under this section for individuals with traumatic brain injury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb618266d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of each grant provided under paragraph (1) shall be determined as set forth in paragraphs (2) and (3) of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618266e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations of $2,700,000 or more","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb618266f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), with respect to each fiscal year in which the amount appropriated under subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") to carry out this section is $2,700,000 or more, the Secretary shall make a grant to a protection and advocacy system within each State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided to a system under paragraph (1) shall be equal to an amount bearing the same ratio to the total amount appropriated for the fiscal year involved under subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") as the population of the State in which the grantee is located bears to the population of all States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimums","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the amount of a grant ","children":[{"tag":"ref","attrib":{"idref":"fn002332"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002332"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “to”."}],"tail":" a protection and advocacy system under paragraph (1) for a fiscal year shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6182672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a protection and advocacy system located in American Samoa, Guam, the United States Virgin Islands, or the Commonwealth of the Northern Mariana Islands, and the protection and advocacy system serving the American Indian consortium, not be less than $20,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6182673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a protection and advocacy system in a State not described in subparagraph (A), not be less than $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year in which the total amount appropriated under subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") to carry out this section is $5,000,000 or more, and such appropriated amount exceeds the total amount appropriated to carry out this section in the preceding fiscal year, the Secretary shall increase each of the minimum grants amount described in subparagraphs (A) and (B) of paragraph (3) by a percentage equal to the percentage increase in the total amount appropriated under subsection ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") to carry out this section between the preceding fiscal year and the fiscal year involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount paid to a protection and advocacy system that serves a State or the American Indian consortium for a fiscal year under this section that remains unobligated at the end of such fiscal year shall remain available to such system for obligation during the next fiscal year for the purposes for which such amount was originally provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, each fiscal year not later than October 1, the Secretary shall pay directly to any protection and advocacy system that complies with the provisions of this section, the total amount of the grant for such system, unless the system provides otherwise for such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a9778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each protection and advocacy system that receives a payment under this section shall submit an annual report to the Secretary concerning the services provided to individuals with traumatic brain injury by such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-11-26"},"text":"November 26, 2014","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress a report describing the services and activities carried out under this section during the period for which the report is being prepared."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a977a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall facilitate agreements to coordinate the collection of data by agencies within the Department of Health and Human Services regarding protection and advocacy services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a977b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a977c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year for which the amount appropriated to carry out this section is $6,000,000 or greater, the Secretary shall use 2 percent of such amount to make a grant to an eligible national association for providing for training and technical assistance to protection and advocacy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a977d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible national association” means a national association with demonstrated experience in providing training and technical assistance to protection and advocacy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a977e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing services under this section, a protection and advocacy system shall have the same authorities, including access to records, as such system would have for purposes of providing services under subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a977f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $4,000,000 for each of fiscal years 2020 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a9781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Indian consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “American Indian consortium” means a consortium established under subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection and advocacy system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “protection and advocacy system” means a protection and advocacy system established under subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–53/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State”, unless otherwise specified, means the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb61a9784-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1253, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXIII/s1305"},"text":"Pub. L. 106–310, div. A, title XIII, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1141"},"text":"114 Stat. 1141","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/206/s6/b"},"text":"Pub. L. 110–206, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-28"},"text":"Apr. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/717"},"text":"122 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4"},"text":"Pub. L. 113–196, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2053"},"text":"128 Stat. 2053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/377/s4"},"text":"Pub. L. 115–377, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5114"},"text":"132 Stat. 5114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb61a9785-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb61a9786-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb61a9787-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act of 2000, referred to in subsecs. (k) and (m)(1), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1677"},"text":"114 Stat. 1677","children":[],"tail":". Subtitle C of title I of the Act is classified generally to part C (§ 15041 et seq.) of subchapter I of chapter 144 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb61a9788-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/377/s4/1"},"text":"Pub. L. 115–377, § 4(1)","children":[],"tail":", inserted “, acting through the Administrator for the Administration for Community Living,” after “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/115/377/s4/2"},"text":"Pub. L. 115–377, § 4(2)","children":[],"tail":", substituted “$4,000,000 for each of fiscal years 2020 through 2024” for “$3,100,000 for each of the fiscal years 2015 through 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/1"},"text":"Pub. L. 113–196, § 4(1)","children":[],"tail":", struck out “, acting through the Administrator of the Health Resources and Services Administration (referred to in this section as the ‘Administrator’),” after “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d)(1), (e)(1), (4), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/2"},"text":"Pub. L. 113–196, § 4(2)","children":[],"tail":", substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/2"},"text":"Pub. L. 113–196, § 4(2)","children":[],"tail":", (3), substituted “Reporting” for “Annual report” in heading; designated existing provisions as par. (1), inserted heading, and substituted “Secretary” for “Administrator”; and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/4"},"text":"Pub. L. 113–196, § 4(4)","children":[],"tail":", substituted “The Secretary shall facilitate agreements to coordinate the collection of data by agencies within the Department of Health and Human Services regarding” for “The Administrator of the Health Resources and Services Administration and the Commissioner of the Administration on Developmental Disabilities shall enter into an agreement to coordinate the collection of data by the Administrator and the Commissioner regarding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/2"},"text":"Pub. L. 113–196, § 4(2)","children":[],"tail":", substituted “Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/196/s4/5"},"text":"Pub. L. 113–196, § 4(5)","children":[],"tail":", substituted “subtitle C of title I of the Developmental Disabilities Assistance and Bill of Rights Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15041"},"text":"42 U.S.C. 15041","children":[],"tail":" et seq.)” for “subtitle C of the Developmental Disabilities Assistance and Bill of Rights Act of 2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"re