":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":", known as the Domestic Volunteer Service Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf55a9c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" substituted “fiscal years 2010 through 2014” for “fiscal years 1994 through 1996” in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) There is authorized to be appropriated for the administration of this chapter, as authorized in subchapter IV of this chapter, $25,312,000 for each of the fiscal years 1987, 1988, and 1989. In addition to the amounts authorized to be appropriated for the administration of this chapter by the preceding sentence, there is authorized to be appropriated the aggregate sum of $500,000 for fiscal years 1987 and 1988 to be available for support of drug abuse prevention.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) For each of the fiscal years 1990 through 1993, there is authorized to be appropriated for the administration of this chapter, as authorized in subchapter IV of this chapter, 20 percent of the total amount appropriated under sections 5081 and 5082 of this title.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" inserted at end “In addition to the amounts authorized to be appropriated for the administration of this chapter by the preceding sentence, there is authorized to be appropriated the aggregate sum of $500,000 for fiscal years 1987 and 1988 to be available for support of drug abuse prevention.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/551"},"text":"Pub. L. 99–551","children":[],"tail":" substituted “$25,312,000 for each of the fiscal years 1987, 1988, and 1989” for “$25,800,000 for fiscal year 1984, $27,000,000 for fiscal year 1985, and $28,000,000 for fiscal year 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" substituted “$25,800,000 for fiscal year 1984, $27,000,000 for fiscal year 1985, and $28,000,000 for fiscal year 1986” for “$30,091,000 for fiscal year 1982 and $29,348,000 for fiscal year 1983”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted provisions authorizing appropriations for fiscal years 1982 and 1983, for provisions authorizing appropriations for fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", through fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143"},"text":"