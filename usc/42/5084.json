{"tag":"section","attrib":{"id":"idbcf55a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5084"},"text":null,"children":[{"tag":"num","attrib":{"value":"5084"},"text":"§ 5084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf55a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5084/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the fiscal years 2010 through 2014, there are authorized to be appropriated for the administration of this chapter as provided for in subchapter IV, 18 percent of the total amount appropriated under sections 5081 and 5082 of this title with respect to such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf55a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5084/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the fiscal years 2010 through 2014, the Director is authorized to expend not less than 2½ percent, and not more than 5 percent, of the amount appropriated under subsection (a), for the purposes prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5056"},"text":"section 5056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf55a98-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tV/s504"},"text":"Pub. L. 93–113, title V, § 504","children":[],"tail":", "