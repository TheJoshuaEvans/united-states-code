{"tag":"section","attrib":{"id":"idc00d21bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323"},"text":null,"children":[{"tag":"num","attrib":{"value":"16323"},"text":"§ 16323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and engineering education pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award a grant to a Southeastern United States consortium of major research universities that currently advances science and education by partnering with National Laboratories, to establish a regional pilot program of its SEEK–16 program for enhancing scientific, technological, engineering, and mathematical literacy, creativity, and decision-making. The consortium shall include leading research universities, one or more universities that train substantial numbers of elementary and secondary school teachers, and (where appropriate) National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regional pilot program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding strategic, formal partnerships among universities with strength in research, universities that train substantial numbers of elementary and secondary school teachers, and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combining Department expertise with one or more National Aeronautics and Space Administration Educator Resource Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing programs to permit current and future teachers to participate in ongoing research projects at National Laboratories and research universities and to adapt lessons learned to the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing and implementing course work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing and implementing a strategy for measuring and assessing progress under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing models for transferring knowledge gained under the pilot program to other institutions and areas of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall be considered an authorized activity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7381b"},"text":"section 7381b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21c9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s983"},"text":"Pub. L. 109–58, title IX, § 983","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/907"},"text":"119 Stat. 907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tVI/s601/a"},"text":"Pub. L. 113–188, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2019"},"text":"128 Stat. 2019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d21ca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d21cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d21cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188"},"text":"Pub. L. 113–188","children":[],"tail":" struck out subsec. (d). Text read as follows: “No later than 2 years after the award of the grant, the Secretary shall transmit to Congress a report outlining lessons learned and, if determined appropriate by the Secretary, containing a plan for expanding the program throughout the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
