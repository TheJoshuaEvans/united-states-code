{"tag":"section","attrib":{"id":"idbf879e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c"},"text":null,"children":[{"tag":"num","attrib":{"value":"12645c"},"text":"§ 12645c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on program grant costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf879e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by this section, the amount of funds approved by the Corporation for a grant to operate a program authorized under the national service laws, for supporting individuals serving in approved national service positions, may not exceed $18,000 per full-time equivalent position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs subject to limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subsection (a), and the increased limitation under subsection (e)(1), shall apply to the Corporation’s share of the member support costs, staff costs, and other costs to operate a program authorized under the national service laws incurred,","children":[{"tag":"ref","attrib":{"idref":"fn004077"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004077"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" by the recipient of the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs not subject to limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subsection (a), and the increased limitation under subsection (e)(1), shall not apply to expenses under a grant authorized under the national service laws to operate a program that are not included in the grant award for operating the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments for inflation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts specified in subsections (a) and (e)(1) shall be adjusted each year after 2008 for inflation as measured by the Consumer Price Index for All Urban Consumers published by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority and reporting requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer may increase the limitation under subsection (a) to not more than $19,500 per full-time equivalent position if necessary to meet the compelling needs of a particular program, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceptional training needs for a program serving disadvantaged youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to pay for increased costs relating to the participation of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of tribal programs or programs located in the territories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to pay for start-up costs associated with a first-time recipient of assistance under a program of the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall report to the authorizing committees annually on all limitations increased under this subsection, with an explanation of the compelling needs justifying such increases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf879e79-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s189"},"text":"Pub. L. 101–610, title I, § 189","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1612"},"text":"Pub. L. 111–13, title I, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1539"},"text":"123 Stat. 1539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf879e7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf879e7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf879e7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
