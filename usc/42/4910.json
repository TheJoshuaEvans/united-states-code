{"tag":"section","attrib":{"id":"idbce728df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910"},"text":null,"children":[{"tag":"num","attrib":{"value":"4910"},"text":"§ 4910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce728e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce728e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully or knowingly violates paragraph (1), (3), (5), or (6) of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4909"},"text":"section 4909 of this title","children":[],"tail":" shall be punished by a fine of not more than $25,000 per day of violation, or by imprisonment for not more than one year, or by both. If the conviction is for a violation committed after a first conviction of such person under this subsection, punishment shall be by a fine of not more than $50,000 per day of violation, or by imprisonment for not more than two years, or by both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce728e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates paragraph (1), (3), (5), or (6) of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4909"},"text":"section 4909 of this title","children":[],"tail":" shall be subject to a civil penalty not to exceed $10,000 per day of such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce728e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, each day of violation of any paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4909/a"},"text":"section 4909(a) of this title","children":[],"tail":" shall constitute a separate violation of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce728e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to restrain violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction of actions brought by and in the name of the United States to restrain any violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4909/a"},"text":"section 4909(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce728e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders issued to protect public health and welfare; notice; opportunity for hearing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce728e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever any person is in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4909/a"},"text":"section 4909(a) of this title","children":[],"tail":", the Administrator may issue an order specifying such relief as he determines is necessary to protect the public health and welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce728e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any order under this subsection shall be issued only after notice and opportunity for a hearing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce728e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Person” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person,” as used in this section, does not include a department, agency, or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce728e9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/574/s11"},"text":"Pub. L. 92–574, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1242"},"text":"86 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/609/s4"},"text":"Pub. L. 95–609, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3081"},"text":"92 Stat. 3081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce728ea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce728eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbce728ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/609"},"text":"Pub. L. 95–609","children":[],"tail":" redesignated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
