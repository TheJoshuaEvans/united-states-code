{"tag":"section","attrib":{"id":"idbf938529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655b"},"text":"§ 12655b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf93852a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this division, a State or Indian tribe (or a local applicant if ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655"},"text":"section 12655 of this title","children":[],"tail":" applies) shall prepare and submit to the Corporation, an application at such time, in such manner, and containing such information as the Corporation may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93852b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under subsection (a) shall describe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf93852c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any youth corps program proposed to be conducted directly by such applicant with assistance provided under this division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{