{"tag":"section","attrib":{"id":"idbba2c29f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962–2"},"text":"§ 1962–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress that the objectives of enhancing regional economic development, the quality of the total environment, including its protection and improvement, the well-being of the people of the United States, and the national economic development are the objectives to be included in federally financed water resource projects (including shore protection projects such as projects for beach nourishment, including the replacement of sand), and in the evaluation of benefits and cost attributable thereto, giving due consideration to the most feasible alternative means of accomplishing these objectives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba2c2a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611/tII/s209"},"text":"Pub. L. 91–611, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1829"},"text":"84 Stat. 1829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s227/f"},"text":"Pub. L. 104–303, title II, § 227(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3703"},"text":"110 Stat. 3703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba2c2a1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba2c2a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba2c2a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Flood Control Act of 1970 and not as a part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba2c2a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" inserted “(including shore protection projects such as projects for beach nourishment, including the replacement of sand)” after “water resource projects”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
