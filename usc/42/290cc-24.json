{"tag":"section","attrib":{"id":"idb5b8c7fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–24"},"text":"§ 290cc–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c7fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The allotment for a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" for a fiscal year shall be the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c7fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000 for each of the several States, the District of Columbia, and the Commonwealth of Puerto Rico, and $50,000 for each of Guam, the Virgin Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c7ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination under formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in subsection (a)(2) is the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–35/a"},"text":"section 290cc–35(a) of this title","children":[],"tail":" for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b8c803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the population living in urbanized areas of the State involved, as indicated by the most recent data collected by the Bureau of the Census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b8c804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–24/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the population living in urbanized areas of the United States, as indicated by the sum of the respective amounts determined for the States under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c805-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 524, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/517"},"text":"101 Stat. 517","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4728"},"text":"104 Stat. 4728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c806-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c807-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b8c808-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 524 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 545 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/s611/2"},"text":"section 611(2) of Pub. L. 100–77","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee"},"text":"section 290ee of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c809-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting provisions relating to determination of amount of allotment for provisions relating to requiring provision of certain mental health services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
