{"tag":"section","attrib":{"id":"idbcc82fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4346"},"text":null,"children":[{"tag":"num","attrib":{"value":"4346"},"text":"§ 4346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure and compensation of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Members of the Council shall serve full time and the Chairman of the Council shall be compensated at the rate provided for Level II of the Executive Schedule Pay Rates (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"5 U.S.C. 5313","children":[],"tail":"). The other members of the Council shall be compensated at the rate provided for Level IV or "},{"tag":"ref","attrib":{"idref":"fn003359"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003359"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" the Executive Schedule Pay Rates ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"5 U.S.C. 5315","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcc82fd3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tII/s206"},"text":"Pub. L. 91–190, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/856"},"text":"83 Stat. 856","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
