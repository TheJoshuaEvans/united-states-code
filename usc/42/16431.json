{"tag":"section","attrib":{"id":"idc0144e53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431"},"text":null,"children":[{"tag":"num","attrib":{"value":"16431"},"text":"§ 16431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal utility participation in transmission organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal regulatory authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Federal regulatory authority” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Federal power marketing agency, the Secretary, except that the Secretary may designate the Administrator of a Federal power marketing agency to act as the appropriate Federal regulatory authority with respect to the transmission system of the Federal power marketing agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Tennessee Valley Authority, the Board of Directors of the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal power marketing agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal power marketing agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal utility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal utility” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal power marketing agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Transmission Organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transmission system” means an electric transmission facility owned, leased, or contracted for by the United States and operated by a Federal utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal regulatory authority may enter into a contract, agreement, or other arrangement transferring control and use of all or part of the transmission system of a Federal utility to a Transmission Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contract, agreement, or arrangement shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" performance standards for operation and use of the transmission system that the head of the Federal utility determines are necessary or appropriate, including standards that ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery of all of the costs and expenses of the Federal utility related to the transmission facilities that are the subject of the contract, agreement, or other arrangement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistency with existing contracts and third-party financing arrangements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistency with the statutory authorities, obligations, and limitations of the Federal utility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for monitoring and oversight by the Federal utility of the Transmission Organization’s terms and conditions of the contract, agreement, or other arrangement, including a provision for the resolution of disputes through arbitration or other means with the Transmission Organization or with other participants, notwithstanding the obligations and limitations of any other law regarding arbitration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision that allows the Federal utility to withdraw from the Transmission Organization and terminate the contract, agreement, or other arrangement in accordance with its terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither this section, actions taken pursuant to this section, nor any other transaction of a Federal utility participating in a Transmission Organization shall confer on the Commission jurisdiction or authority over—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electric generation assets, electric capacity, or energy of the Federal utility that the Federal utility is authorized by law to market; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the power sales activities of the Federal utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing statutory and other obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System operation requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No statutory provision requiring or authorizing a Federal utility to transmit electric power or to construct, operate, or maintain the transmission system of the Federal utility prohibits a transfer of control and use of the transmission system pursuant to, and subject to, the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other obligations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend, or exempt any Federal utility from, any provision of Federal law in effect on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", including any requirement or direction relating to the use of the transmission system of the Federal utility, environmental protection, fish and wildlife protection, flood control, navigation, water delivery, or recreation; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16431/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize abrogation of any contract or treaty obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144e6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1232"},"text":"Pub. L. 109–58, title XII, § 1232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/956"},"text":"119 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0144e6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0144e70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0144e71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1232"},"text":"section 1232 of Pub. L. 109–58","children":[],"tail":". Subsec. (e)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1232"},"text":"section 1232 of Pub. L. 109–58","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s824n"},"text":"section 824n of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
