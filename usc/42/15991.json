{"tag":"section","attrib":{"id":"idbfee28a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991"},"text":null,"children":[{"tag":"num","attrib":{"value":"15991"},"text":"§ 15991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee28a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Interior, in consultation with the Secretary of Agriculture and the Secretary, shall review coal assessments and other available data to identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal lands with coal resources that are available for development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of any restrictions on the development of coal resources on Federal lands identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to areas of such lands for which sufficient data exists, resources of compliant coal and supercompliant coal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee28a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “compliant coal” means coal that contains not less than 1.0 and not more than 1.2 pounds of sulfur dioxide per million Btu; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee28a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “supercompliant coal” means coal that contains less than 1.0 pounds of sulfur dioxide per million Btu.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion and updating of the inventory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall complete the inventory under subsection (a) by not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall update the inventory as the availability of data and developments in technology warrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Resources of the House of Representatives and to the Committee on Energy and Natural Resources of the Senate and make publicly available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report containing the inventory under this section, by not later than 2 years after the effective date of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15991/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each update of such inventory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee28b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s437"},"text":"Pub. L. 109–58, title IV, § 437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/762"},"text":"119 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfee28b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfee28b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfee28b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsec. (c)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfee28b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbfee28b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfee28b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of subtitle D of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which enacted this part, as the “Coal Leasing Amendments Act of 2005”, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s431"},"text":"section 431 of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
