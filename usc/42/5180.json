{"tag":"section","attrib":{"id":"idbd1b801b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5180"},"text":null,"children":[{"tag":"num","attrib":{"value":"5180"},"text":"§ 5180.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1b801c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5180/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency mass feeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized and directed to assure that adequate stocks of food will be ready and conveniently available for emergency mass feeding or distribution in any area of the United States which suffers a major disaster or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b801d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5180/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for purchase of food commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall utilize funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of title 7","children":[],"tail":", to purchase food commodities necessary to provide adequate supplies for use in any area of the United States in the event of a major disaster or emergency in such area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1b801e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s413"},"text":"Pub. L. 93–288, title IV, § 413","children":[],"tai