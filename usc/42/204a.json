{"tag":"section","attrib":{"id":"idb41e9fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a"},"text":null,"children":[{"tag":"num","attrib":{"value":"204a"},"text":"§ 204a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment readiness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb41e9fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Readiness requirements for Commissioned Corps officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb41e9fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, with respect to members of the following Corps components, shall establish requirements, including training and medical examinations, to ensure the readiness of such components to respond to urgent or emergency public health care needs that cannot otherwise be met at the Federal, State, and local levels:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb41e9fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Active duty Regular Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb41e9ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ready Reserve Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb42110f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual assessment of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually determine whether each member of the Corps meets the applicable readiness requirements established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb42110f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Corps who fails to meet or maintain the readiness requirements established under paragraph (1) or who fails to comply with orders to respond to an urgent or emergency public health care need shall, except as provided in paragraph (4), in accordance with procedures established by the Secretary, be subject to disciplinary action as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb42110f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb42110f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive one or more of the requirements established under paragraph (1) for an individual who is not able to meet such requirements because of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb42110f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb42110f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary medical condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb42110f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other extraordinary limitation as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb42110f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations under which a waiver described in subparagraph (A) may be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb42110f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urgent or emergency public health care need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s215"},"text":"section 215 of this title","children":[],"tail":", the term “urgent or emergency public health care need” means a health care need, as determined by the Secretary, arising as the result of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb42110fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national emergency declared by the President under the National Emergencies Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb42110fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency or major disaster declared by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb42110fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public health emergency declared by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"section 247d of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb42110fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any emergency that, in the judgment of the Secretary, is appropriate for the deployment of members of the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42110fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps management for deployment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb42110ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organize members of the Corps into units for rapid deployment by the Secretary to respond to urgent or emergency public health care needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4211100-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish appropriate procedures for the command and control of units or individual members of the Corps that are deployed at the direction of the President or the Secretary in response to an urgent or emergency public health care need of national, State or local significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4211101-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that members of the Corps are trained, equipped and otherwise prepared to fulfill their public health and emergency response roles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4211102-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that deployment planning takes into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4211103-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deployment exemptions that may be granted by the Secretary based on the unique requirements of an agency and an individual’s functional role in such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4211104-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the urgent or emergency public health care need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4211105-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s204a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment of detailed or assigned officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of pay, allowances, and benefits of a Commissioned Corps officer who is detailed or assigned to a Federal entity, the deployment of such officer by the Secretary in response to an urgent or emergency public health care need shall be deemed to be an authorized activity of the Federal entity to which the officer is detailed or assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4211106-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 203A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tII/s206/b"},"text":"Pub. L. 109–417, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2851"},"text":"120 Stat. 2851","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3214/b"},"text":"Pub. L. 116–136, div. A, title III, § 3214(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/373"},"text":"134 Stat. 373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4211107-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4211108-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4211109-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (a)(5)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (a)(5)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb421110a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “Ready Reserve Corps” for “Active Reserves”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb421110b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb421110c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417/tII/s206/a"},"text":"Pub. L. 109–417, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2851"},"text":"120 Stat. 2851","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/417/tII/s206/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the purpose of this section [enacting this section and amending sections 215 and 254d of this title] to improve the force management and readiness of the Commissioned Corps to accomplish the following objectives:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure the Corps is ready to respond rapidly to urgent or emergency public health care needs and challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure the availability of the Corps for assignments that address clinical and public health needs in isolated, hardship, and hazardous duty positions, and, when required, to address needs related to the well-being, security, and defense of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish the Corps as a resource available to Federal and State Government agencies for assistance in meeting public health leadership and service roles.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
