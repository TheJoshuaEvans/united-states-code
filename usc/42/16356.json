{"tag":"section","attrib":{"id":"idc00f6b35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356"},"text":null,"children":[{"tag":"num","attrib":{"value":"16356"},"text":"§ 16356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on equal employment opportunity practices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and biennially thereafter, the Secretary shall transmit to Congress a report on the equal employment opportunity practices at National Laboratories. Such report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a thorough review of each National Laboratory contractor’s equal employment opportunity policies, including promotion to management and professional positions and pay raises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statistical report on complaints and their disposition in the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how equal employment opportunity practices at the National Laboratories are treated in the contract and in calculating award fees for each contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of disciplinary actions and their disposition by either the Department or the relevant contractors for each National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of outreach efforts to attract women and minorities to the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of efforts to retain women and minorities in the National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16356/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of collaboration efforts with the Office of Federal Contract Compliance Programs to improve equal employment opportunity practices at the National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6b3d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s992"},"text":"Pub. L. 109–58, title IX, § 992","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/913"},"text":"119 Stat. 913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
