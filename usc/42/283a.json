{"tag":"section","attrib":{"id":"idb556f910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a"},"text":null,"children":[{"tag":"num","attrib":{"value":"283a"},"text":"§ 283a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting to increase interagency collaboration and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556f911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration with other HHS agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an annual basis, the Director of NIH shall submit to the Secretary a report on the activities of the National Institutes of Health involving collaboration with other agencies of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical trials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each calendar year, the Director of NIH shall submit to the Commissioner of Food and Drugs a report that identifies each clinical trial that is registered during such calendar year in the databank of information established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/i"},"text":"section 282(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human tissue samples","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On an annual basis, the Director of NIH shall submit to the Congress a report that describes how the National Institutes of Health and its agencies store and track human tissue samples.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report under subsections (a), (b), and (c) shall be submitted not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-01-15"},"text":"January 15, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556f915-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 403A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/a/3"},"text":"Pub. L. 109–482, title I, § 104(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3691"},"text":"120 Stat. 3691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb556f916-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb556f917-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb556f918-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 403A of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 403D and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283a–3"},"text":"section 283a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb556f919-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb556f91a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
