{"tag":"section","attrib":{"id":"idb519059f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"263a–4"},"text":"§ 263a–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification revocation and suspension","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51905a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification issued by a State or an accreditation organization for an embryo laboratory shall be revoked or suspended if the State or organization finds, on the basis of inspections and after reasonable notice and opportunity for hearing to the owner or operator of the laboratory, that the owner or operator or any employee of the laboratory—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51905a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been guilty of misrepresentation in obtaining the certification,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51905a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to comply with any standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–2"},"text":"section 263a–2 of this title","children":[],"tail":" applicable to the certification, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51905a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has refused a request of the State or accreditation organization for permission to inspect the laboratory, its operations, and records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51905a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the certification of an embryo laboratory is revoked or suspended, the certification of the laboratory shall continue in effect for 60 days after the laboratory receives notice of the revocation or suspension. If the certification of an embryo laboratory is revoked or suspended, the laboratory may apply for recertification after one year after the date of the revocation or suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51905a5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/493/s5"},"text":"Pub. L. 102–493, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3150"},"text":"106 Stat. 3150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51905a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51905a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb51905a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fertility Clinic Success Rate and Certification Act of 1992, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb51905a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb51905aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon expiration of 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/493/s9"},"text":"section 9 of Pub. L. 102–493","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–1"},"text":"section 263a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
