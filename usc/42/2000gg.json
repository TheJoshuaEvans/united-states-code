{"tag":"section","attrib":{"id":"idbbd01460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000gg"},"text":"§ 2000gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd01461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Equal Employment Opportunity Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered entity”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd01463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term “respondent” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e/n"},"text":"section 2000e(n) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd01464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbd01465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer, which means a person engaged in industry affecting commerce who has 15 or more employees as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e/b"},"text":"section 2000e(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd01466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employing office, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of title 2","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s411/c"},"text":"section 411(c) of title 3","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd01467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity employing a State employee described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16c/a"},"text":"section 2000e–16c(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd01468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16/a"},"text":"section 2000e–16(a) of this title","children":[],"tail":" applies;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd0146a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee (including an applicant), as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e/f"},"text":"section 2000e(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd0146b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered employee (including an applicant), as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of title 2","children":[],"tail":", and an individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311/d"},"text":"section 1311(d) of title 2","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd0146c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered employee (including an applicant), as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s411/c"},"text":"section 411(c) of title 3","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd0146d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State employee (including an applicant) described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16c/a"},"text":"section 2000e–16c(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd0146e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee (including an applicant) to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16/a"},"text":"section 2000e–16(a) of this title","children":[],"tail":" applies;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd0146f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “known limitation” means physical or mental condition related to, affected by, or arising out of pregnancy, childbirth, or related medical conditions that the employee or employee’s representative has communicated to the employer whether or not such condition meets the definition of disability specified in section 3 of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"42 U.S.C. 12102","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e/a"},"text":"section 2000e(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “qualified employee” means an employee or applicant who, with or without reasonable accommodation, can perform the essential functions of the employment position, except that an employee or applicant shall be considered qualified if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd01472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any inability to perform an essential function is for a temporary period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd01473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the essential function could be performed in the near future; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd01474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inability to perform the essential function can be reasonably accommodated; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd01475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “reasonable accommodation” and “undue hardship” have the meanings given such terms in section 101 of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12111"},"text":"42 U.S.C. 12111","children":[],"tail":") and shall be construed as such terms are construed under such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.] and as set forth in the regulations required by this chapter, including with regard to the interactive process that will typically be used to determine an appropriate reasonable accommodation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd01476-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s102"},"text":"Pub. L. 117–328, div. II, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6084"},"text":"136 Stat. 6084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd01477-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbd01478-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbd01479-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Such Act, referred to in par. (7), means the Americans with Disabilities Act of 1990, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbd0147a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbd0147b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s109"},"text":"Pub. L. 117–328, div. II, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6089"},"text":"136 Stat. 6089","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dII/s109"},"text":"“This division [enacting this chapter and provisions set out as a note under this section] shall take effect on the date that is 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbbd0147c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s101"},"text":"Pub. L. 117–328, div. II, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6084"},"text":"136 Stat. 6084","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dII/s101"},"text":"“This division [enacting this chapter and provisions set out as a note under this section] may be cited as the ‘Pregnant Workers Fairness Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
