{"tag":"section","attrib":{"id":"idb88fdd70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395b–7"},"text":"§ 1395b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation of medicare benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88fdd71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall furnish to each individual for whom payment has been made under this subchapter (or would be made without regard to any deductible) a statement which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88fdd72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists the item or service for which payment has been made and the amount of such payment for each item or service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a notice of the individual’s right to request an itemized statement (as provided in subsection (b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88fdd74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for itemized statement for medicare items and services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88fdd75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may submit a written request to any physician, provider, supplier, or any other person (including an organization, agency, or other entity) for an itemized statement for any item or service provided to such individual by such person with respect to which payment has been made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 30-day period to furnish statement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88fdd77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which a request under paragraph (1) has been made, a person described in such paragraph shall furnish an itemized statement describing each item or service provided to the individual requesting the itemized statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88fdd78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly fails to furnish an itemized statement in accordance with subparagraph (A) shall be subject to a civil money penalty of not more than $100 for each such failure. Such penalty shall be imposed and collected in the same manner as civil money penalties under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" are imposed and collected under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of itemized statement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88fdd7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the receipt of an itemized statement furnished under paragraph (1), an individual may submit a written request for a review of the itemized statement to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88fdd7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific allegations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A request for a review of the itemized statement shall identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb88fdd7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific items or services that the individual believes were not provided as claimed, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb88fdd7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other billing irregularity (including duplicate billing).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, with respect to each written request submitted under paragraph (3), determine whether the itemized statement identifies specific items or services that were not provided as claimed or any other billing irregularity (including duplicate billing) that has resulted in unnecessary payments under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take all appropriate measures to recover amounts unnecessarily paid under this subchapter with respect to a statement described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88fdd80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format of statements from Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88fdd81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic option beginning in 2016","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), for statements described in subsection (a) that are furnished for a period in 2016 or a subsequent year, in the case that an individual described in subsection (a) elects, in accordance with such form, manner, and time specified by the Secretary, to receive such statement in an electronic format, such statement shall be furnished to such individual for each period subsequent to such election in such a format and shall not be mailed to the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on revocation option","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88fdd83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary may determine a maximum number of elections described in paragraph (1) by an individual that may be revoked by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88fdd84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum of one revocation option","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case may the Secretary determine a maximum number under subparagraph (A) that is less than one.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88fdd85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–7/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that, in the most cost effective manner and beginning ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", a clear notification of the option to elect to receive statements described in subsection (a) in an electronic format is made available, such as through the notices distributed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–2"},"text":"section 1395b–2 of this title","children":[],"tail":", to individuals described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb88fdd86-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1806, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4311/b/1"},"text":"Pub. L. 105–33, title IV, § 4311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/385"},"text":"111 Stat. 385","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s508/a"},"text":"Pub. L. 114–10, title V, § 508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/169"},"text":"129 Stat. 169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb88fdd87-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb88fdd88-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88fdd89-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10"},"text":"Pub. L. 114–10","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88fdd8a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb88fdd8b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4311/b/3"},"text":"Pub. L. 105–33, title IV, § 4311(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/386"},"text":"111 Stat. 386","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tIV/s4311/b/3"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement by secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) of section 1806(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–7/a/1"},"text":"42 U.S.C. 1395b–7(a)(1)","children":[],"tail":"], as added by paragraph (1), and the repeal made by paragraph (2) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–5"},"text":"section 1395b–5 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Itemized statement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2) of section 1806(a) and section 1806(b) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–7/a/2"},"text":"42 U.S.C. 1395b–7(a)(2)","children":[],"tail":", (b)], as so added, shall take effect not later than "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88fdd8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Encouraged Expansion of Electronic Statements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/tV/s508/b"},"text":"Pub. L. 114–10, title V, § 508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/169"},"text":"129 Stat. 169","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/10/tV/s508/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“To the extent to which the Secretary of Health and Human Services determines appropriate, the Secretary shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply an option similar to the option described in subsection (c)(1) of section 1806 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–7"},"text":"42 U.S.C. 1395b–7","children":[],"tail":") (relating to the provision of the Medicare Summary Notice in an electronic format), as added by subsection (a), to other statements and notifications under title XVIII of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such Medicare Summary Notice and any such other statements and notifications on a more frequent basis than is otherwise required under such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88fdd8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Additional Information in Notices to Beneficiaries About Skilled Nursing Facility Benefits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s925"},"text":"Pub. L. 108–173, title IX, § 925","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2396"},"text":"117 Stat. 2396","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/173/tIX/s925"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Health and Human Services] shall provide that in medicare beneficiary notices provided (under section 1806(a) of the Social Security Act, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–7/a"},"text":"42 U.S.C. 1395b–7(a)","children":[],"tail":") with respect to the provision of post-hospital extended care services under part A of title XVIII of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.], there shall be included information on the number of days of coverage of such services remaining under such part for the medicare beneficiary and spell of illness involved."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply to notices provided during calendar quarters beginning more than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
