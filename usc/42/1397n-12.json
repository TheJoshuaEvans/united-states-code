{"tag":"section","attrib":{"id":"idbaaf8955-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397n–12"},"text":"§ 1397n–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this division:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8956-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8957-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intervention” means a specific service delivered to achieve an impact through a social impact partnership project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8958-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social impact partnership project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “social impact partnership project” means a project that finances social services using a social impact partnership model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf895a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social impact partnership model","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “social impact partnership model” means a method of financing social services in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaf895b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal funds are awarded to a State or local government only if a State or local government achieves certain outcomes agreed on by the State or local government and the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf895c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State or local government coordinates with service providers, investors (if applicable to the project), and (if necessary) an intermediary to identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaf895d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intervention expected to produce the outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaf895e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service provider to deliver the intervention to the target population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaf895f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investors to fund the delivery of the intervention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8960-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–12/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each State of the United States, the District of Columbia, each commonwealth, territory or possession of the United States, and each federally recognized Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf8961-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2063, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVIII/s50802/2"},"text":"Pub. L. 115–123, div. E, title VIII, § 50802(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/282"},"text":"132 Stat. 282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
