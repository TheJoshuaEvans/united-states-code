{"tag":"section","attrib":{"id":"idbfd3e9ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921"},"text":null,"children":[{"tag":"num","attrib":{"value":"14921"},"text":"§ 14921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation or approval required in order to provide adoption services in cases subject to the Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd3e9ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this subchapter, no person may offer or provide adoption services in connection with a Convention adoption in the United States unless that person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited or approved in accordance with this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is providing such services through or under the supervision and responsibility of an accredited agency or approved person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background studies and home studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The performance of a background study on a child or a home study on a prospective adoptive parent, or any report on any such study by a social work professional or organization who is not providing any other adoption service in the case, if the background or home study is approved by an accredited agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child welfare services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of a child welfare service by a person who is not providing any other adoption service in the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of legal services by a person who is not providing any adoption service in the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14921/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective adoptive parents acting on own behalf","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The conduct of a prospective adoptive parent on his or her own behalf in the case, to the extent not prohibited by the law of the State in which the prospective adoptive parent resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd3e9b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tII/s201"},"text":"Pub. L. 106–279, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/830"},"text":"114 Stat. 830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd3e9b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd3e9b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd3e9b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/830"},"text":"114 Stat. 830","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd3e9b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd3e9b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon entry into force for the United States of the Convention on Protection of Children and Co-operation in Respect of Intercountry Adoption, pursuant to Article 46(2)(a) of the Convention, with transition rule, see section 505(a)(2), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
