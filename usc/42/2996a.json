{"tag":"section","attrib":{"id":"idbc31e2f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2996a"},"text":"§ 2996a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e2f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Board of Directors of the Legal Services Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Corporation” means the Legal Services Corporation established under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “eligible client” means any person financially unable to afford legal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Governor” means the chief executive officer of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “legal assistance” means the provision of any legal services consistent with the purposes and provisions of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “recipient” means any grantee, contractee, or recipient of financial assistance described in clause (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2996e/a/1"},"text":"section 2996e(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “staff attorney” means an attorney who receives more than one-half of his annual professional income from a recipient organized solely for the provision of legal assistance to eligible clients under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e301-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tX/s1002"},"text":"Pub. L. 88–452, title X, § 1002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/355/s2"},"text":"Pub. L. 93–355, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/378"},"text":"88 Stat. 378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e302-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbc31e303-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc31e304-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
