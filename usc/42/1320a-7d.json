{"tag":"section","attrib":{"id":"idb83a1bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–7d"},"text":"§ 1320a–7d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance regarding application of health care fraud and abuse sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb83a1bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation and publication of modifications to existing safe harbors and new safe harbors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals for safe harbors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", and not less than annually thereafter, the Secretary shall publish a notice in the Federal Register soliciting proposals, which will be accepted during a 60-day period, for—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications to existing safe harbors issued pursuant to section 14(a) of the Medicare and Medicaid Patient and Program Protection Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b"},"text":"42 U.S.C. 1320a–7b","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional safe harbors specifying payment practices that shall not be treated as a criminal offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/b"},"text":"section 1320a–7b(b) of this title","children":[],"tail":" and shall not serve as the basis for an exclusion under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7/b/7"},"text":"section 1320a–7(b)(7) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advisory opinions to be issued pursuant to subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special fraud alerts to be issued pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposed modifications and proposed additional safe harbors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After considering the proposals described in clauses (i) and (ii) of subparagraph (A), the Secretary, in consultation with the Attorney General, shall publish in the Federal Register proposed modifications to existing safe harbors and proposed additional safe harbors, if appropriate, with a 60-day comment period. After considering any public comments received during this period, the Secretary shall issue final rules modifying the existing safe harbors and establishing new safe harbors, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Health and Human Services (in this section referred to as the “Inspector General”) shall, in an annual report to Congress or as part of the year-end semiannual report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405"},"text":"section 405 of title 5","children":[],"tail":", describe the proposals received under clauses (i) and (ii) of subparagraph (A) and explain which proposals were included in the publication described in subparagraph (B), which proposals were not included in that publication, and the reasons for the rejection of the proposals that were not included."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for modifying and establishing safe harbors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In modifying and establishing safe harbors under paragraph (1)(B), the Secretary may consider the extent to which providing a safe harbor for the specified payment practice may result in any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in access to health care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in the quality of health care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in patient freedom of choice among health care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in competition among health care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in the ability of health care facilities to provide services in medically underserved areas or to medically underserved populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in the cost to Federal health care programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/f"},"text":"section 1320a–7b(f) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase or decrease in the potential overutilization of health care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The existence or nonexistence of any potential financial benefit to a health care professional or provider which may vary based on their decisions of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to order a health care item or service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to arrange for a referral of health care items or services to a particular practitioner or provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other factors the Secretary deems appropriate in the interest of preventing fraud and abuse in Federal health care programs (as so defined).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of safe harbor for certain contingency management interventions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Inspector General shall conduct a review on whether to establish a safe harbor described in paragraph (1)(A)(ii) for evidence-based contingency management incentives and the parameters for such a safe harbor. In conducting the review under the previous sentence, the Inspector General shall consider the extent to which providing such a safe harbor for evidence-based contingency management incentives may result in any of the factors described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary and the Inspector General shall submit to Congress recommendations, including based on the review conducted under subparagraph (A), for improving access to evidence-based contingency management interventions while ensuring quality of care, ensuring fidelity to evidence-based practices, and including strong program integrity safeguards that prevent increased waste, fraud, and abuse and prevent medically unnecessary or inappropriate items or services reimbursed in whole or in part by a Federal health care program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83a1bcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory opinions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1bcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of advisory opinions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Attorney General, shall issue written advisory opinions as provided in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters subject to advisory opinions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue advisory opinions as to the following matters:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" What constitutes prohibited remuneration within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/b"},"text":"section 1320a–7b(b) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/i/6"},"text":"section 1320a–7a(i)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether an arrangement or proposed arrangement satisfies the criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/b/3"},"text":"section 1320a–7b(b)(3) of this title","children":[],"tail":" for activities which do not result in prohibited remuneration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether an arrangement or proposed arrangement satisfies the criteria which the Secretary has established, or shall establish by regulation for activities which do not result in prohibited remuneration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" What constitutes an inducement to reduce or limit services to individuals entitled to benefits under subchapter XVIII or subchapter XIX within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/b"},"text":"section 1320a–7a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether any activity or proposed activity constitutes grounds for the imposition of a sanction under section 1320a–7, 1320a–7a, or 1320a–7b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters not subject to advisory opinions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such advisory opinions shall not address the following matters:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the fair market value shall be, or was paid or received for any goods, services or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether an individual is a bona fide employee within the requirements of section 3121(d)(2) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of advisory opinions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding as to Secretary and parties involved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each advisory opinion issued by the Secretary shall be binding as to the Secretary and the party or parties requesting the opinion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to seek opinion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure of a party to seek an advisory opinion may not be introduced into evidence to prove that the party intended to violate the provisions of sections ","children":[{"tag":"ref","attrib":{"idref":"fn002696"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002696"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 1320a–7, 1320a–7a, or 1320a–7b of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":", the Secretary shall issue regulations to carry out this section. Such regulations shall provide for—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure to be followed by a party applying for an advisory opinion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure to be followed by the Secretary in responding to a request for an advisory opinion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interval in which the Secretary shall respond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable fee to be charged to the party requesting an advisory opinion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which advisory opinions will be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the regulations promulgated pursuant to subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83a1be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall be required to issue to a party requesting an advisory opinion by not later than 60 days after the request is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83a1be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee charged to the party requesting an advisory opinion shall be equal to the costs incurred by the Secretary in responding to the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of subsection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply to requests for advisory opinions made on or after the date which is 6 months after ","children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83a1be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special fraud alerts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83a1be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for special fraud alerts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person may present, at any time, a request to the Inspector General for a notice which informs the public of practices which the Inspector General considers to be suspect or of particular concern under the Medicare program under subchapter XVIII or a State health care program, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7/h"},"text":"section 1320a–7(h) of this title","children":[],"tail":" (in this subsection referred to as a “special fraud alert”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and publication of special fraud alerts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a request described in subparagraph (A), the Inspector General shall investigate the subject matter of the request to determine whether a special fraud alert should be issued. If appropriate, the Inspector General shall issue a special fraud alert in response to the request. All special fraud alerts issued pursuant to this subparagraph shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83a1be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for special fraud alerts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to issue a special fraud alert upon a request described in paragraph (1), the Inspector General may consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83a1bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether and to what extent the practices that would be identified in the special fraud alert may result in any of the consequences described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83a1beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume and frequency of the conduct that would be identified in the special fraud alert.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb83a1bec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1128D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s205"},"text":"Pub. L. 104–191, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2000"},"text":"110 Stat. 2000","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4331/a/1"},"text":"Pub. L. 105–33, title IV, § 4331(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/395"},"text":"111 Stat. 395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tV/s5201/c"},"text":"Pub. L. 105–277, div. J, title V, § 5201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-917"},"text":"112 Stat. 2681–917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tV/s543"},"text":"Pub. L. 106–554, § 1(a)(6) [title V, § 543]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–551; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/79"},"text":"Pub. L. 117–286, § 4(b)(79)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4351"},"text":"136 Stat. 4351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tIV/s4127"},"text":"Pub. L. 117–328, div. FF, title IV, § 4127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5915"},"text":"136 Stat. 5915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb83a1bed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb83a1bee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb83a1bef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 14(a) of the Medicare and Medicaid Patient and Program Protection Act of 1987, referred to in subsec. (a)(1)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/93/s14/a"},"text":"section 14(a) of Pub. L. 100–93","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b"},"text":"section 1320a–7b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (b)(3)(B), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb83a1bf0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s405"},"text":"section 405 of title 5","children":[],"tail":",” for “section 5 of the Inspector General Act of 1978 (5 U.S.C. App.),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" struck out “, and before the date which is 4 years after "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted “or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/i/6"},"text":"section 1320a–7a(i)(6) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" substituted “section 1320a–7a(b)” for “section 1320a–7b(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb83a1bf1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb83a1bf2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of the Health Insurance Portability and Accountability Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4331/f"},"text":"section 4331(f) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7e"},"text":"section 1320a–7e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
