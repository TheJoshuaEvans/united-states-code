{"tag":"section","attrib":{"id":"idc075f577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016"},"text":null,"children":[{"tag":"num","attrib":{"value":"19016"},"text":"§ 19016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Diversity Officer of the NSF","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc075f578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Diversity Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall appoint a senior agency official within the Office of the Director as a Chief Diversity Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f57a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Diversity Officer shall have significant experience, within the Federal Government and the science community, with diversity- and inclusion-related matters, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f57b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil rights compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f57c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harassment policy, reviews, and investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f57d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal employment opportunity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f57e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc075f57f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Diversity Officer is responsible for providing advice on policy, oversight, guidance, and coordination with respect to matters of the Foundation related to diversity and inclusion, including ensuring the geographic diversity of the Foundation programs. Other duties may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining a strategic plan that publicly states a diversity definition, vision, and goals for the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" defining a set of strategic metrics that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly linked to key organizational priorities and goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actionable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively used to implement the strategic plan under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising in the establishment of a strategic plan for diverse participation by individuals and institutions of higher education, including community colleges, historically Black colleges and universities, Tribal Colleges or Universities, minority serving institutions, institutions of higher education with an established STEM capacity building program focused on Native Hawaiians or Alaska Natives, and EPSCoR institutions); ","children":[{"tag":"ref","attrib":{"idref":"fn004388"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004388"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The closing parenthesis probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising in the establishment of a strategic plan for outreach to, and recruiting from, untapped locations and underrepresented populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising on a diversity and inclusion strategy for the Foundation’s portfolio of PreK–12 STEM education focused programs and activities, including goals for addressing barriers to participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising on the application of the Foundation’s broader impacts review criterion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing such additional duties and exercise such powers as the Director may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc075f58a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19016/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc075f58b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10327"},"text":"Pub. L. 117–167, div. B, title III, § 10327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1544"},"text":"136 Stat. 1544","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
