{"tag":"section","attrib":{"id":"idbc1a1582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297g"},"text":"§ 2297g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uranium Enrichment Decontamination and Decommissioning Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1a1583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States an account to be known as the Uranium Enrichment Decontamination and Decommissioning Fund (referred to in this subchapter as the “Fund”). The Fund, and any amounts deposited in it, including any interest earned thereon, shall be available to the Secretary subject to appropriations for the exclusive purpose of carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1a1585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall hold the Fund and, after consultation with the Secretary, annually report to the Congress on the financial condition and operations of the Fund during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1a1586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall invest amounts contained within the Fund in obligations of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc1a1587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having maturities determined by the Secretary of the Treasury to be appropriate for what the Department determines to be the needs of the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc1a1588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bearing interest at rates determined to be appropriate by the Secretary of the Treasury, taking into consideration the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to these obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1a1589-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title II, § 1801, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXI/s1101"},"text":"Pub. L. 102–486, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2953"},"text":"106 Stat. 2953","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
