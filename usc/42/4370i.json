{"tag":"section","attrib":{"id":"idbcccea03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370i"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370i"},"text":"§ 4370i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional liaisons for minority, tribal, and low-income communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcccea04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency (referred to in this section as the “Administrator”) shall assign at least one employee in each regional office of the Environmental Protection Agency to serve as a liaison to minority, Tribal, and low-income communities in the relevant region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall identify each regional liaison assigned under subsection (a) on the internet website of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant regional office of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Environmental Justice of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcccea08-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4305"},"text":"Pub. L. 115–270, title IV, § 4305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3883"},"text":"132 Stat. 3883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcccea09-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcccea0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcccea0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America’s Water Infrastructure Act of 2018, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
