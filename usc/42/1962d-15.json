{"tag":"section","attrib":{"id":"idbba9ee8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–15"},"text":"§ 1962d–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of United States from liability for damages; exception of damages due to fault or negligence of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The requirement in any water resources development project under the jurisdiction of the Secretary of the Army, that non-Federal interests hold and save the United States free from damages due to the construction, operation, and maintenance of the project, does not include damages due to the fault or negligence of the United States or its contractors.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba9ee8e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/251/tI/s9"},"text":"Pub. L. 93–251, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-07"},"text":"Mar. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/16"},"text":"88 Stat. 16","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9ee8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9ee90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9ee91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1974, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
