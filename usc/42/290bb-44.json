{"tag":"section","attrib":{"id":"idb5b67e90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–44"},"text":"§ 290bb–44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assertive community treatment grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b67e91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall award grants to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish assertive community treatment programs for adults with a serious mental illness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain or expand such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be a State, political subdivision of a State, Indian Tribe or Tribal organization (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), mental health system, health care facility, or any other entity the Assistant Secretary deems appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting among applicants for a grant under this section, the Assistant Secretary may give special consideration to the potential of the applicant’s program to reduce hospitalization, homelessness, and involvement with the criminal justice system while improving the health and social outcomes of the patient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than the end of fiscal year 2026, submit a report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives on the grant program under this section, including an evaluation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cost savings and public health outcomes such as mortality, suicide, substance use disorders, hospitalization, and use of services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates of involvement with the criminal justice system of patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates of homelessness among patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient and family satisfaction with program participation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate information, training, and technical assistance to grant recipients under this section to help such recipients to establish, maintain, or expand their assertive community treatment programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $9,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–44/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of certain funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated to carry out this section in any fiscal year, not more than 5 percent shall be available to the Assistant Secretary for carrying out subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b67ea0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520M, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9015"},"text":"Pub. L. 114–255, div. B, title IX, § 9015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1245"},"text":"130 Stat. 1245","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1123/a"},"text":"Pub. L. 117–328, div. FF, title I, § 1123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5653"},"text":"136 Stat. 5653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b67ea1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b67ea2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b67ea3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1123/a/1"},"text":"Pub. L. 117–328, § 1123(a)(1)","children":[],"tail":", substituted “Indian Tribe or Tribal organization” for “Indian tribe or tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1123/a/2"},"text":"Pub. L. 117–328, § 1123(a)(2)","children":[],"tail":", in introductory provisions, substituted “not later than the end of fiscal year 2026” for “not later than the end of fiscal year 2021” and “Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives” for “appropriate congressional committees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1123/a/3"},"text":"Pub. L. 117–328, § 1123(a)(3)","children":[],"tail":", substituted “$9,000,000 for each of fiscal years 2023 through 2027” for “$5,000,000 for the period of fiscal years 2018 through 2022”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
