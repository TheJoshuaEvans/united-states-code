text":"Pub. L. 103–183, title I, § 101(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2228"},"text":"107 Stat. 2228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/183/tI/s101/c/2"},"text":"“With respect to the screening procedure for breast cancer known as a mammography, the requirements in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":"] under section 1503(c) of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300m/c"},"text":"42 U.S.C. 300m(c)","children":[],"tail":"] remain in effect (for an individual or facility conducting such procedures pursuant to a grant to a State under section 1501 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"42 U.S.C. 300k","children":[],"tail":"]) until there is in effect for the facility a certificate (or provisional certificate) issued under section 354 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263b"},"text":"42 U.S.C. 263b","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
