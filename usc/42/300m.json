{"tag":"section","attrib":{"id":"idb64f14c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m"},"text":null,"children":[{"tag":"num","attrib":{"value":"300m"},"text":"§ 300m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements with respect to type and quality of services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64f14c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of provision of all services by date certain","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f14c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that, initially and throughout the period during which amounts are received pursuant to the grant, not less than 60 percent of the grant is expended to provide each of the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":", including making available screening procedures for both breast and cervical cancers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f14c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (b), to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64f14c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of breast cancer, both a physical examination of the breasts and the screening procedure known as a mammography are conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of cervical cancer, both a pelvic examination and the screening procedure known as a pap smear are conducted;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f14c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that, by the end of any second fiscal year of payments pursuant to the grant, each of the services or activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":" is provided; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f14c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that not more than 40 percent of the grant is expended to provide the services or activities described in paragraphs (3) through (6) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f14c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of improved screening procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that, if any screening procedure superior to a procedure described in subsection (a)(2) becomes commonly available and is recommended for use, any entity providing screening procedures pursuant to the grant will utilize the superior procedure rather than the procedure described in such subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f14ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality assurance regarding screening procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that the State will, in accordance with applicable law, assure the quality of screening procedures conducted pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f14cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of services requirement on division of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f14cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a demonstration project under which the Secretary may waive the requirements of paragraphs (1) and (4) of subsection (a) for not more than 5 States, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64f14cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State involved will use the waiver to leverage non-Federal funds to supplement each of the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of such requirement would result in a barrier to the enrollment of qualifying women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State involved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64f14d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates, to the satisfaction of the Secretary, the manner in which the State will use such waiver to expand the level of screening and follow-up services provided immediately prior to the date on which the waiver is granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f14d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides assurances, satisfactory to the Secretary, that the State will, on an annual basis, demonstrate, through such documentation as the Secretary may require, that the State has used such waiver as described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State involved submits to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64f14d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances, satisfactory to the Secretary, that the State will maintain the average annual level of State fiscal year expenditures for the services and activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":" for the period for which the waiver is granted, and for the period for which any extension of such wavier "},{"tag":"ref","attrib":{"idref":"fn002356"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002356"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “waiver”."}],"tail":" is granted, at a level that is not less than—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb64f14d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of the State fiscal year expenditures for such services and activities for the fiscal year preceding the first fiscal year for which the waiver is granted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb64f14d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of the State and upon approval by the Secretary, the average level of the State expenditures for such services and activities for the 3-fiscal year period preceding the first fiscal year for which the waiver is granted; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64f14d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, satisfactory to the Secretary, for maintaining the level of activities carried out under the waiver after the expiration of the waiver and any extension of such waiver;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that granting such a waiver to a State will increase the number of women in the State that receive each of the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":", including making available screening procedures for both breast and cervical cancers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64f14d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that granting such a waiver to a State will not adversely affect the quality of each of the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6515eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In granting waivers under paragraph (1), the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6515ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall grant such waivers for a period that is not less than 1 year but not more than 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6515ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request of a State, may extend a waiver for an additional period that is not less than 1 year but not more than 2 years in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6515ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, upon the request of a State that has received a waiver under paragraph (1), shall, at the end of the waiver period described in subparagraph (A)(i), review performance under the waiver and may extend the waiver for an additional period if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6515ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without an extension of the waiver, there will be a barrier to the enrollment of qualifying women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6515ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State requesting such extended waiver will use the waiver to leverage non-Federal funds to supplement the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6515ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver has increased, and will continue to increase, the number of women in the State that receive the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6515ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver has not, and will not, result in lower quality in the State of the services or activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6515ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State has maintained the average annual level of State fiscal expenditures for the services and activities described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":" for the period for which the waiver was granted at a level that is not less than—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb6515ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of the State fiscal year expenditures for such services and activities for the fiscal year preceding the first fiscal year for which the waiver is granted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6515ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of the State and upon approval by the Secretary, the average level of the State expenditures for such services and activities for the 3-fiscal year period preceding the first fiscal year for which the waiver is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include as part of the evaluations and reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300n–4"},"text":"section 300n–4 of this title","children":[],"tail":", the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6515ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300m/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the total amount of dollars leveraged annually from Non-Federal ","children":[{"tag":"ref","attrib":{"idref