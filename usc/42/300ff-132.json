{"tag":"section","attrib":{"id":"idb6a4d640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–132"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–132"},"text":"§ 300ff–132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Routine notifications with respect to airborne infectious diseases in victims assisted","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Routine notification of designated officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by treating facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a victim of an emergency is transported by emergency response employees to a medical facility and the medical facility makes a determination that the victim has an airborne infectious disease, the medical facility shall notify the designated officer of the emergency response employees who transported the victim to the medical facility of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by facility ascertaining cause of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a victim of an emergency is transported by emergency response employees to a medical facility and the victim dies at or before reaching the medical facility, the medical facility ascertaining the cause of death shall notify the designated officer of the emergency response employees who transported the victim to the initial medical facility of any determination by the medical facility that the victim had an airborne infectious disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of prompt notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a determination described in paragraph (1) or (2) of subsection (a), the notification required in each of such paragraphs shall be made as soon as is practicable, but not later than 48 hours after the determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d645-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2695A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s13"},"text":"Pub. L. 111–87, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2898"},"text":"123 Stat. 2898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d646-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d647-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d648-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
