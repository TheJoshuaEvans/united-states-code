{"tag":"section","attrib":{"id":"idb5786402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"285l–5"},"text":"§ 285l–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5786403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title shall not apply to research, including research performed using biotechnology techniques, or research related to the causes, diagnosis, treatment, control, or prevention of physical or mental diseases or impairments of humans or animals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of test methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title shall prevent a Federal agency from retaining final authority for incorporating the test methods recommended by the ICCVAM in the manner determined to be appropriate by such Federal agency or regulatory body."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title shall be construed to require a manufacturer that is currently not required to perform animal testing to perform such tests. Nothing in sections 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title shall be construed to require a manufacturer to perform redundant endpoint specific testing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285l–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of tests and data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in sections 285","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 to 285"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–5 of this title precludes a party from submitting a test method or scientific data directly to a Federal agency for use in a regulatory program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5786407-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/545/s5"},"text":"Pub. L. 106–545, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2724"},"text":"114 Stat. 2724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5786408-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5786409-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb578640a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the ICCVAM Authorization Act of 2000, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
