{"tag":"section","attrib":{"id":"idbf4739c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383"},"text":null,"children":[{"tag":"num","attrib":{"value":"11383"},"text":"§ 11383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf4739c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382"},"text":"section 11382 of this title","children":[],"tail":" to qualified applicants shall be used to carry out projects that serve homeless individuals or families that consist of one or more of the following eligible activities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4739c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction of new housing units to provide transitional or permanent housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition or rehabilitation of a structure to provide transitional or permanent housing, other than emergency shelter, or to provide supportive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leasing of property, or portions of property, not owned by the recipient or project sponsor involved, for use in providing transitional or permanent housing, or providing supportive services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of rental assistance to provide transitional or permanent housing to eligible persons. The rental assistance may include tenant-based, project-based, or sponsor-based rental assistance. Project-based rental assistance, sponsor-based rental assistance, and operating cost assistance contracts carried out by project sponsors receiving grants under this section may, at the discretion of the applicant and the project sponsor, have an initial term of 15 years, with assistance for the first 5 years paid with funds authorized for appropriation under this chapter, and assistance for the remainder of the term treated as a renewal of an expiring contract as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11386c"},"text":"section 11386c of this title","children":[],"tail":". Project-based rental assistance may include rental assistance to preserve existing permanent supportive housing for homeless individuals and families."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of operating costs for housing units assisted under this part or for the preservation of housing that will serve homeless individuals and families and for which another form of assistance is expiring or otherwise no longer available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supportive services for individuals and families who are currently homeless, who have been homeless in the prior six months but are currently residing in permanent housing, or who were previously homeless and are currently residing in permanent supportive housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Provision of rehousing services, including housing search, mediation or outreach to property owners, credit repair, providing security or utility deposits, rental assistance for a final month at a location, assistance with moving costs, or other activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4739cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are effective at moving homeless individuals and families immediately into housing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may benefit individuals and families who in the prior 6 months have been homeless, but are currently residing in permanent housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a collaborative applicant that is a legal entity, performance of the duties described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360a/f/3"},"text":"section 11360a(f)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation of, participation in, and ensuring consistent participation by project sponsors in, a community-wide homeless management information system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a collaborative applicant that is a legal entity, payment of administrative costs related to meeting the requirements described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360a/f"},"text":"section 11360a(f) of this title","children":[],"tail":", for which the collaborative applicant may use not more than 3 percent of the total funds made available in the geographic area under this part for such costs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a collaborative applicant that is a unified funding agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360a/g"},"text":"section 11360a(g) of this title","children":[],"tail":", payment of administrative costs related to meeting the requirements of that section, for which the unified funding agency may use not more than 3 percent of the total funds made available in the geographic area under this part for such costs, in addition to funds used under paragraph (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of administrative costs to project sponsors, for which each project sponsor may use not more than 10 percent of the total funds made available to that project sponsor through this part for such costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two pars. (13) have been enacted."}],"tail":" Facilitating and coordinating activities to ensure compliance with subsection (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491"},"text":"section 12491 of title 34","children":[],"tail":" and monitoring compliance with the confidentiality protections of subsection (c)(4) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Projects in rural areas that consist of one or more of the following activities:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4739d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of short-term emergency lodging, including in motels or shelters, directly or through vouchers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Repairs to units—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf4739d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which homeless individuals and families will be housed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf4739d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are currently not fit for human habitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/a/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Staff training, professional development, skill development, and staff retention activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may impose minimum grant terms of up to 5 years for new projects providing permanent housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4739dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition, rehabilitation, and new construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that consists of activities described in paragraph (1) or (2) of subsection (a) shall be operated for the purpose specified in the application submitted for the project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382"},"text":"section 11382 of this title","children":[],"tail":" for not less than 15 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that consists of activities described in any of paragraphs (3) through (12) of subsection (a) shall be operated for the purpose specified in the application submitted for the project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382"},"text":"section 11382 of this title","children":[],"tail":" for the duration of the grant period involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the recipient or project sponsor carrying out a project that provides transitional or permanent housing submits a request to the Secretary to carry out instead a project for the direct benefit of low-income persons, and the Secretary determines that the initial project is no longer needed to provide transitional or permanent housing, the Secretary may approve the project described in the request and authorize the recipient or project sponsor to carry out that project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of assistance and prevention of undue benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4739e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a recipient or project sponsor receives assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382"},"text":"section 11382 of this title","children":[],"tail":" to carry out a project that consists of activities described in paragraph (1) or (2) of subsection (a) and the project ceases to provide transitional or permanent housing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4739e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earlier than 10 years after operation of the project begins, the Secretary shall require the recipient or project sponsor to repay 100 percent of the assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not earlier than 10 years, but earlier than 15 years, after operation of the project begins, the Secretary shall require the recipient or project sponsor to repay 20 percent of the assistance for each of the years in the 15-year period for which the project fails to provide that housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of undue benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), if any property is used for a project that receives assistance under subsection (a) and consists of activities described in paragraph (1) or (2) of subsection (a), and the sale or other disposition of the property occurs before the expiration of the 15-year period beginning on the date that operation of the project begins, the recipient or project sponsor who received the assistance shall comply with such terms and conditions as the Secretary may prescribe to prevent the recipient or project sponsor from unduly benefitting from such sale or disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient or project sponsor shall not be required to make the repayments, and comply with the terms and conditions, required under paragraph (1) or (2) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf4739e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale or disposition of the property used for the project results in the use of the property for the direct benefit of very low-income persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the proceeds of the sale or disposition are used to provide transitional or permanent housing meeting the requirements of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project-based rental assistance or operating cost assistance from any Federal program or an equivalent State or local program is no longer made available and the project is meeting applicable performance standards, provided that the portion of the project that had benefitted from such assistance continues to meet the tenant income and rent restrictions for low-income units under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s42/g"},"text":"section 42(g) of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf4739e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are no individuals and families in the geographic area who are homeless, in which case the project may serve individuals and families at risk of homelessness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may allow reasonable costs associated with staff training to be included as part of the activities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for permanent housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any project that receives assistance under subsection (a) and that provides project-based or sponsor-based permanent housing for homeless individuals or families with a disability, including projects that meet the requirements of subsection (a) and subsection (d)(2)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11386b"},"text":"section 11386b of this title","children":[],"tail":" may also serve individuals who had previously met the requirements for such project prior to moving into a different permanent housing project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11383/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of rental assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Provision of permanent housing rental assistance shall be administered by a State, unit of general local government, private nonprofit organization, or public housing agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4739ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s423"},"text":"Pub. L. 100–77, title IV, § 423","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1302"},"text":"Pub. L. 111–22, div. B, title III, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"