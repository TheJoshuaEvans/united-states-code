{"tag":"section","attrib":{"id":"idbd1b8028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5182"},"text":null,"children":[{"tag":"num","attrib":{"value":"5182"},"text":"§ 5182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the President determines that low-income individuals are unable to secure legal services adequate to meet their needs as a consequence of a major disaster, consistent with the goals of the programs authorized by this chapter, the President shall assure that such programs are conducted with the advice and assistance of appropriate Federal agencies and State and local bar associations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd1b8029-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s415"},"text":"Pub. L. 93–288, title IV, § 415","children":[],"tail":", formerly § 412, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/157"},"text":"88 Stat. 157","children":[],"tail":"; renumbered § 415, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/h"},"text":"Pub. L. 100–707, title I, § 106(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b802a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b802b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":