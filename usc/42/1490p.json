 L. 101–235, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2048"},"text":"103 Stat. 2048","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/235/tIV/s401/b"},"text":"“Section 536 of the Housing Act of 1949 [this section], as added by subsection (a), shall take effect on the effective date of regulations implementing such section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
