{"tag":"section","attrib":{"id":"idbdbb421f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803"},"text":null,"children":[{"tag":"num","attrib":{"value":"6803"},"text":"§ 6803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of electric utility rate design proposals by Secretary; contents; submission to Congress; supporting analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbb4220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall develop proposals to improve electric utility rate design. Such proposals shall be designed to encourage energy conservation, minimize the need for new electrical generating capacity, and minimize costs of electric energy to consumers, and shall include (but not be limited to) proposals which provide for the development and implementation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb4221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" load management techniques which are cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates which reflect marginal cost of service, or time of use of service, or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ratemaking policies which discourage inefficient use of fuel and encourage economical purchases of fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates (or other regulatory policies) which encourage electric utility system reliability and reliability of major items of electric utility equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb4225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The proposals prepared under subsection (a) shall be transmitted to each House of Congress not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"August 14, 1976","children":[],"tail":", for review and for such further action as the Congress may direct by law. Such proposals shall be accompanied by an analysis of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb4226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected savings (if any) in consumption of petroleum products, natural gas, electric energy, and other energy resources,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction (if any) in the need for new electrical generating capacity, and of the demand for capital by the electric utility industry, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes (if any) in the cost of electric energy to consumers,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which are likely to result from the implementation nationally of each of the proposals transmitted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb4229-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tII/s203"},"text":"Pub. L. 94–385, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1143"},"text":"90 Stat. 1143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s143"},"text":"Pub. L. 95–617, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3134"},"text":"92 Stat. 3134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb422a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb422b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb422c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
