{"tag":"section","attrib":{"id":"idb82952e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317"},"text":null,"children":[{"tag":"num","attrib":{"value":"1317"},"text":"§ 1317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of the Administrator and Chief Actuary of the Centers for Medicare & Medicaid Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82952e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Centers for Medicare & Medicaid Services shall be appointed by the President by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82952e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82952e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Centers for Medicare & Medicaid Services the position of Chief Actuary. The Chief Actuary shall be appointed by, and in direct line of authority to, the Administrator of such Centers. The Chief Actuary shall be appointed from among individuals who have demonstrated, by their education and experience, superior expertise in the actuarial sciences. The Chief Actuary shall exercise such duties as are appropriate for the office of the Chief Actuary and in accordance with professional standards of actuarial independence. The Chief Actuary may be removed only for cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82952e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Actuary shall be compensated at the highest rate of basic pay for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382/b"},"text":"section 5382(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82952e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1317/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the office of the Chief Actuary there shall be an actuary whose duties relate exclusively to the programs under parts C and D of subchapter XVIII and related provisions of such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82952e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1117, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tIII/s2332/a"},"text":"Pub. L. 98–369, div. B, title III, § 2332(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1088"},"text":"98 Stat. 1088","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4643"},"text":"Pub. L. 105–33, title IV, § 4643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/487"},"text":"111 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/c"},"text":"Pub. L. 108–173, title IX, § 900(c)","children":[],"tail":", (e)(1)(A), "},{"