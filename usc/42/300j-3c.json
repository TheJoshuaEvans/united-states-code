{"tag":"section","attrib":{"id":"idb63e4c53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–3c"},"text":"§ 300j–3c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National assistance program for water infrastructure and watersheds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb63e4c54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency may provide technical and financial assistance in the form of grants to States (1) for the construction, rehabilitation, and improvement of water supply systems, and (2) consistent with nonpoint source management programs established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1329"},"text":"section 1329 of title 33","children":[],"tail":", for source water quality protection programs to address pollutants in navigable waters for the purpose of making such waters usable by water supply systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 30 percent of the amounts appropriated to carry out this section in a fiscal year may be used for source water quality protection programs described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition to receiving assistance under this section, a State shall ensure that such assistance is carried out in the most cost-effective manner, as determined by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unconditional authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 1997 through 2003. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts authorized under paragraph (1), there are authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 1997 through 2003, provided that such authorization shall be in effect for a fiscal year only if at least 75 percent of the total amount of funds authorized to be appropriated for such fiscal year by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12/m"},"text":"section 300j–12(m) of this title","children":[],"tail":" are appropriated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided with funds made available under this section may be used for the acquisition of lands and other interests in lands; however, nothing in this section authorizes the acquisition of lands or other interests in lands from other than willing sellers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of activities for which grants are made under this section shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4c5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63e4c5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63e4c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–3c/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water supply system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “water supply system” means a system for the provision to the public of piped water for human consumption if such system has at least 15 service connections or regularly serves at least 25 individuals and a draw and fill system for the provision to the public of water for human consumption. Such term does not include a system owned by a Federal agency. Such term includes (A) any collection, treatment, storage, and distribution facilities under control of the operator of such system and used primarily in connection with such system, and (B) any collection or pretreatment facilities not under such control that are used primarily in connection with such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb63e4c5f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/tIV/s401"},"text":"Pub. L. 104–182, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1690"},"text":"110 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb63e4c60-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb63e4c61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb63e4c62-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe Drinking Water Act Amendments of 1996, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb63e4c63-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb63e4c64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Indian Reservation Drinking Water Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2001"},"text":"Pub. L. 115–270, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3840"},"text":"132 Stat. 3840","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50111"},"text":"Pub. L. 117–58, div. E, title I, § 50111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1152"},"text":"135 Stat. 1152","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dE/tI/s50111"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Environmental Protection Agency (referred to in this section as the ‘Administrator’) shall carry out a program to implement eligible projects described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project eligible to participate in the program under subsection (a) is a project—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is on a reservation (as defined in section 3 of the Indian Financing Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452"},"text":"25 U.S.C. 1452","children":[],"tail":")) that serves a federally recognized Indian Tribe; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve water quality, water pressure, or water services through means such as connecting to, expanding, repairing, improving, or obtaining water from a public water system (as defined in section 1401 of the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve water quality or sanitation or wastewater services at a treatment works (as defined in section 212 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"33 U.S.C. 1292","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Projects","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If sufficient projects exist, of the funds made available to carry out this section, the Administrator shall use 50 percent to carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 eligible projects described in subsection (b) that are within the Upper Missouri River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 eligible projects described in subsection (b) that are within the Upper Rio Grande Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 eligible projects described in subsection (b) that are within the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 eligible projects described in subsection (b) that are within the Lower Colorado River Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 eligible projects described in subsection (b) that are within the Arkansas-White-Red River Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1)(A), the Administrator shall select not fewer than 2 eligible projects for a reservation that serves more than 1 federally recognized Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting projects to carry out under this section, the Administrator shall give priority to projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to emergency situations occurring due to or resulting in a lack of access to clean drinking water that threatens the health of Tribal populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would serve a Tribal population that would qualify as a disadvantaged community based on the affordability criteria established by the applicable State under section 1452(d)(3) of the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12/d/3"},"text":"42 U.S.C. 300j–12(d)(3)","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would address the underlying factors contributing to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enforcement action commenced pursuant to the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.) against the applicable public water system (as defined in section 1401 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":")) as of the date of enactment of this subparagraph ["},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enforcement action commenced pursuant to the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.) against the applicable treatment works (as defined in section 212 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"33 U.S.C. 1292","children":[],"tail":")) as of the date of enactment of this subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out under this section shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this subsection [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Administrator shall submit to Congress a report that describes the implementation of the program established under subsection (a), which shall include a description of the use and deployment of amounts made available under that program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out the program under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2019 through 2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for each of fiscal years 2022 through 2026.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
