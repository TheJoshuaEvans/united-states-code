{"tag":"section","attrib":{"id":"idb666e2fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–6"},"text":"§ 300x–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb666e2fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":", an application for a grant under such section for a fiscal year in accordance with this section if, subject to subsection (b)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e2fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is received by the Secretary not later than September 1 of the fiscal year prior to the fiscal year for which a State is seeking funds, and the report from the previous fiscal year as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–52/a"},"text":"section 300x–52(a) of this title","children":[],"tail":" is received by December 1 of the fiscal year of the grant;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application contains each funding agreement that is described in this subpart or subpart III for such a grant (other than any such agreement that is not applicable to the State);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreements are made through certification from the chief executive officer of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such agreements, the application provides assurances of compliance satisfactory to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application contains the plan required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–1/a"},"text":"section 300x–1(a) of this title","children":[],"tail":", the information required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–4/b"},"text":"section 300x–4(b) of this title","children":[],"tail":", and the report required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–52/a"},"text":"section 300x–52(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application contains recommendations in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–4/a"},"text":"section 300x–4(a) of this title","children":[],"tail":", or if no such recommendations are received by the State, the application otherwise demonstrates compliance with such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application (including the plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–1/a"},"text":"section 300x–1(a) of this title","children":[],"tail":") is otherwise in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers regarding certain territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any territory of the United States except Puerto Rico, the Secretary may waive such provisions of this subpart and subpart III as the Secretary determines to be appropriate, other than the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–5"},"text":"section 300x–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb666e306-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1917, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/384"},"text":"106 Stat. 384","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3204/d"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3204(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8001/e"},"text":"Pub. L. 114–255, div. B, title VIII, § 8001(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1229"},"text":"130 Stat. 1229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb666e307-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb666e308-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb666e309-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300x–6, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIX/s1918"},"text":"act July 1, 1944, ch. 373, title XIX, § 1918","children":[],"tail":", formerly § 1917, as added "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"