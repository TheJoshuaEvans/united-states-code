{"tag":"section","attrib":{"id":"idbc17a43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286g"},"text":"§ 2286g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Department of Energy defense nuclear facility” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term “Department of Energy defense nuclear facility” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc17a43b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A production facility or utilization facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014"},"text":"section 2014 of this title","children":[],"tail":") that is under the control or jurisdiction of the Secretary of Energy and that is operated for national security purposes, but the term does not include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc17a43c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facility or activity covered by Executive Order No. 12344, dated ","children":[{"tag":"date","attrib":{"date":"1982-02-01"},"text":"February 1, 1982","children":[],"tail":", pertaining to the Naval nuclear propulsion program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a43d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facility or activity involved with the transportation of nuclear explosives or nuclear material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a43e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facility that does not conduct atomic energy defense activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a43f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facility owned by the United States Enrichment Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nuclear waste storage facility under the control or jurisdiction of the Secretary of Energy, but the term does not include a facility developed pursuant to the Nuclear Waste Policy Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101"},"text":"42 U.S.C. 10101","children":[],"tail":" et seq.) and licensed by the Nuclear Regulatory Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a441-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 318, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXIV/s1441/a/1"},"text":"Pub. L. 100–456, div. A, title XIV, § 1441(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2083"},"text":"102 Stat. 2083","child