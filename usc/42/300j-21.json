For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"section 921 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb64ca417-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" inserted “or drinking water fountain” after “water cooler” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Pars. (3)(A), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to references in original act which appear in text as references to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Pars. (3)(A), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s8801"},"text":"section 8801 of title 20","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182"},"text":"Pub. L. 104–182","children":[],"tail":" made technical amendment to section catchline and first word of text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/s391/p/1"},"text":"Pub. L. 103–382, § 391(p)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t20/s8801"},"text":"section 8801 of title