{"tag":"section","attrib":{"id":"idb64ca408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–21"},"text":"§ 300j–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drinking water cooler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “drinking water cooler” means any mechanical device affixed to drinking water supply plumbing which actively cools water for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca40a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead free","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lead free” means, with respect to a drinking water cooler, that each part or component of the cooler which may come in contact with drinking water contains not more than 8 percent lead, except that no drinking water cooler which contains any solder, flux, or storage tank interior surface which may come in contact with drinking water shall be considered lead free if the solder, flux, or storage tank interior surface contains more than 0.2 percent lead. The Administrator may establish more stringent requirements for treating any part or component of a drinking water cooler as lead free for purposes of this part whenever he determines that any such part may constitute an important source of lead in drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca40b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local educational agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca40c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local educational agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca40d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of any private, nonprofit elementary or secondary school building, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca40e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governing authority of any school operating under the defense dependent’s education system provided for under the Defense Dependent’s Education Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"20 U.S.C. 921","children":[],"tail":" and following)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca40f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “repair” means, with respect to a drinking water cooler, to take such corrective action as is necessary to ensure that water cooler is lead free.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “replacement”, when used with respect to a drinking water cooler or drinking water fountain, means the permanent removal of the water cooler or drinking water fountain and the installation of a lead free water cooler or drinking water fountain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school” means any elementary school or secondary school as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":" and any kindergarten or day care facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–21/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead-lined tank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lead-lined tank” means a water reservoir container in a drinking water cooler which container is constructed of lead or which has an interior surface which is not lead free.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca413-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1461, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/572/s2/a"},"text":"Pub. L. 100–572, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2884"},"text":"102 Stat. 2884","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/p"},"text":"Pub. L. 103–382, title III, § 391(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4024"},"text":"108 Stat. 4024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tV/s501/f/7"},"text":"Pub. L. 104–182, title V, § 501(f)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1692"},"text":"110 Stat. 1692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/x"},"text":"Pub. L. 107–110, title X, § 1076(x)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"h