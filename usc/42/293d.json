bered § 701 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292a"},"text":"section 292a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 740 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294m"},"text":"section 294m of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5da3320-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3401/2/A"},"text":"Pub. L. 116–136, § 3401(2)(A)","children":[],"tail":", substituted “$51,470,000 for each of fiscal years 2021 through 2025” for “$51,000,000 for fiscal year 2010, and such sums as may be necessary for each of the fiscal years 2011 through 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3401/2/B"},"text":"Pub. L. 116–136, § 3401(2)(B)","children":[],"tail":", substituted “$1,190,000 for each of fiscal years 2021 through 2025” for “$5,000,000 for each of the fiscal years 2010 through 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3401/2/C"},"text":"Pub. L. 116–136, § 3401(2)(C)","children":[],"tail":", substituted “$15,000,000 for each of fiscal years 2021 through 2025” for “$60,000,000 for fiscal year 2010 and such sums as may be necessary for each of the fiscal years 2011 through 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3401/2/D"},"text":"Pub. L. 116–136, § 3401(2)(D)","children":[],"tail":", which directed substitution of “Not later than "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", and every five years thereafter, the Secretary shall prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives,” for “Not Later than 6 months after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress”, was executed by making the substitution for “Not later than 6 months after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5402/b"},"text":"Pub. L. 111–148, § 5402(b)","children":[],"tail":", substituted “$51,000,000 for fiscal year 2010, and such sums as may be necessary for each of the fiscal years 2011 through 2014” for “$37,000,000 for fiscal year 1998, and such sums as may be necessary for each of the fiscal years 1999 through 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5402/c"},"text":"Pub. L. 111–148, § 5402(c)","children":[],"tail":", substituted “appropriated, $5,000,000 for each of the fiscal years 2010 through 2014” for “appropriated $1,100,000 for fiscal year 1998, and such sums as may be necessary for each of the fiscal years 1999 through 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5402/d"},"text":"Pub. L. 111–148, § 5402(d)","children":[],"tail":", substituted “For the purpose of grants and contracts under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293c/a/1"},"text":"section 293c(a)(1) of this title","children":[],"tail":", there is authorized to be appropriated $60,000,000 for fiscal year 2010 and such sums as may be necessary for each of the fiscal years 2011 through 2014” for “For the purpose of grants and contracts under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293c/a/1"},"text":"section 293c(a)(1) of this title","children":[],"tail":", there is authorized to be appropriated $29,400,000 for fiscal year 1998, and such sums as may be necessary for each of the fiscal years 1999 through 2002”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
