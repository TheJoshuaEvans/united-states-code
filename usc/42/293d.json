{"tag":"section","attrib":{"id":"idb5da3317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293d"},"text":null,"children":[{"tag":"num","attrib":{"value":"293d"},"text":"§ 293d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5da3318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s293a"},"text":"section 293a of this title","children":[],"tail":", $51,470,000 for each of fiscal years 2021 through 2025. Of the amount appropriated in any fiscal year, the Secretary shall ensure that not less than 16 percent shall be distributed to schools of nursing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayments and fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s293b"},"text":"section 293b of this title","children":[],"tail":", there is authorized to be appropriated, $1,190,000 for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da331a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance in health professions regarding individuals from disadvantaged backgrounds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of grants and contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s293c/a/1"},"text":"section 293c(a)(1) of this title","children":[],"tail":", there is authorized to be appropriated $15,000,000 for each of fiscal years 2021 through 2025. The Secretary may use not to exceed 20 percent of the amount appropriated for a fiscal year under this subsection to provide scholarships under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293c/a/2/F"},"text":"section 293c(a)(2)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da331b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", and every five years thereafter, the Secretary shall prepare and submit to the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives, a report concerning the efforts of the Secretary to address the need for a representative mix of individuals from historically minority health professions schools, or from institutions or other entities that historically or by geographic location have a demonstrated record of training or educating underrepresented minorities, within various health professions disciplines, on peer review councils."}],"tail":"\n"}],"tail":"\n"}]