{"tag":"section","attrib":{"id":"idbfa1b59b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806"},"text":null,"children":[{"tag":"num","attrib":{"value":"12806"},"text":"§ 12806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home repair services grants for older and disabled homeowners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b59c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program to provide home repair services for older homeowners and disabled homeowners, including such services as the examination of homes, repair services, and follow-up to ensure the continued effectiveness of the repairs provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b59d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Home repair services shall be provided to homeowners who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b59e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own and reside in the dwellings for which services are provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b59f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are older or disabled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are members of low-income families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Guidelines for the model program shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisted dwelling units be the primary residence of the homeowner for whom services are provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferences be provided for (A) very low-income families, and (B) individuals with intense need characterized by noneconomic factors such as physical and mental disabilities, language barriers, and cultural, social, or geographical isolation caused by racial or ethnic status that restricts the ability of an individual to perform normal daily tasks or that threatens the capacity of the individual to live independently;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12806/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fees charged be based on the income of the individual receiving the home repair services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5a5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s256"},"text":"Pub. L. 101–625, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4122"},"text":"104 Stat. 4122","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
