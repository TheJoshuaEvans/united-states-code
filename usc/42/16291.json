{"tag":"section","attrib":{"id":"idc0083f07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291"},"text":null,"children":[{"tag":"num","attrib":{"value":"16291"},"text":"§ 16291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fossil energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0083f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out research, development, demonstration, and commercial application programs in fossil energy, including activities under this part, with the goal of improving the efficiency, effectiveness, and environmental performance of fossil energy production, upgrading, conversion, and consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs described in paragraph (1) shall take into consideration the following objectives:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the energy conversion efficiency of all forms of fossil energy through improved technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the cost of all fossil energy production, generation, and delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting diversity of energy supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the dependence of the United States on foreign energy supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving United States energy security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the environmental impact of energy-related activities, including technology development to reduce emissions of carbon dioxide and associated emissions of heavy metals within coal combustion residues and gas streams resulting from fossil fuel use and production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the export of fossil energy-related equipment, technology, including emissions control technologies, and services from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the cost of emissions control technologies for fossil energy production, generation, and delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Significantly lowering greenhouse gas emissions for all fossil fuel production, generation, delivery, and utilization technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing carbon removal and utilization technologies, products, and methods that result in net reductions in greenhouse gas emissions, including direct air capture and storage, and carbon use and reuse for commercial application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the conversion, use, and storage of carbon oxides produced from fossil fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing water use, improving water reuse, and minimizing surface and subsurface environmental impact in the development of unconventional domestic oil and natural gas resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the objectives described in subparagraphs (F) through (K) of paragraph (2), the Secretary shall prioritize activities and strategies that have the potential to significantly reduce emissions for each technology relevant to the applicable objective and the international commitments of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0083f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out fossil energy research, development, demonstration, and commercial application activities, including activities authorized under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $611,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $626,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $641,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0083f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts authorized under subsection (a), the following sums are authorized:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083f1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For activities under section 16292 ","children":[{"tag":"ref","attrib":{"idref":"fn004223"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004223"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083f1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $367,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $376,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $394,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16294"},"text":"section 16294 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16296"},"text":"section 16296 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 for fiscal year 2007; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000 for each of fiscal years 2008 and 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Office of Arctic Energy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7144d"},"text":"section 7144d of this title","children":[],"tail":" $25,000,000 for each of fiscal years 2007 through 2009."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0083f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for the Office of Arctic Energy established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7144d"},"text":"section 7144d of this title","children":[],"tail":" $25,000,000 for each of fiscal years 2010 through 2012."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0083f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds authorized under this section may be used for Fossil Energy Environmental Restoration or Import/Export Authorization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16291/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized under subsection (c)(2), not less than 20 percent of the funds appropriated for each fiscal year shall be dedicated to research and development carried out at institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0083f2d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s961"},"text":"Pub. L. 109–58, title IX, § 961","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/889"},"text":"119 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4001"},"text":"Pub. L. 116–260, div. Z, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2527"},"text":"134 Stat. 2527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0083f2e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0083f2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0083f30-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsecs. (a)(1) and (b), was in the original “this subtitle”, meaning subtitle F (§§ 961–968) of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/889"},"text":"119 Stat. 889","children":[],"tail":", which enacted this part and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s2001"},"text":"section 2001 of Title 30","children":[],"tail":", Mineral Lands and Mining, and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"section 1902 of Title 30","children":[],"tail":". For complete classification of subtitle F to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16292"},"text":"Section 16292 of this title","children":[],"tail":", referred to in subsec. (c)(1), relating to coal and related technologies program, was repealed and a new "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16292"},"text":"section 16292 of this title","children":[],"tail":", relating to carbon capture technology program, was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4002/a"},"text":"Pub. L. 116–260, div. Z, title IV, § 4002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2528"},"text":"134 Stat. 2528","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0083f31-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/5"},"text":"Pub. L. 116–260, § 4001(5)","children":[],"tail":", designated second sentence of par. (1), as redesignated, as par. (2), inserted heading, and substituted “The programs described in paragraph (1) shall” for “Such programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/4"},"text":"Pub. L. 116–260, § 4001(4)","children":[],"tail":", designated existing provisions of subsec. (a) as par. (1), substituted “Establishment” for “In general” in subsec. heading, and inserted par. (1) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/3"},"text":"Pub. L. 116–260, § 4001(3)","children":[],"tail":", added subpars. (G) to (L) and struck out former subpar. (G), as redesignated, which read as follows: “Increasing the export of fossil energy-related equipment, technology, and services from the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/2"},"text":"Pub. L. 116–260, § 4001(2)","children":[],"tail":", in subpar. (F), as redesignated, inserted “, including technology development to reduce emissions of carbon dioxide and associated emissions of heavy metals within coal combustion residues and gas streams resulting from fossil fuel use and production” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/1"},"text":"Pub. L. 116–260, § 4001(1)","children":[],"tail":", redesignated pars. (1) to (7) of subsec. (a) as subpars. (A) to (G), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4001/6"},"text":"Pub. L. 116–260, § 4001(6)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
