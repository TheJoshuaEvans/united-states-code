{"tag":"section","attrib":{"id":"idbfc80258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573"},"text":null,"children":[{"tag":"num","attrib":{"value":"13573"},"text":"§ 13573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generation projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc80259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/1"},"text":"section 13572(a)(1) of this title","children":[],"tail":" may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8025a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment or processes previously supported by a Department of Energy program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8025b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced combustion equipment and processes that the Secretary determines will be cost-effective and could substantially contribute to meeting environmental or energy needs, including gasification, gasification fuel cells, gasification coproduction, oxidation combustion techniques, ultra-supercritical boilers, and chemical looping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8025c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hybrid gasification/combustion systems, including systems integrating fuel cells with gasification or combustion units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8025d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish criteria for the selection of generation projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/1"},"text":"section 13572(a)(1) of this title","children":[],"tail":". The Secretary may modify the criteria as appropriate to reflect improvements in equipment, except that the criteria shall not be modified to be less stringent. The selection criteria shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8025e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritization of projects whose installation is likely to result in significant air quality improvements in nonattainment air quality areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8025f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritization of projects whose installation is likely to result in lower emission rates of pollution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritization of projects that result in the repowering or replacement of older, less efficient units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented broad interest in the procurement of the equipment and utilization of the processes used in the projects by owners or operators of facilities for electricity generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" equipment and processes beginning in 2006 through 2011 that are projected to achieve a thermal efficiency of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc80263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent for coal of more than 9,000 Btu per pound based on higher heating values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc80264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 38 percent for coal of 7,000 to 9,000 Btu per pound passed on higher heating values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc80265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36 percent for coal of less than 7,000 Btu per pound based on higher heating values;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that energy used for coproduction or cogeneration shall not be counted in calculating the thermal efficiency under this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" equipment and processes beginning in 2012 and 2013 that are projected to achieve a thermal efficiency of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc80267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 45 percent for coal of more than 9,000 Btu per pound based on higher heating values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc80268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 44 percent for coal of 7,000 to 9,000 Btu per pound passed on higher heating values; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc80269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent for coal of less than 7,000 Btu per pound based on higher heating values;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that energy used for coproduction or cogeneration shall not be counted in calculating the thermal efficiency under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8026a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program balance and priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/1"},"text":"section 13572(a)(1) of this title","children":[],"tail":", the Secretary shall ensure, to the extent practicable, that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8026b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between 25 percent and 75 percent of the projects supported are for the sole purpose of electrical generation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8026c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority is given to projects that use electrical generation equipment and processes that have been developed and demonstrated and applied in actual production of electricity, but are not yet cost-competitive, and that achieve greater efficiency and environmental performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8026d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/1"},"text":"section 13572(a)(1) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8026e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8026f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $350,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000,000 for each of fiscal years 2009 through 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc80272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13573/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No technology, or level of emission reduction, shall be treated as adequately demonstrated for purpose ","children":[{"tag":"ref","attrib":{"idref":"fn004179"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004179"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “purposes”."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7411"},"text":"section 7411 of this title","children":[],"tail":", achievable for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479"},"text":"section 7479 of this title","children":[],"tail":", or achievable in practice for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7501"},"text":"section 7501 of this title","children":[],"tail":" solely by reason of the use of such technology, or the achievement of such emission reduction, by one or more facilities receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/1"},"text":"section 13572(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc80273-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXXI/s3103"},"text":"Pub. L. 102–486, title XXXI, § 3103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s421/a"},"text":"Pub. L. 109–58, title IV, § 421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/758"},"text":"119 Stat. 758","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
