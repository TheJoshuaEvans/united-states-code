{"tag":"section","attrib":{"id":"idbe6bcd4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671l"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671l"},"text":"§ 7671l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", the Administrator, in consultation with the Administrator of the General Services Administration and the Secretary of Defense, shall promulgate regulations requiring each department, agency, and instrumentality of the United States to conform its procurement regulations to the policies and requirements of this subchapter and to maximize the substitution of safe alternatives identified under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671k"},"text":"section 7671k of this title","children":[],"tail":" for class I and class II substances. Not later than 30 months after "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", each department, agency, and instrumentality of the United States shall so conform its procurement regulations and certify to the President that its regulations have been modified in accordance with this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe6bcd4d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 613, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2668"},"text":"104 Stat. 2668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe6bcd4e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbe6bcd4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idbe6bcd50-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 12843","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12843, ","children":[{"tag":"date","attrib":{"date":"1993-04-21"},"text":"Apr. 21, 1993","children":[],"tail":", 58 F.R. 21881, which provided for Federal agencies to implement policies and programs to minimize procurement of ozone-depleting substances, was revoked by Ex. Ord. No. 13148, § 901, "},{"tag":"date","attrib":{"date":"2000-04-21"},"text":"Apr. 21, 2000","children":[],"tail":", 65 F.R. 24604, formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
