{"tag":"section","attrib":{"id":"idbed4a1e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658"},"text":null,"children":[{"tag":"num","attrib":{"value":"9658"},"text":"§ 9658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under State law for damages from exposure to hazardous substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed4a1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State statutes of limitations for hazardous substance cases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed4a1eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to State statutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any action brought under State law for personal injury, or property damages, which are caused or contributed to by exposure to any hazardous substance, or pollutant or contaminant, released into the environment from a facility, if the applicable limitations period for such action (as specified in the State statute of limitations or under common law) provides a commencement date which is earlier than the federally required commencement date, such period shall commence at the federally required commencement date in lieu of the date specified in such State statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed4a1ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law generally applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (1), the statute of limitations established under State law shall apply in all actions brought under State law for personal injury, or property damages, which are caused or contributed to by exposure to any hazardous substance, or pollutant or contaminant, released into the environment from a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed4a1ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under section 9607","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall apply with respect to any cause of action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9607"},"text":"section 9607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed4a1ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed4a1ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter I terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms used in this section shall have the same meaning as when used in subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed4a1f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable limitations period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable limitations period” means the period specified in a statute of limitations during which a civil action referred to in subsection (a)(1) may be brought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed4a1f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commencement date” means the date specified in a statute of limitations as the beginning of the applicable limitations period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed4a1f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally required commencement date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed4a1f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “federally required commencement date” means the date the plaintiff knew (or reasonably should have known) that the personal injury or property damages referred to in subsection (a)(1) were caused or contributed to by the hazardous substance or pollutant or contaminant concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed4a1f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a minor or incompetent plaintiff, the term “federally required commencement date” means the later of the date referred to in subparagraph (A) or the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed4a1f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a minor, the date on which the minor reaches the age of majority, as determined by State law, or has a legal representative appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed4a1f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9658/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an incompetent individual, the date on which such individual becomes competent or has had a legal representative appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed4a1f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIII/s309"},"text":"Pub. L. 96–510, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s203/a"},"text":"Pub. L. 99–499, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1695"},"text":"100 Stat. 1695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed4a1f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbed4a1f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbed4a1fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s203/b"},"text":"Pub. L. 99–499, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1696"},"text":"100 Stat. 1696","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/499/tII/s203/b"},"text":"“The amendment made by subsection (a) of this section [enacting this section] shall take effect with respect to actions brought after ","children":[{"tag":"date","attrib":{"date":"1980-12-11"},"text":"December 11, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
