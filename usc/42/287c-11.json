{"tag":"section","attrib":{"id":"idb5864669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"287c–11"},"text":"§ 287c–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dietary supplements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb586466a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an Office of Dietary Supplements within the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb586466b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Office are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb586466c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to explore more fully the potential role of dietary supplements as a significant part of the efforts of the United States to improve health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb586466d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote scientific study of the benefits of dietary supplements in maintaining health and preventing chronic disease and other health-related conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb586466e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Dietary Supplements shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb586466f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and coordinate scientific research within the National Institutes of Health relating to dietary supplements and the extent to which the use of dietary supplements can limit or reduce the risk of diseases such as heart disease, cancer, birth defects, osteoporosis, cataracts, or prostatism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5864670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and compile the results of scientific research relating to dietary supplements, including scientific data from foreign sources or the Office of Alternative Medicine; ","children":[{"tag":"ref","attrib":{"idref":"fn002207"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002207"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5864671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve as the principal advisor to the Secretary and to the Assistant Secretary for Health and provide advice to the Director of the National Institutes of Health, the Director of the Centers for Disease Control and Prevention, and the Commissioner of Food and Drugs on issues relating to dietary supplements including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5864672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dietary intake regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5864673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of dietary supplements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5864674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" claims characterizing the relationship between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5864675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dietary supplements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5864676-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5864677-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention of disease or other health-related conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5864678-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of health; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5864679-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific issues arising in connection with the labeling and composition of dietary supplements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb586467a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile a database of scientific research on dietary supplements and individual nutrients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb586467b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate funding relating to dietary supplements for the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb586467c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287c–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Dietary supplement” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “dietary supplement” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321/ff"},"text":"section 321(ff) of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb586467d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 485C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/417/s13/a"},"text":"Pub. L. 103–417, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4334"},"text":"108 Stat. 4334","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/43"},"text":"Pub. L. 109–482, title I, § 103(b)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5866d8e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5866d8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5866d90-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Office of Alternative Medicine, referred to in subsec. (c)(2), probably should be a reference to the National Center for Complementary and Integrative Health. Establishment of the Office of Alternative Medicine was repealed and authority for the National Center for Complementary and Alternative Medicine was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVI/s601"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VI, § 601]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–387. The National Center for Complementary and Alternative Medicine was renamed the National Center for Complementary and Integrative Health by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dG/tII/s224/1"},"text":"Pub. L. 113–235, div. G, title II, § 224(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2490"},"text":"128 Stat. 2490","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s287c–21"},"text":"section 287c–21 of this title","children":[],"tail":" and Prior Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283g"},"text":"section 283g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5866d91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “There are authorized to be appropriated to carry out this section $5,000,000 for fiscal year 1994 and such sums as may be necessary for each subsequent fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5866d92-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5866d93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
