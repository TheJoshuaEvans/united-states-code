{"tag":"section","attrib":{"id":"idbc68aa77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057j"},"text":"§ 3057j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68aa78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval criteria; provisions and assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant may be made under this part unless the public or nonprofit private organization submits an application to the Assistant Secretary which meets such criteria as the Assistant Secretary may by regulation prescribe. Each such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aa79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the organization will evaluate the need for supportive and nutrition services among older Native Hawaiians to be represented by the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the use of such methods of administration as are necessary for the proper and efficient administration of the program to be assisted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that the organization will coordinate its activities with the State agency on aging and with the activities carried out under subchapter III in the same geographical area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the organization will make such reports in such form and containing such information as the Assistant Secretary may reasonably require, and comply with such requirements as the Assistant Secretary may impose to ensure the correctness of such reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic evaluation of activities and projects carried out under the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish objectives, consistent with the purpose of this subchapter, toward which activities described in the application will be directed, identify obstacles to the attainment of such objectives, and indicate the manner in which the organization proposes to overcome such obstacles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for establishing and maintaining information and assistance services to assure that older Native Hawaiians to be served by the assistance made available under this part will have reasonably convenient access to such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a preference for Native Hawaiians 60 years of age and older for full or part-time staff positions wherever feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that any legal or ombudsman services made available to older Native Hawaiians represented by the nonprofit private organization will be substantially in compliance with the provisions of subchapter III relating to the furnishing and similar services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide satisfactory assurances that the fiscal control and fund accounting procedures will be adopted as may be necessary to assure proper disbursement of, and accounting for, Federal funds paid under this part to the nonprofit private organization, including any funds paid by the organization to a recipient of a grant or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aa83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall approve any application which complies with the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aa84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval by Assistant Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Assistant Secretary determines not to approve an application submitted under subsection (a) the Assistant Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aa85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state objections in writing to the nonprofit private organization within 60 days after such decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the extent practicable technical assistance to the nonprofit private organization to overcome such stated objections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the organization with a hearing under such rules and regulations as the Assistant Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aa88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds per year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Assistant Secretary approves an application of a nonprofit private or public organization under this part funds shall be awarded for not less than 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aa89-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s624"},"text":"Pub. L. 89–73, title VI, § 624","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/962"},"text":"101 Stat. 962","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tI/s102/b/4"},"text":"Pub. L. 102–375, title I, § 102(b)(4)","children":[],"tail":", title VI, § 603, "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1201"},"text":"106 Stat. 1201","children":[],"tail":", 1270; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aa8a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68aa8b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc68aa8c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s603"},"text":"Pub. L. 102–375, § 603","children":[],"tail":", inserted before semicolon at end “and with the activities carried out under subchapter III in the same geographical area”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/4"},"text":"Pub. L. 102–375, § 102(b)(4)","children":[],"tail":", substituted “information and assistance” for “information and referral”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc68aa8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc68aa8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s603"},"text":"section 603 of Pub. L. 102–375","children":[],"tail":" inapplicable to fiscal year 1992, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/s905/b/5"},"text":"section 905(b)(5) of Pub. L. 102–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc68aa8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
