{"tag":"section","attrib":{"id":"idbc666102-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057a"},"text":"§ 3057a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that older individuals who are Indians, older individuals who are Alaskan Natives, and older individuals who are Native Hawaiians are a vital resource entitled to all benefits and services available and that such services and benefits should be provided in a manner that preserves and restores their respective dignity, self-respect, and cultural identities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc666103-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s602"},"text":"Pub. L. 89–73, title VI, § 602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/959"},"text":"101 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tIX/s904/a/20"},"text":"Pub. L. 102–375, title IX, § 904(a)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1309"},"text":"106 Stat. 1309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc666104-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc666105-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading",