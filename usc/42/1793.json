{"tag":"section","attrib":{"id":"idbb7f0e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793"},"text":null,"children":[{"tag":"num","attrib":{"value":"1793"},"text":"§ 1793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for expansion of school breakfast programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb7f0e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of qualifying school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “qualifying school” means a school in severe need, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773/d/1"},"text":"section 1773(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations provided in advance in an appropriations Act specifically for the purpose of carrying out this section, the Secretary shall establish a program under which the Secretary shall provide grants, on a competitive basis, to State educational agencies for the purpose of providing subgrants to local educational agencies for qualifying schools to establish, maintain, or expand the school breakfast program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to State educational agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a State educational agency shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb7f0e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an appropriate competitive application process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make information available to State educational agencies concerning the availability of funds under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of grants provided by the Secretary to State educational agencies for a fiscal year under this section shall not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb7f0e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb7f0e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of qualifying schools receiving subgrants or other benefits under subsection (d) for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb7f0e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum amount of a subgrant provided to a qualifying school under subsection (d)(4)(B); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants to qualifying schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State educational agency receiving a grant under this section shall use funds made available under the grant to award subgrants to local educational agencies for a qualifying school or groups of qualifying schools to carry out activities in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding subgrants under this subsection, a State educational agency shall give priority to local educational agencies with qualifying schools in which at least 75 percent of the students are eligible for free or reduced price school lunches under the school lunch program established under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and district training and technical support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency or State educational agency may allocate a portion of each subgrant to provide training and technical assistance to the staff of qualifying schools to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount; term","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb7f0e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this paragraph, a subgrant provided by a State educational agency to a local educational agency or qualifying school under this section shall be in such amount, and shall be provided for such term, as the State educational agency determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a subgrant provided by a State educational agency to a local educational agency for a qualifying school or a group of qualifying schools under this subsection shall not exceed $10,000 for each school year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum grant term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency or State educational agency shall not provide subgrants to a qualifying school under this subsection for more than 2 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to awarding grants under this section, the Secretary shall make available to State educational agencies information regarding the most effective mechanisms by which to increase school breakfast participation among eligible children at qualifying schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding subgrants under this section, a State educational agency shall give preference to local educational agencies for qualifying schools or groups of qualifying schools that have adopted, or provide assurances that the subgrant funds will be used to adopt, the most effective mechanisms identified by the Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb7f0e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb7f0e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualifying school may use a grant provided under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb7f0e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, promote, or expand a school breakfast program of the qualifying school under this section, which shall include a nutritional education component;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend the period during which school breakfast is available at the qualifying school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide school breakfast to students of the qualifying school during the school day; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb7f0e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other appropriate purposes, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb7f0e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each activity of a qualifying school under this subsection shall be carried out in accordance with applicable nutritional guidelines and regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made available under this section shall not diminish or otherwise affect the expenditure of funds from State and local sources for the maintenance of the school breakfast program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817e79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months following the end of a school year during which subgrants are awarded under this section, the Secretary shall submit to Congress a report describing the activities of the qualifying schools awarded subgrants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817e7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days before the end of a grant term under this section, a local educational agency that receives a subgrant under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817e7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate whether electing to provide universal free breakfasts under the school breakfast program in accordance with Provision 2 as established under subsections (b) through (k) of section 245.9 of title 7, Code of Federal Regulations (or successor regulations), would be cost-effective for the qualified schools based on estimated administrative savings and economies of scale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817e7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the results of the evaluation to the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1793/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each of fiscal years 2010 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb817e7e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s23"},"text":"Pub. L. 89–642, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tI/s105"},"text":"Pub. L. 111–296, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3201"},"text":"124 Stat. 3201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817e7f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817e80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb817e81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb817e82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb817e83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
