{"tag":"section","attrib":{"id":"idb634d620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"300g–10"},"text":"§ 300g–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity support for public water systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb634d621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb634d622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb634d623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “incident” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552"},"text":"section 3552 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization Framework","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Prioritization Framework” means the prioritization framework developed by the Administrator under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d62a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Support Plan” means the Technical Cybersecurity Support Plan developed by the Administrator under subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb634d62b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of and support for public water systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb634d62c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization Framework","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb634d62d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator, in coordination with the Director, shall develop a prioritization framework to identify public water systems (including sources of water for those public water systems) that, if degraded or rendered inoperable due to an incident, would lead to significant impacts on the health and safety of the public."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d62e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the Prioritization Framework, to the extent practicable, the Administrator shall incorporate consideration of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb634d62f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether cybersecurity vulnerabilities for a public water system have been identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300i–2"},"text":"section 300i–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d630-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of a public water system to remediate a cybersecurity vulnerability without additional Federal support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d631-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a public water system serves a defense installation or critical national security asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d632-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a public water system, if degraded or rendered inoperable due to an incident, would cause a cascading failure of other critical infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d633-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Cybersecurity Support Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb634d634-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator, in coordination with the Director and using existing authorities of the Administrator and the Director for providing voluntary support to public water systems and the Prioritization Framework, shall develop a Technical Cybersecurity Support Plan for public water systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Support Plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb634d636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a methodology for identifying specific public water systems for which cybersecurity support should be prioritized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish timelines for making voluntary technical support for cybersecurity available to specific public water systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d638-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include public water systems identified by the Administrator, in coordination with the Director, as needing technical support for cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d639-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include specific capabilities of the Administrator and the Director that may be utilized to provide support to public water systems under the Support Plan, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb634d63a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" site vulnerability and risk assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb634d63b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penetration tests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb634d63c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional support determined to be appropriate by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d63d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall only include plans for providing voluntary support to public water systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d63e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the Prioritization Framework pursuant to paragraph (1) and the Support Plan pursuant to paragraph (2), the Administrator shall consult with such Federal or non-Federal entities as determined to be appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d63f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb634d640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization Framework","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 190 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to the appropriate Congressional committees a report describing the Prioritization Framework."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb634d641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Cybersecurity Support Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 280 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to the appropriate Congressional committees—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb634d642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Support Plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb634d643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list describing any public water systems identified by the Administrator, in coordination with the Director, as needing technical support for cybersecurity during the development of the Support Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb634d644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb634d645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alters the existing authorities of the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb634d646-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compels a public water system to accept technical support offered by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb634d647-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1420A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50113"},"text":"Pub. L. 117–58, div. E, title I, § 50113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1155"},"text":"135 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
