{"tag":"section","attrib":{"id":"idbbaea99e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1975b"},"text":"§ 1975b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbaea99f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea9a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be a full-time staff director for the Commission who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbaea9a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the administrative head of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea9a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President with the concurrence of a majority of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea9a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within the limitation of its appropriations, the Commission may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbaea9a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint such other personnel as it deems advisable, under the civil service and classification laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbaea9a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure services, as authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", but at rates for individuals not in excess of the daily equivalent paid for positions at the maximum rate for GS–15 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea9a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission who is not otherwise in the service of the Government of the United States shall receive a sum equivalent to the compensation paid at level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", prorated on a daily basis for time spent in the work of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea9a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons otherwise in Government service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission who is otherwise in the service of the Government of the United States shall serve without compensation in addition to that received for such other service, but while engaged in the work of the Commission shall be paid actual travel expenses and per diem in lieu of subsistence expenses when away from such member’s usual place of residence, under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary or uncompensated personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not accept or use the services of voluntary or uncompensated persons. This limitation shall apply with respect to services of members of the Commission as it does with respect to services by other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbaea9ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may make such rules as are necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbaea9ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of old rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as inconsistent with this chapter, and until modified by the Commission, the rules of the Commission on Civil Rights in effect on ","children":[{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":" shall be the initial rules of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1975b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All Federal agencies shall cooperate fully with the Commission to the end that it may effectively carry out its functions and duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbaea9ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/183/s4"},"text":"Pub. L. 98–183, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1304"},"text":"97 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/419/s2"},"text":"Pub. L. 103–419, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4340"},"text":"108 Stat. 4340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbaea9af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbaea9b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbaea9b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1975b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/315"},"text":"Pub. L. 85–315","children":[],"tail":", pt. I, § 103, "},{"tag":"date","attrib":{"date":"1957-09-09"},"text":"Sept. 9, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/635"},"text":"71 Stat. 635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/352/tV"},"text":"Pub. L. 88–352, title V","children":[],"tail":", §§ 502, 503, "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/250"},"text":"78 Stat. 250","children":[],"tail":", 251; "},{"tag":"ref","attrib":{"href":"/us/pl/91/521/s1"},"text":"Pub. L. 91–521, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-25"},"text":"Nov. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1356"},"text":"84 Stat. 1356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/496/s2"},"text":"Pub. L. 92–496, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-14"},"text":"Oct. 14, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/813"},"text":"86 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/444/s2"},"text":"Pub. L. 95–444, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1067"},"text":"92 Stat. 1067","children":[],"tail":", related to compensation of members of Commission. See Codification note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1975"},"text":"section 1975 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbaea9b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/419"},"text":"Pub. L. 103–419","children":[],"tail":" amended section generally, substituting administrative provisions for provisions relating to compensation of members of Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
