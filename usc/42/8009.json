{"tag":"section","attrib":{"id":"idbe77b434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009"},"text":null,"children":[{"tag":"num","attrib":{"value":"8009"},"text":"§ 8009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe77b435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of elderly and permanently disabled adult persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each public housing agency and nonprofit corporation shall, to the maximum extent practicable, utilize elderly and permanently disabled adult persons who are residents of public housing projects or projects assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of title 12","children":[],"tail":", but who are not eligible project residents, to participate in providing the services assisted under this chapter. Such persons shall be paid wages which shall not be lower than whichever is the highest of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe77b436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum wage which would be applicable to the employee under the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.], if section 6(a)(1) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"29 U.S.C. 206(a)(1)","children":[],"tail":"] applied to the resident and if he or she were not exempt under section 13 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s213"},"text":"29 U.S.C. 213","children":[],"tail":"] thereof;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local minimum wage for the most nearly comparable covered employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe77b438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevailing rates of pay for persons employed in similar public occupations by the same employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe77b439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment of services received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No service provided to a public housing resident or to a resident of a housing project assisted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of title 12","children":[],"tail":" under this chapter, except for wages paid under subsection (a) of this section, may be treated as income for the purpose of any other program or provision of State or Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe77b43a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals receiving aid considered residents of own household","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Individuals receiving services assisted under this chapter shall be deemed to be residents of their own households, and not to be residents of a public institution, for the purpose of any other program or provision of State or Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe77b43b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue regulations to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe77b43c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIV/s410"},"text":"Pub. L. 95–557, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2109"},"text":"92 Stat. 2109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe77b43d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe77b43e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe77b43f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
