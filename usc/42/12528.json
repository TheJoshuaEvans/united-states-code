{"tag":"section","attrib":{"id":"idbf7219fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528"},"text":null,"children":[{"tag":"num","attrib":{"value":"12528"},"text":"§ 12528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal, State, and local contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7219fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation share of the cost of carrying out a program for which a grant is made from an allotment under this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for new grants may not exceed 80 percent of the total cost of the program for the first year of the grant period, 65 percent for the second year, and 50 percent for each remaining year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for continuing grants, may not exceed 50 percent of the total cost of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncorporation contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing for the remaining share of the cost of carrying out such a program, each recipient of such a grant under this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for such share through a payment in cash or in kind, fairly evaluated, including facilities, equipment, or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (C), may provide for such share through Federal, State, or local sources, including private funds or donated services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not provide for such share through Federal funds made available under title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.] or the Individuals with Disabilities Education Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer may waive the requirements of subsection (a) in whole or in part with respect to any such program for any fiscal year, on a determination that such a waiver would be equitable due to a lack of resources at the local level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf721a07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s116"},"text":"Pub. L. 101–610, title I, § 116","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. L. 111–13, title I, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1473"},"text":"123 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf721a08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf721a09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf721a0a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (a)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 6301 et seq.) of chapter 70 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (a)(2)(C), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf721a0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12528, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s115A"},"text":"Pub. L. 101–610, title I, § 115A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"hre