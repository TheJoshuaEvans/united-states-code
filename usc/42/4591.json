{"tag":"section","attrib":{"id":"idbcd66047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4591"},"text":null,"children":[{"tag":"num","attrib":{"value":"4591"},"text":"§ 4591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any section, provision, or term of this chapter is adjudged invalid for any reason, such judgment shall not affect, impair, or invalidate any other section, provision, or term of this chapter, and the remaining sections, provisions, and terms shall be and remain in full force and effect.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcd66048-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/616/tVI/s601"},"text":"Pub. L. 91–616, title VI, § 601","children":[],"tail":", formerly title V, § 501, "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1854"},"text":"84 Stat. 1854","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/94/371/s7"},"text":"Pub. L. 94–371, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1038"},"text":"90 Stat. 1038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd66049-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd6604a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcd6604b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/616"},"text":"Pub. L. 91–616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1848"},"text":"84 Stat. 1848","children":[],"tail":", known as the Comprehensive Alcohol Abuse and Alcoholism Prevention, Treatment, and Rehabilitation Act of 1970. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4541"},"text":"section 4541 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcd6604c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/371/s7"},"text":"Pub. L. 94–371, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-26"},"text":"July 26, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1038"},"text":"90 Stat. 1038","children":[],"tail":", redesignated title V of "},{"tag":"ref","attrib":{"href":"/us/pl/91/616"},"text":"Pub. L. 91–616","children":[],"tail":", which was classified to subchapter IV of this chapter, as title VI without renumbering the sections therein. "},{"tag":"ref","attrib":{"href":"/us/pl/91/616/s501"},"text":"Section 501 of Pub. L. 91–616","children":[],"tail":" was renumbered 601, as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
