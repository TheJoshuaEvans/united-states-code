{"tag":"section","attrib":{"id":"idb482b8b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238d"},"text":null,"children":[{"tag":"num","attrib":{"value":"238d"},"text":"§ 238d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for grants to Federal institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations to the Public Health Service available under this chapter for research, training, or demonstration project grants or for grants to expand existing treatment and research programs and facilities for alcoholism, narcotic addiction, drug abuse, and drug dependence and appropriations under title VI of the Mental Health Systems Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9511"},"text":"42 U.S.C. 9511","children":[],"tail":" et seq.] shall also be available on the same terms and conditions as apply to non-Federal institutions, for grants for the same purpose to Federal institutions, except that grants to Federal institutions may be funded at 100 per centum of the costs."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb482b8b8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 235, formerly title V, § 507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/31/s5"},"text":"Pub. L. 90–31, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-06-24"},"text":"June 24, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/79"},"text":"81 Stat. 79","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/513/tI/s3/c"},"text":"Pub. L. 91–513, title I, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1241"},"text":"84 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tXI/s1102/b"},"text":"Pub. L. 94–278, title XI, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/415"},"text":"90 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/398/tVIII/s804/b"},"text":"Pub. L. 96–398, title VIII, § 804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1608"},"text":"94 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/g/2"},"text":"Pub. L. 97–35, title IX, § 902(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/560"},"text":"95 Stat. 560","children":[],"tail":"; renumbered title XXI, § 2107, "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/a/1"},"text":"Pub. L. 98–24, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/176"},"text":"97 Stat. 176","children":[],"tail":"; renumbered title XXIII, § 2307, "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3755"},"text":"100 Stat. 3755","children":[],"tail":"; renumbered title XXV, § 2505, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/1"},"text":"Pub. L. 100–607, title II, § 201(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"re