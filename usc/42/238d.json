tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1564"},"text":"94 Stat. 1564","children":[],"tail":". Title VI of the Mental Health Systems Act is classified generally to subchapter V (§ 9511 et seq.) of chapter 102 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9401"},"text":"section 9401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb482b8bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa–4"},"text":"section 300aaa–4 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":", to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–6"},"text":"section 300cc–6 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–6"},"text":"section 300aa–6 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":", and to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s225a"},"text":"section 225a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb482b8bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" struck out provisions relating to appropriations available under Community Mental Health Centers Act for construction, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/398"},"text":"Pub. L. 96–398","children":[],"tail":" struck out “and” after “drug dependence,” and inserted reference to title VI of the Mental Health Systems Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/278"},"text":"Pub. L. 94–278","children":[],"tail":" substituted “Federal institutions, except that grants to” for “hospitals of the Service, of the Veterans’ Administration, or of the Bureau of Prisons of the Department of Justice, and to Saint Elizabeths Hospital, except grants to such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":" inserted references to appropriations available for grants to expand existing treatment and research programs and facilities for alcoholism, narcotic addiction, drug abuse, and drug dependence, and appropriations available under Community Mental Health Centers Act for construction and staffing of community mental health centers and alcoholism and narcotic addiction, drug abuse, and drug dependence facilities, and inserted provision that grants to specified Federal institutions may be funded at 100 per centum of the costs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb482b8be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":n