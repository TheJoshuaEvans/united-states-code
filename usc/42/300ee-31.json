{"tag":"section","attrib":{"id":"idb68d07a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–31"},"text":"§ 300ee–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information to general public","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68d07a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive information plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall annually prepare a comprehensive plan, including a budget, for a National Acquired Immune Deficiency Syndrome Information Program. The plan shall contain provisions to implement the provisions of this subchapter. The Director shall submit such plan to the Secretary. The authority established in this subsection may not be construed to be the exclusive authority for the Director to carry out information activities with respect to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68d07a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68d07a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may establish a clearinghouse to make information concerning acquired immune deficiency syndrome available to Federal agencies, States, public and private entities, and the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68d07a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The clearinghouse may conduct or support programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68d07a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and obtain educational materials, model curricula, and methods directed toward reducing the transmission of the etiologic agent for acquired immune deficiency syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68d07aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide instruction and support for individuals who provide instruction in methods and techniques of education relating to the prevention of acquired immune deficiency syndrome and instruction in the use of the materials and curricula described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68d07ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct, or to provide for the conduct of, the materials, curricula, and methods described in paragraph (1) and the efficacy of such materials, curricula, and methods in preventing infection with the the ","children":[{"tag":"ref","attrib":{"idref":"fn002420"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002420"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" etiologic agent for acquired immune deficiency syndrome."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68d07ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Toll-free telephone communications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the establishment and maintenance of toll-free telephone communications to provide information to, and respond to queries from, the public concerning acquired immune deficiency syndrome. Such communications shall be available on a 24-hour basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68d07ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2521, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3102"},"text":"102 Stat. 3102","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/22"},"text":"Pub. L. 102–531, title III, § 312(d)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68d07ae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68d07af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb68d07b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
