{"tag":"section","attrib":{"id":"idbdc26e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870"},"text":null,"children":[{"tag":"num","attrib":{"value":"6870"},"text":"§ 6870.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against discrimination; notification to funded project of violation; penalties for failure to comply","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc26e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person in the United States shall, on the ground of race, color, national origin, or sex, or on the ground of any other factor specified in any Federal law prohibiting discrimination, be excluded from participation in, be denied the benefits of, or be subjected to discrimination under any program, project, or activity supported in whole or in part with financial assistance under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc26e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the Secretary determines that a recipient of financial assistance under this part has failed to comply with subsection (a) or any applicable regulation, he shall notify the recipient thereof in order to secure compliance. If, within a reasonable period of time thereafter, such recipient fails to comply, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc26e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer the matter to the Attorney General with a recommendation that an appropriate civil action be instituted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc26e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the power and functions provided by title VI of the Civil Rights Act of 1964 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.] and any other applicable Federal nondiscrimination law; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc26e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6870/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as may be authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc26e77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s420"},"text":"Pub. L. 94–385, title IV, § 420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1158"},"text":"90 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s577/2"},"text":"Pub. L. 96–294, title V, § 577(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/760"},"text":"94 Stat. 760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc26e78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc26e79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdc26e7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Civil Rights Act of 1964 is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc26e7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
