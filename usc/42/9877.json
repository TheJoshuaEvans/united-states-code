{"tag":"section","attrib":{"id":"idbf04648b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877"},"text":null,"children":[{"tag":"num","attrib":{"value":"9877"},"text":"§ 9877.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf04648c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “community center” means facilities operated by nonprofit community-based organizations for the provision of recreational, social, or educational services to the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf04648d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “dependent” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf04648e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who has not attained the age of 17 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf04648f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who has attained the age of 55 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf046490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual with a developmental disability;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “developmental disability” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15002"},"text":"section 15002 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “equipment” has the same meaning given that term by section 198(a)(8) of the Elementary and Secondary Education Act of 1965; ","children":[{"tag":"ref","attrib":{"idref":"fn003917"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003917"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “institution of higher education” has the same meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf046494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9877/6"},