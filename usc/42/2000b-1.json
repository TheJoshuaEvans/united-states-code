{"tag":"section","attrib":{"id":"idbbb5d531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000b–1"},"text":"§ 2000b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of United States for costs and attorney’s fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any action or proceeding under this subchapter the United States shall be liable for costs, including a reasonable attorney’s fee, the same as a private person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb5d532-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tIII/s302"},"text":"Pub. L. 88–352, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/246"},"text":"78 Stat. 246","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
