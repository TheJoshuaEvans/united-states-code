{"tag":"section","attrib":{"id":"idbea776e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8840"},"text":null,"children":[{"tag":"num","attrib":{"value":"8840"},"text":"§ 8840.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No financial assistance may be committed to or made under this subchapter after ","children":[{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":". This section shall not be construed to affect the authority of the Secretary of Energy to spend funds after such date pursuant to any award of financial assistance made on or before that date."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbea776e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s240"},"text":"Pub. L. 96–294, title II, § 240","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/705"},"text":"94 Stat. 705","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
