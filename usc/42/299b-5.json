{"tag":"section","attrib":{"id":"idb60058b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–5"},"text":"§ 299b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care practice and technology innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb60058b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall promote innovation in evidence-based health care practices and technologies by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60058b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting and supporting research on the development, diffusion, and use of health care technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, evaluating, and disseminating methodologies for assessments of health care practices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting intramural and supporting extramural assessments of existing and new health care practices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting education and training and providing technical assistance in the use of health care practice and technology assessment methodologies and results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with the National Library of Medicine and the public and private sector to develop an electronic clearinghouse of currently available assessments and those in progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60058b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60058b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":", the Director shall develop and publish a description of the methods used by the Agency and its contractors for health care practice and technology assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall cooperate and consult with the Assistant Secretary for Health, the Administrator of the Centers for Medicare & Medicaid Services, the Director of the National Institutes of Health, the Commissioner of Food and Drugs, and the heads of any other interested Federal department or agency, and shall seek input, where appropriate, from professional societies and other private and public entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, in developing the methods used under paragraph (1), consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60058bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety, efficacy, and effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60058bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal, social, and ethical implications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60058bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs, benefits, and cost-effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60058be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparisons to alternate health care practices and technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60058bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements of Food and Drug Administration approval to avoid duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60058c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60058c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall conduct or support specific assessments of health care technologies and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to conduct or support assessments, on a reimbursable basis, for the Centers for Medicare & Medicaid Services, the Department of Defense, the Department of Veterans Affairs, the Office of Personnel Management, and other public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to conducting assessments, the Director may make grants to, or enter into cooperative agreements or contracts with, entities described in paragraph (4) for the purpose of conducting assessments of experimental, emerging, existing, or potentially outmoded health care technologies, and for related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity described in this paragraph is an entity that is determined to be appropriate by the Director, including academic medical centers, research institutions and organizations, professional organizations, third party payers, governmental agencies, minority institutions of higher education (such as Historically Black Colleges and Universities, and Hispanic institutions), and consortia of appropriate research entities established for the purpose of conducting technology assessments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60058c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical examination of certain victims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60058c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall develop and disseminate a report on evidence-based clinical practices for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60058c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examination and treatment by health professionals of individuals who are victims of sexual assault (including child molestation) or attempted sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60058c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of health professionals, in consultation with the Health Resources and Services Administration, on performing medical evidentiary examinations of individuals who are victims of child abuse or neglect, sexual assault, elder abuse, or domestic violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60058c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In identifying the issues to be addressed by the report, the Director shall, to the extent practicable, take into consideration the expertise and experience of Federal and State law enforcement officials regarding the victims referred to in paragraph (1), and of other appropriate public and private entities (including medical societies, victim services organizations, sexual assault prevention organizations, and social services organizations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60058ca-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 916, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1660"},"text":"113 Stat. 1660","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/e/2/C"},"text":"Pub. L. 108–173, title IX, § 900(e)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2372"},"text":"117 Stat. 2372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60058cb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60058cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb60058cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (b)(2), (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
