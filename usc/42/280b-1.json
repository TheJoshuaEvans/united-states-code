{"tag":"section","attrib":{"id":"idb529a739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280b–1"},"text":"§ 280b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing overdoses of controlled substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb529a73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based prevention grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb529a73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a73c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, carry out and expand any evidence-based prevention activities described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a73d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and technical assistance to States, localities, and Indian Tribes for purposes of carrying out such activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to States, localities, and Indian Tribes for purposes of carrying out such activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a73f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based prevention activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An evidence-based prevention activity described in this paragraph is any of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improving the efficiency and use of a new or currently operating prescription drug monitoring program, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb529a741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging all authorized users (as specified by the State or other entity) to register with and use the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling such users to access any updates to information collected by the program in as close to real-time as possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the ease of use of such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for a mechanism for the program to notify authorized users of any potential misuse or abuse of controlled substances and any detection of inappropriate prescribing or dispensing practices relating to such substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the analysis of prescription drug monitoring data for purposes of providing de-identified, aggregate reports based on such analysis to State public health agencies, State substance abuse agencies, State licensing boards, and other appropriate State agencies, as permitted under applicable Federal and State law and the policies of the prescription drug monitoring program and not containing any protected health information, to prevent inappropriate prescribing, drug diversion, or abuse and misuse of controlled substances, and to facilitate better coordination among agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing interoperability between the program and any health information technology (including certified health information technology), including by integrating program data into such technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updating program capabilities to respond to technological innovation for purposes of appropriately addressing the occurrence and evolution of controlled substance overdoses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating and encouraging data exchange between the program and the prescription drug monitoring programs of other States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing data collection and quality, including improving patient matching and proactively monitoring data quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a74a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing prescriber and dispenser practice tools, including prescriber practice insight reports for practitioners to review their prescribing patterns in comparison to such patterns of other practitioners in the specialty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb529a74b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the purpose of the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–3"},"text":"section 280g–3 of this title","children":[],"tail":", as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–3/a"},"text":"section 280g–3(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a74c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting community or health system interventions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating interventions to prevent controlled substance overdoses and associated risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementing projects to advance an innovative prevention approach with respect to new and emerging public health crises and opportunities to address such crises, such as enhancing public education and awareness on the risks associated with substances causing overdose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may award grants to States, localities, and Indian Tribes for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out innovative projects for grantees to detect, identify, and rapidly respond to controlled substance misuse, abuse, and overdoses, and associated risk factors, including changes in patterns of such controlled substance use. Such projects may include the use of innovative, evidence-based strategies for detecting such patterns, such as wastewater surveillance, if proven to support actionable prevention strategies, in a manner consistent with applicable Federal and State privacy laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any other evidence-based activity for preventing controlled substance misuse, abuse, and overdoses as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in coordination with the Assistant Secretary for Mental Health and Substance Use and the National Mental Health and Substance Use Policy Laboratory established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–0"},"text":"section 290aa–0 of this title","children":[],"tail":", as appropriate and applicable, may conduct studies and evaluations to address substance use disorders, including preventing substance use disorders or other related topics the Director determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb529a753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced controlled substance overdose data collection, analysis, and dissemination grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb529a754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Centers for Disease Control and Prevention may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, carry out any controlled substance overdose data collection activities described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and technical assistance to States, localities, and Indian Tribes for purposes of carrying out such activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to States, localities, and Indian Tribes for purposes of carrying out such activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Assistant Secretary for Mental Health and Substance Use to collect data pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–4/d/1/A"},"text":"section 290aa–4(d)(1)(A) of this title","children":[],"tail":" (relating to the number of individuals admitted to emergency departments as a result of the abuse of alcohol or other drugs)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance overdose data collection and analysis activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A controlled substance overdose data collection, analysis, and dissemination activity described in this paragraph is any of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a75a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the timeliness of reporting data to the public, including data on fatal and nonfatal overdoses of controlled substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a75b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing the comprehensiveness of controlled substance overdose data by collecting information on such overdoses, and associated risk factors, from appropriate sources such as toxicology reports, autopsy reports, death scene investigations, and emergency departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a75c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Modernizing the system for monitoring and identifying causes of death related to controlled substance overdoses to use an electronic-based system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a75d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using data to help identify risk factors associated with controlled substance overdoses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a75e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting entities involved in providing information on controlled substance overdoses, such as coroners, medical examiners, and public health laboratories, to improve accurate testing and standardized reporting of causes and contributing factors to controlled substances overdoses and analysis of various opioid analogues and other emerging substances related to controlled substance overdoses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a75f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Working to enable and encourage the access, exchange, and use of information regarding controlled substance overdoses and associated risk factors among data sources and entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb529a760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants to States under subsections (a) and (b), the Director of the Centers for Disease Control and Prevention may give priority to jurisdictions with a disproportionately high rate of drug overdoses or drug overdose deaths, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb529a761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb529a762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled substance” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb529a764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–3"},"text":"section 280g–3 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–25g"},"text":"section 290bb–25g of this title","children":[],"tail":", there is authorized to be appropriated $505,579,000 for each of fiscal years 2026 through 2030."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb529a765-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 392A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7161/a"},"text":"Pub. L. 115–271, title VII, § 7161(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4059"},"text":"132 Stat. 4059","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1271/b"},"text":"Pub. L. 117–328, div. FF, title I, § 1271(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5686"},"text":"136 Stat. 5686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s103"},"text":"Pub. L. 119–44, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/670"},"text":"139 Stat. 670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb529a766-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb529a767-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb529a768-3a70-11f1-ae07-e4213316b5fa"},"text":n