{"tag":"section","attrib":{"id":"idbd2e9265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196d"},"text":null,"children":[{"tag":"num","attrib":{"value":"5196d"},"text":"§ 5196d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds to prepare for and respond to hazards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds made available to the States under this subchapter may be used by the States for the purposes of preparing for hazards and providing emergency assistance in response to hazards. Regulations prescribed to carry out this section shall authorize the use of emergency preparedness personnel, materials, and facilities supported in whole or in part through contributions under this subchapter for emergency preparedness activities and measures related to hazards.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd2e9266-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVI/s615"},"text":"Pub. L. 93–288, title VI, § 615","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIV/s3411/a/3"},"text":"Pub. L. 103–337, div. C, title XXXIV, § 3411(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3107"},"text":"108 Stat. 3107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2e9267-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2e9268-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd2e9269-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 2289 of the former Appendix to Title 50, War and National Defense, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3412/a"},"text":"Pub. L. 103–337, § 3412(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
