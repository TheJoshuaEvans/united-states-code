{"tag":"section","attrib":{"id":"idbde16793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6966c"},"text":"§ 6966c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices for battery recycling and labeling guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbde16794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde16795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde16796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “battery” means a device that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde16797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consists of 1 or more electrochemical cells that are electrically connected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde16798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to store and deliver electric energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde16799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recycling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recycling” means the series of activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde1679a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which recyclable materials are processed into specification-grade commodities, and consumed as raw-material feedstock, in lieu of virgin materials, in the manufacturing of new products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde1679b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may include collection, processing, and brokering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde1679c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that result in subsequent consumption by a materials manufacturer, including for the manufacturing of new products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde1679d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices for collection of batteries to be recycled","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde1679e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop best practices that may be implemented by State, Tribal, and local governments with respect to the collection of batteries to be recycled in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde1679f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, is technically and economically feasible for State, Tribal, and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is environmentally sound and safe for waste management workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimizes the value and use of material derived from recycling of batteries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop the best practices described in paragraph (1) in coordination with State, Tribal, and local governments and relevant nongovernmental and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to Congress a report describing the best practices developed under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this subsection $10,000,000 for fiscal year 2022, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde167a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary labeling guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde167a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the Environmental Protection Agency a program (referred to in this subsection as the “program”) to promote battery recycling through the development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary labeling guidelines for batteries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other forms of communication materials for battery producers and consumers about the reuse and recycling of critical materials from batteries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program are to improve battery collection and reduce battery waste, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying battery collection locations and increasing accessibility to those locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting consumer education about battery collection and recycling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing safety concerns relating to the improper disposal of batteries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other standards and law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make every reasonable effort to ensure that voluntary labeling guidelines and other forms of communication materials developed under the program are consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international battery labeling standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Mercury-Containing and Rechargeable Battery Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14301"},"text":"42 U.S.C. 14301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this subsection $15,000,000 for fiscal year 2022, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbde167b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tIV/s70401"},"text":"Pub. L. 117–58, div. G, title IV, § 70401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1261"},"text":"135 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbde167b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbde167b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbde167b4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mercury-Containing and Rechargeable Battery Management Act, referred to in subsec. (c)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142"},"text":"Pub. L. 104–142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1329"},"text":"110 Stat. 1329","children":[],"tail":", which is classified generally to chapter 137 (§ 14301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14301"},"text":"section 14301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbde167b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
