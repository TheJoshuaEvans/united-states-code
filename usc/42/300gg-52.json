{"tag":"section","attrib":{"id":"idb6b7e92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–52"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–52"},"text":"§ 300gg–52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required coverage for reconstructive surgery following mastectomies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of section 2706 ","children":[{"tag":"ref","attrib":{"idref":"fn002477"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002477"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall apply to health insurance coverage offered by a health insurance issuer in the individual market in the same manner as they apply to health insurance coverage offered by a health insurance issuer in connection with a group health plan in the small or large group market."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6b7e92e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2752, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tIX/s903/b"},"text":"Pub. L. 105–277, div. A, § 101(f) [title IX, § 903(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–438.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b7e92f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b7e930-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6b7e931-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2706, referred to in text, is a reference to section 2706 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":". Section 2706, which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–6"},"text":"section 300gg–6 of this title","children":[],"tail":", was renumbered section 2727 and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(2), 1563(c)(5), formerly § 1562(c)(5), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 266, 911, and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–27"},"text":"section 300gg–27 of this title","children":[],"tail":". A new section 2706 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", related to non-discrimination in health care, was added, effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1201/4"},"text":"Pub. L. 111–148, title I, § 1201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/160"},"text":"124 Stat. 160","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–5"},"text":"section 300gg–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6b7e932-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6b7e933-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tIX/s903/c/2"},"text":"Pub. L. 105–277, div. A, § 101(f) [title IX, § 903(c)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–438, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/f/tIX/s903/c/2"},"text":"“The amendment made by subsection (b) [enacting this section] shall apply with respect to health insurance coverage offered, sold, issued, renewed, in effect, or operated in the individual market on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
