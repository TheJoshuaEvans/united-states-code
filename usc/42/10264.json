{"tag":"section","attrib":{"id":"idbf1c31db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10264"},"text":null,"children":[{"tag":"num","attrib":{"value":"10264"},"text":"§ 10264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigatory powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c31dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Chairman or a majority of the members of the Board, the Board may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence, as the Board considers appropriate. Any member of the Board may administer oaths or affirmations to witnesses appearing before the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c31dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production of documents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c31de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10264/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the Chairman or a majority of the members of the Board, and subject to existing law, the Secretary (or any contractor of the Secretary) shall provide the Board with such records, files, papers, data, or information as may be necessary to respond to any inquiry of the Board under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c31df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10264/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to existing law, information obtainable under paragraph (1) shall not be limited to final work products of the Secretary, but shall include drafts of such products and documentation of work in progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c31e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tV/s504"},"text":"Pub. L. 97–425, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5051"},"text":"Pub. L. 100–203, title V, § 5051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-249"},"text":"101 Stat. 1330–249","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c31e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c31e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c31e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
