{"tag":"section","attrib":{"id":"idb4f52a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g"},"text":null,"children":[{"tag":"num","attrib":{"value":"254g"},"text":"§ 254g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges for services by entities using Corps members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f52a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of services regardless of ability to pay or payment source","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity to which a Corps member is assigned shall not deny requested health care services, and shall not discriminate in the provision of services to an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f52a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because the individual is unable to pay for the services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" because payment for the services would be made under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f52a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medicare program under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f52a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medicaid program under title XIX of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f52a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State children’s health insurance program under title XXI of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f52a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following rules shall apply to charges for health care services provided by an entity to which a Corps member is assigned:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f52a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f52a45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of fees or payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the entity shall prepare a schedule of fees or payments for the entity’s services, consistent with locally prevailing rates or charges and designed to cover the entity’s reasonable cost of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f52a46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of discounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the entity shall prepare a corresponding schedule of discounts (including, in appropriate cases, waivers) to be applied to the payment of such fees or payments. In preparing the schedule, the entity shall adjust the discounts on the basis of a patient’s ability to pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f52a47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of schedules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entity shall make every reasonable effort to secure from patients fees and payments for services in accordance with such schedules, and fees or payments shall be sufficiently discounted in accordance with the schedule described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services to beneficiaries of Federal and federally assisted programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of health care services furnished to an individual who is a beneficiary of a program listed in subsection (a)(2), the entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f52a49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall accept an assignment pursuant to section 1842(b)(3)(B)(ii) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u/b/3/B/ii"},"text":"42 U.S.C. 1395u(b)(3)(B)(ii)","children":[],"tail":") with respect to an individual who is a beneficiary under the medicare program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f52a4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall enter into an appropriate agreement with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f52a4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agency administering the program under title XIX of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] with respect to an individual who is a beneficiary under the medicaid program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f52a4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State agency administering the program under title XXI of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.] with respect to an individual who is a beneficiary under the State children’s health insurance program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entity shall take reasonable and appropriate steps to collect all payments due for health care services provided by the entity, including payments from any third party (including a Federal, State, or local government agency and any other third party) that is responsible for part or all of the charge for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f52a4e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 334, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIII/s305"},"text":"Pub. L. 107–251, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1647"},"text":"116 Stat. 1647","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/i"},"text":"Pub. L. 108–163, § 2(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2022"},"text":"117 Stat. 2022","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f52a4f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f52a50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f52a51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (a)(2) and (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII, XIX, and XXI of the Act are classified generally to subchapters XVIII (§ 1395 et seq.), XIX (§ 1396 et seq.), and XXI (§ 1397aa et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4f52a52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 254g, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s334"},"text":"act July 1, 1944, ch. 373, title III, § 334","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s407/b/3"},"text":"Pub. L. 94–484, title IV, § 407(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2274"},"text":"90 Stat. 2274","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2704"},"text":"Pub. L. 97–35, title XXVII, § 2704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/906"},"text":"95 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/194/s3"},"text":"Pub. L. 98–194, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-01"},"text":"Dec. 1, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1345"},"text":"97 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tII/s202/c"},"text":"Pub. L. 100–177, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/996"},"text":"101 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tI/s105"},"text":"Pub. L. 101–597, title I, § 105","children":[],"tail":", title IV, § 401(b)[(a)], "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3018"},"text":"104 Stat. 3018","children":[],"tail":", 3035, related to shared responsibility for costs of Corps personnel providing health services in or to a health professional shortage area during the assignment period, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIII/s305"},"text":"Pub. L. 107–251, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1647"},"text":"116 Stat. 1647","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f52a53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163"},"text":"Pub. L. 108–163","children":[],"tail":" inserted “the payment of” after “applied to”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f52a54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4f52a55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163"},"text":"Pub. L. 108–163","children":[],"tail":" deemed to have taken effect immediately after the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s3"},"text":"section 3 of Pub. L. 108–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s233"},"text":"section 233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
