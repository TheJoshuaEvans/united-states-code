,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbedbcdb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s202/c/1"},"text":"Pub. L. 105–285, § 202(c)(1)","children":[],"tail":", in concluding provisions, inserted “(before "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":")” after “funds available” and “(as in effect before "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":")” after “9910(a) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s202/c/2"},"text":"Pub. L. 105–285, § 202(c)(2)","children":[],"tail":", inserted “(before "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":")” after “funds available” and “(as in effect before "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":")” after “9910(a) of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbedbcdb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbedbcdb7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/425/s1001"},"text":"section 1001 of Pub. L. 99–425","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbedbcdb8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Loan by Utah or Ohio Local Public Body to Nonprofit Corporation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/a/tVI/s640"},"text":"Pub. L. 99–500, § 101(a) [title VI, § 640]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783"},"text":"100 Stat. 1783","children":[],"tail":", 1783–35, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/a/tVI/s640"},"text":"Pub. L. 99–591, § 101(a) [title VI, § 640]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341"},"text":"100 Stat. 3341","children":[],"tail":", 3341–35, purported to amend section 623B(b)(2) of the Community Economic Development Act of 1981, a nonexistent section of that Act ("},{"tag":"ref","attrib":{"href":"/us/pl/99/35/tVI/s611"},"text":"Pub. L. 99–35, title VI, § 611","children":[],"tail":" et seq.), by adding at the end thereof the following new sentence: "},{"tag":"quotedContent","attrib":{},"text":"“Notwithstanding any other provision of law, any Utah or Ohio local public body to which a loan was made after ","children":[{"tag":"date","attrib":{"date":"1982-12-31"},"text":"December 31, 1982","children":[],"tail":", from the Rural Development Loan Fund may, at the discretion of such local public body and with the approval of the Secretary of Health and Human Services, transfer such loan to a nonprofit corporation designated by such body to serve as an intermediate borrower and to carry out the purposes of the loan.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
