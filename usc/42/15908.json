{"tag":"section","attrib":{"id":"idbfe945f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908"},"text":null,"children":[{"tag":"num","attrib":{"value":"15908"},"text":"§ 15908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of geological and geophysical data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe945f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “National Geological and Geophysical Data Preservation Program Act of 2005”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe945f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a National Geological and Geophysical Data Preservation Program in accordance with this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe945f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to archive geologic, geophysical, and engineering data, maps, well logs, and samples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a national catalog of such archival material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical and financial assistance related to the archival material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for preservation of samples to track geochemical signatures from critical mineral (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/a"},"text":"section 1606(a) of title 30","children":[],"tail":") ore bodies for use in provenance tracking frameworks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe945fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall submit to Congress a plan for the implementation of the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe945fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data archive system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe945fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, as a component of the Program, a data archive system to provide for the storage, preservation, and archiving of subsurface, surface, geological, geophysical, and engineering data and samples. The Secretary, in consultation with the Advisory Committee, shall develop guidelines relating to the data archive system, including the types of data and samples to be preserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The system shall be comprised of State agencies that elect to be part of the system and agencies within the Department of the Interior that maintain geological and geophysical data and samples that are designated by the Secretary in accordance with this subsection. The Program shall provide for the storage of data and samples through data repositories operated by such agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not designate a State agency as a component of the data archive system unless that agency is the agency that acts as the geological survey in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe945ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data from Federal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data archive system shall provide for the archiving of relevant subsurface data and samples obtained from Federal land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the most appropriate repository designated under paragraph (2), with preference being given to archiving data in the State in which the data were collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with all applicable law and requirements relating to confidentiality and proprietary data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National catalog","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall develop and maintain, as a component of the Program, a national catalog that identifies—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data and samples available in the data archive system established under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repository for particular material in the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means of accessing the material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the national catalog accessible to the public on the site of the Survey on the Internet, consistent with all applicable requirements related to confidentiality and proprietary data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall advise the Secretary on planning and implementation of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9460a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to its duties under the National Geologic Mapping Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31a"},"text":"43 U.S.C. 31a","children":[],"tail":" et seq.), the Advisory Committee shall perform the following duties:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9460b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the Secretary on developing guidelines and procedures for providing assistance for facilities under subsection (g)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9460c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and critique the draft implementation plan prepared by the Secretary under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9460d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identify useful studies of data archived under the Program that will advance understanding of the Nation’s energy and mineral resources, geologic hazards, and engineering geology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9460e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review the progress of the Program in archiving significant data and preventing the loss of such data, and the scientific progress of the studies funded under the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9460f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Include in the annual report to the Secretary required under section 5(b)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn004196"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004196"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the National Geologic Mapping Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31d/b/3"},"text":"43 U.S.C. 31d(b)(3)","children":[],"tail":") an evaluation of the progress of the Program toward fulfilling the purposes of the Program under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archive facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall provide financial assistance to a State agency that is designated under subsection (d)(2) for providing facilities to archive energy material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall provide financial assistance to any State agency designated under subsection (d)(2) for studies and technical assistance activities that enhance understanding, interpretation, and use of materials archived in the data archive system established under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of an activity carried out with assistance under this subsection shall be not more than 50 percent of the total cost of the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply to the non-Federal share of the cost of an activity carried out with assistance under this subsection the value of private contributions of property and services used for that activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94615-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in each report under section 8 of the National Geologic Mapping Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31g"},"text":"43 U.S.C. 31g","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94616-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the status of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94617-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the progress achieved in developing the Program during the period covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94618-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislative or other action the Secretary considers necessary and appropriate to fulfill the purposes of the Program under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94619-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of State effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress that the States not use this section as an opportunity to reduce State resources applied to the activities that are the subject of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe9461a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe9461b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Advisory Committee” means the advisory committee established under section 5 of the National Geologic Mapping Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s31d"},"text":"43 U.S.C. 31d","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9461c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the National Geological and Geophysical Data Preservation Program carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9461d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior, acting through the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9461e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Survey” means the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe9461f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15908/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2021 through 2029, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe94620-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s351"},"text":"Pub. L. 109–58, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/711"},"text":"119 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVII/s7002"},"text":"Pub. L. 116–260, div. Z, title VII, § 7002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2575"},"text":"134 Stat. 2575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40203"},"text":"Pub. L. 117–58, div. D, title II, § 40203","children":[],"tail":", "},{"tag