2599"},"text":"120 Stat. 2599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s411/c"},"text":"Pub. L. 110–140, title IV, § 411(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1601"},"text":"121 Stat. 1601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tIV/s407/a"},"text":"Pub. L. 111–5, div. A, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/145"},"text":"123 Stat. 145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1011/b"},"text":"Pub. L. 116–260, div. Z, title I, § 1011(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2442"},"text":"134 Stat. 2442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc02386-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc02387-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdc02388-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(7) of the Developmental Disabilities Services and Facilities Construction Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6001/7"},"text":"42 U.S.C. 6001(7)","children":[],"tail":"], referred to in par. (5), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/a"},"text":"Pub. L. 106–402, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2809/a/12"},"text":"Section 2809(a)(12) of this title","children":[],"tail":", referred to in par. (7), which was redesignated as section 2809(a)(5) by "},{"tag":"ref","attrib":{"href":"/us/pl/95/568/s5/a/2/E"},"text":"Pub. L. 95–568, § 5(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2426"},"text":"92 Stat. 2426","children":[],"tail":", was subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683/a"},"text":"Pub. L. 97–35, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/519"},"text":"95 Stat. 519","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles IV and XVI of the Social Security Act are classified generally to subchapters IV (§ 601 et seq.) and XVI (§ 1381 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Low-Income Home Energy Assistance Act of 1981, referred to in par. (7), is title XXVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/893"},"text":"95 Stat. 893","children":[],"tail":", which is classified generally to subchapter II (§ 8621 et seq.) of chapter 94 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc02389-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (9)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" inserted “, including renewable energy technologies and other advanced technologies,” after “devices or technologies” and struck out “, the Secretary of Agriculture, and the Director, of the Community Services Administration” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" substituted “200 percent” for “150 percent” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added par. (8) and struck out former par. (8) which read as follows: “The term ‘State’ means each of the States and the District of Columbia.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" struck out “paragraphs (4), (5), and (6), respectively, of” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3002"},"text":"section 3002 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “150 percent” for “125 percent” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" substituted “an individual with a disability, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705"},"text":"section 705 of title 29","children":[],"tail":"” for “a handicapped individual as defined in section 7(7) of the Rehabilitation Act of 1973”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (9)(G) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" realigned margin of subpar. (G), added subpars. (H) and (I), and redesignated former subpar. (H) as (J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (9)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/440"},"text":"Pub. L. 101–440","children":[],"tail":" added subpar. (G) and redesignated former subpar. (G) as (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (9)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":" substituted a single comma for two consecutive commas after “determine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (7)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558/s401"},"text":"Pub. L. 98–558, § 401","children":[],"tail":", added cl. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558/s402/1"},"text":"Pub. L. 98–558, § 402(1)","children":[],"tail":", in ame