{"tag":"section","attrib":{"id":"idbda5e5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Petroleum” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “petroleum” includes crude oil, gases (including natural gas), natural gasoline, and other related hydrocarbons, oil shale, and the products of any of such resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbda5e5f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258/tI/s101"},"text":"Pub. L. 94–258, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/303"},"text":"90 Stat. 303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda5e5f6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbda5e5f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbda5e5f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258/s1"},"text":"Pub. L. 94–258, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/303"},"text":"90 Stat. 303","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/258/s1"},"text":"“That this Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7420"},"text":"section 7420 of Title 10","children":[],"tail":", Armed Forces, and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6244"},"text":"section 6244 of this title","children":[],"tail":" and sections 7421 to 7436 and 7438 of Title 10] may be cited as the ‘Naval Petroleum Reserves Production Act of 1976’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
