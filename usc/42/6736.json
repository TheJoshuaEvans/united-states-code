{"tag":"section","attrib":{"id":"idbdbb41fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736"},"text":null,"children":[{"tag":"num","attrib":{"value":"6736"},"text":"§ 6736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Puerto Rico, Guam, American Samoa, and Virgin Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbb41fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for five calendar quarters beginning ","children":[{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated for each of the five succeeding calendar quarters (beginning with the calendar quarter which begins on ","children":[{"tag":"date","attrib":{"date":"1977-07-01"},"text":"July 1, 1977","children":[],"tail":") for the purpose of making payments under this subchapter to Puerto Rico, Guam, American Samoa, and the Virgin Islands, an amount equal to 1 percent of the amount authorized for each such quarter under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6722/b"},"text":"section 6722(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb41fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb41fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall allocate from the amount authorized under subsection (a) an amount for the purpose of making payments to such governments equal to the total authorized for the calendar quarter multiplied by the applicable territorial percentage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb41fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this subsection, the applicable territorial percentage is equal to the quotient resulting from the division of the territorial population by the sum of the territorial population for all territories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb41ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbb4200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “territory” means Puerto Rico, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbb4201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “territorial population” means the most recent population for each territory as determined by the Bureau of Census.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbb4202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of sections 6723(c)(4), 6724, 6725, 6726,","children":[{"tag":"ref","attrib":{"idref":"fn003506"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003506"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 6727, 6728, 6729, 6730, 6731, 6732, and 6733 "},{"tag":"ref","attrib":{"idref":"fn003506"},"text":"1","children":[],"tail":" of this title shall apply to the funds authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb4203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The governments of the territories are authorized to make payments to local governments within their jurisdiction from sums received under this section as they deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb4204-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tII/s216"},"text":"Pub. L. 94–369, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tVI/s607"},"text":"Pub. L. 95–30, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/167"},"text":"91 Stat. 167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb4205-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb4206-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdbb4207-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6726"},"text":"Section 6726 of this title","children":[],"tail":", referred to in subsec. (b)(3)(C), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tVI/s603/i"},"text":"Pub. L. 95–30, title VI, § 603(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/166"},"text":"91 Stat. 166","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6733"},"text":"Section 6733 of this title","children":[],"tail":", referred to in subsec. (b)(3)(C), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1131/b"},"text":"Pub. L. 104–66, title I, § 1131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/725"},"text":"109 Stat. 725","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
