{"tag":"section","attrib":{"id":"idbc238ac8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2393"},"text":null,"children":[{"tag":"num","attrib":{"value":"2393"},"text":"§ 2393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments in anticipation of services; withholding of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The payments made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2391"},"text":"section 2391 of this title","children":[],"tail":" to transferees of municipal installations are in anticipation that the respective recipients of those payments furnish, or have furnished, for the community, the school, hospital, or other municipal services in respect of which the payments are made. Any such payment may be withheld, in whole or in part, if the Administrator finds that the recipient is not furnishing such services for any part of the area so designated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc238ac9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 9, § 93, "},{"tag":"ref","attrib":{"href":"/us/stat/69/482"},"text":"69 Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/187/tVI/s601/1"},"text":"Pub. L. 94–187, title VI, § 601(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1077"},"text":"89 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc238aca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc238acb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc238acc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/187"},"text":"Pub. L. 94–187","children":[],"tail":" substituted “Administrator” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc238acd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc238ace-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Energy Research and Development Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
