{"tag":"section","attrib":{"id":"idbf879e14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12640"},"text":null,"children":[{"tag":"num","attrib":{"value":"12640"},"text":"§ 12640.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement of participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State shall not engage a participant to serve in any program that receives assistance under this subchapter unless and until amounts have been appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12681"},"text":"section 12681 of this title","children":[],"tail":" for the provision of national service educational awards and for the payment of other necessary expenses and costs associated with such participant."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf879e15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s180"},"text":"Pub. L. 101–610, title I, § 180","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3166"},"text":"104 Stat. 3166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s119"},"text":"Pub. L. 103–82, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/866"},"text":"107 Stat. 866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf879e16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf879e17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf879e18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" substituted “national service educational awards” for “post-service benefits”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf879e19-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf879e1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
