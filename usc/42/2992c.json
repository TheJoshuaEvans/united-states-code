{"tag":"section","attrib":{"id":"idbc31e2a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2992c"},"text":"§ 2992c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e2aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “average” means the aggregate number of hours of instruction through the use of a Native American language to all students enrolled in a native language immersion program during a school year divided by the total number of students enrolled in the immersion program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “financial assistance” includes assistance advanced by grant, agreement, or contract, but does not include the procurement of plant or equipment, or goods or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian reservation or Alaska Native village” includes the reservation of any federally or State recognized Indian Tribe, including any band, nation, pueblo, or rancheria, any former reservation in Oklahoma, and community under the jurisdiction of an Indian Tribe, including a band, nation, pueblo, or rancheria, with allotted lands or lands subject to a restriction against alienation imposed by the United States or a State, and any lands of or under the jurisdiction of an Alaska Native village or group, including any lands selected by Alaska Natives or Alaska Native organizations under the Alaska Native Claims Settlement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Native Hawaiian” means any individual any of whose ancestors were natives of the area which consists of the Hawaiian Islands prior to 1778;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “rule” has the meaning given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/4"},"text":"section 551(4) of title 5","children":[],"tail":", as amended from time to time;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Native American Pacific Islander” means an individual who is indigenous to a United States territory or possession located in the Pacific Ocean, and includes such individual while residing in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e2b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s815"},"text":"Pub. L. 88–452, title VIII, § 815","children":[],"tail":", formerly § 813, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2327"},"text":"88 Stat. 2327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tX/s1004"},"text":"Pub. L. 98–558, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2906"},"text":"98 Stat. 2906","children":[],"tail":"; renumbered § 815 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV"},"text":"Pub. L. 100–175, title V","children":[],"tail":", §§ 502(2), 503(b), "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/973"},"text":"101 Stat. 973","children":[],"tail":", 975; "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/21"},"text":"Pub. L. 102–375, title VIII, § 822(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1300"},"text":"106 Stat. 1300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/497/s9/b"},"text":"Pub. L. 102–497, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","child