{"tag":"section","attrib":{"id":"idb61d0816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–74"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–74"},"text":"§ 300d–74.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part may be construed to ease any restriction in Federal law applicable to the amount or percentage of funds appropriated to carry out this part that may be used to prepare or submit a report.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb61d0817-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1274, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/194/s3"},"text":"Pub. L. 108–194, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2891"},"text":"117 Stat. 2891","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
