{"tag":"section","attrib":{"id":"idbcab7f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4017a"},"text":"§ 4017a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcab7f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Reserve Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the flood insurance program authorized by this subchapter, the Administrator shall establish in the Treasury of the United States a National Flood Insurance Reserve Fund (in this section referred to as the “Reserve Fund”) which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcab7f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an account separate from any other accounts or funds available to the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be available for meeting the expected future obligations of the flood insurance program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcab7f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of claims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims adjustment expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment of amounts outstanding under any note or other obligation issued by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4016/a"},"text":"section 4016(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcab7f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve ratio","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the phase-in requirements under subsection (d), the Reserve Fund shall maintain a balance equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcab7f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of the sum of the total potential loss exposure of all outstanding flood insurance policies in force in the prior fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such higher percentage as the Administrator determines to be appropriate, taking into consideration any circumstance that may raise a significant risk of substantial future losses to the Reserve Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcab7f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of reserve ratio","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcab7f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall have the authority to establish, increase, or decrease the amount of aggregate annual insurance premiums to be collected for any fiscal year necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcab7f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the reserve ratio required under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve such reserve ratio, if the actual balance of such reserve is below the amount required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising the authority granted under paragraph (1), the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcab7f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected operating expenses of the Reserve Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the insurance loss expenditures under the flood insurance program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any investment income generated under the flood insurance program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor that the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcab7f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In exercising the authority granted under paragraph (1), the Administrator shall be subject to all other provisions of this chapter, including any provisions relating to chargeable premium rates or annual increases of such rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcab7f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of additional annual insurance premiums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or any agreement entered into by the Administrator, the Administrator shall ensure that all amounts attributable to the establishment or increase of annual insurance premiums under paragraph (1) are transferred to the Administrator for deposit into the Reserve Fund, to be available for meeting the expected future obligations of the flood insurance program as described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of premium surcharges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall deposit in the Reserve Fund any surcharges collected pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4015a"},"text":"section 4015a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcab7f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-in requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The phase-in requirements under this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcab7f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2013 and not ending until the fiscal year in which the ratio required under subsection (b) is achieved, in each such fiscal year the Administrator shall place in the Reserve Fund an amount equal to not less than 7.5 percent of the reserve ratio required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount satisfied","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as the ratio required under subsection (b) is achieved, and except as provided in paragraph (3), the Administrator shall not be required to set aside any amounts for the Reserve Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If at any time after the ratio required under subsection (b) is achieved, the Reserve Fund falls below the required ratio under subsection (b), the Administrator shall place in the Reserve Fund for that fiscal year an amount equal to not less than 7.5 percent of the reserve ratio required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcab7f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reserve ratio","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any given fiscal year, if the Administrator determines that the reserve ratio required under subsection (b) cannot be achieved, the Administrator shall submit, on a calendar quarterly basis, a report to Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcab7f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes and details the specific concerns of the Administrator regarding the consequences of the reserve ratio not being achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates how such consequences would harm the long-term financial soundness of the flood insurance program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcab7f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates the maximum attainable reserve ratio for that particular fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcab7f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4017a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall invest such amounts of the Reserve Fund as the Secretary determines advisable in obligations issued or guaranteed by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcab7f94-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIII/s1310A"},"text":"Pub. L. 90–448, title XIII, § 1310A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100212"},"text":"Pub. L. 112–141, div. F, title II, § 100212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/922"},"text":"126 Stat. 922","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/89"},"text":"Pub. L. 113–89","children":[],"tail":", §§ 8(b), 20, "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1024"},"text":"128 Stat. 1024","children":[],"tail":", 1028.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcab7f95-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcab7f96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcab7f97-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(3)(A), was in the original “this Act”, and was translated as reading “this title”, meaning title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", known as the National Flood Insurance Act of 1968, which is classified principally to this chapter, to reflect the probable intent of Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcab7f98-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s8/b"},"text":"Pub. L. 113–89, § 8(b)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s20"},"text":"Pub. L. 113–89, § 20","children":[],"tail":", inserted “, on a calendar quarterly basis,” after “submit” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
