{"tag":"section","attrib":{"id":"idb6a9b7e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–6"},"text":"§ 300gg–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive health insurance coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a9b7e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage for essential health benefits package","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health insurance issuer that offers health insurance coverage in the individual or small group market shall ensure that such coverage includes the essential health benefits package required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/a"},"text":"section 18022(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a9b7e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing under group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan shall ensure that any annual cost-sharing imposed under the plan does not exceed the limitations provided for under paragraph (1) of section 18022(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002452"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002452"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a9b7e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child-only plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a health insurance issuer offers health insurance coverage in any level of coverage specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/d"},"text":"section 18022(d) of this title","children":[],"tail":", the issuer shall also offer such coverage in that level as a plan in which the only enrollees are individuals who, as of the beginning of a plan year, have not attained the age of 21."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a9b7e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental only","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a plan described in section 18031(d)(2)(B)(ii) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a9b7e6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2707, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1201/4"},"text":"Pub. L. 111–148, title I, § 1201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/161"},"text":"124 