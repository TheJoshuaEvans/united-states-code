{"tag":"section","attrib":{"id":"idbf89e776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645e"},"text":null,"children":[{"tag":"num","attrib":{"value":"12645e"},"text":"§ 12645e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Corporation shall comply with applicable audit and reporting requirements as provided in the Chief Financial Officers Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"31 U.S.C. 901","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/101/576"},"text":"Public Law 101–576","children":[],"tail":") and chapter 91 of title 31 (commonly known as the “Government Corporation Control Act”). The Corporation shall report to the authorizing committees any failure to comply with such requirements."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf89e777-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s189B"},"text":"Pub. L. 101–610, title I, § 189B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1612"},"text":"Pub. L. 111–13, title I, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1540"},"text":"123 Stat. 1540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf89e778-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf89e779-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText"