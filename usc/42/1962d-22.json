{"tag":"section","attrib":{"id":"idbbac5f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–22"},"text":"§ 1962d–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes fishery and ecosystem restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbac5f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes comprise a nationally and internationally significant fishery and ecosystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes fishery and ecosystem should be developed and enhanced in a coordinated manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes fishery and ecosystem provides a diversity of opportunities, experiences, and beneficial uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lake","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lake” means Lake Superior, Lake Michigan, Lake Huron (including Lake St. Clair), Lake Erie, and Lake Ontario (including the St. Lawrence River to the 45th parallel of latitude).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lake” includes any connecting channel, historically connected tributary, and basin of a lake specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lakes Commission” means the Great Lakes Commission established by the Great Lakes Basin Compact (","children":[{"tag":"ref","attrib":{"href":"/us/stat/82/414"},"text":"82 Stat. 414","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes Fishery Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lakes Fishery Commission” has the meaning given the term “Commission” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s931"},"text":"section 931 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Great Lakes State” means each of the States of Illinois, Indiana, Michigan, Minnesota, Ohio, Pennsylvania, New York, and Wisconsin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes fishery and ecosystem restoration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-12-11"},"text":"December 11, 2000","children":[],"tail":", the Secretary shall develop a plan for activities of the Corps of Engineers that support the management of Great Lakes fisheries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the plan shall make use of and incorporate documents that relate to the Great Lakes and are in existence on ","children":[{"tag":"date","attrib":{"date":"2000-12-11"},"text":"December 11, 2000","children":[],"tail":", such as lakewide management plans and remedial action plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop the plan in cooperation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbac5f1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the signatories to the Joint Strategic Plan for Management of the Great Lakes Fisheries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbac5f1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other affected interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconnaissance studies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before planning, designing, or constructing a project under paragraph (3), the Secretary shall carry out a reconnaissance study—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify methods of restoring the fishery, ecosystem, and beneficial uses of the Great Lakes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether planning of a project under paragraph (3) should proceed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall plan, design, and construct projects to support the restoration of the fishery, ecosystem, and beneficial uses of the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a program to evaluate the success of the projects carried out under paragraph (3) in meeting fishery and ecosystem restoration goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Evaluations under subparagraph (A) shall be conducted in consultation with the Great Lakes Fishery Commission and appropriate Federal, State, and local agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation features","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project carried out pursuant to this subsection may include compatible recreation features as determined by the Secretary, except that the Federal costs of such features may not exceed 10 percent of the Federal ecosystem restoration costs of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may enter into a cooperative agreement with the Great Lakes Commission or any other agency established to facilitate active State participation in management of the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other Great Lakes activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No activity under this section shall affect the date of completion of any other activity relating to the Great Lakes that is authorized under other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbac5f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbac5f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of development of the plan under subsection (c)(1) shall be 65 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project planning, design, construction, and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for reconnaissance studies, the Federal share of the cost of planning, design, construction, and evaluation of a project under paragraph (3) or (4) of subsection (c) shall be 65 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbac5f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for land, easements, and rights-of-way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall credit the non-Federal interest for the value of any land, easement, right-of-way, dredged material disposal area, or relocation provided for carrying out a project under subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbac5f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal interest may provide up to 100 percent of the non-Federal share required under paragraphs (1) and (2) in the form of services, materials, supplies, or other in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The operation, maintenance, repair, rehabilitation, and replacement of projects carried out under this section shall be a non-Federal responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbac5f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–22/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of this title","children":[],"tail":", for any project carried out under this section, a non-Federal interest may include a private interest and a nonprofit entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbac5f32-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tV/s506"},"text":"Pub. L. 106–541, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2645"},"text":"114 Stat. 2645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5011"},"text":"Pub. L. 110–114, title V, § 5011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1194"},"text":"121 Stat. 1194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI"},"text":"Pub. L. 114–322, title I","children":[],"tail":", §§ 1123, 1140, "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1647"},"text":"130 Stat. 1647","children":[],"tail":", 1658.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbac5f33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbac5f34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbac5f35-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Great Lakes Basin Compact, referred to in subsec. (b)(2), is not classified to the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbac5f36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2000, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbac5f37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1140"},"text":"Pub. L. 114–322, § 1140","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1123"},"text":"Pub. L. 114–322, § 1123","children":[],"tail":", struck out subsec. (g) which authorized appropriations for subsec. (c)(1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5011/a"},"text":"Pub. L. 110–114, § 5011(a)","chi