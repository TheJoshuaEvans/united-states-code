{"tag":"section","attrib":{"id":"idb6182626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–46"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–46"},"text":"§ 300d–46.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this part, the term “uncompensated care costs” means unreimbursed costs from serving self-pay, charity, or Medicaid patients, without regard to payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–4"},"text":"section 1396r–4 of this title","children":[],"tail":", all of which are attributable to emergency care and trauma care, including costs related to subsequent inpatient admissions to the hospital."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6182627-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1246, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3505/a/6"},"text":"Pub. L. 111–148, title III, § 3505(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/525"},"text":"124 Stat. 525","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
