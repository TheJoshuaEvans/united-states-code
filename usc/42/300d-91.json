{"tag":"section","attrib":{"id":"idb61d083a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–91"},"text":"§ 300d–91.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military and civilian partnership for trauma readiness grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb61d083b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military trauma team placement program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d083c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Preparedness and Response and in consultation with the Secretary of Defense, shall award grants to not more than 20 eligible high-acuity trauma centers to enable military trauma teams to provide, on a full-time basis, trauma care and related acute care at such trauma centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d083d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a grant awarded under paragraph (1) to an eligible high-acuity trauma center, such grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d083e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for a period of at least 3 years and not more than 5 years (and may be renewed at the end of such period); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d083f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in an amount that does not exceed $1,000,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552"},"text":"section 1552 of title 31","children":[],"tail":" or any other provision of law, funds available to the Secretary for obligation for a grant under this subsection shall remain available for expenditure for 100 days after the last day of the performance period of such grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d0841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military trauma care provider placement program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d0842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Preparedness and Response and in consultation with the Secretary of Defense, shall award grants to eligible trauma centers to enable military trauma care providers to provide trauma care and related acute care at such trauma centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a grant awarded under paragraph (1) to an eligible trauma center, such grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d0844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for a period of at least 1 year and not more than 3 years (and may be renewed at the end of such period); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be in an amount that does not exceed, in a year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb61d0846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000 for each military trauma care provider that is a physician at such eligible trauma center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61d0847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 for each other military trauma care provider at such eligible trauma center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d0848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d0849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment and public health emergencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receipt of a grant under this section, a grant recipient shall agree to allow military trauma care providers providing care pursuant to such grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d084a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deployed by the Secretary of Defense for military operations, for training, or for response to a mass casualty incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d084b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deployed by the Secretary of Defense, in consultation with the Secretary of Health and Human Services, for response to a public health emergency pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"section 247d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d084c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section to an eligible trauma center may be used to train and incorporate military trauma care providers into such trauma center, including incorporation into operational exercises and training drills related to public health emergencies, expenditures for malpractice insurance, office space, information technology, specialty education and supervision, trauma programs, research, and applicable license fees for such military trauma care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d084d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect any other provision of law that preempts State licensing requirements for health care professionals, including with respect to military trauma care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d084e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d084f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary and the Secretary of Defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible trauma center or eligible high-acuity trauma center awarded a grant under subsection (a) or (b) for a year shall submit to the Secretary and the Secretary of Defense a report for such year that includes information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d0850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of trauma cases managed by military trauma teams or military trauma care providers pursuant to such grant during such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to maintain the integration of the military trauma providers or teams of providers as part of the trauma center, including the financial effect of such grant on the trauma center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the educational effect on resident trainees in centers where military trauma teams are assigned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any research conducted during such year supported by such grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information required by the Secretaries for the purpose of evaluating the effect of such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than once every 2 years, the Secretary, in consultation with the Secretary of Defense, shall submit a report to the congressional committees of jurisdiction that includes information on the effect of placing military trauma care providers in trauma centers awarded grants under this section on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d0856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining military trauma care providers’ readiness and ability to respond to and treat battlefield injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing health care to civilian trauma patients in urban and rural settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of trauma centers and military trauma care providers to increase medical surge capacity, including as a result of a large-scale event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of grant recipients to maintain the integration of the military trauma providers or teams of providers as part of the trauma center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d085a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to incorporate military trauma care providers into operational exercises and training and drills for public health emergencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d085b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of military trauma care providers to participate as part of a medical response during or in advance of a public health emergency, as determined by the Secretary, or a mass casualty incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d085c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61d085d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible high-acuity trauma center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible high-acuity trauma center” means a Level I trauma center that satisfies each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d085e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center has an agreement with the Secretary of Defense to enable military trauma teams to provide trauma care and related acute care at such trauma center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d085f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 20 percent of patients treated at such trauma center in the most recent 3-month period for which data are available are treated for a major trauma at such trauma center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center utilizes a risk-adjusted benchmarking system and metrics to measure performance, quality, and patient outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such trauma center is an academic training center—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb61d0862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affiliated with a medical school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61d0863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that maintains residency programs and fellowships in critical trauma specialties and subspecialties, and provides education and supervision of military trauma team members according to those specialties and subspecialties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61d0864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that undertakes research in the prevention and treatment of traumatic injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center serves as a medical and public health preparedness and response leader for its community, such as by participating in a partnership for State and regional hospital preparedness established under section 247d–3b or 247d–3c of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d0866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible trauma center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible trauma center” means a Level I, II, or III trauma center that satisfies each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61d0867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center has an agreement with the Secretary of Defense to enable military trauma care providers to provide trauma care and related acute care at such trauma center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center utilizes a risk-adjusted benchmarking system and metrics to measure performance, quality, and patient outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61d0869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such trauma center demonstrates a need for integrated military trauma care providers to maintain or improve the trauma clinical capability of such trauma center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d086a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major trauma","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major trauma” means an injury that is greater than or equal to 15 on the injury severity score.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d086b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military trauma team","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “military trauma team” means a complete military trauma team consisting of military trauma care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61d086c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military trauma care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “military trauma care provider” means a member of the Armed Forces who furnishes emergency, critical care, and other trauma acute care services (including a physician, surgeon, physician assistant, nurse, nurse practitioner, respiratory therapist, flight paramedic, combat medic, or enlisted medical technician) or other military trauma care provider as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61d086d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–91/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated $11,500,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb61d086e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1291, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tII/s204"},"text":"Pub. L. 116–22, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/915"},"text":"133 Stat. 915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
