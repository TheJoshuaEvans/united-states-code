{"tag":"section","attrib":{"id":"idbc855a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3515"},"text":null,"children":[{"tag":"num","attrib":{"value":"3515"},"text":"§ 3515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of one-year contracts during two fiscal years","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds provided in this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts may be used for one-year contracts which are to be performed in two fiscal years, so long as the total amount for such contracts is obligated in the year for which the funds are appropriated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc855a33-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394/tII/s208"},"text":"Pub. L. 102–394, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1811"},"text":"106 Stat. 1811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc855a34-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc855a35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc855a36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in the following prior appropriation acts:","children":[],"tail":