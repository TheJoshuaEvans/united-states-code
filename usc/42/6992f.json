{"tag":"section","attrib":{"id":"idbded7547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f"},"text":null,"children":[{"tag":"num","attrib":{"value":"6992f"},"text":"§ 6992f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbded7548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State inspections and enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may conduct inspections under ","children":[{"tag":"ref","attrib":{"idref":"fn003553"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003553"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “under section”."}],"tail":" 6992c of this title and take enforcement actions under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6992d"},"text":"section 6992d of this title","children":[],"tail":" against any person, including any person who has imported medical waste into a State in violation of the requirements of, or regulations under, this subchapter, to the same extent as the Administrator. At the time a State initiates an enforcement action under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6992d"},"text":"section 6992d of this title","children":[],"tail":" against any person, the State shall notify the Administrator in writing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbded7549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of State authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbded754a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempt any State or local law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbded754b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (c), otherwise affect any State or local law or the authority of any State or local government to adopt or enforce any State or local law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbded754c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6992f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State or local law which requires submission of a tracking form from any person subject to this subchapter shall require that the form be identical in content and format to the form required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6992b"},"text":"section 6992b of this title","children":[],"tail":", except that a State may require the submission of other tracking information which is supplemental to the information required on the form required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6992b"},"text":"section 6992b of this title","children":[],"tail":" through additional sheets or such other means as the State deems appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbded754d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s11007"},"text":"Pub. L. 89–272, title II, § 11007","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/582/s2/a"},"text":"Pub. L. 100–582, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-01"},"text":"Nov. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2955"},"text":"102 Stat. 2955","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
