{"tag":"section","attrib":{"id":"idc029aa53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123"},"text":null,"children":[{"tag":"num","attrib":{"value":"17123"},"text":"§ 17123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Green Building Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Federal Director, in coordination with the Commercial Director, shall establish an advisory committee, to be known as the “Green Building Advisory Committee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of representatives of, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each agency referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17081/e"},"text":"section 17081(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other relevant agencies and entities, as determined by the Federal Director, including at least 1 representative of each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029aa59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governmental green building programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent green building associations or councils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building experts, including architects, material suppliers, and construction contractors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security advisors focusing on national security needs, natural disasters, and other dire emergency situations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public transportation industry experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental health experts, including those with experience in children’s health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of non-Federal members on the Committee at any time shall not exceed 15.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Director shall establish a regular schedule of meetings for the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa61-3a70-11f1-ae07-e4213316b5fa",