{"tag":"section","attrib":{"id":"idbdefbfb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132"},"text":null,"children":[{"tag":"num","attrib":{"value":"7132"},"text":"§ 7132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdefbfb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Deputy Secretary, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall be compensated at the rate provided for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":". The Deputy Secretary shall act for and exercise the functions of the Secretary during the absence or disability of the Secretary or in the event the office of Secretary becomes vacant. The Secretary shall designate the order in which the Under Secretary and other officials shall act for and perform the functions of the Secretary during the absence or disability of both the Secretary and Deputy Secretary or in the event of vacancies in both of those offices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdefbfb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary for Science","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdefbfb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department an Under Secretary for Science, who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary shall be compensated at the rate provided for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary for Science shall be appointed from among persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdefbfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have extensive background in scientific or engineering fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are well qualified to manage the civilian research and development programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary for Science shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdefbfbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the Science and Technology Advisor to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the research and development programs of the Department in order to advise the Secretary with respect to any undesirable duplication or gaps in the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to the well-being and management of the multipurpose laboratories under the jurisdiction of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to education and training activities required for effective short- and long-term basic and applied research activities of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to grants and other forms of financial assistance required for effective short- and long-term basic and applied research activities of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary with respect to long-term planning, coordination, and development of a strategic framework for Department research and development activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such additional duties assigned to the Under Secretary by the Secretary relating to basic and applied research, including supervision or support of research activities carried out by any of the Assistant Secretaries designated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7133"},"text":"section 7133 of this title","children":[],"tail":", as the Secretary considers advantageous."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdefbfc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary for Nuclear Security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdefbfc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department an Under Secretary for Nuclear Security, who shall be appointed by the President, by and with the advice and consent of the Senate. The Under Secretary shall be compensated at the rate provided for at level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary for Nuclear Security shall be appointed from among persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdefbfc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have extensive background in national security, organizational management, and appropriate technical fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdefbfc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are well qualified to manage the nuclear weapons, nonproliferation, and materials disposition programs of the National Nuclear Security Administration in a manner that advances and protects the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Nuclear Security shall serve as the Administrator for Nuclear Security under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2402"},"text":"section 2402 of title 50","children":[],"tail":". In carrying out the functions of the Administrator, the Under Secretary shall be subject to the authority, direction, and control of the Secretary. Such authority, direction, and control may be delegated only to the Deputy Secretary of Energy, without redelegation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdefbfc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdefbfc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department an Under Secretary, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall perform such functions and duties as the Secretary shall prescribe, consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary shall be compensated at the rate provided for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdefbfcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Counsel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdefbfcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Department a General Counsel, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall perform such functions and duties as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdefbfcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7132/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel shall be compensated at the rate provided for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdefbfce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s202"},"text":"Pub. L. 95–91, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/569"},"text":"91 Stat. 569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3202"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/954"},"text":"113 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1006/a"},"text":"Pub. L. 109–58, title X, § 1006(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/930"},"text":"119 Stat. 930","children":[],"tail":", 931.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdefbfcf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdefbfd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdefbfd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1006/a"},"text":"Pub. L. 109–58, § 1006(a)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “There shall be in the Department an Under Secretary and a General Counsel, who shall be appointed by the President, by and with the advice and consent of the Senate, and who shall perform such functions and duties as the Secretary shall prescribe. The Under Secretary shall bear primary responsibility for energy conservation. The Under Secretary shall be compensated at the rate provided for level III of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":", and the General Counsel shall be compensated at the rate provided for level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1006/c/1"},"text":"Pub. L. 109–58, § 1006(c)(1)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdefbfd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdefbfd3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Term of Office of Person First Appointed as Under Secretary for Nuclear Security of the Department of Energy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3151"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3151]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–464, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dC/tXXXI/s3151"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Length of Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of office as Under Secretary for Nuclear Security of the Department of Energy of the person first appointed to that position shall be three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Reasons for Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exclusive reasons for removal from office as Under Secretary for Nuclear Security of the person described in subsection (a) shall be inefficiency, neglect of duty, or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Position Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The position of Under Secretary for Nuclear Security of the Department of Energy referred to in this section is the position established by subsection (c) of section 202 of the Department of Energy Organization Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7132"},"text":"42 U.S.C. 7132","children":[],"tail":"), as added by section 3202 of the National Nuclear Security Administration Act (title XXXII of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Public Law 106–65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/113/954"},"text":"113 Stat. 954","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Substantially identical provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/377/s1/a/2/tIII/s313"},"text":"Pub. L. 106–377, § 1(a)(2) [title III, § 313]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–81."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
