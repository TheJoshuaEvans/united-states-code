":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Three-hour maximum","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"700  ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe32949d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The maximum allowable concentration of any air pollutant in any area to which this part applies shall not exceed a concentration for such pollutant for each period of exposure equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe32949e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concentration permitted under the national secondary ambient air quality standard, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe32949f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concentration permitted under the national primary ambient air quality standard,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever concentration is lowest for such pollutant for such period of exposure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3294a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders or rules for determining compliance with maximum allowable increases in ambient concentrations of air pollutants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3294a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any State which has a plan approved by the Administrator for purposes of carrying out this part, the Governor of such State may, after notice and opportunity for public hearing, issue orders or promulgate rules providing that for purposes of determining compliance with the maximum allowable increases in ambient concentrations of an air pollutant, the following concentrations of such pollutant shall not be taken into account:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3294a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concentrations of such pollutant attributable to the increase in emissions from stationary sources which have converted from the use of petroleum products, or natural gas, or both, by reason of an order which is in effect under the provisions of sections 792(a) and (b) of title 15 (or any subsequent legislation which supersedes such provisions) over the emissions from such sources before the effective date of such order.","children":[{"tag":"ref","attrib":{"idref":"fn003628"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003628"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3294a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the concentrations of such pollutant attributable to the increase in emissions from stationary sources which have converted from using natural gas by reason of a natural gas curtailment pursuant to a natural gas curtailment plan in effect pursuant to the Federal Power Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"16 U.S.C. 791a","children":[],"tail":" et seq.] over the emissions from such sources before the effective date of such plan,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3294a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concentrations of particulate matter attributable to the increase in emissions from construction or other temporary emission-related activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3294a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in concentrations attributable to new sources outside the United States over the concentrations attributable to existing sources which are included in the baseline concentration determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479/4"},"text":"section 7479(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3294a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action taken with respect to a source under paragraph (1)(A) or (1)(B) shall apply more than five years after the effective date of the order referred to in paragraph (1)(A) or the plan referred to in paragraph (1)(B), whichever is applicable. If both such order and plan are applicable, no such action shall apply more than five years after the later of such effective dates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3294a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7473/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No action under this subsection shall take effect unless the Governor submits the order or rule providing for such exclusion to the Administrator and the Administrator determines that such order or rule is in compliance with the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe3294a8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 163, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/a"},"text":"Pub. L. 95–95, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/732"},"text":"91 Stat. 732","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/190/s14/a/41"},"text":"Pub. L. 95–190, § 14(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-16"},"text":"Nov. 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1401"},"text":"91 Stat. 1401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe3294a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe3294aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe3294ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Power Act, referred to in subsec. (c)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-10/ch285"},"text":"act June 10, 1920, ch. 285","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1063"},"text":"41 Stat. 1063","children":[],"tail":", which is classified generally to chapter 12 (§ 791a et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s791a"},"text":"section 791a of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe3294ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/190"},"text":"Pub. L. 95–190","children":[],"tail":" inserted “section” before “7475”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
