{"tag":"section","attrib":{"id":"idbbe0dc51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2034"},"text":null,"children":[{"tag":"num","attrib":{"value":"2034"},"text":"§ 2034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Manager, Deputy and Assistant General Managers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is established within the Commission—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbe0dc52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Manager; chief executive officer; duties; appointment; removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"a General Manager, who shall be the chief executive officer of the Commission, and who shall discharge such of the administrative and executive functions of the Commission as the Commission may direct. The General Manager shall be appointed by the Commission, shall serve at the pleasure of the Commission and shall be removable by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe0dc53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy General Manager; duties; appointment; removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"a Deputy General Manager, who shall act in the stead of the General Manager during his absence when so directed by the General Manager, and who shall perform such other administrative and executive functions as the General Manager shall direct. The Deputy General Manager shall be appointed by the General Manager with the approval of the Commission, shall serve at the pleasure of the General Manager, and shall be removable by the General Manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe0dc54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant General Managers; duties; appointment; removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistant General Managers, or their equivalents (not to exceed a total of three positions), who shall perform such administrative and executive functions as the General Manager shall direct. They shall be appointed by the General Manager with the approval of the Commission, shall serve at the pleasure of the General Manager, and shall be removable by the General Manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbe0dc55-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 24, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/925"},"text":"68 Stat. 925","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/85/287/s2"},"text":"Pub. L. 85–287, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-04"},"text":"Sept. 4, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/612"},"text":"71 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tIII/s306/f/1"},"text":"Pub. L. 88–426, title III, § 306(f)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"19