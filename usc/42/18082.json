{"tag":"section","attrib":{"id":"idc04fcfdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082"},"text":null,"children":[{"tag":"num","attrib":{"value":"18082"},"text":"§ 18082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance determination and payment of premium tax credits and cost-sharing reductions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04fcfdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Treasury, shall establish a program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcfde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request of an Exchange, advance determinations are made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18081"},"text":"section 18081 of this title","children":[],"tail":" with respect to the income eligibility of individuals enrolling in a qualified health plan in the individual market through the Exchange for the premium tax credit allowable under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" and the cost-sharing reductions under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcfdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary notifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcfe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Exchange and the Secretary of the Treasury of the advance determinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcfe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Treasury of the name and employer identification number of each employer with respect to whom 1 or more employee ","children":[{"tag":"ref","attrib":{"idref":"fn004337"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004337"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “employees”."}],"tail":" of the employer were determined to be eligible for the premium tax credit under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" and the cost-sharing reductions under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of this title","children":[],"tail":" because—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc04fcfe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer did not provide minimum essential coverage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcfe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer provided such minimum essential coverage but it was determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B/c/2/C"},"text":"section 36B(c)(2)(C) of title 26","children":[],"tail":" to either be unaffordable to the employee or not provide the required minimum actuarial value; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcfe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury makes advance payments of such credit or reductions to the issuers of the qualified health plans in order to reduce the premiums payable by individuals eligible for such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcfe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcfe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide under the program established under subsection (a) that advance determination of eligibility with respect to any individual shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcfe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the annual open enrollment period applicable to the individual (or such other enrollment period as may be specified by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcfe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the individual’s household income for the most recent taxable year for which the Secretary, after consultation with the Secretary of the Treasury, determines information is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcfe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide procedures for making advance determinations on the basis of information other than that described in paragraph (1)(B) in cases where information included with an application form demonstrates substantial changes in income, changes in family size or other household circumstances, change in filing status, the filing of an application for unemployment benefits, or other significant changes affecting eligibility, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcfea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing an individual claiming a decrease of 20 percent or more in income, or filing an application for unemployment benefits, to have eligibility for the credit determined on the basis of household income for a later period or on the basis of the individual’s estimate of such income for the taxable year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcfeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of household income in cases where the taxpayer was not required to file a return of tax imposed by this chapter for the second preceding taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcfec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of premium tax credits and cost-sharing reductions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04fcfed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Secretary of the Treasury and the Exchange through which the individual is enrolling of the advance determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18081"},"text":"section 18081 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcfee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium tax credit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04fcfef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall make the advance payment under this section of any premium tax credit allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" to the issuer of a qualified health plan on a monthly basis (or such other periodic basis as the Secretary may provide)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04fcff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuer responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An issuer of a qualified health plan receiving an advance payment with respect to an individual enrolled in the plan shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04fcff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the premium charged the insured for any period by the amount of the advance payment for the period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Exchange and the Secretary of such reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include with each billing statement the amount by which the premium for the plan has been reduced by reason of the advance payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04fcff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any nonpayment of premiums by the insured—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04fcff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary of such nonpayment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04fcff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a 3-month grace period for nonpayment of premiums before discontinuing coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04fcff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also notify the Secretary of the Treasury and the Exchange under paragraph (1) if an advance payment of the cost-sharing reductions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of this title","children":[],"tail":" is to be made to the issuer of any qualified health plan with respect to any individual enrolled in the plan. The Secretary of the Treasury shall make such advance payment at such time and in such amount as the Secretary specifies in the notice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Federal payments for individuals not lawfully present","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subtitle or the amendments made by this subtitle allows Federal payments, credits, or cost-sharing reductions for individuals who are not lawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04fcff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18082/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subtitle or the amendments made by this subtitle shall be construed to prohibit a State from making payments to or on behalf of an individual for coverage under a qualified health plan offered through an Exchange that are in addition to any credits or cost-sharing reductions allowable to the individual under this subtitle and such amendments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04fcffa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1412"},"text":"Pub. L. 111–148, title I, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/231"},"text":"124 Stat. 231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s71301/c/2"},"text":"Pub. L. 119–21, title VII, § 71301(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/322"},"text":"139 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04fcffb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idc04fcffc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (d)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s71301/c/2"},"text":"Pub. L. 119–21, title VII, § 71301(c)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/322"},"text":"139 Stat. 322","children":[],"tail":", provided that, applicable with respect to plan years beginning on or after "},{"tag":"date","attrib":{"date":"2027-01-01"},"text":"Jan. 1, 2027","children":[],"tail":", subsection (d) of this section is amended by inserting before the period at the end “, or credits under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" for aliens who are not eligible aliens (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B/e/2"},"text":"section 36B(e)(2) of title 26","children":[],"tail":")”. See 2025 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04fcffd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc04fcffe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsecs. (d) and (e), is subtitle E (§§ 1401–1421) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which enacted this subchapter and sections 36B and 45R of Title 26, Internal Revenue Code, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s405"},"text":"section 405 of this title","children":[],"tail":", sections 38, 196, 280C, 6103, and 7213 of Title 26, and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1324"},"text":"section 1324 of Title 31","children":[],"tail":", Money and Finance, and enacted provisions set out as notes under sections 36B and 38 of Title 26. For complete classification of subtitle E to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc04fcfff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" inserted “, or credits under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" for aliens who are not eligible aliens (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B/e/2"},"text":"section 36B(e)(2) of title 26","children":[],"tail":")” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc04fd000-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc04fd001-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" applicable with respect to plan years beginning on or after "},{"tag":"date","attrib":{"date":"2027-01-01"},"text":"Jan. 1, 2027","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/s71301/c/3"},"text":"section 71301(c)(3) of Pub. L. 119–21","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18081"},"text":"section 18081 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
