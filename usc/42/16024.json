{"tag":"section","attrib":{"id":"idbfee2949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024"},"text":null,"children":[{"tag":"num","attrib":{"value":"16024"},"text":"§ 16024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear Regulatory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee294a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5842"},"text":"section 5842 of this title","children":[],"tail":", the Nuclear Regulatory Commission shall have licensing and regulatory authority for any reactor authorized under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee294b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary and the Chairman of the Nuclear Regulatory Commission shall jointly submit to the appropriate committees of the Senate and the House of Representatives a licensing strategy for the prototype nuclear reactor, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee294c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of ways in which current licensing requirements relating to light-water reactors need to be adapted for the types of prototype nuclear reactor being considered by the Project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee294d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of analytical tools that the Nuclear Regulatory Commission will have to develop to independently verify designs and performance characteristics of components, equipment, systems, or structures associated with the prototype nuclear reactor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee294e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research or development activities that may be required on the part of the Nuclear Regulatory Commission in order to review a license application for the prototype nuclear reactor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee294f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the budgetary requirements associated with the licensing strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ongoing interaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall seek the active participation of the Nuclear Regulatory Commission throughout the duration of the Project to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid design decisions that will compromise adequate safety margins in the design of the reactor or impair the accessibility of nuclear safety-related components of the prototype reactor for inspection and maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop tools to facilitate inspection and maintenance needed for safety purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16024/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop risk-based criteria for any future commercial development of a similar reactor architectures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2954-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s644"},"text":"Pub. L. 109–58, title VI, § 644","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/797"},"text":"119 Stat. 797","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
