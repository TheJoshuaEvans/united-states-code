{"tag":"section","attrib":{"id":"idbed983c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674"},"text":null,"children":[{"tag":"num","attrib":{"value":"9674"},"text":"§ 9674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed983c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section, a purchasing group is exempt from the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which prohibits the establishment of a purchasing group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which makes it unlawful for an insurer to provide or offer to provide insurance on a basis providing, to a purchasing group or its member, advantages, based on their loss and expense experience, not afforded to other persons with respect to rates, policy forms, coverages, or other matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which prohibits a purchasing group or its members from purchasing insurance on the group basis described in paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which prohibits a purchasing group from obtaining insurance on a group basis because the group has not been in existence for a minimum period of time or because any member has not belonged to the group for a minimum period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which requires that a purchasing group must have a minimum number of members, common ownership or affiliation, or a certain legal form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which requires that a certain percentage of a purchasing group must obtain insurance on a group basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which requires that any insurance policy issued to a purchasing group or any members of the group be countersigned by an insurance agent or broker residing in that State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State law, rule, or order which otherwise discriminate ","children":[{"tag":"ref","attrib":{"idref":"fn003881"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003881"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “discriminates”."}],"tail":" against a purchasing group or any of its members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions specified in subsection (a) apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pollution liability insurance, and comprehensive general liability insurance which includes this coverage, provided to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed983cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a purchasing group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is a member of a purchasing group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sale of any one of the following to a purchasing group or a member of the group:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed983d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pollution liability insurance and comprehensive general liability coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Insurance related services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed983d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Management services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9674/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agents or brokers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may require that a person acting, or offering to act, as an agent or broker for a purchasing group obtain a license from that State, except that a State may not impose any qualification or requirement which discriminates against a nonresident agent or broker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIV/s404"},"text":"Pub. L. 96–510, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/a"},"text":"Pub. L. 99–499, title II, § 210(a)","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1718"},"text":"100 Stat. 1718","children":[],"tail":"; renumbered § 210(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
