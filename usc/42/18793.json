{"tag":"section","attrib":{"id":"idc06a0f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793"},"text":null,"children":[{"tag":"num","attrib":{"value":"18793"},"text":"§ 18793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy auditor training grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered certification” means any of the following certifications:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American Society of Heating, Refrigerating and Air-Conditioning Engineers Building Energy Assessment Professional certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Association of Energy Engineers Certified Energy Auditor certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Building Performance Institute Home Energy Professional Energy Auditor certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Residential Energy Services Network Home Energy Rater certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other third-party certification recognized by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any third-party certification that the Secretary determines is equivalent to the certifications described in subparagraphs (A) through (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible State” means a State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a demonstrated need for assistance for training energy auditors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any additional criteria determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the State Energy Program, the Secretary shall establish a competitive grant program under which the Secretary shall award grants to eligible States to train individuals to conduct energy audits or surveys of commercial and residential buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0faa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State seeking a grant under subsection (b) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including the energy auditor training program plan described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy auditor training program plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An energy auditor training program plan submitted with an application under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0fad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed training curriculum for energy audit trainees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the covered certification that those trainees will receive on completion of that training curriculum;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0faf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected per-individual cost of training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for connecting trainees with employment opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant awarded to an eligible State under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined by the Secretary, taking into account the population of the eligible State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed $2,000,000 for any eligible State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible State that receives a grant under subsection (b) shall use the grant funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to cover any cost associated with individuals being trained or certified to conduct energy audits by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a0fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a0fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State-certified third party training program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), to pay the wages of a trainee during the period in which the trainee receives training and certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of grant funds provided under subsection (b) to an eligible State may be used for the purpose described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18793/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $40,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0fbe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40503"},"text":"Pub. L. 117–58, div. D, title V, § 40503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1056"},"text":"135 Stat. 1056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0fbf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a0fc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06a0fc1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
