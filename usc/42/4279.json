{"tag":"section","attrib":{"id":"idbcbc2282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4279"},"text":null,"children":[{"tag":"num","attrib":{"value":"4279"},"text":"§ 4279.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of funds; consideration by Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to receive funds through grants, contracts, and contributions from State and local governments and organizations thereof, and from nonprofit organizations. Such funds may be received and expended by the Commission only for purposes of this chapter. In making appropriations to the Commission the Congress shall consider the amount of any funds received by the Commission in addition to those funds appropriated to it by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcbc2283-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/380/s9"},"text":"Pub. L. 86–380, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/733/s6"},"text":"Pub. L. 89–733, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1162"},"text":"80 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcbc2284-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcbc2285-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcbc2286-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{