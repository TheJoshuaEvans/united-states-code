under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6262"},"text":"Section 6262 of this title","children":[],"tail":", referred to in subsec. (e)(2)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s104/1"},"text":"Pub. L. 106–469, title I, § 104(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2033"},"text":"114 Stat. 2033","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
