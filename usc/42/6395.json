{"tag":"section","attrib":{"id":"idbda37471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395"},"text":null,"children":[{"tag":"num","attrib":{"value":"6395"},"text":"§ 6395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda37472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":" shall be subject to a civil penalty of not more than $5,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda37473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for willful violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever willfully violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":" shall be fined not more than $10,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda37474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violation after having been subjected to civil penalty for prior violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly and willfully violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":" with respect to the sale, offer of sale, or distribution in commerce of a product or commodity after having been subjected to a civil penalty for a prior violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":" with respect to the sale, offer of sale, or distribution in commerce of such product or commodity shall be fined not more than $50,000 or imprisoned not more than 6 months, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda37475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction action by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it appears to any officer or agency of the United States in whom is vested, or to whom is delegated, authority under this chapter that any person has engaged, is engaged, or is about to engage in acts or practices constituting a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":", such officer or agency may request the Attorney General to bring an action in an appropriate district court of the United States to enjoin such acts or practices, and upon a proper showing a temporary restraining order or a preliminary or permanent injunction shall be granted without bond. Any such court may also issue mandatory injunctions commanding any person to comply with any rule, regulation, or order described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6394"},"text":"section 6394 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda5e576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private right of action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda5e577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person suffering legal wrong because of any act or practice arising out of any violation of any provision of this chapter described in paragraph (2), may bring an action in an appropriate district court of the United States without regard to the amount in controversy, for appropriate relief, including an action for a declaratory judgment or writ of injunction. Nothing in this subsection shall authorize any person to recover damages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda5e578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of this chapter referred to in paragraph (1) are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda5e579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 6262 ","children":[{"tag":"ref","attrib":{"idref":"fn003488"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003488"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (relating to energy conservation plans)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda5e57a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6271"},"text":"Section 6271 of this title","children":[],"tail":" (relating to international oil allocation)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda5e57b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6272"},"text":"Section 6272 of this title","children":[],"tail":" (relating to international voluntary agreements)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda5e57c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6273"},"text":"Section 6273 of this title","children":[],"tail":" (relating to advisory committees)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda5e57d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6395/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6274"},"text":"Section 6274 of this title","children":[],"tail":" (relating to international exchange of information)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda5e57e-3a70-11f1-ae07-e4213316b5fa","identifi