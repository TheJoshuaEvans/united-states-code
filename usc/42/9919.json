{"tag":"section","attrib":{"id":"idbf091f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919"},"text":null,"children":[{"tag":"num","attrib":{"value":"9919"},"text":"§ 9919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug and child support services and referrals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug testing and rehabilitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to prohibit a State from testing participants in programs, activities, or services carried out or provided under this chapter for controlled substances. A State that conducts such testing shall inform the participants who test positive for any of such substances about the availability of treatment or rehabilitation services and refer such participants for appropriate treatment or rehabilitation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds provided under this chapter expended for such testing shall be considered to be expended for administrative expenses and shall be subject to the limitation specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9907/b/2"},"text":"section 9907(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “controlled substance” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child support services and referrals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each fiscal year for which an eligible entity receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9907"},"text":"section 9907 of this title","children":[],"tail":", such entity shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform custodial parents in single-parent families that participate in programs, activities, or services carried out or provided under this chapter about the availability of child support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9919/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer eligible parents to the child support offices of State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091f11-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s678G"},"text":"Pub. L. 97–35, title VI, § 678G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2749"},"text":"112 Stat. 2749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
