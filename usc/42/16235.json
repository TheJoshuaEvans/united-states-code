{"tag":"section","attrib":{"id":"idbffa0f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235"},"text":null,"children":[{"tag":"num","attrib":{"value":"16235"},"text":"§ 16235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy in public buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and technology transfer program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for the demonstration of innovative technologies for solar and other renewable energy sources in buildings owned or operated by a State or local government, and for the dissemination of information resulting from such demonstration to interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on Federal funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":", the Secretary shall provide under this section no more than 40 percent of the incremental costs of the solar or other renewable energy source project funded."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the application for awards under this section, the Secretary shall require all applicants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate a continuing commitment to the use of solar and other renewable energy sources in buildings they own or operate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to state how they expect any award to further their transition to the significant use of renewable energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f6d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s935"},"text":"Pub. L. 109–58, title IX, § 935","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/873"},"text":"119 Stat. 873","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
