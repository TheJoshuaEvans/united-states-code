{"tag":"section","attrib":{"id":"idbf0b8ff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006"},"text":null,"children":[{"tag":"num","attrib":{"value":"10006"},"text":"§ 10006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf0b8ff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take all actions consistent with law to effectuate the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8ff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation or certification program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may utilize an accreditation or certification program administered by a private entity if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8ff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State delegates the administration of the State accreditation or certification program to such private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8ff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program is approved by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8ff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program is consistent with the minimum Federal standards promulgated under this chapter for such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance; proposed legislative changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Absent compliance by the States with the provisions of this chapter within three years after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", the Secretary shall report to the Congress recommendations for legislative changes considered necessary to assure the States’ compliance with this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8ff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1061/b"},"text":"Pub. L. 104–66, title I, § 1061(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/719"},"text":"109 Stat. 719","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing standards and guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, in the case of a State which has, prior to the effective date of standards and guidelines promulgated pursuant to this chapter, established standards for the accreditation of educational programs and certification of radiologic technologists, such State shall be deemed to be in compliance with the conditions of this section unless the Secretary determines, after notice and hearing, that such State standards do not meet the minimum standards prescribed by the Secretary or are inconsistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8ffa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s981"},"text":"Pub. L. 97–35, title IX, § 981","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/600"},"text":"95 Stat. 600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1061/b"},"text":"Pub. L. 104–66, title I, § 1061(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/719"},"text":"109 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b8ffb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf0b8ffc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf0b8ffd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (d) which read as follows: “The Secretary shall be responsible for continued monitoring of compliance by the States with the applicable provisions of this chapter and shall report to the Senate and the House of Representatives by "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":", and January 1 of each succeeding year the status of the States’ compliance with the purposes of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
