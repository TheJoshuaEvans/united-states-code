{"tag":"section","attrib":{"id":"idb57f9029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286"},"text":null,"children":[{"tag":"num","attrib":{"value":"286"},"text":"§ 286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Library of Medicine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57f902a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist the advancement of medical and related sciences and to aid the dissemination and exchange of scientific and other information important to the progress of medicine and to the public health, there is established the National Library of Medicine (hereafter in this part referred to as the “Library”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f902b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, through the Library and subject to subsection (d), shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57f902c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and preserve books, periodicals, prints, films, recordings, and other library materials pertinent to medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f902d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organize the materials specified in paragraph (1) by appropriate cataloging, indexing, and bibliographical listings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f902e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and disseminate the catalogs, indexes, and bibliographies referred to in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f902f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available, through loans, photographic or other copying procedures, or otherwise, such materials in the Library as the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reference and research assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicize the availability from the Library of the products and services described in any of paragraphs (1) through (5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of computers and telecommunications by health professionals (including health professionals in rural areas) for the purpose of improving access to biomedical information for health care delivery and medical research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in such other activities as the Secretary determines appropriate and as the Library’s resources permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f9034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange, destruction, or disposal of materials not needed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exchange, destroy, or otherwise dispose of any books, periodicals, films, and other library materials not needed for the permanent use of the Library.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f9035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of publications, materials, facilities, or services; prescription of rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57f9036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may, after obtaining the advice and recommendations of the Board of Regents, prescribe rules under which the Library will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57f9037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide copies of its publications or materials,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57f9038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will make available its facilities for research, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57f9039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will make available its bibliographic, reference, or other services,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to public and private entities and individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f903a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Rules prescribed under paragraph (1) may provide for making available such publications, materials, facilities, or services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57f903b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without charge as a public service,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57f903c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a loan, exchange, or charge basis, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57f903d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in appropriate circumstances, under contract arrangements made with a public or other nonprofit entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f903e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional medical libraries; establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary, with the advice of the Board of Regents, determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57f903f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any geographic area of the United States there is no regional medical library adequate to serve such area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under criteria prescribed for the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s286b–6"},"text":"section 286b–6 of this title","children":[],"tail":", there is a need for a regional medical library to serve such area; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57f9041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because there is no medical library located in such area which, with financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s286b–6"},"text":"section 286b–6 of this title","children":[],"tail":", can feasibly be developed into a regional medical library adequate to serve such area,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary may establish, as a branch of the Library, a regional medical library to serve the needs of such area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f9042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and administration of gifts; memorials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"Section 238 of this title","children":[],"tail":" shall be applicable to the acceptance and administration of gifts made for the benefit of the Library or for carrying out any of its functions, and the Board of Regents shall make recommendations to the Secretary relating to establishment within the Library of suitable memorials to the donors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57f9043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Medicine” and “medical” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the terms “medicine” and “medical”, except when used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s286a"},"text":"section 286a of this title","children":[],"tail":", include preventive and therapeutic medicine, dentistry, pharmacy, hospitalization, nursing, public health, and the fundamental sciences related thereto, and other related fields of study, research, or ac­tivity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57f9044-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 465, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/857"},"text":"99 Stat. 857","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/b/1"},"text":"Pub. L. 99–660, title III, § 311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3779"},"text":"100 Stat. 3779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/h/tII/s215"},"text":"Pub. L. 100–202, § 101(h) [title II, § 215]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-256"},"text":"101 Stat. 1329–256","children":[],"tail":", 1329–275; "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s204/2"},"text":"Pub. L. 100–607, title II, § 204(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3079"},"text":"102 Stat. 3079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2620/b/1"},"text":"Pub. L. 100–690, title II, § 2620(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4244"},"text":"102 Stat. 4244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tI/s102/2"},"text":"Pub. L. 101–381, title I, § 102(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/585"},"text":"104 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1401/a"},"text":"Pub. L. 103–43, title XIV, § 1401(a)","children":[],"tail":", (c)(1), title XX, § 2010(b)(3), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/170"},"text":"107 Stat. 170","children":[],"tail":", 214.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57f9045-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57f9046-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57f9047-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1401/c/1"},"text":"Pub. L. 103–43, § 1401(c)(1)","children":[],"tail":", repealed amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":". See 1987 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1401/a"},"text":"Pub. L. 103–43, § 1401(a)","children":[],"tail":", added pars. (6) and (7) and redesignated former par. (6) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2010/b/3"},"text":"Pub. L. 103–43, § 2010(b)(3)","children":[],"tail":", substituted “Section 238” for “Section 300aaa”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/381"},"text":"Pub. L. 101–381","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa"},"text":"section 300aaa of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa"},"text":"section 300aaa of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" substituted “300aaa” for “300cc”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":", which directed the amendment of “Section 465(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s286"},"text":"42 U.S.C. 286","children":[],"tail":"” by inserting “between (5) and (6) an additional charge to the Secretary to ‘publicize the availability of the above products and services of the National Library of Medicine’ ”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1401/c/1"},"text":"Pub. L. 103–43, § 1401(c)(1)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc"},"text":"section 300cc of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa"},"text":"section 300aa of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57f9048-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb57f9049-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb57f904a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s323"},"text":"section 323 of Pub. L. 99–660","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"section 300aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb57f904b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Certain New Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1401/c/2"},"text":"Pub. L. 103–43, title XIV, § 1401(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/170"},"text":"107 Stat. 170","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/tXIV/s1401/c/2"},"text":"“With respect to the authority established for the National Library of Medicine in section 465(b)(6) of the Public Health Service Act, as added by subsection (a) of this section [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s286/b/6"},"text":"42 U.S.C. 286(b)(6)","children":[],"tail":"], such authority shall be effective as if the authority had been established on "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
