{"tag":"section","attrib":{"id":"idbfa1b578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12803"},"text":null,"children":[{"tag":"num","attrib":{"value":"12803"},"text":"§ 12803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program to support the rehabilitation of privately owned rental housing located in neighborhoods where the median income does not exceed 80 percent of the area median as determined by the Secretary and where rents can reasonably be expected not to change materially over an extended period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b57a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of subsidy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the rehabilitation subsidy shall be moderate and shall generally not exceed 50 percent of the total costs associated with the rehabilitation of the housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b57b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines of the model program shall generally comport with the additional protections and restrictions specified under section 1437","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(c) "},{"tag":"ref","attrib":{"idref":"fn004113"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b57c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s253"},"text":"Pub. L. 101–625, title II, § 253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4121"},"text":"104 Stat. 4121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b57d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b57e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa1b57f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1437","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s289/b"},"text":"Pub. L. 101–625, title II, § 289(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4128"},"text":"104 Stat. 4128","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
