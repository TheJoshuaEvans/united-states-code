{"tag":"section","attrib":{"id":"idbc5f348f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032k"},"text":"§ 3032k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community innovations for aging in place","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5f3490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f3491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f3492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a nonprofit health or social service organization, a community-based nonprofit organization, an area agency on aging or other local government agency, a tribal organization, or another entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f3493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary determines to be appropriate to carry out a project under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f3494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates a record of, and experience in, providing or administering group and individual health and social services for older individuals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f3495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an entity providing housing under the congregate housing services program carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8011"},"text":"section 8011 of this title","children":[],"tail":" or the multifamily service coordinator program carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q/g"},"text":"section 1701q(g) of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naturally Occurring Retirement Community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Naturally Occurring Retirement Community” means a community with a concentrated population of older individuals, which may include a residential building, a housing complex, an area (including a rural area) of single family residences, or a neighborhood composed of age-integrated housing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f3497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" where—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f3498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of the heads of households are older individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f3499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a critical mass of older individuals exists, based on local factors that, taken in total, allow an organization to achieve efficiencies in the provision of health and social services to older individuals living in the community; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f349a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not an institutional care or assisted living setting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f349b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f349c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall make grants, on a competitive basis, to eligible entities to develop and carry out model aging in place projects. The projects shall promote aging in place for older individuals (including such individuals who reside in Naturally Occurring Retirement Communities), in order to sustain the independence of older individuals. A recipient of a grant under this subsection shall identify innovative strategies for providing, and linking older individuals to programs and services that provide, comprehensive and coordinated health and social services to sustain the quality of life of older individuals and support aging in place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f349d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall make the grants for periods of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f349e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f349f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (b) for a project, an entity shall submit an application to the Assistant Secretary at such time, in such manner, and containing such information as the Assistant Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f34a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the entity’s experience in providing services to older individuals in age-integrated settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a definition of the contiguous service area and a description of the project area in which the older individuals reside or carry out activities to sustain their well-being;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the results of a needs assessment that identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f34a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing (as of the date of the assessment) community-based health and social services available to individuals residing in the project area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strengths and gaps of such existing services in the project area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of older individuals who reside in the project area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services not being delivered that would promote aging in place and contribute to the well-being of older individuals residing in the project area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the development and implementation of an innovative model for service coordination and delivery within the project area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the plan described in subparagraph (D) will enhance existing services described in subparagraph (C)(i) and support the goal of this section to promote aging in place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of proposed actions by the entity to prevent the duplication of services funded under a provision of this chapter, other than this section, and a description of how the entity will cooperate, and coordinate planning and services (including any formal agreements), with agencies and organizations that provide publicly supported services for older individuals in the project area, including the State agency and area agencies on aging with planning and service areas in the project area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the entity will seek to establish cooperative relationships with interested local entities, including private agencies and businesses that provide health and social services, housing entities, community development organizations, philanthropic organizations, foundations, and other non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the entity’s protocol for referral of residents who may require long-term care services, including coordination with local agencies, including area agencies on aging and Aging and Disability Resource Centers that serve as single points of entry to public services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the entity will offer opportunities for older individuals to be involved in the governance, oversight, and operation of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the entity will submit to the Assistant Secretary such evaluations and reports as the Assistant Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for long-term sustainability of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f34b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f34b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under subsection (b) shall use the funds made available through the grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f34b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure access by older individuals in the project area to community-based health and social services consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f34b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case management, case assistance, and social work services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care management and health care assistance, including disease prevention and health promotion services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education, socialization, and recreational activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f34b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteer opportunities for project participants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to older individuals within the project area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement innovative, comprehensive, and cost-effective approaches for the delivery and coordination of community-based health and social services, including those identified in subparagraph (A)(iv), which may include mental health services, for eligible older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving a grant under subsection (b) for a project shall coordinate activities with organizations providing services funded under subchapter III to support such services for or facilitate the delivery of such services to eligible older individuals served by the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out an aging in place project, an eligible entity shall, to the extent practicable, serve a community of low-income individuals and operate or locate the project and services in or in close proximity to a location where a large concentration of older individuals has aged in place and resided, such as a Naturally Occurring Retirement Community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to an eligible entity under subsection (b) shall be used to supplement, not supplant, any Federal, State, or other funds otherwise available to the entity to provide health and social services to eligible older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f34bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f34bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall (or shall make a grant, on a competitive basis, to an eligible nonprofit organization, to enable the organization to)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f34be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to recipients of grants under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other duties, as determined by the Assistant Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subsection, an organization shall be a nonprofit organization (including a partnership of nonprofit organizations), that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f34c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has experience and expertise in providing technical assistance to a range of entities serving older individuals and experience evaluating and reporting on programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f34c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated knowledge of and expertise in community-based health and social services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, an organization (including a partnership of nonprofit organizations) shall submit an application to the Assistant Secretary at such time, in such manner, and containing such information as the Assistant Secretary may require, including an assurance that the organization will submit to the Assistant Secretary such evaluations and reports as the Assistant Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f34c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall annually prepare and submit a report to Congress that shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f34c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings resulting from the evaluations of the model projects conducted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of recommended best practices regarding carrying out health and social service projects for older individuals aging in place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f34c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032k/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for legislative or administrative action, as the Assistant Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5f34c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s422"},"text":"Pub. L. 89–73, title IV, § 422","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s409"},"text":"Pub. L. 109–365, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2559"},"text":"120 Stat. 2559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5f34c9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5f34ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc5f34cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s422"},"text":"section 422 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s422"},"text":"section 422 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035c"},"text":"section 3035c of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/115"},"text":"Pub. L. 97–115","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
