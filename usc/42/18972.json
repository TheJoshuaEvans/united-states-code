{"tag":"section","attrib":{"id":"idc073aba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972"},"text":null,"children":[{"tag":"num","attrib":{"value":"18972"},"text":"§ 18972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting domestic production of technologies developed under Manufacturing USA Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc073abaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Commerce policies to promote domestic production of technologies developed under Manufacturing USA Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073abab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency head (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278s/a"},"text":"section 278s(a) of title 15","children":[],"tail":") and the Secretary of Defense shall, in consultation with the Secretary of Commerce, establish policies to promote the domestic production of technologies developed by the Manufacturing USA Network."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policies established under subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc073abae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to partner domestic developers of goods, services, or technologies by Manufacturing USA Network activities with domestic manufacturers and sources of financing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to develop and provide incentives to promote transfer of intellectual property and goods, services, or technologies developed by Manufacturing USA Network activities to domestic manufacturers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to assist with supplier scouting and other supply chain development, including the use of the Hollings Manufacturing Extension Partnership under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of title 15","children":[],"tail":" to carry out such measures."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process to review and approve or deny membership in a Manufacturing USA institute by foreign-owned entities, especially from countries of concern, including the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc073abb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to prioritize Federal procurement of goods, services, or technologies developed by the Manufacturing USA Network activities from domestic sources, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processes for waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The policies established under this paragraph shall include processes to permit waivers, on a case by case basis, for policies that promote domestic production based on cost, availability, severity of technical and mission requirements, emergency requirements, operational needs, other legal or international treaty obligations, or other factors determined important to the success of the Manufacturing USA Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073abb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073abb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A company of the People’s Republic of China may not participate in the Manufacturing USA Program without a waiver, as described in paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073abb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Company defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “company” has the meaning given such term in section 847(a) of the National Defense Authorization Act for Fiscal Year 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4819"},"text":"10 U.S.C. 4819","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc073abb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (d) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc073abb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18972/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice from the United States Manufacturing Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek advice from the United States Manufacturing Council of the International Trade Administration of the Department of Commerce on matters concerning investment in and support of the manufacturing workforce within the Manufacturing USA Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc073abb9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10263"},"text":"Pub. L. 117–167, div. B, title II, § 10263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1504"},"text":"136 Stat. 1504","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc073abba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc073abbb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc073abbc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10263"},"text":"section 10263 of div. B of Pub. L. 117–167","children":[],"tail":". Subsecs. (b) to (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10263"},"text":"section 10263 of div. B of Pub. L. 117–167","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278s"},"text":"section 278s of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
