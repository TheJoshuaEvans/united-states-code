{"tag":"section","attrib":{"id":"idbafbd416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437h"},"text":"§ 1437h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of provisions by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbafbd417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and submission of annual budget program; maintenance of accounts; audit by Government Accountability Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the performance of, and with respect to, the functions, powers, and duties vested in him by this chapter, the Secretary, notwithstanding the provisions of any other law, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbafbd418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare annually and submit a budget program as provided for wholly owned Government corporations by chapter 91 of title 31; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafbd419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an integral set of accounts which may be audited by the Government Accountability Office as provided by chapter 91 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbafbd41a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of receipts and assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All receipts and assets of the Secretary under this chapter shall be available for the purposes of this chapter until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbafbd41b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks to act as depositories, custodians and fiscal agents; reimbursement for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Reserve banks are authorized and directed to act as depositories, custodians, and fiscal agents for the Secretary in the general exercise of his powers under this chapter, and the Secretary may reimburse any such bank for its services in such manner as may be agreed upon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbafbd41c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/666"},"text":"88 Stat. 666","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s203/b/2"},"text":"Pub. L. 98–479, title II, § 203(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2229"},"text":"98 Stat. 2229","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/100/358/s5"},"text":"Pub. L. 100–358, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-29"},"text":"June 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/681"},"text":"102 Stat. 681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s122/k"},"text":"Pub. L. 104–316, title I, § 122(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3837"},"text":"110 Stat. 3837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbafbd41d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbafbd41e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbafbd41f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/891"},"text":"50 Stat. 891","children":[],"tail":", as amended, authorized annual contributions in assistance of low rentals for housing projects and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1410"},"text":"section 1410 of this title","children":[],"tail":", prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":". Similar provisions are contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437c"},"text":"section 1437c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbafbd420-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “maintain an integral set of accounts which may be audited by the General Accounting Office as provided by chapter 91 of title 31.” for “maintain an integral set of accounts which shall be audited annually by the General Accounting Office in accordance with the principles and procedures applicable to commercial transactions as provided by chapter 91 of title 31, and no other audit shall be required.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479"},"text":"Pub. L. 98–479","children":[],"tail":" substituted “chapter 91 of title 31” for “the Government Corporations Control Act, as amended”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
