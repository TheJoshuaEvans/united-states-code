d to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdfba6e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Small Business Contracting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/13/dA/tVI/s6022/a"},"text":"Pub. L. 109–13, div. A, title VI, § 6022(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-05-11"},"text":"May 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/285"},"text":"119 Stat. 285","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/13/dA/tVI/s6022/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":", the Department of Energy and the Small Business Administration shall enter into a memorandum of understanding setting forth an appropriate methodology for measuring the achievement of the Department of Energy with respect to awarding contracts to small businesses."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The methodology set forth in the memorandum of understanding entered into under subsection (a) shall, at a minimum, include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a method of counting the achievement of the Department of Energy in awards of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prime contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subcontracts to small businesses awarded by Department of Energy management and operating, management and integration, and other facility management prime contractors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform criteria that could be used by prime contractors when measuring the value and number of subcontracts awarded to small businesses.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdfba6e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program Relating to Use of Proceeds of Disposal or Utilization of Certain Department of Energy Assets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXI/s3138"},"text":"Pub. L. 105–85, div. C, title XXXI, § 3138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2039"},"text":"111 Stat. 2039","children":[],"tail":", which was formerly set out as a note under this section, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4833"},"text":"section 4833 of Pub. L. 107–314","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXI/s3141/k/13/A"},"text":"Pub. L. 108–136, div. C, title XXXI, § 3141(k)(13)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1786"},"text":"117 Stat. 1786","children":[],"tail":", and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2813"},"text":"section 2813 of Title 50","children":[],"tail":", War and National Defense, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6354"},"text":"section 6354 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1454"},"text":"139 Stat. 1454","children":[],"tail":", 1458."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdfba6e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contract Goal for Small Disadvantaged Businesses and Certain Institutions of Higher Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dC/tXXXI/s3159"},"text":"Pub. L. 103–160, div. C, title XXXI, § 3159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1956"},"text":"107 Stat. 1956","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/b/16"},"text":"Pub. L. 103–337, div. A, title X, § 1070(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2857"},"text":"108 Stat. 2857","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tX/s1070/b/16"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), a goal of 5 percent of the amount described in subsection (b) shall be the objective of the Department of Energy in carrying out national security programs of the Department in each of fiscal years 1994 through 2000 for the total combined amount obligated for contracts and subcontracts entered into with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns, including mass media and advertising firms, owned and controlled by socially and economically disadvantaged individuals (as such term is used in section 8(d) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":") and regulations issued under that section), the majority of the earnings of which directly accrue to such individuals;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically Black colleges and universities, including any nonprofit research institution that was an integral part of such a college or university before ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority institutions (as defined in section 1046(3) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1135d"},"text":"20 U.S.C. 1135d","children":[],"tail":"-5(3))), which, for the purposes of this section, shall include Hispanic-serving institutions (as defined in section 316(b)(1) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b/1"},"text":"20 U.S.C. 1059c(b)(1)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the requirements of subsection (a) for any fiscal year apply to the combined total of the funds obligated for contracts entered into by the Department of Energy pursuant to competitive procedures for such fiscal year for purposes of carrying out national security programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In computing the combined total of funds under paragraph (1) for a fiscal year, funds obligated for such fiscal year for contracts for naval reactor programs shall not be included.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent to which the Secretary of Energy determines that compelling national security considerations require otherwise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary notifies the Congress of such a determination and the reasons for the determination.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdfba6e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Small Business Concerns Participation in Programs Funded by Department of Energy Act of 1978—Civilian Applications; Report to Congressional Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/238/tII/s204"},"text":"Pub. L. 95–238, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-25"},"text":"Feb. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/59"},"text":"92 Stat. 59","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s203/f"},"text":"Pub. L. 96–470, title II, § 203(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2243"},"text":"94 Stat. 2243","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/470/tII/s203/f"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the programs for which funds are authorized by this Act [see Tables for classification], the Secretary of Energy shall provide a realistic and adequate opportunity for small business concerns to participate in such programs to the optimum extent feasible consistent with the size and nature of the projects and activities involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall submit annually to the appropriate committees of the House of Representatives and the Senate a full report on the actions taken in carrying out subsection (a) during the preceding year, including the extent to which small business concerns are participating in the programs involved and in projects and activities of various types and sizes within each such program, and indicating the steps currently taken to assure such participation in the future. Such report shall also contain such information as may be required by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1975-12-31/s308"},"text":"section 308 of the Act of December 31, 1975","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5878a"},"text":"42 U.S.C. 5878a","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/89/1074"},"text":"89 Stat. 1074","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in "},{"tag":"ref","attrib":{"href":"/us/pl/95/238/s204/b"},"text":"section 204(b) of Pub. L. 95–238","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 21st item on page 89 of House Document No. 103–7.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
