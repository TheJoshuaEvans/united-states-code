{"tag":"section","attrib":{"id":"idb66e0eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–34"},"text":"§ 300x–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “authorized activities”, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–31"},"text":"section 300x–31 of this title","children":[],"tail":", means the activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21/b"},"text":"section 300x–21(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “funding agreement”, with respect to a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" to a State, means that the Secretary may make such a grant only if the State makes the agreement involved."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “prevention activities”, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–31"},"text":"section 300x–31 of this title","children":[],"tail":", means activities to prevent substance use disorders."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “substance use disorder” means the recurrent use of alcohol or other drugs that causes clinically significant impairment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “treatment activities” means treatment services and, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–31"},"text":"section 300x–31 of this title","children":[],"tail":", authorized activities that are related to treatment services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “treatment facility” means an entity that provides treatment services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–34/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “treatment services”, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–31"},"text":"section 300x–31 of this title","children":[],"tail":", means treatment for substance use disorders."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0eb8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1934, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/402"},"text":"106 Stat. 402","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/j"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1232"},"text":"130 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/a/9"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5678"},"text":"136 Stat. 5678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66e0eb9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66e0eba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66e0ebb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1934 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–24"},"text":"section 300y–24 of this title","children":[],"tail":" and subsequently omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66e0ebc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “The term ‘substance abuse’ means the abuse of alcohol or other drugs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Pars. (3), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “substance use disorders” for “substance abuse”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
