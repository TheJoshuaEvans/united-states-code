{"tag":"section","attrib":{"id":"idbbd73f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2015b"},"text":"§ 2015b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship and fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbd73f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enable students to study, for at least 1 academic semester or equivalent term, science, engineering, or another field of study that the Commission determines is in a critical skill area related to the regulatory mission of the Commission, the Commission may carry out a program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd73f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" award scholarships to undergraduate students who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd73f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are United States citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd73f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement under subsection (c) to be employed by the Commission in the area of study for which the scholarship is awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd73f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enable students to pursue education in science, engineering, or another field of study that the Commission determines is in a critical skill area related to its regulatory mission, in a graduate or professional degree program offered by an institution of higher education in the United States, the Commission may carry out a program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd73f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" award fellowships to graduate students who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd73f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are United States citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd73f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement under subsection (c) to be employed by the Commission in the area of study for which the fellowship is awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd73f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd73f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a scholarship or fellowship under subsection (a) or (b), a recipient of the scholarship or fellowship shall enter into an agreement with the Commission under which, in return for the assistance, the recipient shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbd73f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain satisfactory academic progress in the studies of the recipient, as determined by criteria established by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd73fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree that failure to maintain satisfactory academic progress shall constitute grounds on which the Commission may terminate the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd73fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on completion of the academic course of study in connection with which the assistance was provided, and in accordance with criteria established by the Commission, engage in employment by the Commission for a period specified by the Commission, that shall be not less than 1 time and not more than 3 times the period for which the assistance was provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbd73fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the recipient fails to meet the requirements of subparagraph (A), (B), or (C), reimburse the United States Government for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbd73fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire amount of the assistance provided the recipient under the scholarship or fellowship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbd73fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest at a rate determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd73fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may establish criteria for the partial or total waiver or suspension of any obligation of service or payment incurred by a recipient of a scholarship or fellowship under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd73fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of scholarships or fellowships under this section shall be selected through a competitive process primarily on the basis of academic merit and such other criteria as the Commission may establish, with consideration given to financial need and the goal of promoting the participation of individuals identified in section 1885a or 1885b of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd73fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may appoint directly, with no further competition, public notice, or consideration of any other potential candidate, an individual who has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd73fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a scholarship or fellowship awarded by the Commission under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd73fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2015b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed the academic program for which the scholarship or fellowship was awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd73faa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 243, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s622/a"},"text":"Pub. L. 109–58, title VI, § 622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/782"},"text":"119 Stat. 782","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
