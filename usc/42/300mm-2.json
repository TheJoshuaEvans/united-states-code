{"tag":"section","attrib":{"id":"idb6de0f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–2"},"text":"§ 300mm–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The WTC Program Administrator shall institute a program that provides education and outreach on the existence and availability of services under the WTC Program. The outreach and education program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e07f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e07f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a public Web site with information about the WTC Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e07f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meetings with potentially eligible populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e07f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and dissemination of outreach materials informing people about the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e07f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of phone information services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e07f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be conducted in a manner intended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6e07f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reach all affected populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6e07f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–2/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include materials for culturally and linguistically diverse populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6e07f80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/347/tI/s101"},"text":"Pub. L. 111–347, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3629"},"text":"124 Stat. 3629","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
