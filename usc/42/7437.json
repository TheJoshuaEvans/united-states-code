{"tag":"section","attrib":{"id":"idbe30243f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437"},"text":null,"children":[{"tag":"num","attrib":{"value":"7437"},"text":"§ 7437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas air pollution plans and implementation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe302440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe302441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas air pollution planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any amounts in the Treasury not otherwise appropriated, $250,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":", to carry out subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas air pollution implementation grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any amounts in the Treasury not otherwise appropriated, $4,750,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to carry out subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under paragraph (2), the Administrator shall reserve 3 percent for administrative costs necessary to carry out this section, to provide technical assistance to eligible entities, to develop a plan that could be used as a model by grantees in developing a plan under subsection (b), and to model the effects of plans described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas air pollution planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make a grant to at least one eligible entity in each State for the costs of developing a plan for the reduction of greenhouse gas air pollution to be submitted with an application for a grant under subsection (c). Each such plan shall include programs, policies, measures, and projects that will achieve or facilitate the reduction of greenhouse gas air pollution. Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":", the Administrator shall publish a funding opportunity announcement for grants under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas air pollution reduction implementation grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe302446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall competitively award grants to eligible entities to implement plans developed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To apply for a grant under this subsection, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator shall require, which such application shall include information regarding the degree to which greenhouse gas air pollution is projected to be reduced in total and with respect to low-income and disadvantaged communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make funds available to a grantee under this subsection in such amounts, upon such a schedule, and subject to such conditions based on its performance in implementing its plan submitted under this section and in achieving projected greenhouse gas air pollution reduction, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe302449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe30244a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe30244b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30244c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air pollution control agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30244d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30244e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe30244f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of one or more entities listed in subparagraphs (A) through (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe302450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7437/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe302451-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 137, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60114"},"text":"Pub. L. 117–169, title VI, § 60114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2076"},"text":"136 Stat. 2076","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
