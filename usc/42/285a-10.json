{"tag":"section","attrib":{"id":"idb5679b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–10"},"text":"§ 285a–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, information, and education with respect to blood cancer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5679b78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joe Moakley Research Excellence Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5679b79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall expand, intensify, and coordinate programs for the conduct and support of research with respect to blood cancer, and particularly with respect to leukemia, lymphoma, and multiple myeloma.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5679b7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall carry out this subsection through the Director of the National Cancer Institute and in collaboration with any other agencies that the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5679b7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geraldine Ferraro Cancer Education Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5679b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall direct the appropriate agency within the Department of Health and Human Services, in collaboration with the Director of NIH, to establish and carry out a program to provide information and education for patients and the general public with respect to blood cancer, and particularly with respect to the treatment of leukemia, lymphoma, and multiple myeloma.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5679b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency determined by the Secretary under paragraph (1) shall carry out this subsection in collaboration with private health organizations that have national education and patient assistance programs on blood-related cancers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5679b7e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 417D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/172/s3"},"text":"Pub. L. 107–172, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/541"},"text":"116 Stat. 541","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/17"},"text":"Pub. L. 109–482, title I, § 103(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/180/tII/s204/a"},"text":"Pub. L. 115–180, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1390"},"text":"132 Stat. 1390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56a0b7f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56a0b80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56a0b81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180"},"text":"Pub. L. 115–180","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/172/s3"},"text":"Pub. L. 107–172, § 3","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/17/A"},"text":"Pub. L. 109–482, § 103(b)(17)(A)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “For the purpose of carrying out this subsection, there is authorized to be appropriated such sums as may be necessary for fiscal year 2002 and each subsequent fiscal year. Such authorizations of appropriations are in addition to other authorizations of appropriations that are available for such purpose.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/17/B"},"text":"Pub. L. 109–482, § 103(b)(17)(B)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “For the purpose of carrying out this subsection, there is authorized to be appropriated such sums as may be necessary for fiscal year 2002 and each subsequent fiscal year. Such authorizations of appropriations are in addition to other authorizations of appropriations that are available for such purpose.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb56a0b82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb56a0b83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/tII/s204/b"},"text":"Pub. L. 115–180, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1390"},"text":"132 Stat. 1390","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/180/tII/s204/b"},"text":"“The amendment made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/172/s3"},"text":"section 3 of Pub. L. 107–172","children":[],"tail":"] shall take effect as if included in section 3 of the Hematological Cancer Research Investment and Education Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/pl/107/172"},"text":"Public Law 107–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/116/541"},"text":"116 Stat. 541","children":[],"tail":") [enacting this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb56a0b84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb56a0b85-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/172/s2"},"text":"Pub. L. 107–172, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-14"},"text":"May 14, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/541"},"text":"116 Stat. 541","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/172/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimated 109,500 people in the United States will be diagnosed with leukemia, lymphoma, and multiple myeloma in 2001.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New cases of the blood cancers described in paragraph (1) account for 8.6 percent of new cancer cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those devastating blood cancers will cause the deaths of an estimated 60,300 persons in the United States in 2001. Every 9 minutes, a person in the United States dies from leukemia, lymphoma, or multiple myeloma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While less than 5 percent of Federal funds for cancer research are spent on those blood cancers, those blood cancers cause 11 percent of all cancer deaths in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased Federal support of research into leukemia, lymphoma, and multiple myeloma has resulted and will continue to result in significant advances in the treatment, and ultimately the cure, of those blood cancers as well as other cancers.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
