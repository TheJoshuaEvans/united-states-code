{"tag":"section","attrib":{"id":"idbb377d8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1589b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1589b"},"text":"§ 1589b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of income limitations for occupancy of housing; effect on prior tenants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development notwithstanding any other provisions of subchapters II to VII of this chapter or any other law except provisions hereafter enacted expressly in amendment hereof, is authorized to establish income limitations for occupancy of any housing held by him under subchapters II to VII of this chapter and, giving consideration to the ability of such tenants to obtain other housing accommodations, to require tenants, admitted to occupancy prior to the establishment of such income limitations and who have incomes in excess of limitations established by him, to vacate such housing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb377d8b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title VI, § 612, as added "},{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title VI, § 603(d), "},{"tag":"ref","attrib":{"href":"/us/stat/65/314"},"text":"65 Stat. 314","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb377d8c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb377d8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb377d8e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters III and VI of this chapter, referred to in text, were comprised of sections 1531 to 1536 and 1571 to 1576, respectively, of this title and have been omitted from the Code. For further details, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb377d8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb377d90-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
