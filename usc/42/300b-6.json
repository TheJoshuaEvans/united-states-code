{"tag":"section","attrib":{"id":"idb60eb053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–6"},"text":"§ 300b–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied technology","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through an identifiable administrative unit, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60eb054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–6/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct epidemiological assessments and surveillance of genetic diseases to define the scope and extent of such diseases and the need for programs for the diagnosis, treatment, and control of such diseases, screening for such diseases, and the counseling of persons with such diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–6/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the assessments and surveillance described in paragraph (1), develop for use by the States programs which combine in an effective manner diagnosis, treatment, and control of such diseases, screening for such diseases, and counseling of persons with such diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–6/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the basis of the assessments and surveillance described in paragraph (1), provide technical assistance to States to implement the programs developed under paragraph (2) and train appropriate personnel for such programs.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In carrying out this section, the Secretary may, from funds allotted for use under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/a"},"text":"section 702(a) of this title","children":[],"tail":", make grants to or contracts with public or nonprofit private entities (including grants and contracts for demonstration projects)."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60eb057-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1107, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tII/s205/d/1"},"text":"Pub. L. 95–626, title II, § 205(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3584"},"text":"92 Stat. 3584","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2193/b/5"},"text":"Pub. L. 97–35, title XXI, § 2193(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/827"},"text":"95 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60eb058-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60eb059-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb60eb05a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted provisions relating to allotments under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/a"},"text":"section 702(a) of this title","children":[],"tail":" for provisions relating to appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300b/b"},"text":"section 300b(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb60eb05b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb60eb05c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment, Savings, and Transitional Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date, savings, and transitional provisions relating to amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2194"},"text":"section 2194 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"section 701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
