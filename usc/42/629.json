{"tag":"section","attrib":{"id":"idb79f14a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629"},"text":null,"children":[{"tag":"num","attrib":{"value":"629"},"text":"§ 629.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this program is to enable States to develop and establish, or expand, and to operate coordinated programs of community-based family support services, family preservation services, family reunification services, and adoption promotion and support services to accomplish the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f14a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To prevent child maltreatment among families at risk through the provision of supportive family services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assure children’s safety within the home and preserve intact families in which children have been maltreated, when the family’s problems can be addressed effectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To address the problems of families whose children have been placed in foster care so that reunification may occur in a safe and stable manner in accordance with the Adoption and Safe Families Act of 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f14a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support adoptive families by providing support services as necessary so that they can make a lifetime commitment to their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79f14a9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 430, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/a/2"},"text":"Pub. L. 103–66, title XIII, § 13711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/649"},"text":"107 Stat. 649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/89/tIII/s305/a/1"},"text":"Pub. L. 105–89, title III, § 305(a)(1)","children":[],"tail":", (2), (b)(3)(A), "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2130"},"text":"111 Stat. 2130","children":[],"tail":", 2131; "},{"tag":"ref","attrib":{"href":"/us/pl/107/133/tI/s101"},"text":"Pub. L. 107–133, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-17"},"text":"Jan. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2414"},"text":"115 Stat. 2414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/d"},"text":"Pub. L. 109–288, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1235"},"text":"120 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVII/s50721/b/1"},"text":"Pub. L. 115–123, div. E, title VII, § 50721(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/245"},"text":"132 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79f14aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79f14ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb79f14ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Adoption and Safe Families Act of 1997, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89"},"text":"Pub. L. 105–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2115"},"text":"111 Stat. 2115","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1997 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb79f14ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 430 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s630"},"text":"section 630 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tII/s202/a"},"text":"Pub. L. 100–485, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2377"},"text":"102 Stat. 2377","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79f14ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" struck out “time-limited” before “family reunification services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" substituted “Purpose” for “Findings and purpose” in section catchline, struck out subsec. (a) relating to findings, and struck out subsec. (b) designation and heading before “The purpose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133"},"text":"Pub. L. 107–133","children":[],"tail":" amended section generally, substituting subsecs. (a) and (b) relating to findings and purpose for former subsecs. (a) to (d) relating to purposes, limitations on authorizations of appropriations, description of amounts, inflation percentage, and reservation of certain amounts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/b/3/A"},"text":"Pub. L. 105–89, § 305(b)(3)(A)","children":[],"tail":", substituted “, community-based family support services, time-limited family reunification services, and adoption promotion and support services” for “and community-based family support services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/a/1"},"text":"Pub. L. 105–89, § 305(a)(1)","children":[],"tail":", added pars. (6) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/a/2"},"text":"Pub. L. 105–89, § 305(a)(2)","children":[],"tail":", substituted “1998, 1999, 2000, and 2001” for “and 1998” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb79f14af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f14b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"Oct. 1, 2018","children":[],"tail":", subject to transition rules for required State legislation or tribal action, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50734"},"text":"section 50734 of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f14b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", and applicable to payments under this part and part E of this subchapter for calendar quarters beginning on or after such date, without regard to whether implementing regulations have been promulgated, and with delay permitted if State legislation is required to meet additional requirements, see section 12(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s621"},"text":"section 621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f14b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/133/tIII/s301"},"text":"Pub. L. 107–133, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-17"},"text":"Jan. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2425"},"text":"115 Stat. 2425","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/133/tIII/s301"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the amendments made by this Act [enacting sections 629f to 629i of this title and amending this section and sections 629a, 629c, 629d, 629e, 674, and 677 of this title] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-01-17"},"text":"Jan. 17, 2002","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay Permitted if State Legislation Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a State plan under subpart 2 of part B or part E of the Social Security Act [probably means subpart 2 of part B or part E of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629"},"text":"42 U.S.C. 629","children":[],"tail":" et seq., 670 et seq.)] that the Secretary of Health and Human Services determines requires State legislation (other than legislation appropriating funds) in order for the plan to meet the additional requirements imposed by the amendments specified in subsection (a) of this section, the State plan shall not be regarded as failing to comply with the requirements of such part solely on the basis of the failure of the plan to meet the additional requirements before the first day of the first calendar quarter beginning after the close of the first regular session of the State legislature that begins after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-01-17"},"text":"Jan. 17, 2001","children":[],"tail":"]. For purposes of the preceding sentence, in the case of a State that has a 2-year legislative session, each year of the session shall be deemed to be a separate regular session of the State legislature.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f14b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89"},"text":"Pub. L. 105–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", except as otherwise provided, with delay permitted if State legislation is required, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/89/s501"},"text":"section 501 of Pub. L. 105–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb79f14b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective with respect to calendar quarters beginning on or after ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13711/c"},"text":"section 13711(c) of Pub. L. 103–66","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
