{"tag":"section","attrib":{"id":"idbff2e34d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121"},"text":null,"children":[{"tag":"num","attrib":{"value":"16121"},"text":"§ 16121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff2e34e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cell","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fuel cell” means a device that directly converts the chemical energy of a fuel and an oxidant into electricity by electrochemical processes occurring at separate electrodes in the device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e34f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Light-duty or heavy-duty vehicle fleet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “light-duty or heavy-duty vehicle fleet” does not include any vehicle designed or procured for combat or combat-related missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stationary; portable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “stationary” and “portable”, when used in reference to a fuel cell, include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff2e351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuous electric power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff2e352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" backup electric power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Hydrogen and Fuel Cell Technical Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16155"},"text":"section 16155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff2e354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16121/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Technical Advisory Committee” means the independent Technical Advisory Committee selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16156"},"text":"section 16156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}