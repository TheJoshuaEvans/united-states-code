{"tag":"section","attrib":{"id":"idb607853e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"299c–5"},"text":"§ 299c–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain administrative authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb607853f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy director and other officers and employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may appoint a deputy director for the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other officers and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may appoint and fix the compensation of such officers and employees as may be necessary to carry out this subchapter. Except as otherwise provided by law, such officers and employees shall be appointed in accordance with the civil service laws and their compensation fixed in accordance with title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in carrying out this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"section 8141 of title 40","children":[],"tail":", by lease or otherwise through the Administrator of General Services, buildings or portions of buildings in the District of Columbia or communities located adjacent to the District of Columbia for use for a period not to exceed 10 years; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire, construct, improve, repair, operate, and maintain laboratory, research, and other necessary facilities and equipment, and such other real or personal property (including patents) as the Secretary deems necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in carrying out this subchapter, may make grants to public and nonprofit entities and individuals, and may enter into cooperative agreements or contracts with public and private entities and individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of certain personnel and resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6078547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in carrying out this subchapter, may utilize personnel and equipment, facilities, and other physical resources of the Department of Health and Human Services, permit appropriate (as determined by the Secretary) entities and individuals to utilize the physical resources of such Department, and provide technical assistance and advice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6078548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in carrying out this subchapter, may use, with their consent, the services, equipment, personnel, information, and facilities of other Federal, State, or local public agencies, or of any foreign government, with or without reimbursement of such agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6078549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in carrying out this subchapter, may secure, from time to time and for such periods as the Director deems advisable but in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", the assistance and advice of consultants from the United States or abroad."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607854a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb607854b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in carrying out this subchapter, obtain the services of not more than 50 experts or consultants who have appropriate scientific or professional qualifications. Such experts or consultants shall be obtained in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", except that the limitation in such section on the duration of service shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb607854c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb607854d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Experts and consultants whose services are obtained under paragraph (1) shall be paid or reimbursed for their expenses associated with traveling to and from their assignment location in accordance with sections 5724, 5724a(a), 5724a(c), and 5726(c) of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb607854e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenses specified in subparagraph (A) may not be allowed in connection with the assignment of an expert or consultant whose services are obtained under paragraph (1) unless and until the expert agrees in writing to complete the entire period of assignment, or 1 year, whichever is shorter, unless separated or reassigned for reasons that are beyond the control of the expert or consultant and that are acceptable to the Secretary. If the expert or consultant violates the agreement, the money spent by the United States for the expenses specified in subparagraph (A) is recoverable from the expert or consultant as a statutory obligation owed to the United States. The Secretary may waive in whole or in part a right of recovery under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb607854f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299c–5/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary and uncompensated services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in carrying out this subchapter, may accept voluntary and uncompensated services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6078550-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 946, formerly § 926, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1668"},"text":"113 Stat. 1668","children":[],"tail":"; renumbered § 936, "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/3"},"text":"Pub. L. 109–41, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":"; renumbered § 946, "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3013/a/2"},"text":"Pub. L. 111–148, title III, § 3013(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/381"},"text":"124 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6078551-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6078552-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6078553-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8141"},"text":"section 8141 of title 40","children":[],"tail":"” substituted for “the Act of "},{"tag":"date","attrib":{"date":"1877-03-03"},"text":"March 3, 1877","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s34"},"text":"40 U.S.C. 34","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6078554-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299c–5, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s926"},"text":"act July 1, 1944, ch. 373, title IX, § 926","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/c"},"text":"Pub. L. 101–239, title VI, § 6103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2204"},"text":"103 Stat. 2204","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tI/s102/7"},"text":"Pub. L. 101–381, title I, § 102(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/586"},"text":"104 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/410/s10"},"text":"Pub. L. 102–410, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2101"},"text":"106 Stat. 2101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2010/b/8"},"text":"Pub. L. 103–43, title XX, § 2010(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/214"},"text":"107 Stat. 214","children":[],"tail":", authorized appropriations to carry out this subchapter, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–6"},"text":"section 299c–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
