{"tag":"section","attrib":{"id":"idbc74b8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3152"},"text":null,"children":[{"tag":"num","attrib":{"value":"3152"},"text":"§ 3152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of assistance under this subchapter shall submit reports to the Secretary at such intervals and in such manner as the Secretary shall require by regulation, except that no report shall be required to be submitted more than 10 years after the date of closeout of the assistance award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report shall contain an evaluation of the effectiveness of the economic assistance provided under this subchapter in meeting the need that the assistance was designed to address and in meeting the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b8a4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s212"},"text":"Pub. L. 89–136, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3606"},"text":"112 Stat. 3606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b8a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b8a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc74b8a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3152, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIII/s303"},"text":"Pub. L. 89–136, title III, § 303","children":[],"tail":", formerly § 302, "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/560"},"text":"79 Stat. 560","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/123/tIII/s303"},"text":"Pub. L. 91–123, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-25"},"text":"Nov. 25, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/219"},"text":"83 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/304/s1/c"},"text":"Pub. L. 91–304, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-06"},"text":"July 6, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/375"},"text":"84 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/65/tI/s105"},"text":"Pub. L. 92–65, title I, § 105"