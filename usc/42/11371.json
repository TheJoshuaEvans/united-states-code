{"tag":"section","attrib":{"id":"idbf44c802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371"},"text":null,"children":[{"tag":"num","attrib":{"value":"11371"},"text":"§ 11371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf44c803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “local government” means a unit of general purpose local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “locality” means the geographical area within the jurisdiction of a local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “metropolitan city” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5302"},"text":"section 5302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “operating costs” means expenses incurred by a recipient operating a facility assisted under this part with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf44c807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration, maintenance, repair, and security of such housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf44c808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities, fuels, furnishings, and equipment for such housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “private nonprofit organization” means a secular or religious organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" that is exempt from taxation under subtitle A of title 26, has an accounting system and a voluntary board, and practices nondiscrimination in the provision of assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c80a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recipient” means any governmental or private nonprofit entity that is approved by the Secretary as to financial responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c80b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c80c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c80d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11371/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “urban county” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5302"},"text":"section 5302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf44c80e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s411"},"text":"Pub. L. 100–77, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/495"},"text":"101 Stat. 495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s832/f/1"},"text":"Pub. L. 101–625, title VIII, § 832(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4361"},"text":"104 Sta