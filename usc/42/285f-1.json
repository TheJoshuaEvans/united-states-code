{"tag":"section","attrib":{"id":"idb573a8a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"285f–1"},"text":"§ 285f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research centers regarding chronic fatigue syndrome","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573a8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute, after consultation with the advisory council for the Institute, may make grants to, or enter into contracts with, public or nonprofit private entities for the development and operation of centers to conduct basic and clinical research on chronic fatigue syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each center assisted under this section shall use the facilities of a single institution, or be formed from a consortium of cooperating institutions, meeting such requirements as may be prescribed by the Director of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb573a8a3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 447, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tIX/s902/a"},"text":"Pub. L. 103–43, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/164"},"text":"107 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a8a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a8a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb573a8a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 447 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 447A and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285f–2"},"text":"section 285f–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb573a8a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb573a8a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extramural Study Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tIX/s902/b"},"text":"Pub. L. 103–43, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/164"},"text":"107 Stat. 164","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/tIX/s902/b"},"text":"“Not later than 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"], the Secretary of Health and Human Services shall establish an extramural study section for chronic fatigue syndrome research.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb573a8a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research Activities on Chronic Fatigue Syndrome","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIX/s1903"},"text":"Pub. L. 103–43, title XIX, § 1903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/203"},"text":"107 Stat. 203","children":[],"tail":", directed Secretary of Health and Human Services to, not later than "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", and annually thereafter for next 3 years, prepare and submit to Congress a report that summarizes research activities conducted or supported by National Institutes of Health concerning chronic fatigue syndrome, with information concerning grants made, cooperative agreements or contracts entered into, intramural activities, research priorities and needs, and plan to address such priorities and needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
