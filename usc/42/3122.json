272/s2211/a/1"},"text":"Pub. L. 118–272, § 2211(a)(1)","children":[],"tail":", redesignated par. (4) as (6). Former par. (6) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(A)(vii), (viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/4"},"text":"Pub. L. 118–272, § 2211(a)(4)","children":[],"tail":", added cls. (vii) and (viii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/1"},"text":"Pub. L. 118–272, § 2211(a)(1)","children":[],"tail":", redesignated pars. (5) to (7) as (7) to (9), respectively. Former pars. (8) and (9) redesignated (12) and (13), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/5"},"text":"Pub. L. 118–272, § 2211(a)(5)","children":[],"tail":", added pars. (10) and (11). Former pars. (10) and (11) redesignated (14) and (16), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/6"},"text":"Pub. L. 118–272, § 2211(a)(6)","children":[],"tail":", added par. (12) and struck out former par. (12), as redesignated from par. (8), which defined Regional Commissions to include Appalachian Regional Commission, Delta Regional Authority, Denali Commission, and Northern Great Plains Regional Authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/1"},"text":"Pub. L. 118–272, § 2211(a)(1)","children":[],"tail":", redesignated par. (8) as (12). Former par. (12) redesignated (17)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/a/1"},"text":"Pub. L. 118–272, § 2211(a)(1)","children":[],"tail":", redesignated pars. (9) and (10) as (13) and (14), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"