{"tag":"section","attrib":{"id":"idbc724716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122"},"text":null,"children":[{"tag":"num","attrib":{"value":"3122"},"text":"§ 3122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc724717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue economy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “blue economy” means the sustainable use of marine, lake, or other aquatic resources in support of economic development objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capacity building” includes all activities associated with early stage community-based project formation and conceptualization, prior to project predevelopment activity, including grants to local community organizations for planning participation, community outreach and engagement activities, research, and mentorship support to move projects from formation and conceptualization to project predevelopment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive economic development strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “comprehensive economic development strategy” means a comprehensive economic development strategy approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3162"},"text":"section 3162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72471a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72471b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic development district","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc72471c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “economic development district” means any area in the United States that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc72471d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is composed of areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":" and, to the extent determined appropriate by the Secretary, neighboring counties or communities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc72471e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been designated by the Secretary as an economic development district under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3171"},"text":"section 3171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc72471f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “economic development district” includes any economic development district designated by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3173"},"text":"section 3173 of this title","children":[],"tail":" (as in effect on the day before the effective date of the Economic Development Administration Reform Act of 1998)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc724721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc724722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city or other political subdivision of a State, including a special purpose unit of a State or local government engaged in economic or infrastructure development activities, or a consortium of political subdivisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education or a consortium of institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private nonprofit organization or association acting in cooperation with officials of a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc724729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership for public infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc72472a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training, research, and technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3147"},"text":"section 3147 of this title","children":[],"tail":", the term “eligible recipient” also includes private individuals and for-profit organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72472b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal agency” means a department, agency, or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72472c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grant” includes a cooperative agreement (within the meaning of chapter 63 of title 31).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72472d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, nation, pueblo, or other organized group or community, including any Alaska Native village or Regional Corporation (as defined in or established under the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)), that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72472e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor recreation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “outdoor recreation” means all recreational activities, and the economic drivers of those activities, that occur in nature-based environments outdoors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72472f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project predevelopment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “project predevelopment” means a measure required to be completed before the initiation of a project, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc724730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning and community asset mapping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc724731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc724732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3122/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance and organizational development;","childr