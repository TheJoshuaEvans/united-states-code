{"tag":"section","attrib":{"id":"idbe518e79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7573"},"text":null,"children":[{"tag":"num","attrib":{"value":"7573"},"text":"§ 7573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State standards and controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No State or political subdivision thereof may adopt or attempt to enforce any standard respecting emissions of any air pollutant from any aircraft or engine thereof unless such standard is identical to a standard applicable to such aircraft under this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe518e7a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 233, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/604/s11/a/1"},"text":"Pub. L. 91–604, § 11(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1704"},"text":"84 Stat. 1704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe518e7b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe518e7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe518e7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857