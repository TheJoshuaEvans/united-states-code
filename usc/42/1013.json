{"tag":"section","attrib":{"id":"idb8080fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1013"},"text":null,"children":[{"tag":"num","attrib":{"value":"1013"},"text":"§ 1013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby appropriated for fiscal year 2000 and subsequent fiscal years, out of any funds in the Treasury not otherwise appropriated, such sums as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8080fc6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 813, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1854"},"text":"113 Stat. 1854","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
