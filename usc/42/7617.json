{"tag":"section","attrib":{"id":"idbe5b044f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617"},"text":null,"children":[{"tag":"num","attrib":{"value":"7617"},"text":"§ 7617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic impact assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe5b0450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of proposed rulemaking; substantial revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to action of the Administrator in promulgating or revising—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5b0451-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new source standard of performance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7411"},"text":"section 7411 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7411/d"},"text":"section 7411(d) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulation under part B ","children":[{"tag":"ref","attrib":{"idref":"fn003715"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003715"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of subchapter I (relating to ozone and stratosphere protection),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulation under part C of subchapter I (relating to prevention of significant deterioration of air quality),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulation establishing emission standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521"},"text":"section 7521 of this title","children":[],"tail":" and any other regulation promulgated under that section,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulation controlling or prohibiting any fuel or fuel additive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545/c"},"text":"section 7545(c) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aircraft emission standard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7571"},"text":"section 7571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this section shall apply to any standard or regulation described in paragraphs (1) through (7) of this subsection unless the notice of proposed rulemaking in connection with such standard or regulation is published in the Federal Register after the date ninety days after ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":". In the case of revisions of such standards or regulations, this section shall apply only to revisions which the Administrator determines to be substantial revisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b0458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of assessment by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before publication of notice of proposed rulemaking with respect to any standard or regulation to which this section applies, the Administrator shall prepare an economic impact assessment respecting such standard or regulation. Such assessment shall be included in the docket required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7607/d/2"},"text":"section 7607(d)(2) of this title","children":[],"tail":" and shall be available to the public as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7607/d/4"},"text":"section 7607(d)(4) of this title","children":[],"tail":". Notice of proposed rulemaking shall include notice of such availability together with an explanation of the extent and manner in which the Administrator has considered the analysis contained in such economic impact assessment in proposing the action. The Administrator shall also provide such an explanation in his notice of promulgation of any regulation or standard referred to in subsection (a). Each such explanation shall be part of the statements of basis and purpose required under sections 7607(d)(3) and 7607(d)(6) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b0459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d), the assessment required under this section with respect to any standard or regulation shall contain an analysis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5b045a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of compliance with any such standard or regulation, including extent to which the costs of compliance will vary depending on (A) the effective date of the standard or regulation, and (B) the development of less expensive, more efficient means or methods of compliance with the standard or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b045b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential inflationary or recessionary effects of the standard or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b045c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects on competition of the standard or regulation with respect to small business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b045d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of the standard or regulation on consumer costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b045e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of the standard or regulation on energy use.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this section shall be construed to provide that the analysis of the factors specified in this subsection affects or alters the factors which the Administrator is required to consider in taking any action referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b045f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensiveness of assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment required under this section shall be as extensive as practicable, in the judgment of the Administrator taking into account the time and resources available to the Environmental Protection Agency and other duties and authorities which the Administrator is required to carry out under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b0460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on construction of section","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5b0461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter the basis on which a standard or regulation is promulgated under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preclude the Administrator from carrying out his responsibility under this chapter to protect public health and welfare; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5b0463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize or require any judicial review of any such standard or regulation, or any stay or injunction of the proposal, promulgation, or effectiveness of such standard or regulation on the basis of failure to comply with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b0464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen suits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements imposed on the Administrator under this section shall be treated as nondiscretionary duties for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7604/a/2"},"text":"section 7604(a)(2) of this title","children":[],"tail":", relating to citizen suits. The sole method for enforcement of the Administrator’s duty under this section shall be by bringing a citizen suit under such section 7604(a)(2) for a court order to compel the Administrator to perform such duty. Violation of any such order shall subject the Administrator to penalties for contempt of court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5b0465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7617/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any provision of this chapter in which costs are expressly required to be taken into account, the adequacy or inadequacy of any assessment required under this section may be taken into consideration, but shall not be treated for purposes of judicial review of any such provision as conclusive with respect to compliance or noncompliance with the requirement of such provision to take cost into account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe5b0466-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 317, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tIII/s307"},"text":"Pub. L. 95–95, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/778"},"text":"91 Stat. 778","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/623/s13/d"},"text":"Pub. L. 95–623, § 13(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3458"},"text":"92 Stat. 3458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe5b0467-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe5b0468-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe5b0469-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part B of subchapter I, referred to in subsec. (a)(3), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s601"},"text":"Pub. L. 101–549, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2648"},"text":"104 Stat. 2648","children":[],"tail":". See subchapter VI (§ 7671 et seq.) of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe5b046a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 317 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", is set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe5b046b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/623"},"text":"Pub. L. 95–623","children":[],"tail":" substituted “section 7411” for “section 7411(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe5b046c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe5b046d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
