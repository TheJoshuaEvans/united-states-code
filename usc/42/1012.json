{"tag":"section","attrib":{"id":"idb8080fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012"},"text":null,"children":[{"tag":"num","attrib":{"value":"1012"},"text":"§ 1012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8080fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World War II veteran","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “World War II veteran” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8080fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" served during World War II—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8080fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the active military, naval, or air service of the United States during World War II; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8080fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the organized military forces of the Government of the Commonwealth of the Philippines, while the forces were in the service of the Armed Forces of the United States pursuant to the military order of the President dated ","children":[{"tag":"date","attrib":{"date":"1941-07-26"},"text":"July 26, 1941","children":[],"tail":", including among the military forces organized guerrilla forces under commanders appointed, designated, or subsequently recognized by the Commander in Chief, Southwest Pacific Area, or other competent authority in the Army of the United States, in any case in which the service was rendered before "},{"tag":"date","attrib":{"date":"1946-12-31"},"text":"December 31, 1946","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8080fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was discharged or released therefrom under conditions other than dishonorable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8080fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after service of 90 days or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8080fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of a disability or injury incurred or aggravated in the line of active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World War II","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “World War II” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"1940-09-16"},"text":"September 16, 1940","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1947-07-24"},"text":"July 24, 1947","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental security income benefit under subchapter XVI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “supplemental security income benefit under subchapter XVI”, except as otherwise provided, includes State supplementary payments which are paid by the Commissioner of Social Security pursuant to an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Public Law 93–66","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080fbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal benefit rate under subchapter XVI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal benefit rate under subchapter XVI” means, with respect to any month, the amount of the supplemental security income cash benefit (not including any State supplementary payment which is paid by the Commissioner of Social Security pursuant to an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Public Law 93–66","children":[],"tail":") payable under subchapter XVI for the month to an eligible individual with no income."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080fbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1301/a/1"},"text":"section 1301(a)(1) of this title","children":[],"tail":", only the 50 States, the District of Columbia, and the Commonwealth of the Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8080fc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1012/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “benefit income” means any recurring payment received by a qualified individual as an annuity, pension, retirement, or disability benefit (including any veterans’ compensation or pension, workmen’s compensation payment, old-age, survivors, or disability insurance benefit, railroad retirement annuity or pension, and unemployment insurance benefit), but only if a similar payment was received by the individual from the same (or a related) source during the 12-month period preceding the month in which the individual files an application for benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8080fc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 812, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1853"},"text":"113 Stat. 1853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8080fc2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8080fc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8080fc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"Section 212(b) of Public Law 93–66","children":[],"tail":", referred to in pars. (3) and (4), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Pub. L. 93–66","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1973-07-09"},"text":"July 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/155"},"text":"87 Stat. 155","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
