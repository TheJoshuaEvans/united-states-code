{"tag":"section","attrib":{"id":"idbf0b8fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10002"},"text":null,"children":[{"tag":"num","attrib":{"value":"10002"},"text":"§ 10002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the establishment of minimum standards by the Federal Government for the accreditation of education programs for persons who administer radiologic procedures and for the certification of such persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insure that medical and dental radiologic procedures are consistent with rigorous safety precautions and standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8fd5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s977"},"text":"Pub. L. 97–35, title IX, § 977","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/599"},"text":"95 Stat. 599","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
