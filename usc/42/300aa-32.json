{"tag":"section","attrib":{"id":"idb67c66ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–32"},"text":"§ 300aa–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A petition for review of a regulation under this part may be filed in a court of appeals of the United States within 60 days from the date of the promulgation of the regulation or after such date if such petition is based solely on grounds arising after such 60th day.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb67c66ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3778"},"text":"100 Stat. 3778","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
