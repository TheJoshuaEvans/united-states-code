{"tag":"section","attrib":{"id":"idbf7b8fd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585"},"text":null,"children":[{"tag":"num","attrib":{"value":"12585"},"text":"§ 12585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7b8fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation consideration of certain criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall apply the criteria described in subsections (c) and (d) in determining whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve an application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" and provide assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" to the applicant; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve service positions described in the application as national service positions that include the national service educational award described in division D and provide such approved national service positions to the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to subgrants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or other entity that uses assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/a"},"text":"section 12571(a) of this title","children":[],"tail":" to support national service programs selected on a competitive basis to receive a share of the assistance shall use the criteria described in subsections (c) and (d) when considering an application submitted by a national service program to receive a portion of such assistance or an approved national service position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application of the State or other entity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall contain—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the State or other entity used these criteria in the selection of national service programs to receive assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the positions into which participants will be placed using such assistance, including descriptions of specific tasks to be performed by such participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the minimum qualifications that individuals shall meet to become participants in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria required to be applied in evaluating applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" are as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quality of the national service program proposed to be carried out directly by the applicant or supported by a grant from the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The innovative aspects of the national service program, and the feasibility of replicating the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sustainability of the national service program, based on evidence such as the existence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of strong and broad-based community support for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of multiple funding sources or private funding for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quality of the leadership of the national service program, the past performance of the program, and the extent to which the program builds on existing programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which participants of the national service program are recruited from among residents of the communities in which projects are to be conducted, and the extent to which participants and community residents are involved in the design, leadership, and operation of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extent to which projects would be conducted in the following areas where they are needed most:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communities designated as empowerment zones or redevelopment areas, targeted for special economic incentives, or otherwise identifiable as having high concentrations of low-income people.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas that are environmentally distressed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas adversely affected by Federal actions related to the management of Federal lands that result in significant regional job losses and economic dislocation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas adversely affected by reductions in defense spending or the closure or realignment of military installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Areas that have an unemployment rate greater than the national average unemployment for the most recent 12 months for which satisfactory data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of applicants other than States, the extent to which the application is consistent with the application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" of the State in which the projects would be conducted."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other criteria as the Corporation considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other considerations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall ensure that recipients of assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" are geographically diverse and include projects to be conducted in those urban and rural areas in a State with the highest rates of poverty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may designate, under such criteria as may be established by the Corporation, certain national service programs or types of national service programs described in subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572"},"text":"section 12572 of this title","children":[],"tail":" for priority consideration in the competitive distribution of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/d"},"text":"section 12581(d) of this title","children":[],"tail":". In designating national service programs to receive priority, the Corporation may include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" national service programs that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf7b8ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the national service priorities in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572/f"},"text":"section 12572(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7b8ff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are innovative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7b8ff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are well established in 1 or more States at the time of the application and are proposed to be expanded to additional States using assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8ff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant programs in support of other national service programs if the grant programs are to be conducted by nonprofit organizations with demonstrated and extensive expertise in the provision of services to meet human, educational, environmental, or public safety needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8ff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional corps programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572/c/1/D"},"text":"section 12572(c)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8ff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a competitive distribution of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/d"},"text":"section 12581(d) of this title","children":[],"tail":", the Corporation may give priority consideration to a national service program that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8ff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed in an application submitted by a State Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not one of the types of programs described in paragraph (2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the State Commission provides an adequate explanation of the reasons why it should not be a priority of such State to carry out any of such types of programs in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8ff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review panel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish panels of experts for the purpose of securing recommendations on applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" for more than $250,000 in assistance, or for national service positions that would require more than $250,000 in national service educational awards; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the opinions of such panels prior to making such determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis on areas most in need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making assistance available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" and in providing approved national service positions under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12573"},"text":"section 12573 of this title","children":[],"tail":", the Corporation shall ensure that not less than 50 percent of the total amount of assistance to be distributed to States under subsections (d) and (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581"},"text":"section 12581 of this title","children":[],"tail":" for a fiscal year is provided to carry out or support national service programs and projects that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are conducted in any of the areas described in subsection (c)(6) or on Federal or other public lands, to address unmet human, educational, environmental, or public safety needs in such areas or on such lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8ffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place a priority on the recruitment of participants who are residents of any of such areas or Federal or other public lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Views of State Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making competitive awards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/d"},"text":"section 12581(d) of this title","children":[],"tail":", the Corporation shall solicit and consider the views of a State Commission regarding any application for assistance to carry out a national service program within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rejection of State applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b9000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of State applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation rejects an application submitted by a State Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" for funds described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/e"},"text":"section 12581(e) of this title","children":[],"tail":", the Corporation shall promptly notify the State Commission of the reasons for the rejection of the application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b9001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resubmission and reconsideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall provide a State Commission notified under paragraph (1) with a reasonable opportunity to revise and resubmit the application. At the request of the State Commission, the Corporation shall provide technical assistance to the State Commission as part of the resubmission process. The Corporation shall promptly reconsider an application resubmitted under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b9002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12585/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any State’s allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/e"},"text":"section 12581(e) of this title","children":[],"tail":" for a fiscal year that the Corporation determines will not be provided for that fiscal year shall be available for distribution by the Corporation as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/f"},"text":"section 12581(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7b9003-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s133"},"text":"Pub. L. 101–610, title I, § 133","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/805"},"text":"107 Stat. 805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1311"},"text":"Pub. L. 111–13, title I, § 1311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1509"},"text":"123 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7b9004-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7b9005-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7b9006-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s133"},"text":"section 133 of Pub. L. 101–610","children":[],"tail":" was renumbered section 199K and is classified to section 12655"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf7b9007-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/1"},"text":"Pub. L. 111–13, § 1311(1)","children":[],"tail":", struck out “jobs or” before “positions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/2/A/i"},"text":"Pub. L. 111–13, § 1311(2)(A)(i)","children":[],"tail":", substituted “subsection (a), (b), or (c) of section 12572” for “section 12572(a)” and “section 12581(d)” for “section 12581(d)(2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/2/A/ii"},"text":"Pub. L. 111–13, § 1311(2)(A)(ii)","children":[],"tail":", added subpars. (A) to (C) and struck out former subpars. (A) to (G), which set forth programs the Corporation could include in designating national service programs to receive priority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/2/B"},"text":"Pub. L. 111–13, § 1311(2)(B)","children":[],"tail":", substituted “section 12581(d)” for “section 12581(d)(2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/3"},"text":"Pub. L. 111–13, § 1311(3)","children":[],"tail":", substituted “subsections (d) and (e) of section 12581” for “subsections (a) and (d)(1) of section 12581” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/6"},"text":"Pub. L. 111–13, § 1311(6)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/4/A"},"text":"Pub. L. 111–13, § 1311(4)(A)","children":[],"tail":", substituted “section 12581(e)” for “section 12581(a)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/4/B"},"text":"Pub. L. 111–13, § 1311(4)(B)","children":[],"tail":", substituted “section 12581(e)” for “section 12581(a)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/f"},"text":"section 12581(f) of this title","children":[],"tail":"” for “paragraph (3) of such subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1311/5"},"text":"Pub. L. 111–13, § 1311(5)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7b9008-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf7b9009-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7b900a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"