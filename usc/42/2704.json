{"tag":"section","attrib":{"id":"idbc2ab73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinued Job Corps centers; utilization for special youth programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2ab73f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, the Director of the Office of Economic Opportunity shall establish procedures and make arrangements which are designed to assure that facilities and equipment of Job Corps centers which are being discontinued will, where feasible, be made available for use by State or Federal agencies and other public or private agencies, institutions, and organizations with satisfactory arrangements for utilizing such facilities and equipment for conducting programs, especially those providing opportunities for low-income disadvantaged youth, including, without limitation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2ab740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special remedial programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2ab741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summer youth programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2ab742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exemplary vocational preparation and training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2ab743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural enrichment programs, including music, the arts, and the humanities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2ab744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs designed to improve the qualifications of educational personnel, including instructors in vocational educational programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2ab745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" youth conservation work and other conservation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2ab746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To achieve the objectives of this section, the Director of the Office of Economic Opportunity shall consult with, elicit the cooperation of, and utilize the services of the Administrator of the General Services Administration, and the Secretaries of Agriculture, of the Interior, and of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2ab747-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/177/tI/s113"},"text":"Pub. L. 91–177, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/832"},"text":"83 Stat. 832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s9/a"},"text":"Pub. L. 93–644, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2310"},"text":"88 Stat. 2310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2ab748-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc2ab749-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc2ab74a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Opportunity Amendments of 1969, and not as part of the Economic Opportunity Act of 1964 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc2ab74b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc2ab74c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[