e Department of Health and Human Services by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s676"},"text":"Pub. L. 97–35, title VI, § 676","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/516"},"text":"95 Stat. 516","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9905"},"text":"section 9905 of this title","children":[],"tail":", prior to the general amendment of chapter 106 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9912"},"text":"section 9912 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
