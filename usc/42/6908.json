{"tag":"section","attrib":{"id":"idbdc750b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908"},"text":null,"children":[{"tag":"num","attrib":{"value":"6908"},"text":"§ 6908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small town environmental planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc750b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency (hereafter referred to as the “Administrator”) shall establish a program to assist small communities in planning and financing environmental facilities. The program shall be known as the “Small Town Environmental Planning Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Town Environmental Planning Task Force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc750b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall establish a Small Town Environmental Planning Task Force which shall be composed of representatives of small towns from different areas of the United States, Federal and State governmental agencies, and public interest groups. The Administrator shall terminate the Task Force not later than 2 years after the establishment of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc750b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc750b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify regulations developed pursuant to Federal environmental laws which pose significant compliance problems for small towns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify means to improve the working relationship between the Environmental Protection Agency (hereafter referred to as the Agency) and small towns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review proposed regulations for the protection of the environmental and public health and suggest revisions that could improve the ability of small towns to comply with such regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify means to promote regionalization of environmental treatment systems and infrastructure serving small towns to improve the economic condition of such systems and infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such other assistance to the Administrator as the Administrator deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of environmental requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc750bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", the Administrator shall publish a list of requirements under Federal environmental and public health statutes (and the regulations developed pursuant to such statutes) applicable to small towns. Not less than annually, the Administrator shall make such additions and deletions to and from the list as the Administrator deems appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc750c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall, as part of the Small Town Environmental Planning Program under this section, implement a program to notify small communities of the regulations identified under paragraph (1) and of future regulations and requirements through methods that the Administrator determines to be effective to provide information to the greatest number of small communities, including any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc750c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Newspapers and other periodicals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other news media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade, municipal, and other associations that the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Town Ombudsman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish and staff an Office of the Small Town Ombudsman. The Office shall provide assistance to small towns in connection with the Small Town Environmental Planning Program and other business with the Agency. Each regional office shall identify a small town contact. The Small Town Ombudsman and the regional contacts also may assist larger communities, but only if first priority is given to providing assistance to small towns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-media permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc750c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall conduct a study of establishing a multi-media permitting program for small towns. Such evaluation shall include an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdc750c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental benefits and liabilities of a multi-media permitting program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of using such a program to coordinate a small town’s environmental and public health activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdc750ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal barriers, if any, to the establishment of such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc750cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 3 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-06"},"text":"October 6, 1992","children":[],"tail":", the Administrator shall report to Congress on the results of the evaluation performed in accordance with paragraph (1). Included in this report shall be a description of the activities conducted pursuant to subsections (a) through (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Small town” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “small town” means an incorporated or unincorporated community (as defined by the Administrator) with a population of less than 2,500 individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc750cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6908/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated the sum of $500,000 to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc750ce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/386/tI/s109"},"text":"Pub. L. 102–386, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1515"},"text":"106 Stat. 1515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc750cf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc750d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdc750d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Facility Compliance Act of 1992, and not as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
