{"tag":"section","attrib":{"id":"idbda37469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6394"},"text":null,"children":[{"tag":"num","attrib":{"value":"6394"},"text":"§ 6394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda3746a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6394/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any provision of title I or title II of this Act or this title ","children":[{"tag":"ref","attrib":{"idref":"fn003486"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003486"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (other than any provision of such titles which amend "},{"tag":"ref","attrib":{"idref":"fn003487"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003487"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “amends”."}],"tail":" another law),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda3746b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6394/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any rule, regulation, or order issued pursuant to any such provision or any provision of section 383 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6363"},"text":"42 U.S.C. 6363","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda3746c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6394/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fail to comply with any provision prescribed in, or pursuant to, an energy conservation contingency plan which is in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda3746d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tV/s524"},"text":"Pub. L. 94–163, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/963"},"text":"89 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda3746e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda3746f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbda37470-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I of this Act, referred to in par. (1), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163"},"text":"Pub. L. 94–163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/875"},"text":"89 Stat. 875","children":[],"tail":", which is classified principally to subchapter I (§ 6211 et seq.) of this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II of this Act, referred to in par.