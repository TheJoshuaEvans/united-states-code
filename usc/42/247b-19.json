{"tag":"section","attrib":{"id":"idb4adc070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–19"},"text":"§ 247b–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4adc071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this Act as the “Secretary”) shall establish and implement a program to provide information and education on muscular dystrophy to health professionals and the general public, including information and education on advances in the diagnosis and treatment of muscular dystrophy and training and continuing education through programs for scientists, physicians, medical students, and other health professionals who provide care for patients with muscular dystrophy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4adc072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use amounts made available under this section provides ","children":[{"tag":"ref","attrib":{"idref":"fn002056"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “to provide”."}],"tail":" stipends for health professionals who are enrolled in training programs under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4adc073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4adc074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with leaders in the muscular dystrophy patient community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with professional organizations and the patient community in the development and issuance of care considerations for pediatric and adult patients, including acute care considerations, for Duchenne-Becker muscular dystrophy, and various other forms of muscular dystrophy, and in periodic review and updates, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing and updating care considerations under paragraph (2), incorporate strategies specifically responding to the findings of the national transitions survey of minority, young adult, and adult communities of muscular dystrophy patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" widely disseminate the Duchenne-Becker muscular dystrophy and various other forms of muscular dystrophy care considerations as broadly as possible, including through partnership opportunities with the muscular dystrophy patient community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4adc078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–19/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4adc079-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/84/s5"},"text":"Pub. L. 107–84, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-18"},"text":"Dec. 18, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/828"},"text":"115 Stat. 828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/361/s4"},"text":"Pub. L. 110–361, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4011"},"text":"122 Stat. 4011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/166/s4"},"text":"Pub. L. 113–166, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-26"},"text":"Sept. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1880"},"text":"128 Stat. 1880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4adc07a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4adc07b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4adc07c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/84"},"text":"Pub. L. 107–84","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-18"},"text":"Dec. 18, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/823"},"text":"115 Stat. 823","children":[],"tail":", known as the Muscular Dystrophy Community Assistance, Research and Education Amendments of 2001 and also as the MD–CARE Act. For complete classification of this Act to the Code, see Short Title of 2001 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4adc07d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Muscular Dystrophy Community Assistance, Research and Education Amendments of 2001, also known as the MD–CARE Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4adc07e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/166/s4/1"},"text":"Pub. L. 113–166, § 4(1)","children":[],"tail":", inserted “for pediatric and adult patients, including acute care considerations,” after “issuance of care considerations” and “various” before “other forms of muscular dystrophy” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/166/s4/2"},"text":"Pub. L. 113–166, § 4(2)","children":[],"tail":"–(4), added par. (3), redesignated former par. (3) as (4), and, in par. (4), inserted “various” before “other forms of muscular dystrophy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/361"},"text":"Pub. L. 110–361","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
