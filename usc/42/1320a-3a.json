{"tag":"section","attrib":{"id":"idb82bc4b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–3a"},"text":"§ 1320a–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements for other providers under part B of Medicare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82bc4ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure required to receive payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment may be made under part B of subchapter XVIII for items or services furnished by any disclosing part B provider unless such provider has provided the Secretary with full and complete information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82bc4bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the identity of each person with an ownership or control interest in the provider or in any subcontractor (as defined by the Secretary in regulations) in which the provider directly or indirectly has a 5 percent or more ownership interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82bc4bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any person identified under paragraph (1) or any managing employee of the provider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82bc4bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the identity of any other entities providing items or services for which payment may be made under subchapter XVIII with respect to which such person or managing employee is a person with an ownership or control interest at the time such information is supplied or at any time during the 3-year period ending on the date such information is supplied, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82bc4be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to whether any penalties, assessments, or exclusions have been assessed against such person or managing employee under section 1320a–7, 1320a–7a, or 1320a–7b of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82e34bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including the employer identification number (assigned pursuant to section 6109 of the Internal Revenue Code of 1986) and social security account number (assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s405/c/2/B"},"text":"section 405(c)(2)(B) of this title","children":[],"tail":") of the disclosing part B provider and any person, managing employee, or other entity identified or described under paragraph (1) or (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82e34c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates to information supplied","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A disclosing part B provider shall notify the Secretary of any changes or updates to the information supplied under subsection (a) not later than 180 days after such changes or updates take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82e34c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82e34c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal by HHS","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall transmit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82e34c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commissioner of Social Security information concerning each social security account number (assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s405/c/2/B"},"text":"section 405(c)(2)(B) of this title","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82e34c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of the Treasury information concerning each employer identification number (assigned pursuant to section 6109 of the Internal Revenue Code of 1986),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"supplied to the Secretary pursuant to subsection (a)(3) or section 1320a–3(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002679"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002679"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to the extent necessary for verification of such information in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82e34c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of Social Security and the Secretary of the Treasury shall verify the accuracy of, or correct, the information supplied by the Secretary to such official pursuant to paragraph (1), and shall report such verifications or corrections to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82e34c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reimburse the Commissioner and Secretary of the Treasury, at a rate negotiated between the Secretary and such official, for the costs incurred by such official in performing the verification and correction services described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82e34c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82e34c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “disclosing part B provider” means any entity receiving payment on an assignment-related basis (or, for purposes of subsection (a)(3), any entity receiving payment) for furnishing items or services for which payment may be made under part B of subchapter XVIII, except that such term does not include an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3/a/2"},"text":"section 1320a–3(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82e34c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “managing employee” means, with respect to a provider, a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–5/b"},"text":"section 1320a–5(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82e34ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “person with an ownership or control interest” means, with respect to a provider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82e34cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3/a/3"},"text":"section 1320a–3(a)(3) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82e34cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–3a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who has one of the 5 largest direct or indirect ownership or control interests in the provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82e34cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1124A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4164/b/1"},"text":"Pub. L. 101–508, title IV, § 4164(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-101"},"text":"104 Stat. 1388–101","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tI/s147/f/7/A/i"},"text":"Pub. L. 103–432, title I, § 147(f)(7)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4432"},"text":"108 Stat. 4432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4313/b"},"text":"Pub. L. 105–33, title IV, § 4313(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/388"},"text":"111 Stat. 388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82e34ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82e34cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb82e34d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsecs. (a)(3) and (c)(1)(B), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3"},"text":"Section 1320a–3 of this title","children":[],"tail":", referred to in subsec. (c)(1), does not contain a subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82e34d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/b/1"},"text":"Pub. L. 105–33, § 4313(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/c/2"},"text":"Pub. L. 105–33, § 4313(c)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/b/2"},"text":"Pub. L. 105–33, § 4313(b)(2)","children":[],"tail":", inserted “(or, for purposes of subsection (a)(3), any entity receiving payment)” after “on an assignment-related basis”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/c/1"},"text":"Pub. L. 105–33, § 4313(c)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432"},"text":"Pub. L. 103–432","children":[],"tail":" made technical amendment to reference to subchapter XVIII of this chapter to correct reference to corresponding provision of original act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82e34d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82e34d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/b"},"text":"section 4313(b) of Pub. L. 105–33","children":[],"tail":" applicable to payment for items and services furnished more than 90 days after date of submission of report under "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/d"},"text":"section 4313(d) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3"},"text":"section 1320a–3 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/e"},"text":"section 4313(e) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3"},"text":"section 1320a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82e34d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tI/s147/g"},"text":"Pub. L. 103–432, title I, § 147(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4432"},"text":"108 Stat. 4432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tI/s147/g"},"text":"“Except as otherwise provided in this section [amending this section and sections 1320b–5, 1395","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1395p, 1395q, 1395x, 1395y, and 1395cc of this title, enacting provisions set out as notes under sections 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 1395p, and 1395y of this title, amending provisions set out as notes under this section and sections 254b, 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", and 1395u of this title, and repealing provisions set out as a note under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title], the amendments made by this section shall take effect as if included in the enactment of OBRA–1990 [Pub L. 101–508].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82e34d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4164/b/4"},"text":"Pub. L. 101–508, title IV, § 4164(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-102"},"text":"104 Stat. 1388–102","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tI/s147/f/7/A/ii"},"text":"Pub. L. 103–432, title I, § 147(f)(7)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4432"},"text":"108 Stat. 4432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tI/s147/f/7/A/ii"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by paragraphs (1), (2), and (3) [enacting this section and amending sections 1320a–7 and 1320a–7b of this title] shall apply with respect to items or services furnished on or after—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", in the case of items or services furnished by a provider who, on or before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"], has furnished items or services for which payment may be made under part B of title XVIII of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":", in the case of items or services furnished by any other provider.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82e34d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Confidentiality of Social Security Account Numbers","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Before amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" may become effective, Secretary of Health and Human Services is required to submit to Congress a report on steps Secretary has taken to assure the confidentiality of social security account numbers that will be provided to Secretary, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s4313/d"},"text":"section 4313(d) of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–3"},"text":"section 1320a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
