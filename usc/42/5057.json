{"tag":"section","attrib":{"id":"idbcf31017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057"},"text":null,"children":[{"tag":"num","attrib":{"value":"5057"},"text":"§ 5057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf31018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf31019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual with responsibility for the operation of a program that receives assistance under this chapter shall not discriminate against a participant in, or member of the staff of, such program on the basis of race, color, national origin, sex, age, or political affiliation of such participant or member, or on the basis of disability, if the participant or member is a qualified individual with a disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3101a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in paragraph (1), the term “qualified individual with a disability” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12111/8"},"text":"section 12111(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf3101b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any assistance provided under this chapter shall constitute Federal financial assistance for purposes of title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.), title IX of the Education Amendments of 1972 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"20 U.S.C. 1681","children":[],"tail":" et seq.), section 504 of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"), and the Age Discrimination Act of 1975 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf3101c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious discrimination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf3101d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), an individual with responsibility for the operation of a program that receives assistance under this chapter shall not discriminate on the basis of religion against a participant in such program or a member of the staff of such program who is paid with funds received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3101e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the employment, with assistance provided under this chapter, of any member of the staff, of a program that receives assistance under this chapter, who was employed with the organization operating the program on the date the grant under this chapter was awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf3101f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall promulgate rules and regulations to provide for the enforcement of this section that shall include provisions for summary suspension of assistance for not more than 30 days, on an emergency basis, until notice and an opportunity to be heard can be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf31020-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tIV/s417"},"text":"Pub. L. 93–113, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/413"},"text":"87 Stat. 413","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/143/s12"},"text":"Pub. L. 96–143, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-13"},"text":"Dec. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1079"},"text":"93 Stat. 1079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s608/f/3"},"text":"Pub. L. 97–35, title VI, § 608(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/488"},"text":"95 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s30/a"},"text":"Pub. L. 98–288, § 30(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/197"},"text":"98 Stat. 197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s367"},"text":"Pub. L. 103–82, title III, § 367","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/908"},"text":"107 Stat. 908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf31021-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf31022-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf31023-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1), (b), and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":", known as the Domestic Volunteer Service Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Education Amendments of 1972, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/235"},"text":"86 Stat. 235","children":[],"tail":". Title IX of the Act, known as the Patsy Takemoto Mink Equal Opportunity in Education Act, is classified principally to chapter 38 (§ 1681 et seq.) of Title 20, Education. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in subsec. (b), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/728"},"text":"78 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf55a14-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" amended section generally, substituting present provisions for former provisions relating to nondiscrimination, which set forth: in subsec. (a), general rule; in subsec. (b), special rule against sex discrimination; and in subsec. (c), applicability of nondiscrimination authorities of certain statutes and requirement for regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" struck out “and the Peace Corps Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"22 U.S.C. 2501","children":[],"tail":" et seq.)” after “under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted reference to the Secretary of Health and Human Services for references to the Secretary of Health and Human Resources and the Secretary of Health, Education, and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143/s12/a"},"text":"Pub. L. 96–143, § 12(a)","children":[],"tail":", inserted “handicap,” after “age,” and inserted provisions requiring that for purposes of this subsection, and for purposes of title VI of the Civil Rights Act of 1964, "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":", and the Age Discrimination Act of 1975, any program, project, or activity to which volunteers are assigned under this chapter be deemed to be receiving Federal financial assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143/s12/b"},"text":"Pub. L. 96–143, § 12(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf55a15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf55a16-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s392"},"text":"section 392 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"section 4951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
