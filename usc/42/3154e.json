{"tag":"section","attrib":{"id":"idbc7701dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154e"},"text":"§ 3154e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce training grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7701dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants to support the development and expansion of innovative workforce training programs through sectoral partnerships leading to quality jobs and the acquisition of equipment or construction of facilities to support workforce development activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds from a grant under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7701df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition or development of land and improvements to house workforce training activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition, design and engineering, construction, rehabilitation, alteration, expansion, or improvement of such a facility, including related equipment and machinery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of machinery or equipment to support workforce training activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, technical assistance, and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sector partnerships development, program design, and program implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an eligible recipient that is a State, subject to subsection (c), a State program to support individual trainees for employment in critical industries with high demand and vacancies necessary for further economic development of the applicable State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7701e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires significant post-secondary training; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not require a post-secondary degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grant pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7701e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to States for the purpose described in subsection (b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subsection, the Chief Executive of a State shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, which shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7701ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A method for identifying critical industry sectors driving in-State economic growth that face staffing challenges for in-demand jobs and careers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A governance structure for the implementation of the program established by the State, including defined roles for the consortia of agencies of such State, at a minimum, to include the State departments of economic development, labor, and education, or the State departments or agencies with jurisdiction over those matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy for recruiting participants from at least 1 community that meets 1 or more of the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for how the State will develop a tracking system for eligible programs, participant enrollment, participant outcomes, and an application portal for individual participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award not more than 1 grant under this subsection to any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this subsection may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7701f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary costs to carry out the matters described in this subsection, including tuition and stipends for individuals that receive funds under the program established by the applicable State, subject to the requirements described in paragraph (6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program implementation, planning, technical assistance, or training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3144"},"text":"section 3144 of this title","children":[],"tail":", the Federal share of the cost of any award carried out with a grant made under this subsection shall not exceed 70 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall ensure that grant funds provided under this subsection to each individual that receives funds under the program established by the applicable State is the lesser of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7701f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which the individual is also eligible for a Federal Pell Grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"section 1070a of title 20","children":[],"tail":" for enrollment at the applicable training program for any award year of the training program, $11,000 minus the amount of the awarded Federal Pell Grant."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7701f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For an individual not described in paragraph (1), the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc7701f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $11,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc7701f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the training program in which the individual is enrolled, including tuition, fees, career navigation services, textbook costs, expenses related to assessments and exams for certification or licensure, equipment costs, and wage stipends (in the case of a training program that is an earn-and-learn program).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided under this subsection shall expire on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the development of new workforce development models with the Secretary of Labor and the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7701fa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s219"},"text":"Pub. L. 89–136, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2221"},"text":"Pub. L. 118–272, div. B, title II, § 2221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3186"},"text":"138 Stat. 3186","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
