{"tag":"section","attrib":{"id":"idbf8c5886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651e"},"text":"§ 12651e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8c5887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managing Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8c5888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Corporation 2 Managing Directors, who shall be appointed by the President, and who shall report to the Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c5889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Managing Directors shall be compensated at the rate provided for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c588a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall determine the programs for which the Managing Directors shall have primary responsibility and shall establish the divisions of the Corporation to be headed by the Managing Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c588b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8c588c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Corporation an Office of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c588d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by an Inspector General, appointed in accordance with chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c588e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Financial Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8c588f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Corporation a Chief Financial Officer, who shall be appointed by the Chief Executive Officer pursuant to subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651f"},"text":"section 12651f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c5890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Financial Officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8c5891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Chief Executive Officer regarding financial management matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c5892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee all financial management activities relating to the programs and operations of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c5893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain an integrated accounting and financial management system for the Corporation, including financial reporting and internal controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c5894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain any joint financial management systems with the Department of Education necessary to carry out the programs of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c5895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, manage, and provide policy guidance and oversight of the financial management personnel, activities, and operations of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c5896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Directors for VISTA and National Senior Service Corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8c5897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"One of the Managing Directors appointed under subsection (a) shall, in accordance with applicable provisions of title 5, appoint 4 Assistant Directors who shall report directly to such Managing Director, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8c5898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Assistant Director shall be responsible for programs carried out under parts A [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.] and B "},{"tag":"ref","attrib":{"idref":"fn004083"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004083"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title I of the Domestic Volunteer Service Act of 1973 (the Volunteers in Service to America (VISTA) program) and other antipoverty programs under title I of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c5899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Assistant Director shall be responsible for programs carried out under part A of title II of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5001"},"text":"42 U.S.C. 5001","children":[],"tail":" et seq.] (relating to the Retired Senior Volunteer Program);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c589a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Assistant Director shall be responsible for programs carried out under part B of title II of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5011"},"text":"42 U.S.C. 5011","children":[],"tail":" et seq.] (relating to the Foster Grandparent Program); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8c589b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Assistant Director shall be responsible for programs carried out under part C of title II of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5013"},"text":"42 U.S.C. 5013","children":[],"tail":"] (relating to the Senior Companion Program)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8c589c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for exercise of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Assistant Director appointed pursuant to paragraph (1) may exercise the authority assigned to each such Director only after the effective date of section 203(c)(2) of the National and Community Service Trust Act of 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8c589d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s194"},"text":"Pub. L. 101–610, title I, § 194","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII/s202/a"},"text":"Pub. L. 103–82, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/882"},"text":"107 Stat. 882","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/409/s4/a/4"},"text":"Pub. L. 110–409, § 4(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4304"},"text":"122 Stat. 4304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1705"},"text":"Pub. L. 111–13, title I, § 1705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1547"},"text":"123 Stat. 1547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/p"},"text":"Pub. L. 112–166, § 2(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1288"},"text":"126 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/87"},"text":"Pub. L. 117–286, § 4(b)(87)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4352"},"text":"136 Stat. 4352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8c589e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8c589f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8c58a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 4951 et seq.) of chapter 66 of this title. Part A of title I of the Act is classified generally to part A (§ 4951 et seq.) of subchapter I of chapter 66 of this title. Part B of title I of the Act, which was classified generally to part B (§ 4971 et seq.) of subchapter I of chapter 66 of this title, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2121"},"text":"Pub. L. 111–13, title II, § 2121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1584"},"text":"123 Stat. 1584","children":[],"tail":". Parts A, B, and C of title II of the Act are classified generally to parts A (§ 5001 et seq.), B (§ 5011 et seq.), and C (§ 5013 et seq.), respectively, of subchapter II of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 203(c)(2) of the National and Community Service Trust Act of 1993, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s203/c/2"},"text":"section 203(c)(2) of Pub. L. 103–82","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":". For the effective date of section 203(c)(2) of this Act, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s203/d"},"text":"section 203(d) of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf8c58a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" struck out “, by and with the advice and consent of the Senate” after “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" added par. (1), redesignated par. (3) as (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Office","children":[],"tail":".—There shall be in the Corporation a Chief Financial Officer, who shall be appointed by the President, by and with the advice and consent of the Senate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—The Chief Financial Officer shall be compensated at the rate provided for level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/409"},"text":"Pub. L. 110–409","children":[],"tail":" struck out par. (3). Text read as follows: “The Inspector General shall be compensated at the rate provided for level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8c58a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf8c58a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf8c58a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf8c58a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s202/i"},"text":"section 202(i) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
