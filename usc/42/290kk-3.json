{"tag":"section","attrib":{"id":"idb5c720cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"290kk–3"},"text":"§ 290kk–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational requirements for personnel in drug treatment programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c720cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c720cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing unduly rigid or uniform educational qualification for counselors and other personnel in drug treatment programs may undermine the effectiveness of such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c720ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such educational requirements for counselors and other personnel may hinder or prevent the provision of needed drug treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c720cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290kk–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether personnel of a program participant that has a record of successful drug treatment for the preceding three years have satisfied State or local requirements for education and training, a State or local government shall not discriminate against education and training provided to such personnel by a religious organization, so long as such education and training includes basic content substantially equivalent to the content provided by nonreligious organizations that the State or local government would credit for purposes of determining whether the relevant requirements have been satisfied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c720d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 596C, formerly § 584, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/7/tI/s144"},"text":"Pub. L. 106–554, § 1(a)(7) [title I, § 144]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–622; renumbered § 596C, "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s107/a/2"},"text":"Pub. L. 119–44, title I, § 107(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/674"},"text":"139 Stat. 674","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
