{"tag":"section","attrib":{"id":"idb85b8703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–1"},"text":"§ 1320d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements for adoption of standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85b8704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any standard adopted under this part shall apply, in whole or in part, to the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85b8705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b8706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health care clearinghouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b8707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health care provider who transmits any health information in electronic form in connection with a transaction referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2/a/1"},"text":"section 1320d–2(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b8708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any standard adopted under this part shall be consistent with the objective of reducing the administrative costs of providing and paying for health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b8709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of standard setting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85b870a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), any standard adopted under this part shall be a standard that has been developed, adopted, or modified by a standard setting organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b870b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85b870c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Different standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may adopt a standard that is different from any standard developed, adopted, or modified by a standard setting organization, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85b870d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the different standard will substantially reduce administrative costs to health care providers and health plans compared to the alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b870e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standard is promulgated in accordance with the rulemaking procedures of subchapter III of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b870f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No standard by standard setting organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If no standard setting organization has developed, adopted, or modified any standard relating to a standard that the Secretary is authorized or required to adopt under this part—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85b8710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) shall not apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b8711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (f) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b8712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85b8713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A standard may not be adopted under this part unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85b8714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a standard that has been developed, adopted, or modified by a standard setting organization, the organization consulted with each of the organizations described in subparagraph (B) in the course of such development, adoption, or modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b8715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other standard, the Secretary, in complying with the requirements of subsection (f), consulted with each of the organizations described in subparagraph (B) before adopting the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85b8716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The organizations referred to in subparagraph (A) are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85b8717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Uniform Billing Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b8718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Uniform Claim Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b8719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Workgroup for Electronic Data Interchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85b871a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American Dental Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b871b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation specifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish specifications for implementing each of the standards adopted under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b871c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of trade secrets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise required by law, a standard adopted under this part shall not require disclosure of trade secrets or confidential commercial information by a person required to comply with this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b871d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In complying with the requirements of this part, the Secretary shall rely on the recommendations of the National Committee on Vital and Health Statistics established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242k/k"},"text":"section 242k(k) of this title","children":[],"tail":", and shall consult with appropriate Federal and State agencies and private organizations. The Secretary shall publish in the Federal Register any recommendation of the National Committee on Vital and Health Statistics regarding the adoption of a standard under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85b871e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to modifications of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to a modification to a standard (including an addition to a standard) adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–3/b"},"text":"section 1320d–3(b) of this title","children":[],"tail":" in the same manner as it applies to an initial standard adopted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–3/a"},"text":"section 1320d–3(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85b871f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1172, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2023"},"text":"110 Stat. 2023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85b8720-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85b8721-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb85b8722-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1172 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320c–21"},"text":"section 1320c–21 of this title","children":[],"tail":" prior to the general amendment of part B of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
