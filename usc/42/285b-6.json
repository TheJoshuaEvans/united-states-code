{"tag":"section","attrib":{"id":"idb56c7c9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b–6"},"text":"§ 285b–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Associate Director for Prevention; appointment; function","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56c7c9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Institute an Associate Director for Prevention to coordinate and promote the programs in the Institute concerning the prevention of heart, blood vessel, lung, and blood diseases. The Associate Director shall be appointed by the Director of the Institute from individuals who because of their professional training or experience are experts in public health or preventive medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7c9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Associate Director for Prevention shall prepare for inclusion in the biennial report made under section 284b ","children":[{"tag":"ref","attrib":{"idref":"fn002185"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title a description of the prevention activities of the Institute, including a description of the staff and resources allocated to those activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56c7c9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":