{"tag":"section","attrib":{"id":"idb61825b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–32"},"text":"§ 300d–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb61825ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out parts A and B, subject to subsections (b) and (c), there are authorized to be appropriated $24,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61825bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount appropriated under subsection (a) for a fiscal year is equal to or less than $1,000,000, such appropriation is available only for the purpose of carrying out part A. If the amount so appropriated is greater than $1,000,000, 50 percent of such appropriation shall be made available for the purpose of carrying out part A and 50 percent shall be made available for the purpose of carrying out part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61825bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of part A funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated under subsection (a) for a fiscal year to carry out part A—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61825bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of such amounts for such year shall be allocated for administrative purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61825be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of such amounts for such year shall be allocated for the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–3"},"text":"section 300d–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61825bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–32/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out parts A through C, beginning on ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall transfer authority in administering grants and related authorities under such parts from the Administrator of the Health Resources and Services Administration to the Assistant Secretary for Preparedness and Response."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit