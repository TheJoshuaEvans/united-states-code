{"tag":"section","attrib":{"id":"idbea04ae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8630"},"text":null,"children":[{"tag":"num","attrib":{"value":"8630"},"text":"§ 8630.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable fuels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In providing assistance pursuant to this subchapter, a State, or any other person with which the State makes arrangements to carry out the purposes of this subchapter, may purchase renewable fuels, including biomass.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbea04aea-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2612"},"text":"Pub. L. 97–35, title XXVI, § 2612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s121/b"},"text":"Pub. L. 109–58, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/616"},"text":"119 Stat. 616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea04aeb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea04aec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbea04aed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s121/c"},"text":"Pub. L. 109–58, title I, § 121(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/616"},"text":"119 Stat. 616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/58/tI/s121/c"},"text":"“The Secretary [of Energy] shall report to Congress on the use of renewable fuels in providing assistance under the Low-Income Home Energy Assistance Act of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"42 U.S.C. 8621","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
