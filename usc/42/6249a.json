{"tag":"section","attrib":{"id":"idbd76226c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6249a"},"text":"§ 6249a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd76226d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (b) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/21"},"text":"Pub. L. 106–469, title I, § 103(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2033"},"text":"114 Stat. 2033","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd76226e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal status regarding other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Petroleum product and facilities contracted for under this part have the same status as petroleum product and facilities owned by the United States for all purposes associated with the exercise of the laws of any State or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd76226f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At such time as the petroleum product contracted for under this part is withdrawn from the Reserve upon the expiration, termination, or other conclusion of the contract, such petroleum product (or the equivalent quantity of petroleum product withdrawn from the Reserve pursuant to the contract) shall be deemed, for purposes of determining the extent to which such product is thereafter subject to any Federal, State, or local law or regulation, not to have left the place where such petroleum product was located at the time it was originally committed to a contract under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd762270-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s172"},"text":"Pub. L. 94–163, title I, § 172","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/383/s6/a/4"},"text":"Pub. L. 101–383, § 6(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-15"},"text":"Sept. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/730"},"text":"104 Stat. 730","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/21"},"text":"Pub. L. 106–469, title I, § 103(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2033"},"text":"114 Stat. 2033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd762271-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd762272-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd762273-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469"},"text":"Pub. L. 106–469","children":[],"tail":" struck out subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Amendment to Plan Not Required","children":[],"tail":".—An amendment of the Strategic Petroleum Reserve Plan is not required for any action taken under this part."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Fill Rate Requirement","children":[],"tail":".—For purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6240/d/1"},"text":"section 6240(d)(1) of this title","children":[],"tail":", any petroleum product stored in the Reserve under this part that is removed from the Reserve at the expiration, termination, or other conclusion of the agreement shall be considered to be part of the Reserve until the beginning of the fiscal year following the fiscal year in which the petroleum product was removed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
