{"tag":"section","attrib":{"id":"idbe28f7a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417"},"text":null,"children":[{"tag":"num","attrib":{"value":"7417"},"text":"§ 7417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe28f7a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to obtain assistance in the development and implementation of the purposes of this chapter including air quality criteria, recommended control techniques, standards, research and development, and to encourage the continued efforts on the part of industry to improve air quality and to develop economically feasible methods for the control and abatement of air pollution, the Administrator shall from time to time establish advisory committees. Committee members shall include, but not be limited to, persons who are knowledgeable concerning air quality from the standpoint of health, welfare, economics or technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe28f7a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of any other advisory committees appointed pursuant to this chapter who are not officers or employees of the United States while attending conferences or meetings or while otherwise serving at the request of the Administrator, shall be entitled to receive compensation at a rate to be fixed by the Administrator, but not exceeding $100 per diem, including traveltime, and while away from their homes or regular places of business they may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons in the Government service employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe28f7a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003612"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003612"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" Consultations by Administrator"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe28f7a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing criteria for an air pollutant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408/a/2"},"text":"section 7408(a)(2) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe28f7a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing any list under section 7411(b)(1)(A) or section 7412(b)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn003613"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003613"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe28f7a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing any standard under section 7411 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7412"},"text":"section 7412 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe28f7a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7417/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing any regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521/a"},"text":"section 7521(a) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Administrator shall, to the maximum extent practicable within the time provided, consult with appropriate advisory committees, independence experts, and Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe28f7aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 117 formerly § 6, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/206/s1"},"text":"Pub. L. 88–206, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-17"},"text":"Dec. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/399"},"text":"77 Stat. 399","children":[],"tail":