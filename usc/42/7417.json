:"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe28f7ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7412(b)(1), referred to in subsec. (c)(2), was amended generally by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/tIII/s301"},"text":"Pub. L. 101–549, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2531"},"text":"104 Stat. 2531","children":[],"tail":", and, as so amended, no longer contains a subpar. (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe28f7ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) was originally enacted as subsec. (f) but has been redesignated (c) for purposes of codification in view of the failure of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" to redesignate subsec. (f) as (c) after repealing former subsecs. (a) and (b) and redesignating former subsecs. (d) and (e) as (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857e"},"text":"section 1857e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe28f7af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/623"},"text":"Pub. L. 95–623","children":[],"tail":" substituted “7411” for “7411(b)(1)(B)” and “7412” for “7412(b)(1)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s115/1"},"text":"Pub. L. 95–95, § 115(1)","children":[],"tail":", (2), redesignated subsec. (d) as (a). Former subsec. (a), establishing an Air Quality Advisory Board in the Environmental Protection Agency, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s115/1"},"text":"Pub. L. 95–95, § 115(1)","children":[],"tail":"–(3), redesignated subsec. (e) as (b) and substituted “The members of any other advisory committees” for “The members of the Board and other advisory committees” and “conferences or meetings or while otherwise serving” for “conferences or meetings of the Board or while otherwise serving”. Former subsec. (b), setting out the duties of the Air Quality Advisory Board, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s115/1"},"text":"Pub. L. 95–95, § 115(1)","children":[],"tail":", (2), struck out subsec. (c) which related to clerical and technical assistance for the Air Quality Advisory Board, and redesignated subsecs. (d) and (e) as (a) and (b), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Environmental Protection Agency” for “Department of Health, Education, and Welfare” and “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Environmental Protection Agency” for “Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s4/d"},"text":"Pub. L. 91–604, § 4(d)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" substituted provisions establishing in the Department of Health, Education, and Welfare an Air Quality Advisory Board and providing for the appointment and term of its members for provisions directing the Secretary to maintain liaison with manufacturers looking toward development of devices and fuels to reduce pollutants in automotive exhaust and to appoint a technical committee and call it together from time to time to evaluate progress and develop and recommend research programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" substituted provision setting out the duties of the Air Quality Advisory Board for provisions requiring the Secretary to make semi-annual reports to Congress on measures being taken toward the resolution of vehicle exhaust pollution problems."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"ta