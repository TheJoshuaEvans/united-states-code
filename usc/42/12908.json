{"tag":"section","attrib":{"id":"idbfab5314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908"},"text":null,"children":[{"tag":"num","attrib":{"value":"12908"},"text":"§ 12908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfab5315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab5316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section may be used only for assistance to provide rental assistance for low-income eligible persons. Such assistance may be project based or tenant based and shall be provided to the extent practicable in the manner provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":". Grantees shall ensure that the housing provided is decent, safe, and sanitary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shared housing arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section may be used to assist individuals who elect to reside in shared housing arrangements in the manner provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/p"},"text":"section 1437f(p) of this title","children":[],"tail":", except that, notwithstanding such section, assistance under this section may be made available to nonelderly individuals. The Secretary shall issue any standards for shared housing under this paragraph that vary from standards issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/p"},"text":"section 1437f(p) of this title","children":[],"tail":" only to the extent necessary to provide for circumstances of shared housing arrangements under this paragraph that differ from circumstances of shared housing arrangements for elderly families under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/p"},"text":"section 1437f(p) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab5318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient under this section shall comply with the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab5319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall provide for qualified service providers in the area to provide appropriate services to the eligible persons assisted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab531a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intensive assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any individual with acquired immunodeficiency syndrome or related diseases who requires more care than can be provided in housing assisted under this section, the recipient shall provide for the locating of a care provider who can appropriately care for the individual and referral of the individual to the care provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab531b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project sponsor providing rental assistance under this section may use amounts from any grant received under this section for administrative expenses involved in providing such assistance, subject to the provisions of 12905(g)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn004141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab531c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s859"},"text":"Pub. L. 101–625, title VIII, § 859","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4381"},"text":"104 Stat. 4381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/h/1"},"text":"Pub. L. 102–550, title VI, § 606(h)(1)","children":[],"tail":", (j)(6), (7), (11)(D), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3810"},"text":"106 Stat. 3810","children":[],"tail":", 3811.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab531d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab531e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab531f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/h/1/A"},"text":"Pub. L. 102–550, § 606(h)(1)(A)","children":[],"tail":", substituted “Rental assistance” for “Short-term rental assistance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/h/1/B"},"text":"Pub. L. 102–550, § 606(h)(1)(B)","children":[],"tail":", (j)(11)(D), struck out “short-term” before “rental assistance” and substituted “eligible persons” for “individuals with acquired immunodeficiency syndrome or related diseases”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/j/6"},"text":"Pub. L. 102–550, § 606(j)(6)","children":[],"tail":", substituted “eligible persons” for “individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/j/7"},"text":"Pub. L. 102–550, § 606(j)(7)","children":[],"tail":", inserted “with acquired immunodeficiency syndrome or related diseases” after “any individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/h/1/C"},"text":"Pub. L. 102–550, § 606(h)(1)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
