{"tag":"section","attrib":{"id":"idbc559768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030c–1"},"text":"§ 3030c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights relating to in-home services for frail older individuals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall require entities that provide in-home services under this subchapter to promote the rights of each older individual who receives such services. Such rights include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc559769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The right—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc55976a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be fully informed in advance about each in-home service provided by such entity under this subchapter and about any change in such service that may affect the well-being of such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc55976b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in planning and changing an in-home service provided under this subchapter by such entity unless such individual is judicially adjudged incompetent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc55976c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to voice a grievance with respect to such service that is or fails to be so provided, without discrimination or reprisal as a result of voicing such grievance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc55976d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to confidentiality of records relating to such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc55976e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to have the property of such individual treated with respect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc55976f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030c–1/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be fully informed (orally and in writing), in advance of receiving an in-home service under this subchapter, of such individual’s rights and obligations under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc559770-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s314"},"text":"Pub. L. 89–73, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tIII/s311"},"text":"Pub. L. 102–375, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1237"},"text":"106 Stat. 1237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(11), 3(a)(13), "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1989"},"text":"107 Stat. 1989","children":[],"tail":", 1990.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc559771-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc559772-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc559773-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" struck out “(a) "},{"tag":"inline","attrib":{},"text":"Promotion","children":[],"tail":".—” before “The Assistant” and substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
