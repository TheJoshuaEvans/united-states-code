{"tag":"section","attrib":{"id":"idc075f5b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033"},"text":null,"children":[{"tag":"num","attrib":{"value":"19033"},"text":"§ 19033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc075f5b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on resource needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall provide a report to the Committee on Science, Space, and Technology of the House of Representatives, the Committee on Commerce, Science, and Transportation of the Senate, the Committee on Appropriations of the House of Representatives, and the Committee on Appropriations of the Senate on the resources and the number of full time "},{"tag":"ref","attrib":{"idref":"fn004389"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004389"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “full-time”."}],"tail":" employees needed to carry out the functions of the office established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s19031"},"text":"section 19031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc075f5ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on Office activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f5bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and annually thereafter, the Director shall submit to Congress a report on the activities carried out by the Office of Research Security, detailing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f5bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities conducted by the Office, including administrative actions taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f5bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations as the Director may have for legislative or administrative action relating to improving research security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f5be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and discussion of the gaps in legal authorities that need to be improved to enhance the security of institutions of higher education performing research supported by the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f5bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on Foundation Inspector General cases, as appropriate, relating to undue influence and security threats to research and development activities funded by the Foundation, including theft of property or intellectual property relating to a project funded by the Foundation at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f5c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report submitted under paragraph (1) shall be submitted in both unclassified and classified formats, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc075f5c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10333"},"text":"Pub. L. 117–167, div. B, title III, § 10333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1552"},"text":"136 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
