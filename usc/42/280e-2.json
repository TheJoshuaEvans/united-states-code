{"tag":"section","attrib":{"id":"idb530d353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"280e–2"},"text":"§ 280e–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance in operations of statewide cancer registries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control, may, directly or through grants and contracts, or both, provide technical assistance to the States in the establishment and operation of statewide registries, including assistance in the development of model legislation for statewide cancer registries and assistance in establishing a computerized reporting and data processing system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb530d354-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399D, formerly § 399J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/515/s3"},"text":"Pub. L. 102–515, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3376"},"text":"106 Stat. 3376","children":[],"tail":"; renumbered § 399D, "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tV/s502/2/A"},"text":"Pub. L. 106–310, div. A, title V, § 502(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1115"},"text":"114 Stat. 1115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb530d355-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topi