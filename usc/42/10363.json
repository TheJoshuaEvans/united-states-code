{"tag":"section","attrib":{"id":"idbf235e15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363"},"text":null,"children":[{"tag":"num","attrib":{"value":"10363"},"text":"§ 10363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reclamation climate change and water program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf235e16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a climate change adaptation program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf235e17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with the Administrator and other appropriate agencies to assess each effect of, and risk resulting from, global climate change with respect to the quantity of water resources located in a service area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure, to the maximum extent possible, that strategies are developed at watershed and aquifer system scales to address potential water shortages, conflicts, and other impacts to water users located at, and the environment of, each service area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf235e19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program described in subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf235e1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the United States Geological Survey, the National Oceanic and Atmospheric Administration, the program, and each appropriate State water resource agency, to ensure that the Secretary has access to the best available scientific information with respect to presently observed and projected future impacts of global climate change on water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess specific risks to the water supply of each major reclamation river basin, including any risk relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in snowpack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in the timing and quantity of runoff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in groundwater recharge and discharge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any increase in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235e20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for water as a result of increasing temperatures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of reservoir evaporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each major reclamation river basin, analyze the extent to which changes in the water supply of the United States will impact—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Secretary to deliver water to the contractors of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydroelectric power generation facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreation at reclamation facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish and wildlife habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable species listed as an endangered, threatened, or candidate species under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality issues (including salinity levels of each major reclamation river basin);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flow and water dependent ecological resiliency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood control management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with appropriate non-Federal participants, consider and develop appropriate strategies to mitigate each impact of water supply changes analyzed by the Secretary under paragraph (3), including strategies relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification of any reservoir storage or operating guideline in existence as of ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of new water management, operating, or habitat restoration plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved hydrologic models and other decision support systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater and surface water storage needs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with the Director, the Administrator, the Secretary of Agriculture (acting through the Chief of the Natural Resources Conservation Service), and applicable State water resource agencies, develop a monitoring plan to acquire and maintain water resources data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the understanding of water supply trends; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in each assessment and analysis conducted by the Secretary under paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf235e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", and every 5 years thereafter, the Secretary shall submit to the appropriate committees of Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf235e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each effect of, and risk resulting from, global climate change with respect to the quantity of water resources located in each major reclamation river basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of global climate change with respect to the operations of the Secretary in each major reclamation river basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each mitigation and adaptation strategy considered and implemented by the Secretary to address each effect of global climate change described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each coordination activity conducted by the Secretary with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture (acting through the Chief of the Natural Resources Conservation Service); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appropriate State water resource agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation by the Secretary of the monitoring plan developed under subsection (b)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf235e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf235e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with any non-Federal participant, may conduct 1 or more studies to determine the feasibility and impact on ecological resiliency of implementing each mitigation and adaptation strategy described in subsection (c)(3), including the construction of any water supply, water management, environmental, or habitat enhancement water infrastructure that the Secretary determines to be necessary to address the effects of global climate change on water resources located in each major reclamation river basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235e42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the Federal share of the cost of a study described in paragraph (1) shall not exceed 50 percent of the cost of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235e43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to financial hardship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may increase the Federal share of the cost of a study described in paragraph (1) to exceed 50 percent of the cost of the study if the Secretary determines that, due to a financial hardship, the non-Federal participant of the study is unable to contribute an amount equal to 50 percent of the cost of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235e44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of a study described in paragraph (1) may be provided in the form of any in-kind services that substantially contribute toward the completion of the study, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf235e45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on existing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section amends or otherwise affects any existing authority under reclamation laws that govern the operation of any Federal reclamation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf235e46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10363/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2009 through 2023,","children":[{"tag":"ref","attrib":{"idref":"fn003960"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003960"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Extension of Authorization of Appropriations note below."}],"tail":" to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf235e47-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9503"},"text":"Pub. L. 111–11, title IX, § 9503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1332"},"text":"123 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf235e48-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf235e49-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf235e4a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (b)(3)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf235e4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf235e4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dB/tII/s207"},"text":"Pub. L. 119–74, div. B, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/74"},"text":"140 Stat. 74","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/74/dB/tII/s207"},"text":"“Section 9503(f) of the Omnibus Public Land Management Act of 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10363/f"},"text":"42 U.S.C. 10363(f)","children":[],"tail":") shall be applied by substituting ‘2026’ for ‘2023’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dD/tII/s207"},"text":"Pub. L. 118–42, div. D, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/195"},"text":"138 Stat. 195","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
