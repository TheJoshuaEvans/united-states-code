{"tag":"section","attrib":{"id":"idc04d85b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053"},"text":null,"children":[{"tag":"num","attrib":{"value":"18053"},"text":"§ 18053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to offering of plans in more than one State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04d85b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care choice compacts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04d85b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", the Secretary shall, in consultation with the National Association of Insurance Commissioners, issue regulations for the creation of health care choice compacts under which 2 or more States may enter into an agreement under which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04d85b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more qualified health plans could be offered in the individual markets in all such States but, except as provided in subparagraph (B), only be subject to the laws and regulations of the State in which the plan was written or issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04d85b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the issuer of any qualified health plan to which the compact applies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04d85b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would continue to be subject to market conduct, unfair trade practices, network adequacy, and consumer protection standards (including standards relating to rating), including addressing disputes as to the performance of the contract, of the State in which the purchaser resides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04d85b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be required to be licensed in each State in which it offers the plan under the compact or to submit to the jurisdiction of each such State with regard to the standards described in clause (i) (including allowing access to records as if the insurer were licensed in the State); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04d85b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must clearly notify consumers that the policy may not be subject to all the laws and regulations of the State in which the purchaser resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04d85b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not enter into an agreement under this subsection unless the State enacts a law after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", that specifically authorizes the State to enter into such agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04d85b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of compacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve interstate health care choice compacts under paragraph (1) only if the Secretary determines that such health care choice compact—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04d85ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide coverage that is at least as comprehensive as the coverage defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18022/b"},"text":"section 18022(b) of this title","children":[],"tail":" and offered through Exchanges established under this title; "},{"tag":"ref","attrib":{"idref":"fn004322"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004322"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04d85bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide coverage and cost sharing protections against excessive out-of-pocket spending that are at least as affordable as the provisions of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" would provide;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04d85bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide coverage to at least a comparable number of its residents as the provisions of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" would provide;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04d85bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not increase the Federal deficit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04d85be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not weaken enforcement of laws and regulations described in paragraph (1)(B)(i) in any State that is included in such compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04d85bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health care choice compact described in paragraph (1) shall not take effect before ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04d85c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10104/p"},"text":"Pub. L. 111–148, title X, § 10104(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/902"},"text":"124 Stat. 902","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04d85c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1333"},"text":"Pub. L. 111–148, title I, § 1333","children":[],"tail":", title X, § 10104(p), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/206"},"text":"124 Stat. 206","children":[],"tail":", 902.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04d85c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04d85c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc04d85c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, where footnoted in subsec. (a)(3)(A) to (C), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc04d85c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104/p"},"text":"Pub. L. 111–148, § 10104(p)","children":[],"tail":", struck out subsec. (b) which provided authority and requirements for health insurance issuers to offer nationwide qualified health plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
