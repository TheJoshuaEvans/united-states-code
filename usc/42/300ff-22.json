{"tag":"section","attrib":{"id":"idb69434b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–22"},"text":"§ 300ff–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General use of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69434b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may use amounts provided under grants made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69434b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core medical services described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative expenses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/b/3"},"text":"section 300ff–28(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69434b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required funding for core medical services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69434b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" for a State for a grant year, the State shall, of the portion of the grant remaining after reserving amounts for purposes of subparagraphs (A) and (E)(ii)(I) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/b/3"},"text":"section 300ff–28(b)(3) of this title","children":[],"tail":", use not less than 75 percent to provide core medical services that are needed in the State for individuals with HIV/AIDS who are identified and eligible under this subchapter (including services regarding the co-occurring conditions of the individuals)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69434b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive the application of paragraph (1) with respect to a State for a grant year if the Secretary determines that, within the State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb69434b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are no waiting lists for AIDS Drug Assistance Program services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–26"},"text":"section 300ff–26 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb69434ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core medical services are available to all individuals with HIV/AIDS identified and eligible under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of waiver status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When informing a State that a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" is being made to the State for a fiscal year, the Secretary shall inform the State whether a waiver under subparagraph (A) is in effect for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core medical services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “core medical services”, with respect to an individual infected with HIV/AIDS (including the co-occurring conditions of the individual) means the following services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69434bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outpatient and ambulatory health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" AIDS Drug Assistance Program treatments in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–26"},"text":"section 300ff–26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" AIDS pharmaceutical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oral health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Early intervention services described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health insurance premium and cost sharing assistance for low-income individuals in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–25"},"text":"section 300ff–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical nutrition therapy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospice services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home and community-based health services as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–24/c"},"text":"section 300ff–24(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substance abuse outpatient care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/b/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical case management, including treatment adherence services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69434ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69434cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “support services” means services, subject to the approval of the Secretary, that are needed for individuals with HIV/AIDS to achieve their medical outcomes (such as respite care for persons caring for individuals with HIV/AIDS, outreach services, medical transportation, linguistic services, and referrals for health care and support services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of medical outcomes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “medical outcomes” means those outcomes affecting the HIV-related clinical status of an individual with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69434cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69434ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “early intervention services” means HIV/AIDS early intervention services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51/e"},"text":"section 300ff–51(e) of this title","children":[],"tail":", with follow-up referral provided for the purpose of facilitating the access of individuals receiving the services to HIV-related health services. The entities through which such services may be provided under the grant include public health departments, emergency rooms, substance abuse and mental health treatment programs, detoxification centers, detention facilities, clinics regarding sexually transmitted diseases, homeless shelters, HIV/AIDS counseling and testing sites, health care points of entry specified by States, federally qualified health centers, and entities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/a"},"text":"section 300ff–52(a) of this title","children":[],"tail":" that constitute a point of access to services by maintaining referral relationships."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an entity that proposes to provide early intervention services under paragraph (1), such paragraph shall apply only if the entity demonstrates to the satisfaction of the chief elected official for the State involved that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69434d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, or local funds are otherwise inadequate for the early intervention services the entity proposes to provide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69434d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity will expend funds pursuant to such subparagraph to supplement and not supplant other funds available to the entity for the provision of early intervention services for the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69434d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for women, infants, children, and youth","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69434d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of providing health and support services to infants, children, youth, and women with HIV/AIDS, including treatment measures to prevent the perinatal transmission of HIV, a State shall for each of such populations in the eligible area use, from the grants made for the area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11/a"},"text":"section 300ff–11(a) of this title","children":[],"tail":" for a fiscal year, not less than the percentage constituted by the ratio of the population involved (infants, children, youth, or women in such area) with HIV/AIDS to the general population in such area of individuals with HIV/AIDS."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69434d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the population involved, the Secretary may provide to a State a waiver of the requirement of paragraph (1) if such State demonstrates to the satisfaction of the Secretary that the population is receiving HIV-related health services through the State medicaid program under title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.], the State children’s health insurance program under title XXI of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.], or other Federal or State programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69434d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–22/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not use amounts received under a grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":" to purchase or improve land, or to purchase, construct, or permanently improve (other than minor remodeling) any building or other facility, or to make cash payments to intended recipients of services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69434d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2612, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tII/s201"},"text":"Pub. L. 101–381, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/586"},"text":"104 Stat. 586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/2"},"text":"Pub. L. 104–146, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1354"},"text":"110 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tII/s202"},"text":"Pub. L. 106–345, title II, § 202","children":[],"tail":", title V, § 503(b), "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1330"},"text":"114 Stat. 1330","children":[],"tail":", 1355; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII/s201/a"},"text":"Pub. L. 109–415, title II, § 201(a)","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2785"},"text":"120 Stat. 2785","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69434d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69434d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb69434d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XIX and XXI of the Act are classified generally to subchapters XIX (§ 1396 et seq.) and XXI (§ 1397aa et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb69434da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/2"},"text":"section 3(c)(2) of Pub. L. 104–146","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–23"},"text":"section 300ff–23 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb69434db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2612 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238k"},"text":"section 238k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69434dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s201/a"},"text":"Pub. L. 109–415, § 201(a)","children":[],"tail":", reenacted section catchline without change and amended text generally, substituting provisions relating to general use of grants, required funding for core medical services, support and early intervention services, priority for women, infants, children, and youth, and prohibition against use of amounts for real property improvement or to make cash payments, for provisions relating to general use of grants, support services and outreach, early intervention services, and establishment of a quality management program in each State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s202/1"},"text":"Pub. L. 106–345, § 202(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s503/b"},"text":"Pub. L. 106–345, § 503(b)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/2/A/iii"},"text":"Pub. L. 104–146, § 3(c)(2)(A)(iii)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s202/2"},"text":"Pub. L. 106–345, § 202(2)","children":[],"tail":", added subsecs. (b) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/2/A"},"text":"Pub. L. 104–146, § 3(c)(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/s503/b"},"text":"Pub. L. 106–345, § 503(b)","children":[],"tail":", struck out “(a) In general” before “A State may use amounts”, added par. (1), redesignated former pars. (1) to (4) as (2) to (5), respectively, substituted “therapeutics to treat HIV disease” for “treatments, that have been determined to prolong life or prevent serious deterioration of health,” in par. (5), and inserted after par. (5) “Services described in paragraph (1) shall be delivered through consortia designed as described in paragraph (2), where such consortia exist, unless the State demonstrates to the Secretary that delivery of such services would be more effective when other delivery mechanisms are used. In making a determination regarding the delivery of services, the State shall consult with appropriate representatives of service providers and recipients of services who would be affected by such determination, and shall include in its demonstration to the Secretary the findings of the State regarding such consultation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/c/2/B"},"text":"Pub. L. 104–146, § 3(c)(2)(B)","children":[],"tail":", struck out heading and text of subsec. (b). Text read as follows: “A State shall use not less than 15 percent of funds allocated under this part to provide health and support services to infants, children, women, and families with HIV disease.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69434dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69434de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69434df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
