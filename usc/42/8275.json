{"tag":"section","attrib":{"id":"idbe8d3843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8275"},"text":null,"children":[{"tag":"num","attrib":{"value":"8275"},"text":"§ 8275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall administer the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8272"},"text":"section 8272 of this title","children":[],"tail":" and shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d3844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8275/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Defense to insure that the installation and purchase of photovoltaic solar electric systems pursuant to this part shall not interfere with defense-related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8275/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such requirements as may be appropriate to monitor and assess the performance and operation of photovoltaic electric systems installed pursuant to this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8275/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report annually to the Congress on the status of the program.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall not be subject to the requirements of ","chi