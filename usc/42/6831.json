{"tag":"section","attrib":{"id":"idbdbb4268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831"},"text":null,"children":[{"tag":"num","attrib":{"value":"6831"},"text":"§ 6831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbb4269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb426a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large amounts of fuel and energy are consumed unnecessarily each year in heating, cooling, ventilating, and providing domestic hot water for newly constructed residential and commercial buildings because such buildings lack adequate energy conservation features;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb426b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal voluntary performance standards for newly constructed buildings can prevent such waste of energy, which the Nation can no longer afford in view of its current and anticipated energy shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb426c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure to provide adequate energy conservation measures in newly constructed buildings increases long-term operating costs that may affect adversely the repayment of, and security for, loans made, insured, or guaranteed by Federal agencies or made by federally insured or regulated instrumentalities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb426d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local building codes or similar controls can provide an existing means by which to assure, in coordination with other building requirements and with a minimum of Federal interference in State and local transactions, that newly constructed buildings contain adequate energy conservation features.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbb426e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this subchapter, therefore, are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb426f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redirect Federal policies and practices to assure that reasonable energy conservation features will be incorporated into new commercial and residential buildings receiving Federal financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development and implementation, as soon as practicable, of voluntary performance standards for new residential and commercial buildings which are designed to achieve the maximum practicable improvements in energy efficiency and increases in the use of nondepletable sources of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6831/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage States and local governments to adopt and enforce such standards through their existing building codes and other construction control mechanisms, or to apply them through a special approval process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb4272-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s302"},"text":"Pub. L. 94–385, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1144"},"text":"90 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1041/a"},"text":"Pub. L. 97–35, title X, § 1041(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/621"},"text":"95 Stat. 621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb4273-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb4274-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb4275-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsecs. (a)(2), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" inserted “voluntary” before “performance standards”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdbb4276-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbdbb4277-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1038"},"text":"section 1038 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6240"},"text":"section 6240 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbdbb4278-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Energy Conservation Standards for New Buildings Act of 1976”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/s301"},"text":"section 301 of Pub. L. 94–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6801"},"text":"section 6801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
