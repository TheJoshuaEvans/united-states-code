{"tag":"section","attrib":{"id":"idbcf09f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5026"},"text":null,"children":[{"tag":"num","attrib":{"value":"5026"},"text":"§ 5026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments to Federal financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf09f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf09f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the amount of Federal financial assistance to be provided under this subchapter to applicants, the Director shall consider the impact of changes in the Consumer Price Index For All Urban Consumers published by the Bureau of Labor Statistics of the Department of Labor on the administrative costs of operating the projects for which such assistance will be provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall, to the fullest extent practicable, make appropriate adjustments in the amount referred to in paragraph (1) to ensure the effective administration of such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall take reasonable actions to inform applicants for such assistance that such adjustments may be available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf09f3d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s226"},"text":"Pub. L. 93–113, title II, § 226","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tV/s506"},"text":"Pub. L. 101–204, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1818"},"text":"103 Stat. 1818","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s350"},"text":"Pub. L. 103–82, title III, § 350","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/906"},"text":"107 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2011"},"text":"Pub. L. 104–66, title II, § 2011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/726"},"text":"109 Stat. 726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf09f3e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf09f3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf09f40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" in subsec. (a), redesignated par. (1)(A) as (1), redesignated par. (1)(B) as (2) and substituted “paragraph (1)” for “subparagraph (A)” after “referred to in”, redesignated former par. (2) as subsec. (b), and struck out former subsec. (b) which read as follows: “The Director shall submit, once every 2 years, to the Committee on Education and Labor of the House of Representatives and the Committee on Labor and Human Resources of the Senate, a report on the extent to which adjustments are made under subsection (a) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" struck out par. (1) designation before “The Director shall”, substituted “, once every 2 years” for “annually”, and struck out par. (2) which read as follows: “With respect to each of parts A, B, and C of this subchapter, the Director shall include in such report—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a summary of the number of, and purposes for which, such adjustments are requested by the recipients of grants and contracts under parts A, B, and C of this subchapter, respectively;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a description of the extent that such requests are accommodated; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) a statement explaining the decisions made by the Director with respect to the requested adjustments.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf09f41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf09f42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s392"},"text":"section 392 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"section 4951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
