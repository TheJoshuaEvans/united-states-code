{"tag":"section","attrib":{"id":"idbe07b531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7382e"},"text":"§ 7382e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waste management education research consortium (WERC)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003579"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003579"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish a partnership of Department of Energy laboratories, academic institutions, and private sector industries to conduct environmentally-related education programs, including programs involving environmentally conscious manufacturing and waste management activities that have undergraduate and graduate educational training as a component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b533-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s517"},"text":"Pub. L. 103–382, title V, § 517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4044"},"text":"108 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
