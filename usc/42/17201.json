{"tag":"section","attrib":{"id":"idc02e64a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17201"},"text":null,"children":[{"tag":"num","attrib":{"value":"17201"},"text":"§ 17201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed as waiving, modifying, or superseding the applicability of any requirement under any environmental or other Federal or State law. To the extent that activities authorized in this part take place in coastal and ocean areas, the Secretary shall consult with the Secretary of Commerce, acting through the Under Secretary of Commerce for Oceans and Atmosphere, regarding the potential marine environmental impacts and measures to address such impacts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc02e64a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s622"},"text":"Pub. L. 110–140, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1684"},"text":"121 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e64a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02e64a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02e64a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
