{"tag":"section","attrib":{"id":"idb6a4d687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–136"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–136"},"text":"§ 300ff–136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of designated officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of receiving notifications and responses and making requests under this part on behalf of emergency response employees, the public health officer of each State shall designate 1 official or officer of each employer of emergency response employees in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in making designations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making the designations required in subsection (a), a public health officer shall give preference to individuals who are trained in the provision of health care or in the control of infectious diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d68a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2695E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s13"},"text":"Pub. L. 111–87, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2901"},"text":"123 Stat. 2901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d68b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d68c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d68d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
