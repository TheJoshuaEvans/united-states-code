{"tag":"section","attrib":{"id":"idb61825e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–42"},"text":"§ 300d–42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences in making grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb61825ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial uncompensated care awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61825eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an award basis for each eligible trauma center for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/1"},"text":"section 300d–41(a)(1) of this title","children":[],"tail":" according to the percentage described in paragraph (2), subject to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/b/3"},"text":"section 300d–41(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61825ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The applicable percentages are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61825ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a category A trauma center, 100 percent of the uncompensated care costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61825ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a category B trauma center, not more than 75 percent of the uncompensated care costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61825ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to a category C trauma center, not more than 50 percent of the uncompensated care costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61825f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core mission awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61825f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002331"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002331"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/2"},"text":"section 300d–41(a)(2) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61825f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 25 percent of the amount allocated for core mission awards for Level III and Level IV trauma centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61825f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reserve 25 percent of the amount allocated for core mission awards for large urban Level I and II trauma centers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb61825f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have at least 1 graduate medical education fellowship in trauma or trauma related specialties for which demand is exceeding supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61825f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb61825f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual uncompensated care costs exceed $10,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb61825f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 20 percent of emergency department visits are charity or self-pay or Medicaid patients; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61825f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are not eligible for substantial uncompensated care awards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/1"},"text":"section 300d–41(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61825f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/3"},"text":"section 300d–41(a)(3) of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61825fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give preference to any application submitted by a trauma center that provides trauma care in a geographic area in which the availability of trauma care has significantly decreased or will significantly decrease if the center is forced to close or downgrade service or growth in demand for trauma services exceeds capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61825fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–42/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reallocate any emergency awards funds not obligated due to insufficient, or a lack of qualified, applications to the significant uncompensated care award program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb61825fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1242, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tVI/s601"},"text":"Pub. L. 102–321, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/434"},"text":"106 Stat. 434","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3505/a/2"},"text":"Pub. L. 111–148, title III, § 3505(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/523"},"text":"124 Stat. 523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb61825fd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb61825fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb61825ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added subsecs. (a) to (c) and struck out former subsecs. (a) and (b) which related to preferences in making grants and preferences for certain applications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6182600-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6182601-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", with programs making awards providing financial assistance in fiscal year 1993 and subsequent years effective for awards made on or after "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", see section 801(b), (d)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
