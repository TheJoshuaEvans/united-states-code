{"tag":"section","attrib":{"id":"idbdf4a207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7144d"},"text":"§ 7144d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Arctic Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf4a208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may establish within the Department of Energy an Office of Arctic Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf4a209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of such office shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf4a20a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote research, development, and deployment of electric power technology that is cost-effective and especially well suited to meet the needs of rural and remote regions of the United States, especially where permafrost is present or located nearby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf4a20b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To promote research, development, and deployment in such regions of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf4a20c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced oil recovery technology, including heavy oil recovery, reinjection of carbon, and extended reach drilling technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf4a20d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas-to-liquids technology and liquified natural gas (including associated transportation systems);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf4a20e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small hydroelectric facilities, river turbines, and tidal power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf4a20f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas hydrates, coal bed methane, and shallow bed natural gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf4a210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative energy, including wind, geothermal, and fuel cells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf4a211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall locate such office at a university with expertise and experience in the matters specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf4a212-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXI/s3197"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXI, § 3197]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–482.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf4a213-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf4a214-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf4a215-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
