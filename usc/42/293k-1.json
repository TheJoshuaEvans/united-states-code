{"tag":"section","attrib":{"id":"idb5da3363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"293k–1"},"text":"§ 293k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training opportunities for direct care workers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5da3364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to eligible entities to enable such entities to provide new training opportunities for direct care workers who are employed in long-term care settings such as nursing homes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396g/e/1"},"text":"section 1396g(e)(1) of this title","children":[],"tail":"), assisted living facilities and skilled nursing facilities, intermediate care facilities for individuals with mental retardation, home and community based settings, and any other setting the Secretary determines to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da3365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da3366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":") that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5da3367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited by a nationally recognized accrediting agency or association listed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/c"},"text":"section 1001(c) of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5da3368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has established a public-private educational partnership with a nursing home or skilled nursing facility, agency or entity providing home and community based services to individuals with disabilities, or other long-term care provider; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da3369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da336a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use amounts awarded under a grant under this section to provide assistance to eligible individuals to offset the cost of tuition and required fees for enrollment in academic programs provided by such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da336b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5da336c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under this section, an individual shall be enrolled in courses provided by a grantee under this subsection and maintain satisfactory academic progress in such courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5da336d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving assistance under this section, an individual shall agree that, following completion of the assistance period, the individual will work in the field of geriatrics, disability services, long term services and supports, or chronic care management for a minimum of 2 years under guidelines set by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5da336e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s293k–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $10,000,000 for the period of fiscal years 2011 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5da336f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 747A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5302"},"text":"Pub. L. 111–148, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/617"},"text":"124 Stat. 617","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
