{"tag":"section","attrib":{"id":"idbf12bb9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10143"},"text":null,"children":[{"tag":"num","attrib":{"value":"10143"},"text":"§ 10143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title to material","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Delivery, and acceptance by the Secretary, of any high-level radioactive waste or spent nuclear fuel for a repository constructed under this part shall constitute a transfer to the Secretary of title to such waste or spent fuel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf12bb9f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s123"},"text":"Pub. L. 97–425, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2229"},"text":"96 Stat. 2229","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
