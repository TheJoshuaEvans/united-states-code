{"tag":"section","attrib":{"id":"idbc369db0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2996j"},"text":"§ 2996j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special limitations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Corporation shall prescribe procedures to insure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc369db1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance under this subchapter shall not be suspended unless the grantee, contractor, or person or entity receiving financial assistance under this subchapter has been given reasonable notice and opportunity to show cause why such action should not be taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc369db2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance under this subchapter shall not be terminated, an application for refunding shall not be denied, and a suspension of financial assistance shall not be continued for longer than thirty days, unless the grantee, contractor, or person or entity receiving financial assistance under this subchapter has been afforded reasonable notice and opportunity for a timely, full, and fair hearing, and, when requested, such hearing shall be conducted by an independent hearing examiner. Such hearing shall be held prior to any final decision by the Corporation to terminate financial assistance or suspend or deny funding. Hearing examiners shall be appointed by the Corporation in accordance with procedures established in regulations promulgated by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc369db3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tX/s1011"},"text":"Pub. L. 88–452, title X, § 1011","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/355/s2"},"text":"Pub. L. 93–355, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/388"},"text":"88 Stat. 388","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/222/s16"},"text":"Pub. L. 95–222, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1624"},"text":"91 Stat. 1624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc369db4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc369db5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc369db6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/222"},"text":"Pub. L. 95–222","children":[],"tail":" inserted provisions relating to function and appointment of an independent hearing examiner, and the time for any hearings."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc369db7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":