l":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/tIX/s913/e"},"text":"Pub. L. 96–499, title IX, § 913(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2620"},"text":"94 Stat. 2620","children":[],"tail":", related to State programs for social services assistance, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2352/a"},"text":"section 2352(a) of Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaa85d3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" added par. (7) and struck out former par. (7) which read as follows: “$2,380,000,000 for each of the fiscal years 1997 through 2002; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" added par. (8) and struck out former par. (8) which read as follows: “$2,380,000,000 for the fiscal year 1998;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" added par. (8) and struck out former par. (8) which read as follows: “$2,800,000,000 for the fiscal year 2003 and each succeeding fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" added pars. (9) to (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" added pars. (5) to (8) and struck out former par. (5) which read as follows: “$2,800,000,000 for each fiscal year after fiscal year 1989.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s8016/1"},"text":"Pub. L. 101–239, § 8016(1)","children":[],"tail":", substituted “1987, and 1989;” for “and 1987, and for each succeeding fiscal year other than the fiscal year 1988; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s8016/2"},"text":"Pub. L. 101–239, § 8016(2)","children":[],"tail":", (3), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9135/a/2/A"},"text":"Pub. L. 100–203, § 9135(a)(2)(A)","children":[],"tail":", inserted at end “The allotment for fiscal year 1989 and each succeeding fiscal year to American Samoa shall be an amount which bears the same ratio to the amount allotted to the Northern Mariana Islands for that fiscal year as the population of American Samoa bears to the population of the Northern Mariana Islands determined on the basis of the most recent data available at the time such allotment is determined.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9135/a/2/B"},"text":"Pub. L. 100–203, § 9135(a)(2)(B)","children":[],"tail":", inserted “American Samoa,” after “the Virgin Islands,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9134/a/A"},"text":"Pub. L. 100–203, § 9134(a)(A)","children":[],"tail":", struck out “and” after “1983;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9134/a/B"},"text":"Pub. L. 100–203, § 9134(a)(B)","children":[],"tail":", substituted “years 1984, 1985, 1986, and 1987, and for each succeeding fiscal year other than the fiscal year 1988; and” for “year 1984 and each succeeding fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9134/a/C"},"text":"Pub. L. 100–203, § 9134(a)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1883/e/1/B"},"text":"Pub. L. 99–514, § 1883(e)(1)(B)","children":[],"tail":", struck out “(subject to subsection (d) of this section)” after “promulgated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514/s1883/e/1/A"},"text":"Pub. L. 99–514, § 1883(e)(1)(A)","children":[],"tail":", struck out subsec. (d) which read as follows: “The determination and promulgation required by subsection (b) of this section with respect to the fiscal year 1982 shall be made as soon as possible after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/135"},"text":"Pub. L. 98–135","children":[],"tail":" substituted “$2,700,000,000 for the fiscal year 1984 and each succeeding fiscal year.” for “$2,500,000,000 for the fiscal year 1984;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/135"},"text":"Pub. L. 98–135","children":[],"tail":" struck out pars. (4) and (5) which provided, respectively, for an amount of $2,600,000,000 for fiscal year 1985 and $2,700,000,000 for fiscal year 1986 and succeeding fiscal years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" inserted “(other than Puerto Rico, Guam, the Virgin Islands, and the Northern Mariana Islands)” in provisions following cl. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbaa85d3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbaa85d3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tII/s214/b"},"text":"Pub. L. 105–277, div. A, § 101(f) [title II, § 214(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–361, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/f/tII/s214/b"},"text":"“The amendment made by this section [amending this section] takes effect immediately after the amendments made by section 8401 of the Transportation Equity Act for the 21st Century take effect [","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/s8401/c"},"text":"section 8401(c) of Pub. L. 105–178","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s604"},"text":"section 604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbaa85d3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9135/a/2"},"text":"section 9135(a)(2) of Pub. L. 100–203","children":[],"tail":" applicable with respect to fiscal years beginning on or after "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s9135/c"},"text":"section 9135(c) of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s623"},"text":"section 623 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbaa85d3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/s160/e"},"text":"section 160(e) of Pub. L. 97–248","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbaa85d3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement That Additional Funds Supplement and Not Supplant Funds Available From Other Sources","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9134/b"},"text":"Pub. L. 100–203, title IX, § 9134(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-315"},"text":"101 Stat. 1330–315","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tIX/s9134/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The additional $50,000,000 made available to the States for the fiscal year 1988 pursuant to the amendments made by subsection (a) [amending this section] shall—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used only for the purpose of providing additional services under title XX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"42 U.S.C. 1397","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be expended only to supplement the level of any funds that would, in the absence of the additional funds appropriated pursuant to such amendments, be available from other sources (including any amounts available under title XX of the Social Security Act without regard to such amendments) for services in accordance with such title, and shall in no case supplant such funds from other sources or reduce the level thereof.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbaa85d40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tIV/s401"},"text":"Pub. L. 98–473, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2195"},"text":"98 Stat. 2195","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tIV/s401"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of title XX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"42 U.S.C. 1397","children":[],"tail":" et seq.], the amount applicable under section 2003(c)(3) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b/c/3"},"text":"42 U.S.C. 1397b(c)(3)","children":[],"tail":"] shall be $2,725,000,000 for fiscal year 1985. Of such amount, $25,000,000 shall be allotted and used in accordance with this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any other amounts appropriated under this resolution [","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":"] or any Act, there are hereby appropriated $25,000,000 for fiscal year 1985, for carrying out title XX of the Social Security Act, to be used in accordance with the provisions of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated under this section shall remain available until ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", without regard to section 102 of this resolution."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, each State’s allotment of the additional amounts authorized and appropriated under this section shall be the same proportion of $25,000,000 as such State’s proportional allotment of other title XX funds for fiscal year 1985, as determined under section 2003 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b"},"text":"42 U.S.C. 1397b","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The additional $25,000,000 made available to the States for fiscal year 1985 pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used only for the purpose of providing training and retraining (including training in the prevention of child abuse in child care settings) to providers of licensed or registered child care services, operators and staffs (including those receiving in-service training) of facilities where licensed or registered child care services are provided, State licensing and enforcement officials, and parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be expended only to supplement the level of any funds that would, in the absence of the additional funds appropriated under this section, be available from other sources (including any amounts available under title XX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"42 U.S.C. 1397","children":[],"tail":" et seq.] without regard to this section) for the purpose specified in paragraph (1), and shall in no case supplant such funds from other sources or reduce the level thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be separately accounted for in the reports and audits provided for in section 2006 of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397e"},"text":"42 U.S.C. 1397e","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to provide guidance and assistance to the States in utilizing funds allocated pursuant to title XX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"42 U.S.C. 1397","children":[],"tail":" et seq.], not later than 3 months after the date of enactment of this section ["},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"], the Secretary shall draft and distribute to the States for their consideration, a Model Child Care Standards Act containing—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" minimum licensing or registration standards for day care centers, group homes, and family day care homes regarding matters including—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training, development, supervision, and evaluation of staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff qualification requirements, by job classification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff-child ratios;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" probation periods for new staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment history checks for staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"“(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent visitation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any State receiving an allotment under such title from the funds made available as a result of subsection (a) shall have in effect, not later than ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures, established by State law or regulation, to provide for employment history and background checks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions of State law, enacted in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/544"},"text":"Public Law 92–544","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/86/115"},"text":"86 Stat. 115","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/stat/86/1115"},"text":"86 Stat. 1115","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41101"},"text":"34 U.S.C. 41101","children":[],"tail":"] requiring nationwide criminal record checks"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for all operators, staff or employees, or prospective operators, staff or employees of child care facilities (including any facility or program having primary custody of children for 20 hours or more per week), juvenile detention, correction or treatment facilities, with the objective of protecting the children involved and promoting such children’s safety and welfare while receiving service through such facilities or programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any State not meeting the requirements of subparagraph (A) by ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", such State’s allotment for fiscal year 1986 or 1987 shall be reduced in the aggregate by an amount equal to one-half of the amount by which such State’s allotment under such title was increased for fiscal year 1985 as a result of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determination and promulgation required by section 2003(b) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b/b"},"text":"42 U.S.C. 1397b(b)","children":[],"tail":"] with respect to the fiscal year 1985 (to take into account the preceding provisions of this section) shall be made as soon as possible after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
