{"tag":"section","attrib":{"id":"idbe8d38a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285c"},"text":null,"children":[{"tag":"num","attrib":{"value":"8285c"},"text":"§ 8285c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8d38a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out this subchapter there is authorized to be appropriated the sum of $10,000,000 for the fiscal year ending on ","children":[{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and the sum of $15,000,000 for the fiscal year ending on "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d38a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8285c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any funds appropriated under the authorization contained in this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d38a8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s584"},"text":"Pub. L. 96–294, title V, § 584","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/761"},"text":"94 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d38a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d38aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d38ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Security Act, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
