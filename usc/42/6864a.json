{"tag":"section","attrib":{"id":"idbdc023ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6864a"},"text":"§ 6864a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector investments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc023cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent funds are made available for such purpose, provide financial assistance to entities receiving funding from the Federal Government or from a State through a weatherization assistance program under section 6863 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6864"},"text":"section 6864 of this title","children":[],"tail":" for the development and initial implementation of partnerships, agreements, or other arrangements with utilities, private sector interests, or other institutions, under which non-Federal financial assistance would be made available to support programs which install energy efficiency improvements in low-income housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance provided under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negotiation of such partnerships, agreements and other arrangements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presentation of arguments before State or local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expert advice on the development of such partnerships, agreements, and other arrangements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities reasonably associated with the development and initial implementation of such arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance provided under this section to entities other than States shall, to the extent practicable, coincide with the timing of financial assistance provided to such entities under section 6863 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6864"},"text":"section 6864 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 80 percent of amounts provided under this section shall be provided to entities other than States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient of financial assistance under this section shall have up to three years to complete projects undertaken with such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc023d5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s414A"},"text":"Pub. L. 94–385, title IV, § 414A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s142/a"},"text":"Pub. L. 102–486, title I, § 142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2842"},"text":"106 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
