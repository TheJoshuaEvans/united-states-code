{"tag":"section","attrib":{"id":"idc01b530b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539"},"text":null,"children":[{"tag":"num","attrib":{"value":"16539"},"text":"§ 16539.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory Jobs ACCESS Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01b530c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On or after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary may establish a program, to be known as the “Department of Energy National Lab Jobs ACCESS Program”, under which the Secretary may award, on a competitive basis, 5-year grants to eligible entities described in subsection (c) for the Federal share of the costs of pre-apprenticeship programs and apprenticeship programs described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b530d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-apprenticeship and apprenticeship programs described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pre-apprenticeship program or apprenticeship program described in this subsection is a pre-apprenticeship program or apprenticeship program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b530e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leads to recognized postsecondary credentials for secondary school and postsecondary students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b530f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is focused on skills and qualifications needed, as determined by the Secretary in consultation with the directors of the National Laboratories, to meet the immediate and ongoing needs of traditional and emerging technician positions (including machinists and cybersecurity technicians) at the National Laboratories and covered facilities of the National Nuclear Security Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established in consultation with a National Laboratory or covered facility of the National Nuclear Security Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered with and approved by the Secretary of Labor or a State apprenticeship agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that participants in the pre-apprenticeship program or apprenticeship program do not displace paid employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity described in this subsection is a workforce intermediary or an eligible sponsor of a pre-apprenticeship program or apprenticeship program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates experience in implementing and providing career planning and career pathways toward pre-apprenticeship programs or apprenticeship programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a relationship with a National Laboratory or covered facility of the National Nuclear Security Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has knowledge of the technician workforce needs of the laboratory or facility and the associated security requirements of the laboratory or facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to enter into an agreement with the laboratory or facility that would be paid for in part or entirely from grant funds received under this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the ability to recruit and support individuals who plan to work in relevant technician positions upon the successful completion of the pre-apprenticeship program or apprenticeship program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b531a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides students who complete the pre-apprenticeship program or apprenticeship program with, or prepares such students for obtaining, a recognized postsecondary credential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b531b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses related instruction that is specifically aligned with the needs of the laboratory or facility and utilizes workplace learning advisors and on-the-job training to the greatest extent possible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b531c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates successful outcomes connecting graduates of the pre-apprenticeship program or apprenticeship program to careers relevant to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b531d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes the program described in subsection (a), an eligible entity described in subsection (c) seeking a grant under the program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b531e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities described in subsection (c) to receive grants under this section, the Secretary may prioritize an eligible entity that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b531f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an industry or sector partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides related instruction for a pre-apprenticeship program or apprenticeship program through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, a secondary school, a provider of adult education, an area career and technical education school, or an institution of higher education (such as a community college) that includes basic science, technology, and mathematics education in the related instruction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an apprenticeship program that was registered with the Department of Labor or a State apprenticeship agency before the date on which the eligible entity applies for the grant under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works with the Secretary of Defense, the Secretary of Veterans Affairs, or veterans organizations to transition members of the Armed Forces and veterans to pre-apprenticeship programs or apprenticeship programs in a relevant sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to use the grant to carry out the pre-apprenticeship program or apprenticeship program with an entity that receives State funding or is operated by a State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plans to use the grant to carry out the pre-apprenticeship program or apprenticeship program for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" young adults ages 16 to 29, inclusive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with barriers to employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary may consider regional diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity described in subsection (c) may not submit, either individually or as part of a joint application, more than one application for a grant under this section during any one fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b532a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided under this section may not, for any 24-month period of the 5-year grant period, exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b532b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of a pre-apprenticeship program or apprenticeship program carried out using a grant under this section shall be not less than 25 percent of the total cost of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b532c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to eligible entities described in subsection (c) to leverage the existing job training and education programs of the Department of Labor and other relevant programs at appropriate Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b532d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b532e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary establishes the program described in subsection (a), not less than once every 2 years thereafter, the Secretary shall submit to Congress, and make publicly available on the website of the Department of Energy, a report on the program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b532f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b5330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity that receives a grant under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity carried out using a grant under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices used to leverage the investment of the Federal Government under this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the results achieved by the program, including the rate of employment for participants after completing a pre-apprenticeship program or apprenticeship program carried out using a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the establishment of a pre-apprenticeship program or apprenticeship program using a grant awarded under this section, and annually thereafter, the entity carrying out the program shall submit to the Secretary and the Secretary of Labor a report on the effectiveness of the program based on the accountability measures described in clauses (i) and (ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A"},"text":"section 3141(b)(2)(A) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESEA terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “local educational agency” and “secondary school” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WIOA terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “career planning”, “community-based organization”, “customized training”, “economic development agency”, “individual with a barrier to employment”, “industry or sector partnership”, “on-the-job training”, “recognized postsecondary credential”, and “workplace learning advisor” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “apprenticeship program” means a program registered under the Act of ","children":[{"tag":"date","attrib":{"date":"1937-08-16"},"text":"August 16, 1937","children":[],"tail":" (commonly known as the “National Apprenticeship Act”; "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":", chapter 663; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s50"},"text":"29 U.S.C. 50","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area career and technical education school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “area career and technical education school” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2302"},"text":"section 2302 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b533a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community college","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community college” has the meaning given the term “junior or community college” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1058/f"},"text":"section 1058(f) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b533b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered facility of the national nuclear security administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered facility of the National Nuclear Security Administration” means a national security laboratory or a nuclear weapons production facility as such terms are defined in section 2501 ","children":[{"tag":"ref","attrib":{"idref":"fn004234"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004234"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b533c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible sponsor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible sponsor” means a public organization or nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b533d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to an apprenticeship program, administers the program through a partnership that may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b533e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an industry or sector partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b533f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer or industry association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a labor-management organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local workforce development board or State workforce development board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 2- or 4-year institution of higher education that offers an educational program leading to an associate’s or bachelor’s degree in conjunction with a certificate of completion of apprenticeship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Forces (including the National Guard and Reserves);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a pre-apprenticeship program, is a local educational agency, a secondary school, an area career and technical education school, a provider of adult education, a State workforce development board, a local workforce development board, or a community-based organization, that administers the program with any required coordination and necessary approvals from the Secretary of Labor or a State department of labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local workforce development board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local workforce development board” has the meaning given the term “local board” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b534a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit organization” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b534b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-apprenticeship program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pre-apprenticeship program” means a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b534c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to prepare individuals to enter and succeed in an apprenticeship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b534d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a documented partnership with at least one, if not more, apprenticeship programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b534e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provider of adult education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “provider of adult education” has the meaning given the term “eligible provider” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3272"},"text":"section 3272 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b534f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related instruction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “related instruction” means an organized and systematic form of instruction designed to provide an individual in a pre-apprenticeship program or apprenticeship program with the knowledge of the technical subjects related to the intended occupation of the individual after completion of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy, in consultation with the Secretary of Labor, except as otherwise specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sponsor” means any person, association, committee, or organization operating a pre-apprenticeship program or apprenticeship program and in whose name the program is (or is to be) registered or approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State apprenticeship agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State apprenticeship agency” has the meaning given that term in section 29.2 of title 29, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State workforce development board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State workforce development board” has the meaning given the term “State board” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce intermediary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “workforce intermediary”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a nonprofit organization that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b5356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/19/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactively addresses workforce needs using a dual customer approach, which considers the needs of both employees and employers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/19/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has partnered with a sponsor of a pre-apprenticeship program or apprenticeship program or is a sponsor of a pre-apprenticeship program or apprenticeship program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16539/l/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a community organization, an employer organization, a community college, a temporary staffing agency, a State workforce development board, a local workforce development board, or a labor or labor-management organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01b5359-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXI/s3122"},"text":"Pub. L. 116–92, div. C, title XXXI, § 3122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1953"},"text":"133 Stat. 1953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01b535a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01b535b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01b535c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2501"},"text":"Section 2501 of title 50","children":[],"tail":", referred to in subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(6), was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6101"},"text":"section 6101 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1339"},"text":"139 Stat. 1339","children":[],"tail":", 1458. “National security laboratory” and “nuclear weapons production facility” are defined in pars. (6) and (8), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6101"},"text":"section 6101 of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc01b535d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2020, and not as part of the America COMPETES Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
