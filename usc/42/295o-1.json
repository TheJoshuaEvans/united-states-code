{"tag":"section","attrib":{"id":"idb5efb657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"295o–1"},"text":"§ 295o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally applicable provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5efb658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that grants and contracts under this subchapter are awarded on a competitive basis, as appropriate, to carry out innovative demonstration projects or provide for strategic workforce supplementation activities as needed to meet health workforce goals and in accordance with this subchapter. Contracts may be entered into under this subchapter with public or private entities as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless specifically required otherwise in this subchapter, the Secretary shall accept applications for grants or contracts under this subchapter from health professions schools, academic health centers, State or local governments, or other appropriate public or private nonprofit entities for funding and participation in health professions and nursing training activities. The Secretary may accept applications from for-profit private entities if determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb65a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5efb65b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of grants and contracts under this subchapter shall meet information requirements as specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb65c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to ensure that, with respect to any data collection required under this subchapter, such data is collected in a manner that takes into account age, sex, race, and ethnicity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb65d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to permit the use of amounts appropriated under this subchapter to be used for data collection purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb65e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to ensure the annual evaluation of programs and projects operated by recipients of grants or contracts under this subchapter. Such procedures shall ensure that continued funding for such programs and projects will be conditioned upon a demonstration that satisfactory progress has been made by the program or project in meeting the objectives of the program or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb65f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Training programs conducted with amounts received under this subchapter shall meet applicable accreditation and quality standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5efb661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in the case of an award to an entity of a grant, cooperative agreement, or contract under this subchapter, the period during which payments are made to the entity under the award may not exceed 5 years. The provision of payments under the award shall be subject to annual approval by the Secretary of the payments and subject to the availability of appropriations for the fiscal year involved to make the payments. This paragraph may not be construed as limiting the number of awards under the program involved that may be made to the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an award to an entity of a grant, cooperative agreement, or contract under this subchapter, paragraph (1) shall apply only to the extent not inconsistent with any other provision of this subchapter that relates to the period during which payments may be made under the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review regarding certain programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5efb664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application for a grant under this subchapter, except any scholarship or loan program, including those under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002286"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002286"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 292, 292q, or 292s of this title, shall be submitted to a peer review group for an evaluation of the merits of the proposals made in the application. The Secretary may not approve such an application unless a peer review group has recommended the application for approval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each peer review group under this subsection shall be composed principally of individuals who are not officers or employees of the Federal Government. In providing for the establishment of peer review groups and procedures, the Secretary shall ensure sex, racial, ethnic, and geographic balance among the membership of such groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be carried out by the Secretary acting through the Administrator of the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference or priority considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering a preference or priority for funding which is based on outcome measures for an eligible entity under this subchapter, the Secretary may also consider the future ability of the eligible entity to meet the outcome preference or priority through improvements in the eligible entity’s program design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analytic activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5efb669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-cutting workforce analytical activities are carried out as part of the workforce information and analysis activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294n"},"text":"section 294n of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" discipline-specific workforce information and analytical activities are carried out as part of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5efb66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community-based linkage program under part D; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5efb66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health workforce development program under subpart 2 of part E.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5efb66d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Osteopathic Schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, any reference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5efb66e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical schools shall include osteopathic medical schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5efb66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295o–1/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical students shall include osteopathic medical students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5efb670-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 799, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s106/a/2/F"},"text":"Pub. L. 105–392, title I, § 106(a)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3558"},"text":"112 Stat. 3558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5efb671-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5efb672-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5efb673-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 799 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 799B by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":" and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p"},"text":"section 295p of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 799 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295i"},"text":"section 295i of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
