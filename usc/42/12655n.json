{"tag":"section","attrib":{"id":"idbf9385d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655n"},"text":"§ 12655n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State employee status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9385da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participants and crew leaders shall be responsible to, or be the responsibility of, the program agency administering the program on which such participants, crew leaders, and volunteers work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9385db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9385dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection, a participant or crew leader in a program that receives assistance under this division shall not be considered a Federal employee and shall not be subject to the provisions of law relating to Federal employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work-related injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subchapter I of chapter 81 of title 5, relating to the compensation of Federal employees for work injuries, a participant or crew leader serving in a program that receives assistance under this division shall be considered an employee of the United States within the meaning of the term “employee” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":" and the provision "},{"tag":"ref","attrib":{"idref":"fn004095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “provisions”."}],"tail":" of that subchapter shall apply, except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9385de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “performance of duty”, as used in such subchapter, shall not include an act of a participant or crew leader while absent from the assigned post of duty of such participant or crew leader, except while participating in an activity authorized by or under the direction and supervision of a program agency (including an activity while on pass or during travel to or from such post of duty); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9385df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for disability shall not begin to accrue until the day following the date that the employment of the injured participant or crew leader is terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tort claims procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of chapter 171 of title 28, relating to tort claims procedure, a participant or crew leaders assigned to a youth corps program for which a grant has been made to the Secretary of Agriculture, Secretary of the Interior, or the Director of ACTION, shall be considered an employee of the United States within the meaning of the term “employee of the government” as defined in section 2671 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9385e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for quarters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":", relating to allowances for quarters, a participant or crew leader shall be considered an employee of the United States within the meaning of the term “employee” as defined in paragraph (3) of subsection (a) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9385e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contract authority under this division shall be subject to the availability of appropriations. Assistance made available under this division shall only be used for activities that are in addition to those which would otherwise be carried out in the area in the absence of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9385e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199M"},"text":"Pub. L. 101–610, title I, § 199M","children":[],"tail":", formerly § 135, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3149"},"text":"104 Stat. 3149","children":[],"tail":"; renumbered § 199O, renumbered § 199M, "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (e)(8)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":", 816, as amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/304/s3/b/1"},"text":"Pub. L. 103–304, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1567"},"text":"108 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9385e4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNot