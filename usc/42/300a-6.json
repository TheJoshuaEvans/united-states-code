{"tag":"section","attrib":{"id":"idb60c3fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300a–6"},"text":"§ 300a–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against funding programs using abortion as family planning method","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the funds appropriated under this subchapter shall be used in programs where abortion is a method of family planning.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb60c3fa8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title X, § 1008, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/572/s6/c"},"text":"Pub. L. 91–572, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1508"},"text":"84 Stat. 1508","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
