{"tag":"section","attrib":{"id":"idbd7622cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6250c"},"text":"§ 6250c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northeast Home Heating Oil Reserve Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7622cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a decision of the Secretary of Energy to establish a Reserve under this part, the Secretary of the Treasury shall establish in the Treasury of the United States an account known as the “Northeast Home Heating Oil Reserve Account” (referred to in this section as the “Account”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn003453"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003453"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" Secretary of the Treasury shall deposit in the Account any amounts appropriated to the Account and any receipts from the sale, exchange, or other disposition of petroleum distillate from the Reserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7622ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may obligate amounts in the Account to carry out activities under this part without the need for further appropriation, and amounts available to the Secretary of Energy for obligation under this section shall remain available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7622cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s184"},"text":"Pub. L. 94–163, title I, § 184","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tII/s201/a/3"},"text":"Pub. L. 106–469, title II, § 201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2036"},"text":"114 Stat. 2036","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
