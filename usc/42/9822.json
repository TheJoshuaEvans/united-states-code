{"tag":"section","attrib":{"id":"idbedbcded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9822"},"text":null,"children":[{"tag":"num","attrib":{"value":"9822"},"text":"§ 9822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of certain appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to the Rural Development Loan Fund under title VII of the Economic Opportunity Act of 1964 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2981"},"text":"42 U.S.C. 2981","children":[],"tail":" et seq.] (as in effect on "},{"tag":"date","attrib":{"date":"1981-08-12"},"text":"August 12, 1981","children":[],"tail":"), and interest accumulated in such fund, shall be deposited in the Rural Development Loan Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9812/c/1"},"text":"section 9812(c)(1) of this title","children":[],"tail":" and shall continue to be available to carry out the purposes of such fund. Funds appropriated to the Community Development Credit Union Revolving Loan Fund under title VII of the Economic Opportunity Act of 1964 (as in effect on "},{"tag":"date","attrib":{"date":"1981-08-12"},"text":"August 12, 1981","children":[],"tail":"), and interest accumulated in such fund, shall continue to be available to carry out the purposes of such fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbede3dee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s633"},"text":"Pub. L. 97–35, title VI, § 633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/498"},"text":"95 Stat. 498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbede3def-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbede3df0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbede3df1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Economic Opportunity Act of 1964, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452"},"text":"Pub. L. 88–452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-20"},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/508"},"text":"78 Stat. 508","children":[],"tail":". Title VII of the Economic Opportunity Act of 1964 was classified generally to subchapter VII (§ 2981 et seq.) of chapter 34 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683/a"},"text":"Pub. L. 97–35, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/519"},"text":"95 Stat. 519","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbede3df2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"date","attrib":{"date":"1981-08-12"},"text":"August 12, 1981","children":[],"tail":"” substituted in text for “the day before the date of the enactment of this Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbede3df3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbede3df4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Community Development Credit Union Revolving Loan Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/609"},"text":"Pub. L. 99–609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3475"},"text":"100 Stat. 3475","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/609"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Community Development Credit Union Revolving Loan Fund Transfer Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRANSFER OF COMMUNITY DEVELOPMENT CREDIT UNION REVOLVING LOAN FUND.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Fund by NCUA.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":"], the National Credit Union Administration Board shall administer the Community Development Credit Union Revolving Loan Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All authority to carry out the purposes of the Fund and to prescribe regulations in connection with the administration of the Fund which, on the day before the date of the enactment of this Act, was vested in the Secretary of Health and Human Services shall vest on such date in the Board. Except as provided in subsection (c), the Secretary shall have no further responsibility with respect to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Availability of Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All funds appropriated to the Fund and interest accumulated in the Fund which continue to be available under section 633 of the Omnibus Budget Reconciliation Act of 1981 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9822"},"text":"42 U.S.C. 9822","children":[],"tail":"] shall continue to be available to the Board to carry out the purposes of the Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Assets; Etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall transfer to the National Credit Union Administration all assets, liabilities, grants, contracts, property, records, and funds held, used, arising from, or available to the Secretary in connection with the administration of the Fund before the end of the 60-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any regulations prescribed by the Secretary in connection with the administration of the Fund shall continue in effect until superseded by regulations prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing rights, duties, and obligations not affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not be construed as affecting the validity of any right, duty, or obligation of the United States or any other person arising under or pursuant to any contract, loan, or other instrument or agreement which was in effect on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of suits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No action or other proceeding commenced by or against the Secretary in connection with the administration of the Fund shall abate by reason of the enactment of this Act, except that the Board shall be substituted for the Secretary as a party to any such action or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Board’ means the National Credit Union Administration Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Fund’ means the Community Development Credit Union Revolving Loan Fund established under title VII of the Economic Opportunity Act of 1964 [see References in Text note above] (as in effect before the date of the enactment of the Omnibus Budget Reconciliation Act of 1981 [","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Health and Human Services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
