{"tag":"section","attrib":{"id":"idbc58093d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030g–23"},"text":"§ 3030g–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition services impact study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc58093e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc58093f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall perform a study to assess how to measure and evaluate the discrepancy between available services and the demand for such services in the home delivered nutrition services program and the congregate nutrition services program under this part, which shall include assessing various methods (such as those that States use) to measure and evaluate the discrepancy (such as measurement through the length of waitlists).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc580940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In performing the study, the Assistant Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc580941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider means of obtaining information in rural and underserved communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider using existing tools (existing as of the date the Assistant Secretary begins the study) such as the tools developed through the Performance Outcome Measurement Project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc580943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall analyze and determine which methods are the least burdensome and most effective for measuring and evaluating the discrepancy described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc580944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc580945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2020-03-25"},"text":"March 25, 2020","children":[],"tail":", the Assistant Secretary shall prepare recommendations—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc580946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how to measure and evaluate, with the least burden and the most effectiveness, the discrepancy described in subsection (a)(1) (such as measurement through the length of waitlists); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" about whether studies similar to the study described in subsection (a) should be carried out for programs carried out under this chapter, other than this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc580948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall issue the recommendations, and make the recommendations available as a notification pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3012/a/34"},"text":"section 3012(a)(34) of this title","children":[],"tail":" and to the committees of the Senate and of the House of Representatives with jurisdiction over this chapter, and the Special Committee on Aging of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc580949-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s339B"},"text":"Pub. L. 89–73, title III, § 339B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tII/s216"},"text":"Pub. L. 116–131, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/259"},"text":"134 Stat. 259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
