{"tag":"section","attrib":{"id":"idbcdb1b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4636"},"text":null,"children":[{"tag":"num","attrib":{"value":"4636"},"text":"§ 4636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments not to be considered as income for revenue purposes or for eligibility for assistance under Social Security Act or other Federal law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No payment received under this subchapter shall be considered as income for the purposes of title 26; or for the purposes of determining the eligibility or the extent of eligibility of any person for assistance under the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.] or any other Federal law (except for any Federal law providing low-income housing assistance)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcdb1b6c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646/tII/s216"},"text":"Pub. L. 91–646, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1902"},"text":"84 Stat. 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tIV/s413"},"text":"Pub. L. 100–17, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/255"},"text":"101 Stat. 255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdb1b6d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdb1b6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcdb1b6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcdb1b70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" inserted “(except for any Federal law providing low-income housing assistance)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcdb1b71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcdb1b72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" effective on effective date provided in regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4633"},"text":"section 4633 of this title","children":[],"tail":" (as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/s412"},"text":"section 412 of Pub. L. 100–17","children":[],"tail":"), but not later than 2 years after "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/s418"},"text":"section 418 of Pub. L. 100–17","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
