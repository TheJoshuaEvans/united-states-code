{"tag":"section","attrib":{"id":"idb5e88b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a"},"text":null,"children":[{"tag":"num","attrib":{"value":"295a"},"text":"§ 295a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health training centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants or contracts for the operation of public health training centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public health training center shall be an accredited school of public health, or another public or nonprofit private institution accredited for the provision of graduate or specialized training in public health, that plans, develops, operates, and evaluates projects to improve preventive medicine, health promotion and disease prevention, or access to and quality of health care services in rural or medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants or contracts under this section the Secretary shall give preference to accredited schools of public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a public health training center, an award may not be made under subsection (a) unless the program agrees that it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will establish or strengthen field placements for students in public or nonprofit private health agencies or organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will involve faculty members and students in collaborative projects to enhance public health services to medically underserved communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will specifically designate a geographic area or medically underserved population to be served by the center that shall be in a location removed from the main location of the teaching facility of the school that is participating in the program with such center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will assess the health personnel needs of the area to be served by the center and assist in the planning and development of training programs to meet such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 766, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s105"},"text":"Pub. L. 105–392, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3554"},"text":"112 Stat. 3554","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3401/11"},"text":"Pub. L. 116–136, div. A, title III, § 3401(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/387"},"text":"134 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88b1d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note"