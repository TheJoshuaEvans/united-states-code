{"tag":"section","attrib":{"id":"idbcd1a5c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370m–10"},"text":"§ 4370m–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a report that includes an analysis of whether the provisions of this subchapter could be adapted to streamline the Federal permitting process for smaller projects that are not covered projects."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcd1a5c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dD/tXLI/s41011"},"text":"Pub. L. 114–94, div. D, title XLI, § 41011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1761"},"text":"129 Stat. 1761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd1a5c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd1a5c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcd1a5c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fixing America’s Surface Transportation Act, also known as the FAST Act, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
