{"tag":"section","attrib":{"id":"idc0203450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012"},"text":null,"children":[{"tag":"num","attrib":{"value":"17012"},"text":"§ 17012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced battery loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203451-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide guarantees of loans by private institutions for the construction of facilities for the manufacture of advanced vehicle batteries and battery systems that are developed and produced in the United States, including advanced lithium ion batteries and hybrid electrical system and component manufacturers and software designers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a loan guarantee under subsection (a) to an applicant if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a loan guarantee, credit is not available to the applicant under reasonable terms or conditions sufficient to finance the construction of a facility described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective earning power of the applicant and the character and value of the security pledged provide a reasonable assurance of repayment of the loan to be guaranteed in accordance with the terms of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan bears interest at a rate determined by the Secretary to be reasonable, taking into account the current average yield on outstanding obligations of the United States with remaining periods of maturity comparable to the maturity of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting recipients of loan guarantees from among applicants, the Secretary shall give preference to proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet all applicable Federal and State permitting requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to be successful; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in local markets that have the greatest need for the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan guaranteed under subsection (a) shall have a maturity of not more than 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan agreement for a loan guaranteed under subsection (a) shall provide that no provision of the loan agreement may be amended or waived without the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurance of repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that an applicant for a loan guarantee under subsection (a) provide an assurance of repayment in the form of a performance bond, insurance, collateral, or other means acceptable to the Secretary in an amount equal to not less than 20 percent of the amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of a loan guarantee under subsection (a) shall pay the Secretary an amount determined by the Secretary to be sufficient to cover the administrative costs of the Secretary relating to the loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all guarantees made under this section. Any such guarantee made by the Secretary shall be conclusive evidence of the eligibility of the loan for the guarantee with respect to principal and interest. The validity of the guarantee shall be incontestable in the hands of a holder of the guaranteed loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020345f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until each guaranteed loan under this section has been repaid in full, the Secretary shall annually submit to Congress a report on the activities of the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17012/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to issue a loan guarantee under subsection (a) terminates on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203462-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s135"},"text":"Pub. L. 110–140, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1513"},"text":"121 Stat. 1513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0203463-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0203464-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203465-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
