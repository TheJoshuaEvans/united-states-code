{"tag":"section","attrib":{"id":"idbce4b870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902"},"text":null,"children":[{"tag":"num","attrib":{"value":"4902"},"text":"§ 4902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce4b871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, corporation, partnership, or association, and (except as provided in sections 4910(e) and 4911(a) of this title) includes any officer, employee, department, agency, or instrumentality of the United States, a State, or any political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “product” means any manufactured article or goods or component thereof; except that such term does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce4b874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aircraft, aircraft engine, propeller, or appliance, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbce4b876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any military weapons or equipment which are designed for combat use; (ii) any rockets or equipment which are designed for research, experimental, or developmental work to be performed by the National Aeronautics and Space Administration; or (iii) to the extent provided by regulations of the Administrator, any other machinery or equipment designed for use in experimental work done by or for the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “ultimate purchaser” means the first person who in good faith purchases a product for purposes other than resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “new product” means (A) a product the equitable or legal title of which has never been transferred to an ultimate purchaser, or (B) a product which is imported or offered for importation into the United States and which is manufactured after the effective date of a regulation under section 4905 or 4907 of this title which would have been applicable to such product had it been manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “manufacturer” means any person engaged in the manufacturing or assembling of new products, or the importing of new products for resale, or who acts for, and is controlled by, any such person in connection with the distribution of such products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commerce” means trade, traffic, commerce, or transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce4b87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a place in a State and any place outside thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce4b87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which affects trade, traffic, commerce, or transportation described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “distribute in commerce” means sell in, offer for sale in, or introduce or deliver for introduction into, commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal agency” means an executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") and includes the United States Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4902/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “environmental noise” means the intensity, duration, and the character of sounds from all sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce4b881-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/574/s3"},"text":"Pub. L. 92–574, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1234"},"text":"86 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce4b882-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce4b883-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbce4b884-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (3)(A), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"” substituted for “section 101 of the Federal Aviation Act of 1958” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbce4b885-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbce4b886-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
