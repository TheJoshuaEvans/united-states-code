{"tag":"section","attrib":{"id":"idbbfb1b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164"},"text":"§ 2164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbfb1b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may authorize the Commission to cooperate with another nation and to communicate to that nation Restricted Data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfb1b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refining, purification, and subsequent treatment of source material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civilian reactor development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of special nuclear material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial and other applications of atomic energy for peaceful purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development relating to the foregoing:","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"proviso","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no such cooperation shall involve the communication of Restricted Data relating to the design or fabrication of atomic weapons: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That the cooperation is undertaken pursuant to an agreement for cooperation entered into in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":", or is undertaken pursuant to an agreement existing on "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"August 30, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfb1b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Department of Defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may authorize the Department of Defense, with the assistance of the Commission, to cooperate with another nation or with a regional defense organization to which the United States is a party, and to communicate to that nation or organization such Restricted Data (including design information) as is necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfb1b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of defense plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of personnel in the employment of and defense against atomic weapons and other military applications of atomic energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of the capabilities of potential enemies in the employment of atomic weapons and other military applications of atomic energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of compatible delivery systems for atomic weapons;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whenever the President determines that the proposed cooperation and the proposed communication of the Restricted Data will promote and will not constitute an unreasonable risk to the common defense and security, while such other nation or organization is participating with the United States pursuant to an international arrangement by substantial and material contributions to the mutual defense and security: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the cooperation is undertaken pursuant to an agreement entered into in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfb1b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of information concerning atomic weapons; research, development, or design, of military reactors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the cooperation authorized in subsections (a) and (b), the President may authorize the Commission, with the assistance of the Department of Defense, to cooperate with another nation and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfb1b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exchange with that nation Restricted Data concerning atomic weapons: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That communication of such Restricted Data to that nation is necessary to improve its atomic weapon design, development, or fabrication capability and provided that nation has made substantial progress in the development of atomic weapons; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to communicate or exchange with that nation Restricted Data concerning research, development, or design, of military reactors,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whenever the President determines that the proposed cooperation and the communication of the proposed Restricted Data will promote and will not constitute an unreasonable risk to the common defense and security, while such other nation is participating with the United States pursuant to an international arrangement by substantial and material contributions to the mutual defense and security: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the cooperation is undertaken pursuant to an agreement entered into in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfb1b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Department of Energy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfb1b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the cooperation authorized in subsections (a), (b), and (c), the President may, upon making a determination described in paragraph (2), authorize the Department of Energy, with the assistance of the Department of Defense, to cooperate with another nation to communicate to that nation such Restricted Data, and the President may, upon making such determination, authorize the Department of Defense, with the assistance of the Department of Energy, to cooperate with another nation to communicate to that nation such data removed from the Restricted Data category under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2162"},"text":"section 2162 of this title","children":[],"tail":", as is necessary for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfb1b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of a program for the control of and accounting for fissile material and other weapons material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfb1b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of the control of and accounting for atomic weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfb1b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the verification of a treaty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfb1b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of international standards for the classification of data on atomic weapons, data on fissile material, and related data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A determination referred to in paragraph (1) is a determination that the proposed cooperation and proposed communication referred to in that paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbfb1b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will promote the common defense and security interests of the United States and the nation concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbfb1b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not constitute an unreasonable risk to such common defense and security interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfb1b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperation under this subsection shall be undertaken pursuant to an agreement for cooperation entered into in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfb1b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2164/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication of data by other Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may authorize any agency of the United States to communicate in accordance with the terms and conditions of an agreement for cooperation arranged pursuant to subsection (a), (b), (c), or (d), such Restricted Data as is determined to be transmissible under the agreement for cooperation involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbfb1b73-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 144, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/942"},"text":"68 Stat. 942","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/85/479"},"text":"Pub. L. 85–479","children":[],"tail":", §§ 5–7, "},{"tag":"date","attrib":{"date":"1958-07-02"},"text":"July 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/278"},"text":"72 Stat. 278","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXI/s3155/a"},"text":"Pub. L. 103–337, div. C, title XXXI, § 3155(a)","children":[],"tail":", (c)(4), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3091"},"text":"108 Stat. 3091","children":[],"tail":", 3092.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbfb1b74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbfb1b75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbfb1b76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3155/a/2"},"text":"Pub. L. 103–337, § 3155(a)(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3155/c/4"},"text":"Pub. L. 103–337, § 3155(c)(4)","children":[],"tail":", substituted “(c), or (d)” for “or (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3155/a/1"},"text":"Pub. L. 103–337, § 3155(a)(1)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/479/s5"},"text":"Pub. L. 85–479, § 5","children":[],"tail":", substituted “civilian reactor development” for “reactor development” in cl. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/479/s6"},"text":"Pub. L. 85–479, § 6","children":[],"tail":", authorized communication of design information, of data concerning other military applications of atomic energy necessary for the training of personnel or for the evaluation of the capabilities of potential enemies, and of data necessary to the development of compatible delivery systems for atomic weapons, and struck out provisions which prohibited communication of data which would reveal important information concerning the design or fabrication of the nuclear components of atomic weapons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/479/s7"},"text":"Pub. L. 85–479, § 7","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbfb1b77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbfb1b78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Inspections","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXI/s3154/a"},"text":"Pub. L. 104–106, div. C, title XXXI, § 3154(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/624"},"text":"110 Stat. 624","children":[],"tail":", which was formerly set out as a note under this section, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4501/a"},"text":"section 4501(a) of Pub. L. 107–314","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXI/s3141/h/2/A"},"text":"Pub. L. 108–136, div. C, title XXXI, § 3141(h)(2)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1771"},"text":"117 Stat. 1771","children":[],"tail":", and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2651/a"},"text":"section 2651(a) of Title 50","children":[],"tail":", War and National Defense, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6221"},"text":"section 6221 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1401"},"text":"139 Stat. 1401","children":[],"tail":", 1458."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbbfb1b79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idbbfb1b7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority vested in President by subsecs. (b) and (c) of this section delegated to Secretary of Defense and Secretary of Energy, see section 2(a)(2) and (3) of Ex. Ord. No. 10841, as amended, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
