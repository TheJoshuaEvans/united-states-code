{"tag":"section","attrib":{"id":"idbc77028f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3174"},"text":null,"children":[{"tag":"num","attrib":{"value":"3174"},"text":"§ 3174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of comprehensive economic development strategies to Regional Commissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any part of an economic development district is in a region covered by 1 or more of the Regional Commissions, the economic development district shall ensure that a copy of the comprehensive economic development strategy of the district is provided to the affected Regional Commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc770290-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIV/s404"},"text":"Pub. L. 89–136, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3609"},"text":"112 Stat. 3609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tIV/s402/a"},"text":"Pub. L. 108–373, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1768"},"text":"118 Stat. 1768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc770291-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc770292-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"ta