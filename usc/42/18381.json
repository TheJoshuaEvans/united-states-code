{"tag":"section","attrib":{"id":"idc056fc35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18381"},"text":null,"children":[{"tag":"num","attrib":{"value":"18381"},"text":"§ 18381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the Science Mission Directorate maintains a long term technology development program for space and Earth science. This effort should be coordinated with an overall Agency technology investment approach, as authorized in section 905 of this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc056fc36-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tVIII/s801"},"text":"Pub. L. 111–267, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2832"},"text":"124 Stat. 2832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc056fc37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc056fc38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc056fc39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 905 of this Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIX/s905"},"text":"Pub. L. 111–267, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2836"},"text":"124 Stat. 2836","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
