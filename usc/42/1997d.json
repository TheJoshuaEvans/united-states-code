{"tag":"section","attrib":{"id":"idbbb38be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1997d"},"text":"§ 1997d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of retaliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person reporting conditions which may constitute a violation under this subchapter shall be subjected to retaliation in any manner for so reporting.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb38be1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/247/s6"},"text":"Pub. L. 96–247, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-23"},"text":"May 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/352"},"text":"94 Stat. 352","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
