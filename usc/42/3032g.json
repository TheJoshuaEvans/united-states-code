{"tag":"section","attrib":{"id":"idbc5f3461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032g"},"text":"§ 3032g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5f3462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5f3463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall make grants or enter into contracts with not fewer than two and not more than four eligible entities to establish and operate Resource Centers on Native American Elders (referred to in this section as “Resource Centers”). The Assistant Secretary shall make such grants or enter into such contracts for periods of not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5f3465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Resource Center that receives funds under this section shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f3466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f3467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f3468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the dissemination of results of the research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f3469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and training to entities that provide services to Native Americans who are older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5f346a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the functions described in subparagraph (A), a Resource Center shall focus on priority areas of concern for the Resource Centers regarding Native Americans who are older individuals, which areas shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5f346b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health (including mental health) problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f346c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term care, including in-home care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f346d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elder abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5f346e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other problems and issues that the Assistant Secretary determines are of particular importance to Native Americans who are older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f346f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants and entering into contracts under paragraph (1), the Assistant Secretary shall give preference to institutions of higher education that have conducted research on, and assessments of, the characteristics and needs of Native Americans who are older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the type of information to be sought from, and activities to be performed by, Resource Centers, the Assistant Secretary shall consult with the Director of the Office for American Indian, Alaskan Native, and Native Hawaiian Aging and with national organizations with special expertise in serving Native Americans who are older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant or enter into a contract under paragraph (1), an entity shall be an institution of higher education with experience conducting research and assessment on the needs of older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5f3472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, with assistance from each Resource Center, shall prepare and submit to the Speaker of the House of Representatives and the President pro tempore of the Senate an annual report on the status and needs, including the priority areas of concern, of Native Americans who are older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5f3473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall make grants and enter into contracts to provide in-service training opportunities and courses of instruction on aging to Indian tribes through public or nonprofit Indian aging organizations and to provide annually national trainings for directors of programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5f3474-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s418"},"text":"Pub. L. 89–73, title IV, § 418","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2263"},"text":"114 Stat. 2263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s407"},"text":"Pub. L. 109–365, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2557"},"text":"120 Stat. 2557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s5/b"},"text":"Pub. L. 114–144, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/341"},"text":"130 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5f3475-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5f3476-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc5f3477-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144"},"text":"Pub. L. 114–144","children":[],"tail":" substituted “national trainings for” for “a national meeting to train”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" inserted “(including mental health)” after “health”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
