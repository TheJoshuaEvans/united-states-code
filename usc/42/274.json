{"tag":"section","attrib":{"id":"idb5203172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274"},"text":null,"children":[{"tag":"num","attrib":{"value":"274"},"text":"§ 274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organ procurement and transplantation network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5203173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the continued operation of an Organ Procurement and Transplantation Network which meets the requirements of subsection (b). The Secretary may award grants, contracts, or cooperative agreements, as the Secretary determines appropriate, for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5203174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5203175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Organ Procurement and Transplantation Network shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5203176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be operated through awards to public or private entities made by the Secretary that are distinct from the awards made to support the organization tasked with supporting the board of directors described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a board of directors—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5203178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes representatives of organ procurement organizations (including organizations that have received grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s273"},"text":"section 273 of this title","children":[],"tail":"), transplant centers, voluntary health associations, and the general public; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5203179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that shall establish an executive committee and other committees, whose chairpersons shall be selected to ensure continuity of leadership for the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb520317a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Organ Procurement and Transplantation Network shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb520317b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish in one location or through regional centers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb520317c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national list of individuals who need organs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb520317d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national system, through the use of computers and in accordance with established medical criteria, to match organs and individuals included in the list, especially individuals whose immune system makes it difficult for them to receive organs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520317e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish membership criteria and medical criteria for allocating organs and provide to members of the public an opportunity to comment with respect to such criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520317f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a 24-hour telephone or information technology service to facilitate matching organs with individuals included in the list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist organ procurement organizations in the nationwide distribution of organs equitably among transplant patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and use standards of quality for the acquisition and transportation of donated organs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and distribute, on a regionalized basis (and, to the extent practicable, among regions or on a national basis), samples of blood sera from individuals who are included on the list and whose immune system makes it difficult for them to receive organs, in order to facilitate matching the compatibility of such individuals with organ donors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, as appropriate, the transportation of organs from organ procurement organizations to transplant centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to physicians and other health professionals regarding organ donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, analyze, and publish data concerning organ donation and transplants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out studies and demonstration projects for the purpose of improving procedures for organ procurement and allocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work actively to increase the supply of donated organs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an annual report containing information on the comparative costs and patient outcomes at each transplant center affiliated with the organ procurement and transplantation network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize the differences in health and in organ transplantation issues between children and adults throughout the system and adopt criteria, polices, and procedures that address the unique health care needs of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520318a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out studies and demonstration projects for the purpose of improving procedures for organ donation procurement and allocation, including but not limited to projects to examine and attempt to increase transplantation among populations with special needs, including children and individuals who are members of racial or ethnic minority groups, and among populations with limited access to transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520318b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that for purposes of this paragraph, the term “children” refers to individuals who are under the age of 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520318c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the integration of electronic health records systems through application programming interfaces (or successor technologies) among hospitals, organ procurement organizations, and transplant centers, including the use of automated electronic hospital referrals and the grant of remote, electronic access to hospital electronic health records of potential donors by organ procurement organizations, in a manner that complies with the privacy regulations promulgated under the Health Insurance Portability and Accountability Act of 1996, at part 160 of title 45, Code of Federal Regulations, and subparts A, C, and E of part 164 of such title (or any successor regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520318d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider establishing a dashboard to display the number of transplants performed, the types of transplants performed, the number and types of organs that entered the Organ Procurement and Transplantation Network system and failed to be transplanted, and other appropriate statistics, which should be updated more frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb520318e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In adopting and using standards of quality under paragraph (2)(E), the Organ Procurement and Transplantation Network may adopt and use such standards with respect to organs infected with human immunodeficiency virus (in this paragraph referred to as “HIV”), provided that any such standards ensure that organs infected with HIV may be transplanted only into individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb520318f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are infected with HIV before receiving such organ; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5203190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5203191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are participating in clinical research approved by an institutional review board under the criteria, standards, and regulations described in subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274f–5"},"text":"section 274f–5 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5203192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274f–5/c"},"text":"section 274f–5(c) of this title","children":[],"tail":" that participation in such clinical research, as a requirement for such transplants, is no longer warranted, are receiving a transplant under the standards and regulations under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s274f–5/c"},"text":"section 274f–5(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5203193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of critical comments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5203194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving from interested persons critical comments relating to the manner in which the Organ Procurement and Transplantation Network is carrying out the duties of the Network under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5203195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consideration by the Secretary of such critical comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5203196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5203197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may collect registration fees from any member of the Organ Procurement and Transplantation Network for each transplant candidate such member places on the list described in subsection (b)(2)(A)(i). Such registration fees shall be collected and distributed only to support the operation of the Organ Procurement and Transplantation Network. Such registration fees are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5203198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may collect the registration fees under paragraph (1) directly or through awards made under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5203199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amounts collected under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb520319a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the currently applicable appropriation, account, or fund of the Department of Health and Human Services as discretionary offsetting collections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb520319b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available, only to the extent and in the amounts provided in advance in appropriations Acts, to distribute such fees among awardees described in subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb520319c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb520319d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promptly post on the website of the Organ Procurement and Transplantation Network—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb520319e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of registration fees collected under this subsection from each member of the Organ Procurement and Transplantation Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb520319f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of activities such fees are used to support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52031a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the information posted pursuant to subparagraph (A), as applicable for each calendar quarter for which fees are collected under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52031a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2026-02-03"},"text":"February 3, 2026","children":[],"tail":", the Comptroller General of the United States shall, to the extent data are available—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52031a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review concerning the activities under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52031a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Health, Education, Labor, and Pensions and the Committee on Finance of the Senate and the Committee on Energy and Commerce of the House of Representatives, a report on such review, including related recommendations, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":