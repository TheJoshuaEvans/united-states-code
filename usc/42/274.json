ef":"/us/pl/100/607/s403/a/1"},"text":"Pub. L. 100–607, § 403(a)(1)","children":[],"tail":", added subpar. (B) and redesignated former subpars. (B) and (C) as (C) and (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/a/1"},"text":"Pub. L. 100–607, § 403(a)(1)","children":[],"tail":", (2), redesignated former subpar. (C) as (D) and substituted “organs” for “organs which cannot be placed within the service areas of the organizations”. Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/a/1"},"text":"Pub. L. 100–607, § 403(a)(1)","children":[],"tail":", (3), redesignated former subpar. (D) as (E) and inserted “including standards for preventing the acquisition of organs that are infected with the etiologic agent for acquired immune deficiency syndrome,” after “organs,”. Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/a/1"},"text":"Pub. L. 100–607, § 403(a)(1)","children":[],"tail":", (4), redesignated former subpar. (E) as (F) and inserted “(and, to the extent practicable, among regions or on a national basis)” after “basis”. Former subpar. (F) redesignated (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(G) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/a/1"},"text":"Pub. L. 100–607, § 403(a)(1)","children":[],"tail":", redesignated former subpars. (F) to (H) as (G) to (I), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/a/5"},"text":"Pub. L. 100–607, § 403(a)(5)","children":[],"tail":", added subpar. (J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s403/b"},"text":"Pub. L. 100–607, § 403(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb52031ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb52031ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/616/tII/s202/d"},"text":"Pub. L. 101–616, title II, § 202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3284"},"text":"104 Stat. 3284","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/616/tII/s202/d"},"text":"“The amendments made by subsection (a) [amending this section] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb52031ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report; Limitation on Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/426"},"text":"Pub. L. 110–426","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/426/s3"},"text":"Pub. L. 110–426, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4835"},"text":"122 Stat. 4835","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/426/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall request that the Executive Director of the Organ Procurement and Transplantation Network submit to Congress, not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":"], a report that shall include—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of transplant programs that have become inactive or have closed since the heart allocation policy change of 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distance to the next closest operational heart transplant center from such inactivated or closed programs and an evaluation of whether or not access to care has been reduced to the population previously serviced by such inactive or closed program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of patients with rural zip codes that received transplants after the heart allocation policy change of 2006 as compared with the number of such patients that received such transplants prior to such heart allocation policy change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the number of transplants performed, the mortality rate for individuals on the transplant waiting lists, and the post-transplant survival rate nationally and by region prior to and after the heart allocation policy change of 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically with respect to allosensitized patients, a comparison of the number of heart transplants performed, the mortality rate for individuals on the heart transplant waiting lists, and the post heart transplant survival rate nationally and by region prior to and after the heart allocation policy change of 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The increase provided for in the amendment made by section 2 [amending this section] shall not apply with respect to contracts entered into under section 372(a) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274/a"},"text":"42 U.S.C. 274(a)","children":[],"tail":") after the date that is 1 year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":"] if the Executive Director of the Organ Procurement and Transplantation Network fails to submit the report under subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
