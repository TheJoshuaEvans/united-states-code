{"tag":"section","attrib":{"id":"idc00d212f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16316"},"text":null,"children":[{"tag":"num","attrib":{"value":"16316"},"text":"§ 16316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced scientific computing research and development program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16316/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an advanced scientific computing research and development program that includes activities related to applied mathematics and activities authorized by the American Super Computing Leadership Act of 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5541"},"text":"15 U.S.C. 5541","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16316/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the program with the goal of supporting departmental missions, and providing the high-performance computational, networking, advanced visualization technologies, and workforce resources, that are required for world leadership in science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d2132-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s976/a"},"text":"Pub. L. 109–58, title IX, § 976(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/903"},"text":"119 Stat. 903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s304/b/1/B"},"text":"Pub. L. 115–246, title III, § 304(b)(1)(B)","children":[],"tail":", formerly § 304(a)(1)(B), "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3145"},"text":"132 Stat. 3145","children":[],"tail":", renumbered § 304(b)(1)(B), "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10104/a/1"},"text":"Pub. L. 117–167, div. B, title I, § 10104(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1433"},"text":"136 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d2133-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d2134-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00d2135-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The American Super Computing Leadership Act of 2017, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423"},"text":"Pub. L. 108–423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2400"},"text":"118 Stat. 2400","children":[],"tail":", which is classified principally to subchapter III (§ 5541 et seq.) of chapter 81 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5501"},"text":"section 5501 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d2136-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246"},"text":"Pub. L. 115–246","children":[],"tail":" substituted “American Super Computing Leadership Act of 2017” for “Department of Energy High-End Computing Revitalization Act of 2004”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
