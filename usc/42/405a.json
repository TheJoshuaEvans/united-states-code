{"tag":"section","attrib":{"id":"idb72a59d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405a"},"text":null,"children":[{"tag":"num","attrib":{"value":"405a"},"text":"§ 405a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations pertaining to frequency or due dates of payments and reports under voluntary agreements covering State and local employees; effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no regulation and no modification of any regulation, promulgated by the Secretary of Health and Human Services, after ","children":[{"tag":"date","attrib":{"date":"1976-01-02"},"text":"January 2, 1976","children":[],"tail":", shall become effective prior to the end of the eighteen-month period which begins with the first day of the first calendar month which begins after the date on which such regulation or modification of a regulation is published in the Federal Register, if and insofar as such regulation or modification of a regulation pertains, directly or indirectly, to the frequency or due dates for payments and reports required under section 418(e) "},{"tag":"ref","attrib":{"idref":"fn002572"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002572"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb72a59d9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/202/s7"},"text":"Pub. L. 94–202, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-01-02"},"text":"Jan. 2, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1137"},"text":"89 Stat. 1137","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"t