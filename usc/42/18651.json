{"tag":"section","attrib":{"id":"idc060987f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651"},"text":null,"children":[{"tag":"num","attrib":{"value":"18651"},"text":"§ 18651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High intensity laser research initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0609880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a high intensity laser research initiative consistent with the recommendations of the National Academies report entitled “Opportunities in Intense Ultrafast Lasers: Reaching for the Brightest Light” and the report from the Brightest Light Initiative workshop entitled “The Future of Intense Ultrafast Lasers in the U.S.”. The initiative should include research and development of petawatt-scale and of high average power laser technologies necessary for future facility needs in discovery science and to advance energy technologies, as well as support for a user network of academic and National Laboratory high intensity laser facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall leverage new laser technologies for more compact, less complex, and low-cost accelerator systems needed for science applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall coordinate the initiative established under subsection (a) among all relevant programs within the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Science shall coordinate the initiative established under subsection (a) with other relevant programs within the Department and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there are authorized to be appropriated to the Secretary to carry out the activities described in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc060988a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18651/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc060988b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s313"},"text":"Pub. L. 115–246, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10112/a"},"text":"Pub. L. 117–167, div. B, title I, § 10112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1459"},"text":"136 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
