{"tag":"section","attrib":{"id":"idb425cb96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s210–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"210–1"},"text":"§ 210–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual and sick leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb425cb97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s210–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations of the President, commissioned officers of the Regular Corps and officers of the Ready Ready ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Reserve Corps on active duty may be granted annual leave and sick leave without any deductions from their pay and allowances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb425cb98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s210–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations described in subsection (a) may authorize accumulated annual leave of not more than 120 days for any commissioned officer of the Regular Corps or officer of the Ready Reserve Corps on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb425cb99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s210–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See 1962 Amendment note for subsec. (d) below."}],"tail":" Definitions"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section the term “accumulated annual leave” means unused accrued annual leave carried forward from one leave year into a succeeding leave year, and the term “accrued annual leave” means the annual leave accruing to an officer during one leave year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb425cb9a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 219, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch654/s2"},"text":"Aug. 9, 1950, ch. 654, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/426"},"text":"64 Stat. 426","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14b"},"text":"Pub. L. 87–649, § 14b","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/499"},"text":"76 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/76/tIII/s311"},"text":"Pub. L. 96–76, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/586"},"text":"93 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3214/e/3"},"text":"Pub. L. 116–136, div. A, title III, § 3214(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/373"},"text":"134 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2225/a"},"text":"Pub. L. 117–328, div. FF, title II, § 2225(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5750"},"text":"136 Stat. 5750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb425cb9b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb425cb9c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb425cb9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2225/a/1"},"text":"Pub. L. 117–328, § 2225(a)(1)","children":[],"tail":", substituted “Ready Reserve Corps” for “Reserve Corps” and struck out “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such regulations shall not authorize annual leave to be accumulated in excess of sixty days” after “allowances”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2225/a/2"},"text":"Pub. L. 117–328, § 2225(a)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2225/a/3"},"text":"Pub. L. 117–328, § 2225(a)(3)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “Ready Reserve Corps” for “Reserve Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/76"},"text":"Pub. L. 96–76","children":[],"tail":", repealed subsec. (c) which set forth limitations on granting of annual leave under subsec. (a) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" repealed subsec. (b) which required forfeiture of all pay and allowances of an officer absent without leave. See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s503"},"text":"section 503 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" repealed last sentence which authorized a lump-sum payment for unused accumulated and accrued annual leave on date of separation, retirement, or release from active duty. See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s501"},"text":"section 501 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" repealed subsec. (d) insofar as it was applicable to the last sentence of subsec. (c). See Amendment note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb425cb9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb425cb9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2225/b"},"text":"Pub. L. 117–328, div. FF, title II, § 2225(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5750"},"text":"136 Stat. 5750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tII/s2225/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to accumulated annual leave (as defined in section 219 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s210–1"},"text":"42 U.S.C. 210–1","children":[],"tail":")) that a commissioned officer of the Regular Corps or officer of the Ready Reserve Corps on active duty would, but for the regulations described in such section, lose at the end of fiscal year 2022 or a subsequent fiscal year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb425cba0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb425cba1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1950-07-01"},"text":"July 1, 1950","children":[],"tail":", see section 3(a) of act "},{"tag":"date","attrib":{"date":"1950-08-09"},"text":"Aug. 9, 1950","children":[],"tail":", set out as an Effective Date of 1950 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s210"},"text":"section 210 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb425cba2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization To Accumulate Excess Annual Leave","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/180/dD/tIII/s302"},"text":"Pub. L. 117–180, div. D, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"Sept. 30, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2136"},"text":"136 Stat. 2136","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/180/dD/tIII/s302"},"text":"“For purposes of annual leave accumulated in fiscal year 2022, the authority provided in section 2106 of division C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Public Law 116–159","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s210–1"},"text":"42 U.S.C. 210–1","children":[],"tail":" note) shall apply to such leave by substituting ‘2022’ for ‘2020’ in subsections (a) and (d)(2).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/dC/tI/s2106"},"text":"Pub. L. 116–159, div. C, title I, § 2106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/729"},"text":"134 Stat. 729","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/159/dC/tI/s2106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 219 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s210–1"},"text":"42 U.S.C. 210–1","children":[],"tail":"), a commissioned officer of the Public Health Service who, except for this section, would lose at the end of the fiscal year 2020 accumulated annual leave in excess of 60 days, may retain such amounts of accumulated annual leave in excess of 60 days."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Excess Leave","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Annual leave retained pursuant to subsection (a) shall be lost unless it is used by the officer no later than ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply to an officer on terminal leave preceding separation, retirement, or release from active duty, as of the effective date specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall become effective on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb425cba3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensation for Prior Accumulated and Accrued Leave; Limitation; Inapplicable to Officers on Terminal Leave Prior to ","children":[{"tag":"date","attrib":{"date":"1950-07-01"},"text":"July 1, 1950","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch654/s3/b"},"text":"Act Aug. 9, 1950, ch. 654, § 3(b)","children":[],"tail":", (c), "},{"tag":"ref","attrib":{"href":"/us/stat/64/426"},"text":"64 Stat. 426","children":[],"tail":", 427, provided that any officer credited with more than sixty days of accumulated and accrued leave on "},{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", be compensated for so much of such leave as exceeds sixty days, that such compensation be due and payable on "},{"tag":"date","attrib":{"date":"1950-07-01"},"text":"July 1, 1950","children":[],"tail":", and that the provisions of this Act not apply to any officer on terminal leave preceding separation, retirement, or release from active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb425cba4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch654/s4"},"text":"Act Aug. 9, 1950, ch. 654, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/427"},"text":"64 Stat. 427","children":[],"tail":", provided for the availability of funds for payment of compensation for prior accumulated and accrued leave for any officer under section 3 of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb425cba5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Leave Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-09/ch654/s5"},"text":"Act Aug. 9, 1950, ch. 654, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/427"},"text":"64 Stat. 427","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-08-09/ch654/s5"},"text":"“Except insofar as the provisions of this Act [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s210"},"text":"section 210 of this title","children":[],"tail":", and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s210"},"text":"section 210 of this title","children":[],"tail":"] are inconsistent therewith, leave regulations adopted prior to the enactment of this Act ["},{"tag":"date","attrib":{"date":"1950-08-09"},"text":"Aug. 9, 1950","children":[],"tail":"], pursuant to the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], shall remain in effect until repealed, amended, or superseded.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb425cba6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb425cba7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Public Health Service, of Surgeon General of Public Health Service, and all other officers and employees of Public Health Service, and functions of all agencies of or in Public Health Service transferred to Secretary of Health, Education, and Welfare by Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb425cba8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President delegated to Secretary of Health and Human Services, see Ex. Ord. No. 11140, ","children":[{"tag":"date","attrib":{"date":"1964-01-30"},"text":"Jan. 30, 1964","children":[],"tail":", 29 F.R. 1637, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
