{"tag":"section","attrib":{"id":"idbeae7b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9120"},"text":null,"children":[{"tag":"num","attrib":{"value":"9120"},"text":"§ 9120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of licensees’ activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each license shall require the licensee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeae7b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9120/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow the Administrator to place appropriate Federal officers or employees in or aboard the ocean thermal energy conversion facility or plantship to which the license applies, at such times and to such extent as the Administrator deems reasonable and necessary to assess compliance with any condition or regulation applicable to the license, and to report to the Administrator whenever such officers or employees have reason to believe there is a failure to comply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeae7b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9120/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with such officers and employees in the performance of monitoring functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeae7b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9120/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor the environmental effects, if any, of the operation of the ocean thermal energy conversion facility or plantship in accordance with regulations issued by the Administrator, and to submit such information as the Administrator finds to be necessary and appropriate to assess environmental impacts and to develop and evaluate mitigation methods and possibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeae7b81-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/tI/s110"},"text":"Pub. L. 96–320, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/988"},"text":"94 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tVI/s602/a/8"},"text":"Pub. L. 98–623, title VI, § 602(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3411"},"text":"98 Stat. 3411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeae7b82-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeae7b83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeae7b84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":" substituted “in or aboard” for “aboard”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
