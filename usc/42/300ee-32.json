{"tag":"section","attrib":{"id":"idb68d07b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–32"},"text":"§ 300ee–32.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information campaigns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68d07b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may make grants to public entities, and to nonprofit private entities concerned with acquired immune deficiency syndrome, and shall enter into contracts with public and private entities, for the development and delivery of public service announcements and paid advertising messages that warn individuals about activities which place them at risk of infection with the etiologic agent for such syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68d07b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not provide financial assistance under subsection (a) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68d07b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for such assistance is submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68d07b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to carrying out the purpose for which the assistance is to be provided, the application provides assurances of compliance satisfactory to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68d07b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–32/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68d07b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2522, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3103"},"text":"102 Stat. 3103","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/23"},"text":"Pub. L. 102–531, title III, § 312(d)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68d07b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68d07b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb68d07ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
