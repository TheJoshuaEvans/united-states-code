{"tag":"section","attrib":{"id":"idbb6bfad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1769i"},"text":"§ 1769i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb6bfad4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfad5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds made available under paragraph (3), the Secretary, acting through the Administrator of the Food and Nutrition Service, may conduct annual national performance assessments of the meal programs under this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting an assessment, the Secretary may assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of producing meals and meal supplements under the programs described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nutrient profile of meals, and status of menu planning practices, under the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $5,000,000 for fiscal year 2004 and each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb6bfadb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds made available under paragraph (5), the Secretary, acting through the Administrator of the Food and Nutrition Service, shall conduct a study of the feasibility of improving the certification process used for the school lunch program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfadc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary may conduct pilot projects to improve the certification process used for the school lunch program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfadd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall examine the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other income reporting systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfadf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an integrated benefit eligibility determination process managed by a single agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfae0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income or program participation data gathered by State or local agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfae1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other options determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb6bfae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary may waive such provisions of this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.) as are necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb6bfae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The protections of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1758/b/6"},"text":"section 1758(b)(6) of this title","children":[],"tail":" shall apply to any study or pilot project carried out under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb6bfae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection such sums as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb6bfae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1769i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with program research and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States, State educational agencies, local educational agencies, schools, institutions, facilities, and contractors participating in programs authorized under this chapter and the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.) shall cooperate with officials and contractors acting on behalf of the Secretary, in the conduct of evaluations and studies under those Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb6bfae7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s28"},"text":"June 4, 1946, ch. 281, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/265/tI/s129"},"text":"Pub. L. 108–265, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-30"},"text":"June 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/767"},"text":"118 Stat. 767","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tIII/s305"},"text":"Pub. L. 111–296, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3243"},"text":"124 Stat. 3243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb6bfae8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb6bfae9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb6bfaea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsecs. (a)(1), (b)(4)(A), and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Those Acts, referred to in subsec. (c), mean the Richard B. Russell National School Lunch Act, which was in the original “this Act” and was translated to read “this chapter”, and the Child Nutrition Act of 1966. See above.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb6bfaeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296"},"text":"Pub. L. 111–296","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb6bfaec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb6bfaed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296"},"text":"Pub. L. 111–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
