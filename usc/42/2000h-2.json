{"tag":"section","attrib":{"id":"idbbc69e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000h–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000h–2"},"text":"§ 2000h–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention by Attorney General; denial of equal protection on account of race, color, religion, sex or national origin","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever an action has been commenced in any court of the United States seeking relief from the denial of equal protection of the laws under the fourteenth amendment to the Constitution on account of race, color, religion, sex or national origin, the Attorney General for or in the name of the United States may intervene in such action upon timely application if the Attorney General certifies that the case is of general public importance. In such action the United States shall be entitled to the same relief as if it had instituted the action.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbc69e59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tIX/s902"},"text":"Pub. L. 88–352, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/266"},"text":"78 Stat. 266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tIX/s906/a"},"text":"Pub. L. 92–318, title IX, § 906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/375"},"text":"86 Stat. 375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbc69e5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbc69e5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbc69e5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":" inserted “sex” after “religion,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
