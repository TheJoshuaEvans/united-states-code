{"tag":"section","attrib":{"id":"idbbb84591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000d–4"},"text":"§ 2000d–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal authority and financial assistance to programs or activities by way of contract of insurance or guaranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall add to or detract from any existing authority with respect to any program or activity under which Federal financial assistance is extended by way of a contract of insurance or guaranty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb84592-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tVI/s605"},"text":"Pub. L. 88–352, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/253"},"text":"78 Stat. 253","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
