{"tag":"section","attrib":{"id":"idb69da9ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–51"},"text":"§ 300ff–51.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of a program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69daa00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes described in subsection (b), the Secretary, acting through the Administrator of the Health Resources and Services Administration, may make grants to public and nonprofit private entities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/a"},"text":"section 300ff–52(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the applicant for the grant agrees to expend the grant only for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core medical services described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support services described in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative expenses as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–64/g/3"},"text":"section 300ff–64(g)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early intervention services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant for a grant under subsection (a) shall expend not less than 50 percent of the amount received under the grant for the services described in subparagraphs (B) through (E) of subsection (e)(1) for individuals with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required funding for core medical services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant under subsection (a) to an applicant for a fiscal year, the applicant shall, of the portion of the grant remaining after reserving amounts for purposes of paragraphs (3) and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–64/g"},"text":"section 300ff–64(g) of this title","children":[],"tail":", use not less than 75 percent to provide core medical services that are needed in the area involved for individuals with HIV/AIDS who are identified and eligible under this subchapter (including services regarding the co-occurring conditions of the individuals)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall waive the application of paragraph (1) with respect to an applicant for a grant if the Secretary determines that, within the service area of the applicant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb69daa0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are no waiting lists for AIDS Drug Assistance Program services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–26"},"text":"section 300ff–26 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb69daa0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core medical services are available to all individuals with HIV/AIDS identified and eligible under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of waiver status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When informing an applicant that a grant under subsection (a) is being made for a fiscal year, the Secretary shall inform the applicant whether a waiver under subparagraph (A) is in effect for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core medical services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “core medical services”, with respect to an individual with HIV/AIDS (including the co-occurring conditions of the individual) means the following services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outpatient and ambulatory health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" AIDS Drug Assistance Program treatments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–26"},"text":"section 300ff–26 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" AIDS pharmaceutical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oral health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Early intervention services described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health insurance premium and cost sharing assistance for low-income individuals in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–25"},"text":"section 300ff–25 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical nutrition therapy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospice services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home and community-based health services as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–24/c"},"text":"section 300ff–24(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substance abuse outpatient care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/c/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical case management, including treatment adherence services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “support services” means services, subject to the approval of the Secretary, that are needed for individuals with HIV/AIDS to achieve their medical outcomes (such as respite care for persons caring for individuals with HIV/AIDS, outreach services, medical transportation, linguistic services, and referrals for health care and support services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of medical outcomes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “medical outcomes” means those outcomes affecting the HIV-related clinical status of an individual with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of early intervention services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The early intervention services referred to in this section are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling individuals with respect to HIV/AIDS in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–62"},"text":"section 300ff–62 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing individuals with respect to HIV/AIDS, including tests to confirm the presence of the disease, tests to diagnose the extent of the deficiency in the immune system, and tests to provide information on appropriate therapeutic measures for preventing and treating the deterioration of the immune system and for preventing and treating conditions arising from HIV/AIDS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other clinical and diagnostic services regarding HIV/AIDS, and periodic medical evaluations of individuals with HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the therapeutic measures described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referrals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services referred to in paragraph (1)(C) are referrals of individuals with HIV/AIDS to appropriate providers of health and support services, including, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to entities receiving amounts under part A or B for the provision of such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to biomedical research facilities of institutions of higher education that offer experimental treatment for such disease, or to community-based organizations or other entities that provide such treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–71"},"text":"section 300ff–71 of this title","children":[],"tail":", in the case of a pregnant woman."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of availability of all early intervention services through each grantee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the applicant for the grant agrees that each of the early intervention services specified in paragraph (2) will be available through the grantee. With respect to compliance with such agreement, such a grantee may expend the grant to provide the early intervention services directly, and may expend the grant to enter into agreements with public or nonprofit private entities, or private for-profit entities if such entities are the only available provider of quality HIV care in the area, under which the entities provide the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grantees described in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb69daa2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (A), (D), (E), and (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/a/1"},"text":"section 300ff–52(a)(1) of this title","children":[],"tail":" shall use not less than 50 percent of the amount of such a grant to provide the services described in subparagraphs (A), (B), (D), and (E) of paragraph (1) directly and on-site or at sites where other primary care services are rendered; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb69daa2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–51/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraphs (B) and (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–52/a/1"},"text":"section 300ff–52(a)(1) of this title","children":[],"tail":" shall ensure the availability of early intervention services through a system of linkages to community-based primary care providers, and to establish mechanisms for the referrals described in paragraph (1)(C), and for follow-up concerning such referrals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69daa2f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2651, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/606"},"text":"104 Stat. 606","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIV/s401/b/2"},"text":"Pub. L. 101–557, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2771"},"text":"104 Stat. 2771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":", §§ 3(d)(1), 12(c)(7), "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","chil