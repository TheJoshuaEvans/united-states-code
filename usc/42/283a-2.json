{"tag":"section","attrib":{"id":"idb556f929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"283a–2"},"text":"§ 283a–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting regarding training of graduate students for doctoral degrees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556f92a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each institution receiving an award under this subchapter for the training of graduate students for doctoral degrees shall annually report to the Director of NIH, with respect to graduate students supported by the National Institutes of Health at such institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556f92b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of such students admitted for study who successfully attain a doctoral degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556f92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for students described in paragraph (1), the average time between the beginning of graduate study and the receipt of a doctoral degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283a–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(b)”."}],"tail":" Provision of information to applicants"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution described in subsection (a) shall provide to each student submitting an application for a program of graduate study at such institution the information described in paragraphs (1) and (2) of such subsection with respect to the program or programs to which such student has applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5596a2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 403C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/a/3"},"text":"Pub. L. 109–482, title I, § 104(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3692"},"text":"120 Stat. 3692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tXI/s1104/5"},"text":"Pub. L. 110–85, title XI, § 1104(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/975"},"text":"121 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2042/c"},"text":"Pub. L. 114–255, div. A, title II, § 2042(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1073"},"text":"130 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5596a2f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5596a30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5596a31-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 403C of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 403D and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283a–3"},"text":"section 283a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5596a32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" struck out “(not including any leaves of absence)” after “time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s1104/5/A"},"text":"Pub. L. 110–85, § 1104(5)(A)","children":[],"tail":", substituted “graduate students supported by the National Institutes of Health” for “each degree-granting program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s1104/5/B"},"text":"Pub. L. 110–85, § 1104(5)(B)","children":[],"tail":", inserted “such” after “percentage of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85/s1104/5/C"},"text":"Pub. L. 110–85, § 1104(5)(C)","children":[],"tail":", inserted “(not including any leaves of absence)” after “average time”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5596a33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5596a34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
