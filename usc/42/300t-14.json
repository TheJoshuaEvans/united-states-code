{"tag":"section","attrib":{"id":"idb65640b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300t–14"},"text":"§ 300t–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To make payments under grants under sections 300t–12 and 300t–13 of this title there are authorized to be appropriated $30,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", $50,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", and $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", except that in any fiscal year not more than 10 percent of the amount appropriated under this section may be obligated for grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300t–13"},"text":"section 300t–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb65640b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1644, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tIII/s301/a"},"text":"Pub. L. 96–79, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/640"},"text":"93 Stat. 640","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
