{"tag":"section","attrib":{"id":"idbbb11a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1983"},"text":null,"children":[{"tag":"num","attrib":{"value":"1983"},"text":"§ 1983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action for deprivation of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who, under color of any statute, ordinance, regulation, custom, or usage, of any State or Territory or the District of Columbia, subjects, or causes to be subjected, any citizen of the United States or other person within the jurisdiction thereof to the deprivation of any rights, privileges, or immunities secured by the Constitution and laws, shall be liable to the party injured in an action at law, suit in equity, or other proper proceeding for redress, except that in any action brought against a judicial officer for an act or omission taken in such officer’s judicial capacity, injunctive relief shall not be granted unless a declaratory decree was violated or declaratory relief was unavailable. For the purposes of this section, any Act of Congress applicable exclusively to the District of Columbia shall be considered to be a statute of the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb11a08-3a70-11f1-ae07-e4213316b5fa"},"text":"(R.S. § 1979; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/170/s1"},"text":"Pub. L. 96–170, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1284"},"text":"93 Stat. 1284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tIII/s309/c"},"text":"Pub. L. 104–317, title III, § 309(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3853"},"text":"110 Stat. 3853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb11a09-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb11a0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbb11a0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1979 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1871-04-20/ch22/s1"},"text":"act Apr. 20, 1871, ch. 22, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/13"},"text":"17 Stat. 13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s43"},"text":"section 43 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbb11a0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" inserted before period at end of first sentence “, except that in any action brought against a judicial officer for an act or omission taken in such officer’s judicial capacity, injunctive relief shall not be granted unless a declaratory decree was violated or declaratory relief was unavailable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/170"},"text":"Pub. L. 96–170","children":[],"tail":" inserted “or the District of Columbia” after “Territory”, and provisions relating to Acts of Congress applicable solely to the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbb11a0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbbb11a0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/170"},"text":"Pub. L. 96–170","children":[],"tail":" applicable with respect to any deprivation of rights, privileges, or immunities secured by the Constitution and laws occurring after "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/170/s3"},"text":"section 3 of Pub. L. 96–170","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1343"},"text":"section 1343 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
