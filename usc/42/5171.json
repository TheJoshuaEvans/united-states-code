{"tag":"section","attrib":{"id":"idbd16c4b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5171"},"text":null,"children":[{"tag":"num","attrib":{"value":"5171"},"text":"§ 5171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd16c4b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repair, reconstruction, restoration, or replacement of United States facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may authorize any Federal agency to repair, reconstruct, restore, or replace any facility owned by the United States and under the jurisdiction of such agency which is damaged or destroyed by any major disaster if he determines that such repair, reconstruction, restoration, or replacement is of such importance and urgency that it cannot reasonably be deferred pending the enactment of specific authorizing legislation or the making of an appropriation for such purposes, or the obtaining of congressional committee approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd16c4ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds appropriated to agency for repair, reconstruction, restoration, or replacement of agency facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the provisions of this section, such repair, reconstruction, restoration, or replacement may be begun notwithstanding a lack or an insufficiency of funds appropriated for such purpose, where such lack or insufficiency can be remedied by the transfer, in accordance with law, of funds appropriated to that agency for another purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd16c4bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steps for mitigation of hazards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, Federal agencies shall evaluate the natural hazards to which these facilities are exposed and shall take appropriate action to mitigate such hazards, including safe land-use and construction practices, in accordance with standards prescribed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd16c4bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s405"},"text":"Pub. L. 93–288, title IV, § 405","children":[],"tail":", formerly § 401, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/153"},"text":"88 Stat. 153","children":[],"tail":"; renumbered § 405, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/a/2"},"text":"Pub. L. 100–707, title I, § 106(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4696"},"text":"102 Stat. 4696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd16c4bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd16c4be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd16c4bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s405"},"text":"section 405 of Pub. L. 93–288","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5175"},"text":"section 5175 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
