{"tag":"section","attrib":{"id":"idb685dc68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–31"},"text":"§ 300cc–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall establish fellowship and training programs to be conducted by the Centers for Disease Control and Prevention to train individuals to develop skills in epidemiology, surveillance, testing, counseling, education, information, and laboratory analysis relating to acquired immune deficiency syndrome. Such programs shall be designed to enable health professionals and health personnel trained under such programs to work, after receiving such training, in national and international efforts toward the prevention, diagnosis, and treatment of acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs conducted by National Institute of Mental Health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the National Institute of Mental Health, shall conduct or support fellowship and training programs for individuals pursuing graduate or postgraduate study in order to train such individuals to conduct scientific research into the psychological and social sciences as such sciences relate to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to limitation on number of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual receiving a fellowship or receiving training under subsection (a) or (b) shall not be included in any determination of the number of full-time equivalent employees of the Department of Health and Human Services for the purpose of any limitation on the number of such employees established by law prior to, on, or after ","children":[{"tag":"date","attrib":{"date":"1988-11-04"},"text":"November 4, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–31/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc6d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2341, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3076"},"text":"102 Stat. 3076","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2617/e"},"text":"Pub. L. 100–690, title II, § 2617(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4240"},"text":"102 Stat. 4240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/21"},"text":"Pub. L. 102–531, title III, § 312(d)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/7"},"text":"Pub. L. 103–43, title XVIII, § 1811(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/200"},"text":"107 Stat. 200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc6e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc6f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb685dc70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"tex