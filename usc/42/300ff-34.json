{"tag":"section","attrib":{"id":"idb69b60b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–34"},"text":"§ 300ff–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perinatal transmission of HIV/AIDS; contingent requirement regarding State grants under this part","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69b60b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual determination of reported cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall annually determine the rate of reported cases of AIDS as a result of perinatal transmission among residents of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b60b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Causes of perinatal transmission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the rate under subsection (a), a State shall also determine the possible causes of perinatal transmission. Such causes may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b60b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inadequate provision within the State of prenatal counseling and testing in accordance with the guidelines issued by the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b60b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the inadequate provision or utilization within the State of appropriate therapy or failure of such therapy to reduce perinatal transmission of HIV, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69b60b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that therapy is not available, accessible or offered to mothers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69b60b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that available therapy is offered but not accepted by mothers; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b60b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors (which may include the lack of prenatal care) determined relevant by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b60ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–34/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CDC reporting system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 months after ","children":[{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", the Director of the Centers for Disease Control and Prevention shall develop and implement a system to be used by States to comply with the requirements of subsections (a) and (b). The Director shall issue guidelines to ensure that the data collected is statistically valid."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69b60bb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2626, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s7/b/3"},"text":"Pub. L. 104–146, § 7(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1369"},"text":"110 Stat. 1369","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/166/s5/1"},"text":"Pub. L. 104–166, § 5(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-29"},"text":"July 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1449"},"text":"110 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tII/s211/1"},"text":"Pub. L. 106–345, title II, § 211(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1339"},"text":"114 Stat. 1339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tVII"},"text":"Pub. L. 109–415, title VII","children":[],"tail":", §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2820"},"text":"120 Stat. 2820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69b60bc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69b60bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69b60be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","att