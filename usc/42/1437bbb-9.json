{"tag":"section","attrib":{"id":"idbb115782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437bbb–9"},"text":"§ 1437bbb–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb115783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration program under this subchapter shall terminate not less than 2 and not more than 5 years after the date on which the demonstration program is commenced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb115784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the termination of the demonstration program under this subchapter, the Secretary shall submit to the Congress a final report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb115785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation ","children":[{"tag":"ref","attrib":{"idref":"fn003151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of”."}],"tail":" the effectiveness of the activities carried out under the demonstration program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb115786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any findings and recommendations of the Secretary for any appropriate legislative action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb115787-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title IV, § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2624"},"text":"112 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
