{"tag":"section","attrib":{"id":"idbf53202e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501"},"text":null,"children":[{"tag":"num","attrib":{"value":"11501"},"text":"§ 11501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of enterprise zones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf53202f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of zones","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf532030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Enterprise zone” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “enterprise zone” means any area that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is nominated by one or more local governments and the State or States in which it is located for designation as an enterprise zone (in this section referred to as a “nominated area”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Housing and Urban Development designates as an enterprise zone, after consultation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretaries of Agriculture, Commerce, Labor, and the Treasury, the Director of the Office of Management and Budget, and the Administrator of the Small Business Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an area on an Indian reservation, the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of designations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development may designate not more than 100 nominated areas as enterprise zones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum designation in rural areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the areas designated under subparagraph (A), not less than ⅓ shall be areas that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are within a local government jurisdiction or jurisdictions with a population of less than 50,000 (as determined under the most recent census data available);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are outside of a metropolitan statistical area (as designated by the Director of the Office of Management and Budget); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf53203a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are determined by the Secretary, after consultation with the Secretary of Commerce, to be rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53203b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas designated based solely on degree of poverty","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf53203c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary shall designate (i) the nominated areas with the highest average ranking with respect to the criteria set forth in subparagraphs (C) and (D) of subsection (c)(3), and the 1 criterion set forth in subparagraph (E)(i) or (E)(ii) of subsection (c)(3) that gives an area a higher ranking; and (ii) for areas described in paragraph (2)(B), the nominated areas with the highest ranking with respect to the 1 criterion set forth in subparagraph (C), (D), (E)(i), or (E)(ii) of subsection (c)(3) that gives an area a higher ranking. For purposes of the preceding sentence, an area shall be ranked within each such criterion on the basis of the amount by which the area exceeds such criterion, with the area that exceeds such criterion by the greatest amount given the highest ranking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53203d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception where inadequate course of action, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An area shall not be designated under subparagraph (A) if the Secretary determines that the course of action with respect to such area is inadequate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53203e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate application to rural and other areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall be applied separately with respect to areas described in paragraph (2)(B) and to other areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53203f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on designations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before designating any area as an enterprise zone, the Secretary shall prescribe by regulation not later than 4 months following ","children":[{"tag":"date","attrib":{"date":"1988-02-05"},"text":"February 5, 1988","children":[],"tail":", after consultation with the officials described in paragraph (1)(B)—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf532041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures for nominating an area under paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parameters relating to the size and population characteristics of an enterprise zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which nominated areas will be evaluated based on the criteria specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate nominated areas as enterprise zones only during the 24-month period beginning on the 1st day of the 1st month following the month in which the date of the enactment of the Housing and Community Development Act of 1992 occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not make any designation under paragraph (1) unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the local governments and the State in which the nominated area is located have the authority—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf532047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to nominate such area for designation as an enterprise zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf532048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make the State and local commitments under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf532049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assurances satisfactory to the Secretary that such commitments will be fulfilled;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf53204a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nomination therefor is submitted in such a manner and in such form, and contains such information, as the Secretary shall by regulation prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf53204b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that any information furnished is reasonably accurate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf53204c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State and local governments certify that no portion of the area nominated is already included in an enterprise zone or in an area otherwise nominated to be an enterprise zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53204d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination process for Indian reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a nominated area on an Indian reservation, the reservation governing body (as determined by the Secretary of the Interior) shall be deemed to be both the State and local governments with respect to such area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf53204e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for which designation is in effect","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf53204f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any designation of an area as an enterprise zone shall remain in effect during the period beginning on the date of the designation and ending on the earliest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" December 31 of the 24th calendar year following the calendar year in which such date occurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination date designated by the State and local governments as provided for in their nomination pursuant to subsection (a)(4)(C)(ii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the Secretary revokes such designation under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after consultation with the officials described in subsection (a)(1)(B) and a hearing on the record involving officials of the State or local government involved, may revoke the designation of an area if the Secretary determines that the local government or the State in which it is located is not complying substantially with the State and local commitments pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf532054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area and eligibility requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf532055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a designation of any nominated area under subsection (a)(1) only if it meets the requirements of paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nominated area meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area is within the jurisdiction of the local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boundary of the area is continuous; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf53205a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a population, as determined by the most recent census data available, of not less than—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf53205b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4,000 if any portion of such area (other than a rural area described in subsection (a)(2)(B)(i)) is located within a metropolitan statistical area (as designated by the Director of the Office of Management and Budget) with a population of 50,000 or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf53205c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,000 in any other case; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf53205d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entirely within an Indian reservation (as determined by the Secretary of the Interior).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53205e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), a nominated area meets the requirements of this paragraph if the State and local governments in which it is located certify and the Secretary, after such review of supporting data as he deems appropriate, accepts such certification, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf53205f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area is one of pervasive poverty, unemployment, and general distress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area is located wholly within the jurisdiction of a local government that is eligible for Federal assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unemployment rate, as determined by the appropriate available data, was not less than 1.5 times the national unemployment rate for that period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poverty rate (as determined by the most recent census data available) for each populous census tract (or where not tracted, the equivalent county division as defined by the Bureau of the Census for the purpose of defining poverty areas) within the area was not less than 20 percent for the period to which such data relate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the area meets at least one of the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 70 percent of the households living in the area have incomes below 80 percent of the median income of households of the local government (determined in the same manner as under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The population of the area decreased by 20 percent or more between 1970 and 1980 (as determined from the most recent census available).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements for rural areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), a nominated area that is a rural area described in subsection (a)(2)(B) meets the requirements of paragraph (3) if the State and local governments in which it is located certify and the Secretary, after such review of supporting data as he deems appropriate, accepts such certification, that the area meets—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria set forth in subparagraphs (A) and (B) of paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than one of the criteria set forth in the other subparagraphs of paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf532069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required State and local commitments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf53206a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No nominated area shall be designated as an enterprise zone unless the local government and the State in which it is located agree in writing that, during any period during which the area is an enterprise zone, such governments will follow a specified course of action designated to reduce the various burdens borne by employers or employees in such area. A course of action shall not be treated as meeting the requirements of this paragraph unless the course of action include provisions described in not less than 4 of the subparagraphs of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53206b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Course of action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The course of action under paragraph (1) may be implemented by both such governments and private nongovernmental entities, may be funded from proceeds of any program administered by the Secretary of Housing and Urban Development or of any program administered by the Secretary of Agriculture under title V of the Housing Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1471"},"text":"42 U.S.C. 1471","children":[],"tail":" et seq.], and may include, but is not limited to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf53206c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction of tax rates or fees applying within the enterprise zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53206d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the level of public services, or in the efficiency of the delivery of public services, within the enterprise zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53206e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to reduce, remove, simplify, or streamline paperwork requirements within the enterprise zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53206f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involvement in the program by public authorities or private entities, organizations, neighborhood associations, and community groups, particularly those within the nominated area, including a written commitment to provide jobs and job training for, and technical, financial, or other assistance to, employers, employees, and residents of the nominated area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the giving of special preference to contractors owned and operated by members of any minority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gift (or sale at below fair market value) of surplus land in the enterprise zone to neighborhood organizations agreeing to operate a business on the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of past efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating courses of action agreed to by any State or local government, the Secretary shall take into account the past efforts of such State or local government in reducing the various burdens borne by employers and employees in the area involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of assistance for business relocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf532074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The course of action implemented under paragraph (1) may not include any action to assist—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any establishment relocating from one area to another area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subcontractor whose purpose is to divest, or whose economic success is dependent upon divesting, any other contractor or subcontractor of any contract customarily performed by such other contractor or subcontractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf532077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations established in subparagraph (A) shall not be construed to prohibit assistance for the expansion of an existing business entity through the establishment of a new branch, affiliate, or subsidiary if the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf532078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds that the establishment of the new branch, affiliate, or subsidiary will not result in an increase in unemployment in the area of original location or in any other area where the existing business entity conducts business operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf532079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no reason to believe that the new branch, affiliate, or subsidiary is being established with the intention of closing down the operations of the existing business entity in the area of its original location or in any other area where the existing business entity conducts business operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf53207a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf53207b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one government seeks to nominate an area as an enterprise zone, any reference to, or requirement of, this section shall apply to all such governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf53207c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf53207d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any county, city, town, township, parish, village, or other general purpose political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53207e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of political subdivisions described in subparagraph (A) recognized by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf53207f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11501/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands, and any other possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf532082-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tVII/s701"},"text":"Pub. L. 100–242, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1957"},"text":"101 Stat. 1957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1090/a"},"text":"Pub. L. 100–628, title X, § 1090(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3283"},"text":"102 Stat. 3283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVIII/s834/a"},"text":"Pub. L. 102–550, title VIII, § 834(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3855"},"text":"106 Stat. 3855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf532083-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf532084-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf532085-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Housing and Community Development Act of 1992, referred to in subsec. (a)(4)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Housing Act of 1949, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"act July 15, 1949, ch. 338","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/413"},"text":"63 Stat. 413","children":[],"tail":". Title V of the Housing Act of 1949 is classified generally to subchapter III (§ 1471 et seq.) of chapter 8A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1441"},"text":"section 1441 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf532086-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s834/a/1"},"text":"Pub. L. 102–550, § 834(a)(1)","children":[],"tail":", substituted “the date of the enactment of the Housing and Community Development Act of 1992 occurs” for “the effective date of the regulations described in subparagraph (A) occurs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s834/a/2"},"text":"Pub. L. 102–550, § 834(a)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"February 5, 1988","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/s1090/b"},"text":"Pub. L. 100–628, § 1090(b)","children":[],"tail":", substituted “under subparagraph (A)” for “under clause (i)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/s1090/a"},"text":"Pub. L. 100–628, § 1090(a)","children":[],"tail":", amended first sentence generally. Prior to amendment, first sentence read as follows: “Except as provided in subparagraph (B), the Secretary shall designate the nominated areas with the highest average ranking with respect to the criteria set forth in subparagraphs (C), (D), and (E) of subsection (c)(3) of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf532087-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf532088-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1090/c"},"text":"Pub. L. 100–628, title X, § 1090(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3283"},"text":"102 Stat. 3283","children":[],"tail":", provided that not later than 30 days after "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children"