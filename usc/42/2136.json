{"tag":"section","attrib":{"id":"idbbecc391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2136"},"text":null,"children":[{"tag":"num","attrib":{"value":"2136"},"text":"§ 2136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classes of facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbecc392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" group the facilities licensed either under section 2133 or 2134 of this title into classes which may include either production or utilization facilities or both, upon the basis of the similarity of operating and technical characteristics of the facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbecc393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the various activities to be carried on at each such class of facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbecc394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the amounts of special nuclear material available for use by each such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbecc395-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 106, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/938"},"text":"68 Stat. 938","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
