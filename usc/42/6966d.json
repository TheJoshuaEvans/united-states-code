{"tag":"section","attrib":{"id":"idbde167b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6966d"},"text":"§ 6966d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer recycling education and outreach grant program; Federal procurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbde167b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde167b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer recycling education and outreach grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde167b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a program (referred to in this subsection as the “grant program”) to award competitive grants to eligible entities to improve the effectiveness of residential and community recycling programs through public education and outreach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall award grants under the grant program for projects that, by using one or more eligible activities described in paragraph (5)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the public about residential or community recycling programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information about the recycled materials that are accepted as part of a residential or community recycling program that provides for the separate collection of residential solid waste from recycled material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collection rates and decrease contamination in residential and community recycling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that is eligible to receive a grant under the grant program is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Native Hawaiian organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"section 7517 of title 20","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Hawaiian Home Lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Hawaiian Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"2 or more entities described in subparagraph (A) may receive a grant under the grant program to coordinate the provision of information to residents that may access 2 or more residential recycling programs, including programs that accept different recycled materials, to provide to the residents information regarding differences among those residential recycling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a grant under the grant program, an eligible entity shall demonstrate to the Administrator that the grant funds will be used to encourage the collection of recycled materials that are sold to an existing or developing market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business plans and financial data","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity may make a demonstration under subparagraph (A) through the submission to the Administrator of appropriate business plans and financial data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall treat any business plans or financial data received under clause (i) as confidential information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the grant program may use the grant funds for activities including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public service announcements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a door-to-door education and outreach campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social media and digital outreach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advertising campaign on recycling awareness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and dissemination of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a toolkit for a municipal and commercial recycling program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the importance of quality in the recycling stream;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the economic and environmental benefits of recycling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on what happens to materials after the materials are placed into a residential or community recycling program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" businesses recycling outreach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bin, cart, and other receptacle labeling and signs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities that the Administrator determines are appropriate to carry out the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds may be awarded under the grant program for a residential recycling program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not provide for the separate collection of residential solid waste (as defined in section 246.101 of title 40, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":")) from recycled material (as defined in that section), unless the funds are used to promote a transition to a system that separately collects recycled materials; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes the establishment of, or conversion to, a residential collection system that does not provide for the separate collection of residential solid waste from recycled material (as those terms are defined under subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model recycling program toolkit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the grant program, the Administrator, in consultation with other relevant Federal agencies, States, Indian Tribes, units of local government, nonprofit organizations, and the private sector, shall develop a model recycling program toolkit for States, Indian Tribes, and units of local government that includes, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a standardized set of terms and examples that may be used to describe materials that are accepted by a residential recycling program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that the Administrator determines can be widely applied across residential recycling programs, taking into consideration the differences in recycled materials accepted by residential recycling programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational principles on best practices for the collection and processing of recycled materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community self-assessment guide to identify gaps in existing recycling programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training modules that enable States and nonprofit organizations to provide technical assistance to units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to consumer educational materials that States, Indian Tribes, and units of local government can adapt and use in recycling programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guide to measure the effectiveness of a grant received under the grant program, including standardized measurements for recycling rates and decreases in contamination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the standardized set of terms and examples under subparagraph (A)(i), the Administrator may not establish any requirements for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what materials shall be accepted by a residential recycling program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labeling of products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide assistance to the educational community, including nonprofit organizations, such as an organization the science, technology, engineering, and mathematics program of which incorporates recycling, to promote the introduction of recycling principles and best practices into public school curricula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To the Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 180 days, and not later than 2 years, after the date on which a grant under the grant program is awarded to an eligible entity, the eligible entity shall submit to the Administrator a report describing, by using the guide developed under paragraph (7)(A)(vii)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the change in volume of recycled material collected through the activities funded with the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the change in participation rate of the recycling program funded with the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of contamination in the recycling stream as a result of the activities funded with the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall submit to Congress an annual report describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbde167f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of residential recycling programs awarded funds under the grant program, including statistics comparing the quantity and quality of recycled materials collected by those programs, as described in the reports submitted to the Administrator under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbde167f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/b/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on additional actions to improve residential recycling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde167f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde167f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde167f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section and the amendments made by this section $15,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde167f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount made available under paragraph (1) for a fiscal year, not less than 20 percent shall be allocated to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde167f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-income communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde167fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966d/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities identified as Native American pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s3001/9"},"text":"section 3001(9) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbde167fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tIV/s70402"},"text":"Pub. L. 117–58, div. G, title IV, § 70402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1262"},"text":"135 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbde167fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbde167fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbde167fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendments made by this section, referred to in subsec. (d)(1), means the amendments made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70402/c"},"text":"section 70402(c) of Pub. L. 117–58","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6962"},"text":"section 6962 of this title","children":[],"tail":". See Codification note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbde167ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70402"},"text":"section 70402 of Pub. L. 117–58","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70402"},"text":"section 70402 of Pub. L. 117–58","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6962"},"text":"section 6962 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Infrastructure Investment and Jobs Act, and not as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
