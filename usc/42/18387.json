{"tag":"section","attrib":{"id":"idc056fc52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18387"},"text":null,"children":[{"tag":"num","attrib":{"value":"18387"},"text":"§ 18387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Near-Earth object survey and policy with respect to threats posed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc056fc53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy reaffirmation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress reaffirms the policy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20102/g"},"text":"section 20102(g) of title 51","children":[],"tail":" relating to surveying near-Earth asteroids and comets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fc54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the OSTP shall implement, before ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":", a policy for notifying Federal agencies and relevant emergency response institutions of an impending near-Earth object threat if near-term public safety is at risk, and assign a Federal agency or agencies to be responsible for protecting the United States and working with the international community on such threats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fc55-3a70-11f1-ae07-e4213316b5fa"},"text":"(","child