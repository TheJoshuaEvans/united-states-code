{"tag":"section","attrib":{"id":"idbc214156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2364"},"text":null,"children":[{"tag":"num","attrib":{"value":"2364"},"text":"§ 2364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community employment and population","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The indemnity obligation specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2363"},"text":"section 2363 of this title","children":[],"tail":" shall arise only if, for the six months just preceding the date on which it is invoked—"}],"tail":null},{"tag":"subsection","attrib":{"id":"idbc214157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of operating, maintenance, and administrative employees in the project area, as determined by the Commission, has been less than fourteen thousand three hundred and thirty-seven in the case of Oak Ridge or seven thousand six hundred and twenty-two in the case of Richland or four thousand six hundred and twenty in the case of Los Alamos; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc214158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population in the community has been less than twenty-nine thousand two hundred and fifty in the case of Oak Ridge or twenty-five thousand two hundred in the case of Richland or eleven thousand seven hundred and sixty-nine in the case of Los Alamos.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this section employment shall be determined on the basis of the pay period or periods ending nearest the 15th of each month.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc214159-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 6, § 64, "},{"tag":"ref","attrib":{"href":"/us/stat/69/479"},"text":"69 Stat. 479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/719"},"text":"Pub. L. 87–719","children":[],"tail":", §§ 18, 19, "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/666"},"text":"76 Stat. 666","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc21415a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc21415b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc21415c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/719/s18"},"text":"Pub. L. 87–719, § 18","children":[],"tail":", inserted “or four thousand six hundred and twenty in the case of Los Alamos” after “Richland”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/719/s19"},"text":"Pub. L. 87–719, § 19","children":[],"tail":", inserted “or eleven thousand seven hundred and sixty-nine in the case of Los Alamos” after “Richland”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc21415d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc21415e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
