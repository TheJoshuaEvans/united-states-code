{"tag":"section","attrib":{"id":"idb7a184fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b"},"text":null,"children":[{"tag":"num","attrib":{"value":"629b"},"text":"§ 629b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a184fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State plan meets the requirements of this subsection if the plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a184fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the State agency shall administer, or supervise the administration of, the State program under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a184fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a184ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a18500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the goals intended to be accomplished under the plan by the end of the 5th fiscal year in which the plan is in operation in the State, and (ii) is updated periodically to set forth the goals intended to be accomplished under the plan by the end of each 5th fiscal year thereafter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the methods to be used in measuring progress toward accomplishment of the goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains assurances that the State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a18503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the end of each of the 1st 4 fiscal years covered by a set of goals, will perform an interim review of progress toward accomplishment of the goals, and on the basis of the interim review will revise the statement of goals in the plan, if necessary, to reflect changed circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a18504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the end of the last fiscal year covered by a set of goals, will perform a final review of progress toward accomplishment of the goals, and on the basis of the final review (I) will prepare, transmit to the Secretary, and make available to the public a final report on progress toward accomplishment of the goals, and (II) will develop (in consultation with the entities required to be consulted pursuant to subsection (b)) and add to the plan a statement of the goals intended to be accomplished by the end of the 5th succeeding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for coordination, to the extent feasible and appropriate, of the provision of services under the plan and the provision of services or benefits under other Federal or federally assisted programs serving the same populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains assurances that not more than 10 percent of expenditures under the plan for any fiscal year with respect to which the State is eligible for payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629d"},"text":"section 629d of this title","children":[],"tail":" for the fiscal year shall be for administrative costs, and that the remaining expenditures shall be for programs of family preservation services, community-based family support services, family reunification services, and adoption promotion and support services, with significant portions of such expenditures for each such program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains assurances that the State will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually prepare, furnish to the Secretary, and make available to the public a description (including separate descriptions with respect to family preservation services, community-based family support services, family reunification services, and adoption promotion and support services) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a18509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service programs to be made available under the plan in the immediately succeeding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a1850a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the populations which the programs will serve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a1850b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic areas in the State in which the services will be available; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a1850c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" perform the activities described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a1850d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the 1st fiscal year under the plan, at the time the State submits its initial plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a1850e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each succeeding fiscal year, by the end of the 3rd quarter of the immediately preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1850f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for such methods of administration as the Secretary finds to be necessary for the proper and efficient operation of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains assurances that Federal funds provided to the State under this subpart will not be used to supplant Federal or non-Federal funds for existing services and activities which promote the purposes of this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the State will furnish reports to the Secretary, at such times, in such format, and containing such information as the Secretary may require, that demonstrate the State’s compliance with the prohibition contained in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the State agency will furnish such reports, containing such information, and participate in such evaluations, as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides that, not later than June 30 of each year, the State will submit to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a18516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of form CFS–101 (including all parts and any successor forms) that report on planned child and family services expenditures by the agency for the immediately succeeding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a18517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" copies of form CFS–101 (including all parts and any successor forms) that provide, with respect to the programs authorized under this subpart and subpart 1 and, at State option, other programs included on such forms, for the most recent preceding fiscal year for which reporting of actual expenditures is complete—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb7a18518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers of families and of children served by the State agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7a18519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population served by the State agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7a1851a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic areas served by the State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7a1851b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/8/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual expenditures of funds provided to the State agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1851c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains assurances that in administering and conducting service programs under the plan, the safety of the children to be served shall be of paramount concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1851d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the State identifies which populations are at the greatest risk of maltreatment and how services are targeted to the populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1851e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a description of policies in place, including training for employees, to address child welfare reports and investigations of neglect concerning the living arrangements or subsistence needs of a child with the goal to prevent the separation of a child from a parent of the child solely due to poverty, to ensure access to services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629a/a/1/H"},"text":"section 629a(a)(1)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1851f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a18520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve a plan that meets the requirements of subsection (a) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plan was developed jointly by the Secretary and the State, and the State, in developing the plan, consulted with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7a18522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate public and nonprofit private agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a18523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations involved in providing services for children and families in the areas of family preservation, family support, family reunification, foster care, kinship, and adoption promotion and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a18524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents with child welfare experience, foster parents, adoptive parents, and kinship caregivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7a18525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children, youth, and young adults with experience in the child welfare system, including State boards and councils comprised of youth with lived experience who represent the diversity of children in the State to whom the plan would apply; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has made publicly accessible on a website of the State agency a report that outlines how the State has implemented the suggestions of the children and youth referred to in subparagraph (A)(iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a18527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans of Indian tribes or tribal consortia","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7a18528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from inappropriate requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exempt a plan submitted by an Indian tribe or tribal consortium from the requirements of subsection (a)(4) of this section to the extent that the Secretary determines those requirements would be inappropriate to apply to the Indian tribe or tribal consortium, taking into account the resources, needs, and other circumstances of the Indian tribe or tribal consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7a18529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A) of this paragraph, the Secretary may not approve a plan of an Indian tribe or tribal consortium under this subpart to which (but for this subparagraph) an allotment of less than $10,000 would be made under sections 629c(a) and 629g(c)(1) of this title combined if allotments were made under such sections to all Indian tribes and tribal consortia with plans approved under this subpart with the same or larger numbers of children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a1852a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual submission of State reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a1852b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile the reports required under subsection (a)(8)(B) and, not later than September 30 of each year, submit such compilation to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1852c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The compilation shall include the individual State reports and tables that synthesize State information into national totals for each element required to be included in the reports, including planned and actual spending by service category for the program authorized under this subpart and planned spending by service category for the program authorized under subpart 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a1852d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s629b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public accessibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 30 of each year, the Secretary shall publish the compilation on the website of the Department of Health and Human Services in a location easily accessible by the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a1852e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 432, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13711/a/2"},"text":"Pub. L. 103–66, title XIII, § 13711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/651"},"text":"107 Stat. 651","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/89/tIII/s305/b/1"},"text":"Pub. L. 105–89, title III, § 305(b)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1997-11-19"},"text":"Nov. 19, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2130"},"text":"111 Stat. 2130","children":[],"tail":", 2131; "},{"tag":"ref","attrib":{"href":"/us/pl/105/200/tIV/s410/c"},"text":"Pub. L. 105–200, title IV, § 410(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/673"},"text":"112 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/288"},"text":"Pub. L. 109–288","children":[],"tail":", §§ 3(e)(1), (2), 5(b)(3)(A), (c), "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1235"},"text":"120 Stat. 1235","children":[],"tail":", 1243, 1244; "},{"tag":"ref","attrib":{"href":"/us/pl/112/34/tI/s102/b"},"text":"Pub. L. 112–34, title I, § 102(b)","children":[],"tail":", (e), (g)(1), "},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"Sept. 30, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/371"},"text":"125 Stat. 371","children":[],"tail":", 372; "},{"