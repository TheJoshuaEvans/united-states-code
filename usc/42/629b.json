 (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s111/b"},"text":"Pub. L. 118–258, § 111(b)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s109/b"},"text":"Pub. L. 118–258, § 109(b)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “The Secretary shall approve a plan that meets the requirements of subsection (a) only if the plan was developed jointly by the Secretary and the State, after consultation by the State agency with appropriate public and nonprofit private agencies and community-based organizations with experience in administering programs of services for children and families (including family preservation, family support, family reunification, and adoption promotion and support services).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258/s107/b/1"},"text":"Pub. L. 118–258, § 107(b)(1)","children":[],"tail":", substituted “would be made under sections 629c(a) and 629g(c)(1) of this title combined” for “would be made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c/a"},"text":"section 629c(a) of this title","children":[],"tail":"” and “if allotments were made under such sections” for “if allotments were made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s629c/a"},"text":"section 629c(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50721/b/2"},"text":"Pub. L. 115–123, § 50721(b)(2)","children":[],"tail":", struck out “time-limited” before “family reunification services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50721/b/2"},"text":"Pub. L. 115–123, § 50721(b)(2)","children":[],"tail":", struck out “time-limited” before “family reunification services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50721/b/2"},"text":"Pub. L. 115–123, § 50721(b)(2)","children":[],"tail":", struck out “time-limited” before “family reunification”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(8)(B)(i), (ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/g/1"},"text":"Pub. L. 112–34, § 102(g)(1)","children":[],"tail":", substituted “form CFS–101 (including all parts and any successor forms)” for “forms CFS 101–Part I and CFS 101–Part II (or any successor forms)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/b"},"text":"Pub. L. 112–34, § 102(b)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/34/s102/e"},"text":"Pub. L. 112–34, § 102(e)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/e/1"},"text":"Pub. L. 109–288, § 3(e)(1)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s5/b/3/A/i"},"text":"Pub. L. 109–288, § 5(b)(3)(A)(i)","children":[],"tail":", inserted “or tribal consortia” after “tribes” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s5/c"},"text":"Pub. L. 109–288, § 5(c)","children":[],"tail":", substituted “the requirements of subsection (a)(4) of this section to the extent that the Secretary determines those requirements” for “any requirement of this section that the Secretary determines”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s5/b/3/A/ii"},"text":"Pub. L. 109–288, § 5(b)(3)(A)(ii)","children":[],"tail":", inserted “or tribal consortium” after “Indian tribe” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s5/b/3/A/iii"},"text":"Pub. L. 109–288, § 5(b)(3)(A)(iii)","children":[],"tail":", inserted “or tribal consortium” after “Indian tribe” and “and tribal consortia” after “Indian tribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/288/s3/e/2"},"text":"Pub. L. 109–288, § 3(e)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/200"},"text":"Pub. L. 105–200","children":[],"tail":" inserted “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/b/1/A/i"},"text":"Pub. L. 105–89, § 305(b)(1)(A)(i)","children":[],"tail":", substituted “, community-based family support services, time-limited family reunification services, and adoption promotion and support services,” for “and community-based family support services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/b/1/A/ii"},"text":"Pub. L. 105–89, § 305(b)(1)(A)(ii)","children":[],"tail":", substituted “, community-based family support services, time-limited family reunification services, and adoption promotion and support services” for “and community-based family support services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/c/1"},"text":"Pub. L. 105–89, § 305(c)(1)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/89/s305/b/1/B"},"text":"Pub. L. 105–89, § 305(b)(1)(B)","children":[],"tail":", substituted “, family support, time-limited family reunification, and adoption promotion and support” for “and family support”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7a18533-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a18534-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/258"},"text":"Pub. L. 118–258","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"Oct. 1, 2025","children":[],"tail":", and applicable to payments under this part for calendar quarters beginning on or after such date, with delay permitted if either State legislation or tribal action is required to meet additional requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/258/s117"},"text":"section 117 of Pub. L. 118–258","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a18535-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"