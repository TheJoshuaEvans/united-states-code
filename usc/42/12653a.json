{"tag":"section","attrib":{"id":"idbf8ea33a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653a"},"text":"§ 12653a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential awards for service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea33b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea33c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Corporation, may make Presidential awards for service to individuals providing significant service, and to outstanding service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea33d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals and programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511"},"text":"section 12511 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea33e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual receiving an award under this subsection need not be a participant in a program authorized under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea33f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program receiving an award under this subsection need not be a program authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making an award under this section to an individual or program, the President, acting through the Corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized to incur necessary expenses for the honorary recognition of the individual or program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not authorized to make a cash award to such individual or program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Corporation, shall ensure that information concerning individuals and programs receiving awards under this section is widely disseminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8ea344-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198A"},"text":"Pub. L. 101–610, title I, § 198A","children":[],"tail":", formerly § 198B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/c"},"text":"Pub. L. 103–82, title I, § 104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/843"},"text":"107 Stat. 843","children":[],"tail":"; renumbered § 198A and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI"},"text":"Pub. L. 111–13, title I","children":[],"tail":", §§ 1803(b), 1804, "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1554"},"text":"123 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8ea345-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8ea346-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8ea347-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children"