{"tag":"section","attrib":{"id":"idc02e64fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213"},"text":null,"children":[{"tag":"num","attrib":{"value":"17213"},"text":"§ 17213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydropower research, development, and demonstration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for technologies that improve the capacity, efficiency, resilience, security, reliability, affordability, and environmental impact, including potential cumulative environmental impacts, of hydropower systems. In carrying out such program, the Secretary shall prioritize activities designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e64fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop technology for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e64fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-powered dams, including aging and potentially hazardous dams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pumped storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed waterways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new stream-reach development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modular and small dams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased operational flexibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of relevant existing facilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop new strategies and technologies, including analytical methods, physical and numerical tools, and advanced computing, as well as methods to validate such methods and tools, in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the operational lifetime of hydropower systems and their physical structures, while improving environmental impact, including potential cumulative environmental impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in device and system design, installation, operation, and maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce costs, limit outages, and increase unit and plant efficiencies, including by examining the impact of changing water and electricity demand on hydropower generation, flexibility, and provision of grid services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study, in conjunction with other relevant Federal agencies as appropriate, methods to improve the hydropower licensing process, including by compiling current and accepted best practices, public comments, and methodologies to assess the full range of potential environmental and economic impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify opportunities for joint research, development, and demonstration programs between hydropower systems, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e650a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pumped storage systems and other renewable energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e650b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small hydro facilities and other energy storage systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e650c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other hybrid energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e650d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small hydro facilities and critical infrastructure, including water infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e650e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydro facilities and responsive load technologies, which may include smart buildings and city systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e650f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the reliability of hydropower technologies, including during extreme weather events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop methods and technologies to improve environmental impact, including potential cumulative environmental impacts, of hydropower and pumped storage technologies, including potential impacts on wildlife, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aquatic life and resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" navigation of waterways; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upstream and downstream environmental conditions, including sediment movement, water quality, and flow volumes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify ways to increase power generation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversifying plant configuration options;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving pump-back efficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigating multi-phase systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, testing, and monitoring advanced generators with faster cycling times, variable speeds, and improved efficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e651a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, testing, and monitoring advanced turbines capable of improving environmental impact, including potential cumulative environmental impacts, including small turbine designs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e651b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing standardized powertrain components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e651c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing components with advanced materials and manufacturing processes, including additive manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e651d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing analytical tools that enable hydropower to provide grid services that, amongst other services, improve grid integration of other energy sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e651e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advance new pumped storage technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e651f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems with adjustable speed and other new pumping and generating equipment designs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modular systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative closed-loop systems, including mines and quarries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovative equipment and materials as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce civil works costs and construction times for hydropower and pumped storage systems, including comprehensive data and systems analysis of hydropower and pumped storage construction technologies and processes in order to identify areas for whole-system efficiency gains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advance efficient and reliable integration of hydropower and pumped storage systems with the electric grid by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving methods for operational forecasting of renewable energy systems to identify opportunities for hydropower applications in pumped storage and hybrid energy systems, including forecasting of seasonal and annual energy storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering aggregating small distributed hydropower assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying barriers to grid scale implementation of hydropower and pumped storage technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve computational fluid dynamic modeling methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve flow measurement methods, including maintenance of continuous flow measurement equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e652a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify best methods for compiling data on all hydropower resources and assets, including identifying potential for increased capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e652b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17213/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify mechanisms to test and validate performance of hydropower and pumped storage technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02e652c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s634"},"text":"Pub. L. 110–140, title VI, § 634","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2480"},"text":"134 Stat. 2480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e652d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02e652e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc02e652f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 17213, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s634"},"text":"Pub. L. 110–140, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1687"},"text":"121 Stat. 1687","children":[],"tail":", related to National Marine Renewable Energy Research, Development, and Demonstration Centers, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
