{"tag":"section","attrib":{"id":"idbb2e0782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490p–1"},"text":"§ 1490p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Rural Housing Preservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb2e0783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Farmers Home Administration an Office of Rental Housing Preservation (hereafter in this section referred to as the “Office”). The Office shall be headed by a Director designated by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2e0784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Office are:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb2e0785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and process applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1472/c"},"text":"section 1472(c) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1485/t"},"text":"section 1485(t) of this title","children":[],"tail":" related to the preservation of rural rental housing;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e0786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical or financial assistance to any other projects needing such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e0787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate and direct all other activities related to the preservation of rural housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e0788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490p–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor compliance of projects prepaid or receiving incentives under the Housing Act of 1949.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb2e0789-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 537, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVII/s712/c"},"text":"Pub. L. 102–550, title VII, § 712(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3841"},"text":"106 Stat. 3841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb2e078a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb2e078b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb2e078c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing Act of 1949, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"act July 15, 1949, ch. 338","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/413"},"text":"63 Stat. 413","children":[],"tail":", which is classified principally to this chapter (§ 1441 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1441"},"text":"section 1441 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
