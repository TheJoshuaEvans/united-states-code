{"tag":"section","attrib":{"id":"idbfbbf456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332"},"text":null,"children":[{"tag":"num","attrib":{"value":"13332"},"text":"§ 13332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal-fired diesel engines","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for utilizing coal-derived liquid or gaseous fuels, including ultra-clean coal-water slurries, in diesel engines. The program shall address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf457-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required engine retrofit technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf458-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal-fuel production technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf459-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emission control requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf45a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing of low-Btu highly reactive fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf45b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel delivery and storage systems requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf45c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13332/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other infrastructure required to support commercial deployment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf45d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1302"},"text":"Pub. L. 102–486, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2972"},"text":"106 Stat. 2972","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
