{"tag":"section","attrib":{"id":"idbfdfd097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15207"},"text":null,"children":[{"tag":"num","attrib":{"value":"15207"},"text":"§ 15207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall consult with the Institute of Heraldry within the Department of Defense regarding the design and artistry of the Medal of Valor. The Board may also consider suggestions received by the Department of Justice regarding the design of the medal, including those made by persons not employed by the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdfd098-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s9"},"text":"Pub. L. 107–12, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/22"},"text":"115 Stat. 22","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
