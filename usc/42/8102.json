{"tag":"section","attrib":{"id":"idbe7ee011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neighborhood Reinvestment Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe7ee012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Neighborhood Reinvestment Corporation (hereinafter referred to as the “corporation”) which shall be a body corporate and shall possess the powers, and shall be subject to the direction and limitations specified herein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation and expansion of demonstration activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall implement and expand the demonstration activities carried out by the Urban Reinvestment Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall maintain its principal office in the District of Columbia or at such other place the corporation may from time to time prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from taxation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation, including its franchise, activities, assets, and income, shall be exempt from all taxation now or hereafter imposed by the United States, by any territory, dependency, or possession thereof, or by any State, county, municipality, or local taxing authority, except that any real property of the corporation shall be subject to State, territorial, county, municipal, or local taxation to the same extent according to its value as other real property is taxed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe7ee016-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tVI/s603"},"text":"Pub. L. 95–557, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2115"},"text":"92 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s315/1"},"text":"Pub. L. 96–399, title III, § 315(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1645"},"text":"94 Stat. 1645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe7ee017-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe7ee018-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe7ee019-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" struck out “National” before “Neighborhood”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
