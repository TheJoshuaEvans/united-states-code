{"tag":"section","attrib":{"id":"idbfbbf4cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13351"},"text":null,"children":[{"tag":"num","attrib":{"value":"13351"},"text":"§ 13351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional clean coal technology solicitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf4ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program design","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Additional clean coal technology solicitations described in subsection (b) shall be designed to ensure the timely development of cost-effective technologies or energy production processes or systems utilizing coal that achieve greater efficiency in the conversion of coal to useful energy when compared to currently commercially available technology for the use of coal and the control of emissions from the combustion of coal. Such program shall be designed to ensure, to the greatest extent possible, the availability for commercial use of such technologies by the year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf4cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional solicitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the Clean Coal Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Public Law 98–473","children":[],"tail":", the Secretary shall consider the potential benefits of conducting additional solicitations pursuant to such program and, based on the results of that consideration, may carry out such additional solicitations, which shall be similar in scope and percentage of Federal cost sharing as that provided by "},{"tag":"ref","attrib":{"href":"/us/pl/101/121"},"text":"Public Law 101–121","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf4d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1321"},"text":"Pub. L. 102–486, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2976"},"text":"106 Stat. 2976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfbbf4d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfbbf4d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfbbf4d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Public Law 98–473","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":