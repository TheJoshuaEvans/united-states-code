{"tag":"section","attrib":{"id":"idb4ebb45a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–10"},"text":"§ 254c–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A grant may be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–9"},"text":"section 254c–9 of this title","children":[],"tail":" only if the applicant involved makes the following agreements:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ebb45b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 5 percent of the grant will be used for administration, accounting, reporting, and program oversight functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ebb45c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grant will be used to supplement and not supplant funds from other sources related to the treatment of lupus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ebb45d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant will abide by any limitations deemed appropriate by the Secretary on any charges to individuals receiving services pursuant to the grant. As deemed appropriate by the Secretary, such limitations on charges may vary based on the financial circumstances of the individual receiving services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ebb45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The grant will not be expended to make payment for services authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–9/a"},"text":"section 254c–9(a) of this title","children":[],"tail":" to the extent that payment has been made, or can reasonably be expected to be made, with respect to such services—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ebb45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any State compensation program, under an insurance policy, or under any Federal or State health benefits program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ebb460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an entity that provides health services on a prepaid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ebb461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–10/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant will, at each site at which the applicant provides services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–9/a"},"text":"section 254c–9(a) of this title","children":[],"tail":", post a conspicuous notice informing individuals who receive the services of any Federal policies that apply to the applicant with respect to the imposition of charges on such individuals."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4ebb462-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/505/tV/s522"},"text":"Pub. L. 106–505, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2344"},"text":"114 Stat. 2344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4ebb463-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4ebb464-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4ebb465-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Lupus Research and Care Amendments of 2000, and also as part of the Public Health Improvement Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
