{"tag":"section","attrib":{"id":"idb6136ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–4"},"text":"§ 300d–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency medical services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6136ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Interagency Committee on Emergency Medical Services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, the Secretary of Health and Human Services, and the Secretary of Homeland Security, acting through the Under Secretary for Emergency Preparedness and Response, shall establish a Federal Interagency Committee on Emergency Medical Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Committee shall consist of the following officials, or their designees:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, National Highway Traffic Safety Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, Preparedness Division, Directorate of Emergency Preparedness and Response of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, Health Resources and Services Administration, Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, Centers for Disease Control and Prevention, Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, United States Fire Administration, Directorate of Emergency Preparedness and Response of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, Centers for Medicare and Medicaid Services, Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, Indian Health Service, Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief, Wireless Telecommunications Bureau, Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of any other Federal agency appointed by the Secretary of Transportation or the Secretary of Homeland Security through the Under Secretary for Emergency Preparedness and Response, in consultation with the Secretary of Health and Human Services, as having a significant role in relation to the purposes of the Interagency Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State emergency medical services director appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Interagency Committee are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure coordination among the Federal agencies involved with State, local, tribal, or regional emergency medical services and 9–1–1 systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify State, local, tribal, or regional emergency medical services and 9–1–1 needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recommend new or expanded programs, including grant programs, for improving State, local, tribal, or regional emergency medical services and implementing improved emergency medical services communications technologies, including wireless 9–1–1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify ways to streamline the process through which Federal agencies support State, local, tribal or regional emergency medical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist State, local, tribal or regional emergency medical services in setting priorities based on identified needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise, consult, and make recommendations on matters relating to the implementation of the coordinated State emergency medical services programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Highway Traffic Safety Administration, in cooperation with the Administrator of the Health Resources and Services Administration of the Department of Health and Human Services and the Director of the Preparedness Division, Directorate of Emergency Preparedness and Response of the Department of Homeland Security, shall provide administrative support to the Interagency Committee, including scheduling meetings, setting agendas, keeping minutes and records, and producing reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Interagency Committee shall select a chairperson of the Committee each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Committee shall meet as frequently as is determined necessary by the chairperson of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Committee shall prepare an annual report to Congress regarding the Committee’s activities, actions, and recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Emergency Medical Services Advisory Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, in coordination with the Secretary of Health and Human Services and the Secretary of Homeland Security, shall establish a National Emergency Medical Services Advisory Council (referred to in this subsection as the “Advisory Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall be composed of 25 members, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed by the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collectively be representative of all sectors of the emergency medical services community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Advisory Council are to advise and consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6136bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Interagency Committee on Emergency Medical Services on matters relating to emergency medical services issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6136bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation on matters relating to emergency medical services issues affecting the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Highway Traffic Safety Administration shall provide administrative support to the Advisory Council, including scheduling meetings, setting agendas, keeping minutes and records, and producing reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Council shall annually select a chairperson of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall meet as frequently as is determined necessary by the chairperson of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–4/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall prepare an annual report to the Secretary of Transportation regarding the Advisory Council’s actions and recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6136bcb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10202"},"text":"Pub. L. 109–59, title X, § 10202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1932"},"text":"119 Stat. 1932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31108"},"text":"Pub. L. 112–141, div. C, title I, § 31108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/756"},"text":"126 Stat. 756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6136bcc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6136bcd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6136bce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe, Accountable, Flexible, Efficient Transportation Equity Act: A Legacy for Users or SAFETEA–LU, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6136bcf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300d–4, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXII/s1201"},"text":"act July 1, 1944, ch. 373, title XII, § 1201","children":[],"tail":", formerly § 1205, as added "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/154/s2/a"},"text":"Pub. L. 93–154, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/597"},"text":"87 Stat. 597","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/573/s6"},"text":"Pub. L. 94–573, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2713"},"text":"90 Stat. 2713","children":[],"tail":", renumbered § 1201 and amended "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s902/d/1"},"text":"Pub. L. 97–35, title IX, § 902(d)(1)","children":[],"tail":", (3), "},{"tag":"ref","attrib":{"href":"/us/stat/95/560"},"text":"95 Stat. 560","children":[],"tail":", authorized Secretary to make grants and enter into contracts to support research in emergency medical techniques, methods, devices, and delivery, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/117/s12/e"},"text":"Pub. L. 99–117, § 12(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-07"},"text":"Oct. 7, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/495"},"text":"99 Stat. 495","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6136bd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6136bd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6136bd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
