{"tag":"section","attrib":{"id":"idbdc99a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6914a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6914a"},"text":"§ 6914a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling of lubricating oil","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of any provision of law which requires the labeling of commodities, lubricating oil shall be treated as lawfully labeled only if it bears the following statement, prominently displayed:","children":[],"tail":null},{"tag":"level","attrib":{"id":"idbdc99a03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"“DON’T POLLUTE—CONSERVE RESOURCES; RETURN USED OIL TO COLLECTION CENTERS”.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc99a04-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s2005"},"text":"Pub. L. 89–272, title II, § 2005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/463/s4/a"},"text":"Pub. L. 96–463, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2056"},"text":"94 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc99a05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc99a06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdc99a07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","