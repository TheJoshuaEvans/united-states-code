{"tag":"section","attrib":{"id":"idbce2475f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4846"},"text":null,"children":[{"tag":"num","attrib":{"value":"4846"},"text":"§ 4846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws superseded, and null and void","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is hereby expressly declared that it is the intent of the Congress to supersede any and all laws of the States and units of local government insofar as they may now or hereafter provide for a requirement, prohibition, or standard relating to the lead content in paints or other similar surface-coating materials which differs from the provisions of this chapter or regulations issued pursuant to this chapter. Any law, regulation, or ordinance purporting to establish such different requirement, prohibition, or standard shall be null and void.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce24760-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/695/tV/s504"},"text":"Pub. L. 91–695, title V, § 504","children":[],"tail":", formerly § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/151/s7/e"},"text":"Pub. L. 93–151, § 7(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-09"},"text":"Nov. 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/568"},"text":"87 Stat. 568","children":[],"tail":"; renumbered § 504, "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tII/s208/b"},"text":"Pub. L. 95–626, title II, § 208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3588"},"text":"92 Stat. 3588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce24761-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce24762-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbce24763-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/695/s504"},"text":"section 504 of Pub. L. 91–695","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4844"},"text":"section 4844 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/626"},"text":"Pub. L. 95–626","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
