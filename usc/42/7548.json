{"tag":"section","attrib":{"id":"idbe4f1e02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7548"},"text":null,"children":[{"tag":"num","attrib":{"value":"7548"},"text":"§ 7548.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of particulate emissions from motor vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe4f1e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7548/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and analysis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe4f1e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7548/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall conduct a study concerning the effects on health and welfare of particulate emissions from motor vehicles or motor vehicle engines to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521"},"text":"section 7521 of this title","children":[],"tail":" applies. Such study shall characterize and quantify such emissions and analyze the relationship of such emissions to various fuels and fuel additives."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe4f1e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7548/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The study shall also include an analysis of particulate emissions from mobile sources which are not related to engine emissions (including, but not limited to tire debris, and asbestos from brake lining).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe4f1e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7548/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall report to the Congress the findings and results of the study conducted under subsection (a) not later than two years after ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":". Such report shall also include recommendations for standards or methods to regulate particulate emissions described in paragraph (2) of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe518e07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tII/s224/d"},"text":"Pub. L. 95–95, title II, § 224(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/767"},"text":"91 Stat. 767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe518e08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe518e09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe518e0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 214 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", was renumbered section 216 by "},{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550"},"text":"section 7550 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe518e0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe518e0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe518e0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Suspended Particulate Matter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/tIV/s403/a"},"text":"Pub. L. 95–95, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/792"},"text":"91 Stat. 792","children":[],"tail":", directed Administrator of EPA, not later than 18 months after "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", in cooperation with National Academy of Sciences, to study and report to Congress on relationship between size, weight, and chemical composition of suspended particulate matter and nature and degree of endangerment to public health or welfare presented by such particulate matter and availability of technology for controlling such particulate matter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
