ref","attrib":{"href":"/us/pl/94/484/tIX/s902/b"},"text":"Pub. L. 94–484, title IX, § 902(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2324"},"text":"90 Stat. 2324","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tI"},"text":"Pub. L. 96–79, title I","children":[],"tail":", §§ 104(c)(2), 108(d)(2), 117(b)(3), 126(a)(1), (b), "},{"tag":"ref","attrib":{"href":"/us/stat/93/596"},"text":"93 Stat. 596","children":[],"tail":", 602, 619, 628; "},{"tag":"date","attrib":{"date":"1980-12-17"},"text":"Dec. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/538/tIII"},"text":"Pub. L. 96–538, title III","children":[],"tail":", §§ 308, 309, "},{"tag":"ref","attrib":{"href":"/us/stat/94/3192"},"text":"94 Stat. 3192","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s936/a"},"text":"Pub. L. 97–35, title IX, § 936(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/572"},"text":"95 Stat. 572","children":[],"tail":", defined terms applicable to this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tVII/s701/a"},"text":"Pub. L. 99–660, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3799"},"text":"100 Stat. 3799","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6515f05-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183"},"text":"Pub. L. 103–183","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
