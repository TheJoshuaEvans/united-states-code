{"tag":"section","attrib":{"id":"idb6515eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n"},"text":null,"children":[{"tag":"num","attrib":{"value":"300n"},"text":"§ 300n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional required agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6515eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for low-income women","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that low-income women will be given priority in the provision of services and activities pursuant to paragraphs (1) and (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on imposition of fees for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that, if a charge is imposed for the provision of services or activities under the grant, such charge—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be made according to a schedule of charges that is made available to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be adjusted to reflect the income of the woman involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be imposed on any woman with an income of less than 100 percent of the official poverty line, as established by the Director of the Office of Management and Budget and revised by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide provision of services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that services and activities under the grant will be made available throughout the State, including availability to members of any Indian tribe or tribal organization (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirement established in paragraph (1) for a State if the Secretary determines that compliance by the State with the requirement would result in an inefficient allocation of resources with respect to carrying out the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to tribes and tribal organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6515ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, acting through the Director of the Centers for Disease Control and Prevention, may make grants to tribes and tribal organizations (as such terms are used in paragraph (1)) for the purpose of carrying out programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a"},"text":"section 300k(a) of this title","children":[],"tail":". This subchapter applies to such a grant (in relation to the jurisdiction of the tribe or organization) to the same extent and in the same manner as such subchapter applies to a grant to a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" (in relation to the jurisdiction of the State)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6515ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a tribe or tribal organization is receiving a grant under subparagraph (A) and the State in which the tribe or organization is located is receiving a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":", the requirement established in paragraph (1) for the State regarding the tribe or organization is deemed to have been waived under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to items and services under other programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that the grant will not be expended to make payment for any item or service to the extent that payment has been made, or can reasonably be expected to be made, with respect to such item or service—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any State compensation program, under an insurance policy, or under any Federal or State health benefits program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an entity that provides health services on a prepaid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other breast and cervical cancer programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that the services and activities funded through the grant shall be coordinated with other Federal, State, and local breast and cervical cancer programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that not more than 10 percent of the grant will be expended for administrative expenses with respect to the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that the grant will not be expended to provide inpatient hospital services for any individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will establish such fiscal control and fund accounting procedures as may be necessary to ensure the proper disbursal of, and accounting for, amounts received by the State under such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request, the State will provide records maintained pursuant to paragraph (1) to the Secretary or the Comptroller of the United States for purposes of auditing the expenditures by the State of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" unless the State involved agrees to submit to the Secretary such reports as the Secretary may require with respect to the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6515f01-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XV, § 1504, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/354/s2"},"text":"Pub. L. 101–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-10"},"text":"Aug. 10, 1990","children":[],"tail":", "},{"t