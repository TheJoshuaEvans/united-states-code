{"tag":"section","attrib":{"id":"idbdf6eb5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7157"},"text":null,"children":[{"tag":"num","attrib":{"value":"7157"},"text":"§ 7157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers from Department of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are transferred to, and vested in, the Secretary all functions of the Secretary of Commerce, the Department of Commerce, and officers and components of that Department, as relate to or are utilized by the Office of Energy Programs, but limited to industrial energy conservation programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdf6eb60-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s308"},"text":"Pub. L. 95–91, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/581"},"text":"91 Stat. 581","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
