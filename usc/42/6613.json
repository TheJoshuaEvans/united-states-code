{"tag":"section","attrib":{"id":"idbdaf5c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613"},"text":null,"children":[{"tag":"num","attrib":{"value":"6613"},"text":"§ 6613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdaf5c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary function of the Director is to provide, within the Executive Office of the President, advice on the scientific, engineering, and technological aspects of issues that require attention at the highest levels of Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdaf5c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to such other functions and activities as the President may assign, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdaf5c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President of scientific and technological considerations involved in areas of national concern including, but not limited to, the economy, national security, homeland security, health, foreign relations, the environment, and the technological recovery and use of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdaf5c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the scale, quality, and effectiveness of the Federal effort in science and technology and advise on appropriate actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdaf5c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President on scientific and technological considerations with regard to Federal budgets, assist the Office of Management and Budget with an annual review and analysis of funding proposed for research and development in budgets of all Federal agencies, and aid the Office of Management and Budget and the agencies throughout the budget development process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdaf5c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6613/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the President in providing general leadership and coordination of the research and development programs of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdaf5c33-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s204"},"text":"Pub. L. 94–282, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/463"},"text":"90 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1712/1"},"text":"Pub. L. 107–296, title XVII, § 1712(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2320"},"text":"116 Stat. 2320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdaf5c34-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdaf5c35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdaf5c36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" inserted “homeland security,” after “national security,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdaf5c37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbdaf5c38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
