{"tag":"section","attrib":{"id":"idc016970e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16492"},"text":null,"children":[{"tag":"num","attrib":{"value":"16492"},"text":"§ 16492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of certain oil used in transformers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, or rule promulgated by the Environmental Protection Agency, vegetable oil made from soybeans and used in electric transformers as thermal insulation shall not be regulated as an oil identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2720/a/1/B"},"text":"section 2720(a)(1)(B) of title 33","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc016970f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIV/s1403"},"text":"Pub. L. 109–58, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1061"},"text":"119 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
