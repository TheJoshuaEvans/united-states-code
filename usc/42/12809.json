{"tag":"section","attrib":{"id":"idbfa1b5c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12809"},"text":null,"children":[{"tag":"num","attrib":{"value":"12809"},"text":"§ 12809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation of State and local government in rem properties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b5c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program under which States and units of general local government may convert in rem properties to provide affordable permanent housing for the homeless by leasing such properties to nonprofit organizations and permitting such organizations to rehabilitate the properties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall target vacant properties for rehabilitation by nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s259"},"text":"Pub. L. 101–625, title II, § 259","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4124"},"text":"104 Stat. 4124","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
