 this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/280"},"text":"Pub. L. 99–280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66b9cf9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" struck out “substance abuse” before “allocation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s604/a/1"},"text":"Pub. L. 116–94, § 604(a)(1)","children":[],"tail":", struck out “State law regarding” before “sale” and substituted “21” for “18” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s604/a/3"},"text":"Pub. L. 116–94, § 604(a)(3)","children":[],"tail":", (4), redesignated subsec. (b) as (a) and amended subsec. (a) generally. Prior to amendment, subsec. (a) related to the requirement of State enforcement of law in a manner that can reasonably be expected to reduce the extent to which tobacco products are available to individuals under the age of 18 in order to qualify for funding agreements for grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":", and activities and reports regarding such enforcement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/s604/a/2"},"text":"Pub. L. 116–94, § 604(a)(2)","children":[],"tail":", struck out subsec. (a), which required grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for fiscal year 1994 and subsequent fiscal years 