{"tag":"section","attrib":{"id":"idbfa697ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873"},"text":null,"children":[{"tag":"num","attrib":{"value":"12873"},"text":"§ 12873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa697eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make implementation grants to applicants for the purpose of carrying out homeownership programs approved under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa697ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Implementation grants may be used for activities to carry out homeownership programs (including programs for cooperative ownership), including the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa697ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Architectural and engineering work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition of the eligible property for the purpose of transferring ownership to eligible families in accordance with a homeownership program that meets the requirements under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rehabilitation of any property covered by the homeownership program, in accordance with standards established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Abatement of lead-based paint hazards, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4822/a"},"text":"section 4822(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative costs of the applicant, which may not exceed 15 percent of the amount of the assistance provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of resident management corporations and resident management councils, but only if the applicant has not received assistance under section 12872 ","children":[{"tag":"ref","attrib":{"idref":"fn004123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title for such activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling and training of homebuyers and homeowners under the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relocation of tenants who elect to move.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any necessary temporary relocation of tenants during rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning for establishment of for- or not-for-profit small businesses by or on behalf of residents, job training, and other activities that promote economic self-sufficiency of homebuyers and homeowners of the property covered by the homeownership program and economic development of the neighborhood.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funding of operating expenses and replacement reserves of the property covered by the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defraying costs for the ongoing training needs of the recipient that are related to developing and carrying out the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Economic development activities that promote economic self-sufficiency of homebuyers, residents, and homeowners under the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa697fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa697fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient shall assure that contributions equal to not less than 33 percent of the grant amounts made available under this section, excluding any amounts provided for post-sale operating expense, shall be provided from non-Federal sources to carry out the homeownership program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such contributions may be in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa697fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash contributions from non-Federal resources, which may not include funds from a grant made under section 5306(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306/d"},"text":"section 5306(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa697ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of administrative expenses, as defined by the Secretary, from non-Federal resources, including funds from a grant made under section 5306(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306/d"},"text":"section 5306(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of taxes, fees, or other charges that are normally and customarily imposed but are waived, foregone, or deferred in a manner that facilitates the implementation of a homeownership program assisted under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of land or other real property as appraised according to procedures acceptable to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of investment in on-site and off-site infrastructure required for a homeownership program assisted under this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other in-kind contributions as the Secretary may approve.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Contributions for administrative expenses shall be recognized only up to an amount equal to 7 percent of the total amount of grants made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa69804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004124"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004124"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two subsecs. (d) have been enacted."}],"tail":" Application"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa69805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for an implementation grant shall be submitted by an applicant in such form and in accordance with such procedures as the Secretary shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that an application contain at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa69807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for an implementation grant, specifying the amount of the grant requested and its proposed uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, an application for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":", specifying the proposed uses of such assistance and the period during which the assistance will be needed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the qualifications and experience of the applicant in providing low-income housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the proposed homeownership program, consistent with section 12874 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title and the other requirements of this part, specifying the activities proposed to be carried out and their estimated costs, identifying reasonable schedules for carrying it out, and demonstrating the program will comply with the affordability requirements under section 12874(b) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the property involved, and a description of the composition of the tenants, including family size and income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of and commitment for the resources that are expected to be made available to provide the matching funding required under subsection (c) and of other resources that are expected to be made available in support of the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the financing proposed for any (i) rehabilitation and (ii) acquisition (I) of the property, by an entity for transfer to eligible families, and (II) by eligible families of ownership interests in, or shares representing, units in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed sales price, the basis for such price determination, and terms to an entity, if any, that will purchase the property for resale to eligible families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa6980f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed sales prices, if any, and terms to eligible families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed restrictions on the resale of units under a homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and description of the entity that will operate and manage the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by the public official responsible for submitting the comprehensive housing affordability strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12705"},"text":"section 12705 of this title","children":[],"tail":" that the proposed activities are consistent with the approved housing strategy of the State or unit of general local government within which the project is located (or, during the first 12 months after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", that the application is consistent with such other existing State or local housing plan or strategy that the Secretary shall determine to be appropriate); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the applicant will comply with the requirements of the Fair Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.], title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], and the Age Discrimination Act of 1975 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], and will affirmatively further fair housing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa69814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" Selection criteria"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish selection criteria for assistance under this section, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa69815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications or potential capabilities of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of the homeownership program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of tenant interest in the development of a homeownership program for the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for developing an affordable homeownership program and the suitability of the property for homeownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national geographic diversity among housing for which applicants are selected to receive assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa6981a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which a sufficient supply of affordable rental housing of the type assisted under this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" exists in the locality, so that the implementation of the homeownership program will not appreciably reduce the number of such rental units available to residents currently residing in such units or eligible for residency in such units; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa6981b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary determines to be appropriate for purposes of carrying out the program established by the ","children":[{"tag":"ref","attrib":{"idref":"fn004125"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004125"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “this”."}],"tail":" part in an effective and efficient manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa6981c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12873/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify each applicant, not later than 6 months after the date of the submission of the application, whether the application is approved or not approved. The Secretary may approve the application for an implementation grant with a statement that the application for the section 8 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"] assistance for residents of the project not purchasing units is conditionally approved, subject to the availability of appropriations in subsequent fiscal years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa6981d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s423"},"text":"Pub. L. 101–625, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4163"},"text":"104 Stat. 4163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1012/i/2"},"text":"Pub. L. 102–550, title X, § 1012(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3906"},"text":"106 Stat. 3906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa6981e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa6981f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa69820-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12872"},"text":"Section 12872 of this title","children":[],"tail":", referred to in subsec. (b)(6), was in the original “section 322” and was translated as reading “section 422”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s422"},"text":"section 422 of Pub. L. 101–625","children":[],"tail":", to reflect the probable intent of Congress. "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s322"},"text":"Section 322 of Pub. L. 101–625","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1708"},"text":"section 1708 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12874"},"text":"Section 12874 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12874/b"},"text":"section 12874(b) of this title","children":[],"tail":", referred to in subsec. (d)(2)(D), were in the original “section 324” and “section 324(b)”, respectively, and were translated as reading “section 424” and “section 424(b)”, respectively, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s424"},"text":"section 424 of Pub. L. 101–625","children":[],"tail":", to reflect the probable intent of Congress. "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s324"},"text":"Section 324 of Pub. L. 101–625","children":[],"tail":", which proposed an amendment to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1709"},"text":"section 1709 of Title 12","children":[],"tail":", never took effect pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s351"},"text":"section 351 of Pub. L. 101–625","children":[],"tail":". Such section 324 did not contain a subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Housing Act, referred to in subsec. (d)(2)(M), is title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":", which is classified principally to subchapter I (§ 3601 et seq.) of chapter 45 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (d)(2)(M), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Act is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in subsec. (d)(2)(M), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (d)(6), means title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", known as the Homeownership and Opportunity Through HOPE Act, and probably should have been “this subtitle”, meaning subtitle B (§§ 421–431) of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", which is classified principally to this part. For complete classification of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437aaa"},"text":"section 1437aaa of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa69821-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(4) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" added par. (4) and redesignated former pars. (4) to (13) as (5) to (14), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
