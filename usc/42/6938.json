{"tag":"section","attrib":{"id":"idbdd58167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938"},"text":null,"children":[{"tag":"num","attrib":{"value":"6938"},"text":"§ 6938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export of hazardous wastes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdd58168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning twenty-four months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", no person shall export any hazardous waste identified or listed under this subchapter unless "},{"tag":"ref","attrib":{"idref":"fn003527"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003527"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a dash."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd58169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdd5816a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person has provided the notification required in subsection (c) of this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdd5816b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the receiving country has consented to accept such hazardous waste,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdd5816c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the receiving country’s written consent is attached to the manifest accompanying each waste shipment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdd5816d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment conforms with the terms of the consent of the government of the receiving country required pursuant to subsection (e), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd5816e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and the government of the receiving country have entered into an agreement as provided for in subsection (f) and the shipment conforms with the terms of such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd5816f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than twelve months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Administrator shall promulgate the regulations necessary to implement this section. Such regulations shall become effective one hundred and eighty days after promulgation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd58170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who intends to export a hazardous waste identified or listed under this subchapter beginning twelve months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", shall, before such hazardous waste is scheduled to leave the United States, provide notification to the Administrator. Such notification shall contain the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd58171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the exporter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types and estimated quantities of hazardous waste to be exported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated frequency or rate at which such waste is to be exported; and the period of time over which such waste is to be exported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ports of entry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which such hazardous waste will be transported to and treated, stored, or disposed in the receiving country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the ultimate treatment, storage or disposal facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd58177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for requesting consent of receiving country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within thirty days of the Administrator’s receipt of a complete notification under this section, the Secretary of State, acting on behalf of the Administrator, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd58178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward a copy of the notification to the government of the receiving country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd58179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the government that United States law prohibits the export of hazardous waste unless the receiving country consents to accept the hazardous waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd5817a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the government to provide the Secretary with a written consent or objection to the terms of the notification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd5817b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward to the government of the receiving country a description of the Federal regulations which would apply to the treatment, storage, and disposal of the hazardous waste in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd5817c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of written consent to exporter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within thirty days of receipt by the Secretary of State of the receiving country’s written consent or objection (or any subsequent communication withdrawing a prior consent or objection), the Administrator shall forward such a consent, objection, or other communication to the exporter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd5817d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where there exists an international agreement between the United States and the government of the receiving country establishing notice, export, and enforcement procedures for the transportation, treatment, storage, and disposal of hazardous wastes, only the requirements of subsections (a)(2) and (g) shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd5817e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", any person who exports any hazardous waste identified or listed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6921"},"text":"section 6921 of this title","children":[],"tail":" shall file with the Administrator no later than March 1 of each year, a report summarizing the types, quantities, frequency, and ultimate destination of all such hazardous waste exported during the previous calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd5817f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6938/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude the Administrator from establishing other standards for the export of hazardous wastes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6922"},"text":"section 6922 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6923"},"text":"section 6923 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdd58180-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s3017"},"text":"Pub. L. 89–272, title II, § 3017","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tII/s245/a"},"text":"Pub. L. 98–616, title II, § 245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3262"},"text":"98 Stat. 3262","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
