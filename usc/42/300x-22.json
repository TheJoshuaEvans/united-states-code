{"tag":"section","attrib":{"id":"idb6695377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–22"},"text":"§ 300x–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6695378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation regarding primary prevention programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that, in expending the grant, the State involved—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6695379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will expend not less than 20 percent for programs for individuals who do not require treatment for substance use disorders, which programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb669537a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate and counsel the individuals on such disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb669537b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for activities to reduce the risk of such disorders by the individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb669537c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will, in carrying out paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb669537d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to programs for populations that are at risk of developing a pattern of such disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb669537e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that programs receiving priority under subparagraph (A) develop community-based strategies for the prevention of such disorders, including strategies to discourage the use of alcoholic beverages and tobacco products by individuals to whom it is unlawful to sell or distribute such beverages or products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb669537f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations regarding women","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6695380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a fiscal year is that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6695381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant for fiscal year 1993, the State involved will expend not less than 5 percent of the grant to increase (relative to fiscal year 1992) the availability of treatment services designed for pregnant women and women with dependent children (either by establishing new programs or expanding the capacity of existing programs);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant for fiscal year 1994, the State will expend not less than 5 percent of the grant to so increase (relative to fiscal year 1993) the availability of such services for such women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant for any subsequent fiscal year, the State will expend for such services for such women not less than an amount equal to the amount expended by the State for fiscal year 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6695385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of a State, the Secretary may provide to the State a waiver of all or part of the requirement established in paragraph (1) if the Secretary determines that the State is providing an adequate level of treatments services for women described in such paragraph, as indicated by a comparison of the number of such women seeking the services with the availability in the State of the services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall approve or deny a request for a waiver under subparagraph (A) not later than 120 days after the date on which the request is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any waiver provided by the Secretary under subparagraph (A) shall be applicable only to the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Childcare and prenatal care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a State is that each entity providing treatment services with amounts reserved under paragraph (1) by the State will, directly or through arrangements with other public or nonprofit private entities, make available prenatal care to women receiving such services and, while the women are receiving the services, childcare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6695389-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1922, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/389"},"text":"106 Stat. 389","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/a"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(a)","children":[],"tail":", (f)(2)(A), "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1210"},"text":"114 Stat. 1210","children":[],"tail":", 1211; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/a/3"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5677"},"text":"136 Stat. 5677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb669538a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb669538b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (b)(2), (3)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/f/2"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1211"},"text":"114 Stat. 1211","children":[],"tail":", provided that, effective upon publication of regulations developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/e/1"},"text":"section 300x–32(e)(1) of this title","children":[],"tail":", subsection (c) of this section [now subsection (b)] is amended by striking out paragraph (2) and redesignating paragraph (3) as paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb669538c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb669538d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1922 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–9a"},"text":"section 300x–9a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1922 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–1"},"text":"section 300y–1 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb669538e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1241/a/3/B"},"text":"Pub. L. 117–328, § 1241(a)(3)(B)","children":[],"tail":", substituted “such disorders” for “such abuse” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1241/a/3/A"},"text":"Pub. L. 117–328, § 1241(a)(3)(A)","children":[],"tail":", substituted “substance use disorders” for “substance abuse” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/a"},"text":"Pub. L. 106–310, § 3303(a)","children":[],"tail":", redesignated subsec. (b) as (a) and struck out heading and text of former subsec. (a). Text read as follows: “A funding agreement for a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that, in expending the grant, the State involved will expend—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) not less than 35 percent for prevention and treatment activities regarding alcohol; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) not less than 35 percent for prevention and treatment activities regarding other drugs.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/a/2"},"text":"Pub. L. 106–310, § 3303(a)(2)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3303/a/2"},"text":"Pub. L. 106–310, § 3303(a)(2)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb669538f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6695390-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/f/2"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1211"},"text":"114 Stat. 1211","children":[],"tail":", provided that the amendment made by section 3303(f)(2) is effective upon the publication of the regulations developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/e/1"},"text":"section 300x–32(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
