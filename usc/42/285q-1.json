{"tag":"section","attrib":{"id":"idb57d1f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"285q–1"},"text":"§ 285q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285q"},"text":"section 285q of this title","children":[],"tail":", the Director of the Institute may provide research training and instruction and establish, in the Institute and other nonprofit institutions, research traineeships and fellowships in the study and investigation of the prevention of disease, health promotion, and the nursing care of individuals with and the families of individuals with acute and chronic illnesses. The Director of the Institute may provide individuals receiving such training and instruction or such traineeships or fellowships with such stipends and allowances (including amounts for travel and subsistence and dependency allowances) as the Director determines necessary. The Director may make grants to nonprofit institutions to provide such training and instruction and traineeships and fellowships."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb57d1f5a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464W, formerly § 484, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/867"},"text":"99 Stat. 867","children":[],"tail":"; renumbered § 464W and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXV/s1511/a/2"},"text":"Pub. L. 103–43, title XV, § 1511(a)(2)","children":[],"tail":", (b)(2), (4)(A), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/178"},"text":"107 Stat. 178","children":[],"tail":", 179.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57d1f5b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57d1f5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57d1f5d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s287c–1"},"text":"section 287c–1 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57d1f5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1511/a/2"},"text":"Pub. L. 103–43, § 1511(a)(2)","children":[],"tail":", (b)(4)(A), substituted “section 285q” for “section 287c” and “Institute” for “Center” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
