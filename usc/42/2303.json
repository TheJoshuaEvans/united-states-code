{"tag":"section","attrib":{"id":"idbc1ed03d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to effectuate the policies set forth above by providing for—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1ed03e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of conditions which will not impede the recruitment and retention of personnel essential to the atomic energy program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed03f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the obligation of the United States to contribute to the support of municipal functions in a manner commensurate with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc1ed040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fiscal problems peculiar to the communities by reason of their construction as national defense installations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc1ed041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the municipal and other burdens imposed on the governmental or other entities at the communities by the United States in its operations at or near the communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity for the residents of the communities to assume the obligations and privileges of local self-government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the encouragement of the construction of new homes at the communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1ed044-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 1, § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/69/472"},"text":"69 Stat. 472","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
