{"tag":"section","attrib":{"id":"idc011dd24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393"},"text":null,"children":[{"tag":"num","attrib":{"value":"16393"},"text":"§ 16393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business advocacy and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc011dd25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business advocate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require the Director of each National Laboratory (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":") and the Director of each single-purpose research facility to designate a small business advocate to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the participation of small business concerns, including socially and economically disadvantaged small business concerns (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a/4"},"text":"section 637(a)(4) of title 15","children":[],"tail":"), in procurement, research, development, demonstration, and commercial application activities, including product development, technology licensing, and technology transfer activities conducted by the National Laboratory or single-purpose research facility;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director of the National Laboratory or single-purpose research facility on the actual participation of small business concerns in the activities described in paragraph (1) along with recommendations, if appropriate, on how to improve participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to small business concerns facilities, training, mentoring, and information on how to participate in the activities described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the awareness inside the National Laboratory or single-purpose research facility of the capabilities and opportunities presented by small business concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidelines and metrics for the programs under subsections (b) and (c) and report on the effectiveness of the program to the Director of the National Laboratory or single-purpose research facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of small business assistance program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require the Director of each National Laboratory, and may require the Director of a single-purpose research facility, to establish a program to provide small business concerns with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance directed at making the small business concerns more effective and efficient subcontractors or suppliers to the National Laboratory or single-purpose research facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general technical assistance, the cost of which shall not exceed $10,000 per instance of assistance, to improve the products or services of the small business concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business voucher program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Director” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc011dd31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of each National Laboratory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc011dd32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of each single-purpose research facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business concern” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Chief Commercialization Officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391/a"},"text":"section 16391(a) of this title","children":[],"tail":", and in consultation with the Directors, shall establish a program to provide small business concerns with vouchers under paragraph (3)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve the goal described in subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the products, services, and capabilities of small business concerns in the mission space of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vouchers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Directors are authorized to provide to small business concerns vouchers to be used at National Laboratories and single-purpose research facilities for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, development, demonstration, technology transfer, skills training and workforce development, or commercial application activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities that the applicable Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, working with the Directors, shall establish a stream-lined approval process for financial assistance agreements signed between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns selected to receive a voucher under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories and single-purpose research facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall require cost-sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall report annually on the progress and implementation of the small business voucher program established under this section, including the number and locations of small businesses that received grants under this program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds expended under subsection (b) may be used for direct grants to small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16393/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary for activities under subsection (b) $5,000,000 for each of fiscal years 2006 through 2008 and for activities under subsection (c) $25,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc011dd43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1003"},"text":"Pub. L. 109–58, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/929"},"text":"119 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10718"},"text":"Pub. L. 117–167, div. B, title VI, § 10718","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1705"},"text":"136 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc011dd44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc011dd45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc011dd46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/1/A"},"text":"Pub. L. 117–167, § 10718(1)(A)","children":[],"tail":", substituted “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":") and the Director of each single-purpose research facility” for “, and may require the Director of a single-purpose research facility,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/1/B"},"text":"Pub. L. 117–167, § 10718(1)(B)","children":[],"tail":", substituted “encourage” for “increase” and “research, development, demonstration, and commercial application activities, including product development,” for “collaborative research,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/1/C"},"text":"Pub. L. 117–167, § 10718(1)(C)","children":[],"tail":", substituted “the activities described in paragraph (1)” for “procurement and collaborative research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/1/D"},"text":"Pub. L. 117–167, § 10718(1)(D)","children":[],"tail":", inserted “facilities,” before “training” and substituted “the activities described in paragraph (1)” for “procurement and collaborative research activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/1/E"},"text":"Pub. L. 117–167, § 10718(1)(E)","children":[],"tail":", substituted “and metrics for the programs under subsections (b) and (c)” for “for the program under subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/2"},"text":"Pub. L. 117–167, § 10718(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10718/2"},"text":"Pub. L. 117–167, § 10718(2)","children":[],"tail":", (4), redesignated subsec. (d) as (e), substituted “for activities under subsection (b)” for “for activities under this section”, and inserted before period at end “and for activities under subsection (c) $25,000,000 for each of fiscal years 2023 through 2027”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
