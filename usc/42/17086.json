{"tag":"section","attrib":{"id":"idc024ef2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086"},"text":null,"children":[{"tag":"num","attrib":{"value":"17086"},"text":"§ 17086.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced integration of buildings onto the electric grid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc024ef30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program of research, development, and demonstration to enable components of commercial and residential buildings to serve as dynamic energy loads on and resources for the electric grid. The program shall focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing low-cost, low power, wireless sensors to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor building energy load;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecast building energy need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable building-level energy control;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing data management capabilities and standard communication protocols to further interoperability at the building and grid-level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing advanced building-level energy management of components through integration of smart technologies, control systems, and data processing, to enable energy efficiency and savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimizing energy consumption at the building level to enable grid stability and resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving visualization of behind the meter equipment and technologies to provide better insight into the energy needs and energy forecasts of individual buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the cost of key components to accelerate the adoption of smart building technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting against cybersecurity threats and addressing security vulnerabilities of building systems or equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with utility partners, building owners, technology vendors, and building developers to test and validate technologies and encourage the commercial application of these technologies by building owners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider the specific challenges of enabling greater interaction between components of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small- and medium-sized buildings and the electric grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential and commercial buildings and the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings-to-grid integration report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology and the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report on the results of a study that examines the research, development, and demonstration opportunities, challenges, and standards needed to enable components of commercial and residential buildings to serve as dynamic energy loads on and resources for the electric grid."}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the technologies needed to enable building components as dynamic loads on and resources for the electric grid, including how such technologies can be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc024ef44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporated into new commercial and residential buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retrofitted in older buildings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines for the design of new buildings and building components to enable modern grid interactivity and improve energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of barriers to the adoption by building owners of advanced technologies enabling greater integration of building components onto the electric grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the feasibility of adopting technologies developed under subsection (a) at Department facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the report, the Secretary shall develop a 10-year roadmap to guide the research, development, and demonstration program to enable components of commercial and residential buildings to serve as dynamic energy loads on and resources for the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall update the report required under this section every 3 years for the duration of the program under subsection (a) and shall submit the updated report to the Committee on Science, Space, and Technology and the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the recommendations from the report in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17086/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate across all relevant program offices at the Department to achieve the goals established in this section, including the Office of Electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc024ef4e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s426"},"text":"Pub. L. 110–140, title IV, § 426","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1007/e/1"},"text":"Pub. L. 116–260, div. Z, title I, § 1007(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2435"},"text":"134 Stat. 2435","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
