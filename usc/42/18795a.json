{"tag":"section","attrib":{"id":"idc06a1003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a"},"text":null,"children":[{"tag":"num","attrib":{"value":"18795a"},"text":"§ 18795a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-efficiency electric home rebate program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a1004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a1005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds to State energy offices and Indian Tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, to carry out a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a1006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants to State energy offices to develop and implement a high-efficiency electric home rebate program in accordance with subsection (c), $4,275,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a1007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants to Indian Tribes to develop and implement a high-efficiency electric home rebate program in accordance with subsection (c), $225,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a1009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State energy offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reserve funds made available under paragraph (1)(A) for each State energy office—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a100a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the allocation formula for the State Energy Program in effect on ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a100b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be distributed to a State energy office if the application of the State energy office under subsection (b) is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a100c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reserve funds made available under paragraph (1)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a100d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a100e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be distributed to an Indian Tribe if the application of the Indian Tribe under subsection (b) is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a100f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":", any money reserved under—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc06a1010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A) but not distributed under clause (ii) of that subparagraph shall be redistributed to the State energy offices operating a high-efficiency electric home rebate program in proportion to the amount distributed to those State energy offices under that clause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a1011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (B) but not distributed under clause (ii) of that subparagraph shall be redistributed to the Indian Tribes operating a high-efficiency electric home rebate program in proportion to the amount distributed to those Indian Tribes under that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available under paragraph (1), the Secretary shall use not more than 3 percent for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a1013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a1014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance relating to activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a1015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State energy office or Indian Tribe seeking a grant under the program shall submit to the Secretary an application that includes a plan to implement a high-efficiency electric home rebate program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a1016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to verify the income eligibility of eligible entities seeking a rebate for a qualified electrification project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to allow rebates for qualified electrification projects at the point of sale in a manner that ensures that the income eligibility of an eligible entity seeking a rebate may be verified at the point of sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to ensure that an eligible entity does not receive a rebate for the same qualified electrification project through both a high-efficiency electric home rebate program and any other Federal grant or rebate program, pursuant to subsection (c)(8); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information that the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a101a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-efficiency electric home rebate program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a101b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the program, the Secretary shall award grants to State energy offices and Indian Tribes to establish a high-efficiency electric home rebate program under which rebates shall be provided to eligible entities for qualified electrification projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a101c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe guidelines for high-efficiency electric home rebate programs, including guidelines for providing point of sale rebates in a manner consistent with the income eligibility requirements under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a101d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of rebate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a101e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appliance upgrades","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a rebate provided under a high-efficiency electric home rebate program for the purchase of an appliance under a qualified electrification project shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a101f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $1,750 for a heat pump water heater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a1020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $8,000 for a heat pump for space heating or cooling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a1021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not more than $840 for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a1022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric stove, cooktop, range, or oven; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a1023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric heat pump clothes dryer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a1024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonappliance upgrades","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a rebate provided under a high-efficiency electric home rebate program for the purchase of a nonappliance upgrade under a qualified electrification project shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a1025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $4,000 for an electric load service center upgrade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a1026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $1,600 for insulation, air sealing, and ventilation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a1027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $2,500 for electric wiring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a1028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rebate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving multiple rebates under this section may receive not more than a total of $14,000 in rebates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a1029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rebate provided using funding under this section shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a102a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an eligible entity described in subsection (d)(1)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a102b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the cost of the qualified electrification project for a household the annual income of which is not less than 80 percent and not greater than 150 percent of the area median income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a102c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the cost of the qualified electrification project for a household the annual income of which is less than 80 percent of the area median income;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a102d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an eligible entity described in subsection (d)(1)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a102e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the cost of the qualified electrification project for a multifamily building not less than 50 percent of the residents of which are households the annual income of which is not less than 80 percent and not greater than 150 percent of the area median income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06a102f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the cost of the qualified electrification project for a multifamily building not less than 50 percent of the residents of which are households the annual income of which is less than 80 percent of the area median income; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a1030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an eligible entity described in subsection (d)(1)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06a1031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of the cost of the qualified electrification project for a household—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06a1032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of which the eligible entity is working; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06a1033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual income of which is not less than 80 percent and not greater than 150 percent of the area median income; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 100 percent of the cost of the qualified electrification project for a household—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c7f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of which the eligible entity is working; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual income of which is less than 80 percent of the area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount for installation of upgrades","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an eligible entity described in subsection (d)(1)(C) that receives a rebate under the program and performs the installation of the applicable qualified electrification project, a State energy office or Indian Tribe shall provide to that eligible entity, in addition to the rebate, an amount that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c7f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exceed $500; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is commensurate with the scale of the upgrades installed as part of the qualified electrification project, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount received under subparagraph (A) by an eligible entity described in that subparagraph shall not be subject to the requirement under paragraph (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity described in subparagraph (C) of subsection (d)(1) shall discount the amount of a rebate received for a qualified electrification project from any amount charged by that eligible entity to the eligible entity described in subparagraph (A) or (B) of that subsection on behalf of which the qualified electrification project is carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities carried out by a State energy office using a grant provided under the program shall not be subject to the expenditure prohibitions and limitations described in section 420.18 of title 10, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on combining rebates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rebate provided by a State energy office or Indian Tribe under a high-efficiency electric home rebate program may not be combined with any other Federal grant or rebate, including a rebate provided under a HOMES rebate program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18795/d"},"text":"section 18795(d) of this title","children":[],"tail":"), for the same qualified electrification project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State energy office or Indian Tribe that receives a grant under the program shall use not more than 20 percent of the grant amount for planning, administration, or technical assistance relating to a high-efficiency electric home rebate program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a low- or moderate-income household;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual or entity that owns a multifamily building not less than 50 percent of the residents of which are low- or moderate-income households; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental, commercial, or nonprofit entity, as determined by the Secretary, carrying out a qualified electrification project on behalf of an entity described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-efficiency electric home rebate program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-efficiency electric home rebate program” means a rebate program carried out by a State energy office or Indian Tribe pursuant to subsection (c) using a grant received under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low- or moderate-income household","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low- or moderate-income household” means an individual or family the total annual income of which is less than 150 percent of the median income of the area in which the individual or family resides, as reported by the Department of Housing and Urban Development, including an individual or family that has demonstrated eligibility for another Federal program with income restrictions equal to or below 150 percent of area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program carried out by the Secretary under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified electrification project","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified electrification project” means a project that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c7f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes the purchase and installation of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c7f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric heat pump water heater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric heat pump for space heating and cooling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric stove, cooktop, range, or oven;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric heat pump clothes dryer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric load service center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air sealing and materials to improve ventilation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric wiring;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any appliance described in clause (i), the purchase of which is carried out—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06c7f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of new construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replace a nonelectric appliance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06c7f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a first-time purchase with respect to that appliance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out at, or relating to, a single-family home or multifamily building, as applicable and defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18795a/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified electrification project” does not include any project with respect to which the appliance, system, equipment, infrastructure, component, or other item described in subclauses (I) through (VIII) of subparagraph (A)(i) is not certified under the Energy Star program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":", if applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7f5a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50122"},"text":"Pub. L. 117–169, title V, § 50122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022",