{"tag":"section","attrib":{"id":"idbdbb4213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802"},"text":null,"children":[{"tag":"num","attrib":{"value":"6802"},"text":"§ 6802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbb4214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “electric utility” means any person, State agency, or Federal agency which sells electric energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal agency” means any agency or instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State agency” means a State, political subdivision thereof, or any agency or instrumentality of either.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State utility regulatory commission” means (A) any utility regulatory commission which is a State agency or (B) the Tennessee Valley Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb4219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State, the District of Columbia, Puerto Rico, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbb421a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6802/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “utility regulatory commission” means any State agency or Federal agency which has authority to fix, modify, approve, or disapprove rates for the sale of electric energy by any electric utility (other than by such agency).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbb421b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tII/s202"},"text":"Pub. L. 94–385, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1142"},"text":"90 Stat. 1142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/617/tI/s143"},"text":"Pub. L. 95–617, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3134"},"text":"92 Stat. 3134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s5/b/2"},"text":"Pub. L. 105–388, § 5(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3479"},"text":"112 Stat. 3479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbb421c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbb421d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdbb421e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" made technical amendment by striking heading and designation which had been inserted by "},{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617"},"text":"Pub. L. 95–617","children":[],"tail":" substituted “The term ‘Secretary’ means the Secretary of Energy” for “The term ‘Administrator’ means the Administrator of the Federal Energy Administration; except that after such Administration ceases to exist, such term means any officer of the United States designated by the President for purposes of this subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
