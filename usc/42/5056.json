{"tag":"section","attrib":{"id":"idbcf30ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056"},"text":null,"children":[{"tag":"num","attrib":{"value":"5056"},"text":"§ 5056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of programs and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf30ffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General objectives; persons conducting the evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall measure and evaluate the impact of all programs authorized by this chapter, their effectiveness in achieving stated goals, in general, and in relation to their cost, their impact on related programs, and their structure and mechanism for delivery of services. Each program shall be evaluated at least once every three years. Evaluations shall be conducted by persons not immediately involved in the administration of the program or project evaluated. Such evaluation shall also measure and evaluate compliance with the equitable distribution requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5054"},"text":"section 5054 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf30ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General standards; publication; reports of ensuing actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop and publish general standards for evaluation of program and project effectiveness in achieving the objectives of this chapter. Reports submitted pursuant to section 5047 ","children":[{"tag":"ref","attrib":{"idref":"fn003386"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003386"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall describe the actions taken as a result of evaluations carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf30fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opinions of participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out evaluations under this subchapter, the Director shall, whenever possible, arrange to obtain the opinions of program and project participants about the strengths and weaknesses of such programs and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf31000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summaries of results; publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall publish summaries of the results of evaluations of program and project impact and effectiveness no later than sixty days after the completion thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf31001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall take the necessary action to assure that all studies, evaluations, proposals, and data produced or developed with Federal funds shall become the property of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf31002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of programs that relate to services that assist families caring for frail and disabled adult family members; evaluation of impact by volunteers on such programs; report to committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":", the Director shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf31003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the impact of Corporation programs carried out under subchapter II that relate to services that assist families caring for frail and disabled adult family members and shall include in such evaluation information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf31004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the range and extent of service needs of, and the services provided to, family caregivers assisted by volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf31005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics of volunteers and the skills, training, and supervision necessary to provide various types of volunteer assistance to family caregivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf31006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative costs, including recruitment, training, and supervision costs, associated with volunteer assistance to family caregivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf31007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other issues as may be relevant to provide services to assist family caregivers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf31008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate the impact that volunteers who participate in programs under parts B and C of subchapter II without receiving a stipend have on such programs and shall include in such evaluation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf31009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on adminstrative ","children":[{"tag":"ref","attrib":{"idref":"fn003387"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003387"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “administrative”."}],"tail":" costs associated with such volunteers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf3100a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the quality of services provided by such volunteers and the quality of services provided by volunteers who receive a stipend under such parts, including the rate of absenteeism and turnover; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf3100b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the effect that participation by volunteers who do not receive such stipend have on the administration of such programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3100c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the authorizing committees a report summarizing in detail the results of the evaluations made under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf3100d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5056/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds limitation; reduction of allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to use such sums as are required, but not to exceed 1 per centum of the funds appropriated under this chapter, to conduct program and project evaluations (directly, or by grants or contracts) as required by this chapter. In the case of allotments from such an appropriation, the amount available for such allotments (and the amount deemed appropriate therefor) shall be reduced accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf3100e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tIV/s416"},"text":"Pub. L. 93–113, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/412"},"text":"87 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s23"},"text":"Pub. L. 98–288, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/195"},"text":"98 Stat. 195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/551/s8"},"text":"Pub. L. 99–551, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3075"},"text":"100 Stat. 3075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tIV/s402"},"text":"Pub. L. 101–204, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1815"},"text":"103 Stat. 1815","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIV/s405/a/9"},"text":"Pub. L. 103–82, title IV, § 405(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/920"},"text":"107 Stat. 920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2153"},"text":"Pub. L. 111–13, title II, § 2153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1591"},"text":"123 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf3100f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf31010-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf31011-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), and (g), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":", known as the Domestic Volunteer Service Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5047"},"text":"Section 5047 of this title","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s365"},"text":"Pub. L. 103–82, title III, § 365","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/908"},"text":"107 Stat. 908","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf31012-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s2153/1"},"text":"Pub. L. 111–13, § 2153(1)","children":[],"tail":", struck out “(including the VISTA Literacy Corps which shall be evaluated as a separate program at least once every 3 years)” after “authorized by this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s2153/2"},"text":"Pub. L. 111–13, § 2153(2)","children":[],"tail":", substituted “authorizing committees” for “Committee on Education and Labor of the House of Representatives and the Committee on Labor and Human Resources of the Senate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" substituted “Corporation” for “ACTION Agency” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" inserted “(including the VISTA Literacy Corps which shall be evaluated as a separate program at least once every 3 years)” after “this chapter” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/551/s8/a"},"text":"Pub. L. 99–551, § 8(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Director shall biennially measure and evaluate the impact of all programs authorized by this chapter, their effectiveness in achieving stated goals in general, and in relation to their cost, their impact on related programs, and their structure and mechanisms for delivery of services. Evaluations shall be conducted by persons not immediately involved in the administration of the program or any project of such program being evaluated. Such evaluation shall also measure and evaluate compliance with the equitable distribution requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5054"},"text":"section 5054 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/551/s8/b"},"text":"Pub. L. 99–551, § 8(b)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" substituted “biennially” for “periodically” in first sentence, and substituted “or any project of such program being evaluated. Such evaluation shall also measure and evaluate compliance with the equitable distribution requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5054"},"text":"section 5054 of this title","children":[],"tail":"” for “or project evaluated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf31013-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf31014-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf31015-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-04-04"},"text":"Apr. 4, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s406/b"},"text":"section 406(b) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8332"},"text":"section 8332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf31016-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/551"},"text":"Pub. L. 99–551","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/551/s11"},"text":"section 11 of Pub. L. 99–551","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
