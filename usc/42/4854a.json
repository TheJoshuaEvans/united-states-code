{"tag":"section","attrib":{"id":"idbce4b82b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4854a"},"text":"§ 4854a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing technologies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, in cooperation with other Federal agencies, shall conduct research to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce4b82c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop improved methods for evaluating lead-based paint hazards in housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b82d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop improved methods for reducing lead-based paint hazards in housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b82e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop improved methods for measuring lead in paint films, dust, and soil samples;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b82f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance standards for various detection methods, including spot test kits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance standards for lead-based paint hazard reduction methods, including the use of encapsulants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish appropriate cleanup standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the efficacy of interim controls in various hazard situations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the relative performance of various abatement techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the long-term cost-effectiveness of interim control and abatement strategies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce4b835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of hazard evaluation and reduction activities funded by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce4b836-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1052"},"text":"Pub. L. 102–550, title X, § 1052","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3925"},"text":"106 Stat. 3925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce4b837-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce4b838-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbce4b839-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (10), was in the original “this Act”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":", known as the Residential Lead-Based Paint Hazard Reduction Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4851"},"text":"section 4851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
