{"tag":"section","attrib":{"id":"idb69b6049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–30"},"text":"§ 300ff–30.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69b604a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award supplemental grants to States determined to be eligible under subsection (b) to enable such States to provide comprehensive services of the type described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a"},"text":"section 300ff–22(a) of this title","children":[],"tail":" to supplement the services otherwise provided by the State under a grant under this subpart in emerging communities within the State that are not eligible to receive grants under part A."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b604b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a supplemental grant under subsection (a), a State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b604c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be eligible to receive a grant under this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b604d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the existence in the State of an emerging community as defined in subsection (d)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b604e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree that the grant will be used to provide funds directly to emerging communities in the State, separately from other funds under this subchapter that are provided by the State to such communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b604f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the information described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that desires a grant under this section shall, as part of the State application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27"},"text":"section 300ff–27 of this title","children":[],"tail":", submit a detailed description of the manner in which the State will use amounts received under the grant and of the severity of need. Such description shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b6051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report concerning the dissemination of supplemental funds under this section and the plan for the utilization of such funds in the emerging community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of the existing commitment of local resources, both financial and in-kind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration that the State will maintain HIV-related activities at a level that is equal to not less than the level of such activities in the State for the 1-year period preceding the fiscal year for which the State is applying to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of the ability of the State to utilize such supplemental financial resources in a manner that is immediately responsive and cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration that the resources will be allocated in accordance with the local demographic incidence of AIDS including appropriate allocations for services for infants, children, women, and families with HIV/AIDS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of the inclusiveness of the planning process, with particular emphasis on affected communities and individuals with HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of the manner in which the proposed services are consistent with local needs assessments and the statewide coordinated statement of need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions of emerging community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “emerging community” means a metropolitan area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–17"},"text":"section 300ff–17 of this title","children":[],"tail":") for which there has been reported to and confirmed by the Director of the Centers for Disease Control and Prevention a cumulative total of at least 500, but fewer than 1,000, cases of AIDS during the most recent period of 5 calendar years for which such data are available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued status as emerging community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section, a metropolitan area that is an emerging community for a fiscal year continues to be an emerging community until the metropolitan area fails, for three consecutive fiscal years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b605a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the requirements of subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b605b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have a cumulative total of 750 or more living cases of AIDS (reported to and confirmed by the Director of the Centers for Disease Control and Prevention) as of December 31 of the most recent calendar year for which such data is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b605c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant under subsection (a) for a State for a fiscal year shall be an amount equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b605d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b/b/1"},"text":"section 300ff–31b(b)(1) of this title","children":[],"tail":" for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b605e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–30/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage equal to the ratio constituted by the number of living cases of HIV/AIDS in emerging communities in the State to the sum of the respective numbers of such cases in such communities for all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69b605f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2621, formerly § 2620, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tII/s207/2"},"text":"Pub. L. 106–345, title II, § 207(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1337"},"text":"114 Stat. 1337","children":[],"tail":"; renumbered § 2621 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII"},"text":"Pub. L. 109–415, title II","children":[],"tail":", §§ 204(a), 205(1), 206, title VII, §§ 702(3), 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2796"},"text":"120 Stat. 2796","children":[],"tail":", 2797, 2799, 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69b6060-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69b6061-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb69b6062-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300ff–30, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVI/s2620"},"text":"act July 1, 1944, ch. 373, title XXVI, § 2620","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tII/s201"},"text":"Pub. L. 101–381, title II, § 201","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/597"},"text":"104 Stat. 597","children":[],"tail":", authorized appropriations for fiscal years 1991 through 1995, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":", §§ 6(b), 13, "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1367"},"text":"110 Stat. 1367","children":[],"tail":", 1374, effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2621 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31"},"text":"section 300ff–31 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/345"},"text":"Pub. L. 106–345","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69b6063-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s206/1"},"text":"Pub. L. 109–415, § 206(1)","children":[],"tail":", substituted “Emerging communities” for “Supplemental grants” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s206/2"},"text":"Pub. L. 109–415, § 206(2)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s204/a"},"text":"Pub. L. 109–415, § 204(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–21"},"text":"section 300ff–21 of this title","children":[],"tail":"” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s702/3"},"text":"Pub. L. 109–415, § 702(3)","children":[],"tail":", substituted “HIV/AIDS” for “HIV disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s206/3"},"text":"Pub. L. 109–415, § 206(3)","children":[],"tail":", added subsecs. (d) to (f) and struck out former subsecs. (d) and (e) defining “emerging community” and relating to funding, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69b6064-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69b6065-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
