{"tag":"section","attrib":{"id":"idbf2113cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361"},"text":null,"children":[{"tag":"num","attrib":{"value":"10361"},"text":"§ 10361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2113cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate and safe supplies of water are fundamental to the health, economy, security, and ecology of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2113cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" systematic data-gathering with respect to, and research and development of, the water resources of the United States will help ensure the continued existence of sufficient quantities of water to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2113ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2113cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2113d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigated agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2113d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2113d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of aquatic ecosystems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2113d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global climate change poses a significant challenge to the protection and use of the water resources of the United States due to an increased uncertainty with respect to the timing, form, and geographical distribution of precipitation, which may have a substantial effect on the supplies of water for agricultural, hydroelectric power, industrial, domestic supply, and environmental needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235dc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" although States bear the primary responsibility and authority for managing the water resources of the United States, the Federal Government should support the States, as well as regional, local, and tribal governments, by carrying out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235dc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nationwide data collection and monitoring activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to increase the efficiency of the use of water in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235dc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Federal agencies that conduct water management and related activities have a responsibility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235dc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take a lead role in assessing risks to the water resources of the United States (including risks posed by global climate change); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop strategies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235dcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate the potential impacts of each risk described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help ensure that the long-term water resources management of the United States is sustainable and will ensure sustainable quantities of water;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235dcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is critical to continue and expand research and monitoring efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235dce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the understanding of the variability of the water cycle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide basic information necessary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf235dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manage and efficiently use the water resources of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf235dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify new supplies of water that are capable of being reclaimed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf235dd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the study of water use is vital—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf235dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the understanding of the impacts of human activity on water and ecological resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf235dd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10361/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the assessment of whether available surface and groundwater supplies will be available to meet the future needs of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf235dd5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9501"},"text":"Pub. L. 111–11, title IX, § 9501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1329"},"text":"123 Stat. 1329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf235dd6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf235dd7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf235dd8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/174/s1"},"text":"Pub. L. 118–174, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2602"},"text":"138 Stat. 2602","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/174/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10367"},"text":"section 10367 of this title","children":[],"tail":"] may be cited as the ‘Water Monitoring and Tracking Essential Resources (WATER) Data Improvement Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf235dd9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Water Data Sharing Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50213"},"text":"Pub. L. 117–58, div. E, title II, § 50213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1172"},"text":"135 Stat. 1172","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dE/tII/s50213"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Administrator [of the Environmental Protection Agency] shall establish a competitive grant pilot program (referred to in this section as the ‘pilot program’) under which the Administrator may award grants to eligible entities under subsection (b) to establish systems that improve the sharing of information concerning water quality, water infrastructure needs, and water technology, including cybersecurity technology, between States or among counties and other units of local government within a State, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a website or data hub to exchange water data, including data on water quality or water technology, including new and emerging, but proven, water technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intercounty communications initiatives related to water data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data sharing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Internet of Water principles developed by the Nicholas Institute for Environmental Policy Solutions shall, to the extent practicable, guide any water data sharing efforts under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of existing data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The recipient of a grant under the pilot program to establish a website or data hub described in paragraph (1)(A) shall, to the extent practicable, leverage existing data sharing infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible for a grant under the pilot program is—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State, county, or other unit of local government that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a coastal watershed with significant pollution levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a water system with significant pollution levels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has significant individual water infrastructure deficits; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional consortium established under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under the pilot program, an eligible entity under subsection (b) shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional Consortia.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"States may establish regional consortia in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regional consortium established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include not fewer than 2 States that have entered into a memorandum of understanding—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exchange water data, including data on water quality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share information, protocols, and procedures with respect to projects that evaluate, demonstrate, or install new and emerging, but proven, water technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out projects—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exchange water data, including data on water quality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that evaluate, demonstrate, or install new and emerging, but proven, water technology; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a regional intended use plan, in accordance with paragraph (3), to identify projects to carry out, including projects using grants received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional intended use plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regional intended use plan of a regional consortium established under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify projects that the regional consortium intends to carry out, including projects that meet the requirements of paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects included in an intended use plan of a State prepared under section 606(c) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1386/c"},"text":"33 U.S.C. 1386(c)","children":[],"tail":") within the regional consortium; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects not included in an intended use plan of a State prepared under section 606(c) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1386/c"},"text":"33 U.S.C. 1386(c)","children":[],"tail":") within the regional consortium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15