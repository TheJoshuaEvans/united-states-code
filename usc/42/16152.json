{"tag":"section","attrib":{"id":"idbff52c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152"},"text":null,"children":[{"tag":"num","attrib":{"value":"16152"},"text":"§ 16152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean hydrogen; hydrogen","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “clean hydrogen” and “hydrogen” mean hydrogen produced in compliance with the greenhouse gas emissions standard established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16166/a"},"text":"section 16166(a) of this title","children":[],"tail":", including production from any fuel source."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cell","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fuel cell” means a device that directly converts the chemical energy of a fuel, which is supplied from an external source, and an oxidant into electricity by electrochemical processes occurring at separate electrodes in the device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heavy-duty vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “heavy-duty vehicle” means a motor vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52c77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is rated at more than 8,500 pounds gross vehicle weight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a curb weight of more than 6,000 pounds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a basic vehicle frontal area in excess of 45 square feet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “infrastructure” means the equipment, systems, or facilities used to produce, distribute, deliver, or store hydrogen (except for onboard storage).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Light-duty vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “light-duty vehicle” means a motor vehicle that is rated at 8,500 or less pounds gross vehicle weight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portable; storage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “portable” and “storage”, when used in reference to a fuel cell, include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff52c7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuous electric power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff52c7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" backup electric power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Hydrogen and Fuel Cell Technical Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16155"},"text":"section 16155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52c80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16152/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Technical Advisory Committee” means the independent Technical Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16156"},"text":"section 16156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52c81-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s803"},"text":"Pub. L. 109–58, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/844"},"text":"119 Stat. 844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40312"},"text":"Pub. L. 117–58, div. D, title III, § 40312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1006"},"text":"135 Stat. 1006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff52c82-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff52c83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff52c84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40312/2"},"text":"Pub. L. 117–58, § 40312(2)","children":[],"tail":", (3), added par. (1) and redesignated former pars. (1) to (3) as (2) to (4), respectively. Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40312/2"},"text":"Pub. L. 117–58, § 40312(2)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40312/1"},"text":"Pub. L. 117–58, § 40312(1)","children":[],"tail":", substituted “Portable; storage” for “Stationary; portable” in heading and “The terms ‘portable’ and ‘storage’, when” for “The terms ‘stationary’ and ‘portable’, when” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40312/2"},"text":"Pub. L. 117–58, § 40312(2)","children":[],"tail":", redesignated pars. (5) to (7) as (6) to (8), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff52c85-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbff52c86-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
