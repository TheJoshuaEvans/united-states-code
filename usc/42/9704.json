{"tag":"section","attrib":{"id":"idbed98410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704"},"text":null,"children":[{"tag":"num","attrib":{"value":"9704"},"text":"§ 9704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National reactor engineering simulator feasibility study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed98411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultative requirements; purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Commission and the Advisory Committee, shall initiate a study of the need for and feasibility of establishing a reactor engineering simulator facility at a national laboratory, for the primary purpose of fostering research in generic design improvements and simplifications through the simulation of the performance of various types of light water reactors under a wide variety of abnormal conditions and postulated accident conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed98412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of relevant factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In performing the study, the Secretary shall consider relevant factors including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed98413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential advantages that would accrue from the establishment of such a facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such a facility would further the generic safety research and development program established by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such a facility can be established by nongovernmental entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunities for cost sharing by nongovernmental entities in the construction and operation of such a facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of such a facility in emergencies to limit the extent of any future nuclear powerplant excursions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for international cooperation in the establishment and operation of such a facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed98419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate national laboratory for siting such a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed9841a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by ","children":[{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":", submit to the Committee on Science and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report characterizing the study and the resulting conclusions and recommendations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed9841b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/567/s5"},"text":"Pub. L. 96–567, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3331"},"text":"94 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed9841c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbed9841d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbed9841e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbed9841f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbed98420-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain functions from Nuclear Regulatory Commission to Chairman thereof, see Reorg. Plan No. 1 of 1980, 45 F.R. 40561, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/94/3585"},"text":"94 Stat. 3585","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5841"},"text":"section 5841 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
