{"tag":"section","attrib":{"id":"idb65fb702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–13"},"text":"§ 300u–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community transformation grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65fb703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”), acting through the Director of the Centers for Disease Control and Prevention (referred to in this section as the “Director”), shall award competitive grants to State and local governmental agencies and community-based organizations for the implementation, evaluation, and dissemination of evidence-based community preventive health activities in order to reduce chronic disease rates, prevent the development of secondary conditions, address health disparities, and develop a stronger evidence-base of effective prevention programming, with not less than 20 percent of such grants being awarded to rural and frontier areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State governmental agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local governmental agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national network of community-based organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local non-profit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Director an application at such time, in such a manner, and containing such information as the Director may require, including a description of the program to be carried out under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a history or capacity, if funded, to develop relationships necessary to engage key stakeholders from multiple sectors within and beyond health care and across a community, such as healthy futures corps and health care providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb70d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use amounts received under a grant under this section to carry out programs described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb70f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community transformation plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section shall submit to the Director (for approval) a detailed plan that includes the policy, environmental, programmatic, and ","children":[{"tag":"ref","attrib":{"idref":"fn002376"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002376"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" as appropriate "},{"tag":"ref","attrib":{"idref":"fn002376"},"text":"1","children":[],"tail":" infrastructure changes needed to promote healthy living and reduce disparities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities within the plan may focus on (but not be limited to)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating healthier school environments, including increasing healthy food options, physical activity opportunities, promotion of healthy lifestyle, emotional wellness, and prevention curricula, and activities to prevent chronic diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating the infrastructure to support active living and access to nutritious foods in a safe environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and promoting programs targeting a variety of age levels to increase access to nutrition, physical activity and smoking cessation, improve social and emotional wellness, enhance safety in a community, or address any other chronic disease priority area identified by the grantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing and implementing worksite wellness programming and incentives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working to highlight healthy options at restaurants and other food venues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing strategies to reduce racial and ethnic disparities, including social, economic, and geographic determinants of health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing special populations needs, including all age groups and individuals with disabilities, and individuals in urban, rural, and frontier areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based prevention health activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use amounts received under a grant under this section to implement a variety of programs, policies, and infrastructure improvements to promote healthier lifestyles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall implement activities detailed in the community transformation plan under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb71c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity may provide in-kind resources such as staff, equipment, or office space in carrying out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb71d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb71e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall use amounts provided under a grant under this section to conduct activities to measure changes in the prevalence of chronic disease risk factors among community members participating in preventive health activities ","children":[{"tag":"ref","attrib":{"idref":"fn002377"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002377"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subparagraph (A), the eligible entity shall, with respect to residents in the community, measure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb65fb720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in weight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in proper nutrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in physical activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in tobacco use prevalence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in emotional well-being and overall mental health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors using community-specific data from the Behavioral Risk Factor Surveillance Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb65fb726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall annually submit to the Director a report containing an evaluation of activities carried out under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grantee under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb65fb729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet at least annually in regional or national meetings to discuss challenges, best practices, and lessons learned with respect to activities carried out under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb65fb72a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop models for the replication of successful programs and activities and the mentoring of other eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb72b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65fb72c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop a program to provide training for eligible entities on effective strategies for the prevention and control of chronic disease and the link between physical, emotional, and social well-being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb72d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community transformation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide appropriate feedback and technical assistance to grantees to establish community transformation plans ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65fb72e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide a literature review and framework for the evaluation of programs conducted as part of the grant program under this section, in addition to working with academic institutions or other entities with expertise in outcome evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb72f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee shall not use funds provided under a grant under this section to create video games or to carry out any other activities that may lead to higher rates of obesity or inactivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65fb730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–13/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, such sums as may be necessary for each of fiscal year ","children":[{"tag":"ref","attrib":{"idref":"fn002378"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002378"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “years”."}],"tail":" 2010 through 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65fb731-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4201"},"text":"Pub. L. 111–148, title IV, § 4201","children":[],"tail":", title X, § 10403, "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/564"},"text":"124 Stat. 564","children":[],"tail":", 975.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65fb732-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65fb733-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb65fb734-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb65fb735-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10403/1"},"text":"Pub. L. 111–148, § 10403(1)","children":[],"tail":", inserted “, with not less than 20 percent of such grants being awarded to rural and frontier areas” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10403/2"},"text":"Pub. L. 111–148, § 10403(2)","children":[],"tail":", substituted “urban, rural, and frontier areas” for “both urban and rural areas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10403/3"},"text":"Pub. L. 111–148, § 10403(3)","children":[],"tail":", substituted “each of fiscal year” for “each fiscal years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
