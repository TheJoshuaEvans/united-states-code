{"tag":"section","attrib":{"id":"idbdb1cc5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615"},"text":null,"children":[{"tag":"num","attrib":{"value":"6615"},"text":"§ 6615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National science and technology strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdb1cc5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 31 of the year immediately after the calendar year in which a review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6615b"},"text":"section 6615b of this title","children":[],"tail":" is completed, the Director of the Office of Science and Technology Policy shall, in coordination with the National Science and Technology Council, develop and submit to Congress a comprehensive national science and technology strategy of the United States to meet national research and development objectives for the following 4-year period (in this section referred to as “the national science and technology strategy”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb1cc5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing each national science and technology strategy described in subsection (a), the Director of the Office of Science and Technology Policy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb1cc5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdb1cc5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations and priorities developed by the review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6615b"},"text":"section 6615b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recently published interim or final national security strategy report submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3043"},"text":"section 3043 of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant national plans, reports, and strategies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic plans of relevant Federal departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb1cc63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdb1cc64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strategic objectives and research priorities necessary to maintain and advance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdb1cc65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leadership of the United States in science and technology, including in the key technology focus areas, including near-term, medium-term, and long-term economic competitiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdb1cc66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leadership of the United States in technologies required to address societal and national challenges, including a transition to a circular economy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs, policies, and activities that the President recommends across all Federal departments and agencies to achieve the strategic objectives and research priorities described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to promote sustainability practices and strategies for increasing jobs in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global trends in science and technology, including potential threats to the leadership of the United States in science and technology and opportunities for international collaboration in science and technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdb1cc6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to foster the development of international partnerships to reinforce domestic policy actions, build new markets, engage in collaborative research, and create an international environment that reflects United States values and protects United States interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb1cc6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall consult as necessary with the Office of Management and Budget and other appropriate elements of the Executive Office of the President to ensure that the recommendations and priorities delineated in the science and technology strategy are incorporated in the development of annual budget requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb1cc6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bi-annual briefing to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall provide on a bi-annual basis, after each release of the national science and technology strategy, a briefing to the relevant congressional committees, which may include updates on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb1cc6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The status and development of the national science and technology strategy, including any significant changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb1cc6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The implementation of the national science and technology strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb1cc6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information about the national science and technology strategy, as determined by the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb1cc70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall, consistent with the protection of national security and other sensitive matters to the maximum extent practicable, make each national science and technology strategy publicly available on an internet website of the Office. Each report may include a classified annex if the Director of the Office of Science and Technology Policy determines such is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb1cc71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6615/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section terminates on the date that is ten years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdb1cc72-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s206"},"text":"Pub. L. 94–282, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/466"},"text":"90 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s215/3"},"text":"Pub. L. 97–375, title II, § 215(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1826"},"text":"96 Stat. 1826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10611"},"text":"Pub. L. 117–167, div. B, title VI, § 10611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1634"},"text":"136 Stat. 1634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb1cc73-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb1cc74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdb1cc75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6618"},"text":"section 6618 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/282/tII/s209"},"text":"Pub. L. 94–282, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/468"},"text":"90 Stat. 468","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s215/1"},"text":"Pub. L. 97–375, title II, § 215(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1826"},"text":"96 Stat. 1826","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdb1cc76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" amended section generally. Prior to amendment, section related to biennial science and technology report and outlook."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" substituted provisions requiring the President to submit to Congress in odd numbered years a science and technology report and outlook for provisions which required the Office of Science and Technology Policy to create a five-year science and technology outlook, dealing with current and emerging problems and with opportunities for and constraints on new and existing capabilities, to be revised annually, composed with the consultation of officials of departments and agencies having related programs and responsibilities, and with officials of the Office of Management and Budget and other appropriate elements of the Executive Office of the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdb1cc77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdb1cc78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (a) of this section relating to submission of biennial report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and the 16th item on page 42 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
