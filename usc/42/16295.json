{"tag":"section","attrib":{"id":"idc0084036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295"},"text":null,"children":[{"tag":"num","attrib":{"value":"16295"},"text":"§ 16295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oil and gas research programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0084037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application of oil and gas, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0084038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploration and production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas hydrates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008403a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservoir life and extension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008403b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and distribution infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008403c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ultraclean fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008403d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heavy oil, oil shale, and tar sands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008403e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related environmental research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008403f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The objectives of this program shall include advancing the science and technology available to domestic petroleum producers, particularly independent operators, to minimize the economic dislocation caused by the decline of domestic supplies of oil and natural gas resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas and oil deposits report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and every 2 years thereafter, the Secretary of the Interior, in consultation with other appropriate Federal agencies, shall submit to Congress a report on the latest estimates of natural gas and oil reserves, reserves growth, and undiscovered resources in Federal and State waters off the coast of Louisiana, Texas, Alabama, and Mississippi."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated clean power and energy research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0084042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a national center or consortium of excellence in clean energy and power generation, using the resources of the Clean Power and Energy Research Consortium in existence on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", to address the critical dependence of the United States on energy and the need to reduce emissions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center or consortium shall conduct a program of research, development, demonstration, and commercial application on integrating the following 6 focus areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0084044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efficiency and reliability of gas turbines for power generation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduction in emissions from power generation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion of energy conservation issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effectively using alternative fuels and renewable energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of advanced materials technology for oil and gas exploration and use in harsh environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16295/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education on energy and power generation issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc008404a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s965"},"text":"Pub. L. 109–58, title IX, § 965","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/892"},"text":"119 Stat. 892","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
