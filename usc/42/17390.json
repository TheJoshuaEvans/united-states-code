{"tag":"section","attrib":{"id":"idc03a738e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390"},"text":null,"children":[{"tag":"num","attrib":{"value":"17390"},"text":"§ 17390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary model pathways","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03a738f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of voluntary model pathways","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a7390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary of Energy (in this section referred to as the “Secretary”), in consultation with the steering committee established under paragraph (3), shall initiate the development of voluntary model pathways for modernizing the electric grid through a collaborative, public-private effort that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03a7391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces illustrative policy pathways encompassing a diverse range of technologies that can be adapted for State and regional applications by regulators and policymakers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates the modernization of the electric grid and associated communications networks to achieve the objectives described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures a reliable, resilient, affordable, safe, and secure electric grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acknowledges and accounts for different priorities, electric systems, and rate structures across States and regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbc85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pathways established under paragraph (1) shall facilitate achievement of as many of the following objectives as practicable:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbc86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Near real-time situational awareness of the electric system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data visualization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced monitoring and control of the advanced electric grid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhanced certainty of policies for investment in the electric grid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased innovation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Greater consumer empowerment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhanced grid resilience, reliability, and robustness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbc8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of distributed energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbc8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperability of the electric system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbc90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictive modeling and capacity forecasting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduced cost of service for consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diversification of generation sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbc93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steering committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a steering committee to help develop the pathways under paragraph (1), to be composed of members appointed by the Secretary, consisting of persons with appropriate expertise representing a diverse range of interests in the public, private, and academic sectors, including representatives of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbc94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Energy Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State regulatory authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmission organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of all sectors of the electric power industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent research institutes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbc9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbc9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17390/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to States, Indian Tribes, or units of local government to adopt or implement one or more elements of the pathways developed under subsection (a)(1), including on a pilot basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbc9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8008"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2586"},"text":"134 Stat. 2586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbc9f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbca0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc03cbca1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
