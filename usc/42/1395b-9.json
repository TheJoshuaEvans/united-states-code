{"tag":"section","attrib":{"id":"idb8924de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395b–9"},"text":"§ 1395b–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8924de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated administration of medicare prescription drug and Medicare Advantage programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924de9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is within the Centers for Medicare & Medicaid Services a center to carry out the duties described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924dea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such center shall be headed by a director who shall report directly to the Administrator of the Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924deb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administration of parts C and D.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of notice and information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–2"},"text":"section 1395b–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other duties as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the center is carrying out the duties described in paragraph (3) by not later than ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924df0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of management staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924df1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may employ, within the Centers for Medicare & Medicaid Services, such individuals as management staff as the Secretary determines to be appropriate. With respect to the administration of parts C and D, such individuals shall include individuals with private sector expertise in negotiations with health benefits plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924df2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for employment under paragraph (1) an individual shall be required to have demonstrated, by their education and experience (either in the public or private sector), superior expertise in at least one of the following areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924df3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The review, negotiation, and administration of health care contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924df4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The design of health care benefit plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924df5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Actuarial sciences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924df6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance with health plan contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924df7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumer education and decision making.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924df8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other area specified by the Secretary that requires specialized management or other expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924df9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924dfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance-related pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Secretary shall establish the rate of pay for an individual employed under paragraph (1). Such rate shall take into account expertise, experience, and performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924dfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case may the rate of compensation determined under subparagraph (A) exceed the highest rate of basic pay for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382/b"},"text":"section 5382(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924dfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare Beneficiary Ombudsman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924dfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint within the Department of Health and Human Services a Medicare Beneficiary Ombudsman who shall have expertise and experience in the fields of health care and education of (and assistance to) individuals entitled to benefits under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924dfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Medicare Beneficiary Ombudsman shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924dff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive complaints, grievances, and requests for information submitted by individuals entitled to benefits under part A or enrolled under part B, or both, with respect to any aspect of the medicare program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924e00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide assistance with respect to complaints, grievances, and requests referred to in subparagraph (A), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8924e01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in collecting relevant information for such individuals, to seek an appeal of a decision or determination made by a fiscal intermediary, carrier, MA organization, or the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8924e02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to such individuals with any problems arising from disenrollment from an MA plan under part C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8924e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to such individuals in presenting information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i/4/C"},"text":"section 1395r(i)(4)(C) of this title","children":[],"tail":" (relating to income-related premium adjustment; "},{"tag":"ref","attrib":{"idref":"fn002764"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002764"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit annual reports to Congress and the Secretary that describe the activities of the Office and that include such recommendations for improvement in the administration of this subchapter as the Ombudsman determines appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Ombudsman shall not serve as an advocate for any increases in payments or new coverage of services, but may identify issues and problems in payment or coverage policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working with health insurance counseling programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent possible, the Ombudsman shall work with health insurance counseling programs (receiving funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–4"},"text":"section 1395b–4 of this title","children":[],"tail":") to facilitate the provision of information to individuals entitled to benefits under part A or enrolled under part B, or both regarding MA plans and changes to those plans. Nothing in this paragraph shall preclude further collaboration between the Ombudsman and such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pharmaceutical and technology ombudsman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8924e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Secretary shall provide for a pharmaceutical and technology ombudsman within the Centers for Medicare & Medicaid Services who shall receive and respond to complaints, grievances, and requests that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8924e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are from entities that manufacture pharmaceutical, biotechnology, medical device, or diagnostic products that are covered or for which coverage is being sought under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8924e09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are with respect to coverage, coding, or payment under this subchapter for such products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8924e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The second sentence of subsection (c)(2) shall apply to the ombudsman under subparagraph (A) in the same manner as such sentence applies to the Medicare Beneficiary Ombudsman under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8924e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395b–9/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for implementation of beneficiary enrollment simplification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out the provisions of and the amendments made by section 120 of division CC of the Consolidated Appropriations Act, 2021, the Secretary shall provide for the transfer, from the Federal Hospital Insurance Trust Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i"},"text":"section 1395i of this title","children":[],"tail":" and the Federal Supplementary Medical Insurance Trust Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":" (in such proportion as the Secretary determines appropriate), to the Centers for Medicare & Medicaid Services Program Management Account, of $2,000,000 for each of fiscal years 2021 through 2030, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8924e0c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1808, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX"},"text":"Pub. L. 108–173, title IX","children":[],"tail":", §§ 900(a), (b), 923(a), "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2369"},"text":"117 Stat. 2369","children":[],"tail":", 2393; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4010"},"text":"Pub. L. 114–255, div. A, title IV, § 4010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1185"},"text":"130 Stat. 1185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/tI/s120/b"},"text":"Pub. L. 116–260, div. CC, title I, § 120(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2955"},"text":"134 Stat. 2955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8924e0d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8924e0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8924e0f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 120 of division CC of the Consolidated Appropriations Act, 2021, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/s120"},"text":"section 120 of div. CC of Pub. L. 116–260","children":[],"tail":", which amended this section and sections 1395i–2a, 1395p, 1395q, and 1395r of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8924e10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (d). ","children":[{"tag"