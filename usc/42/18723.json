{"tag":"section","attrib":{"id":"idc062e37e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723"},"text":null,"children":[{"tag":"num","attrib":{"value":"18723"},"text":"§ 18723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural and municipal utility advanced cybersecurity grant and technical assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc062e37f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced cybersecurity technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced cybersecurity technology” means any technology, operational capability, or service, including computer hardware, software, or a related asset, that enhances the security posture of electric utilities through improvements in the ability to protect against, detect, respond to, or recover from a cybersecurity threat (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of title 6","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk-power system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bulk-power system” has the meaning given the term in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of title 16."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural electric cooperative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility owned by a political subdivision of a State, such as a municipally owned electric utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility owned by any agency, authority, corporation, or instrumentality of 1 or more political subdivisions of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a not-for-profit entity that is in a partnership with not fewer than 6 entities described in subparagraph (A), (B), or (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investor-owned electric utility that sells less than 4,000,000 megawatt hours of electricity per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Rural and Municipal Utility Advanced Cybersecurity Grant and Technical Assistance Program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary, in coordination with the Secretary of Homeland Security and in consultation with the Federal Energy Regulatory Commission, the North American Electric Reliability Corporation, and the Electricity Subsector Coordinating Council, shall establish a program, to be known as the “Rural and Municipal Utility Advanced Cybersecurity Grant and Technical Assistance Program”, to provide grants and technical assistance to, and enter into cooperative agreements with, eligible entities to protect against, detect, respond to, and recover from cybersecurity threats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e38a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the Program shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e38b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deploy advanced cybersecurity technologies for electric utility systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e38c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the participation of eligible entities in cybersecurity threat information sharing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e38d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e38e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e38f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall award grants and provide technical assistance under the Program to eligible entities on a competitive basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop criteria and a formula for awarding grants and providing technical assistance under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into cooperative agreements with eligible entities that can facilitate the objectives described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a process to ensure that all eligible entities are informed about and can become aware of opportunities to receive grants or technical assistance under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for grants and technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants and providing technical assistance under the Program, the Secretary shall give priority to an eligible entity that, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has limited cybersecurity resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns assets critical to the reliability of the bulk-power system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns defense critical electric infrastructure (as defined in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a) of title 16)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information provided to, or collected by, the Federal Government pursuant to this section the disclosure of which the Secretary reasonably foresees could be detrimental to the physical security or cybersecurity of any electric utility or the bulk-power system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made available by any Federal agency, State, political subdivision of a State, or Tribal authority pursuant to any Federal, State, political subdivision of a State, or Tribal law, respectively, requiring public disclosure of information or records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e39a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18723/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $250,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc062e39b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40124"},"text":"Pub. L. 117–58, div. D, title I, § 40124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/953"},"text":"135 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/d/3"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3663"},"text":"136 Stat. 3663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc062e39c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc062e39d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc062e39e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of title 6","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of title 6","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc062e39f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc062e3a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
