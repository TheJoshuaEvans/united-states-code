{"tag":"section","attrib":{"id":"idbb922177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–14"},"text":"§ 1862p–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broader Impacts Review Criterion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb922178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall apply a broader impacts review criterion to identify and demonstrate project support of the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the economic competitiveness of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advancing of the health and welfare of the American public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting the national defense of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing partnerships between academia and industry in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing an American STEM workforce that is globally competitive through improved pre-kindergarten through grade 12 STEM education and teacher development, and improved undergraduate STEM education and instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving public scientific literacy and engagement with science and technology in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92217f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expanding participation of women and individuals from underrepresented groups in STEM.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Director shall develop and implement a policy for the Broader Impacts Review Criterion that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for educating professional staff at the Foundation, merit review panels, and applicants for Foundation research grants on the policy developed under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" clarifies that the activities of grant recipients undertaken to satisfy the Broader Impacts Review Criterion shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb922183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable employ proven strategies and models and draw on existing programs and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when novel approaches are justified, build on the most current research results;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for some portion of funds allocated to broader impacts under a research grant to be used for assessment and evaluation of the broader impacts activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages institutions of higher education and other nonprofit education or research organizations to develop and provide, either as individual institutions or in partnerships thereof, appropriate training and programs to assist Foundation-funded principal investigators at their institutions in achieving the goals of the Broader Impacts Review Criterion as described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–14/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires principal investigators applying for Foundation research grants to provide evidence of institutional support for the portion of the investigator’s proposal designed to satisfy the Broader Impacts Review Criterion, including evidence of relevant training, programs, and other institutional resources available to the investigator from either their home institution or organization or another institution or organization with relevant expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb922188-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s526"},"text":"Pub. L. 111–358, title V, § 526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4019"},"text":"124 Stat. 4019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s102/c"},"text":"Pub. L. 114–329, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2972"},"text":"130 Stat. 2972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb922189-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb92218a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb92218b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb92218c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Foundation shall apply a Broader Impacts Review Criterion to achieve the following goals:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Increased economic competitiveness of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Development of a globally competitive STEM workforce.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Increased participation of women and underrepresented minorities in STEM.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Increased partnerships between academia and industry.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Improved pre-K–12 STEM education and teacher development.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) Improved undergraduate STEM education.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) Increased public scientific literacy.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) Increased national security.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb92218d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb92218e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s2"},"text":"section 2 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"section 6621 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
