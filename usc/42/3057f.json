{"tag":"section","attrib":{"id":"idbc68aa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057f"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057f"},"text":"§ 3057f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus educational facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68aa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multipurpose senior centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of the Interior through the Bureau of Indian Affairs shall make available surplus Indian educational facilities to tribal organizations, and nonprofit organizations with tribal approval, for use as multipurpose senior centers. Such centers may be altered so as to provide extended care facilities, community center facilities, nutrition services, child care services, and other supportive services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; submission; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible tribal organization desiring to take advantage of such surplus facilities shall submit an application to the Secretary of the Interior at such time and in such manner, and containing or accompanied by such information, as the Secretary of the Interior determines to be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aa57-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s615"},"text":"Pub. L. 89–73, title VI, § 615","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/961"},"text":"101 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aa58-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68aa59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc68aa5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3057f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s607"},"text":"Pub. L. 89–73, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s106"},"text":"Pub. L. 95–478, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1551"},"text":"92 Stat. 1551","children":[],"tail":", related to payments, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3057m"},"text":"section 3057m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc68aa5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc68aa5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
