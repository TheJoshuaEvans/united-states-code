{"tag":"section","attrib":{"id":"idbac29bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397mm"},"text":"§ 1397mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to improve outreach and enrollment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbac29bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and enrollment grants; national campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated under subsection (g), subject to paragraphs (2) and (3), the Secretary shall award grants to eligible entities during the period of fiscal years 2009 through 2029 to conduct outreach and enrollment efforts that are designed to increase the enrollment and participation of eligible children under this subchapter and subchapter XIX.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ten percent set aside for national enrollment campaign","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to 10 percent of such amounts shall be used by the Secretary for expenditures during such period to carry out a national enrollment campaign in accordance with subsection (h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ten percent set aside for evaluating and providing technical assistance to grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the period of fiscal years 2024 through 2029, an amount equal to 10 percent of such amounts shall be used by the Secretary for the purpose of evaluating and providing technical assistance to eligible entities awarded grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac29bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for award of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac29be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to target geographic areas with high rates of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbac29be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible but unenrolled children, including such children who reside in rural areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbac29be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" racial and ethnic minorities and health disparity populations, including those proposals that address cultural and linguistic barriers to enrollment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the most demonstrable evidence required under paragraphs (1) and (2) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ten percent set aside for outreach to Indian children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to 10 percent of the funds appropriated under subsection (g) shall be used by the Secretary to award grants to Indian Health Service providers and urban Indian organizations receiving funds under title V of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1651"},"text":"25 U.S.C. 1651","children":[],"tail":" et seq.) for outreach to, and enrollment of, children who are Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac29be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that desires to receive a grant under subsection (a) shall submit an application to the Secretary in such form and manner, and containing such information, as the Secretary may decide. Such application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence demonstrating that the entity includes members who have access to, and credibility with, ethnic or low-income populations in the communities in which activities funded under the grant are to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence demonstrating that the entity has the ability to address barriers to enrollment, such as lack of awareness of eligibility, stigma concerns and punitive fears associated with receipt of benefits, and other cultural barriers to applying for and receiving child health assistance or medical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific quality or outcomes performance measures to evaluate the effectiveness of activities funded by a grant awarded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the eligible entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac29beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment of the effectiveness of such activities against the performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the collection and reporting of enrollment data and other information in order for the Secretary to conduct such assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible entity that is not the State, provide the State with enrollment data and other information as necessary for the State to make necessary projections of eligible children and pregnant women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac29bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of enrollment data and information determined from effectiveness assessments; annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available the enrollment data and information collected and reported in accordance with subsection (c)(4)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an annual report to Congress on the outreach and enrollment activities conducted with funds appropriated under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac29bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort for States awarded grants; no match required for any eligible entity awarded a grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State that is awarded a grant under this section, the State share of funds expended for outreach and enrollment activities under the State child health plan shall not be less than the State share of such funds expended in the fiscal year preceding the first fiscal year for which the grant is awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac29bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No eligible entity awarded a grant under subsection (a) shall be required to provide any matching funds as a condition for receiving the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac29bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac29bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac29bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State with an approved child health plan under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe or tribal consortium, a tribal organization, an urban Indian organization receiving funds under title V of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1651"},"text":"25 U.S.C. 1651","children":[],"tail":" et seq.), or an Indian Health Service provider."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal health safety net organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national, State, local, or community-based public or nonprofit private organization, including organizations that use community health workers, community-based doula programs, or parent mentors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac29bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A faith-based organization or consortia, to the extent that a grant awarded to such an entity is consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–65"},"text":"section 300x–65 of this title","children":[],"tail":" relating to a grant award to nongovernmental entities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An elementary or secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal health safety net organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal health safety net organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac50bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federally-qualified health center (as defined in section 1396d(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of this title);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hospital defined as a disproportionate share hospital for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r–4"},"text":"section 1396r–4 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s256b/a/4"},"text":"section 256b(a)(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity or consortium that serves children under a federally funded program, including the special supplemental nutrition program for women, infants, and children (WIC) established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":", the Head Start and Early Head Start programs under the Head Start Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"42 U.S.C. 9801","children":[],"tail":" et seq.),"},{"tag":"ref","attrib":{"idref":"fn003103"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003103"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the school lunch program established under the Richard B. Russell National School Lunch Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.], and an elementary or secondary school."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indians; Indian tribe; tribal organization; urban Indian organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian”, “Indian tribe”, “tribal organization”, and “urban Indian organization” have the meanings given such terms in section 4 of the Indian Health Care Improvement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"25 U.S.C. 1603","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community health worker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community health worker” means an individual who promotes health or nutrition within the community in which the individual resides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac50c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by serving as a liaison between communities and health care agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing guidance and social assistance to community residents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by enhancing community residents’ ability to effectively communicate with health care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing culturally and linguistically appropriate health or nutrition education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by advocating for individual and community health or nutrition needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing referral and followup services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent mentor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “parent mentor” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbac50c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a parent or guardian of at least one child who is an eligible child under this subchapter or subchapter XIX; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbac50c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is trained to assist families with children who have no health insurance coverage with respect to improving the social determinants of the health of such children, including by providing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbac50c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education about health insurance coverage, including, with respect to obtaining such coverage, eligibility criteria and application and renewal processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbac50c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with completing and submitting applications for health insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbac50c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a liaison between families and representatives of State plans under subchapter XIX or State child health plans under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbac50c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on identifying medical and dental homes and community pharmacies for children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbac50c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/f/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance and referrals to successfully address social determinants of children’s health, including poverty, food insufficiency, and housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac50c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is appropriated, out of any money in the Treasury not otherwise appropriated, $140,000,000 for the period of fiscal years 2009 through 2015, $40,000,000 for the period of fiscal years 2016 and 2017, $120,000,000 for the period of fiscal years 2018 through 2023, $48,000,000 for the period of fiscal years 2024 through 2027, and $40,000,000 for the period of fiscal years 2028 and 2029, for the purpose of awarding grants under this section. Amounts appropriated and paid under the authority of this section shall be in addition to amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397dd"},"text":"section 1397dd of this title","children":[],"tail":" and paid to States in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of this title","children":[],"tail":", including with respect to expenditures for outreach activities in accordance with subsections (a)(1)(D)(iii) and (c)(2)(C) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbac50c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National enrollment campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts made available under subsection (a)(2), the Secretary shall develop and implement a national enrollment campaign to improve the enrollment of underserved child populations in the programs established under this subchapter and subchapter XIX. Such campaign may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbac50c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of partnerships with the Secretary of Education and the Secretary of Agriculture to develop national campaigns to link the eligibility and enrollment systems for the assistance programs each Secretary administers that often serve the same children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of information about the programs established under this subchapter and subchapter XIX in public health awareness campaigns administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased financial and technical support for enrollment hotlines maintained by the Secretary to ensure that all States participate in such hotlines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of joint public awareness outreach initiatives with the Secretary of Education and the Secretary of Labor regarding the importance of health insurance to building strong communities and the economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of special outreach materials for Native Americans or for individuals with limited English proficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of materials and toolkits and the provision of technical assistance to States regarding enrollment and retention strategies for eligible children under this subchapter and subchapter XIX; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbac50c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397mm/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other outreach initiatives as the Secretary determines would increase public awareness of the programs under this subchapter and subchapter XIX.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbac50c1b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XXI, § 2113, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tII/s201/a"},"text":"Pub. L. 111–3, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/35"},"text":"123 Stat. 35","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10203/d/2/E"},"text":"Pub. L. 111–148, title X, § 10203(d)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/931"},"text":"124 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/10/tIII/s303"},"text":"Pub. L. 114–10, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-16"},"text":"Apr. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/158"},"text":"129 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/120/dC/s3004/a"},"text":"Pub. L. 115–120, div. C, § 3004(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-01-22"},"text":"Jan. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/36"},"text":"132 Stat. 36","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tI/s50103"},"text":"Pub. L. 115–123, div. E, title I, § 50103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/176"},"text":"132 Stat. 176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tV/s5111/c/4"},"text":"Pub. L. 117–328, div. FF, title V, § 5111(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5939"},"text":"136 Stat. 5939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbac50c1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbac50c1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbac50c1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Indian Health Care Improvement Act, referred to in subsecs. (b)(2) and (f)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437"},"text":"Pub. L. 94–437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1400"},"text":"90 Stat. 1400","children":[],"tail":". Title V of the Act is classified generally to subchapter IV (§ 1651 et seq.) of chapter 18 of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1601"},"text":"section 1601 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Head Start Act, referred to in subsec. (f)(2)(D), is subchapter B (§ 635 et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/499"},"text":"95 Stat. 499","children":[],"tail":", which is classified generally to subchapter II (§ 9831 et seq.) of chapter 105 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (f)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbac50c1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5111/c/4/A/i"},"text":"Pub. L. 117–328, § 5111(c)(4)(A)(i)","children":[],"tail":", substituted “through 2029” for “through 2027”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5111/c/4/A/ii"},"text":"Pub. L. 117–328, § 5111(c)(4)(A)(ii)","children":[],"tail":", substituted “through 2029” for “through 2027”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s5111/c/4/B"},"text":"Pub. L. 117–328, § 5111(c)(4)(B)","children":[],"tail":", substituted “2017,” for “2017,,” and “$48,000,000” for “and $48,000,000” and inserted “, and $40,000,000 for the period of fiscal years 2028 and 2029” after “through 2027”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50103/a/1"},"text":"Pub. L. 115–123, § 50103(a)(1)","children":[],"tail":", (b)(1), substituted “paragraphs (2) and (3)” for “paragraph (2)” and “2027” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3004/a/1"},"text":"Pub. L. 115–120, § 3004(a)(1)","children":[],"tail":", substituted “2023” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50103/b/2"},"text":"Pub. L. 115–123, § 50103(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3004/b/1"},"text":"Pub. L. 115–120, § 3004(b)(1)","children":[],"tail":", substituted “, community-based doula programs, or parent mentors” for “or community-based doula programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3004/b/2"},"text":"Pub. L. 115–120, § 3004(b)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50103/a/2"},"text":"Pub. L. 115–123, § 50103(a)(2)","children":[],"tail":", substituted “, $120,000,000” for “and $120,000,000” and inserted “, and $48,000,000 for the period of fiscal years 2024 through 2027” after “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s3004/a/2"},"text":"Pub. L. 115–120, § 3004(a)(2)","children":[],"tail":", substituted “, $40,000,000” for “and $40,000,000” and inserted “, and $120,000,000 for the period of fiscal years 2018 through 2023” after “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s50103/c"},"text":"Pub. L. 115–123, § 50103(c)","children":[],"tail":", added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s303/1"},"text":"Pub. L. 114–10, § 303(1)","children":[],"tail":", substituted “2017” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/10/s303/2"},"text":"Pub. L. 114–10, § 303(2)","children":[],"tail":", inserted “and $40,000,000 for the period of fiscal years 2016 and 2017” after “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10203/d/2/E/i"},"text":"Pub. L. 111–148, § 10203(d)(2)(E)(i)","children":[],"tail":", substituted “2015” for “2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10203/d/2/E/ii"},"text":"Pub. L. 111–148, § 10203(d)(2)(E)(ii)","children":[],"tail":", substituted “$140,000,000 for the period of fiscal years 2009 through 2015” for “$100,000,000 for the period of fiscal years 2009 through 2013”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbac50c20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbac50c21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-04-01"},"text":"Apr. 1, 2009","children":[],"tail":", and applicable to child health assistance and medical assistance provided on or after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/s3"},"text":"section 3 of Pub. L. 111–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"section 1396 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
