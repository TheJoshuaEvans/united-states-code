{"tag":"section","attrib":{"id":"idc05240b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201"},"text":null,"children":[{"tag":"num","attrib":{"value":"18201"},"text":"§ 18201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05240b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accompaniment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “accompaniment” means assisting, representing, and accompanying a woman in seeking judicial relief for child support, child custody, restraining orders, and restitution for harm to persons and property, and in filing criminal charges, and may include the payment of court costs and reasonable attorney and witness fees associated therewith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible institution of higher education” means an institution of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") that has established and operates, or agrees to establish and operate upon the receipt of a grant under this chapter, a pregnant and parenting student services office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community service center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community service center” means a non-profit organization that provides social services to residents of a specific geographical area via direct service or by contract with a local governmental agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high school” means any public or private school that operates grades 10 through 12, inclusive, grades 9 through 12, inclusive or grades 7 through 12, inclusive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intervention services” means, with respect to domestic violence, sexual violence, sexual assault, or stalking, 24-hour telephone hotline services for police protection and referral to shelters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes the District of Columbia, any commonwealth, possession, or other territory of the United States, and any Indian tribe or reservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive social services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “supportive social services” means transitional and permanent housing, vocational counseling, and individual and group counseling aimed at preventing domestic violence, sexual violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05240be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18201/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “violence” means actual violence and the risk or threat of violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05240bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10211"},"text":"Pub. L. 111–148, title X, § 10211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/931"},"text":"124 Stat. 931","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
