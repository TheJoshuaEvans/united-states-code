{"tag":"section","attrib":{"id":"idbff79ec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192"},"text":null,"children":[{"tag":"num","attrib":{"value":"16192"},"text":"§ 16192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next Generation Lighting Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79ec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced solid-state lighting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced solid-state lighting” means a semiconducting device package and delivery system that produces white light using externally applied voltage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry Alliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Industry Alliance” means an entity selected by the Secretary under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Initiative” means the Next Generation Lighting Initiative carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” includes research on the technologies, materials, and manufacturing processes required for white light emitting diodes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" White light emitting diode","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “white light emitting diode” means a semiconducting package, using either organic or inorganic materials, that produces white light using externally applied voltage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a Next Generation Lighting Initiative in accordance with this section to support research, development, demonstration, and commercial application activities related to advanced solid-state lighting technologies based on white light emitting diodes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The objectives of the Initiative shall be to develop advanced solid-state organic and inorganic lighting technologies based on white light emitting diodes that, compared to incandescent and fluorescent lighting technologies, are longer lasting, are more energy-efficient and cost-competitive, and have less environmental impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry Alliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall competitively select an Industry Alliance to represent participants who are private, for-profit firms, open to large and small businesses, that, as a group, are broadly representative of United States solid-state lighting research, development, infrastructure, and manufacturing expertise as a whole."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the research activities of the Initiative through competitively awarded grants to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" researchers, including Industry Alliance participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry alliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually solicit from the Industry Alliance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79ed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comments to identify solid-state lighting technology needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the progress of the research activities of the Initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in annually updating solid-state lighting technology roadmaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information and roadmaps under paragraph (2) shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development, demonstration, and commercial application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a development, demonstration, and commercial application program for the Initiative through competitively selected awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making the awards, the Secretary may give preference to participants in the Industry Alliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intellectual property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require (in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s202/a/ii"},"text":"section 202(a)(ii) of title 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2182"},"text":"section 2182 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5908"},"text":"section 5908 of this title","children":[],"tail":") that for any new invention developed under subsection (e)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Industry Alliance participants who are active participants in research, development, and demonstration activities related to the advanced solid-state lighting technologies that are covered by this section shall be granted the first option to negotiate with the invention owner, at least in the field of solid-state lighting, nonexclusive licenses and royalties on terms that are reasonable under the circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff79ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, for 1 year after a United States patent is issued for the invention, the patent holder shall not negotiate any license or royalty with any entity that is not a participant in the Industry Alliance described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff79ee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, during the year described in subparagraph (A), the patent holder shall negotiate nonexclusive licenses and royalties in good faith with any interested participant in the Industry Alliance described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79ee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other terms as the Secretary determines are required to promote accelerated commercialization of inventions made under the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79ee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16192/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academy review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into an arrangement with the National Academy of Sciences to conduct periodic reviews of the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79ee6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s912"},"text":"Pub. L. 109–58, title IX, § 912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/858"},"text":"119 Stat. 858","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
