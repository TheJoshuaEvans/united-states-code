{"tag":"section","attrib":{"id":"idbbd284b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000gg–5"},"text":"§ 2000gg–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbd284b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd284b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invalidate or limit the powers, remedies, and procedures under any Federal law or law of any State or political subdivision of any State or jurisdiction that provides greater or equal protection for individuals affected by pregnancy, childbirth, or related medical conditions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd284b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by regulation or otherwise, to require an employer-sponsored health plan to pay for or cover any particular item, procedure, or treatment or to affect any right or remedy available under any other Federal, State, or local law with respect to any such payment or coverage requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd284b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter is subject to the applicability to religious employment set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–1/a"},"text":"section 2000e–1(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd284ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s107"},"text":"Pub. L. 117–328, div. II, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6089"},"text":"136 Stat. 6089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd284bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbd284bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbd284bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s109"},"text":"section 109 of div. II of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s20