{"tag":"section","attrib":{"id":"idbea04ab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627"},"text":null,"children":[{"tag":"num","attrib":{"value":"8627"},"text":"§ 8627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea04ab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper utilization of funds; response to complaints respecting improprieties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04ab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, after adequate notice and an opportunity for a hearing conducted within the affected State, withhold funds from any State which does not utilize its allotment substantially in accordance with the provisions of this subchapter and the assurances such State provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624"},"text":"section 8624 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04ab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall respond in writing in no more than 60 days to matters raised in complaints of a substantial or serious nature that a State has failed to use funds in accordance with the provisions of this subchapter or the assurances provided by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624"},"text":"section 8624 of this title","children":[],"tail":". For purposes of this paragraph, a violation of any one of the assurances contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624/b"},"text":"section 8624(b) of this title","children":[],"tail":" that constitutes a disregard of such assurance shall be considered a serious complaint."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04ab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations; conduct, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04ab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct in several States in each fiscal year investigations of the use of funds received by the States under this subchapter in order to evaluate compliance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04ab9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretary determines that there is a pattern of complaints from any State in any fiscal year, the Secretary shall conduct an investigation of the use of funds received under this subchapter by such State in order to ensure compliance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04aba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General of the United States may conduct an investigation of the use of funds received under this subchapter by a State in order to ensure compliance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04abb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of books, documents, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to an investigation conducted under subsection (b) of this section, a State shall make appropriate books, documents, papers, and records available to the Secretary or the Comptroller General of the United States, or any of their duly authorized representatives, for examination, copying, or mechanical reproduction on or off the premises of the appropriate entity upon a reasonable request therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04abc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8627/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for information not readily available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting any investigation under subsection (b), the Secretary may not request any information not readily available to such State or require that any information be compiled, collected, or transmitted in any new form not already available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea04abd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2608"},"text":"Pub. L. 97–35, title XXVI, § 2608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/901"},"text":"95 Stat. 901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVI/s608"},"text":"Pub. L. 98–558, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2893"},"text":"98 Stat. 2893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tVII/s708"},"text":"Pub. L. 101–501, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1261"},"text":"104 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea04abe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea04abf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea04ac0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" substituted “in writing in no more than 60 days to matters raised in” for “in an expeditious and speedy manner to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558"},"text":"Pub. L. 98–558","children":[],"tail":" substituted “the Secretary” for “he” before “shall conduct”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea04ac1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea04ac2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea04ac3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558"},"text":"Pub. L. 98–558","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/s609/a"},"text":"section 609(a) of Pub. L. 98–558","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
