{"tag":"section","attrib":{"id":"idbdfe17a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7269b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7269b"},"text":"§ 7269b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of unexpended appropriation balances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The unexpended balances of prior appropriations provided for activities in this Act or subsequent Energy and Water Development Appropriations Acts may on and after ","children":[{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", be transferred to appropriation accounts for such activities established pursuant to this title."},{"tag":"ref","attrib":{"idref":"fn003572"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003572"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" Balances so transferred may be merged with funds in the applicable established accounts and thereafter may be accounted for as one fund for the same time period as originally enacted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdfe17a3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tIII/s303"},"text":"Pub. L. 102–377, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1339"},"text":"106 Stat. 1339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfe17a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfe17a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdfe17a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377"},"text":"Pub. L. 102–377","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1332"},"text":"106 Stat. 1332","children":[],"tail":". For complete classification of title III to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfe17a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development Appropriations Act, 1993, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
