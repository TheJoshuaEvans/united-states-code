{"tag":"section","attrib":{"id":"idbfcf06a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304"},"text":null,"children":[{"tag":"num","attrib":{"value":"14304"},"text":"§ 14304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf06a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When on the basis of any information the Administrator determines that a person has violated, or is in violation of, any requirement of this chapter (except a requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14323"},"text":"section 14323 of this title","children":[],"tail":") the Administrator—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf06a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any violation, may issue an order assessing a civil penalty of not more than $10,000 for each violation, or requiring compliance immediately or within a reasonable specified time period, or both; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any violation or failure to comply with an order issued under this section, may commence a civil action in the United States district court in the district in which the violation occurred or in the district in which the violator resides for appropriate relief, including a temporary or permanent injunction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order under subsection (a)(1) shall state with reasonable specificity the nature of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In assessing a civil penalty under subsection (a)(1), the Administrator shall take into account the seriousness of the violation and any good faith efforts to comply with applicable requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of order; request for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order under subsection (a)(1) shall become final unless, not later than 30 days after the order is served, a person named in the order requests a hearing on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receiving a request under subsection (d), the Administrator shall promptly conduct a hearing on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena power","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with any hearing on the record under this section, the Administrator may issue subpoenas for the attendance and testimony of witnesses and for the production of relevant papers, books, and documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued violation after expiration of period for compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a violator fails to take corrective action within the time specified in an order under subsection (a)(1), the Administrator may assess a civil penalty of not more than $10,000 for the continued noncompliance with the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf06ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not take any enforcement action against a person for selling, offering for sale, or offering for promotional purposes to the ultimate consumer a battery or product covered by this chapter that was—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf06ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased ready for sale to the ultimate consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf06ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold, offered for sale, or offered for promotional purposes without modification.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply to a person—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf06af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/h/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is the importer of a battery covered by this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf06b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14304/h/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has knowledge of the chemical contents of the battery","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"when such chemical contents make the sale, offering for sale, or offering for promotional purposes of such battery unlawful under subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf06b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/s5"},"text":"Pub. L. 104–142, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1331"},"text":"110 Stat. 1331","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
