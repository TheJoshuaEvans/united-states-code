{"tag":"section","attrib":{"id":"idc02e6530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214"},"text":null,"children":[{"tag":"num","attrib":{"value":"17214"},"text":"§ 17214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine energy research, development, and demonstration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02e6531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Defense, Secretary of Commerce (acting through the Under Secretary of Commerce for Oceans and Atmosphere) and other relevant Federal agencies, shall conduct a program of research, development, demonstration, and commercial application of marine energy technology, including activities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e6532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist technology development to improve the components, processes, and systems used for power generation from marine energy resources at a variety of scales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and expand critical testing infrastructure and facilities necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6534-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate and prove marine energy devices at a range of scales in a manner that is cost-effective and efficient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate the technological readiness and commercial application of such devices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address marine energy resource variability issues, including through the application of energy storage technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance efficient and reliable integration of marine energy with the electric grid, which may include smart building systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and study critical short-term and long-term needs to maintaining a sustainable marine energy supply chain based in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the reliability, security, and resilience of marine energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e653a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validate the performance, reliability, maintainability, and cost of marine energy device designs and system components in an operating environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e653b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the protection of critical infrastructure, such as adequate separation between marine energy devices and submarine telecommunications cables, including through the development of voluntary, consensus-based standards for such purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e653c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for crosscutting research, development, and demonstration programs between existing energy research programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e653d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and improve, in conjunction with the Secretary of Commerce, acting through the Under Secretary of Commerce for Oceans and Atmosphere, and other relevant Federal agencies as appropriate, the environmental impact, including potential cumulative environmental impacts, of marine energy technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e653e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential impacts on fisheries and other marine resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e653f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing technologies, including mechanisms for self-evaluation, and other means available for improving environmental impact, including potential cumulative environmental impacts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, in consultation with relevant Federal agencies, potential navigational impacts of marine energy technologies and strategies to prevent possible adverse impacts, in addition to opportunities for marine energy systems to aid the United States Coast Guard, such as remote sensing for coastal border security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop numerical and physical tools, including models and monitoring technologies, to assist industry in device and system design, installation, operation, and maintenance, including methods to validate such tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support materials science as it relates to marine energy technology, such as the development of corrosive-resistant materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve marine energy resource forecasting and general understanding of aquatic system behavior, including turbulence and extreme conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop metrics and voluntary, consensus-based standards, in coordination with the National Institute of Standards and Technology and appropriate standard development organizations, for marine energy components, systems, and projects, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring performance of marine energy technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characterizing environmental conditions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance integration with hybrid energy systems, including desalination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities to integrate marine energy technologies into new and existing infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn004264"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004264"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" develop technology necessary to support the use of marine energy—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e654a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the generation and storage of power at sea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e654b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the generation and storage of power to promote the resilience of coastal communities, including in applications relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02e654c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desalination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02e654d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disaster recovery and resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02e654e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/a/18/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community microgrids in isolated power systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e654f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of non-power sector applications for advanced marine energy technologies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e6550-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation and the Secretary of Commerce, shall conduct a study to examine opportunities for research and development in advanced marine energy technologies for non-power sector applications, including applications with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6551-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maritime transportation sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated maritime energy infrastructure, including infrastructure that serves ports, to improve system resilience and disaster recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling scientific missions at sea and in extreme environments, including the Arctic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report that describes the results of the study conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02e6555-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s635"},"text":"Pub. L. 110–140, title VI, § 635","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2482"},"text":"134 Stat. 2482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e6556-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02e6557-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc02e6558-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 17214, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s635"},"text":"Pub. L. 110–140, title VI, § 635","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1688"},"text":"121 Stat. 1688","children":[],"tail":", related to applicability of other laws, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
