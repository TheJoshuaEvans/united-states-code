{"tag":"section","attrib":{"id":"idb615dc7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–17"},"text":"§ 300d–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of submission of application containing certain agreements and assurances","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" to a State for a fiscal year unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dc7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State submits to the Secretary an application for the payments containing agreements in accordance with this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreements are made through certification from the chief executive officer of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such agreements, the application provides assurances of compliance satisfactory to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application contains the plan provisions and the information required to be submitted to the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–14"},"text":"section 300d–14 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dc82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–17/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dc83-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1217, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2924"},"text":"104 Stat. 2924","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
