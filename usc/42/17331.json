{"tag":"section","attrib":{"id":"idc0359124-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331"},"text":null,"children":[{"tag":"num","attrib":{"value":"17331"},"text":"§ 17331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States assistance for developing countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359125-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the United States Agency for International Development shall support policies and programs in developing countries that promote clean and efficient energy technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359126-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce the necessary market conditions for the private sector delivery of energy and environmental management services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359127-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create an environment that is conducive to accepting clean and efficient energy technologies that support the overall purpose of reducing greenhouse gas emissions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359128-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving policy, legal, and regulatory frameworks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359129-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing institutional abilities to provide energy and environmental management services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035912a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing public awareness and participation in the decision-making of delivering energy and environmental management services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035912b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the use of American-made clean and efficient energy technologies, products, and energy and environmental management services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035912c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the United States Agency for International Development shall submit to the appropriate congressional committees an annual report on the implementation of this section for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035912d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated to the Administrator of the United States Agency for International Development $200,000,000 for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc035912e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s911"},"text":"Pub. L. 110–140, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1725"},"text":"121 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc035912f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0359130-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0359131-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
