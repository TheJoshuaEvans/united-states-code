{"tag":"section","attrib":{"id":"idbff072b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093"},"text":null,"children":[{"tag":"num","attrib":{"value":"16093"},"text":"§ 16093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cell school buses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff072b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program for entering into cooperative agreements—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with private sector fuel cell bus developers for the development of fuel cell-powered school buses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsequently, with not less than 2 units of local government using natural gas-powered school buses and such private sector fuel cell bus developers to demonstrate the use of fuel cell-powered school buses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal contribution for activities funded under this section shall be not less than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent for fuel infrastructure development activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent for demonstration activities and for development activities not described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall transmit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff072be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the process of converting natural gas infrastructure to accommodate fuel cell-powered school buses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff072bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the results of the development and demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff072c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16093/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $25,000,000 for the period of fiscal years 2006 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff072c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s743"},"text":"Pub. L. 109–58, title VII, § 743","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/826"},"text":"119 Stat. 826","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
