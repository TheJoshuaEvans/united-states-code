{"tag":"section","attrib":{"id":"idc07866bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19071"},"text":null,"children":[{"tag":"num","attrib":{"value":"19071"},"text":"§ 19071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microgravity utilization policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07866be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that space technology and the utilization of the microgravity environment for science, engineering, and technology development is critical to long-term competitiveness with near-peer competitors, including China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent appropriate during an award period, the Foundation shall facilitate access by recipients of Foundation awards to the microgravity environment, including in private sector platforms, for the development of science, engineering, and technology relevant to the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07866c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall provide to the appropriate committees of Congress a report on the Foundation’s plan for facilitating awardee access to the microgravity environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07866c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10364"},"text":"Pub. L. 117–167, div. B, title III, § 10364","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1569"},"text":"136 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
