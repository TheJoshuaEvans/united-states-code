{"tag":"section","attrib":{"id":"idbfa8e149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876"},"text":null,"children":[{"tag":"num","attrib":{"value":"12876"},"text":"§ 12876.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e14a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “applicant” means the following entities that may represent the tenants of the housing:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e14b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A resident management corporation established in accordance with the requirements of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437r"},"text":"section 1437r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e14c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A resident council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e14d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cooperative association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e14e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public or private nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e14f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public body (including an agency or instrumentality thereof).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public housing agency (including an Indian housing authority).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A mutual housing association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible family” means a family or individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a tenant of the eligible property on the date the Secretary approves an implementation grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose income does not exceed 80 percent of the median income for the area, as determined by the Secretary with adjustments for smaller and larger families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible property” means a multifamily rental property, containing 5 or more units, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or held by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financed by a loan or mortgage held by the Secretary or insured by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to have serious physical or financial problems under the terms of an insurance or loan program administered by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or held by the Secretary of Agriculture, the Resolution Trust Corporation, the Federal Deposit Insurance Corporation, the Secretary of Defense, the Secretary of Transportation, the General Services Administration, any other Federal agency, or a State or local government or an agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “homeownership program” means a program for homeownership under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian housing authority” has the meaning given such term in section 1437a(b)(11) ","children":[{"tag":"ref","attrib":{"idref":"fn004128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “low-income family” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/2"},"text":"section 1437a(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public housing agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/6"},"text":"section 1437a(b)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recipient” means an applicant approved to receive a grant under this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or such other entity specified in the approved application that will assume the obligations of the recipient under this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e15f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “resident council” means any incorporated nonprofit organization or association that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is representative of the tenants of the housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopts written procedures providing for the election of officers on a regular basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a democratically elected governing board, elected by the tenants of the housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12876/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa8e164-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s426"},"text":"Pub. L. 101–625, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4170"},"text":"104 Stat. 4170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s181/d"},"text":"Pub. L. 102–550, title I, § 181(d)","children":[],"tail":", (e), (h), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3735"},"text":"106 Stat. 3735","children":[],"tail":", 3736.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa8e165-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa8e166-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa8e167-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/11"},"text":"Section 1437a(b)(11) of this title","children":[],"tail":", referred to in par. (5), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s501/b/1/D"},"text":"Pub. L. 104–330, title V, § 501(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4041"},"text":"110 Stat. 4041","children":[],"tail":", and a new section 1437a(b)(11), defining “public housing agency plan”, was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s506/4"},"text":"Pub. L. 105–276, title V, § 506(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2524"},"text":"112 Stat. 2524","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in par. (8), means title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", known as the Homeownership and Opportunity Through HOPE Act, and probably should have been “this subtitle”, meaning subtitle B (§§ 421–431) of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", which is classified principally to this part. For complete classification of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437aaa"},"text":"section 1437aaa of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa8e168-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s181/d"},"text":"Pub. L. 102–550, § 181(d)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s181/e"},"text":"Pub. L. 102–550, § 181(e)","children":[],"tail":", (h), inserted “the Federal Deposit Insurance Corporation, the Secretary of Defense, the Secretary of Transportation, the General Services Administration, any other Federal agency,” after “Corporation,” and “or an agency or instrumentality thereof” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
