{"tag":"section","attrib":{"id":"idb4edfdde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–16"},"text":"§ 254c–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health services delivered via telehealth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4edfddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edfde0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a public or nonprofit private telehealth provider network that offers services that include mental health services provided by qualified mental health providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfde1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified mental health professionals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified mental health professionals” refers to providers of mental health services reimbursed under the medicare program carried out under title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.) who have additional training in the treatment of mental illness in children and adolescents or who have additional training in the treatment of mental illness in the elderly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfde2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special populations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “special populations” refers to the following 2 distinct groups:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4edfde3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children and adolescents in mental health underserved rural areas or in mental health underserved urban areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4edfde4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Elderly individuals located in long-term care facilities in mental health underserved rural or urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfde5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telehealth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “telehealth” means the use of electronic information and telecommunications technologies to support long distance clinical health care, patient and professional health-related education, public health, and health administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfde6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edfde7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Office for the Advancement of Telehealth of the Health Resources and Services Administration, shall award grants to eligible entities to establish demonstration projects for the provision of mental health services to special populations as delivered remotely by qualified mental health professionals using telehealth and for the provision of education regarding mental illness as delivered remotely by qualified mental health professionals using telehealth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfde8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Populations served","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award the grants under paragraph (1) in a manner that distributes the grants so as to serve equitably the populations described in subparagraphs (A) and (B) of subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfde9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edfdea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall use the grant funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4edfdeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the populations described in subsection (a)(3)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4edfdec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide mental health services, including diagnosis and treatment of mental illness, as delivered remotely by qualified mental health professionals using telehealth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4edfded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collaborate with local public health entities to provide the mental health services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4edfdee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the populations described in subsection (a)(3)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4edfdef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide mental health services, including diagnosis and treatment of mental illness, in long-term care facilities as delivered remotely by qualified mental health professionals using telehealth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4edfdf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collaborate with local public health entities to provide the mental health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfdf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section may also use the grant funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4edfdf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay telecommunications costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4edfdf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay qualified mental health professionals on a reasonable cost basis as determined by the Secretary for services rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edfdf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall not use the grant funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4edfdf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase or install transmission equipment (other than such equipment used by qualified mental health professionals to deliver mental health services using telehealth under the project involved); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4edfdf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build upon or acquire real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfdf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure, to the greatest extent possible, that such grants are equitably distributed among geographical regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfdf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary determines to be reasonable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfdf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2002-10-26"},"text":"October 26, 2002","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress a report that shall evaluate activities funded with grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfdfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–16/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, $20,000,000 for fiscal year 2002 and such sums as may be necessary for fiscal years 2003 through 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4edfdfb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 330K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tII/s221"},"text":"Pub. L. 107–251, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1640"},"text":"116 Stat. 1640","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/d"},"text":"Pub. L. 108–163, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2021"},"text":"117 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4edfdfc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4edfdfd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4edfdfe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4edfdff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/d/1"},"text":"Pub. L. 108–163, § 2(d)(1)","children":[],"tail":", substituted “subsection (a)(3)” for “subsection (a)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/d/2/A"},"text":"Pub. L. 108–163, § 2(d)(2)(A)","children":[],"tail":", substituted “subsection (a)(3)(A)” for “subsection (a)(4)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/d/2/B"},"text":"Pub. L. 108–163, § 2(d)(2)(B)","children":[],"tail":", substituted “subsection (a)(3)(B)” for “subsection (a)(4)(B)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4edfe00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4edfe01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163"},"text":"Pub. L. 108–163","children":[],"tail":" deemed to have taken effect immediately after the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s3"},"text":"section 3 of Pub. L. 108–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s233"},"text":"section 233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
