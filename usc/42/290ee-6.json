{"tag":"section","attrib":{"id":"idb5c264bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–6"},"text":"§ 290ee–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional Centers of Excellence in Substance Use Disorder Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c264bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with appropriate agencies, shall award cooperative agreements to eligible entities for the designation of such entities as Regional Centers of Excellence in Substance Use Disorder Education for purposes of improving health professional training resources with respect to substance use disorder prevention, treatment, and recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a cooperative agreement under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c264be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be an accredited entity that offers education to students in various health professions, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c264bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a teaching hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c264c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c264c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified behavioral health clinic; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c264c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other health professions school, school of public health, or Cooperative Extension Program at institutions of higher education, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":", engaged in the prevention, treatment, or recovery of substance use disorders;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate community engagement and partnerships with community stakeholders, including entities that train health professionals, mental health counselors, social workers, peer recovery specialists, substance use treatment programs, community health centers, physician offices, certified behavioral health clinics, research institutions, and law enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application containing such information, at such time, and in such manner, as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity receiving an award under this section shall develop, evaluate, and distribute evidence-based resources regarding the prevention and treatment of, and recovery from, substance use disorders. Such resources may include information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c264c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the neurology and pathology of substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancements in the treatment of substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques and best practices to support recovery from substance use disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for the prevention and treatment of, and recovery from substance use disorders across patient populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other topic areas that are relevant to the objectives described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding cooperative agreements under subsection (a), the Secretary shall take into account regional differences among eligible entities and shall make an effort to ensure geographic distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate each project carried out by an entity receiving an award under this section and shall disseminate the findings with respect to each such evaluation to appropriate public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $4,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c264ce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 551, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7101"},"text":"Pub. L. 115–271, title VII, § 7101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4037"},"text":"132 Stat. 4037","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
