{"tag":"section","attrib":{"id":"idbb994cc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1868"},"text":null,"children":[{"tag":"num","attrib":{"value":"1868"},"text":"§ 1868.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special commissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb994cca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1868/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each special commission established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1863/h"},"text":"section 1863(h) of this title","children":[],"tail":" shall be appointed by the Board and shall consist of such members as the Board considers appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb994ccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1868/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special commissions may be established to study and make recommendations to the Foundation on issues relating to research and education in science and engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb994ccc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-10/ch171/s9"},"text":"May 10, 1950, ch. 171, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/152"},"text":"64 Stat. 152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/407/s7"},"text":"Pub. L. 90–407, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-18"},"text":"July 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/364"},"text":"82 Stat. 364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/159/tI/s109/d"},"text":"Pub. L. 99–159, title I, § 109(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-22"},"text":"Nov. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/889"},"text":"99 Stat. 889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb994ccd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb994cce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb994ccf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/159"},"text":"Pub. L. 99–159","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Each special commission established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1863/i"},"text":"section 1863(i) of this title","children":[],"tail":" shall consist of eleven members appointed by the Board, six of whom shall be eminent scientists and five of whom shall be persons other than scientists. Each special commission shall choose its own chairman and vice chairman."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) It shall be the duty of each such special commission to make a comprehensive survey of research, both public and private, being carried on in its field, and to formulate and recommend to the Foundation at the earliest practicable date an over-all research program in its field.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/407"},"text":"Pub. L. 90–407","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1863/i"},"text":"section 1863(i) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862/a/7"},"text":"section 1862(a)(7) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb994cd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb994cd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Existing Offices, Procedures, and Organization of the National Science Foundation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/407"},"text":"Pub. L. 90–407","children":[],"tail":" intended to continue in effect the existing offices, procedures, and organization of the Foundation, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/407/s16"},"text":"section 16 of Pub. L. 90–407","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862"},"text":"section 1862 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
