{"tag":"section","attrib":{"id":"idc0227da1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053"},"text":null,"children":[{"tag":"num","attrib":{"value":"17053"},"text":"§ 17053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal fleet fueling centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227da2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":", the head of each Federal agency shall install at least 1 renewable fuel pump at each Federal fleet fueling center in the United States under the jurisdiction of the head of the Federal agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227da3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than October 31 of the first calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and each October 31 thereafter, the President shall submit to Congress a report that describes the progress toward complying with subsection (a), including identifying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227da4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal fleet fueling centers that contain at least 1 renewable fuel pump; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227da5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal fleet fueling centers that do not contain any renewable fuel pumps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227da6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a Department of Defense fueling center with a fuel turnover rate of less than 100,000 gallons of fuel per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227da7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17053/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227da8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s246"},"text":"Pub. L. 110–140, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attri