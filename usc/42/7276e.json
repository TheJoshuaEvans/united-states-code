{"tag":"section","attrib":{"id":"idbe0088bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7276e"},"text":"§ 7276e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of rewards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out a program under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7276d"},"text":"section 7276d of this title","children":[],"tail":", each Administrator referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7276d"},"text":"section 7276d of this title","children":[],"tail":" is authorized to provide rewards (including cash rewards) to individuals who provide information or evidence leading to the arrest and prosecution of individuals causing damage to, or loss of, Federal property under their jurisdiction. The amount of any one such reward paid to any individual may not exceed a value of $1,000."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe02d2ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/78/s2"},"text":"Pub. L. 107–78, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/808"},"text":"115 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe02d2af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe02d2b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe02d2b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
