{"tag":"section","attrib":{"id":"idb65640a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"300t–13"},"text":"§ 300t–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for reduction of excess hospital capacity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65640a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Excess hospital capacity” defined; particular activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of demonstrating the effectiveness of various means for reducing excesses in resources and facilities of hospitals (referred to in this section as “excess hospital capacity”), the Secretary may make grants to State Agencies designated under section 300m(b)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002367"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002367"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to assist such Agencies in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65640a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying (by geographic region or by health service) excess hospital capacity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65640a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing programs to inform the public of the costs associated with excess hospital capacity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65640a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing programs to reduce excess hospital capacity in a manner which will produce the greatest savings in the cost of health care delivery,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65640aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing means to overcome barriers to the reduction of excess hospital capacity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65640ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in planning, evaluating, and carrying out programs to decertify health care facilities providing health services that are not appropriate, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65640ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity related to the reduction of excess hospital capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65640ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300t–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under subsection (a) shall be made on such terms and conditions as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65640ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1643, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tIII/s301/a"},"text":"Pub. L. 96–79, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/639"},"text":"93 Stat. 639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65640af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65640b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb65640b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300m"},"text":"Section 300m of this title","children":[],"tail":", referred to in subsec. (a), was in the original a reference to section 1521 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was repealed effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/9