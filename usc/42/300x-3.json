{"tag":"section","attrib":{"id":"idb666e2c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–3"},"text":"§ 300x–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State mental health planning council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb666e2c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" is that the State involved will establish and maintain a State mental health planning council in accordance with the conditions described in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e2c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A condition under subsection (a) for a Council is that the duties of the Council are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e2c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review plans provided to the Council pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–4/a"},"text":"section 300x–4(a) of this title","children":[],"tail":" by the State involved and to submit to the State any recommendations of the Council for modifications to the plans;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as an advocate for adults with a serious mental illness, children with a severe emotional disturbance, and other individuals with mental illnesses or emotional problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor, review, and evaluate, not less than once each year, the allocation and adequacy of mental health services within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e2ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e2cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A condition under subsection (a) for a Council is that the Council be composed of residents of the State, including representatives of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e2cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the principal State agencies with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e2cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health, education, vocational rehabilitation, criminal justice, housing, and social services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e2ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the plan submitted pursuant to title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private entities concerned with the need, planning, operation, funding, and use of mental health services and related support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adults with serious mental illnesses who are receiving (or have received) mental health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the families of such adults or families of children with emotional disturbance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A condition under subsection (a) for a Council is that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e2d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the membership of the Council, the ratio of parents of children with a serious emotional disturbance to other members of the Council is sufficient to provide adequate representation of such children in the deliberations of the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 50 percent of the members of the Council are individuals who are not State employees or providers of mental health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e2d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Council” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Council” means a State mental health planning council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb666e2d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1914, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/382"},"text":"106 Stat. 382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb666e2d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb666e2d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb666e2d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (c)(1)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb666e2da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300x–3, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIX/s1915"},"text":"act July 1, 1944, ch. 373, title XIX, § 1915","children":[],"tail":", formerly § 1914, as added "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/545"},"text":"95 Stat. 545","children":[],"tail":"; renumbered § 1915 and amended "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/509/tI"},"text":"Pub. L. 98–509, title I","children":[],"tail":", §§ 105(b), 106(a), (b), (d), (g), "},{"tag":"ref","attrib":{"href":"/us/stat/98/2358"},"text":"98 Stat. 2358","children":[],"tail":", 2359; "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII"},"text":"Pub. L. 100–690, title II","children":[],"tail":", §§ 2024–2026, "},{"tag":"ref","attrib":{"href":"/us/stat/102/4198"},"text":"102 Stat. 4198","children":[],"tail":", 4199; "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s2/d"},"text":"Pub. L. 101–93, § 2(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/606"},"text":"103 Stat. 606","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/639/s3/a/2"},"text":"Pub. L. 101–639, § 3(a)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4601"},"text":"104 Stat. 4601","children":[],"tail":", related to the use of grant allotments for alcohol, drug abuse, and mental health services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/s201/2"},"text":"Pub. L. 102–321, § 201(2)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 1914 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–2"},"text":"section 300x–2 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
