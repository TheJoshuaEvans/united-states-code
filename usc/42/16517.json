{"tag":"section","attrib":{"id":"idc0190855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517"},"text":null,"children":[{"tag":"num","attrib":{"value":"16517"},"text":"§ 16517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy infrastructure reinvestment financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0190856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16513"},"text":"section 16513 of this title","children":[],"tail":", the Secretary may make guarantees, including refinancing, under this section only for projects that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retool, repower, repurpose, or replace energy infrastructure that has ceased operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable operating energy infrastructure to increase capacity or output; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support or enable the provision of known or forecastable electric supply at time intervals necessary to maintain or enhance grid reliability or other system adequacy needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019085a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under subsection (a) may include the remediation of environmental damage associated with energy infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019085b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To apply for a guarantee under this section, an applicant shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019085c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan describing the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019085d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an applicant that is an electric utility, an assurance that the electric utility shall pass on any financial benefit from the guarantee made under this section to the customers of, or associated communities served by, the electric utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019085e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16512/f"},"text":"section 16512(f) of this title","children":[],"tail":", the term of an obligation shall require full repayment over a period not to exceed 30 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019085f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of energy infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “energy infrastructure” means a facility, and associated equipment, used for enabling the identification, leasing, development, production, processing, transportation, transmission, refining, and generation needed for energy and critical minerals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary for fiscal year 2025, out of any money in the Treasury not otherwise appropriated, $1,000,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":", to carry out activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16517/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount made available under paragraph (1), the Secretary shall use not more than 3 percent for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0190863-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVII/s1706"},"text":"Pub. L. 109–58, title XVII, § 1706","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50144/c"},"text":"Pub. L. 117–169, title V, § 50144(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2045"},"text":"136 Stat. 2045","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tV/s50403/a"},"text":"Pub. L. 119–21, title V, § 50403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/152"},"text":"139 Stat. 152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0190864-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0190865-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0190866-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/1/B"},"text":"Pub. L. 119–21, § 50403(a)(1)(B)","children":[],"tail":", substituted “increase capacity or output; or” for “avoid, reduce, utilize, or sequester air pollutants or anthropogenic emissions of greenhouse gases.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/1/A"},"text":"Pub. L. 119–21, § 50403(a)(1)(A)","children":[],"tail":", (C), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/2"},"text":"Pub. L. 119–21, § 50403(a)(2)","children":[],"tail":", (3), redesignated subsec. (d) as (c) and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “A project under subsection (a)(1) that involves electricity generation through the use of fossil fuels shall be required to have controls or technologies to avoid, reduce, utilize, or sequester air pollutants and anthropogenic emissions of greenhouse gases.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/4"},"text":"Pub. L. 119–21, § 50403(a)(4)","children":[],"tail":", redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “an analysis of how the proposed project will engage with and affect associated communities; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/3"},"text":"Pub. L. 119–21, § 50403(a)(3)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/3"},"text":"Pub. L. 119–21, § 50403(a)(3)","children":[],"tail":", (5), redesignated subsec. (f) as (e) and substituted “for enabling the identification, leasing, development, production, processing, transportation, transmission, refining, and generation needed for energy and critical minerals.” for “for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the generation or transmission of electric energy; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the production, processing, and delivery of fossil fuels, fuels derived from petroleum, or petrochemical feedstocks.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former subsec. (e) redesignated (d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s50403/a/6"},"text":"Pub. L. 119–21, § 50403(a)(6)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
