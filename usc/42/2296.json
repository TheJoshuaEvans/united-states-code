{"tag":"section","attrib":{"id":"idbc17a48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296"},"text":"§ 2296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonliability of United States; indemnification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Government of the United States of America shall not be liable for any damages or third party liability arising out of or resulting from the joint program: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That nothing in this section shall deprive any person of any rights under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"section 2210 of this title","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That nothing in this section shall apply to arrangements made by the Commission under a research and development program authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2292"},"text":"section 2292 of this title","children":[],"tail":". The Government of the United States shall take such steps as may be necessary, including appropriate disclaimer or indemnity arrangements, in order to carry out the provisions of this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc17a48d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/846/s7"},"text":"Pub. L. 85–846, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1086"},"text":"72 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/206/s20"},"text":"Pub. L. 87–206, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-06"},"text":"Sept. 6, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/479"},"text":"75 Stat. 479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a48e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a48f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a490-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the EURATOM Cooperation Act of 1958 which comprises this subchapter, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc17a491-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/206"},"text":"Pub. L. 87–206","children":[],"tail":" inserted proviso making provisions of section inapplicable to arrangements made by the Commission under a research and development program authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2292"},"text":"section 2292 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
