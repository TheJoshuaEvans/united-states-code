{"tag":"section","attrib":{"id":"idb5a5b581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–7a"},"text":"§ 290bb–7a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth prevention and recovery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a5b582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a5b583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”, except as otherwise provided), in consultation with the Secretary of Education and other heads of agencies, including the Assistant Secretary for Mental Health and Substance Use and the Administrator of the Health Resources and Services Administration, as appropriate, shall establish a resource center to provide technical support to recipients of grants under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a5b584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth prevention and recovery initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a5b585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education, shall administer a program to provide support for communities to support the prevention of, treatment of, and recovery from, substance use disorders for children, adolescents, and young adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a5b588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency, or a consortium of local educational agencies, that is seeking to establish or expand substance use prevention or recovery support services at one or more secondary schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b58a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (or consortia of such institutions), which may include a recovery program at an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b58b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local board or one-stop operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b58c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization with appropriate expertise in providing services or programs for children, adolescents, or young adults, excluding a school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b58d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, political subdivision of a State, Indian Tribe, or Tribal organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b58e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high school or dormitory serving high school students that receives funding from the Bureau of Indian Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b58f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foster care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foster care” has the meaning given such term in section 1355.20(a) of title 45, Code of Federal Regulations (or any successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high school” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeless youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “homeless youth” has the meaning given the term “homeless children or youths” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"section 11434a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe; Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian Tribe” and “Tribal organization” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":" and includes a “postsecondary vocational institution” as defined in section 1002(c) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local educational agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local board; one-stop operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “local board” and “one-stop operator” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Out-of-school youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “out-of-school youth” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3164/a/1/B"},"text":"section 3164(a)(1)(B) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recovery program” means a program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a5b598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help children, adolescents, or young adults who are recovering from substance use disorders to initiate, stabilize, and maintain healthy and productive lives in the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes peer-to-peer support delivered by individuals with lived experience in recovery, and communal activities to build recovery skills and supportive social networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b59a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secondary school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “secondary school” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b59b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State educational agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b59c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b59d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify or facilitate the development of evidence-based best practices for prevention of substance misuse by children, adolescents, and young adults, including for specific populations at increased risk for substance misuse such as youth in foster care, homeless youth, out-of-school youth, and youth who are at risk of or have experienced trafficking that address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a5b59e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary prevention, which may include strategies to increase education and awareness of the potency and dangers of synthetic opioids (including drugs contaminated with fentanyl) and, as appropriate, other emerging drug use or misuse issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b59f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate recovery support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate use of medication-assisted treatment for such individuals, if applicable, and ways of overcoming barriers to the use of medication-assisted treatment in such population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient and effective communication, which may include the use of social media, to maximize outreach efforts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such best practices to State educational agencies, local educational agencies, schools and dormitories funded by the Bureau of Indian Education, institutions of higher education, recovery programs at institutions of higher education, local boards, one-stop operators, family and youth homeless providers, and nonprofit organizations, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a rigorous evaluation of each grant funded under this subsection, particularly its impact on the indicators described in paragraph (7)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance for grantees under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education, shall award 3-year grants, on a competitive basis, to eligible entities to enable such entities, in coordination with Indian Tribes, if applicable, and State agencies responsible for carrying out substance use disorder prevention and treatment programs, to carry out evidence-based programs for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention of substance misuse by children, adolescents, and young adults, which may include primary prevention and strategies to increase education and awareness of the potency and dangers of synthetic opioids (including drugs contaminated with fentanyl) and, as appropriate, emerging drug use or misuse issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery support services for children, adolescents, and young adults, which may include counseling, job training, linkages to community-based services, family support groups, peer-to-peer support, and recovery coaching; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment or referrals for treatment of substance use disorders, which may include the use of medication-assisted treatment, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subsection, the Secretary shall give special consideration to the unique needs of Tribal, urban, suburban, and rural populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this subsection, an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require. Such application shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b5ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a5b5ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of substance use disorders in the population that will be served by the grant program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity has solicited input from relevant stakeholders, which may include faculty, teachers, staff, families, students, and experts in substance use disorder prevention, treatment, and recovery in developing such application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of the proposed project, including the intended outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity plans to use grant funds for evidence-based activities, in accordance with this subsection to prevent, provide recovery support for, or treat substance use disorders amongst such individuals, or a combination of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity will collaborate with relevant partners, which may include State educational agencies, local educational agencies, institutions of higher education, juvenile justice agencies, prevention and recovery support providers, local service providers, including substance use disorder treatment programs, providers of mental health services, youth serving organizations, family and youth homeless providers, child welfare agencies, and primary care providers, in carrying out the grant program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to sustain the activities carried out under the grant program, after the grant program has ended; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the eligible entity will participate in the evaluation described in paragraph (3)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible entity awarded a grant under this subsection shall submit to the Secretary a report at such time and in such manner as the Secretary may require. Such report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b5b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible entity used grant funds, in accordance with this subsection, including the number of children, adolescents, and young adults reached through programming; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description, including relevant data, of how the grant program has made an impact on the intended outcomes described in paragraph (6)(A)(iii), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5a5b5b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicators of student success, which, if the eligible entity is an educational institution, shall include student well-being and academic achievement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance use disorders amongst children, adolescents, and young adults, including the number of overdoses and deaths amongst children, adolescents, and young adults served by the grant during the grant period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5a5b5b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other indicators, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":", submit a report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce and the Committee on Education and the Workforce of the House of Representatives a report summarizing the effectiveness of the grant program under this subsection, based on the information submitted in reports required under paragraph (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b5ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this subsection, there are authorized to be appropriated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a5b5bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 for fiscal year 2027;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,000,000 for fiscal year 2028;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,000,000 for fiscal year 2029; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a5b5bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–7a/c/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a5b5c0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7102"},"text":"Pub. L. 115–271, title VII, § 7102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4038"},"text":"132 Stat. 4038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s110/a"},"text":"Pub. L. 119–44, title I, § 110(a)","children":[],"tail":", title III, § 304, "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/677"},"text":"139 Stat. 677","children":[],"tail":", 685.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a5b5c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a5b5c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a5b5c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7102"},"text":"section 7102 of Pub. L. 115–271","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7102"},"text":"section 7102 of Pub. L. 115–271","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–7"},"text":"section 290bb–7 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Substance Use–Disorder Prevention that Promotes Opioid Recovery and Treatment for Patients and Communities Act, also known as the SUPPORT for Patients and Communities Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5a5b5c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/1/A/i"},"text":"Pub. L. 119–44, § 304(1)(A)(i)","children":[],"tail":", inserted “, or a consortium of local educational agencies,” after “a local educational agency” and substituted “secondary schools” for “high schools”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A)(vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/1/A/ii"},"text":"Pub. L. 119–44, § 304(1)(A)(ii)","children":[],"tail":", substituted “Tribe, or Tribal” for “tribe, or tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/1/B"},"text":"Pub. L. 119–44, § 304(1)(B)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, text read as follows: “The terms ‘Indian tribe’ and ‘tribal organization’ have the meanings given such terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(K), (L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/1/C"},"text":"Pub. L. 119–44, § 304(1)(C)","children":[],"tail":", (D), added subpar. (K) and redesignated former subpar. (K) as (L)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/2"},"text":"Pub. L. 119–44, § 304(2)","children":[],"tail":", in introductory provisions, struck out “and abuse” before “by children,” and inserted “at increased risk for substance misuse” after “specific populations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s110/a/1"},"text":"Pub. L. 119–44, § 110(a)(1)","children":[],"tail":", inserted “, which may include strategies to increase education and awareness of the potency and dangers of synthetic opioids (including drugs contaminated with fentanyl) and, as appropriate, other emerging drug use or misuse issues” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/3/A"},"text":"Pub. L. 119–44, § 304(3)(A)","children":[],"tail":", substituted “Indian Tribes” for “Indian tribes” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/3/B"},"text":"Pub. L. 119–44, § 304(3)(B)","children":[],"tail":", struck out “and abuse” before “by children,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s110/a/2"},"text":"Pub. L. 119–44, § 110(a)(2)","children":[],"tail":", inserted “and strategies to increase education and awareness of the potency and dangers of synthetic opioids (including drugs contaminated with fentanyl) and, as appropriate, emerging drug use or misuse issues” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/3/C"},"text":"Pub. L. 119–44, § 304(3)(C)","children":[],"tail":", substituted “peer-to-peer support” for “peer mentoring”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/4"},"text":"Pub. L. 119–44, § 304(4)","children":[],"tail":", substituted “Tribal” for “tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(A)(vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/5"},"text":"Pub. L. 119–44, § 304(5)","children":[],"tail":", added cl. (vi)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/6"},"text":"Pub. L. 119–44, § 304(6)","children":[],"tail":", substituted “2028” for “2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s304/7"},"text":"Pub. L. 119–44, § 304(7)","children":[],"tail":", amended par. (9) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated $10,000,000 to carry out this subsection for each of fiscal years 2019 through 2023.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
