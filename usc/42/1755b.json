{"tag":"section","attrib":{"id":"idbb481f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1755b"},"text":"§ 1755b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pulse crop products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb481f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage greater awareness and interest in the number and variety of pulse crop products available to schoolchildren, as recommended by the most recent Dietary Guidelines for Americans published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5341"},"text":"section 5341 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible pulse crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible pulse crop” means dry beans, dry peas, lentils, and chickpeas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pulse crop product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pulse crop product” means a food product derived in whole or in part from an eligible pulse crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of pulse crops and pulse crop products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the commodities delivered under section 6 of the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755"},"text":"42 U.S.C. 1755","children":[],"tail":"), subject to the availability of appropriations, the Secretary shall purchase eligible pulse crops and pulse crop products for use in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school lunch program established under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school breakfast program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"section 1773 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":", the Secretary shall conduct an evaluation of the activities conducted under subsection (c), including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb481f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of whether children participating in the school lunch and breakfast programs described in subsection (c) increased overall consumption of eligible pulse crops as a result of the activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of which eligible pulse crops and pulse crop products are most acceptable for use in the school lunch and breakfast programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary regarding the integration of the use of pulse crop products in carrying out the school lunch and breakfast programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any change in the nutrient composition in the school lunch and breakfast programs due to the activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb481f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any other outcomes determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb481f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the completion of the evaluation under subsection (d), the Secretary shall submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Education and the Workforce of the House of Representative ","children":[{"tag":"ref","attrib":{"idref":"fn003187"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003187"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Representatives”."}],"tail":" a report describing the results of the evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb4a9068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1755b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb4a9069-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4213"},"text":"Pub. L. 113–79, title IV, § 4213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/830"},"text":"128 Stat. 830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb4a906a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb4a906b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb4a906c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb4a906d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of the Richard B. Russell National School Lunch Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb4a906e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb4a906f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":null},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
