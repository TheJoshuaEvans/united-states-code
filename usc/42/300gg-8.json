{"tag":"section","attrib":{"id":"idb6a9b7f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–8"},"text":"§ 300gg–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage for individuals participating in approved clinical trials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a9b7f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a9b7f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a group health plan or a health insurance issuer offering group or individual health insurance coverage provides coverage to a qualified individual, then such plan or issuer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a9b7fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not deny the individual participation in the clinical trial referred to in subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a9b7fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (c), may not deny (or limit or impose additional conditions on) the coverage of routine patient costs for items and services furnished in connection with participation in the trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a9b7fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not discriminate against the individual on the basis of the individual’s participation in such trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a9b7fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Routine patient costs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a9b7fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B), subject to subparagraph (B), routine patient costs include all items and services consistent with the coverage provided in the plan (or coverage) that is typically covered for a qualified individual who is not enrolled in a clinical trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a9b7ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(B), routine patient costs does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a9b800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigational item, device, or service, itself;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a9b801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" items and services that are provided solely to satisfy data collection and analysis needs and that are not used in the direct clinical management of the patient; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a9b802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service that is clearly inconsistent with widely accepted and established standards of care for a particular diagnosis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a9b803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of in-network providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If one or more participating providers is participating in a clinical trial, nothing in paragraph (1) shall be construed as preventing a plan or issuer from requiring that a qualified individual participate in the trial through such a participating provider if the provider will accept the individual as a participant in the trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a9b804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of out-of-network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (3), paragraph (1) shall apply to a qualified individual participating in an approved clinical trial that is conducted outside the State in which the qualified individual resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a9b805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individual defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “qualified individual” means an individual who is a participant or beneficiary in a health plan or with coverage described in subsection (a)(1) and who meets the following conditions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a9b806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual is eligible to participate in an approved clinical trial according to the trial protocol with respect to treatment of cancer or other life-threatening disease or condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac01f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac01f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the referring health care professional is a participating health care provider and has concluded that the individual’s participation in such trial would be appropriate based upon the individual meeting the conditions described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac01f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant or beneficiary provides medical and scientific information establishing that the individual’s participation in such trial would be appropriate based upon the individual meeting the conditions described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac01fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to require a group health plan, or a health insurance issuer offering group or individual health insurance coverage, to provide benefits for routine patient care services provided outside of the plan’s (or coverage’s) health care provider network unless out-of-network benefits are otherwise provided under the plan (or coverage).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac01fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approved clinical trial defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac01fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “approved clinical trial” means a phase I, phase II, phase III, or phase IV clinical trial that is conducted in relation to the prevention, detection, or treatment of cancer or other life-threatening disease or condition and is described in any of the following subparagraphs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac01fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federally funded trials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study or investigation is approved or funded (which may include funding through in-kind contributions) by one or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6ac01fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac01ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac0200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency for Health Care Research and Quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac0201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Medicare & Medicaid Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac0202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative ","children":[{"tag":"ref","attrib":{"idref":"fn002453"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002453"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “A”."}],"tail":" group or center of any of the entities described in clauses (i) through (iv) or the Department of Defense or the Department of Veterans Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac0203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualified non-governmental research entity identified in the guidelines issued by the National Institutes of Health for center support grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6ac0204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any of the following if the conditions described in paragraph (2) are met:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6ac0205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6ac0206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6ac0207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/A/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac0208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The study or investigation is conducted under an investigational new drug application reviewed by the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac0209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The study or investigation is a drug trial that is exempt from having such an investigational new drug application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac020a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for departments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions described in this paragraph, for a study or investigation conducted by a Department, are that the study or investigation has been reviewed and approved through a system of peer review that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac020b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be comparable to the system of peer review of studies and investigations used by the National Institutes of Health, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac020c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assures unbiased review of the highest scientific standards by qualified individuals who have no interest in the outcome of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac020d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-threatening condition defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “life-threatening condition” means any disease or condition from which the likelihood of death is probable unless the course of the disease or condition is interrupted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac020e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit a plan’s or issuer’s coverage with respect to clinical trials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac020f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to FEHBP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of chapter 89 of title 5, this section shall apply to health plans offered under the program under such chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac0210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–8/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, nothing in this section shall preempt State laws that require a clinical trials policy for State regulated health insurance plans that is in addition to the policy required under this section..","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ac0211-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2709, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10103/c"},"text":"Pub. L. 111–148, title X, § 10103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/892"},"text":"124 Stat. 892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ac0212-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ac0213-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6ac0214-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2709 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–9"},"text":"section 300gg–9 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6ac0215-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2709 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238h"},"text":"section 238h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
