{"tag":"section","attrib":{"id":"idc05e2829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648"},"text":null,"children":[{"tag":"num","attrib":{"value":"18648"},"text":"§ 18648.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerator research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc05e282a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7139"},"text":"section 7139 of this title","children":[],"tail":", the Director shall carry out a research program—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05e282b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance accelerator science and technology relevant to the Department, other Federal agencies, and United States industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e282c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster partnerships to develop, demonstrate, and enable the commercial application of accelerator technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e282d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the development of a skilled, diverse, and inclusive accelerator workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05e282e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide access to accelerator design and engineering resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc060982f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerator research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program authorized under subsection (a), the Director shall support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research activities in cross-cutting accelerator technologies including superconducting magnets and accelerators, beam physics, data analytics-based accelerator controls, simulation software, new particle sources, advanced laser technology, and transformative research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimal operation of the Accelerator Test Facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerator development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program authorized under subsection (a), the Director shall support partnerships to foster the development, demonstration, and commercial application of accelerator technologies, including advanced superconducting wire and cable, superconducting RF cavities, and high efficiency radiofrequency power sources for accelerators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research collaborations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing accelerator technologies under the program authorized under subsection (a), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the requirements necessary to support translational research and development for medical, industrial, security, and defense applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage investments in accelerator technologies and fundamental research in particle physics by partnering with institutions of higher education, industry, and other Federal agencies to enable the commercial application of advanced accelerator technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there are authorized to be appropriated to the Secretary to carry out the activities described in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $19,080,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,224,800 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $21,438,288 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc060983a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $22,724,585 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc060983b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18648/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24,088,060 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc060983c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s310"},"text":"Pub. L. 115–246, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10109"},"text":"Pub. L. 117–167, div. B, title I, § 10109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1451"},"text":"136 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
