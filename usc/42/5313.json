{"tag":"section","attrib":{"id":"idbd4687b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313"},"text":null,"children":[{"tag":"num","attrib":{"value":"5313"},"text":"§ 5313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4687b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the close of each fiscal year in which assistance under this chapter is furnished, the Secretary shall submit to the Congress a report which shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4687b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress made in accomplishing the objectives of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4687b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the use of such funds during the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4687b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the action grants authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5318"},"text":"section 5318 of this title","children":[],"tail":", a listing of each unit of general local government receiving funds and the amount of such grants, as well as a brief summary of the projects funded for each such unit, the extent of financial participation by other public or private entities, and the impact on employment and economic activity of such projects during the previous fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4687b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5308"},"text":"section 5308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4687b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to require recipients of assistance under this chapter to submit to him such reports and other information as may be necessary in order for the Secretary to make the report required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4687b9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s113"},"text":"Pub. L. 93–383, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/651"},"text":"88 Stat. 651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/128/tI/s109"},"text":"Pub. L. 95–128, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1124"},"text":"91 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s309"},"text":"Pub. L. 97–35, title III, § 309","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/397"},"text":"95 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIX/s910/h"},"text":"Pub. L. 101–625, title IX, § 910(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4392"},"text":"104 Stat. 4392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4687ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4687bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd4687bc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd4687bd-3