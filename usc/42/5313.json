t":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128"},"text":"Pub. L. 95–128","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/128/s114"},"text":"section 114 of Pub. L. 95–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd4687c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study Regarding Availability of Housing Proximate to Places of Employment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIX/s919"},"text":"Pub. L. 101–625, title IX, § 919","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4401"},"text":"104 Stat. 4401","children":[],"tail":", directed Secretary of Housing and Urban Development to conduct a study regarding availability of housing within reasonable proximity of places of employment and to submit a report not later than expiration of 1-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", to appropriate committees of Congress containing results and conclusions of such study, as well as proposed strategies to increase availability of housing for low- and moderate-income families within reasonable proximity of places of employment for working members of such families to and prevent geographical divergence of such housing and places of employment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd4687c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Involuntary Housing Displacement; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tI/s105/b"},"text":"Pub. L. 96–399, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1618"},"text":"94 Stat. 1618","children":[],"tail":", directed Secretary of Housing and Urban Development to continue study on involuntary displacement conducted under "},{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIX/s902"},"text":"Pub. L. 95–557, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2125"},"text":"92 Stat. 2125","children":[],"tail":", set out below, and transmit, not later than "},{"tag":"date","attrib":{"date":"1981-03-30"},"text":"Mar. 30, 1981","children":[],"tail":", a report to Congress containing data collected since initial report submitted under such section 902, and further recommendations on minimizing involuntary displacement and alleviating problems caused by such displacement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd4687c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adequacy, Effectiveness, and Equity of Formula for Allocation of Funds; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tI/s113"},"text":"Pub. L. 96–399, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1622"},"text":"94 Stat. 1622","children":[],"tail":", directed Secretary of Housing and Urban Development, not later than "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"Jan. 1, 1983","children":[],"tail":", to report to Congress with respect to adequacy, effectiveness, and equity of formula used for allocation of funds under title I of the Housing and Community Development Act of 1974 (this chapter), with specific analysis and recommendations concerning manner in which such formula is or could be affected by data derived from 1980 decennial census."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd4687c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Policy and Study on Housing Displacement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tIX/s902"},"text":"Pub. L. 95–557, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2125"},"text":"92 Stat. 2125","children":[],"tail":", declared it to be the policy of Congress that in administration of Federal housing and development programs, involuntary displacement of persons from homes and neighborhoods should be minimized and in keeping with such stated policy, authorized Secretary of Housing and Urban Development to conduct a study on nature and extent of such displacement and, not later than "},{"tag":"date","attrib":{"date":"1979-01-31"},"text":"Jan. 31, 1979","children":[],"tail":", report to Congress on recommendations for formulation of a national policy to minimize such displacement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd4687c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Small Cities; Report to President and Congress; Alternative Formulae","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128/tI/s113"},"text":"Pub. L. 95–128, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1111"},"text":"91 Stat. 1111","children":[],"tail":", directed Secretary of Housing and Urban Development to conduct a study and, not later than one year after "},{"tag":"date","attrib":{"date":"1977-10-12"},"text":"Oct. 12, 1977","children":[],"tail":", report to President and Congress recommendations on formation of a national policy on developmental needs of small cities and, among other things, include in such report alternative verifiable formulae to be used in distribution of discretionary balance funds available for allocation to such small cities under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
