{"tag":"section","attrib":{"id":"idbaa85d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397f"},"text":"§ 1397f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaa85d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaa85d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397a"},"text":"section 1397a of this title","children":[],"tail":", each State shall be entitled to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa85d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 grants under this section for each qualified empowerment zone in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa85d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 grant under this section for each qualified enterprise community in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaa85d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaa85d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empowerment grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of each grant to a State under this section for a qualified empowerment zone shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaa85d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the zone is designated in an urban area, $50,000,000, multiplied by that proportion of the population of the zone that resides in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaa85d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the zone is designated in a rural area, $20,000,000, multiplied by such proportion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaa85d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the grant to a State under this section for a qualified enterprise community shall be ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"95","children":[],"tail":" of $280,000,000, multiplied by that proportion of the population of the community that resides in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make population determinations for purposes of this paragraph based on the most recent decennial census data available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified empowerment zones","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each qualified empowerment zone, the Secretary shall make—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaacd7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 grant under this section to each State in which the zone lies, on the date of the designation of the zone under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaacd7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 grant under this section to each such State, on the 1st day of the 1st fiscal year that begins after the date of the designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified enterprise communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each qualified enterprise community, the Secretary shall make 1 grant under this section to each State in which the community lies, on the date of the designation of the community under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"$1,000,000,000 shall be made available to the Secretary for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaacd81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program options","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397d/a"},"text":"section 1397d(a) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaacd82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to prevent and remedy the neglect and abuse of children, a State may use amounts paid under this section to make grants to, or enter into contracts with, entities to provide residential or nonresidential drug and alcohol prevention and treatment programs that offer comprehensive services for pregnant women and mothers, and their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to assist disadvantaged adults and youths in achieving and maintaining self-sufficiency, a State may use amounts paid under this section to make grants to, or enter into contracts with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations operated for profit or not for profit, for the purpose of training and employing disadvantaged adults and youths in construction, rehabilitation, or improvement of affordable housing, public infrastructure, and community facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations and community or junior colleges, for the purpose of enabling such entities to provide short-term training courses in entrepreneurism and self-employment, and other training that will promote individual self-sufficiency and the interests of the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State may use amounts paid under this section to make grants to, or enter into contracts with, nonprofit community-based organizations to enable such organizations to provide activities designed to promote and protect the interests of children and families, outside of school hours, including keeping schools open during evenings and weekends for mentoring and study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to assist disadvantaged adults and youths in achieving and maintaining economic self-support, a State may use amounts paid under this section to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund services designed to promote community and economic development in qualified empowerment zones and qualified enterprise communities, such as skills training, job counseling, transportation services, housing counseling, financial management, and business counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in emergency and transitional shelter for disadvantaged families and individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support programs that promote home ownership, education, or other routes to economic independence for low-income families and individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaacd8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaacd8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d) of this section, each State that receives a grant under this section with respect to an area shall use the grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for services directed only at the goals set forth in paragraphs (1), (2), and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397"},"text":"section 1397 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the strategic plan for the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for activities that benefit residents of the area for which the grant is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use a portion of any grant made under this section in the manner described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397a/e"},"text":"section 1397a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaacd91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remittance of certain amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaacd92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of grant upon termination of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State to which an amount is paid under this subsection during a fiscal year with respect to an area the designation of which under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986 ends before the end of the fiscal year shall remit to the Secretary an amount equal to the total of the amounts so paid with respect to the area, multiplied by that proportion of the fiscal year remaining after the designation ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts paid to the States and not obligated within 2 years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall remit to the Secretary any amount paid to the State under this section that is not obligated by the end of the 2-year period that begins with the date of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaacd94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation of remaining funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaacd95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remitted amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b/c"},"text":"section 1397b(c) of this title","children":[],"tail":" for any fiscal year is hereby increased by the total of the amounts remitted during the fiscal year pursuant to subsection (d) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts not paid to the States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397b/c"},"text":"section 1397b(c) of this title","children":[],"tail":" for fiscal year 1998 is hereby increased by the amount made available for grants under this section that has not been paid to any State by the end of fiscal year 1997."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaacd97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaacd98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified empowerment zone","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified empowerment zone” means, with respect to a State, an area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has been designated (other than by the Secretary of the Interior) as an empowerment zone under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the designation is in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic plan for which is a qualified plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part or all of which is in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacd9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified enterprise community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified enterprise community” means, with respect to a State, an area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacd9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has been designated (other than by the Secretary of the Interior) as an enterprise community under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacd9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the designation is in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacda0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic plan for which is a qualified plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacda1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part or all of which is in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacda2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “strategic plan” means, with respect to an area, the plan contained in the application for designation of the area under part I of subchapter U of chapter 1 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacda3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified plan” means, with respect to an area, a plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaacda4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a detailed description of the activities proposed for the area that are to be funded with amounts provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacda5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a commitment that the amounts provided under this section to any State for the area will not be used to supplant Federal or non-Federal funds for services and activities which promote the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacda6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was developed in cooperation with the local government or governments with jurisdiction over the area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaacda7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that any State will not use the amounts provided under this section for the area in the manner described in subsection (b), explains the reasons why not.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacda8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” has the meaning given such term in section 1393(a)(2) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaacda9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397f/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “urban area” has the meaning given such term in section 1393(a)(3) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaacdaa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2007, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXIII/s13761"},"text":"Pub. L. 103–66, title XIII, § 13761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/664"},"text":"107 Stat. 664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s263"},"text":"Pub. L. 103–432, title II, § 263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4467"},"text":"108 Stat. 4467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaaacdab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaaacdac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaaacdad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsecs. (a)(3), (d)(1), and (f), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbaaacdae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1397f, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tXX/s2007"}