":"idbaaacdaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432"},"text":"Pub. L. 103–432","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
