{"tag":"section","attrib":{"id":"idc00d21da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341"},"text":null,"children":[{"tag":"num","attrib":{"value":"16341"},"text":"§ 16341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western Hemisphere energy cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to promote cooperation on energy issues with countries of the Western Hemisphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall fund activities to work with countries of the Western Hemisphere to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the production of energy supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development and transfer of energy supply and efficiency technologies that would have a beneficial impact on world energy markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by institutions of higher education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the Secretary shall carry out the program under this section with the participation of institutions of higher education so as to take advantage of the acceptance of institutions of higher education by countries of the Western Hemisphere as sources of unbiased technical and policy expertise when assisting the Secretary in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating new technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving technical issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with those countries in the development of new policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training policymakers, particularly in the case of institutions of higher education that involve the participation of minority students, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d21e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part B institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16341/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $16,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s985"},"text":"Pub. L. 109–58, title IX, § 985","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/908"},"text":"119 Stat. 908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
