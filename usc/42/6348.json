{"tag":"section","attrib":{"id":"idbd9c4819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348"},"text":null,"children":[{"tag":"num","attrib":{"value":"6348"},"text":"§ 6348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency in industrial facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd9c481a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c481b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to industry associations to support programs to improve energy efficiency in industry. In order to be eligible for a grant under this subsection, an industry association shall establish a voluntary energy efficiency improvement target program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c481c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall request project proposals and provide annual grants on a competitive basis. In evaluating grant proposals under this subsection, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c481d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential energy savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c481e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential environmental benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c481f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of cost sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which new and innovative technologies will be encouraged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of industry involvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated project cost-effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which progress toward the energy improvement targets can be monitored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects eligible for grants under this subsection may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c4825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workshops.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training seminars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Handbooks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Newsletters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c482a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c482b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this subsection shall not exceed $250,000 and each grant shall not exceed 75 percent of the total cost of the project for which the grant is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c482c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c482d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an annual award program to recognize those industry associations or individual industrial companies that have significantly improved their energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c482e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on industrial reporting and voluntary targets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall, in consultation with affected industries, evaluate and report to the Congress regarding the establishment of Federally mandated energy efficiency reporting requirements and voluntary energy efficiency improvement targets for energy intensive industries. Such report shall include an evaluation of the costs and benefits of such reporting requirements and voluntary energy efficiency improvement targets, and recommendations regarding the role of such activities in improving energy efficiency in energy intensive industries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9c482f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s131"},"text":"Pub. L. 102–486, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2836"},"text":"106 Stat. 2836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9c4830-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd9c4831-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd9c4832-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Energy Policy and Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
