{"tag":"section","attrib":{"id":"idb4a6950b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–7"},"text":"§ 247b–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a6950c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a6950d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may carry out a program of entering into contracts with appropriately qualified health professionals under which such health professionals agree to conduct prevention activities or preparedness and response activities, including rapid response to public health emergencies and significant public health threats, as employees of the Centers for Disease Control and Prevention and the Agency for Toxic Substances and Disease Registry, in consideration of the Federal Government agreeing to repay, for each year of such service, not more than $50,000 of the principal and interest of the educational loans of such health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8defe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into an agreement with a health professional pursuant to paragraph (1) unless such professional—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a8deff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a substantial amount of educational loans relative to income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to serve as an employee of the Centers for Disease Control and Prevention or the Agency for Toxic Substances and Disease Registry for purposes of paragraph (1) for a period of not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the National Health Service Corps Loan Repayment Program established in subpart III of part D of this subchapter, the provisions of such subpart shall, except as inconsistent with subsection (a), apply to the program established in this section in the same manner and to the same extent as such provisions apply to the National Health Service Corps Loan Repayment Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, except as described in paragraph (2), there are authorized to be appropriated $500,000 for fiscal year 1994, and such sums as may be necessary for each of the fiscal years 1995 through 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Epidemic Intelligence Service program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section with respect to qualified health professionals serving in the Epidemic Intelligence Service, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b–8"},"text":"section 247b–8 of this title","children":[],"tail":", there is authorized to be appropriated $1,000,000 for each of fiscal years 2019 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated for a fiscal year for contracts under subsection (a) shall remain available until the expiration of the second fiscal year beginning after the fiscal year for which the amounts were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a8df06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVII/s703"},"text":"Pub. L. 103–183, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2240"},"text":"107 Stat. 2240","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s406"},"text":"Pub. L. 105–392, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3588"},"text":"112 Stat. 3588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tIII/s301/c"},"text":"Pub. L. 116–22, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/932"},"text":"133 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4a8df07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4a8df08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4a8df09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s301/c/1/A"},"text":"Pub. L. 116–22, § 301(c)(1)(A)","children":[],"tail":", inserted “or preparedness and response activities, including rapid response to public health emergencies and significant public health threats” after “conduct prevention activities” and substituted “$50,000” for “$35,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s301/c/1/B"},"text":"Pub. L. 116–22, § 301(c)(1)(B)","children":[],"tail":", substituted “2 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s301/c/2"},"text":"Pub. L. 116–22, § 301(c)(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “For the purpose of carrying out this section, except as described in paragraph (2)” for “For the purpose of carrying out this section”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s406/1"},"text":"Pub. L. 105–392, § 406(1)","children":[],"tail":", substituted “$35,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s406/2"},"text":"Pub. L. 105–392, § 406(2)","children":[],"tail":", substituted “2002” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s406/3"},"text":"Pub. L. 105–392, § 406(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
