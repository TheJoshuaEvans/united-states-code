{"tag":"section","attrib":{"id":"idb524ec5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"274i–2"},"text":"§ 274i–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design and production of medal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb524ec5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this section, the Secretary of the Treasury shall design and strike the Stephanie Tubbs Jones Gift of Life Medals, each of which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb524ec5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weigh 250 grams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524ec5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a diameter of 3 inches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524ec5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of bronze.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524ec60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb524ec61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The design of the medals shall commemorate the compassion and courage manifested by and the sacrifices made by organ donors and their families, and the medals shall bear suitable emblems, devices, and inscriptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524ec62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The design of medals struck under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb524ec63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected by the Secretary of the Treasury, in consultation with the Secretary of Health and Human Services, the Organ Procurement and Transplantation Network, interested members of the family of Stephanie Tubbs Jones, Dr. William H. Frist, and the Commission of Fine Arts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb524ec64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewed by the Citizens Coin Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524ec65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The medals struck pursuant to this section are national medals for purposes of chapter 51 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524ec66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Striking and delivery of minimum-sized lots","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall strike and deliver to the Secretary of Health and Human Services no fewer than 100 medals at any time pursuant to an order by such Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524ec67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of medals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Medals struck under this section and sold to the Secretary of Health and Human Services for distribution in accordance with this part shall be sold to the Secretary of Health and Human Services at a price sufficient to cover the cost of designing and striking the medals, including labor, materials, dies, use of machinery, and overhead expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524ec68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No expenditures in advance of receipt of fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb524ec69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall not strike or distribute any medals under this part until such time as the Secretary of Health and Human Services certifies that sufficient funds have been received by such Secretary to cover the cost of the medals ordered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524ec6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274i–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design in advance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary of the Treasury may begin designing the medal at any time after ","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"October 14, 2008","children":[],"tail":", and take such other action as may be necessary to be prepared to strike such medals upon receiving the certification described in such paragraph, including preparing dies and striking test pieces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb524ec6b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/413/s4"},"text":"Pub. L. 110–413, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4339"},"text":"122 Stat. 4339","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
