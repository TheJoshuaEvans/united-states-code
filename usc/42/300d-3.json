{"tag":"section","attrib":{"id":"idb6136b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–3"},"text":"§ 300d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to improve trauma care in rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6136b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to eligible entities for the purpose of carrying out research and demonstration projects to support the improvement of emergency medical services and trauma care in rural areas through the development of innovative uses of technology, training and education, transportation of seriously injured patients for the purposes of receiving such emergency medical services, access to prehospital care, evaluation of protocols for the purposes of improvement of outcomes and dissemination of any related best practices, activities to facilitate clinical research, as applicable and appropriate, and increasing communication and coordination with applicable State or Tribal trauma systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6136b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be a public or private entity that provides trauma care in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6136b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to eligible entities that will provide services under the grant in any rural area identified by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–14/d/1"},"text":"section 300d–14(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless an application for the grant is submitted to the Secretary and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6136b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives a grant under this section shall submit to the Secretary such reports as the Secretary may require to inform administration of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6136b9e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1202, formerly § 1204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2918"},"text":"104 Stat. 2918","children":[],"tail":"; renumbered § 1203 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVI/s601/b/2"},"text":"Pub. L. 103–183, title VI, § 601(b)(2)","children":[],"tail":", (f)(1), "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2238"},"text":"107 Stat. 2238","children":[],"tail":", 2239; "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s401/a/1"},"text":"Pub. L. 105–392, title IV, § 401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3587"},"text":"112 Stat. 3587","children":[],"tail":"; renumbered § 1202 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/23"},"text":"Pub. L. 110–23","children":[],"tail":", §§ 3(2), 4, "},{"tag":"date","attrib":{"date":"2007-05-03"},"text":"May 3, 2007","children":[],"tail":", "},{"tag":"ref","