{"tag":"section","attrib":{"id":"idc00f6b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371"},"text":null,"children":[{"tag":"num","attrib":{"value":"16371"},"text":"§ 16371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CIFIA program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “CIFIA program” means the carbon dioxide transportation infrastructure finance and innovation program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372/a"},"text":"section 16372(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common carrier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “common carrier” means a transportation infrastructure operator or owner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishes a publicly available tariff containing the just and reasonable rates, terms, and conditions of nondiscriminatory service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds itself out to provide transportation services to the public for a fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent commitment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contingent commitment” means a commitment to obligate funds from future available budget authority that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingent on those funds being made available in law at a future date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not an obligation of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible project costs” means amounts substantially all of which are paid by, or for the account of, an obligor in connection with a project, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the cost of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development-phase activities, including planning, feasibility analysis, revenue forecasting, environmental review, permitting, preliminary engineering and design work, and other preconstruction activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, reconstruction, rehabilitation, replacement, and acquisition of real property (including land relating to the project and improvements to land), environmental mitigation, construction contingencies, and acquisition and installation of equipment (including labor); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capitalized interest necessary to meet market requirements, reasonably required reserve funds, capital issuance expenses, and other carrying costs during construction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transaction costs associated with financing the project, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of legal counsel and technical consultants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsidy amount paid in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372/c/3/B/ii"},"text":"section 16372(c)(3)(B)(ii) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16373/b/6/B/ii"},"text":"section 16373(b)(6)(B)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal credit instrument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal credit instrument” means a secured loan or loan guarantee authorized to be provided under the CIFIA program with respect to a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lender” means a qualified institutional buyer (as defined in section 230.144A(a) of title 17, Code of Federal Regulations (or a successor regulation), commonly known as Rule 144A(a) of the Securities and Exchange Commission and issued under the Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.)), that is not a Federal qualified institutional buyer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Letter of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “letter of interest” means a letter submitted by a potential applicant prior to an application for credit assistance in a format prescribed by the Secretary on the website of the CIFIA program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the project and the location, purpose, and cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the proposed financial plan, including the requested credit and grant assistance and the proposed obligor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a status of environmental review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information regarding satisfaction of other eligibility requirements of the CIFIA program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan guarantee” means any guarantee or other pledge by the Secretary to pay all or part of the principal of, and interest on, a loan made to an obligor, or debt obligation issued by an obligor, in each case funded by a lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master credit agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “master credit agreement” means a conditional agreement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is for the purpose of extending credit assistance for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6ba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project of high priority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372/c/3/A"},"text":"section 16372(c)(3)(A) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16372/c/3/B"},"text":"section 16372(c)(3)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not provide for a current obligation of Federal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make a contingent commitment of a Federal credit instrument or grant at a future date, subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of future funds being made available to carry out the CIFIA program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the satisfaction of all conditions for the provision of credit assistance under the CIFIA program, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16373/b"},"text":"section 16373(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the maximum amounts and general terms and conditions of the Federal credit instruments or grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the 1 or more revenue sources that will secure the repayment of the Federal credit instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for the obligation of funds for the Federal credit instruments or grants after all requirements have been met for the projects subject to the agreement, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with all applicable requirements specified under the CIFIA program, including sections 16372(d) and 16373(b)(1) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of funds to carry out the CIFIA program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/9/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that contingent commitments shall result in a financial close and obligation of credit or grant assistance by not later than 4 years after the date of entry into the agreement or release of the commitment, as applicable, unless otherwise extended by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligor” means a corporation, partnership, joint venture, trust, non-Federal governmental entity, agency, or instrumentality, or other entity that is liable for payment of the principal of, or interest on, a Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Produced in the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “produced in the United States”, with respect to iron and steel, means that all manufacturing processes for the iron and steel, including the application of any coating, occurs within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a project for common carrier carbon dioxide transportation infrastructure or associated equipment, including pipeline, shipping, rail, or other transportation infrastructure and associated equipment, that will transport or handle carbon dioxide captured from anthropogenic sources or ambient air, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project obligation” means any note, bond, debenture, or other debt obligation issued by an obligor in connection with the financing of a project, other than a Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secured loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “secured loan” means a direct loan to an obligor or a debt obligation issued by an obligor and purchased by the Secretary, in each case funded by the Secretary in connection with the financing of a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16373"},"text":"section 16373 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidy amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “subsidy amount” means the amount of budget authority sufficient to cover the estimated long-term cost to the Federal Government of a Federal credit instrument—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculated on a net present value basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluding administrative costs and any incidental effects on governmental receipts or outlays in accordance with the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial completion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “substantial completion”, with respect to a project, means the date—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which the project commences transportation of carbon dioxide; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16371/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a comparable event to the event described in subparagraph (A), as determined by the Secretary and specified in the project credit agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6bbc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999A"},"text":"Pub. L. 109–58, title IX, § 999A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40304/a"},"text":"Pub. L. 117–58, div. D, title III, § 40304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/988"},"text":"135 Stat. 988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6bbd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6bbe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00f6bbf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in par. (6), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in par. (15)(B), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc00f6bc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 16371, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999A"},"text":"Pub. L. 109–58, title IX, § 999A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/916"},"text":"119 Stat. 916","children":[],"tail":", authorized the Secretary of Energy to carry out a program of research, development, demonstration, and commercial application of technologies for ultra-deepwater and unconventional natural gas and other petroleum resources, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tIII/s301/a"},"text":"Pub. L. 113–67, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1181"},"text":"127 Stat. 1181","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc00f6bc1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc00f6bc2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
