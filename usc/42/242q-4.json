{"tag":"section","attrib":{"id":"idb495cbd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"242q–4"},"text":"§ 242q–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 242q to 242q–5 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb495cbd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging research","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb495cbd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “aging research” means research on the aging process and on the diagnosis and treatment of diseases, disorders, and complications related to aging, including menopause. Such research includes research on such treatments, and on medical devices and other medical interventions regarding such diseases, disorders, and complications, that can assist individuals in avoiding institutionalization and prolonged hospitalization and in otherwise increasing the independence of the individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb495cbd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subparagraph (A), the term “independence”, with respect to diseases, disorders, and complications of aging, means the functional ability of individuals to perform activities of daily living or instrumental activities of daily living without assistance or supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–4/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Task Force” means the Task Force on Aging Research established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242q/a"},"text":"section 242q(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb495cbd9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIII/s304"},"text":"Pub. L. 101–557, title III, § 304","children":[],"tail":", formerly § 305, "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2770"},"text":"104 Stat. 2770","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/3/B"},"text":"Pub. L. 109–482, title I, § 104(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3694"},"text":"120 Stat. 3694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cbda-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cbdb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cbdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Home Health Care and Alzheimer’s Disease Amendments of 1990, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb495cbdd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s304"},"text":"section 304 of Pub. L. 101–557","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242q–3"},"text":"section 242q–3 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
