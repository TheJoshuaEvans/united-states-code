{"tag":"section","attrib":{"id":"idbd9c4833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349"},"text":null,"children":[{"tag":"num","attrib":{"value":"6349"},"text":"§ 6349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process-oriented industrial energy efficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd9c4834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c4835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered industry” means the food and food products industry, lumber and wood products industry, petroleum and coal products industry, and all other manufacturing industries specified in Standard Industrial Classification Codes 20 through 39 (or successor classification codes);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “process-oriented industrial assessment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c4837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification of opportunities in the production process (from the introduction of materials to final packaging of the product for shipping) for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd9c4838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c4839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing environmental impact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c483a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing technological improvements to increase competitiveness and achieve cost-effective product quality enhancement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c483b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of opportunities for improving the energy efficiency of lighting, heating, ventilation, air conditioning, and the associated building envelope; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c483c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of cost-effective opportunities for using renewable energy technology in the production process and in the systems described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c483d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “utility” means any person, State agency (including any municipality), or Federal agency, which sells electric or gas energy to retail customers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c483e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c483f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the extent funds are made available for such purpose, make grants to States which, consistent with State law, shall be used for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c4840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote, through appropriate institutions such as universities, nonprofit organizations, State and local government entities, technical centers, utilities, and trade organizations, the use of energy-efficient technologies in covered industries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish programs to train individuals (on an industry-by-industry basis) in conducting process-oriented industrial assessments and to encourage the use of such trained assessors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist utilities in developing, testing, and evaluating energy efficiency programs and technologies for industrial customers in covered industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States receiving grants under this subsection shall consult with utilities and representatives of affected industries, as appropriate, in determining the most effective use of such funds consistent with the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall establish eligibility criteria for grants made pursuant to this subsection. Such criteria shall require a State applying for a grant to demonstrate that such State—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c4845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2621/a"},"text":"section 2621(a) of title 16","children":[],"tail":", has considered and made a determination regarding the implementation of the standards specified in paragraphs (7) and (8) of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s2621/d"},"text":"section 2621(d) of title 16","children":[],"tail":" (with respect to integrated resources planning and investments in conservation and demand management); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c4846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by legislation or regulation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd9c4847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows utilities to recover the costs prudently incurred in providing process-oriented industrial assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd9c4848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourages utilities to provide to covered industries—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd9c4849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process-oriented industrial assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd9c484a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial incentives for implementing energy efficiency improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c484b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made pursuant to this subsection shall be allocated each fiscal year among States meeting the criteria specified in paragraph (3) who have submitted applications 60 days before the first day of such fiscal year. Such allocation shall be made in accordance with a formula to be prescribed by the Secretary based on each State’s share of value added in industry (as determined by the Census of Manufacturers) as a percentage of the value added by all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c484c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this subsection may continue to be renewed after 2 consecutive fiscal years during which a State receives a grant under this subsection, subject to the availability of funds, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9c484d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the funds made available to the State during the previous 2 years were used in a manner required under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9c484e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State demonstrates, in a manner prescribed by the Secretary, utility participation in programs established pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c484f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the functions described in paragraph (1), States shall, to the extent practicable, coordinate such functions with activities and programs conducted by the Energy Analysis and Diagnostic Centers of the Department of Energy and the Manufacturing Technology Centers of the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c4850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9c4851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall, by contract with nonprofit organizations with expertise in process-oriented industrial energy efficiency technologies, establish and, as appropriate, update criteria for conducting process-oriented industrial assessments on an industry-by-industry basis. Such criteria shall be made available to State and local government, public utility commissions, utilities, representatives of affected process-oriented industries, and other interested parties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a nationwide directory of organizations offering industrial energy efficiency assessments, technologies, and services consistent with the purposes of this section. Such directory shall be made available to State governments, public utility commissions, utilities, industry representatives, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an annual award program to recognize utilities operating outstanding or innovative industrial energy efficiency technology assistance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9c4854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to further the purposes of this section, the Secretary shall convene annual meetings of parties interested in process-oriented industrial assessments, including representatives of State government, public utility commissions, utilities, and affected process-oriented industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9c4855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6349/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9c4856-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s132"},"text":"Pub. L. 102–486, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2837"},"text":"106 Stat. 2837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1052/a/1"},"text":"Pub. L. 104–66, title I, § 1052(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/717"},"text":"109 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tIV/s401/d"},"text":"Pub. L. 105–362, title IV, § 401(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3282"},"text":"112 Stat. 3282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9c4857-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd9c4858-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd9c4859-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Energy Policy and Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd9c485a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" redesignated subsec. (e) as (d) and struck out heading and text of former subsec. (d) which related to reports to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" substituted “Not later than "},{"tag":"date","attrib":{"date":"1995-10-24"},"text":"October 24, 1995","children":[],"tail":", and biennially thereafter” for “Not later than 2 years after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", and annually thereafter” in introductory provisions and added par. (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
