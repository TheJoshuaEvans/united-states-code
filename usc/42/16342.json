{"tag":"section","attrib":{"id":"idc00d21ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342"},"text":null,"children":[{"tag":"num","attrib":{"value":"16342"},"text":"§ 16342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International energy training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Commerce, the Secretary of the Interior, and Secretary of State, and the Federal Energy Regulatory Commission, shall coordinate training and outreach efforts for international commercial energy markets in countries with developing and restructuring economies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training and outreach efforts referred to in subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production-related fiscal regimes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grid and network issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy user and demand side response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international trade of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international transportation of energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,500,000 for each of fiscal years 2007 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s986A"},"text":"Pub. L. 109–58, title IX, § 986A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/910"},"text":"119 Stat. 910","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
