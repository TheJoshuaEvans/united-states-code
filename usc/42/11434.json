{"tag":"section","attrib":{"id":"idbf50afbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434"},"text":null,"children":[{"tag":"num","attrib":{"value":"11434"},"text":"§ 11434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf50afbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing the State plan submitted by a State educational agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11432/g"},"text":"section 11432(g) of this title","children":[],"tail":", the Secretary shall use a peer review process and shall evaluate whether State laws, policies, and practices described in such plan adequately address the problems of homeless children and youths relating to access to education and placement as described in such plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide support and technical assistance to a State educational agency to assist such agency in carrying out its responsibilities under this part, if requested by the State educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf50afc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, before the next school year that begins after ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", update and disseminate nationwide the public notice described in this subsection (as in effect prior to such date) of the educational rights of homeless children and youths."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall disseminate the notice nationwide to all Federal agencies, and grant recipients, serving homeless families or homeless children and youths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation, dissemination, and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct evaluation, dissemination, and technical assistance activities for programs designed to meet the educational needs of homeless elementary and secondary school students, and may use funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11435"},"text":"section 11435 of this title","children":[],"tail":" to conduct such activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require applications for grants under this part to be submitted to the Secretary not later than the expiration of the 120-day period beginning on the date that funds are available for purposes of making such grants and shall make such grants not later than the expiration of the 180-day period beginning on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, based on the information received from the States and information gathered by the Secretary under subsection (h), shall determine the extent to which State educational agencies are ensuring that each homeless child and homeless youth has access to a free appropriate public education, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431/1"},"text":"section 11431(1) of this title","children":[],"tail":". The Secretary shall provide support and technical assistance to State educational agencies, concerning areas in which documented barriers to a free appropriate public education persist."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop, issue, and publish in the Federal Register, not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", guidelines concerning ways in which a State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf50afc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may assist local educational agencies to implement the provisions related to homeless children and youths amended by that Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may review and revise State policies and procedures that may present barriers to the identification of homeless children and youths, and the enrollment, attendance, and success of homeless children and youths in school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf50afcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11435"},"text":"section 11435 of this title","children":[],"tail":", the Secretary shall, directly or through grants, contracts, or cooperative agreements, periodically collect and disseminate data and information regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf50afcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and primary nighttime residence of homeless children and youths in all areas served by local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf50afcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education and related services such children and youths receive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf50afce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the needs of homeless children and youths are being met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf50afcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other data and information as the Secretary determines to be necessary and relevant to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate such collection and dissemination with other agencies and entities that receive assistance and administer programs under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf50afd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":", the Secretary shall prepare and submit to the President and the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report on the status of education of homeless children and youths, which shall include information on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf50afd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the education of homeless children and youths; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf50afd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11434/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions of the Secretary and the effectiveness of the programs supported under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf50afd4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s724"},"text":"Pub. L. 100–77, title VII, § 724","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1032"},"text":"Pub. L. 107–110, title X, § 1032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2004"},"text":"115 Stat. 2004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9104"},"text":"Pub. L. 114–95, title IX, § 9104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2136"},"text":"129 Stat. 2136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf50afd5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf50afd6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf50afd7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"That Act, referred to in subsec. (g)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1802"},"text":"129 Stat. 1802","children":[],"tail":", known as The Every Student Succeeds Act. For complete classification of this Act to the Code, see Short Title of 2015 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf50afd8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11434, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s724"},"text":"Pub. L. 100–77, title VII, § 724","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s323"},"text":"Pub. L. 103–382, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3964"},"text":"108 Stat. 3964","children":[],"tail":", related to Secretarial responsibilities, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 11434, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVII/s724"},"text":"Pub. L. 100–77, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/528"},"text":"101 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tVI/s612/d"},"text":"Pub. L. 101–645, title VI, § 612(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4742"},"text":"104 Stat. 4742","children":[],"tail":", related to national responsibilities, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf50afd9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/1"},"text":"Pub. L. 114–95, § 9104(1)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The Secretary shall, before the next school year that begins after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", create and disseminate nationwide a public notice of the educational rights of homeless children and youths and disseminate such notice to other Federal agencies, programs, and grantees, including Head Start grantees, Health Care for the Homeless grantees, Emergency Food and Shelter grantees, and homeless assistance programs administered by the Department of Housing and Urban Development.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/2"},"text":"Pub. L. 114–95, § 9104(2)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The Secretary shall conduct evaluation and dissemination activities of programs designed to meet the educational needs of homeless elementary and secondary school students, and may use funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11435"},"text":"section 11435 of this title","children":[],"tail":" to conduct such activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/3"},"text":"Pub. L. 114–95, § 9104(3)","children":[],"tail":", substituted “120-day” for “60-day” and “180-day” for “120-day”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/4"},"text":"Pub. L. 114–95, § 9104(4)","children":[],"tail":", inserted at end “The Secretary shall provide support and technical assistance to State educational agencies, concerning areas in which documented barriers to a free appropriate public education persist.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/5"},"text":"Pub. L. 114–95, § 9104(5)","children":[],"tail":", added subsec. (g) and struck out former subsec. (g). Prior to amendment, text read as follows: “The Secretary shall develop, issue, and publish in the Federal Register, not later than 60 days after "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":", school enrollment guidelines for States with respect to homeless children and youths. The guidelines shall describe—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) successful ways in which a State may assist local educational agencies to immediately enroll homeless children and youths in school; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) how a State can review the State’s requirements regarding immunization and medical or school records and make such revisions to the requirements as are appropriate and necessary in order to enroll homeless children and youths in school immediately.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/6"},"text":"Pub. L. 114–95, § 9104(6)","children":[],"tail":", substituted “primary nighttime residence” for “location” and inserted before semicolon at end “in all areas served by local educational agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9104/7"},"text":"Pub. L. 114–95, § 9104(7)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"December 10, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"January 8, 2002","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf50afda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf50afdb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2016-10-01"},"text":"Oct. 1, 2016","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s9107"},"text":"section 9107 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"section 11431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf50afdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
