{"tag":"section","attrib":{"id":"idbd310328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205"},"text":null,"children":[{"tag":"num","attrib":{"value":"5205"},"text":"§ 5205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster grant closeout procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd310329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd31032a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716/e"},"text":"section 3716(e) of title 31","children":[],"tail":" and except as provided in paragraph (2), no administrative action to recover any payment made to a State or local government for disaster or emergency assistance under this chapter shall be initiated in any forum after the date that is 3 years after the date of transmission of the final expenditure report for project completion as certified by the grantee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd31032b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under paragraph (1) shall apply unless there is evidence of civil or criminal fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd31032c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebuttal of presumption of record maintenance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd31032d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any dispute arising under this section after the date that is 3 years after the date of transmission of the final expenditure report for project completion as certified by the grantee, there shall be a presumption that accounting records were maintained that adequately identify the source and application of funds provided for financially assisted activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd31032e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmative evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The presumption described in paragraph (1) may be rebutted only on production of affirmative evidence that the State or local government did not maintain documentation described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd31032f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inability to produce documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inability of the Federal, State, or local government to produce source documentation supporting expenditure reports later than 3 years after the date of transmission of the final expenditure report for project completion as certified by the grantee shall not constitute evidence to rebut the presumption described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period during which the Federal, State, or local government has the right to access source documentation shall not be limited to the required 3-year retention period referred to in paragraph (3), but shall last as long as the records are maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd310331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding nature of grant requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or local government shall not be liable for reimbursement or any other penalty for any payment made under this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd310332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment was authorized by an approved agreement specifying the costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs were reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the grant was accomplished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd310335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitating closeout","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd310336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency may develop incentives and penalties that encourage State, local, or Indian tribal governments to close out expenditures and activities on a timely basis related to disaster or emergency assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd310337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Emergency Management Agency shall, consistent with applicable regulations and required procedures, meet its responsibilities to improve closeout practices and reduce the time to close disaster program awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd310338-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVII/s705"},"text":"Pub. L. 93–288, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tIII/s304"},"text":"Pub. L. 106–390, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1573"},"text":"114 Stat. 1573","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD"},"text":"Pub. L. 115–254, div. D","children":[],"tail":", §§ 1216(c)(1), 1221(a), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3451"},"text":"132 Stat. 3451","children":[],"tail":", 3453.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd310339-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd31033a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd31033b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd31033c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1216/c/1/A"},"text":"Pub. L. 115–254, § 1216(c)(1)(A)","children":[],"tail":", substituted “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716/e"},"text":"section 3716(e) of title 31","children":[],"tail":" and except” for “Except” and “report for project completion as certified by the grantee” for “report for the disaster or emergency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1216/c/1/B/i"},"text":"Pub. L. 115–254, § 1216(c)(1)(B)(i)","children":[],"tail":", substituted “report for project completion as certified by the grantee” for “report for the disaster or emergency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1216/c/1/B/ii"},"text":"Pub. L. 115–254, § 1216(c)(1)(B)(ii)","children":[],"tail":", inserted “for project completion as certified by the grantee” after “final expenditure report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1221/a"},"text":"Pub. L. 115–254, § 1221(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd31033d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd31033e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd31033f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1221/b"},"text":"Pub. L. 115–254, div. D, § 1221(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3454"},"text":"132 Stat. 3454","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dD/s1221/b"},"text":"“The Administrator [of the Federal Emergency Management Agency] shall issue regulations to implement the amendment made by this section [amending this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
