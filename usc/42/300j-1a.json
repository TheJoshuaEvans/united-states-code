{"tag":"section","attrib":{"id":"idb63c01ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–1a"},"text":"§ 300j–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative water technology grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb63c01f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63c01f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63c01f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63c01f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public water system (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f/4"},"text":"section 300f(4) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63c01f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63c01f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a research institution or foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63c01f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional water organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63c01f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–1/e/8"},"text":"section 300j–1(e)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63c01f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out a grant program for the purpose of accelerating the development and deployment of innovative water technologies that address pressing drinking water supply, quality, treatment, or security challenges of public water systems, areas served by private wells, or source waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63c01f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (b), the Administrator shall make grants to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63c01fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, test, and deploy innovative water technologies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63c01fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to deploy demonstrated innovative water technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63c01fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63c01fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants through a competitive process to eligible entities the Administrator determines are best able to carry out the purpose of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63c01fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority to projects that have the potential—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63e4bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce ratepayer or community costs or costs of future capital investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63e4bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to significantly improve human health or the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63e4bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide additional drinking water supplies with minimal environmental impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of activities carried out using a grant under this section shall be not more than 65 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of a grant under this section shall be $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each year, the Administrator shall submit to Congress and make publicly available on the website of the Administrator a report that describes any advancements during the previous year in development of innovative water technologies made as a result of funding provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this program may include projects that are carried out by an eligible entity in cooperation with a private entity, including a farmer, farmer cooperative, or manufacturer of water technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63e4bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–1a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 and 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb63e4bf7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2007"},"text":"Pub. L. 115–270, title II, § 2007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3845"},"text":"132 Stat. 3845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb63e4bf8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb63e4bf9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb63e4bfa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America’s Water Infrastructure Act of 2018, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
