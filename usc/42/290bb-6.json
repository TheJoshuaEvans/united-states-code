{"tag":"section","attrib":{"id":"idb5a36b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–6"},"text":"§ 290bb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Center for Substance Abuse Treatment and States concerning military facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a36b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Substance Abuse Treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Center for Substance Abuse Treatment shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a36b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the agencies represented on the Commission on Alternative Utilization of Military Facilities the utilization of military facilities or parts thereof, as identified by such Commission, established under the National Defense Authorization Act of 1989, that could be utilized or renovated to house nonviolent persons for drug treatment purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify State agencies responsible for the oversight of drug abuse treatment entities and programs of the availability of space at the installations identified in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a36b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State agencies responsible for the oversight of drug abuse treatment entities and programs in developing methods for adapting the installations described in paragraph (1) into residential treatment centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a36b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With regard to military facilities or parts thereof, as identified by the Commission on Alternative Utilization of Military Facilities established under section 3042 of the Comprehensive Alcohol Abuse, Drug Abuse, and Mental Health Amendments Act of 1988,","children":[{"tag":"ref","attrib":{"idref":"fn002224"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002224"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" that could be utilized or renovated to house nonviolent persons for drug treatment purposes, State agencies responsible for the oversight of drug abuse treatment entities and programs shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a5b55e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish eligibility criteria for the treatment of individuals at such facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b55f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select treatment providers to provide drug abuse treatment at such facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to treatment providers selected under paragraph (2) to assist such providers in securing financing to fund the cost of the programs at such facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a5b561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, regulate, and coordinate with the military official in charge of the facility, work programs for individuals receiving treatment at such facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a5b562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of space","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to notifying States of the availability of space at military facilities under subsection (a)(2), the Director may reserve space at such facilities to conduct research or demonstration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a5b563-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 513, formerly § 561, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2081/a"},"text":"Pub. L. 100–690, title II, § 2081(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4215"},"text":"102 Stat. 4215","children":[],"tail":"; renumbered § 513 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s112/a"},"text":"Pub. L. 102–321, title I, § 112(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/344"},"text":"106 Stat. 344","children":[],"tail":", 345.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a5b564-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a5b565-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5a5b566-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Defense Authorization Act of 1989, referred to in subsec. (a)(1), probably means the National Defense Authorization Act, Fiscal Year 1989, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1918"},"text":"102 Stat. 1918","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3042 of the Comprehensive Alcohol Abuse, Drug Abuse, and Mental Health Amendments Act of 1988, referred to in subsec. (b), probably should be a reference to section 2819 of the National Defense Authorization Act, Fiscal Year 1989, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dB/tXXVIII"},"text":"Pub. L. 100–456, div. B, title XXVIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2119"},"text":"102 Stat. 2119","children":[],"tail":", which established the Commission on Alternative Utilization of Military Facilities and which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391"},"text":"section 2391 of Title 10","children":[],"tail":", Armed Forces, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1031/b"},"text":"Pub. L. 105–261, div. A, title X, § 1031(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2123"},"text":"112 Stat. 2123","children":[],"tail":". The Comprehensive Alcohol Abuse, Drug Abuse, and Mental Health Amendments Act of 1988 is subtitle A of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4193"},"text":"102 Stat. 4193","children":[],"tail":", and does not contain a section 3042."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a5b567-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ff"},"text":"section 290ff of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5a5b568-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 513 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–2"},"text":"section 290bb–2 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s122/d"},"text":"Pub. L. 102–321, title I, § 122(d)[(e)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/360"},"text":"106 Stat. 360","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 513 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s229b"},"text":"section 229b of this title","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238j"},"text":"section 238j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5a5b569-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s112/b/1"},"text":"Pub. L. 102–321, § 112(b)(1)","children":[],"tail":", substituted provisions relating to Center for Substance Abuse Treatment for provisions relating to National Institute on Drug Abuse in heading and text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5a5b56a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5a5b56b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
