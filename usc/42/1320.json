{"tag":"section","attrib":{"id":"idb8295303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320"},"text":"§ 1320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of certain projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No payment shall be made under this chapter with respect to any experimental, pilot, demonstration, or other project all or any part of which is wholly financed with Federal funds made available under this chapter (without any State, local, or other non-Federal financial participation) unless such project shall have been personally approved by the Secretary or Deputy Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8295304-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1120, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tII/s249"},"text":"Pub. L. 90–248, title II, § 249","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/919"},"text":"81 Stat. 919","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/608/s2/5"},"text":"Pub. L. 93–608, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1971"},"text":"88 Stat. 1971","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s107/a"},"text":"Pub. L. 97–375, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1820"},"text":"