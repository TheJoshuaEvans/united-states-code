{"tag":"section","attrib":{"id":"idbcc82fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c"},"text":null,"children":[{"tag":"num","attrib":{"value":"4361c"},"text":"§ 4361c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcc82fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments for educational programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized to select and appoint up to 75 full-time permanent staff members in the Office of Research and Development to pursue full-time educational programs for the purpose of (A) securing an advanced degree or (B) securing academic training, for the purpose of making a career change in order to better carry out the Agency’s research mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall select and appoint staff members for these assignments according to rules and criteria promulgated by him. The Agency may continue to pay the salary and benefits of the appointees as well as reasonable and appropriate relocation expenses and tuition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of each appointment shall be for up to one year, with a single renewal of up to one year in appropriate cases at the discretion of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Staff members appointed to this program shall not count against any Agency personnel ceiling during the term of their appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-doctoral research fellows","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized to appoint up to 25 Post-doctoral Research Fellows in accordance with the provisions of section 213.3102(aa) of title 5 of the Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons holding these appointments shall not count against any personnel ceiling of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Government research associates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82ff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized and encouraged to utilize research associates from outside the Federal Government in conducting the research, development, and demonstration programs of the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82ff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These persons shall be selected and shall serve according to rules and criteria promulgated by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcc82ff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4361c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Women and minority groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all programs in this section, the Administrator shall place special emphasis on providing opportunities for education and training of women and minority groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82ff4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/477/s6"},"text":"Pub. L. 95–477, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1510"},"text":"92 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc82ff5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc82ff6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcc82ff7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1979, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcc82ff8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcc82ff9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contracts by Office of Research and Development of the Environmental Protection Agency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dK/tIII"},"text":"Pub. L. 108–7, div. K, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/509"},"text":"117 Stat. 509","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dK/tIII"},"text":"“That the Office of Research and Development of the Environmental Protection Agency may hereafter contract directly with individuals or indirectly with institutions or nonprofit organizations, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":" [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"41 U.S.C. 6101","children":[],"tail":"], for the temporary or intermittent personal services of students or recent graduates, who shall be considered employees for the purposes of chapters 57 and 81 of title 5, United States Code, relating to compensation for travel and work injuries, and chapter 171 of title 28, United States Code, relating to tort claims, but shall not be considered to be Federal employees for any other purposes.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
