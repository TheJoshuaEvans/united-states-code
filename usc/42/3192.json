{"tag":"section","attrib":{"id":"idbc7702a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192"},"text":null,"children":[{"tag":"num","attrib":{"value":"3192"},"text":"§ 3192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic development information clearinghouse","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7702aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain a central information clearinghouse on the Internet with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7702ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on economic development, economic adjustment, disaster recovery, defense conversion, and trade adjustment programs and activities of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7702ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" links to State economic development organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7702ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" links to other appropriate economic development resources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist potential and actual applicants for economic development, economic adjustment, disaster recovery, defense conversion, and trade adjustment assistance under Federal and State laws in locating and applying for the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":" and other areas by providing to interested persons, communities, industries, and businesses in the areas any technical information, market research, or other forms of assistance, information, or advice that would be useful in alleviating or preventing conditions of excessive unemployment or underemployment in the areas; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3192/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain appropriate information from other Federal agencies needed to carry out the duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7702b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s502"},"text":"Pub. L. 89–136, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children"