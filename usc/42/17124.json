{"tag":"section","attrib":{"id":"idc029aa6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124"},"text":null,"children":[{"tag":"num","attrib":{"value":"17124"},"text":"§ 17124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Energy Efficiency Finance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aa6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary of Energy for Energy Efficiency and Renewable Energy, shall establish an Advisory Committee on Energy Efficiency Finance to provide advice and recommendations to the Department on energy efficiency finance and investment issues, options, ideas, and trends, and to assist the energy community in identifying practical ways of lowering costs and increasing investments in energy efficiency technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee established under this section shall have a balanced membership that shall include members with expertise in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of seed capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of venture capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of other sources of private equity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment banking with respect to corporate finance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment banking with respect to mergers and acquisitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equity capital markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt capital markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales and trading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial lending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential lending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee on Energy Efficiency Finance shall terminate on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa79-3a7