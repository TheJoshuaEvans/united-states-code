{"tag":"section","attrib":{"id":"idc01696bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456"},"text":null,"children":[{"tag":"num","attrib":{"value":"16456"},"text":"§ 16456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this part, no provision of this part shall apply to, or be deemed to include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01696be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or any political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign governmental authority not operating in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agency, authority, or instrumentality of any entity referred to in paragraph (1), (2), or (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01696c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16456/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer, agent, or employee of any entity referred to in paragraph (1), (2), (3), or (4) acting as such in the course of his or her official duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01696c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1268"},"text":"Pub. L. 109–58, title XII, § 1268","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/976"},"text":"119 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01696c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01696c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc01696c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle”, meaning subtitle F (§§ 1261–1277) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/972"},"text":"119 Stat. 972","children":[],"tail":", which enacted this part, amended sections 824 and 824m of Title 16, Conservation, repealed chapter 2C (§ 79 et seq.) of Title 15, Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s825q"},"text":"section 825q of Title 16","children":[],"tail":", and enacted provisions set out as notes under sections 15801 and 16451 of this title. For complete classification of subtitle F to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
