{"tag":"section","attrib":{"id":"idbc72474e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3123"},"text":null,"children":[{"tag":"num","attrib":{"value":"3123"},"text":"§ 3123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination on basis of sex prohibited in federally assisted programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person in the United States shall, on the ground of sex, be excluded from participation in, be denied the benefits of, or be subjected to discrimination under any program or activity receiving Federal financial assistance under the Public Works and Economic Development Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc72474f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/65/tI/s112"},"text":"Pub. L. 92–65, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-05"},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/168"},"text":"85 Stat. 168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc724750-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc724751-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc724752-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Works and Economic Development Act of 1965, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136"},"text":"Pub. L. 89–136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/552"},"text":"79 Stat. 552","children":[],"tail":", which is classified generally to this chapter (§ 3121 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc724753-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Public Works and Economic Development Act of 1965 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
