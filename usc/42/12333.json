{"tag":"section","attrib":{"id":"idbf6aee19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333"},"text":null,"children":[{"tag":"num","attrib":{"value":"12333"},"text":"§ 12333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall make grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in each State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12337"},"text":"section 12337 of this title","children":[],"tail":" to improve State planning and coordination of services, and under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":" to expand supportive services, in order to promote the availability of developmental, preventive, and remedial services to children, youth and their families that are designed to ensure—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate and safe physical shelter whether in their own homes or, if necessary, in out-of-home programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high quality physical and mental health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of the development of children to ensure that children enter school prepared and ready to learn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highest quality educational opportunity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective training and apprenticeships to increase the likelihood of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for community service and productive employment, and for participation by children and youth in decisions affecting the lives of such children and youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wide range of civic, cultural, and recreational activities that recognize young individuals as resources and promote self-esteem and a sense of community; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to States on a competitive basis under section 12339 ","children":[{"tag":"ref","attrib":{"idref":"fn004041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to establish family resource programs (including family support centers) in order to enhance the ability of families to remain together and to thrive through the provision of community based services that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and build family and parenting skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and assist families in the use of formal and informal family support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a support network to strengthen and reinforce good parenting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12333/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are closely linked with, but not duplicative of, other community resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aee27-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s927"},"text":"Pub. L. 101–501, title IX, § 927","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1269"},"text":"104 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aee28-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aee29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6aee2a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12339"},"text":"Section 12339 of this title","children":[],"tail":", referred to in par. (2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s401/b/1"},"text":"Pub. L. 103–252, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/672"},"text":"108 Stat. 672","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aee2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aee2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
