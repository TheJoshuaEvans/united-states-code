{"tag":"section","attrib":{"id":"idc011dc7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16376"},"text":null,"children":[{"tag":"num","attrib":{"value":"16376"},"text":"§ 16376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local permits","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provision of credit assistance under the CIFIA program with respect to a project shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dc80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16376/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve any recipient of the assistance of any project obligation to obtain any required State or local permit or approval with respect to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dc81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16376/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the right of any unit of State or local government to approve or regulate any rate of return on private equity invested in the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dc82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16376/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise supersede any State or local law (including any regulation) applicable to the construction or operation of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc011dc83-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999F"},"text":"Pub. L. 109–58, title IX, § 999F","children":[],"tail":", as a