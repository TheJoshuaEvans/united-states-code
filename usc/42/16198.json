{"tag":"section","attrib":{"id":"idbffa0e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198"},"text":null,"children":[{"tag":"num","attrib":{"value":"16198"},"text":"§ 16198.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart energy and water efficiency pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a water district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe or Alaska Native village; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other authority that provides water, wastewater, or water reuse services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart energy and water efficiency pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “smart energy and water efficiency pilot program” or “pilot program” means the pilot program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smart energy and water efficiency pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0e60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out a smart energy and water efficiency pilot program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the smart energy and water efficiency pilot program is to award grants to eligible entities to demonstrate unique, advanced, or innovative technology-based solutions that will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the net energy balance of water, wastewater, and water reuse systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the net energy balance of water, wastewater, and water reuse systems to help communities across the United States make measurable progress in conserving water, saving energy, and reducing costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the implementation of innovative and unique processes and the installation of established advanced automated systems that provide real-time data on energy and water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve energy-water conservation and quality and predictive maintenance through technologies that utilize internet connected technologies, including sensors, intelligent gateways, and security embedded in hardware.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make competitive, merit-reviewed grants under the pilot program to not less than 3, but not more than 5, eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting an eligible entity to receive a grant under the pilot program, the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0e69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy and cost savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uniqueness, commercial viability, and reliability of the technology to be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the project integrates next-generation sensors software, analytics, and management tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated cost-effectiveness of the pilot project through measurable energy savings, water savings or reuse, and infrastructure costs averted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the technology can be deployed in a variety of geographic regions and the degree to which the technology can be implemented in a wide range of applications ranging in scale from small towns to large cities, including Tribal communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the technology has been successfully deployed elsewhere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the technology was sourced from a manufacturer based in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project will be completed in 5 years or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), an eligible entity seeking a grant under the pilot program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under clause (i) shall, at a minimum, include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbffa0e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the technology to be used in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated results, including energy and water savings, of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive budget for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of the project lead organization and any partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of users to be served by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the ways in which the proposal would meet performance measures established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/3/C/ii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary determines to be necessary to complete the review and selection of a grant recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0e7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall select grant recipients under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually carry out an evaluation of each project for which a grant is provided under this section that meets performance measures and benchmarks developed by the Secretary, consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the performance measures and benchmarks developed under clause (i), in carrying out an evaluation under that clause, the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbffa0e81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the progress and impact of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffa0e82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the degree to which the project is meeting the goals of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and policy assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of a grant recipient, the Secretary shall provide technical and policy assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make available to the public through the Internet and other means the Secretary considers to be appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0e85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of each evaluation carried out under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0e86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any best practices identified by the Secretary as a result of those evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0e87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress a report containing the results of each evaluation carried out under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16198/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $15,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0e89-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s918"},"text":"Pub. L. 109–58, title IX, § 918","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1014/a"},"text":"Pub. L. 116–260, div. Z, title I, § 1014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2451"},"text":"134 Stat. 2451","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
