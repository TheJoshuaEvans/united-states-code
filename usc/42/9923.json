{"tag":"section","attrib":{"id":"idbf0b8f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923"},"text":null,"children":[{"tag":"num","attrib":{"value":"9923"},"text":"§ 9923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National or regional programs designed to provide instructional activities for low-income youth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf0b8f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make a grant to an eligible service provider to administer national or regional programs to provide instructional activities for low-income youth. In making such a grant, the Secretary shall give priority to eligible service providers that have a demonstrated ability to operate such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any instructional activity carried out by an eligible service provider receiving a grant under this section shall be carried out on the campus of an institution of higher education (as defined in section 1141(a) ","children":[{"tag":"ref","attrib":{"idref":"fn003919"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003919"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 20) and shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to the facilities and resources of such an institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial medical examination and follow-up referral or treatment, without charge, for youth during their participation in such activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one nutritious meal daily, without charge, for participating youth during each day of participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high quality instruction in a variety of sports (that shall include swimming and that may include dance and any other high quality recreational activity) provided by coaches and teachers from institutions of higher education and from elementary and secondary schools (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrichment instruction and information on matters relating to the well-being of youth, to include educational opportunities and information on study practices, education for the prevention of drug and alcohol abuse, and information on health and nutrition, career opportunities, and family and job responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee; partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligible service provider shall, in each community in which a program is funded under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf0b8f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based advisory committee is established, with representatives from local youth, family, and social service organizations, schools, entities providing park and recreation services, and other community-based organizations serving high-risk youth; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf0b8f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an existing community-based advisory board, commission, or committee with similar membership is utilized to serve as the committee described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into formal partnerships with youth-serving organizations or other appropriate social service entities in order to link program participants with year-round services in their home communities that support and continue the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A service provider that is a national private, nonprofit organization, a coalition of such organizations, or a private, nonprofit organization applying jointly with a business concern shall be eligible to apply for a grant under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant has demonstrated experience in operating a program providing instruction to low-income youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant agrees to contribute an amount (in cash or in kind, fairly evaluated) of not less than 25 percent of the amount requested, for the program funded through the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant agrees to use no funds from a grant authorized under this section for administrative expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant agrees to comply with the regulations or program guidelines promulgated by the Secretary for use of funds made available through the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a service provider shall submit to the Secretary, for approval, an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations or program guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations or program guidelines to ensure funds made available through a grant made under this section are used in accordance with the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf0b8f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9923/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $15,000,000 for each of fiscal years 1999 through 2003 for grants to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8f6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s682"},"text":"Pub. L. 97–35, title VI, § 682","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2753"},"text":"112 Stat. 2753","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/ee"},"text":"Pub. L. 107–110, title X, § 1076(ee)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2093"},"text":"115 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/t"},"text":"Pub. L. 114–95, title IX, § 9215(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2171"},"text":"129 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b8f6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf0b8f70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf0b8f71-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141/a"},"text":"Section 1141(a) of title 20","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"Pub. L. 105–244, § 3","children":[],"tail":", title I, § 101(b), title VII, § 702, "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1585"},"text":"112 Stat. 1585","children":[],"tail":", 1616, 1803, effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":". However, the term “institution of higher education” is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf0b8f72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s682"},"text":"section 682 of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910c"},"text":"section 9910c of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s682"},"text":"section 682 of Pub. L. 97–35","children":[],"tail":" was renumbered section 683 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9911"},"text":"section 9911 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s682"},"text":"section 682 of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9911"},"text":"section 9911 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf0b8f73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" substituted “7801” for “8801”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf0b8f74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf0b8f75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf0b8f76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
