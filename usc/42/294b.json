{"tag":"section","attrib":{"id":"idb5dca442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b"},"text":null,"children":[{"tag":"num","attrib":{"value":"294b"},"text":"§ 294b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing educational support for health professionals serving in rural and underserved communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5dca443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, as appropriate, shall make grants to, and enter into contracts with, eligible entities to support access to accredited continuing medical education for primary care physicians and health care providers at community health centers or rural health clinics to improve and increase access to care for patients in rural and medically underserved areas. Such grants or contracts may be used to improve health care, increase retention, increase representation of minority health care providers, enhance the practice environment, increase primary care physician and health care provider knowledge, and provide information dissemination and educational support to reduce professional isolation through the timely dissemination of research findings using relevant resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible entity” means an entity described in section 295","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(b) of this title, such as a community health center or rural health clinic."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring to receive an award under this section shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how participation in activities funded under this section will help improve access to, and quality of, health care services and training needs of primary care physicians and health care providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for providing peer-to-peer training, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall use amounts awarded under a grant or contract under this section to provide innovative supportive activities to enhance education for primary care physicians and health care providers described in subsection (a) through distance learning, continuing educational activities, collaborative conferences, and electronic and telelearning activities, with priority for primary care providers who are seeking additional education in specialty fields such as infectious disease, endocrinology, pediatrics, mental health and substance use disorders, pain management, geriatrics, and other areas, as appropriate, in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5dca44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve retention of primary care physicians and health care providers and increase access to specialty health care services for patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5dca44b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support access to the integration of specialty care through existing service delivery locations and care across settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca44c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities may use amounts awarded under a grant or contract under this section for continuing educational activities that include a clinical training component, including in-person patient care, in the respective community health center or rural health clinic, with the primary care physician or health care provider at such site and the clinical specialist from whom such additional training is being provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca44d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that revives a grant or contract under this section shall use not more than 5 percent of the amounts received under the grant or contract under this section for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca44e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-duplication of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that activities under this section do not unnecessarily duplicate efforts of other programs overseen by the Health Resources and Services Administration, including activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–20"},"text":"section 254c–20 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca44f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2023 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5dca450-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 752, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5403/b"},"text":"Pub. L. 111–148, title V, § 5403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/648"},"text":"124 Stat. 648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2227"},"text":"Pub. L. 117–328, div. FF, title II, § 2227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5751"},"text":"136 Stat. 5751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5dca451-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5dca452-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"ta