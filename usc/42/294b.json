,"text":"Pub. L. 100–607, title VI","children":[],"tail":", §§ 628(5), 629(b)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/102/3145"},"text":"102 Stat. 3145","children":[],"tail":", 3146, related to limitations on individually insured loans and loan insurance, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292b"},"text":"section 292b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 294b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s742"},"text":"act July 1, 1944, ch. 373, title VII, § 742","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/129/s2/b"},"text":"Pub. L. 88–129, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/172"},"text":"77 Stat. 172","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/290/s4/c"},"text":"Pub. L. 89–290, § 4(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1057"},"text":"79 Stat. 1057","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/709/s3/e"},"text":"Pub. L. 89–709, § 3(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1103"},"text":"80 Stat. 1103","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/751/s5/b"},"text":"Pub. L. 89–751, § 5(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1232"},"text":"80 Stat. 1232","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tI/s121/b"},"text":"Pub. L. 90–490, title I, § 121(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/778"},"text":"82 Stat. 778","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-07-09"},"text":"July 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/52/s1/a"},"text":"Pub. L. 92–52, § 1(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/144"},"text":"85 Stat. 144","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s105/a"},"text":"Pub. L. 92–157, title I, § 105(a)","children":[],"tail":", (f)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/85/449"},"text":"85 Stat. 449","children":[],"tail":", 451; "},{"tag":"date","attrib":{"date":"1974-08-23"},"text":"Aug. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/385/s2/a"},"text":"Pub. L. 93–385, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/741"},"text":"88 Stat. 741","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tXI/s1105/a"},"text":"Pub. L. 94–278, title XI, § 1105(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/416"},"text":"90 Stat. 416","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tI/s101/e"},"text":"Pub. L. 94–484, title I, § 101(e)","children":[],"tail":", title IV, §§ 404, 406(d), "},{"tag":"ref","attrib":{"href":"/us/stat/90/2244"},"text":"90 Stat. 2244","children":[],"tail":", 2267, 2268, which related to authorization of appropriations, was transferred to section 294"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 752 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293p"},"text":"section 293p of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 752 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294u"},"text":"section 294u of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5dca454-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/1"},"text":"Pub. L. 117–328, § 2227(1)","children":[],"tail":", inserted “rural and” after “serving in” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/2"},"text":"Pub. L. 117–328, § 2227(2)","children":[],"tail":", substituted “, as appropriate, shall make grants to, and enter into contracts with, eligible entities to support access to accredited continuing medical education for primary care physicians and health care providers at community health centers or rural health clinics to improve and increase access to care for patients in rural and medically underserved areas. Such grants or contracts may be used” for “shall make grants to, and enter into contracts with, eligible entities” and “health care providers” for “faculty members” and inserted “increase primary care physician and health care provider knowledge,” after “practice environment,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/3"},"text":"Pub. L. 117–328, § 2227(3)","children":[],"tail":", inserted “, such as a community health center or rural health clinic” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/4"},"text":"Pub. L. 117–328, § 2227(4)","children":[],"tail":", which directed substitution of “may require, including—” and pars. (1) and (2) for “by require.”, was executed by making the substitution for “may require.”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/5"},"text":"Pub. L. 117–328, § 2227(5)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “An eligible entity shall use amounts awarded under a grant or contract under this section to provide innovative supportive activities to enhance education through distance learning, continuing educational activities, collaborative conferences, and electronic and telelearning activities, with priority for primary care.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/7"},"text":"Pub. L. 117–328, § 2227(7)","children":[],"tail":", added subsecs. (e) and (f). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2227/6"},"text":"Pub. L. 117–328, § 2227(6)","children":[],"tail":", (8), redesignated subsec. (e) as (g) and substituted “fiscal years 2023 through 2025” for “the fiscal years 2010 through 2014, and such sums as may be necessary for each subsequent fiscal year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
