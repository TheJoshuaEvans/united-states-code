{"tag":"section","attrib":{"id":"idb5b8c7f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–23"},"text":"§ 290cc–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c7f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless, with respect to the costs of providing services pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22"},"text":"section 290cc–22 of this title","children":[],"tail":", the State involved agrees to make available, directly or through donations from public or private entities, non-Federal contributions toward such costs in an amount that is not less than $1 for each $3 of Federal funds provided in such payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required in subsection (a) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, shall not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c7f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation regarding grants by States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that the State will not require the entities to which grants are provided pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–22/a"},"text":"section 290cc–22(a) of this title","children":[],"tail":" to provide non-Federal contributions in excess of the non-Federal contributions described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c7f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 523, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/3"},"text":"Pub. L. 100–77, title VI, § 611(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/517"},"text":"101 Stat. 517","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tV/s511"},"text":"Pub. L. 101–645, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4728"},"text":"104 Stat. 4728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b8c7f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b8c7f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b8c7fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 523 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 544 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/s611/2"},"text":"section 611(2) of Pub. L. 100–77","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290dd–3"},"text":"section 290dd–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b8c7fb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/645"},"text":"Pub. L. 101–645","children":[],"tail":" amended section generally, substituting present provisions for provisions which related to: in subsec. (a), general requirements; and in subsec. (b), determination of amount of non-Federal contribution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
