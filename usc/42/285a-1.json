{"tag":"section","attrib":{"id":"idb5679ad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–1"},"text":"§ 285a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancer control programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall establish and support demonstration, education, and other programs for the detection, diagnosis, prevention, and treatment of cancer and for rehabilitation and counseling respecting cancer. Programs established and supported under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5679ad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" locally initiated education and demonstration programs (and regional networks of such programs) to transmit research results and to disseminate information respecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5679ad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection, diagnosis, prevention, and treatment of cancer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5679ad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuing care of cancer patients and the families of cancer patients, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5679ada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitation and counseling respecting cancer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to physicians and other health professionals who provide care to individuals who have cancer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5679adb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the demonstration of and the education of students of the health professions and health professionals in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5679adc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective methods for the prevention and early detection of cancer and the identification of individuals with a high risk of developing cancer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5679add-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved methods of patient referral to appropriate centers for early diagnosis and treatment of cancer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5679ade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration of new methods for the dissemination of information to the general public concerning the prevention, early detection, diagnosis, and treatment and control of cancer and information concerning unapproved and ineffective methods, drugs, and devices for the diagnosis, prevention, treatment, and control of cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5679adf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 412, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/832"},"text":"99 Stat. 832","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
