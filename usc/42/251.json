{"tag":"section","attrib":{"id":"idb4dd5c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251"},"text":null,"children":[{"tag":"num","attrib":{"value":"251"},"text":"§ 251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical examination and treatment of Federal employees; medical care at remote stations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4dd5c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Surgeon General is authorized to provide at institutions, hospitals, and station of the Service medical, surgical, and hospital services and supplies for persons entitled to treatment under subchapter I of Chapter 81 of title 5 and extensions thereof. The Surgeon General may also provide for making medical examinations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4dd5c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the Federal Government for retirement purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees in the Federal classified service, and applicants for appointment, as requested by the Director of the Office of Personnel Management for the purpose of promoting health and efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seamen for purposes of qualifying for certificates of service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4dd5c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees eligible for benefits under the Longshore and Harbor Workers’ Compensation Act, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"33 U.S.C. 901","children":[],"tail":" et seq.], as requested by any deputy commissioner thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4dd5c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to provide medical, surgical, and dental treatment and hospitalization and optometric care for Federal employees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8901/1"},"text":"section 8901(1) of title 5","children":[],"tail":") and their dependents at remote medical facilities of the Public Health Service where such care and treatment are not otherwise available. Such employees and their dependents who are not entitled to this care and treatment under any other provision of law shall be charged for it at rates established by the Secretary to reflect the reasonable cost of providing the care and treatment. Any payments pursuant to the preceding sentence shall be credited to the applicable appropriation to the Public Health Service for the year in which such payments are received."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4dd5c72-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 324, "},{"tag":"ref","attrib":{"href":"/us/stat/58/697"},"text":"58 Stat. 697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s10/a"},"text":"Pub. L. 90–174, § 10(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/540"},"text":"81 Stat. 540","children":[],"tail":"; 1978 Reorg. Plan No. 2, § 102, eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", 43 F.R. 36037, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s615/b/4"},"text":"Pub. L. 97–468, title VI, § 615(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2578"},"text":"96 Stat. 2578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s27/d/2"},"text":"Pub. L. 98–426, § 27(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1654"},"text":"98 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4dd5c73-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4dd5c74-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4dd5c75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Longshore and Harbor Workers’ Compensation Act, as amended, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509"},"text":"act Mar. 4, 1927, ch. 509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1424"},"text":"44 Stat. 1424","children":[],"tail":", which is classified generally to chapter 18 (§ 901 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4dd5c76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “subchapter I of chapter 81 of title 5” substituted for “United States Employees’ Compensation Act” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4dd5c77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" substituted “Longshore and Harbor Workers’ Compensation Act” for “Longshoremen’s and Harbor Workers’ Compensation Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" struck out “employees of the Alaska Railroad and” before “employees of the Federal Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/174/s10/a"},"text":"Pub. L. 90–174, § 10(a)","children":[],"tail":", designated existing provisions as subsec. (a) and redesignated cls. (a) to (d) as cls. (1) to (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/174/s10/b"},"text":"Pub. L. 90–174, § 10(b)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4dd5c78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb4dd5c79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (b) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4dd5c7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s28/e/1"},"text":"section 28(e)(1) of Pub. L. 98–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4dd5c7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" effective on date of transfer of Alaska Railroad to the State ["},{"tag":"date","attrib":{"date":"1985-01-05"},"text":"Jan. 5, 1985","children":[],"tail":"], pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1203"},"text":"section 1203 of Title 45","children":[],"tail":", Railroads, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/s615/b"},"text":"section 615(b) of Pub. L. 97–468","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb4dd5c7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb4dd5c7d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Office of Personnel Management” substituted for “Civil Service Commission” in subsec. (a)(2), pursuant to Reorg. Plan No. 2 of 1978, § 102, 43 F.R. 36037, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":", Government Organization and Employees, which transferred all functions vested by statute in United States Civil Service Commission to Director of Office of Personnel Management (except as otherwise specified), effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", as provided by section 1–102 of Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of Title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Public Health Service, Surgeon General of Public Health Service, and all other officers and employees of Public Health Service, and functions of all agencies of or in Public Health Service transferred to Secretary of Health, Education, and Welfare by Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
