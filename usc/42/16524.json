{"tag":"section","attrib":{"id":"idc0190887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524"},"text":null,"children":[{"tag":"num","attrib":{"value":"16524"},"text":"§ 16524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on the benefits of economic dispatch","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0190888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination and consultation with the States, shall conduct a study on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures currently used by electric utilities to perform economic dispatch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019088a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying possible revisions to those procedures to improve the ability of nonutility generation resources to offer their output for sale for the purpose of inclusion in economic dispatch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019088b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential benefits to residential, commercial, and industrial electricity consumers nationally and in each state ","children":[{"tag":"ref","attrib":{"idref":"fn004233"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004233"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" if economic dispatch procedures were revised to improve the ability of nonutility generation resources to offer their output for inclusion in economic dispatch."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019088c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “economic dispatch” when used in this section means the operation of generation facilities to produce energy at the lowest cost to reliably serve consumers, recognizing any operational limits of generation and transmission facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019088d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress and the States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and on a yearly basis following, the Secretary shall submit a report to Congress and the States on the results of the study conducted under subsection (a), including recommendations to Congress and the States for any suggested legislative or regulatory changes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc019088e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVIII/s1832"},"text":"Pub. L. 109–58, title XVIII, § 1832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1138"},"text":"119 Stat. 1138","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
