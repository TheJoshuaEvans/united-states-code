{"tag":"section","attrib":{"id":"idbe58bb02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7609"},"text":null,"children":[{"tag":"num","attrib":{"value":"7609"},"text":"§ 7609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe58bb03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall review and comment in writing on the environmental impact of any matter relating to duties and responsibilities granted pursuant to this chapter or other provisions of the authority of the Administrator, contained in any (1) legislation proposed by any Federal department or agency, (2) newly authorized Federal projects for construction and any major Federal agency action (other than a project for construction) to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":" applies, and (3) proposed regulations published by any department or agency of the Federal Government. Such written comment shall be made public at the conclusion of any such review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe58bb04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsatisfactory legislation, action, or regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event the Administrator determines that any such legislation, action, or regulation is unsatisfactory from the standpoint of public health or welfare or environmental quality, he shall publish his determination and the matter shall be referred to the Council on Environmental Quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe58bb05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/604/s12/a"},"text":"Pub. L. 91–604, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1709"},"text":"84 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe58bb06-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe58bb07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe58bb08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857h–7"},"text":"section 1857h–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe58bb09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 309 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360/tIII"},"text":"act July 14