{"tag":"section","attrib":{"id":"idb95aa77e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–131"},"text":"§ 1395w–131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to Medicare Advantage program and related managed care programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95aa77f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to offering of qualified prescription drug coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An MA organization on and after ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95aa781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not offer an MA plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/a/2/A"},"text":"section 1395w–21(a)(2)(A) of this title","children":[],"tail":" in an area unless either that plan (or another MA plan offered by the organization in that same service area) includes required prescription drug coverage (as defined in paragraph (2)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not offer prescription drug coverage (other than that required under parts A and B) to an enrollee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95aa783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an MSA plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95aa784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under another MA plan unless such drug coverage under such other plan provides qualified prescription drug coverage and unless the requirements of this section with respect to such coverage are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(A), the term “required coverage” means with respect to an MA–PD plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95aa786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic prescription drug coverage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified prescription drug coverage that provides supplemental prescription drug coverage, so long as there is no MA monthly supplemental beneficiary premium applied under the plan (due to the application of a credit against such premium of a rebate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–24/b/1/C"},"text":"section 1395w–24(b)(1)(C) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of default enrollment rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seamless continuation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/c/3/A/ii"},"text":"section 1395w–21(c)(3)(A)(ii) of this title","children":[],"tail":", an individual who is enrolled in a health benefits plan shall not be considered to have been deemed to make an election into an MA–PD plan unless such health benefits plan provides any prescription drug coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa78a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MA continuation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/c/3/B"},"text":"section 1395w–21(c)(3)(B) of this title","children":[],"tail":", an individual who is enrolled in an MA plan shall not be considered to have been deemed to make an election into an MA–PD plan unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95aa78b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of the election as of ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", the MA plan provided as of "},{"tag":"date","attrib":{"date":"2005-12-31"},"text":"December 31, 2005","children":[],"tail":", any prescription drug coverage; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa78c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for periods after ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", such MA plan is an MA–PD plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa78d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance of MA–PD election during first year of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/e/4"},"text":"section 1395w–21(e)(4) of this title","children":[],"tail":" in the case of an individual who is electing to discontinue enrollment in an MA–PD plan, the individual shall be permitted to enroll in a prescription drug plan under part D at the time of the election of coverage under the original medicare fee-for-service program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa78e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules regarding enrollees in MA plans not providing qualified prescription drug coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual who is enrolled in an MA plan (other than an MSA plan) that does not provide qualified prescription drug coverage, if the organization offering such coverage discontinues the offering with respect to the individual of all MA plans that do not provide such coverage—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb95aa78f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/4/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is deemed to have elected the original medicare fee-for-service program option, unless the individual affirmatively elects to enroll in an MA–PD plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb95aa790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/b/4/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of such a deemed election, the disenrollment shall be treated as an involuntary termination of the MA plan described in subparagraph (B)(ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ss/s/3"},"text":"section 1395ss(s)(3) of this title","children":[],"tail":" for purposes of applying such section."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The information disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–22/c/1"},"text":"section 1395w–22(c)(1) of this title","children":[],"tail":" for individuals who are enrolled in such an MA plan shall include information regarding such rules."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of part D rules for prescription drug coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the offering of qualified prescription drug coverage by an MA organization under this part on and after ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the provisions of this part shall apply under part C with respect to prescription drug coverage provided under MA–PD plans in lieu of the other provisions of part C that would apply to such coverage under such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall waive the provisions referred to in paragraph (1) to the extent the Secretary determines that such provisions duplicate, or are in conflict with, provisions otherwise applicable to the organization or plan under part C or as may be necessary in order to improve coordination of this part with the benefits under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of MA owned and operated pharmacies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104/b/1/C"},"text":"section 1395w–104(b)(1)(C) of this title","children":[],"tail":" in the case of an MA–PD plan that provides access (other than mail order) to qualified prescription drug coverage through pharmacies owned and operated by the MA organization, if the Secretary determines that the organization’s pharmacy network is sufficient to provide comparable access for enrollees under the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for private fee-for-service plans that offer prescription drug coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an MA plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/a/2/C"},"text":"section 1395w–21(a)(2)(C) of this title","children":[],"tail":" that offers qualified prescription drug coverage, on and after "},{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", the following rules apply:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding negotiated prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a)(1) and (d)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102"},"text":"section 1395w–102 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104/b/2/A"},"text":"section 1395w–104(b)(2)(A) of this title","children":[],"tail":" shall not be construed to require the plan to provide negotiated prices (described in subsection (d)(1)(B) of such section), but shall apply to the extent the plan does so."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of pharmacy access standard and disclosure requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the plan provides coverage for drugs purchased from all pharmacies, without charging additional cost-sharing, and without regard to whether they are participating pharmacies in a network or have entered into contracts or agreements with pharmacies to provide drugs to enrollees covered by the plan, subsections (b)(1)(C) and (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104"},"text":"section 1395w–104 of this title","children":[],"tail":" shall not apply to the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug utilization management program and medication therapy management program not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subparagraphs (A) and (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104/c/1"},"text":"section 1395w–104(c)(1) of this title","children":[],"tail":" shall not apply to the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of reinsurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the amount of reinsurance payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–115/b"},"text":"section 1395w–115(b) of this title","children":[],"tail":" using a methodology that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95aa79a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bases such amount on the Secretary’s estimate of the amount of such payments that would be payable if the plan were an MA–PD plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/a/2/A/i"},"text":"section 1395w–21(a)(2)(A)(i) of this title","children":[],"tail":" and the previous provisions of this subsection did not apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa79b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account the average reinsurance payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–115/b"},"text":"section 1395w–115(b) of this title","children":[],"tail":" for populations of similar risk under MA–PD plans described in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa79c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from risk corridor provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–115/e"},"text":"section 1395w–115(e) of this title","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa79d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (d) and (e)(2)(C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–111"},"text":"section 1395w–111 of this title","children":[],"tail":" shall not apply and the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–24/a/5/B"},"text":"section 1395w–24(a)(5)(B) of this title","children":[],"tail":" prohibiting the review, approval, or disapproval of amounts described in such section shall apply to the proposed bid and terms and conditions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–111/d"},"text":"section 1395w–111(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa79e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of incurred costs without regard to formulary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exclusion of costs incurred for covered part D drugs which are not included (or treated as being included) in a plan’s formulary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/b/4/C/i"},"text":"section 1395w–102(b)(4)(C)(i) of this title","children":[],"tail":" shall not apply insofar as the plan does not utilize a formulary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa79f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to reasonable cost reimbursement contractors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa7a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3) and rules established by the Secretary, in the case of an organization that is providing benefits under a reasonable cost reimbursement contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395mm/h"},"text":"section 1395mm(h) of this title","children":[],"tail":" and that elects to provide qualified prescription drug coverage to a part D eligible individual who is enrolled under such a contract, the provisions of this part (and related provisions of part C) shall apply to the provision of such coverage to such enrollee in the same manner as such provisions apply to the provision of such coverage under an MA–PD local plan described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395–21/a/2/A/i"},"text":"section 1395–21(a)(2)(A)(i) of this title","children":[],"tail":" and coverage under such a contract that so provides qualified prescription drug coverage shall be deemed to be an MA–PD local plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa7a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying paragraph (1), the organization may not enroll part D eligible individuals who are not enrolled under the reasonable cost reimbursement contract involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa7a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bids not included in determining national average monthly bid amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bid of an organization offering prescription drug coverage under this subsection shall not be taken into account in computing the national average monthly bid amount and low-income benchmark premium amount under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa7a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to PACE","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa7a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3) and rules established by the Secretary, in the case of a PACE program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395eee"},"text":"section 1395eee of this title","children":[],"tail":" that elects to provide qualified prescription drug coverage to a part D eligible individual who is enrolled under such program, the provisions of this part (and related provisions of part C) shall apply to the provision of such coverage to such enrollee in a manner that is similar to the manner in which such provisions apply to the provision of such coverage under an MA–PD local plan described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21/a/2/A/ii"},"text":"section 1395w–21(a)(2)(A)(ii) of this title","children":[],"tail":" and a PACE program that so provides such coverage may be deemed to be an MA–PD local plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa7a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying paragraph (1), the organization may not enroll part D eligible individuals who are not enrolled under the PACE program involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa7a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–131/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bids not included in determining standardized bid amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The bid of an organization offering prescription drug coverage under this subsection is not be taken into account in computing any average benchmark bid amount and low-income benchmark premium amount under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95aa7a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1860D–21, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tI/s101/a/2"},"text":"Pub. L. 108–173, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2122"},"text":"117 Stat. 2122","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s11201/e/4"},"text":"Pub. L. 117–169, title I, § 11201(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1891"},"text":"136 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95aa7a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95aa7a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95aa7aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" substituted “section 1395w–102(b)(4)(C)(i)” for “section 1395w–102(b)(4)(B)(i)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
