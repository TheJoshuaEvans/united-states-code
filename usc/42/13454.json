{"tag":"section","attrib":{"id":"idbfc320a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454"},"text":null,"children":[{"tag":"num","attrib":{"value":"13454"},"text":"§ 13454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced buildings for 2005","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc320a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall initiate a 5-year program, in accordance with sections 13541 and 13542 of this title, to increase building energy efficiency, while maintaining affordability, by the year 2005. Such program shall include activities on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building design, design methods, and construction techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building materials, including recycled materials, and components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-site energy supply conversion systems such as photovoltaics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automated energy management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of evaluating performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insulation products manufactured with nonozone depleting materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc320a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc320a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc320aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Proposals submitted under this subsection shall include and be judged upon—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc320ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of knowledge of current building practices in the United States and in other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how the proposal will encourage the commercialization of the technologies resulting from activities in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of consideration of collaboration with Department of Energy national laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of collaboration with relevant industry or other groups or organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc320af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13454/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration of the ability of the proposers to undertake and complete the project proposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc320b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2104"},"text":"Pub. L. 102–486, title XXI, § 2104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3069"},"text":"106 Stat. 3069","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
