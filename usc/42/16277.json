{"tag":"section","attrib":{"id":"idc0013b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277"},"text":null,"children":[{"tag":"num","attrib":{"value":"16277"},"text":"§ 16277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance computation and supportive research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0013b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modeling and simulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to enhance the capabilities of the United States to develop new reactor technologies through high-performance computation modeling and simulation techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary shall coordinate with relevant Federal agencies as described by the National Strategic Computing Initiative established by Executive Order 13702 (80 Fed. Reg. 46177 (","children":[{"tag":"date","attrib":{"date":"2015-07-29"},"text":"July 29, 2015","children":[],"tail":")), while taking into account the following objectives:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using expertise from the private sector, institutions of higher education, and the National Laboratories to develop computational software and capabilities that prospective users may access to accelerate research and development of advanced nuclear reactor systems and reactor systems for space exploration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing computational tools to simulate and predict nuclear phenomena that may be validated through physical experimentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the utility of the research infrastructure of the Department by coordinating with the Advanced Scientific Computing Research program within the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leveraging experience from the Energy Innovation Hub for Modeling and Simulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring that new experimental and computational tools are accessible to relevant research communities, including private sector entities engaged in nuclear energy technology development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive research activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider support for additional research activities to maximize the utility of the research facilities of the Department, including physical processes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to simulate degradation of materials and behavior of fuel forms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for validation of computational tools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure the coordination of, and avoid unnecessary duplication of, the activities of the program under subsection (a) with the activities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research entities of the Department, including the National Laboratories, the Advanced Research Projects Agency–Energy, and the Advanced Scientific Computing Research program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16277/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0013b69-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s957"},"text":"Pub. L. 109–58, title IX, § 957","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/888"},"text":"119 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/g"},"text":"Pub. L. 115–248, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3157"},"text":"132 Stat. 3157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2004"},"text":"Pub. L. 116–260, div. Z, title II, § 2004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2470"},"text":"134 Stat. 2470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0013b6a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0013b6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0013b6c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13702, referred to in subsec. (b), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5501"},"text":"section 5501 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0013b6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/248"},"text":"Pub. L. 115–248","children":[],"tail":" amended section generally. Prior to amendment, section related to survey and plan regarding alternatives to industrial radioactive sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
