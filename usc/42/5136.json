{"tag":"section","attrib":{"id":"idbd0f98f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136"},"text":null,"children":[{"tag":"num","attrib":{"value":"5136"},"text":"§ 5136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural hazard risk assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f98f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f98f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community disaster resilience zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community disaster resilience zone” means a census tract designated by the President under subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f98f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f98fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f98fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f98fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f98fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall continue to maintain a natural hazard assessment program that develops and maintains products that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f98fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f98ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define natural hazard risk across the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Features","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The products maintained under subsection (b) shall, for lands within States and areas under the jurisdiction of Indian tribal governments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" show the risk of natural hazards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9902-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include ratings and data for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f9903-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss exposure, including population equivalence, buildings, and agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social vulnerability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other element determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community disaster resilience zones designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the President makes the update and enhancement required under subsection (e)(4), and not less frequently than every 5 years thereafter, the President shall identify and designate community disaster resilience zones, which shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f9909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 50 census tracts assigned the highest individual hazard risk ratings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f990a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (3), in each State, not less than 1 percent of census tracts that are assigned high individual risk ratings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f990b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk ratings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the President shall use census tract risk ratings derived from a product maintained under subsection (b) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f990c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reflect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0f990d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" high levels of individual hazard risk ratings based on an assessment of the intersection of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd0f990e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss to population equivalence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd0f990f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd0f9910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture value;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high social vulnerability ratings and low community resilience ratings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other elements determined by the President; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the principal natural hazard risks identified for the respective census tracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic balance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying and designating the community disaster resilience zones described in paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f9915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of achieving geographic balance, when applicable, the President shall consider making designations in coastal, inland, urban, suburban, and rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President shall include census tracts on Tribal lands located within a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of a community disaster resilience zone under paragraph (1) shall be effective for a period of not less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and update","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"December 20, 2022","children":[],"tail":", and not less frequently than every 5 years thereafter, the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any product that is a natural hazard risk assessment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f991a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the underlying methodology of the product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f991b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive public input on the methodology and data used for the product;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f991c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider including additional data in any product that is a natural hazard risk assessment, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f991d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent census tract data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f991e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data from the American Community Survey of the Bureau of the Census, a successor survey, a similar survey, or another data source, including data by census tract on housing characteristics and income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f991f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to development, improvements, and hazard mitigation measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data that assesses past and future loss exposure, including analysis on the effects of a changing climate on future loss exposure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data from the Resilience Analysis and Planning Tool of the Federal Emergency Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other information relevant to prioritizing areas that have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0f9923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" high risk levels of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd0f9924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural hazard loss exposure, including population equivalence, buildings, infrastructure, and agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd0f9925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social vulnerability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low levels of community resilience;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available any changes in methodology or data used to inform an update to a product maintained under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update and enhance the products maintained under subsection (b), as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural hazard risk assessment insights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining additional data to include in products that are natural hazard risk assessments under subsection (e)(2), the President shall consult with, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f992a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f992b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture and the Chief of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f992c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, the Administrator of the National Oceanic and Atmospheric Administration, the Director of the Bureau of the Census, and the Director of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f992d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense and the Commanding Officer of the United States Army Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f992e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f992f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior and the Director of the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Federal Housing Finance Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community disaster resilience zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to financial assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5133/i"},"text":"section 5133(i) of this title","children":[],"tail":" to perform a resilience or mitigation project within, or that primarily benefits, a community disaster resilience zone, the President may increase the amount of the Federal share described under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5133/h"},"text":"section 5133(h) of this title","children":[],"tail":" to not more than 90 percent of the total cost of the resilience or mitigation project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resilience or mitigation project planning assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may provide financial, technical, or other assistance under this subchapter to an eligible entity that plans to perform a resilience or mitigation project within, or that primarily benefits, a community disaster resilience zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of assistance provided under paragraph (1) shall be to carry out activities in preparation for a resilience or mitigation project or seek an evaluation and certification under subsection (i)(2) for a resilience or mitigation project before the date on which permanent work of the resilience or mitigation project begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If required by the President, an eligible entity seeking assistance under paragraph (1) shall submit an application in accordance with subsection (i)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under paragraph (1), the President may use amounts set aside under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5133/i"},"text":"section 5133(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f9938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community disaster resilience zone project applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f9939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If required by the President or other Federal law, an eligible entity shall submit to the President an application at such time, in such manner, and containing or accompanied by such information as the President may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f993a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f993b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date on which an eligible entity submits an application under paragraph (1), the President shall evaluate the application to determine whether the resilience or mitigation project that the entity plans to perform within, or that primarily benefits, a community disaster resilience zone—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0f993c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to reduce injuries, loss of life, and damage and destruction of property, such as damage to critical services and facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f993d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially reduces the risk of, or increases resilience to, future damage, hardship, loss, or suffering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f993e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that an application submitted under paragraph (1) meets the criteria described in subparagraph (A), the President shall certify the proposed resilience or mitigation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f993f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification of a proposed resilience or mitigation project under subparagraph (B) shall not be construed to exempt the resilience or mitigation project from the requirements of any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f9940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects causing displacement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a resilience or mitigation project certified under paragraph (2)(B) that involves the displacement of a resident from any occupied housing unit, the entity performing the resilience or mitigation project shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f9941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, at the option of the resident, a suitable and habitable housing unit that is, with respect to the housing unit from which the resident is displaced—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0f9942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a comparable size;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the same local community or a community with reduced hazard risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered under similar costs, conditions, and terms;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that property acquisitions resulting from the displacement and made in connection with the resilience or mitigation project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0f9946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are deed restricted in perpetuity to preclude future property uses not relating to mitigation or resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0f9947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are the result of a voluntary decision by the resident; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f9948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5136/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan for robust public participation in the resilience or mitigation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f9949-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tII/s206"},"text":"Pub. L. 93–288, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/255/s3/a"},"text":"Pub. L. 117–255, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2363"},"text":"136 Stat. 2363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f994a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd0f994b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd0f994c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/255/s3/c"},"text":"Pub. L. 117–255, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2367"},"text":"136 Stat. 2367","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/255/s3/c"},"text":"“The amendments made by this Act [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"] shall only apply with respect to amounts appropriated on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd0f994d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Risk Index Funding","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/255/s3/b"},"text":"Pub. L. 117–255, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2367"},"text":"136 Stat. 2367","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/255/s3/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in section 206 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5136"},"text":"42 U.S.C. 5136","children":[],"tail":"], as added by subsection (a) of this section, shall be construed to prohibit the Administrator of the Federal Emergency Management Agency from using amounts available to maintain and update the National Risk Index until the earlier of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which those amounts are transferred to another source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
