{"tag":"section","attrib":{"id":"idbf25cf4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10369"},"text":null,"children":[{"tag":"num","attrib":{"value":"10369"},"text":"§ 10369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research agreement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into contracts, grants, or cooperative agreements, for periods not to exceed 5 years, to carry out research within the Bureau of Reclamation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf28183e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9509"},"text":"Pub. L. 111–11, title IX, § 9509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1346"},"text":"123 Stat. 1346","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
