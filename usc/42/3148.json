{"tag":"section","attrib":{"id":"idbc74b831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148"},"text":null,"children":[{"tag":"num","attrib":{"value":"3148"},"text":"§ 3148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment priorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), for a project to be eligible for assistance under this subchapter, the project shall be consistent with 1 or more of the following investment priorities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Economic development planning or implementation projects that support development of public facilities, including basic public infrastructure, transportation infrastructure, or telecommunications infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Economic development planning or implementation projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support job skills training to meet the hiring needs of the area in which the project is to be carried out and that result in well-paying jobs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise promote labor force participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovation and entrepreneurship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Economic development planning or implementation projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of innovation and entrepreneurship-related infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote business development and lending; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b83a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the commercialization of new technologies that are creating technology-driven businesses and high-skilled, well-paying jobs of the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b83b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic recovery resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Economic development planning or implementation projects that enhance the ability of an area to withstand and recover from adverse short-term or long-term changes in economic conditions, including effects from industry contractions or economic impacts from natural disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b83c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Economic development planning or implementation projects that encourage job creation, business expansion, technology and capital upgrades, and productivity growth in manufacturing, including efforts that contribute to the competitiveness and growth of domestic suppliers or the domestic production of innovative, high-value products and production technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b83d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary plans to use an investment priority that is not described in subsection (a), the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a written notification that explains the basis for using that investment priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b83e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3148/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section waives any other requirement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b83f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s208"},"text":"Pub. L. 89–136, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2218"},"text":"Pub. L. 118–272, div. B, title II, § 2218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3182"},"text":"138 Stat. 3182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b840-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b841-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc74b842-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3148, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s208"},"text":"Pub. L. 89–136, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3605"},"text":"112 Stat. 3605","children":[],"tail":", related to prevention of unfair competition, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s206/a"},"text":"Pub. L. 108–373, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1761"},"text":"118 Stat. 1761","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
