{"tag":"section","attrib":{"id":"idbcdffdd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4769"},"text":null,"children":[{"tag":"num","attrib":{"value":"4769"},"text":"§ 4769.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, without fiscal year limitation, such sums as may be necessary to carry out the programs authorized by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcdffdd5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tV/s509"},"text":"Pub. L. 91–648, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1928"},"text":"84 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdffdd6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdffdd7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcdffdd8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, means the provisions of subchapters I, II, III, and IV of this chapter. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4761"},"text":"section 4761 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
