{"tag":"section","attrib":{"id":"idb520316d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s273b"},"text":null,"children":[{"tag":"num","attrib":{"value":"273b"},"text":"§ 273b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on the long-term health effects of living organ donation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-21"},"text":"December 21, 2007","children":[],"tail":", and annually thereafter, the Secretary of Health and Human Services shall submit to the appropriate committees of Congress a report that details the progress made towards understanding the long-term health effects of living organ donation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb520316e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/144/s3"},"text":"Pub. L. 110–144, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-21"},"text":"Dec. 21, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1814"},"text":"121 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb520316f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5203170-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5203171-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Charlie W. Norwood Living Organ Donation Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
