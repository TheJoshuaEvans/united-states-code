{"tag":"section","attrib":{"id":"idb6753ae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–10"},"text":"§ 300aa–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6753ae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Vaccine Injury Compensation Program to be administered by the Secretary under which compensation may be paid for a vaccine-related injury or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6753ae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the ethical obligation of any attorney who is consulted by an individual with respect to a vaccine-related injury or death to advise such individual that compensation may be available under the program ","children":[{"tag":"ref","attrib":{"idref":"fn002401"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002401"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" for such injury or death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6753ae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake reasonable efforts to inform the public of the availability of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6753ae9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2110, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3758"},"text":"100 Stat. 3758","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6601/b"},"text":"Pub. L. 101–239, title VI, § 6601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2285"},"text":"103 Stat. 2285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6753aea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6753aeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6753aec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300aa–10, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2111, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238h"},"text":"section 238h of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 2110 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238g"},"text":"section 238g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6753aed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6753aee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6753aef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6601/s"},"text":"Section 6601(s) of Pub. L. 101–239","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/572/tIX/s902/b/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by this section [amending this section and sections 300aa–11 to 300aa–17, 300aa–21, 300aa–23, 300aa–26, and 300aa–27 of this title] shall apply as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petitions filed after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":"] shall proceed under the National Vaccine Injury Compensation Program under title XXI of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"42 U.S.C. 300aa–1","children":[],"tail":" et seq.] as amended by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petitions currently pending in which the evidentiary record is closed shall continue to proceed under the Program in accordance with the law in effect before the date of the enactment of this section, except that if the United States Court of Federal Claims is to review the findings of fact and conclusions of law of a special master on such a petition, the court may receive further evidence in conducting such review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petitions currently pending in which the evidentiary record is not closed shall proceed under the Program in accordance with the law as amended by this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"All pending cases which will proceed under the Program as amended by this section shall be immediately suspended for 30 days to enable the special masters and parties to prepare for proceeding under the Program as amended by this section. In determining the 240-day period prescribed by section 2112(d) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–12/d"},"text":"42 U.S.C. 300aa–12(d)","children":[],"tail":"], as amended by this section, or the 420-day period prescribed by section 2121(b) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–21/b"},"text":"42 U.S.C. 300aa–21(b)","children":[],"tail":"], as so amended, any period of suspension under the preceding sentence shall be excluded."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments to section 2115 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–15"},"text":"42 U.S.C. 300aa–15","children":[],"tail":"] shall apply to all pending and subsequently filed petitions.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6753af0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s323"},"text":"section 323 of Pub. L. 99–660","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"section 300aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
