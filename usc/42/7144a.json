{"tag":"section","attrib":{"id":"idbdf4a1ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7144a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7144a"},"text":"§ 7144a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of security, counterintelligence, and intelligence policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall be responsible for developing and promulgating the security, counterintelligence, and intelligence policies of the Department. The Secretary may use the immediate staff of the Secretary to assist in developing and promulgating those policies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdf4a1eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tII/s214"},"text":"Pub. L. 95–91, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXII/s3204/a"},"text":"Pub. L. 106–65, div. C, title XXXII, § 3204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/955"},"text":"113 Stat. 955","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXI/s3117/g"},"text":"Pub. L. 109–364, div. C, title XXXI, § 3117(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2508"},"text":"120 Stat. 2508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXIV/s6422"},"text":"Pub. L. 116–92, div. E, title LXIV, § 6422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2200"},"text":"133 Stat. 2200","children":[],"