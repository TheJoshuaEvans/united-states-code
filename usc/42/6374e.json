{"tag":"section","attrib":{"id":"idbda373e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6374e"},"text":"§ 6374e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal fleet conservation requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda373e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reduction in petroleum consumption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda373e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall issue regulations for Federal fleets subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6374"},"text":"section 6374 of this title","children":[],"tail":" to require that, beginning in fiscal year 2010, each Federal agency shall reduce petroleum consumption and increase alternative fuel consumption each year by an amount necessary to meet the goals described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda373e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goals of the requirements under paragraph (1) are that not later than ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", and for each year thereafter, each Federal agency shall achieve at least a 20 percent reduction in annual petroleum consumption and a 10 percent increase in annual alternative fuel consumption, as calculated from the baseline established by the Secretary for fiscal year 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda373e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milestones","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the regulations described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda373e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interim numeric milestones to assess annual agency progress towards accomplishing the goals described in that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that agencies annually report on progress towards meeting each of the milestones and the 2015 goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda373ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda373eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda373ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations under subsection (a) shall require each Federal agency to develop a plan, and implement the measures specified in the plan by dates specified in the plan, to meet the required petroleum reduction levels and the alternative fuel consumption increases, including the milestones specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbda373ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the specific measures the agency will use to meet the requirements of subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbda373ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantify the reductions in petroleum consumption or increases in alternative fuel consumption projected to be achieved by each measure each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda373f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan may allow an agency to meet the required petroleum reduction level through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbda373f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of alternative fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of vehicles with higher fuel economy, including hybrid vehicles, neighborhood electric vehicles, electric vehicles, and plug-in hybrid vehicles if the vehicles are commercially available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substitution of cars for light trucks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in vehicle load factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decrease in vehicle miles traveled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decrease in fleet size; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbda373f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374e/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda373f8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400FF"},"text":"Pub. L. 94–163, title III, § 400FF","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s142"},"text":"Pub. L. 110–140, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1518"},"text":"121 Stat. 1518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda373f9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbda373fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbda373fb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
