{"tag":"section","attrib":{"id":"idb5ed45f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j"},"text":null,"children":[{"tag":"num","attrib":{"value":"295j"},"text":"§ 295j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences and required information in certain programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5ed45f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences in making awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ed45f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), in making awards of grants or contracts under any of sections 293k and 294 of this title, the Secretary shall give preference to any qualified applicant that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ed45f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a high rate for placing graduates in practice settings having the principal focus of serving residents of medically underserved communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed45f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 2-year period preceding the fiscal year for which such an award is sought, has achieved a significant increase in the rate of placing graduates in such settings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed45f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizes a longitudinal evaluation (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294n/d/2"},"text":"section 294n(d)(2) of this title","children":[],"tail":") and reports data from such system to the national workforce database (as established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294n/b/2/E"},"text":"section 294n(b)(2)(E) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ed45fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation regarding peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the Secretary may not give an applicant preference if the proposal of the applicant is ranked at or below the 20th percentile of proposals that have been recommended for approval by peer review groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ed45fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Graduate” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “graduate” means, unless otherwise specified, an individual who has successfully completed all training and residency requirements necessary for full certification in the health profession selected by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ed45fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for new programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ed45fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To permit new programs to compete equitably for funding under this section, those new programs that meet at least 4 of the criteria described in paragraph (3) shall qualify for a funding preference under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ed45fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subsection, the term “new program” means any program that has graduated less than three classes. Upon graduating at least three classes, a program shall have the capability to provide the information necessary to qualify the program for the general funding preferences described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ed45ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The criteria referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ed4600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mission statement of the program identifies a specific purpose of the program as being the preparation of health professionals to serve underserved populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The curriculum of the program includes content which will help to prepare practitioners to serve underserved populations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Substantial clinical training experience is required under the program in medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A minimum of 20 percent of the clinical faculty of the program spend at least 50 percent of their time providing or supervising care in medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entire program or a substantial portion of the program is physically located in a medically underserved community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Student assistance, which is linked to service in medically underserved communities following graduation, is available to the students in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ed4606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295j/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program provides a placement mechanism for deploying graduates to medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ed4607-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 791, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2058"},"text":"106 Stat. 2058","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/a/5"},"text":"Pub. L. 102–531, title III, § 313(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI"},"text":"Pub. L. 105–392, title I","children":[],"tail":", §§ 106(a)(2)(B), 107, "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3557"},"text":"112 Stat. 3557","children":[],"tail":", 3560; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5103/c"},"text":"Pub. L. 111–148, title V, § 5103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/605"},"text":"124 Stat. 605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ed4608-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ed4609-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5ed460a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 295j, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s799A"},"text":"act July 1, 1944, ch. 373, title VII, § 799A","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s637/a"},"text":"Pub. L. 100–607, title VI, § 637(a)","childr