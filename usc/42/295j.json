ag":"ref","attrib":{"href":"/us/pl/100/607/s637/b"},"text":"section 637(b) of Pub. L. 100–607","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/n/1"},"text":"Pub. L. 101–93, § 5(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/613"},"text":"103 Stat. 613","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/n/2"},"text":"section 5(n)(2) of Pub. L. 101–93","children":[],"tail":" amended this subchapter to read as if the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/s714"},"text":"section 714 of Pub. L. 100–713","children":[],"tail":" had not been enacted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 791 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295h"},"text":"section 295h of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5ed460b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s107/b/1"},"text":"Pub. L. 105–392, § 107(b)(1)","children":[],"tail":", substituted “sections 293k and 294 of this title” for “sections 293k through 293"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294b"},"text":"section 294b of this title","children":[],"tail":", or under section 294d or 294e of this title” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s107/b/2"},"text":"Pub. L. 105–392, § 107(b)(2)","children":[],"tail":", struck out “under section 295"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of this title” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s106/a/2/B"},"text":"Pub. L. 105–392, § 106(a)(2)(B)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which required submission of certain information by applicant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":", §§ 106(a)(2)(B)(ii), 107(a), added subsec. (c) and redesignated former subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":", in introductory provisions, inserted references to sections 294d and 294e of this title and substituted reference to section 295"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(f)(2) of this title for reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293p/a"},"text":"section 293p(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5ed460c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5ed460d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/s313/c"},"text":"section 313(c) of Pub. L. 102–531","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292y"},"text":"section 292y of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5ed460e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Required Assurances Regarding Bloodborne Diseases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/408/tIII/s308"},"text":"Pub. L. 102–408, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2089"},"text":"106 Stat. 2089","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/408/tIII/s308"},"text":"“With respect to awards of grants or contracts under title VII or VIII of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292"},"text":"42 U.S.C. 292","children":[],"tail":" et seq., 296 et seq.], the Secretary of Health and Human Services may make such an award for the provision of traineeships only if the applicant for the award provides assurances satisfactory to the Secretary that all trainees will, as appropriate, receive instruction in the utilization of universal precautions and infection control procedures for the prevention of the transmission of bloodborne diseases.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
