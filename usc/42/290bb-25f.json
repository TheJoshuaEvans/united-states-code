{"tag":"section","attrib":{"id":"idb5ace12d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–25f"},"text":"§ 290bb–25f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention and education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5ace12e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this Act as the “Secretary”) shall award grants to public and nonprofit private entities to enable such entities to carry out science-based education programs in elementary and secondary schools to highlight the harmful effects of anabolic steroids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ace12f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ace130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for grants under subsection (a), an entity shall prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ace131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Secretary shall give preference to applicants that intend to use grant funds to carry out programs based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ace132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Athletes Training and Learning to Avoid Steroids program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ace133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Athletes Targeting Healthy Exercise and Nutrition Alternatives program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ace134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs determined to be effective by the National Institute on Drug Abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ace135-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received under a grant under subsection (a) shall be used for education programs that will directly communicate with teachers, principals, coaches, as well as elementary and secondary school children concerning the harmful effects of anabolic steroids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ace136-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–25f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $15,000,000 for each of fiscal years 2005 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ace137-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/358/s4"},"text":"Pub. L. 108–358, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1664"},"text":"118 Stat. 1664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ace138-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ace139-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5ace13a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/358"},"text":"Pub. L. 108–358","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"October 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1661"},"text":"92 Stat. 1661","children":[],"tail":", known as the Anabolic Steroid Control Act of 2004. For complete classification of this Act to the Code, see Short Title of 2004 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":", Food and Drugs, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5ace13b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Anabolic Steroid Control Act of 2004, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
