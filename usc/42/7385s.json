{"tag":"section","attrib":{"id":"idbe0c7065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s"},"text":"§ 7385s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered DOE contractor employee” means any Department of Energy contractor employee determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385s–4"},"text":"section 7385s–4 of this title","children":[],"tail":" to have contracted a covered illness through exposure at a Department of Energy facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered illness” means an illness or death resulting from exposure to a toxic substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c7068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c7069-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3671"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3671]","children":[],"tail":", as added "},{"tag":"ref","at