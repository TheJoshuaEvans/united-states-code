{"tag":"section","attrib":{"id":"idbb39ef33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1592k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592k"},"text":"§ 1592k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of fair rentals and classes of occupants by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall fix fair rentals based on the value thereof as determined by the Secretary which shall be charged for housing accommodations operated under this subchapter and may prescribe the class or classes of persons who may occupy such accommodations, preferences, or priorities in the rental thereof, and the terms, conditions, and period of such occupancy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb39ef34-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title III, § 312, "},{"tag":"ref","attrib":{"href":"/us/stat/65/308"},"text":"65 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb39ef35-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb39ef36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb39ef37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
