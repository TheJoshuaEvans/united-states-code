{"tag":"section","attrib":{"id":"idb64ca3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19g"},"text":"§ 300j–19g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64ca3c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a public water system that serves a community with a population of 10,000 or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural hazard; resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “resilience” and “natural hazard” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300i–2/h"},"text":"section 300i–2(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resilience and sustainability program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resilience and sustainability program” means the Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish and carry out a program, to be known as the “Midsize and Large Drinking Water System Infrastructure Resilience and Sustainability Program”, under which the Administrator, subject to the availability of appropriations for the resilience and sustainability program, shall award grants to eligible entities for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing resilience to natural hazards and extreme weather events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing cybersecurity vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may only use grant funds received under the resilience and sustainability program to assist in the planning, design, construction, implementation, operation, or maintenance of a program or project that increases resilience to natural hazards and extreme weather events, or reduces cybersecurity vulnerabilities, through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of water or the enhancement of water-use efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification or relocation of existing drinking water system infrastructure made, or that is at risk of being, significantly impaired by natural hazards or extreme weather events, including risks to drinking water from flooding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the design or construction of new or modified desalination facilities to serve existing communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of water supply through the use of watershed management and source water protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of energy efficiency or the use and generation of renewable energy in the conveyance or treatment of drinking water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development and implementation of measures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the resilience of the eligible entity to natural hazards and extreme weather events; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce cybersecurity vulnerabilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of water or the enhancement of a water supply through the implementation of water reuse measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the formation of regional water partnerships to collaboratively address documented water shortages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To seek a grant under the resilience and sustainability program, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal of the program or project to be planned, designed, constructed, implemented, operated, or maintained by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the natural hazard risks, extreme weather events, or potential cybersecurity vulnerabilities, as applicable, to be addressed by the proposed program or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation prepared by a Federal, State, regional, or local government agency of the natural hazard risk, potential cybersecurity vulnerability, or risk for extreme weather events to the area where the proposed program or project is to be located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any recent natural hazards, cybersecurity events, or extreme weather events that have affected the community water system of the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the proposed program or project would improve the performance of the community water system of the eligible entity under the anticipated natural hazards, cybersecurity vulnerabilities, or extreme weather events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an explanation of how the proposed program or project is expected—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the resilience of the community water system of the eligible entity to the anticipated natural hazards or extreme weather events; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce cybersecurity vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to Congress a report that describes the implementation of the resilience and sustainability program, which shall include a description of the use and deployment of amounts made available to carry out the resilience and sustainability program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the resilience and sustainability program $50,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available under paragraph (1) for grants to eligible entities under the resilience and sustainability program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent shall be used to provide grants to eligible entities that serve a population of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64ca3e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to or greater than 10,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fewer than 100,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be used to provide grants to eligible entities that serve a population equal to or greater than 100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19g/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available under paragraph (1), not more than 2 percent may be used by the Administrator for the administrative costs of carrying out the resilience and sustainability program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca3ec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50107"},"text":"Pub. L. 117–58, div. E, title I, § 50107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1144"},"text":"135 Stat. 1144","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
