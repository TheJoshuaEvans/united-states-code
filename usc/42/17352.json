{"tag":"section","attrib":{"id":"idc0359203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352"},"text":null,"children":[{"tag":"num","attrib":{"value":"17352"},"text":"§ 17352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and management of Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0359204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the executive branch a foundation to be known as the “International Clean Energy Foundation” that shall be responsible for carrying out the provisions of this part. The Foundation shall be a government corporation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s103"},"text":"section 103 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be governed by a Board of Directors in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress, in establishing the structure of the Foundation set forth in this subsection, to create an entity that serves the long-term foreign policy and energy security goals of reducing global greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Foundation a Chief Executive Officer who shall be responsible for the management of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035920a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be appointed by the Board, with the advice and consent of the Senate, and shall be a recognized leader in clean and efficient energy technologies and climate change and shall have experience in energy security, business, or foreign policy, chosen on the basis of a rigorous search.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035920b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall report to, and be under the direct authority of, the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035920c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and rank","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc035920d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be compensated at the rate provided for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035920e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035920f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be responsible for the management of the Foundation and shall exercise the powers and discharge the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to appoint officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation and with approval of the Board, the Chief Executive Officer shall appoint all officers of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0359212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Foundation a Board of Directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall perform the functions specified to be carried out by the Board in this part and may prescribe, amend, and repeal bylaws, rules, regulations, and procedures governing the manner in which the business of the Foundation may be conducted and in which the powers granted to it by law may be exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State (or the Secretary’s designee), the Secretary of Energy (or the Secretary’s designee), and the Administrator of the United States Agency for International Development (or the Administrator’s designee); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four other individuals with relevant experience in matters relating to energy security (such as individuals who represent institutions of energy policy, business organizations, foreign policy organizations, or other relevant organizations) who shall be appointed by the President, by and with the advice and consent of the Senate, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual shall be appointed from among a list of individuals submitted by the Majority Leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual shall be appointed from among a list of individuals submitted by the Minority Leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual shall be appointed from among a list of individuals submitted by the Majority Leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc035921a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual shall be appointed from among a list of individuals submitted by the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035921b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer of the Foundation shall serve as a nonvoting, ex officio member of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035921c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc035921d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of the Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board described in paragraph (3)(A) shall serve for a term that is concurrent with the term of service of the individual’s position as an officer within the other Federal department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035921e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board described in paragraph (3)(B) shall be appointed for a term of 3 years and may be reappointed for a term of an additional 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035921f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Board shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Board may be filled with an appointment of an acting member by the Chairperson of the Board for up to 1 year while a nominee is named and awaits confirmation in accordance with paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a Chairperson of the Board. The Secretary of State (or the Secretary’s designee) shall serve as the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Board described in paragraph (3) shall constitute a quorum, which, except with respect to a meeting of the Board during the 135-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", shall include at least 1 member of the Board described in paragraph (3)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at the call of the Chairperson, who shall call a meeting no less than once a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of the Federal Government","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board described in paragraph (3)(A) may not receive additional pay, allowances, or benefits by reason of the member’s service on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each such member of the Board shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), a member of the Board described in paragraph (3)(B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc035922a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid compensation out of funds made available for the purposes of this part at the daily equivalent of the highest rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for each day (including travel time) during which the member is engaged in the actual performance of duties as a member of the Board; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc035922b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while away from the member’s home or regular place of business on necessary travel in the actual performance of duties as a member of the Board, shall be paid per diem, travel, and transportation expenses in the same manner as is provided under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc035922c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17352/c/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board may not be paid compensation under clause (i)(II) for more than 90 days in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc035922d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s922"},"text":"Pub. L. 110–140, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1733"},"text":"121 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc035922e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc035922f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0359230-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s922"},"text":"section 922 of Pub. L. 110–140","children":[],"tail":". Subsec. (b)(4)(B) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s922"},"text":"section 922 of Pub. L. 110–140","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0359231-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0359232-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 20