{"tag":"section","attrib":{"id":"idbfd3e927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901"},"text":null,"children":[{"tag":"num","attrib":{"value":"14901"},"text":"§ 14901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd3e928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress recognizes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the international character of the Convention on Protection of Children and Co-operation in Respect of Intercountry Adoption (done at The Hague on ","children":[{"tag":"date","attrib":{"date":"1993-05-29"},"text":"May 29, 1993","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e92a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for uniform interpretation and implementation of the Convention in the United States and abroad,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and therefore finds that enactment of a Federal law governing adoptions and prospective adoptions subject to the Convention involving United States residents is essential.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e92b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for implementation by the United States of the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the rights of, and prevent abuses against, children, birth families, and adoptive parents involved in adoptions (or prospective adoptions) subject to the Convention, and to ensure that such adoptions are in the children’s best interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e92e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the ability of the Federal Government to assist United States citizens seeking to adopt children from abroad and residents of other countries party to the Convention seeking to adopt children from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd3e92f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/s2"},"text":"Pub. L. 106–279, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd3e930-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd3e931-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd3e932-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd3e933-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfd3e934-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Dates; Transition Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tV/s505"},"text":"Pub. L. 106–279, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/844"},"text":"114 Stat. 844","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/279/tV/s505"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Dates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions effective upon enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 2, 3, 101 through 103, 202 through 205, 401(a), 403, 503, and 505(a) [enacting this section and sections 14902, 14911 to 14913, 14922 to 14924, 14941(a), 14943, and 14953 of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions effective upon the entry into force of the convention","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the provisions of this Act not specified in paragraph (1) [enacting sections 14914, 14921, 14931, 14932, 14941(b), (c), 14942, 14944, 14951, 14952, and 14954 of this title, amending sections 1101 and 1154 of Title 8, Aliens and Nationality, and enacting provisions set out as notes under this section] shall take effect upon the entry into force of the Convention [Convention on Protection of Children and Co-operation in Respect of Intercountry Adoption] for the United States pursuant to Article 46(2)(a) of the Convention [The Convention entered into force for the United States on ","children":[{"tag":"date","attrib":{"date":"2008-04-01"},"text":"Apr. 1, 2008","children":[],"tail":".]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Convention and this Act [see Short Title note below] shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a child immigrating to the United States, if the application for advance processing of an orphan petition or petition to classify an orphan as an immediate relative for the child is filed before the effective date described in subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a child emigrating from the United States, if the prospective adoptive parents of the child initiated the adoption process in their country of residence with the filing of an appropriate application before the effective date described in subsection (a)(2).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbfd3e935-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/184/s1"},"text":"Pub. L. 116–184, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/897"},"text":"134 Stat. 897","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/184/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14914"},"text":"section 14914 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14914"},"text":"section 14914 of this title","children":[],"tail":"] may be cited as the ‘Intercountry Adoption Information Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbfd3e936-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/276/s1"},"text":"Pub. L. 112–276, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2466"},"text":"126 Stat. 2466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/276/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14925"},"text":"section 14925 of this title","children":[],"tail":", amending sections 14922 and 14943 of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14925"},"text":"section 14925 of this title","children":[],"tail":"] may be cited as the ‘Intercountry Adoption Universal Accreditation Act of 2012’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfd3e937-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/s1/a"},"text":"Pub. L. 106–279, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/279/s1/a"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":" and sections 1101 and 1154 of Title 8, Aliens and Nationality] may be cited as the ‘Intercountry Adoption Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
