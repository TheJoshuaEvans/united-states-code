{"tag":"section","attrib":{"id":"idbfebb6e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952"},"text":null,"children":[{"tag":"num","attrib":{"value":"15952"},"text":"§ 15952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State regulatory coordination and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfebb6e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Governor of a State, the Administrator may enter into a refinery permitting cooperative agreement with the State, under which each party to the agreement identifies steps, including timelines, that it will take to streamline the consideration of Federal and State environmental permits for a new refinery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfebb6e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority under agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall be authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfebb6e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept from a refiner a consolidated application for all permits required from the Environmental Protection Agency, to the extent consistent with other applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into memoranda of agreement with other Federal agencies to coordinate consideration of refinery applications and permits among Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfebb6e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into memoranda of agreement with a State, under which Federal and State review of refinery permit applications will be coordinated and concurrently considered, to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee27e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to provide financial assistance to State governments to facilitate the hiring of additional personnel with expertise in fields relevant to consideration of refinery permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee27e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15952/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to provide technical, legal, or other assistance to State governments to facilitate their review of applications to build new refineries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee27e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s392"},"text":"Pub. L. 109–58, title III, § 392","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/749"},"text":"119 Stat. 749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
