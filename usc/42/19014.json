{"tag":"section","attrib":{"id":"idc075f521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014"},"text":null,"children":[{"tag":"num","attrib":{"value":"19014"},"text":"§ 19014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding geographic and institutional diversity in research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc075f522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing support for EPSCoR","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because maintaining the Nation’s scientific and economic leadership requires the participation of talented individuals nationwide, EPSCoR investments into State research and education capacities are in the Federal interest and should be sustained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" EPSCoR should maintain its experimental component by supporting innovative methods for improving research capacity and competitiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director should carry out this subsection while maintaining or increasing proposal success rates at emerging research institutions throughout the United States and without precluding access to awards for such institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity and inclusion","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, not less than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f52a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15.5 percent in fiscal year 2023,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f52b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 16 percent in fiscal year 2024,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f52c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 16.5 percent in fiscal year 2025,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f52d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 17 percent in fiscal year 2026,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f52e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 percent in fiscal year 2027,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f52f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 19 percent in fiscal year 2028, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent in fiscal year 2029,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the amounts appropriated to the Foundation for research and related activities, and science, mathematics, and engineering education and human resources programs and activities, excluding those amounts made available for polar research and operations support (and operations and maintenance of research facilities), shall be awarded to EPSCoR institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, not less than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 16 percent in fiscal year 2023,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 percent in fiscal year 2024, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f534-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent in each of fiscal years 2025 through 2029,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"of the amounts appropriated to the Foundation for scholarships (including at community colleges), graduate fellowships and traineeships, and postdoctoral awards shall be used to support EPSCoR institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall consider prioritizing funding and activities that enable sustainable growth in the competitiveness of EPSCoR jurisdictions, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure investments to build research capacity in EPSCoR jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarships, fellowships, and traineeships within new and existing programs, to promote the development of sustainable research and academic personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnerships between eligible organizations in EPSCoR and non-EPSCoR jurisdictions, to develop administrative, grant management, and proposal writing capabilities in EPSCoR jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capacity building activities for emerging research institutions, historically Black colleges and universities, Tribal Colleges or Universities, and minority serving institutions, consistent with this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19183"},"text":"section 19183 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f53a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging the Partnerships for Innovation program, as well as the Foundation coordination role in the Department of Commerce technology and innovation hub program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a"},"text":"section 3722a of title 15","children":[],"tail":" as added by section 10621, to build sustainable innovation ecosystems in EPSCoR jurisdictions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f53b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall achieve the percentages specified in this paragraph to the maximum extent practicable, consistent with the National Science Foundation merit review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f53c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an award to a consortium, the Director may count the entire award toward meeting the funding requirements of subparagraph (A) if the lead entity of the consortium is located in an EPSCoR institution ","children":[{"tag":"ref","attrib":{"idref":"fn004387"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004387"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f53d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with the fiscal year 2023, the Director shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f53e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Foundation’s implementation of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f53f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress in building research capacity, including both infrastructure and personnel, in EPSCoR jurisdictions, including at historically Black colleges and universities, Tribal Colleges or Universities, minority-serving institutions, and emerging research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Foundation does not meet the requirement described in subparagraph (A), an explanation relating thereto and a plan for compliance in the following fiscal year and remediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and sustainability report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":", the Director shall submit to Congress a report containing an analysis of the impacts of the requirements under subparagraphs (A) and (B). The report shall include—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc075f542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of how the requirements under this paragraph affected the balance of total funding awarded by the Foundation to states and territories across the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any changes in award success and total funding awarded to Historically black colleges and universities, Tribal Colleges or Universities, minority-serving institutions, and emerging research institutions between ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the gains in academic research capacity, quality, and competitiveness and in science and technology human resource development in EPSCoR jurisdictions made between ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of EPSCoR eligibility criteria and determination on whether new eligibility criteria should be developed based on the findings from clauses (i), (ii), and (iii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/G/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to sustain and grow improvements in research capacity and competitiveness in EPSCoR jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPSCoR eligibility","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure eligibility for current EPSCoR jurisdictions for five years from ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", after which the Director shall determine whether new eligibility criteria should be developed based on the findings in the report required under subparagraph (G)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/a/3/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":", the Director shall report to Congress regarding any new eligibility criteria determined under clause (i), any changes to jurisdictional eligibility based on such criteria, and the necessity and practicality of continuing or modifying the requirement under subparagraph (A) given any such changes to eligibility. The report shall include an analysis of options to support regions in non-EPSCoR jurisdictions, adjacent to EPSCoR jurisdictions, that historically receive disproportionately low levels of funding from the Foundation, including, if appropriate, options to expand the EPSCoR program or to establish new programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc075f54a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fostering STEM research diversity and capacity program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f54b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make awards on a competitive, merit-reviewed basis to eligible institutions to implement and study innovative approaches for building research capacity in order to engage and retain students from a range of institutions and diverse backgrounds in STEM.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f54c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institution defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection the term “eligible institution” means an institution of higher education that, according to the data published by the National Center for Science and Engineering Statistics, is not, on average, among the top 100 institutions in Federal research and development expenditures during the 3-year period prior to the year of the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f54d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities under this subsection shall be focused on achieving simultaneous impacts at the student, faculty, and institutional levels by increasing the research capacity at eligible institutions and the number of undergraduate and graduate students pursuing STEM degrees from eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f54e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this program, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f54f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require eligible institutions seeking funding under this subsection to submit an application to the Director at such time, in such manner, containing such information and assurances as the Director may require. The application shall include, at a minimum a description of how the eligible institution plans to sustain the proposed activities beyond the duration of the award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f550-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require applicants to identify disciplines and focus areas in which the eligible institution can excel, and explain how the applicant will use the award to build capacity to bolster the institutional research competitiveness of eligible entities to support awards made by the Foundation and increase regional and national capacity in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f551-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the awards funded under this subsection to support research and related activities, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc075f552-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development or expansion of research programs in disciplines and focus areas in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f553-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty recruitment and professional development in disciplines and focus areas in subparagraph (B), including for early-career researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f554-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipends for undergraduate and graduate students participating in research in disciplines and focus areas in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f555-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of instrumentation necessary to build research capacity at an eligible institution in disciplines and focus areas in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f556-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of capacity-building and research infrastructure needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f557-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative research development support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc075f558-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities necessary to build research capacity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that no eligible institution should receive more than $10,000,000 in any single year of funds made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f55a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this subsection, the Director may also consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f55b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant will support students from diverse backgrounds, including first-generation undergraduate students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f55c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic and institutional diversity of the applying institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f55d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the applicants can leverage public-private partnerships and existing partnerships with Federal Research Agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f55e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure the awards made under this subsection are complementary and not duplicative of existing programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f55f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit a report to Congress after the third year of the program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the program for growing the geographic and institutional diversity of institutions of higher education receiving research awards from the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the quality, quantity, and geographic and institutional diversity of institutions of higher education conducting Foundation-sponsored research since the establishment of the program in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the quantity and diversity of undergraduate and graduate students graduating from eligible institutions with STEM degrees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical summary data on the program, including the geographic and institutional allocation of award funding, the number and diversity of supported graduate and undergraduate students, and how it contributes to capacity building at eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Director $150,000,000 for each of the fiscal years 2023 through 2027 to carry out the activities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc075f565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships with emerging research institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc075f566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a five-year pilot program for awards to research partnerships that involve emerging research institutions and may involve institutions classified as very high research activity by the Carnegie Classification of Institutions of Higher Education at the time of application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this program, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that each proposal submitted by a multi-institution collaboration for an award, including those under part G of this subchapter, that exceeds $1,000,000, as appropriate, specify how the applicants will support substantive, meaningful, sustainable, and mutually beneficial partnerships with one or more emerging research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require recipients funded under this subsection to direct no less than 35 percent of the total award to one or more emerging research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f56a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require recipients funded under this subsection to report on the partnership activities as part of the annual reporting requirements of the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f56b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit feedback on the partnership directly from partner emerging research institutions, in such form as the Director deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f56c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity building","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds awarded to emerging research institutions under this subsection may be used to build research capacity, including through support for faculty salaries and training, field and laboratory research experiences for undergraduate and graduate students, and maintenance and repair of research equipment and instrumentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc075f56d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit a report to Congress after the third year of the pilot program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc075f56e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment, drawing on feedback from the research community and other sources of information, of the effectiveness of the pilot program for improving the quality of partnerships with emerging research institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc075f56f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19014/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if deemed effective, a plan for permanent implementation of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc075f570-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10325"},"text":"Pub. L. 117–167, div. B, title III, § 10325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1539"},"text":"136 Stat. 1539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc075f571-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc075f572-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc075f573-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10621, referred to in subsec. (a)(3)(C)(v), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10621"},"text":"section 10621 of div. B of Pub. L. 117–167","children":[],"tail":", which enacted sections 3722a and 3722b of Title 15, Commerce and Trade, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3723"},"text":"section 3723 of Title 15","children":[],"tail":", and enacted provisions set out as notes under sections 3722a and 3722b of Title 15."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", referred to in subsec. (a)(3)(G)(ii), (iii), was in the original “the date of enactment” in cl. (ii) and “the enactment of this Act” in cl. (iii), and both instances were translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc075f574-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10325"},"text":"section 10325 of div. B of Pub. L. 117–167","children":[],"tail":". Subsec. (a)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/s10325"},"text":"section 10325 of div. B of Pub. L. 117–167","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p–9"},"text":"section 1862p–9 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
