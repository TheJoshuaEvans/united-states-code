{"tag":"section","attrib":{"id":"idbd762258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249"},"text":null,"children":[{"tag":"num","attrib":{"value":"6249"},"text":"§ 6249.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting for petroleum product and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd762259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the other provisions of this part, the Secretary may contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd76225a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for storage, in otherwise unused Strategic Petroleum Reserve facilities, of petroleum product not owned by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76225b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for storage, in storage facilities other than those of the Reserve, of petroleum product either owned or not owned by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd76225c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd76225d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petroleum product stored pursuant to such a contract shall, until the expiration, termination, or other conclusion of the contract, be a part of the Reserve and subject to the Secretary’s authority under part B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76225e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may enter into a contract for storage of petroleum product under subsection (a) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd76225f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines (i) that entering into one or more contracts under such subsection would achieve benefits comparable to the acquisition of an equivalent amount of petroleum product, or an equivalent volume of storage capacity, for the Reserve under part B, and (ii) that, because of budgetary constraints, the acquisition of an equivalent amount of petroleum product or volume of storage space for the Reserve cannot be accomplished under part B; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd762260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary notifies each House of the Congress of the determination and identifies in the notification the location, type, and ownership of storage and related facilities proposed to be included, or the volume, type, and ownership of petroleum products proposed to be stored, in the Reserve, and an estimate of the proposed benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd762261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under subsection (a) shall not limit the discretion of the President or the Secretary to conduct a drawdown and sale of petroleum products from the Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd762262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under subsection (a) shall include a provision that the obligation of the United States to make payments under the contract in any fiscal year is subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd762263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charge for storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may store petroleum product pursuant to a contract entered into under subsection (a)(1) with or without charge or may pay a fee for its storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd762264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts entered into under subsection (a) may be of such duration as the Secretary considers necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd762265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding arbitration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may agree to binding arbitration of disputes under any contract entered into under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd762266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6249/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may utilize such funds as are available in the SPR Petroleum Account to carry out the activities described in subsection (a), and may obligate and expend such funds to carry out such activities, in advance of the receipt of petroleum products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd762267-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s171"},"text":"Pub. L. 94–163, title I, § 171","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/383/s6/a/4"},"text":"Pub. L. 101–383, § 6(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-15"},"text":"Sept. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/729"},"text":"104 Stat. 729","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIV/s1403"},"text":"Pub. L. 102–486, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2994"},"text":"106 Stat. 2994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/20"},"text":"Pub. L. 106–469, title I, § 103(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2033"},"text":"114 Stat. 2033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd762268-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd762269-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd76226a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/s171"},"text":"section 171 of Pub. L. 94–163","children":[],"tail":" was renumbered section 191 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6251"},"text":"section 6251 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd76226b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/20/A"},"text":"Pub. L. 106–469, § 103(20)(A)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “the Secretary notifies each House of the Congress of such determination and includes in such notification the same information required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6234/e"},"text":"section 6234(e) of this title","children":[],"tail":" with regard to storage and related facilities proposed to be included, or petroleum product proposed to be stored, in the Reserve.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/20/B"},"text":"Pub. L. 106–469, § 103(20)(B)","children":[],"tail":", substituted “sale of petroleum products from” for “distribution of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
