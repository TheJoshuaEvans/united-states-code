{"tag":"section","attrib":{"id":"idc0013b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278"},"text":null,"children":[{"tag":"num","attrib":{"value":"16278"},"text":"§ 16278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enabling nuclear energy innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0013b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Reactor Innovation Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized a program to enable the testing and demonstration of reactor concepts to be proposed and funded, in whole or in part, by the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary shall leverage the technical expertise of relevant Federal agencies and the National Laboratories in order to minimize the time required to enable construction and operation of privately funded experimental reactors at National Laboratories or other Department-owned sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reactors described in subsection (b) shall operate to meet the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enabling physical validation of advanced nuclear reactor concepts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Resolving technical uncertainty and increasing practical knowledge relevant to safety, resilience, security, and functionality of advanced nuclear reactor concepts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General research and development to improve nascent technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing technical expertise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary may enter into a memorandum of understanding with the Chairman of the Commission in order to share technical expertise and knowledge through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling the testing and demonstration of advanced nuclear reactor concepts to be proposed and funded, in whole or in part, by the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating a database to store and share data and knowledge relevant to nuclear science and engineering between Federal agencies and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and testing electric and nonelectric integration and energy conversion systems relevant to advanced nuclear reactors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging expertise from the Commission with respect to safety analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003846a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling technical staff of the Commission to actively observe and learn about technologies developed under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc003846b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman of the Commission and the Secretary shall enter into a memorandum of understanding regarding the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc003846c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensuring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc003846d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department has sufficient technical expertise to support the timely research, development, demonstration, and commercial application by the civilian nuclear industry of safe and innovative advanced nuclear reactor technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003846e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission has sufficient technical expertise to support the evaluation of applications for licenses, permits, and design certifications and other requests for regulatory approval for advanced nuclear reactors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003846f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of computers and software codes to calculate the behavior and performance of advanced nuclear reactors based on mathematical models of the physical behavior of advanced nuclear reactors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensuring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0038471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department maintains and develops the facilities necessary to enable the timely research, development, demonstration, and commercial application by the civilian nuclear industry of safe and innovative reactor technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission has access to the facilities described in subparagraph (A), as needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0038473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0038474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":", the Secretary, in consultation with the National Laboratories, relevant Federal agencies, and other stakeholders, shall submit to the appropriate committees of Congress a report assessing the capabilities of the Department to authorize, host, and oversee privately funded experimental advanced nuclear reactors as described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0038476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety review and oversight capabilities of the Department, including options to leverage expertise from the Commission and the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options to regulate privately proposed and funded experimental reactors hosted by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential sites capable of hosting privately funded experimental advanced nuclear reactors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0038479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficacy of the available contractual mechanisms of the Department to partner with the private sector and Federal agencies, including cooperative research and development agreements, strategic partnership projects, and agreements for commercializing technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003847a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liability of the Federal Government with respect to the disposal of low-level radioactive waste, spent nuclear fuel, or high-level radioactive waste (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101"},"text":"section 10101 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003847b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on the aggregate inventory in the United States of low-level radioactive waste, spent nuclear fuel, or high-level radioactive waste (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101"},"text":"section 10101 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003847c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential cost structures relating to physical security, decommissioning, liability, and other long-term project costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc003847d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other challenges or considerations identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003847e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once every 2 years, the Secretary shall update relevant provisions of the report submitted under paragraph (1) and submit to the appropriate committees of Congress the update.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc003847f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clauses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0038480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the Secretary or any person to construct or operate a nuclear reactor for the purpose of demonstrating the suitability for commercial application of the nuclear reactor unless licensed by the Commission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5842"},"text":"section 5842 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16278/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any activity carried out under this section that involves the risk of public liability shall be subject to the financial protection or indemnification requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"section 2210 of this title","children":[],"tail":" (commonly known as the “Price-Anderson Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0038482-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s958"},"text":"Pub. L. 109–58, title IX, § 958","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/h"},"text":"Pub. L. 115–248, § 2(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3157"},"text":"132 Stat. 3157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
