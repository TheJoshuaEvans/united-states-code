{"tag":"section","attrib":{"id":"idbcb4f641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101d"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101d"},"text":"§ 4101d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood insurance rate map certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall implement a flood mapping program for the National Flood Insurance Program, only after review by the Technical Mapping Advisory Council, that, when applied, results in technically credible flood hazard data in all areas where Flood Insurance Rate Maps are prepared or updated, shall certify in writing to the Congress when such a program has been implemented, and shall provide to the Congress the Technical Mapping Advisory Council review report.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcb4f642-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s17"},"text":"Pub. L. 113–89, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1027"},"text":"128 Stat. 1027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb4f643-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb4f644-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcb4f645-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Homeowner Flood Insurance Affordability Act of 2014, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcb4f646-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcb4f647-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4005"},"text":"section 4005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
