{"tag":"section","attrib":{"id":"idbb436499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1716"},"text":null,"children":[{"tag":"num","attrib":{"value":"1716"},"text":"§ 1716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of death or detention","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A determination that an individual is dead or a determination that he has been detained by a hostile force or person may be made on the basis of evidence that he has disappeared under circumstances such as to make such death or detention appear probable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb43649a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1942-12-02/ch668"},"text":"Dec. 2, 1942, ch. 668","children":[],"tail":", title II, § 206, "},{"tag":"ref","attrib":{"href":"/us/stat/56/1034"},"text":"56 Stat. 1034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/608/tI/s104"},"text":"Pub. L. 85–608, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/537"},"text":"72 Stat. 537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb43649b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb43649c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb43649d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/608"},"text":"Pub. L. 85–608","children":[],"tail":" substituted “a hostile force or person” for “the enemy”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb43649e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb43649f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/608"},"text":"Pub. L. 85–608","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/608/s402"},"text":"section 402 of Pub. L. 85–608","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"section 1651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
