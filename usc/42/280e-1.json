{"tag":"section","attrib":{"id":"idb530d34a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"280e–1"},"text":"§ 280e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants regarding registries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb530d34b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb530d34c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control, may make grants to States for the purpose of developing plans that meet the assurances required by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280e/c/2"},"text":"section 280e(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb530d34d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose described in paragraph (1), the Secretary may make grants to public entities other than States and to nonprofit private entities. Such a grant may be made to an entity only if the State in which the purpose is to be carried out has certified that the State approves the entity as qualified to carry out the purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb530d34e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a grant under subsection (a) only if an application for the grant is submitted to the Secretary, the application contains the certification required in subsection (a)(2) (if the application is for a grant under such subsection), and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb530d34f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399C, formerly § 399I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/515/s3"},"text":"Pub. L. 102–515, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3375"},"text":"106 Stat. 3375","children":[],"tail":"; renumbered § 399C, "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tV/s502/2/A"},"text":"Pub. L. 106–310, div. A, title V, § 502(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1115"},"text":"114 Stat. 1115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb530d350-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb530d351-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb530d352-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Centers for Disease Control changed to Centers for Disease Control and Prevention by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312"},"text":"Pub. L. 102–531, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3504"},"text":"106 Stat. 3504","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
