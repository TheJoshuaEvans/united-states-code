{"tag":"section","attrib":{"id":"idbf31b565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10823"},"text":null,"children":[{"tag":"num","attrib":{"value":"10823"},"text":"§ 10823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments under allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary shall make payments to each eligible system from its allotment under this subchapter. Any amount paid to an eligible system for a fiscal year and remaining unobligated at the end of such year shall remain available to such system for the next fiscal year for the purposes for which it was made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf31b566-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s113"},"text":"Pub. L. 99–319, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/484"},"text":"100 Stat. 484","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
