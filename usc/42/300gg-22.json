{"tag":"section","attrib":{"id":"idb6ae7357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–22"},"text":"§ 300gg–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ae7358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ae7359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to section 300gg–23 ","children":[{"tag":"ref","attrib":{"idref":"fn002467"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002467"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, each State may require that health insurance issuers that issue, sell, renew, or offer health insurance coverage in the State in the individual or group market meet the requirements of this part and part D (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–121"},"text":"section 300gg–121 of this title","children":[],"tail":") with respect to such issuers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ae735a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to implement provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a determination by the Secretary that a State has failed to substantially enforce a provision (or provisions) in this part or part D (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–121"},"text":"section 300gg–121 of this title","children":[],"tail":") with respect to health insurance issuers in the State, the Secretary shall enforce such provision (or provisions) under subsection (b) insofar as they relate to the issuance, sale, renewal, and offering of health insurance coverage in connection with group health plans or individual health insurance coverage in such State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b0bc4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial enforcement authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b0bc4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subsection shall apply to enforcement of a provision (or provisions) of this part or part D (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–121"},"text":"section 300gg–121 of this title","children":[],"tail":") only—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bc4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to individual health insurance coverage or group health plans that are non-Federal governmental plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bc4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the cases described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bc50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the succeeding provisions of this subsection, any non-Federal governmental plan that is a group health plan and any health insurance issuer that fails to meet a provision of this part or part D (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–121"},"text":"section 300gg–121 of this title","children":[],"tail":") applicable to such plan or issuer is subject to a civil money penalty under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a failure by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health insurance issuer, the issuer is liable for such penalty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a group health plan that is a non-Federal governmental plan which is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsored by 2 or more employers, the plan is liable for such penalty, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not so sponsored, the employer is liable for such penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount of penalty imposed under this paragraph is $100 for each day for each individual with respect to which such a failure occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in imposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of any penalty to be assessed under this paragraph, the Secretary shall take into account the previous record of compliance of the entity being assessed with the applicable provisions of this part and part D (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–121"},"text":"section 300gg–121 of this title","children":[],"tail":") and the gravity of the violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty not to apply where failure not discovered exercising reasonable diligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No civil money penalty shall be imposed under this paragraph on any failure during any period for which it is established to the satisfaction of the Secretary that none of the entities against whom the penalty would be imposed knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty not to apply to failures corrected within 30 days","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No civil money penalty shall be imposed under this paragraph on any failure if such failure was due to reasonable cause and not to willful neglect, and such failure is corrected during the 30-day period beginning on the first day any of the entities against whom the penalty would be imposed knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative review","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entity assessed shall be afforded an opportunity for hearing by the Secretary upon request made within 30 days after the date of the issuance of a notice of assessment. In such hearing the decision shall be made on the record pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":". If no hearing is requested, the assessment shall constitute a final and unappealable order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a hearing is requested, the initial agency decision shall be made by an administrative law judge, and such decision shall become the final order unless the Secretary modifies or vacates the decision. Notice of intent to modify or vacate the decision of the administrative law judge shall be issued to the parties within 30 days after the date of the decision of the judge. A final order which takes effect under this paragraph shall be subject to review only as provided under subparagraph (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of action for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any entity against whom an order imposing a civil money penalty has been entered after an agency hearing under this paragraph may obtain review by the United States district court for any district in which such entity is located or the United States District Court for the District of Columbia by filing a notice of appeal in such court within 30 days from the date of such order, and simultaneously sending a copy of such notice by registered mail to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of administrative record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly certify and file in such court the record upon which the penalty was imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The findings of the Secretary shall be set aside only if found to be unsupported by substantial evidence as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706/2/E"},"text":"section 706(2)(E) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any final decision, order, or judgment of the district court concerning such review shall be subject to appeal as provided in chapter 83 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay assessment; maintenance of action","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to pay assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any entity fails to pay an assessment after it has become a final and unappealable order, or after the court has entered final judgment in favor of the Secretary, the Secretary shall refer the matter to the Attorney General who shall recover the amount assessed by action in the appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In such action the validity and appropriateness of the final order imposing the penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, penalties collected under this paragraph shall be paid to the Secretary (or other officer) imposing the penalty and shall be available without appropriation and until expended for the purpose of enforcing the provisions with respect to which the penalty was imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b0bc68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority relating to genetic discrimination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b0bc69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the cases described in paragraph (1), notwithstanding the provisions of paragraph (2)(C), the succeeding subparagraphs of this paragraph shall apply with respect to an action under this subsection by the Secretary with respect to any failure of a health insurance issuer in connection with a group health plan, to meet the requirements of subsection (a)(1)(F), (b)(3), (c), or (d) of section 2702 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or section 2701 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or 2702(b)(1) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" with respect to genetic information in connection with the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty imposed under this paragraph shall be $100 for each day in the noncompliance period with respect to each participant or beneficiary to whom such failure relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this paragraph, the term “noncompliance period” means, with respect to any failure, the period—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date such failure first occurs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date the failure is corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum penalties where failure discovered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding clauses (i) and (ii) of subparagraph (D):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of 1 or more failures with respect to an individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are not corrected before the date on which the plan receives a notice from the Secretary of such violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which occurred or continued during the period involved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" the amount of penalty imposed by subparagraph (A) by reason of such failures with respect to such individual shall not be less than $2,500.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher minimum penalty where violations are more than de minimis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent violations for which any person is liable under this paragraph for any year are more than de minimis, clause (i) shall be applied by substituting “$15,000” for “$2,500” with respect to such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b0bc75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty not to apply where failure not discovered exercising reasonable diligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be imposed by subparagraph (A) on any failure during any period for which it is established to the satisfaction of the Secretary that the person otherwise liable for such penalty did not know, and exercising reasonable diligence would not have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty not to apply to failures corrected within certain periods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No penalty shall be imposed by subparagraph (A) on any failure if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure was due to reasonable cause and not to willful neglect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such failure is corrected during the 30-day period beginning on the first date the person otherwise liable for such penalty knew, or exercising reasonable diligence would have known, that such failure existed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b0bc79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limitation for unintentional failures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of failures which are due to reasonable cause and not to willful neglect, the penalty imposed by subparagraph (A) for failures shall not exceed the amount equal to the lesser of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b0bc7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the aggregate amount paid or incurred by the employer (or predecessor employer) during the preceding taxable year for group health plans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b0bc7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b0bc7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–22/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure which is due to reasonable cause and not to willful neglect, the Secretary may waive part or all of the penalty imposed by subparagraph (A) to the extent that the payment of such penalty would be excessive relative to the failure involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"ta