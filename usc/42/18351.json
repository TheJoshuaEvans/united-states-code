{"tag":"section","attrib":{"id":"idc054b1cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351"},"text":null,"children":[{"tag":"num","attrib":{"value":"18351"},"text":"§ 18351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of the International Space Station","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc054b1ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the policy of the United States, in consultation with its international partners in the ISS program, to support full and complete utilization of the ISS through at least ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b1cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NASA action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of the policy set forth in subsection (a), NASA shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b1d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue international, commercial, and intragovernmental means to maximize ISS logistics supply, maintenance, and operational capabilities, reduce risks to ISS systems sustainability, and offset and minimize United States operations costs relating to the ISS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, to the extent practicable, the ISS for the development of capabilities and technologies needed for the future of human space exploration beyond low-Earth orbit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, if practical and cost effective, the ISS for Science Mission Directorate missions in low-Earth orbit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fbc3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tV/s501"},"text":"Pub. L. 111–267, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2822"},"text":"124 Stat. 2822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s114/b/1"},"text":"Pub. L. 114–90, title I, § 114(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/715"},"text":"129 Stat. 715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/10/tIII/s301/c"},"text":"Pub. L. 115–10, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-03-21"},"text":"Mar. 21, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/23"},"text":"131 Stat. 23","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10815/a"},"text":"Pub. L. 117–167, div. B, title VII, § 10815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1737"},"text":"136 Stat. 1737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc056fbc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc056fbc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc056fbc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"” for “2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/10"},"text":"Pub. L. 115–10","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Policy of the United States","children":[],"tail":".—It shall be the policy of the United States, in consultation with its international partners in the ISS program, to support full and complete utilization of the ISS through at least 2024."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"NASA Actions","children":[],"tail":".—In furtherance of the policy set forth in subsection (a), NASA shall pursue international, commercial, and intragovernmental means to maximize ISS logistics supply, maintenance, and operational capabilities, reduce risks to ISS systems sustainability, and offset and minimize United States operations costs relating to the ISS.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b/1/A"},"text":"Pub. L. 114–90, § 114(b)(1)(A)","children":[],"tail":", struck out “through 2020” after “Station” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s114/b/1/B"},"text":"Pub. L. 114–90, § 114(b)(1)(B)","children":[],"tail":", substituted “through at least 2024” for “through at least 2020”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
