{"tag":"section","attrib":{"id":"idbf4983b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11388"},"text":null,"children":[{"tag":"num","attrib":{"value":"11388"},"text":"§ 11388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit a report to the Congress annually, summarizing the activities carried out under this part and setting forth the findings, conclusions, and recommendations of the Secretary as a result of the activities. The report shall be submitted not later than 4 months after the end of each fiscal year (except that, in the case of fiscal year 1993, the report shall be submitted not later than 6 months after the end of the fiscal year).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf4983b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s434"},"text":"Pub. L. 100–77, title IV, § 434","children":[],"tail":", formerly § 428, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/a"},"text":"Pub. L. 102–550, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4021"},"text":"106 Stat. 4021","children":[],"tail":"; renumbered § 433, "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1305/2"},"text":"Pub. L. 111–22, div. B, title III, § 1305(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1690"},"text":"123 Stat. 1690","children":[],"tail":"; renumbered § 434, "},{"tag":"ref","attrib":{"href":"/us/pl/114/201/tIV/s401/a/1"},"text":"Pub. L. 114–201, title IV, § 401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib"