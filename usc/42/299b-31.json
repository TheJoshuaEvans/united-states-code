{"tag":"section","attrib":{"id":"idb60512e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–31"},"text":"§ 299b–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality measure development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb60512e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subpart, the term “quality measure” means a standard for measuring the performance and improvement of population health or of health plans, providers of services, and other clinicians in the delivery of health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60512e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of quality measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60512e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Director of the Agency for Healthcare Research and Quality and the Administrator of the Centers for Medicare & Medicaid Services, shall identify, not less often than triennially, gaps where no quality measures exist and existing quality measures that need improvement, updating, or expansion, consistent with the national strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280j"},"text":"section 280j of this title","children":[],"tail":", to the extent available, for use in Federal health programs. In identifying such gaps and existing quality measures that need improvement, the Secretary shall take into consideration—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60512e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gaps identified by the entity with a contract under section 1890(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/a"},"text":"42 U.S.C. 1395aaa(a)","children":[],"tail":"] and other stakeholders;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality measures identified by the pediatric quality measures program under section 1139A of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9a"},"text":"42 U.S.C. 1320b–9a","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality measures identified through the Medicaid Quality Measurement Program under section 1139B of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9b"},"text":"42 U.S.C. 1320b–9b","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60512e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the public on an Internet website a report on any gaps identified under paragraph (1) and the process used to make such identification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60512e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or contracts for quality measure development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60512e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants, contracts, or intergovernmental agreements to eligible entities for purposes of developing, improving, updating, or expanding quality measures identified under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60512ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization in the development of quality measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, or agreements under this subsection, the Secretary shall give priority to the development of quality measures that allow the assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60512eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health outcomes and functional status of patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and coordination of health care across episodes of care and care transitions for patients across the continuum of providers, health care settings, and health plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience, quality, and use of information provided to and used by patients, caregivers, and authorized representatives to inform decisionmaking about treatment options, including the use of shared decisionmaking tools and preference sensitive care (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–36"},"text":"section 299b–36 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the meaningful use of health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety, effectiveness, patient-centeredness, appropriateness, and timeliness of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficiency of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the equity of health services and health disparities across health disparity populations (as defined in section 285t ","children":[{"tag":"ref","attrib":{"idref":"fn002315"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002315"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) and geographic areas;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient experience and satisfaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of innovative strategies and methodologies identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–33"},"text":"section 299b–33 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60512f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant or contract under this subsection, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60512f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated expertise and capacity in the development and evaluation of quality measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have adopted procedures to include in the quality measure development process—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60512f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of those providers or payers whose performance will be assessed by the measure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60512f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of other parties who also will use the quality measures (such as patients, consumers, and health care purchasers);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the entity with a contract under section 1890(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/a"},"text":"42 U.S.C. 1395aaa(a)","children":[],"tail":"] and other stakeholders, as practicable, and the Secretary so that quality measures developed by the eligible entity will meet the requirements to be considered for endorsement by the entity with a contract under such section 1890(a);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have transparent policies regarding governance and conflicts of interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Secretary at such time and in such manner, as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60512fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that receives a grant, contract, or agreement under this subsection shall use such award to develop quality measures that meet the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60512fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such measures support measures required to be reported under the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.], where applicable, and in support of gaps and existing quality measures that need improvement, as described in subsection (b)(1)(A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60512ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such measures support measures developed under section 1139A of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9a"},"text":"42 U.S.C. 1320b–9a","children":[],"tail":"] and the Medicaid Quality Measurement Program under section 1139B of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–9b"},"text":"42 U.S.C. 1320b–9b","children":[],"tail":"], where applicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, data on such quality measures is able to be collected using health information technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each quality measure is free of charge to users of such measure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each quality measure is publicly available on an Internet website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use amounts available under this section to update and test, where applicable, quality measures endorsed by the entity with a contract under section 1890(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395aaa/a"},"text":"42 U.S.C. 1395aaa(a)","children":[],"tail":"] or adopted by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that grants or contracts awarded under this section are coordinated with grants and contracts awarded under sections 1139A(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002316"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002316"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The subsection designation is missing."}],"tail":" and 1139B(4)(A) "},{"tag":"ref","attrib":{"idref":"fn002316"},"text":"2","children":[],"tail":" of the Social Security Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of outcome measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6051306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop, and periodically update (not less than every 3 years), provider-level outcome measures for hospitals and physicians, as well as other providers as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6051307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories of measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The measures developed under this subsection shall include, to the extent determined appropriate by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6051308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcome measurement for acute and chronic diseases, including, to the extent feasible, the 5 most prevalent and resource-intensive acute and chronic medical conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051309-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcome measurement for primary and preventative care, including, to the extent feasible, measurements that cover provision of such care for distinct patient populations (such as healthy children, chronically ill adults, or infirm elderly individuals).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb605130a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing such measures, the Secretary shall seek to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb605130b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address issues regarding risk adjustment, accountability, and sample size;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb605130c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the full scope of services that comprise a cycle of care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb605130d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include multiple dimensions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb605130e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeframe","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb605130f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–31/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acute and chronic diseases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":","},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Secretary shall develop not less than 10 