{"tag":"section","attrib":{"id":"idc030d74c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242"},"text":null,"children":[{"tag":"num","attrib":{"value":"17242"},"text":"§ 17242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial insulation demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc030d74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced insulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced insulation” means insulation that has an R value of not less than R35 per inch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered refrigeration unit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered refrigeration unit” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial refrigerated truck;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial refrigerated trailer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial refrigerator, freezer, or refrigerator-freezer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6313/c"},"text":"section 6313(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall submit to Congress a report that includes an evaluation of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the state of technological advancement of advanced insulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected amount of cost savings that would be generated by implementing advanced insulation into covered refrigeration units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines in the report described in subsection (b) that the implementation of advanced insulation into covered refrigeration units would generate an economically justifiable amount of cost savings, the Secretary, in cooperation with manufacturers of covered refrigeration units, shall establish a demonstration program under which the Secretary shall demonstrate the cost-effectiveness of advanced insulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for a period of up to 5 years after an award is granted under the demonstration program, exempt from mandatory disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (popularly known as the Freedom of Information Act) information that the Secretary determines would be a privileged or confidential trade secret or commercial or financial information under subsection (b)(4) of such section if the information had been obtained from a non-Government party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"Section 16352 of this title","children":[],"tail":" shall apply to any project carried out under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d75a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $8,000,000 for the period of fiscal years 2009 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc030d75b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s652"},"text":"Pub. L. 110–140, title VI, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1694"},"text":"121 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc030d75c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc030d75d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc030d75e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
