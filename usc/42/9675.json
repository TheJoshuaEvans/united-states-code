{"tag":"section","attrib":{"id":"idbed983d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675"},"text":null,"children":[{"tag":"num","attrib":{"value":"9675"},"text":"§ 9675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of securities laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed983d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ownership interests of members of a risk retention group shall be considered to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed983d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempted securities for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77e"},"text":"section 77e of title 15","children":[],"tail":" and for purposes of section 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 15; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed983da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securities for purposes of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77q"},"text":"section 77q of title 15","children":[],"tail":" and the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j"},"text":"section 78j of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment Company Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A risk retention group shall not be considered to be an investment company for purposes of the Investment Company Act of 1940 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed983dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9675/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue sky law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ownership interests of members in a risk retention group shall not be considered securities for purposes of any State blue sky law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed983dd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIV/s405"},"text":"Pub. L. 96–510, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s210/a"},"text":"Pub. L. 99–499, title II, § 210(a)","children":[],"tail":", formerly § 210, "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1719"},"text":"100 Stat. 1719","children":[],"tail":"; renumbered § 210(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/563/s11/c/1"},"text":"Pub. L. 99–563, § 11(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3177"},"text":"100 Stat. 3177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed983de-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbed983df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbed983e0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (b), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
