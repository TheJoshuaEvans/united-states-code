{"tag":"section","attrib":{"id":"idc07866d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19082"},"text":null,"children":[{"tag":"num","attrib":{"value":"19082"},"text":"§ 19082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall periodically carry out reviews within each of the directorates and divisions to assess the cost and benefits of extending the operations of research facilities that have exceeded their planned operational lifespan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc07866d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10372"},"text":"Pub. L. 117–167, div. B, title III, § 10372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1571"},"text":"136 Stat. 1571","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
