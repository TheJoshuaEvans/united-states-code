{"tag":"section","attrib":{"id":"idb7fe726c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805"},"text":null,"children":[{"tag":"num","attrib":{"value":"805"},"text":"§ 805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local assistance and Tribal consistency fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fe726d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $2,000,000,000 to remain available until ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", with amounts to be obligated, subject to subsection (g), for each of fiscal years 2022 and 2023 in accordance with subsection (b), for making payments under this section to eligible revenue sharing counties and eligible Tribal governments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe726e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe726f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible revenue sharing counties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2022 and 2023, the Secretary shall reserve $750,000,000 of the total amount appropriated under subsection (a) to allocate and pay to each eligible revenue sharing county in amounts that are determined by the Secretary taking into account economic conditions of each eligible revenue sharing county, using measurements of poverty rates, household income, land values, and unemployment rates as well as other economic indicators, over the 20-year period ending with ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible Tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2022 and 2023, the Secretary shall reserve $250,000,000 of the total amount appropriated under subsection (a) to allocate and pay to eligible Tribal governments in amounts that are determined by the Secretary taking into account economic conditions of each eligible Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible revenue sharing county, an eligible Tribal government, or an eligible revenue sharing consolidated government may use funds provided under a payment made under this section for any governmental purpose other than a lobbying activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible revenue sharing county or eligible revenue sharing consolidated government receiving a payment under this section shall provide to the Secretary periodic reports providing a detailed accounting of the uses of fund by such eligible revenue sharing county or eligible revenue sharing consolidated government and such other information as the Secretary may require for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any eligible revenue sharing county or eligible revenue sharing consolidated government that has failed to submit a report required under subsection (d) or failed to comply with subsection (c), shall be required to repay to the Secretary an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe7274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a failure to comply with subsection (c), the amount of funds used in violation of such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a failure to submit a report required under subsection (d), such amount as the Secretary determines appropriate, but not to exceed 5 percent of the amount paid to the eligible revenue sharing county or eligible revenue sharing consolidated government under this section for all fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe7277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible revenue sharing consolidated government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible revenue sharing consolidated government” means a county, parish, or borough—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fe7278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been classified by the Bureau of the Census as an active government consolidated with another government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe7279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which, as determined by the Secretary, there is a negative revenue impact due to implementation of a Federal program or changes to such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe727a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible revenue sharing county","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible revenue sharing county” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fe727b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a county, parish, or borough—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7fe727c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is independent of any other unit of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe727d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, as determined by the Secretary, is the principal provider of government services for the area within its jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe727e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which, as determined by the Secretary, there is a negative revenue impact due to implementation of a Federal program or changes to such program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe727f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia, the Commonwealth of Puerto Rico, Guam, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible Tribal government” means the recognized governing body of an eligible Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible Tribe” means any Indian or Alaska Native tribe, band, nation, pueblo, village, community, component band, or component reservation, individually identified (including parenthetically) in the list published most recently as of ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":" pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible revenue sharing consolidated governments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe7284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible revenue sharing consolidated governments for fiscal years 2023 and 2024","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate and pay to each eligible revenue sharing consolidated government for each of fiscal years 2023 and 2024 an amount equal to the amount that the Secretary would have allocated to such eligible revenue sharing consolidated government for fiscal year 2022 if all eligible revenue sharing consolidated governments had been treated as eligible revenue sharing counties for purposes of being eligible for payments under subsection (b)(1) for such fiscal year using the allocation methodology adopted by the Department of the Treasury for such eligible revenue sharing counties as of ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fe7286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the allocations and payments described in paragraph (1) from the amounts described in subparagraph (B), which shall be available to the Secretary for such purpose notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe7287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts described in this subparagraph are the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7fe7288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount allocated to an eligible revenue sharing county under subsection (b)(1) for fiscal year 2022 or 2023 that, as of ","children":[{"tag":"date","attrib":{"date":"2023-01-31"},"text":"January 31, 2023","children":[],"tail":", has not been requested by such county."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe7289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s805/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts made available to the Secretary under section 102(d)(4) of the State, Local, Tribal, and Territorial Fiscal Recovery, Infrastructure, and Disaster Relief Flexibility Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fe728a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VI, § 605, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9901/a"},"text":"Pub. L. 117–2, title IX, § 9901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/234"},"text":"135 Stat. 234","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dLL/s103"},"text":"Pub. L. 117–328, div. LL, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6104"},"text":"136 Stat. 6104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fe728b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7fe728c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7fe728d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(d)(4) of the State, Local, Tribal, and Territorial Fiscal Recovery, Infrastructure, and Disaster Relief Flexibility Act, referred to in subsec. (g)(2)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dLL/s102/d/4"},"text":"section 102(d)(4) of div. LL of Pub. L. 117–328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6104"},"text":"136 Stat. 6104","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7fe728e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 805, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tVI/s605"},"text":"act Aug. 14, 1935, ch. 531, title VI, § 605","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tIII/s302"},"text":"Pub. L. 92–603, title III, § 302","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1484"},"text":"86 Stat. 1484","children":[],"tail":", which defined “services to the aged, blind or disabled”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/647"},"text":"Pub. L. 93–647","children":[],"tail":", §§ 3(b), 7(b), "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2349"},"text":"88 Stat. 2349","children":[],"tail":", 2351."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7fe728f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/b/1"},"text":"Pub. L. 117–328, § 103(b)(1)","children":[],"tail":", inserted “, subject to subsection (g),” after “amounts to be obligated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/b/2"},"text":"Pub. L. 117–328, § 103(b)(2)","children":[],"tail":", substituted “, an eligible Tribal government, or an eligible revenue sharing consolidated government” for “or an eligible Tribal government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/b/3"},"text":"Pub. L. 117–328, § 103(b)(3)","children":[],"tail":", inserted “or eligible revenue sharing consolidated government” after “eligible revenue sharing county” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/b/3"},"text":"Pub. L. 117–328, § 103(b)(3)","children":[],"tail":", inserted “or eligible revenue sharing consolidated government” after “eligible revenue sharing county” in introductory provisions and in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/b/4"},"text":"Pub. L. 117–328, § 103(b)(4)","children":[],"tail":", added par. (1) and redesignated former pars. (1) to (4) as (2) to (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s103/a"},"text":"Pub. L. 117–328, § 103(a)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
