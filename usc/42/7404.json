{"tag":"section","attrib":{"id":"idbe139b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404"},"text":null,"children":[{"tag":"num","attrib":{"value":"7404"},"text":"§ 7404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research relating to fuels and vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe139b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research programs; grants; contracts; pilot and demonstration plants; byproducts research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall give special emphasis to research and development into new and improved methods, having industry-wide application, for the prevention and control of air pollution resulting from the combustion of fuels. In furtherance of such research and development he shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe139b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct and accelerate research programs directed toward development of improved, cost-effective techniques for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe139b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of combustion byproducts of fuels,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe139b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal of potential air pollutants from fuels prior to combustion,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe139b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of emissions from the evaporation of fuels,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe139b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the efficiency of fuels combustion so as to decrease atmospheric emissions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe139b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing synthetic or new fuels which, when used, result in decreased atmospheric emissions.","children":[{"tag":"ref","attrib":{"idref":"fn003585"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003585"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for Federal grants to public or nonprofit agencies, institutions, and organizations and to individuals, and contracts with public or private agencies, institutions, or persons, for payment of (A) part of the cost of acquiring, constructing, or otherwise securing for research and development purposes, new or improved devices or methods having industrywide application of preventing or controlling discharges into the air of various types of pollutants; (B) part of the cost of programs to develop low emission alternatives to the present internal combustion engine; (C) the cost to purchase vehicles and vehicle engines, or portions thereof, for research, development, and testing purposes; and (D) carrying out the other provisions of this section, without regard to section 3324(a) and (b) of title 31 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That research or demonstration contracts awarded pursuant to this subsection (including contracts for construction) may be made in accordance with, and subject to the limitations provided with respect to research contracts of the military departments in, section 2353 "},{"tag":"ref","attrib":{"idref":"fn003586"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003586"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 10, except that the determination, approval, and certification required thereby shall be made by the Administrator; "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That no grant may be made under this paragraph in excess of $1,500,000;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, by laboratory and pilot plant testing, the results of air pollution research and studies in order to develop new or improved processes and plant designs to the point where they can be demonstrated on a large and practical scale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct, operate, and maintain, or assist in meeting the cost of the construction, operation, and maintenance of new or improved demonstration plants or processes which have promise of accomplishing the purposes of this chapter; ","children":[{"tag":"ref","attrib":{"idref":"fn003587"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003587"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The word “and” probably should appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study new or improved methods for the recovery and marketing of commercially valuable byproducts resulting from the removal of pollutants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe139b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Administrator in establishing research and development programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this section, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe139b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and accelerate research and development of cost-effective instrumentation techniques to facilitate determination of quantity and quality of air pollutant emissions, including, but not limited to, automotive emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, on a reimbursable basis, the facilities of existing Federal scientific laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and operate necessary facilities and test sites at which to carry on the research, testing, development, and programming necessary to effectuate the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire secret processes, technical data, inventions, patent applications, patents, licenses, and an interest in lands, plants, and facilities, and other property or rights by purchase, license, lease, or donation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe139b35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause on-site inspections to be made of promising domestic and foreign projects, and cooperate and participate in their development in instances in which the purposes of the chapter will be served thereby.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe139b36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean alternative fuels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct a research program to identify, characterize, and predict air emissions related to the production, distribution, storage, and use of clean alternative fuels to determine the risks and benefits to human health and the environment relative to those from using conventional gasoline and diesel fuels. The Administrator shall consult with other Federal agencies to ensure coordination and to avoid duplication of activities authorized under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe139b37-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 104, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/487"},"text":"81 Stat. 487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/137"},"text":"Pub. L. 91–137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-05"},"te