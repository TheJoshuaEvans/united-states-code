":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2353"},"text":"Section 2353 of title 10","children":[],"tail":", referred to in subsec. (a)(2), was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4174"},"text":"section 4174 of title 10","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1844/b/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1844(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4245"},"text":"134 Stat. 4245","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/6/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe139b3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(2)(D), “section 3324(a) and (b) of title 31 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “sections 3648 and 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", which Act enacted Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857b–1"},"text":"section 1857b–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe139b3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 104 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", was renumbered section 105 by "},{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7405"},"text":"section 7405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe139b3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsecs. (a)(1), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s901/d/1"},"text":"Pub. L. 101–549, § 901(d)(1)","children":[],"tail":", substituted “cost-effective” for “low-cost”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s901/d/2"},"text":"Pub. L. 101–549, § 901(d)(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “For the purposes of this section there are authorized to be appropriated $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", $125,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", $150,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", and $150,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", and $150,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":". Amounts appropriated pursuant to this subsection shall remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/319"},"text":"Pub. L. 93–319","children":[],"tail":" authorized appropriation of $150,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/15"},"text":"Pub. L. 93–15","children":[],"tail":" authorized appropriation of $150,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s2/b"},"text":"Pub. L. 91–604, § 2(b)","children":[],"tail":", inserted provisions authorizing research programs directed toward development of techniques for improving the efficiency of fuels combustion so as to decrease atmospheric emissions, and producing synthetic or new fuels which result in decreased atmospheric emissions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s2/c"},"text":"Pub. L. 91–604, § 2(c)","children":[],"tail":", added cls. (B) and (C) and redesignated former cl. (B) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s13/a"},"text":"Pub. L. 91–604, § 13(a)","children":[],"tail":", substituted provisions authorizing appropriations for fiscal years ending "},{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", 1972, and 1973, for provisions authorizing appropriations for fiscal years ending "},{"tag":"date","attrib":{"date":"1968-06-30"},"text":"June 30, 1968","children":[],"tail":" and 1969."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/137"},"text":"Pub. L. 91–137","children":[],"tail":" authorized appropriation of $45,000,000 for fiscal year ending "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe139b3e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe139b3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hydrogen Fuel Cell Vehicle Study and Test Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVIII/s807"},"text":"Pub. L. 101–549, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2689"},"text":"104 Stat. 2689","children":[],"tail":", provided that the Administrator of the Environmental Protection Agency, in conjunction with the National Aeronautics and Space Administration and the Department of Energy, would conduct a study, performed in the university or universities which are best exhibiting the facilities and expertise to develop such a fuel cell vehicle and test program on the development of a hydrogen fuel cell electric vehicle, to determine how best to transfer existing NASA hydrogen fuel cell technology into the form of a mass-producible, cost effective hydrogen fuel cell vehicle and include at a minimum a feasibility-design study, the construction of a prototype, and a demonstration, and provided that the study and test program were to be completed and a report submitted to Congress within 3 years after "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe139b40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Combustion of Contaminated Used Oil in Ships","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVIII/s813"},"text":"Pub. L. 101–549, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2693"},"text":"104 Stat. 2693","children":[],"tail":", directed that within 2 years after "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", the Administrator of the Environmental Protection Agency was to complete a study and submit a report to Congress evaluating the health and environmental impacts of the combustion of contaminated used oil in ships, the reasons for using such oil, the alternatives, and the costs of such alternatives, and other relevant factors and impacts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe139b41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension to ","children":[{"tag":"date","attrib":{"date":"1970-08-31"},"text":"Aug. 31, 1970","children":[],"tail":" of Authorization Period for Fiscal Year 1970"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/316"},"text":"Pub. L. 91–316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-10"},"text":"July 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/416"},"text":"84 Stat. 416","children":[],"tail":", provided in part that the authorization contained in section 104(c) of the Clean Air Act [subsec. (c) of this section] for the fiscal year ending "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", should remain available through "},{"tag":"date","attrib":{"date":"1970-08-31"},"text":"Aug. 31, 1970","children":[],"tail":", notwithstanding any provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
