{"tag":"section","attrib":{"id":"idc0227dac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054"},"text":null,"children":[{"tag":"num","attrib":{"value":"17054"},"text":"§ 17054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biofuels distribution and advanced biofuels infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227dad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of Transportation and in consultation with the Administrator of the Environmental Protection Agency, shall carry out a program of research, development, and demonstration relating to existing transportation fuel distribution infrastructure and new alternative distribution infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227dae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program described in subsection (a) shall focus on the physical and chemical properties of biofuels and efforts to prevent or mitigate against adverse impacts of those properties in the areas of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227daf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrosion of metal, plastic, rubber, cork, fiberglass, glues, or any other material used in pipes and storage tanks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissolving of storage tank sediments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clogging of filters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contamination from water or other adulterants or pollutants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poor flow properties related to low temperatures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oxidative and thermal instability in long-term storage and uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" microbial contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" problems associated with electrical conductivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227db7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17054/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other areas as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227db8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s248"},"text":"Pub. L. 110–140, title II, § 248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1548"},"text":"121 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227db9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0227dba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0227dbb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
