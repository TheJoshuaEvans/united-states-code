{"tag":"section","attrib":{"id":"idbcee554e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4993"},"text":null,"children":[{"tag":"num","attrib":{"value":"4993"},"text":"§ 4993.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director may provide technical and financial assistance to Federal agencies, State and local governments and agencies, private nonprofit organizations, employers, and other private organizations that utilize or desire to utilize volunteers in carrying out the purpose of this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcee554f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s123"},"text":"Pub. L. 93–113, title I, § 123","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/293/s3/b/1"},"text":"Pub. L. 94–293, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-27"},"text":"May 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/525"},"text":"90 Stat. 525","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s13"},"text":"Pub. L. 98–288, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/192"},"text":"98 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tVI/s602"},"text":"Pub. L. 101–204, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1820"},"text":"103 Stat. 1820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s332"},"text":"Pub. L. 103–82, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/903"},"text":"107 Stat. 903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcee5550-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcee5551-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcee5552-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" amended section generally, substituting single sentence authorizing technical and financial assistance for former subsecs. (a) and (b) which contained similar general authority and provisions detailing use of the general authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" substituted “(2) technical assistance and training programs, including the creation or expansion of private capabilities where possible and the development of voluntary organizations, with particular emphasis on low-income, minority, and community-based groups, or (3)” for “or (2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbce