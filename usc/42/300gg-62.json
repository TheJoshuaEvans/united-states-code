{"tag":"section","attrib":{"id":"idb6b7e974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–62"},"text":"§ 300gg–62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption and application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b7e975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), nothing in this part (or part C insofar as it applies to this part) shall be construed to prevent a State from establishing, implementing, or continuing in effect standards and requirements unless such standards and requirements prevent the application of a requirement of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b7e977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this part (or part C insofar as it applies to this part) shall be construed to affect or modify the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144"},"text":"section 1144 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b7e978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–51"},"text":"section 300gg–51 of this title","children":[],"tail":") shall be construed as requiring health insurance coverage offered in the individual market to provide specific benefits under the terms of such coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b7e979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of part A provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b7e97a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of part A shall apply to health insurance issuers providing health insurance coverage in the individual market in a State as provided for in such part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b7e97b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–62/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that any provision of this part conflicts with a provision of part A with respect to health insurance issuers providing health insurance coverage in the individual market in a State, the provisions of such part A shall apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b7e97c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2762, formerly § 2746, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s111/a"},"text":"Pub. L. 104–191, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1987"},"text":"110 Stat. 1987","children":[],"tail":"; renumbered § 2762 and amended, "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s605/a/2"},"text":"Pub. L. 104–204, title VI, § 605(a)(2)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2941"},"text":"110 Stat. 2941","children":[],"tail":", 2942; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1563/c/15"},"text":"Pub. L. 111–148, title I, § 1563(c)(15)","children":[],"tail":", formerly § 1562(c)(15), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/269"},"text":"124 Stat. 269","children":[],"tail":", 911.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b7e97d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b7e97e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6b7e97f-3a70-11f1-ae07-e4213316b5fa"},"