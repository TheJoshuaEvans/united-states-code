{"tag":"section","attrib":{"id":"idbfbbf4a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342"},"text":null,"children":[{"tag":"num","attrib":{"value":"13342"},"text":"§ 13342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oil substitution through coal liquefaction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf4a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for the purpose of developing economically and environmentally acceptable advanced technologies for oil substitution through coal liquefaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf4a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program established under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf4a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved resource selection and product quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf4a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of technologies to increase net yield of liquid fuel product per ton of coal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf4aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in overall thermal efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf4ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in capital and operating costs through technology improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf4ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf4ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1312"},"text":"Pub. L. 102–486, title XIII, § 1312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2976"},"text":"106 Stat. 2976","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
