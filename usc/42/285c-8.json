{"tag":"section","attrib":{"id":"idb56ec772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"285c–8"},"text":"§ 285c–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutritional disorders program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56ec773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute, in consultation with the Director of NIH, shall establish a program of conducting and supporting research, training, health information dissemination, and other activities with respect to nutritional disorders, including obesity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56ec774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program established under subsection (a), the Director of the Institute shall conduct and support each of the activities described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56ec775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program established under subsection (a), the Director of the Institute shall carry out activities to facilitate and enhance knowledge and understanding of nutritional disorders, including obesity, on the part of health professionals, patients, and the public through the effective dissemination of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56ec776-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 434, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVI/s601"},"text":"Pub. L. 103–43, title VI, § 601[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/161"},"text":"107 Stat. 161","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
