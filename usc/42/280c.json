{"tag":"section","attrib":{"id":"idb52c190f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c"},"text":null,"children":[{"tag":"num","attrib":{"value":"280c"},"text":"§ 280c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52c1910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, shall make not less than 5, and not more than 20, grants to States for the purpose of assisting grantees in carrying out demonstration projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify low-income individuals who can avoid institutionalization or prolonged hospitalization if skilled medical services, skilled nursing care services, homemaker or home health aide services, or personal care services are provided in the homes of the individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the costs of the provision of such services in the homes of such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the provision by public and private entities of such services, and other long-term care services, in the homes of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c1914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement with respect to age of recipients of services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) to a State unless the State agrees to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 25 percent of the grant is expended to provide services under such subsection to individuals who are not less than 65 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the portion of the grant reserved by the State for purposes of complying with paragraph (1), not less than 10 percent is expended to provide such services to individuals who are not less than 85 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c1917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to items and services under other programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may not make payments from a grant under subsection (a) for any item or service to the extent that payment has been made, or can reasonably be expected to be made, with respect to such item or service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any State compensation program, under an insurance policy, or under any Federal or State health benefits program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an entity that provides health services on a prepaid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52c191a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 395, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tVI/s602"},"text":"Pub. L. 100–175, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/979"},"text":"101 Stat. 979","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/557/tI/s101/a"},"text":"Pub. L. 101–557, title I, § 101(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2766"},"text":"104 Stat. 2766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/108/s2/f"},"text":"Pub. L. 102–108, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-17"},"text":"Aug. 17, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/550"},"text":"105 Stat. 550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52c191b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52c191c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb52c191d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 280C, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s399A"},"text":"act July 1, 1944, ch. 373, title III, § 399A","children":[],"tail":", formerly § 399c, as added "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/222/s3"},"text":"Pub. L. 93–222, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/934"},"text":"87 Stat. 934","children":[],"tail":"; renumbered § 399A, "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tVI/s607/a"},"text":"Pub. L. 94–63, title VI, § 607(a)","children":[],"tail":", (c), "},{"tag":"ref","attrib":{"href":"/us/stat/89/351"},"text":"89 Stat. 351","children":[],"tail":", provided for programs designed to assure the quality of health care, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/623/s11/b"},"text":"Pub. L. 95–623, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3455"},"text":"92 Stat. 3455","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 395 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII"},"text":"act July 1, 1944, ch. 373, title III","children":[],"tail":", formerly § 397, as added "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/291/s2"},"text":"Pub. L. 89–291, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1063"},"text":"79 Stat. 1063","children":[],"tail":"; renumbered § 396 and amended "},{"tag":"date","attrib":{"date":"1970-03-13"},"text":"Mar. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/212"},"text":"Pub. L. 91–212","children":[],"tail":", §§ 2(e), 6(a)(1), (2), 10(c)(3), (d)(2)(A), "},{"tag":"ref","attrib":{"href":"/us/stat/84/63"},"text":"84 Stat. 63","children":[],"tail":", 64, 67; "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/45/tI/s107/d"},"text":"Pub. L. 93–45, title I, § 107(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/92"},"text":"87 Stat. 92","children":[],"tail":"; renumbered § 395 and amended "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tII"},"text":"Pub. L. 93–353, title II","children":[],"tail":", §§ 203(c), 204, "},{"tag":"ref","attrib":{"href":"/us/stat/88/372"},"text":"88 Stat. 372","children":[],"tail":", 373, which related to grants for establishing, expanding, and improving basic medical library or related resources, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–7"},"text":"section 280b–7 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/b"},"text":"Pub. L. 99–158, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/879"},"text":"99 Stat. 879","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb52c191e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/108"},"text":"Pub. L. 102–108","children":[],"tail":" inserted “skilled medical services,” after “if”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s101/a"},"text":"Pub. L. 101–557, § 101(a)","children":[],"tail":", substituted “shall make not less than 5, and not more than 20, grants” for “shall make not less than 3, and not more than 5, grants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s101/b"},"text":"Pub. L. 101–557, § 101(b)","children":[],"tail":", substituted “skilled nursing care services, homemaker or home health aide services, or personal care services are provided in the homes of the individuals” for “skilled medical services or related health services (or both) are provided in the homes of the individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/s101/c"},"text":"Pub. L. 101–557, § 101(c)","children":[],"tail":", substituted “to ensure that—” and pars. (1) and (2) for “to ensure that not less than 25 percent of individuals receiving services pursuant to subsection (a) of this section are individuals who are not less than 65 years of age”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb52c191f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb52c1920-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/s701/a"},"text":"section 701(a) of Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb52c1921-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", which enacted this part as the “Health Care Services in the Home Act of 1987”, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/s601"},"text":"section 601 of Pub. L. 100–175","children":[],"tail":", set out as a Short Title of 1987 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
