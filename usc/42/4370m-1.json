{"tag":"section","attrib":{"id":"idbcccea5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370m–1"},"text":"§ 4370m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Permitting Improvement Steering Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcccea5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Federal Permitting Improvement Steering Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcccea5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as Chair of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcccea62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by head of agency","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcccea64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual listed in subparagraph (B) shall designate a member of the agency in which the individual serves to serve on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redesignation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an individual listed in subparagraph (B) designates a different member to serve on the Council than the member designated under subclause (I), the individual shall notify the Executive Director of the designation by not later than 30 days after the date on which the designation is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A councilmember described in clause (i) shall hold a position in the agency of deputy secretary (or the equivalent) or higher.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcccea68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with guidance provided by the Director of the Office of Management and Budget, each individual listed in subparagraph (B) shall designate 1 or more appropriate members of the agency in which the individual serves to serve as an agency CERPO.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties of the agency CERPO under this subchapter, an agency CERPO shall report directly to the applicable agency councilmember.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Heads of agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individuals that shall each designate a councilmember under this subparagraph are as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Federal Energy Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Nuclear Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Advisory Council on Historic Preservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/2/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other head of a Federal agency that the Executive Director may invite to participate as a member of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the members listed in paragraphs (1) and (2), the Chairman of the Council on Environmental Quality and the Director of the Office of Management and Budget shall also be members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcccea7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcccea7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcccea7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director, in consultation with the Council, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":", establish an inventory of covered projects that are pending the environmental review or authorization of the head of any Federal agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcccea7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize the projects in the inventory as appropriate, based on sector and project type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each category, identify the types of environmental reviews and authorizations most commonly involved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add a covered project to the inventory after receiving a notice described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–2/a/1"},"text":"section 4370m–2(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitating agency designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director, in consultation with the Council, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a facilitating agency for each category of covered projects described in subparagraph (A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the list of designated facilitating agencies for each category of projects in the inventory on the Dashboard in an easily accessible format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance schedules","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":", the Executive Director, in consultation with the Council, shall develop recommended performance schedules, including intermediate and final completion dates, for environmental reviews and authorizations most commonly required for each category of covered projects described in subparagraph (A)(ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcccea88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The performance schedules shall reflect employment of the most sound and efficient applicable processes, including the alignment of Federal reviews of projects, reduction of permitting and project delivery time, and consideration of the best practices for public participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbcccea8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, and consistent with applicable Federal law, the Executive Director, in consultation with the Council, shall aim to develop recommended performance schedules under clause (i) of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbcccea8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a recommended performance schedule developed under clause (i) exceeds 2 years, the relevant agencies, in consultation with the Executive Director and the Council, shall explain in that recommended performance schedule the factors that cause the environmental reviews and authorizations in that category of covered projects to take longer than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbcccea8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The final completion dates in any performance schedule for the completion of an environmental review or authorization under clause (i) shall not exceed the average time to complete an environmental review or authorization for a project within that category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbcccea8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of average time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The average time referred to in item (aa) shall be calculated based on relevant historical data, as determined by the Executive Director, and shall run from the period beginning on the date on which the Executive Director must make a specific entry for the project on the Dashboard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m–2/b/2"},"text":"section 4370m–2(b)(2) of this title","children":[],"tail":" (except that, for projects initiated before that duty takes effect, the period beginning on the date of filing of a completed application), and ending on the date of the issuance of a record of decision or other final agency action on the review or authorization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbcccea8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/ii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each performance schedule shall specify that any decision by an agency on an environmental review or authorization must be issued not later than 180 days after the date on which all information needed to complete the review or authorization (including any hearing that an agency holds on the matter) is in the possession of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the performance schedules are established under this subparagraph, and not less frequently than once every 2 years thereafter, the Executive Director, in consultation with the Council, shall review and revise the performance schedules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director, in consultation with the Council, may recommend to the Director of the Office of Management and Budget or to the Council on Environmental Quality, as appropriate, that guidance be issued as necessary for agencies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out responsibilities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectuate the adoption by agencies of the best practices and recommendations of the Council described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the Council may appoint and fix the compensation of such employees as the Executive Director considers necessary to carry out the roles and responsibilities of the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcccea95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcccea96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall make recommendations to the Executive Director with respect to the designations under paragraph (1)(B) and the performance schedules under paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may update the recommendations described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcccea99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Council shall issue recommendations on the best practices for improving the Federal permitting process for covered projects, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcccea9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enhancing early stakeholder engagement, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcccea9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging with Native American stakeholders to ensure that project sponsors and agencies identify potential natural, archeological, and cultural resources and locations of historic and religious significance in the area of a covered project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcccea9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully considering and, as appropriate, incorporating recommendations provided in public comments on any proposed covered project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring timely decisions regarding environmental reviews and authorizations, including through the development of performance metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving coordination between Federal and non-Federal governmental entities, including through the development of common data standards and terminology across agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcccea9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing transparency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing information collection requirements and other administrative burdens on agencies, project sponsors, and other interested parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and making available to applicants appropriate geographic information systems and other tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating and distributing training materials useful to Federal, State, tribal, and local permitting officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the Executive Director, improving preliminary engagement with project sponsors in developing coordinated project plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using programmatic assessments, templates, and other tools based on the best available science and data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbccceaa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing other aspects of infrastructure permitting, as determined by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbccceaa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet not less frequently than annually with groups or individuals representing State, tribal, and local governments that are engaged in the infrastructure permitting process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbccceaa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency CERPOs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency CERPO shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbccceaa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the respective agency councilmember on matters related to environmental reviews and authorizations, including agency compliance with intermediate and final completion dates described in coordinated project plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbccceaa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical support, when requested to facilitate efficient and timely processes for environmental reviews and authorizations for covered projects under the jurisdictional responsibility of the agency, including supporting timely identification and resolution of potential disputes within the agency or between the agency and other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbccceaaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze agency environmental review and authorization processes, policies, and authorities and make recommendations to the respective agency councilmember for ways to standardize, simplify, and improve the efficiency of the processes, policies, and authorities, including by implementing guidance issued under paragraph (1)(D) and other best practices, including the use of information technology and geographic information system tools within the agency and across agencies, to the extent consistent with existing law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbccceaab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370m–1/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and develop training programs for agency staff that support and conduct environmental reviews or authorizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbccceaac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dD/tXLI/s41002"},"text":"Pub. L. 114–94, div. D, title XLI, § 41002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1743"},"text":"129 Stat. 1743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVIII/s70801/b"},"text":"Pub. L. 117–58, div. G, title VIII, § 70801(b)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1288"},"text":"135 Stat. 1288","children":[],"tail":", 1294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dE/tVI/s635/a"},"text":"Pub. L. 117–328, div. E, title VI, § 635(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4703"},"text":"136 Stat. 4703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbccceaad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbccceaae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbccceaaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fixing America’s Surface Transportation Act, also known as the FAST Act, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbccceab0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/b/1"},"text":"Pub. L. 117–58, § 70801(b)(1)","children":[],"tail":", substituted “Federal Permitting Improvement Steering Council” for “Federal Permitting Improvement Council” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/b/2/A"},"text":"Pub. L. 117–58, § 70801(b)(2)(A)","children":[],"tail":", designated existing provisions as subcl. (I), inserted subcl. heading, and added subcl. (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/i"},"text":"Pub. L. 117–58, § 70801(i)","children":[],"tail":", substituted “councilmember” for “councilmem-ber”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/b/2/B"},"text":"Pub. L. 117–58, § 70801(b)(2)(B)","children":[],"tail":", substituted “the applicable agency councilmember” for “a deputy secretary (or the equivalent) or higher”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/b/3/A/i"},"text":"Pub. L. 117–58, § 70801(b)(3)(A)(i)","children":[],"tail":", added subcl. (I) and struck out former subcl. (I). Prior to amendment, text read as follows: “The performance schedules shall reflect employment of the use of the most efficient applicable processes, including the alignment of Federal reviews of projects and reduction of permitting and project delivery time.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C)(ii)(II), (III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70801/b/3/A/ii"},"text":"Pub. L. 117–58, § 70801(b)(3)(A)(ii)","children":[],"tail":", (iii), added 