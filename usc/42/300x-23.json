{"tag":"section","attrib":{"id":"idb6695391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–23"},"text":"§ 300x–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intravenous substance use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6695392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of treatment programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6695393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of reaching capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will, in the case of programs of treatment for intravenous substance use disorders, require that any such program receiving amounts from the grant, upon reaching 90 percent of its capacity to admit individuals to the program, provide to the State a notification of such fact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6695394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will, with respect to notifications under paragraph (1), ensure that each individual who requests and is in need of treatment for intravenous substance use disorders is admitted to a program of such treatment not later than—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6695395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 14 days after making the request for admission to such a program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6695396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 120 days after the date of such request, if no such program has the capacity to admit the individual on the date of such request and if interim services are made available to the individual not later than 48 hours after such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6695397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach to persons who inject drugs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved, in providing amounts from the grant to any entity for treatment services for persons who inject drugs, will require the entity to carry out activities to encourage individuals in need of such treatment to undergo treatment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6695398-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1923, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/390"},"text":"106 Stat. 390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/b"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1229"},"text":"130 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/a/4"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5677"},"text":"136 Stat. 5677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6695399-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb669539a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb669539b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1923 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–9b"},"text":"section 300x–9b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1923 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–2"},"text":"section 300y–2 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb669539c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1241/a/4/A"},"text":"Pub. L. 117–328, § 1241(a)(4)(A)","children":[],"tail":", substituted “substance use” for “substance abuse” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1241/a/4/B"},"text":"Pub. L. 117–328, § 1241(a)(4)(B)","children":[],"tail":", which directed amendment of subsec. (a) by substituting “substance use disorders” for “drug abuse”, was executed by making the substitution both places “drug abuse” appeared, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “to persons who inject drugs” for “regarding intravenous substance abuse” in heading and “for persons who inject drugs” for “for intravenous drug abuse” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
