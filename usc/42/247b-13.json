{"tag":"section","attrib":{"id":"idb4a8df93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–13"},"text":"§ 247b–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prenatal and postnatal health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a8df94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall carry out programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect, analyze, and make available data on prenatal smoking and alcohol and other substance abuse and misuse, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a8df96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4a8df97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence, prevalence, and implications of such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4a8df98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence and prevalence of implications and outcomes, including neonatal abstinence syndrome and other maternal and child health outcomes associated with such activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information or data, as appropriate, on family health history, medication exposures during pregnancy, demographic information, such as race, ethnicity, geographic location, and family history, and other relevant information, to inform such analysis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct applied epidemiological research on the prevention and long-term outcomes associated with prenatal and postnatal smoking, alcohol and other substance abuse and misuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support, conduct, and evaluate the effectiveness of educational, treatment, and cessation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information and education to the public on the prevention and implications of prenatal and postnatal smoking, alcohol and other substance abuse and misuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to issue public reports on the analysis of data described in paragraph (1), including analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a8df9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term outcomes of children affected by neonatal abstinence syndrome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health outcomes associated with prenatal smoking, alcohol, and substance abuse and misuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8dfa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant studies, evaluations, or information the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8dfa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary may award grants to and enter into contracts with States, local governments, tribal entities, scientific and academic institutions, federally qualified health centers, and other public and nonprofit entities, and may provide technical and consultative assistance to such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8dfa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this section, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8dfa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and consultative assistance to entities receiving grants under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8dfa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a pathway for data sharing between States, tribal entities, and the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8dfa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure data collection under this section is consistent with applicable State, Federal, and Tribal privacy laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8dfa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the National Coordinator for Health Information Technology, as appropriate, to assist States and Tribes in implementing systems that use standards recognized by such National Coordinator, as such recognized standards are available, in order to facilitate interoperability between such systems and health information technology systems, including certified health information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8dfa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such $4,250,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a8dfa8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tIX/s911"},"text":"Pub. L. 106–310, div. A, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1127"},"text":"114 Stat. 1127","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7064"},"text":"Pub. L. 115–271, title VII, § 7064","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4021"},"text":"132 Stat. 4021","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s101"},"text":"Pub. L. 119–44, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/670"},"text":"139 Stat. 670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4a8dfa9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4a8dfaa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4a8dfab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44"},"text":"Pub. L. 119–44","children":[],"tail":" substituted “$4,250,000 for each of fiscal years 2026 through 2030” for “such sums as may be necessary for each of the fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/1/A"},"text":"Pub. L. 115–271, § 7064(1)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to collect, analyze, and make available data on prenatal smoking, alcohol and illegal drug use, including data on the implications of such activities and on the incidence and prevalence of such activities and their implications;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/1/B"},"text":"Pub. L. 115–271, § 7064(1)(B)","children":[],"tail":", substituted “prevention and long-term outcomes associated with” for “prevention of” and “other substance abuse and misuse” for “illegal drug use”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/1/C"},"text":"Pub. L. 115–271, § 7064(1)(C)","children":[],"tail":", substituted “, treatment, and cessation programs;” for “and cessation programs; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/1/D"},"text":"Pub. L. 115–271, § 7064(1)(D)","children":[],"tail":", substituted “other substance abuse and misuse; and” for “illegal drug use.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/1/E"},"text":"Pub. L. 115–271, § 7064(1)(E)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/2"},"text":"Pub. L. 115–271, § 7064(2)","children":[],"tail":", inserted “tribal entities,” after “local governments,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/4"},"text":"Pub. L. 115–271, § 7064(4)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7064/3"},"text":"Pub. L. 115–271, § 7064(3)","children":[],"tail":", (5), redesignated subsec. (c) as (d) and substituted “2019 through 2023” for “2001 through 2005”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4ab4fac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4ab4fad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improving Data and the Public Health Response","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/91/s4"},"text":"Pub. L. 114–91, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/725"},"text":"129 Stat. 725","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/91/s4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary [of Health and Human Services] may continue activities, as appropriate, related to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to support States and Federally recognized Indian Tribes in collecting information on neonatal abstinence syndrome through the utilization of existing surveillance systems and collaborating with States and Federally recognized Indian Tribes to improve the quality, consistency, and collection of such data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to support States in implementing effective public health measures, such as disseminating information to educate the public, health care providers, and other stakeholders on prenatal opioid use and neonatal abstinence syndrome.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
