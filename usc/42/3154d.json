{"tag":"section","attrib":{"id":"idbc7701d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154d"},"text":"§ 3154d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7701d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of renewable energy site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “renewable energy site” means a brownfield site that is redeveloped through the incorporation of 1 or more renewable energy technologies, including solar, wind, geothermal, ocean, and emerging, but proven, renewable energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make a grant for a project for the development of a renewable energy site if the Secretary determines that the project will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7701d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 1 or more renewable energy technologies described in subsection (a), to develop abandoned or contaminated sites for commercial use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7701d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the commercial and economic opportunities in the area in which the project is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7701d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that any portion of a grant awarded under subsection (b) involves remediation, the remediation shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3222"},"text":"section 3222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7701d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s218"},"text":"Pub. L. 89–136, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s213/a"},"text":"Pub. L. 108–373, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1766"},"text":"118 Stat. 1766","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2220"},"text":"Pub. L. 118–272, div. B, title II, § 2220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3185"},"text":"138 Stat. 3185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7701d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7701da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7701db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2220/1"},"text":"Pub. L. 118–272, § 2220(1)","children":[],"tail":", substituted “Renewable energy” for “Brightfields demonstration” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2220/2"},"text":"Pub. L. 118–272, § 2220(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “In this section, the term ‘brightfield site’ means a brownfield site that is redeveloped through the incorporation of 1 or more solar energy technologies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2220/3/A"},"text":"Pub. L. 118–272, § 2220(3)(A)","children":[],"tail":", (B), substituted “Establishment” for “Demonstration program” in heading and “renewable energy” for “brightfield” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2220/3/C"},"text":"Pub. L. 118–272, § 2220(3)(C)","children":[],"tail":", substituted “renewable energy technologies described in subsection (a),” for “solar energy technologies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2220/4"},"text":"Pub. L. 118–272, § 2220(4)","children":[],"tail":", struck out subsec. (d). Text read as follows: “There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2004 through 2008, to remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
