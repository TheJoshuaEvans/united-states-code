{"tag":"section","attrib":{"id":"idb61a9789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–54"},"text":"§ 300d–54.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stop, Observe, Ask, and Respond to Health and Wellness Training Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb61a978a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to be known as the Stop, Observe, Ask, and Respond to Health and Wellness Training Program or the SOAR to Health and Wellness Training Program (in this section referred to as the “Program”) to provide training to health care and social service providers on human trafficking in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a978b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a978c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall include the Stop, Observe, Ask, and Respond to Health and Wellness Training Program’s activities existing on the day before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", and the authorized initiatives described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a978d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized initiatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorized initiatives of the Program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61a978e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engaging stakeholders, including victims of human trafficking and Federal, State, local, and tribal partners, to develop a flexible training module—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb61a978f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for supporting activities under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb61a9790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that adapts to changing needs, settings, health care providers, and social service providers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61a9791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to grantees related to implementing activities described in subsection (c) and reporting on any best practices identified by the grantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61a9792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a reliable methodology for collecting data, and reporting such data, on the number of human trafficking victims identified and served by grantees in a manner that, at a minimum, prevents disclosure of individually identifiable information consistent with all applicable privacy laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61a9793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating, as appropriate, the training described in paragraphs (1) through (4) of subsection (c) with training programs, in effect on ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", for health care and social service providers for victims of intimate partner violence, sexual assault, stalking, child abuse, child neglect, child maltreatment, and child sexual exploitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants to appropriate entities to train health care and social service providers to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a9795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential human trafficking victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement best practices for working with law enforcement to report and facilitate communication with human trafficking victims, in accordance with all applicable Federal, State, local, and tribal laws, including legal confidentiality requirements for patients and health care and social service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement best practices for referring such victims to appropriate health care, social, or victims service agencies or organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a9798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such victims with coordinated, age-appropriate, culturally relevant, trauma-informed, patient-centered, and evidence-based care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a9799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration in awarding grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in making awards under this section, shall give consideration to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a979a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a979b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demographics of the population to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a979c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the predominant types of human trafficking cases involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a979d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care and social service provider profiles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a979e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb61a979f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect data and report on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb61a97a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of entities that received a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb61a97a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number and geographic distribution of health care and social service providers trained through the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a97a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the data required to be collected under paragraph (1), for purposes of the initial report to be submitted under paragraph (3), the Secretary shall collect data on the total number of facilities and health care professional organizations that were operating under, and the total number of health care and social service providers trained through, the Stop, Observe, Ask, and Respond to Health and Wellness Training Program existing prior to the establishment of the Program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb61a97a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":", and annually thereafter, the Secretary shall submit an annual report to Congress on the data collected under this subsection in a manner that, at a minimum, prevents the disclosure of individually identifiable information consistent with all applicable privacy laws and regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a97a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available, on the Internet website of the Department of Health and Human Services, a description of the best practices and procedures used by entities that receive a grant for carrying out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a97a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “human trafficking” has the meaning given the term “severe forms of trafficking in persons” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb61a97a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–54/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $4,000,000 for each of fiscal years 2020 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb61a97a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, §1254, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/398/s2"},"text":"Pub. L. 115–398, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5328"},"text":"132 Stat. 5328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb61a97a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb61a97a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb61a97aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (h), was in the original “this Act”, and was translated, to reflect the probable intent of Congress, as meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/398"},"text":"Pub. L. 115–398","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5328"},"text":"132 Stat. 5328","children":[],"tail":", which enacted this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
