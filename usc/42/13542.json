{"tag":"section","attrib":{"id":"idbfc801db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13542"},"text":null,"children":[{"tag":"num","attrib":{"value":"13542"},"text":"§ 13542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc801dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this Act, for research and development programs carried out under this Act, the Secretary shall require a commitment from non-Federal sources of at least 20 percent of the cost of the project. The Secretary may reduce or eliminate the non-Federal requirement under this subsection if the Secretary determines that the research and development is of a basic or fundamental nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc801dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration and commercial application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this Act, the Secretary shall require at least 50 percent of the costs directly and specifically related to any demonstration or commercial application project under this Act to be provided from non-Federal sources. The Secretary may reduce the non-Federal requirement under this subsection if the Secretary determines that the reduction is necessary and appropriate considering the technological risks involved in the project and is necessary to meet the objectives of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc801de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In calculating the amount of the non-Federal commitment under paragraph (1) or (2), the Secretary shall include cash, personnel, services, equipment, and other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc801df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tennessee Valley Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds derived by the Tennessee Valley Authority from its power program may be used for all or part of any cost sharing requirements under this section, except to the extent that such funds are provided by annual appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc801e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXX/s3002"},"text":"Pub. L. 102–486, title XXX, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3127"},"text":"106 Stat. 3127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc801e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc801e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc801e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2776"},"text":"106 Stat. 2776","children":[],"tail":", known as the Energy Policy Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13201"},"text":"section 13201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
