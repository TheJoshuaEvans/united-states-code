{"tag":"section","attrib":{"id":"idc07f92a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120"},"text":null,"children":[{"tag":"num","attrib":{"value":"19120"},"text":"§ 19120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc07f92a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the Directorate has been in operation for 6 years, the Director shall enter into an agreement with the National Academies to provide an evaluation of how well the Directorate is achieving the purposes identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19102"},"text":"section 19102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f92a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07f92a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of Directorate activities on the Foundation’s primary science mission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f92aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the Directorate’s impact on the challenges and key technology focus areas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19107"},"text":"section 19107 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f92ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of efforts to ensure coordination between the Directorate and other Federal agencies, and with external entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f92ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of lessons learned from operation of the Directorate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07f92ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended funding levels for the Directorate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc07f92ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the evaluation, the evaluation shall be made available to Congress and the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07f92af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10399A"},"text":"Pub. L. 117–167, div. B, title III, § 10399A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1598"},"text":"136 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
