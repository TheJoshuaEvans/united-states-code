{"tag":"section","attrib":{"id":"idbf687cb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312"},"text":null,"children":[{"tag":"num","attrib":{"value":"12312"},"text":"§ 12312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Commissioner","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf687cba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf687cbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the effective and visible advocate for children, youth, and families within the Department of Health and Human Services and with other departments, agencies, and instrumentalities of the Federal Government by maintaining active review and commenting responsibilities, as appropriate, concerning Federal policies affecting young individuals, and the families of young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate information related to the problems of young individuals and the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary in appropriate matters pertaining to young individuals, and the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the grants authorized under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop plans and conduct research in the field of young individuals, and the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist, to the maximum extent practicable, in the establishment and implementation of programs designed to meet the needs of young individuals for supportive services including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf687cc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health and mental health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing and shelter assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and training services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teen parenting support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family support and preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teen pregnancy prevention and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687cca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling on the effects of violence in the communities of such individuals and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687ccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreational and volunteer opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf687ccc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/6/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive early childhood development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687ccd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and consultation to States and the political subdivisions of such States with respect to programs for young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare, publish, and disseminate educational materials concerning the welfare of young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687ccf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather statistics concerning young individuals, and the families of such individuals, that other Federal agencies are not collecting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable coordinate activities carried out or assisted by all departments, agencies, and instrumentalities of the Federal Government with respect to the collection, preparation, and dissemination of information relevant to young individuals and the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate more effective uses of existing resources and available services for young individuals and the families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop basic policies and set priorities with respect to the development and operation of programs and activities conducted under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene conferences of authorities and officials of organizations, including Federal, State, and local agencies, and nonprofit private organizations, of programs for children, youth and their families for the development and implementation of policies related to the priorities and purposes of this chapter, including topics such as the establishment of a nationwide network of comprehensive, coordinated services and opportunities for such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic evaluations of the programs and activities related to the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf687cd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, in coordination with other agencies, methods to ensure adequate training for personnel concerning children, youth and families and to ensure the adequate dissemination of such information to appropriate State and community agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf687cd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of volunteerism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In executing the duties and functions of the Administration under this subchapter and in carrying out the programs and activities authorized under this chapter, the Commissioner, in consultation with the Chief Executive Officer of the Corporation for National and Community Service, shall take necessary steps to coordinate with and seek the advice of voluntary agencies and organizations that provide services related to the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf687cd7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s916"},"text":"Pub. L. 101–501, title IX, § 916","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1263"},"text":"104 Stat. 1263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIV/s405"},"text":"Pub. L. 103–82, title IV, § 405","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/922"},"text":"107 Stat. 922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf687cd8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf687cd9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf687cda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" substituted “the Chief Executive Officer of the Corporation for National and Community Service” for “the Director of the ACTION Agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf687cdb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf687cdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-04-04"},"text":"Apr. 4, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s406/b"},"text":"section 406(b) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8332"},"text":"section 8332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf687cdd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
