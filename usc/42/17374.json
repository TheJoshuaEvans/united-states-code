{"tag":"section","attrib":{"id":"idc038023a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374"},"text":null,"children":[{"tag":"num","attrib":{"value":"17374"},"text":"§ 17374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency in extractive industries resource payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc038023b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc038023c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure greater United States energy security by combating corruption in the governments of foreign countries that receive revenues from the sale of their natural resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038023d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the development of democracy and increase political and economic stability in such resource rich foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc038023e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc038023f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase energy security by promoting anti-corruption initiatives in oil and natural gas rich countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote global energy security through promotion of programs such as the Extractive Industries Transparency Initiative (EITI) that seek to instill transparency and accountability into extractive industries resource payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the United States should further global energy security and promote democratic development in resource-rich foreign countries by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0380242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging further participation in the EITI by eligible countries and companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the efficacy of the EITI program by ensuring a robust and candid review mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0380245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and annually thereafter, the Secretary of State, in consultation with the Secretary of Energy, shall submit to the appropriate congressional committees a report on progress made in promoting transparency in extractive industries resource payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by paragraph (1) shall include a detailed description of United States participation in the EITI, bilateral and multilateral diplomatic efforts to further participation in the EITI, and other United States initiatives to strengthen energy security, deter energy kleptocracy, and promote transparency in the extractive industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17374/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $3,000,000 for the purposes of United States contributions to the Multi-Donor Trust Fund of the EITI.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0380248-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s935"},"text":"Pub. L. 110–140, title IX, § 935","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1748"},"text":"121 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0380249-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc038024a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc038024b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
