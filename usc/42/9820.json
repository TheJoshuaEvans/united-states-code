{"tag":"section","attrib":{"id":"idbedbcde7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9820"},"text":null,"children":[{"tag":"num","attrib":{"value":"9820"},"text":"§ 9820.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to plan economic development and cooperative programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to facilitate the purposes of this subchapter, the Secretary is authorized to provide financial assistance to any public or private nonprofit agency or organization for planning of community economic development programs and cooperative programs under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbedbcde8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s631"},"text":"Pub. L. 97–35, title VI, § 631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/498"},"text":"95 Stat. 498","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
