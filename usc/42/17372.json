{"tag":"section","attrib":{"id":"idc03801a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372"},"text":null,"children":[{"tag":"num","attrib":{"value":"17372"},"text":"§ 17372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual national energy security strategy report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03801a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03801a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), on the date on which the President submits to Congress the budget for the following fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the President shall submit to Congress a comprehensive report on the national energy security of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Presidents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the reports required under paragraph (1), the President shall submit a comprehensive report on the national energy security of the United States by not later than 150 days after the date on which the President assumes the office of President after a presidential election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03801a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this section shall describe the national energy security strategy of the United States, including a comprehensive description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03801a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the worldwide interests, goals, and objectives of the United States that are vital to the national energy security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the foreign policy, worldwide commitments, and national defense capabilities of the United States necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03801a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deter political manipulation of world energy resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03801a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement the national energy security strategy of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed short-term and long-term uses of the political, economic, military, and other authorities of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03801ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect or promote energy security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03801ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve the goals and objectives described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the capabilities of the United States to protect the national energy security of the United States, including an evaluation of the balance among the capabilities of all elements of the national authority of the United States to support the implementation of the national energy security strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the President determines to be necessary to inform Congress on matters relating to the national energy security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03801af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified and unclassified form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each national energy security strategy report shall be submitted to Congress in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03801b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a classified form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03801b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03801b2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s933"},"text":"Pub. L. 110–140, title IX, § 933","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1740"},"text":"121 Stat. 1740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03801b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03801b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03801b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
