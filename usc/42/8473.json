{"tag":"section","attrib":{"id":"idbe991f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473"},"text":null,"children":[{"tag":"num","attrib":{"value":"8473"},"text":"§ 8473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332"},"text":"section 4332 of this title","children":[],"tail":null}],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following actions are not deemed to be major Federal actions for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant or denial of any temporary exemption under this chapter for any electric powerplant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the grant or denial of any permanent exemption under this chapter for any existing electric powerplant, other than an exemption—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe991f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8352/c"},"text":"section 8352(c) of this title","children":[],"tail":", relating to cogeneration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/24/B"},"text":"Pub. L. 100–42, § 1(c)(24)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/314"},"text":"101 Stat. 314","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8352/b"},"text":"section 8352(b) of this title","children":[],"tail":", relating to certain State or local requirements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8352/g"},"text":"section 8352(g) of this title","children":[],"tail":", relating to certain intermediate load powerplants; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8473/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant or denial of any exemption under this chapter for any powerplant for which the Secretary finds, in consultation with the appropriate Federal agency, and publishes such finding that an environmental impact statement is required in connection with another Federal action and such statement will be prepared by such agency and will reflect the exemption adequately.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except as provided in the preceding provisions of this section, any determination of what constitutes or does not constitute a major Federal action shall be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332"},"text":"section 4332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe991f57-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVII/s763"},"text":"Pub. L. 95–620, title VII, § 763","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3346"},"text":"92 Stat. 3346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/24"},"text":"Pub. L. 100–42, § 1(c)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/314"},"text":"101 Stat. 314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe991f58-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe991f59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe991f5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe991f5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/24/A"},"text":"Pub. L. 100–42, § 1(c)(24)(A)","children":[],"tail":", struck out “or major fuel-burning installation” after “powerplant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/24"},"text":"Pub. L. 100–42, § 1(c)(24)","children":[],"tail":", struck out “or major fuel-burning installation” after “powerplant” and struck out subpar. (B) which read as follows: “under section 8352("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title, relating to scheduled equipment outages;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/24/A"},"text":"Pub. L. 100–42, § 1(c)(24)(A)","children":[],"tail":", struck out “or major fuel-burning installation” after “powerplant”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
