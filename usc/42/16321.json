{"tag":"section","attrib":{"id":"idc00d21b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16321"},"text":null,"children":[{"tag":"num","attrib":{"value":"16321"},"text":"§ 16321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility for Rare Isotope Beams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall construct and operate a Facility for Rare Isotope Beams. The Secretary shall commence construction no later than ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as may be necessary to carry out this section. The Secretary shall not spend more than $1,100,000,000 in Federal funds for all activities associated with the Facility for Rare Isotope Beams, prior to operation of the Accelerator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21b9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s981"},"text":"Pub. L. 109–58, title IX, § 981","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/907"},"text":"119 Stat. 907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s308/b"},"text":"Pub. L. 115–246, title III, § 308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3150"},"text":"132 Stat. 3150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d21ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d21bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d21bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246"},"text":"Pub. L. 115–246","children":[],"tail":" substituted “Facility for Rare Isotope Beams” for “Rare Isotope Accelerator” in section catchline and in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
