{"tag":"section","attrib":{"id":"idbc7972f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199"},"text":null,"children":[{"tag":"num","attrib":{"value":"3199"},"text":"§ 3199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Disaster Recovery and Resilience","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7972f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an Office of Disaster Recovery and Resilience—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7972f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct and implement the post-disaster economic recovery responsibilities of the Economic Development Administration pursuant to subsections (c)(2) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3149"},"text":"section 3149 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3233"},"text":"section 3233 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7972f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct and implement economic recovery and enhanced resilience support function activities as directed under the National Disaster Recovery Framework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7972f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support long-term economic recovery in communities in which a major disaster or emergency has been declared under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.), or otherwise impacted by an event of national significance, as determined by the Secretary, through—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7972f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convening and deploying an economic development assessment team;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7972f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hosting or attending convenings related to identification of additional Federal, State, local, and philanthropic entities and resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7972f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring potential flexibilities related to existing awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7972f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of technical assistance through staff or contractual resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7972fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7972fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7972fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to appoint such temporary personnel as may be necessary to carry out the responsibilities of the Office of Disaster Recovery and Resilience, without regard to the provisions of subchapter I of chapter 33 of title 5 governing appointments in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7972fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion of employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding chapter 33 of title 5, or any other provision of law relating to the examination, certification, and appointment of individuals in the competitive service, a temporary employee appointed under this subsection may be selected by the Secretary for a permanent appointment in the competitive service in the Economic Development Administration under internal competitive promotion procedures if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc7972fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has served continuously for at least 2 years under 1 or more appointments under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc7972ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee’s performance has been at an acceptable level of performance throughout the period or periods referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status upon conversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual converted under this subsection shall become a career-conditional employee, unless the employee has already completed the service requirements for career tenure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year during which the Secretary exercises the authority under this subsection, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that describes the use of that authority including, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc797302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees hired under the authority during the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the positions and grades for which employees were hired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees converted to career-conditional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Secretary assessed employee performance to determine the eligibility of the employee for conversion under paragraph (2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees who were hired under that authority as temporary employees who have met the continuous service requirements described in subparagraph (A) of paragraph (2) but not the performance requirements described in subparagraph (B) of that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees who were hired under that authority who have separated from the Economic Development Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection waives any requirement relating to qualifications of applicants for positions in the Office of Disaster Recovery and Resilience under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797309-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this subsection shall expire on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc79730a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster team","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc79730b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall establish a disaster team (referred to in this section as the “disaster team”) for the deployment of individuals to carry out responsibilities of the Office of Disaster Recovery and Resilience after a major disaster or emergency has been declared under the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) and the Department has been activated by the Federal Emergency Management Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79730c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc79730d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of staff","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall designate to serve on the disaster team—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbc79730e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the Office of Disaster Recovery and Resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc79730f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the Department who are not employees of the Economic Development Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc797310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the heads of other Federal agencies, employees of those agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating individuals under subparagraph (A), the Secretary shall ensure that the disaster team includes a sufficient quantity of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc797312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are capable of deploying rapidly and efficiently to respond to major disasters and emergencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc797313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highly trained full-time employees who will lead and manage the disaster team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that appropriate and ongoing training is provided to members of the disaster team to ensure that the members are adequately trained regarding the programs and policies of the Economic Development Administration relating to post-disaster economic recovery efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc797316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, with or without reimbursement, any service, equipment, personnel, or facility of any Federal agency with the explicit support of that agency, to the extent such use does not impair or conflict with the authority of the President or the Administrator of the Federal Emergency Management Agency under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) to direct Federal agencies in any major disaster or emergency declared under that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc797317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide members of the disaster team with travel expenses, including per diem in lieu of subsistence, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of services for, or relating to, the disaster team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-07-01"},"text":"July 1, 2026","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc797319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities of the Office of Disaster Recovery and Resilience and any disaster teams established pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79731a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and details of the disasters in which the Office of Disaster Recovery and Resilience and permanent and temporary personnel, including disaster teams, were involved and deployed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79731b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the locations and length of any deployments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79731c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel deployed, broken down by category, including permanent and temporary personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc79731d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3199/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a breakdown of expenses, with or without reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc79731e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s509"},"text":"Pub. L. 89–136, title V, § 509","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2228"},"text":"Pub. L. 118–272, div. B, title II, § 2228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3192"},"text":"138 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc79731f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc797320-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc797321-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsecs. (a)(3) and (c)(1), (4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
