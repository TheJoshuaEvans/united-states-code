{"tag":"section","attrib":{"id":"idb6836b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–3"},"text":"§ 300cc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Research Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the Commissioner of Food and Drugs, the Secretary, acting through the Director of the National Institute of Allergy and Infectious Diseases, shall establish within such Institute an advisory committee to be known as the AIDS Research Advisory Committee (hereafter in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall be composed of physicians whose clinical practice includes a significant number of patients with acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836b7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Director of such Institute (and may provide advice to the Directors of other agencies of the National Institutes of Health, as appropriate) on appropriate research activities to be undertaken with respect to clinical treatment of such syndrome, including advice with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836b7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on drugs for preventing or minimizing the development of symptoms or conditions arising from infection with the etiologic agent for such syndrome, including recommendations on the projects of research with respect to diagnosing immune deficiency and with respect to predicting, diagnosing, preventing, and treating opportunistic cancers and infectious diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836b7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" research on the effectiveness of treating such symptoms or conditions with drugs that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6836b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not approved by the Commissioner of Food and Drugs for the purpose of treating such symptoms or conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6836b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are being utilized for such purpose by individuals infected with such etiologic agent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review ongoing publicly and privately supported research on clinical treatment for acquired immune deficiency syndrome, including research on drugs described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836b81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically issue, and make available to health care professionals, reports describing and evaluating such research;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct studies and convene meetings for the purpose of determining the recommendations among physicians in clinical practice on clinical treatment of acquired immune deficiency syndrome, including treatment with the drugs described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a study for the purpose of developing, with respect to individuals infected with the etiologic agent for acquired immune deficiency syndrome, a consensus among health care professionals on clinical treatments for preventing or minimizing the development of symptoms or conditions arising from infection with such etiologic agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836b84-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2304, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3065"},"text":"102 Stat. 3065","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2617/a"},"text":"Pub. L. 100–690, title II, § 2617(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4240"},"text":"102 Stat. 4240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/1"},"text":"Pub. L. 103–43, title XVIII, § 1811(1)","children":[],"tail":", title XX, § 2008(d)(1), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"