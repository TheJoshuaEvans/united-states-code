{"tag":"section","attrib":{"id":"idb7e6a45a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679"},"text":null,"children":[{"tag":"num","attrib":{"value":"679"},"text":"§ 679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data relating to adoption and foster care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e6a45b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Adoption and Foster Care Information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e6a45c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", the Secretary shall establish an Advisory Committee on Adoption and Foster Care Information (in this section referred to as the “Advisory Committee”) to study the various methods of establishing, administering, and financing a system for the collection of data with respect to adoption and foster care in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a45d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The study required by paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify the types of data necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess (on a continuing basis) the incidence, characteristics, and status of adoption and foster care in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop appropriate national policies with respect to adoption and foster care;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the feasibility and appropriateness of collecting data with respect to privately arranged adoptions and adoptions arranged through private agencies without assistance from public child welfare agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the validity of various methods of collecting data with respect to adoption and foster care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the financial and administrative impact of implementing each such method.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", the Advisory Committee shall submit to the Secretary and the Congress a report setting forth the results of the study required by paragraph (1) and evaluating and making recommendations with respect to the various methods of establishing, administering, and financing a system for the collection of data with respect to adoption and foster care in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), the membership and organization of the Advisory Committee shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The membership of the Advisory Committee shall include representatives of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private, nonprofit organizations with an interest in child welfare (including organizations that provide foster care and adoption services),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing State and local governmental agencies with responsibility for foster care and adoption services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing State and local governmental agencies with responsibility for the collection of health and social statistics,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing State and local judicial bodies with jurisdiction over family law,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies responsible for the collection of health and social statistics, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations and agencies involved with privately arranged or international adoptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the date of the submission of the report required by paragraph (3), the Advisory Committee shall cease to exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e6a46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress; regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e6a470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":", the Secretary shall submit to the Congress a report that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes a method of establishing, administering, and financing a system for the collection of data relating to adoption and foster care in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the feasibility and appropriateness of collecting data with respect to privately arranged adoptions and adoptions arranged through private agencies without assistance from public child welfare agencies, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates the impact of the system proposed under clause (i) on the agencies with responsibility for implementing it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report required by subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify any changes in law that will be necessary to implement the system proposed under subparagraph (A)(i), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the type of system that will be implemented under paragraph (2) in the absence of such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":", the Secretary shall promulgate final regulations providing for the implementation of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the system proposed under paragraph (1)(A)(i), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the changes in law specified pursuant to paragraph (1)(B)(i) have not been enacted, the system described in paragraph (1)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such regulations shall provide for the full implementation of the system not later than ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e6a47b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any data collection system developed and implemented under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e6a47c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid unnecessary diversion of resources from agencies responsible for adoption and foster care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that any data that is collected is reliable and consistent over time and among jurisdictions through the use of uniform definitions and methodologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide comprehensive national information with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demographic characteristics of adoptive and foster children and their biological and adoptive or foster parents,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the foster care population (including the number of children in foster care, length of placement, type of placement, availability for adoption, and goals for ending or continuing foster care),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number and characteristics of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children placed in or removed from foster care,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children adopted or with respect to whom adoptions have been terminated, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children placed in foster care outside the State which has placement and care responsibility,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of assistance provided by Federal, State, and local adoption and foster care programs and the characteristics of the children with respect to whom such assistance is provided; ","children":[{"tag":"ref","attrib":{"idref":"fn002642"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002642"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a comma."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the annual number of children in foster care who are identified as sex trafficking victims—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e6a487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who were such victims before entering foster care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e6a488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who were such victims while in foster care; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize appropriate requirements and incentives to ensure that the system functions reliably throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e6a48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection on adoption and legal guardianship disruption and dissolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To promote improved knowledge on how best to ensure strong, permanent families for children, the Secretary shall promulgate regulations providing for the collection and analysis of information regarding children who enter into foster care under the supervision of a State after prior finalization of an adoption or legal guardianship. The regulations shall require each State with a State plan approved under this part to collect and report as part of such data collection system the number of children who enter foster care under supervision of the State after finalization of an adoption or legal guardianship and may include information concerning the length of the prior adoption or guardianship, the age of the child at the time of the prior adoption or guardianship, the age at which the child subsequently entered foster care under supervision of the State, the type of agency involved in making the prior adoptive or guardianship placement, and any other factors determined necessary to better understand factors associated with the child’s post-adoption or post-guardianship entry to foster care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e6a48b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 479, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIX/s9443"},"text":"Pub. L. 99–509, title IX, § 9443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2073"},"text":"100 Stat. 2073","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s209/c"},"text":"Pub. L. 103–432, title II, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4459"},"text":"108 Stat. 4459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/183/tI/s103"},"text":"Pub. L. 113–183, title I, § 103","children":[],"tail":", title II, § 208, "},{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1922"},"text":"128 Stat. 1922","children":[],"tail":", 1940.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e6a48c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e6a48d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7e6a48e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/s103"},"text":"Pub. L. 113–183, § 103","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/s208"},"text":"Pub. L.