{"tag":"section","attrib":{"id":"idb6a4d67a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–135"},"text":"§ 300ff–135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of employee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d67b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After receiving a notification for purposes of section 300ff–132 or 300ff–133(d)(2) of this title, a designated officer of emergency response employees shall, to the extent practicable, immediately notify each of such employees who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d67c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responded to the emergency involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d67d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as indicated by guidelines developed by the Secretary, may have been exposed to an infectious disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d67e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain contents of notification to employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification under this subsection to an emergency response employee shall inform the employee of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d67f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that the employee may have been exposed to an infectious disease and the name of the disease involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action by the employee that, as indicated by guidelines developed by the Secretary, is medically appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if medically appropriate under such criteria, the date of such emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responses other than notification of exposure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receiving a response under paragraph (3) or (4) of subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–133"},"text":"section 300ff–133 of this title","children":[],"tail":", or a response under subsection (g)(1) of such section, the designated officer for the employee shall, to the extent practicable, immediately inform the employee of the response."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d683-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2695D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s13"},"text":"Pub. L. 111–87, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2901"},"text":"123 Stat. 2901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d684-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d685-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d686-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
