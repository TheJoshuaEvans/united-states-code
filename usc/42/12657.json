{"tag":"section","attrib":{"id":"idbf95ce11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657"},"text":null,"children":[{"tag":"num","attrib":{"value":"12657"},"text":"§ 12657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf95ce12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall, directly or through grants, contracts, or cooperative agreements (including through State Commissions), conduct appropriate training for and provide technical assistance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs receiving assistance under the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" entities (particularly entities in rural areas and underserved communities) that desire to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf95ce15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out or establish national service programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply for assistance (including subgrants) under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf95ce17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such training and technical assistance activities may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to entities applying to carry out national service programs or entities carrying out national service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting leadership development in national service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the instructional and programmatic quality of national service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the management and budgetary skills of individuals operating or overseeing national service programs, including developing skills to increase the cost effectiveness of the programs under the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for or improving the training provided to the participants in programs under the national service laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the education of individuals participating in national service programs in risk management procedures, including the training of participants in appropriate risk management practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training individuals operating or overseeing national service programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf95ce1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in volunteer recruitment, management, and retention to improve the abilities of such individuals to use participants and other volunteers in an effective manner, which training results in high-quality service and the desire of participants and volunteers to continue to serve in other capacities after the program is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in program evaluation and performance measures to inform practices to augment the capacity and sustainability of the national service programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf95ce21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively accommodate individuals with disabilities to increase the participation of individuals with disabilities in national service programs, which training may utilize funding from the reservation of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581/k"},"text":"section 12581(k) of this title","children":[],"tail":" to increase the participation of individuals with disabilities;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing networks and collaboration among employers, educators, and other key stakeholders in the community to further leverage resources to increase local participation in national service programs, and to coordinate community-wide planning and service with respect to national service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training and technical assistance for the National Senior Service Corps, including providing such training and technical assistance to programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5001"},"text":"section 5001 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out such other activities as the Chief Executive Officer determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf95ce25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Corporation shall give priority to programs under the national service laws and entities eligible to establish such programs that seek training or technical assistance and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf95ce26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to carry out high-quality programs where the services are needed most;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to carry out high-quality programs where national service programs do not exist or where the programs are too limited to meet community needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to carry out high-quality programs that focus on and provide service opportunities for underserved rural and urban areas and populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf95ce29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12657/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to assist programs in developing a service component that combines students, out-of-school youths, and older adults as participants to provide needed community services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf95ce2a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199N"},"text":"Pub. L. 101–610, title I, § 199N","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1821"},"text":"Pub. L. 111–13, title I, § 1821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1577"},"text":"123 Stat. 1577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf95ce2b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf95ce2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf95ce2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
