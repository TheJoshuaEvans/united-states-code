{"tag":"section","attrib":{"id":"idbe3294fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7478"},"text":null,"children":[{"tag":"num","attrib":{"value":"7478"},"text":"§ 7478.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period before plan approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe3294fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7478/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing regulations to remain in effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until such time as an applicable implementation plan is in effect for any area, which plan meets the requirements of this part to prevent significant deterioration of air quality with respect to any air pollutant, applicable regulations under this chapter prior to ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", shall remain in effect to prevent significant deterioration of air quality in any such area for any such pollutant except as otherwise provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3294fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7478/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations deemed amended; construction commenced after ","children":[{"tag":"date","attrib":{"date":"1975-06-01"},"text":"June 1, 1975","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any regulation in effect prior to ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", to prevent significant deterioration of air quality would be inconsistent with the requirements of section 7472(a), section 7473(b) or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7474/a"},"text":"section 7474(a) of this title","children":[],"tail":", then such regulations shall be deemed amended so as to conform with such requirements. In the case of a facility on which construction was commenced (in accordance with the definition of “commenced” in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479/2"},"text":"section 7479(2) of this title","children":[],"tail":") after "},{"tag":"date","attrib":{"date":"1975-06-01"},"text":"June 1, 1975","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", the review and permitting of such facility shall be in accordance with the regulations for the prevention of significant deterioration in effect prior to "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe3294fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 168, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s127/a"},"text":"Pub. L. 95–95, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/740"},"text":"91 Stat. 740","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/190/s14/a/52"},"text":"Pub. L. 95–190, § 14(a)(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-16"},"text":"Nov. 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1402"},"text":"91 Stat. 1402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe3294fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe3294ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe329500-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/190"},"text":"Pub. L. 95–190","children":[],"tail":" substituted “(in accordance with the definition of ‘commenced’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479/2"},"text":"section 7479(2) of this title","children":[],"tail":")” for “in accordance with this definition”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
