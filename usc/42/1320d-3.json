{"tag":"section","attrib":{"id":"idb85dd0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320d–3"},"text":"§ 1320d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timetables for adoption of standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85dd0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":" not later than 18 months after "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":", except that standards relating to claims attachments shall be adopted not later than 30 months after "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85dd0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions and modifications to standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85dd0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall review the standards adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":", and shall adopt modifications to the standards (including additions to the standards), as determined appropriate, but not more frequently than once every 12 months. Any addition or modification to a standard shall be completed in a manner which minimizes the disruption and cost of compliance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85dd0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85dd0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First 12-month period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with respect to additions and modifications to code sets under subparagraph (B), the Secretary may not adopt any modification to a standard adopted under this part during the 12-month period beginning on the date the standard is initially adopted, unless the Secretary determines that the modification is necessary in order to permit compliance with the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86041b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions and modifications to code sets","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86041b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that procedures exist for the routine maintenance, testing, enhancement, and expansion of code sets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86041b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320d–3/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a code set is modified under this subsection, the modified code set shall include instructions on how data elements of health information that were encoded prior to the modification may be converted or translated so as to preserve the informational value of the data elements that existed before the modification. Any modification to a code set under this subsection shall be implemented in a manner that minimizes the disruption and cost of complying with such modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86041b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1174, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tII/s262/a"},"text":"Pub. L. 104–191, title II, § 262(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2026"},"text":"110 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
