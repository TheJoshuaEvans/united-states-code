{"tag":"section","attrib":{"id":"idb77b872c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for reemployment services and eligibility assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb77b872d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor (in this section referred to as the “Secretary”) shall award grants under this section for a fiscal year to eligible States to conduct a program of reemployment services and eligibility assessments for claimants for regular compensation, including claimants referred to reemployment services as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/j"},"text":"section 503(j) of this title","children":[],"tail":", for weeks in such fiscal year for which such claimants receive unemployment compensation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b872e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are to accomplish the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b872f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve employment outcomes of individuals that receive unemployment compensation and to reduce the average duration of receipt of such compensation through employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To strengthen program integrity and reduce improper payments of unemployment compensation by States through the detection and prevention of such payments to individuals who are not eligible for such compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote alignment with the broader vision of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"29 U.S.C. 3101","children":[],"tail":" et seq.) of increased program integration and service delivery for job seekers, including claimants for unemployment compensation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish reemployment services and eligibility assessments as an entry point for individuals receiving unemployment compensation into other workforce system partner programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b8734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out a State program of reemployment services and eligibility assessments using grant funds awarded to the State under this section, a State shall use such funds only for interventions demonstrated to reduce the number of weeks for which program participants receive unemployment compensation by improving employment outcomes for program participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding evidence-based interventions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the requirement imposed by paragraph (1), a State shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b8736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years 2023 and 2024, use no less than 25 percent of the grant funds awarded to the State under this section for interventions with a high or moderate causal evidence rating that show a demonstrated capacity to improve employment and earnings outcomes for program participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years 2025 and 2026, use no less than 40 percent of such grant funds for interventions described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years beginning after fiscal year 2026, use no less than 50 percent of such grant funds for interventions described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b873a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any intervention without a high or moderate causal evidence rating used by a State in carrying out a State program of reemployment services and eligibility assessments under this section shall be under evaluation at the time of use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b873b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall use not more than 10 percent of grant funds awarded to the State under this section to conduct or cause to be conducted evaluations of interventions used in carrying out a program under this section (including evaluations conducted pursuant to paragraph (1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b873c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b873d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of eligibility to receive a grant under this section for a fiscal year, a State shall submit to the Secretary, at such time and in such manner as the Secretary may require, a State plan that outlines how the State intends to conduct a program of reemployment services and eligibility assessments under this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b873e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that, and a description of how, the program will provide—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb77b873f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper notification to participating individuals of the program’s eligibility conditions, requirements, and benefits, including the issuance of warnings and simple, clear notifications to ensure that participating individuals are fully aware of the consequences of failing to adhere to such requirements, including policies related to non-attendance or non-fulfillment of work search requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable scheduling accommodations to maximize participation for eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that, and a description of how, the program will conform with the purposes outlined in subsection (b) and satisfy the requirement to use evidence-based standards under subsection (c), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb77b8742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the evidence-based interventions the State plans to use to speed reemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how such interventions are appropriate to the population served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, a description of the evaluation structure the State plans to use for interventions without at least a moderate or high causal evidence rating, which may include national evaluations conducted by the Department of Labor or by other entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of any reemployment activities and evaluations conducted in the prior fiscal year, and any data collected on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb77b8746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characteristics of program participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of weeks for which program participants receive unemployment compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment and other outcomes for program participants consistent with State performance accountability measures provided by the State unemployment compensation program and in section 116(b) of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b"},"text":"29 U.S.C. 3141(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve any State plan, that is timely submitted to the Secretary, in such manner as the Secretary may require, that satisfies the conditions described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b874a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval and revision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a State plan submitted pursuant to this subsection fails to satisfy the conditions described in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b874b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove such plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b874c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the State, not later than 30 days after the date of receipt of the State plan, a written notice of such disapproval that includes a description of any portion of the plan that was not approved and the reason for the disapproval of each such portion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b874d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the State with an opportunity to correct any such failure and submit a revised State plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b874e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b874f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b8750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year after fiscal year 2020, the Secretary shall allocate a percentage equal to the base funding percentage for such fiscal year of the funds made available for grants under this section among the States awarded such a grant for such fiscal year using a formula prescribed by the Secretary based on the rate of insured unemployment (as defined in section 203(e)(1) of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)) in the State for a period to be determined by the Secretary. In developing such formula with respect to a State, the Secretary shall consider the importance of avoiding sharp reductions in grant funding to a State over time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base funding percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “base funding percentage” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb77b8752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years 2021 through 2026, 89 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years after 2026, 84 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for outcome payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b8755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under this section for each fiscal year after 2020, the Secretary shall reserve a percentage equal to the outcome reservation percentage for such fiscal year for outcome payments to increase the amount otherwise awarded to a State under paragraph (1). Such outcome payments shall be paid to States conducting reemployment services and eligibility assessments under this section that, during the previous fiscal year, met or exceeded the outcome goals provided in subsection (b)(1) related to reducing the average duration of receipt of unemployment compensation by improving employment outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outcome reservation percentage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), the term “outcome reservation percentage” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb77b8757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years 2021 through 2026, 10 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb77b8758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal years after 2026, 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for research and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under this section for each fiscal year after 2020, the Secretary may reserve not more than 1 percent to conduct research and provide technical assistance to States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b875a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and public comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b875b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the States and seek public comment in developing the allocation formula under paragraph (1) and the criteria for carrying out the reservations under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b875c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available the allocation formula and criteria developed pursuant to subclause (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b875d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days prior to making any changes to the allocation formula or the criteria developed pursuant to subsection (f)(5)(A), the Secretary shall submit to Congress, including to the Committee on Ways and Means and the Committee on Appropriations of the House of Representatives and the Committee on Finance and the Committee on Appropriations of the Senate, a notification of any such change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b875e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to carry out this section shall be used to supplement the level of Federal, State, and local public funds that, in the absence of such availability, would be expended to provide reemployment services and eligibility assessments to individuals receiving unemployment compensation, and in no case to supplant such Federal, State, or local public funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b875f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b8760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Causal evidence rating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “high causal evidence rating” and “moderate causal evidence rating” shall have the meaning given such terms by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible state","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible State” means a State that has in effect a State plan approved by the Secretary in accordance with subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intervention” means a service delivery strategy for the provision of State reemployment services and eligibility assessment activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the meaning given the term in section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s506/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term unemployment compensation means “regular compensation”, “extended compensation”, and “additional compensation” (as such terms are defined by section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb77b8765-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title III, § 306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dC/tII/s30206/a"},"text":"Pub. L. 115–123, div. C, title II, § 30206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/127"},"text":"132 Stat. 127","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/120/s2/a"},"text":"Pub. L. 118–120, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1626"},"text":"138 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb77b8766-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb77b8767-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb77b8768-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", which enacted chapter 32 (§ 3101 et seq.) of Title 29, Labor, repealed chapter 30 (§ 2801 et seq.) of Title 29 and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made amendments to numerous other sections and notes in the Code. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s1/a"},"text":"section 1(a) of Pub. L. 113–128","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal-State Extended Unemployment Compensation Act of 1970, referred to in subsecs. (f)(1)(A) and (i)(4), (5), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373"},"text":"Pub. L. 91–373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/708"},"text":"84 Stat. 708","children":[],"tail":", which is classified generally as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":", Internal Revenue Code. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb77b8769-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/120"},"text":"Pub. L. 118–120","children":[],"tail":" substituted “claimants for regular compensation, including claimants referred to reemployment services as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/j"},"text":"section 503(j) of this title","children":[],"tail":",” for “individuals referred to reemployment services as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/j"},"text":"section 503(j) of this title","children":[],"tail":"” and “such claimants” for “such individuals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb77b876a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb77b876b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/120/s2/b"},"text":"Pub. L. 118–120, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1626"},"text":"138 Stat. 1626","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/120/s2/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-11-25"},"text":"Nov. 25, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
