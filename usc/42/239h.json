{"tag":"section","attrib":{"id":"idb4879af3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s239h"},"text":null,"children":[{"tag":"num","attrib":{"value":"239h"},"text":"§ 239h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as explicitly provided herein, nothing in this part shall be construed to override or limit any rights an individual may have to seek compensation, benefits, or redress under any other provision of Federal or State law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4879af4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 269, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/20/s2"},"text":"Pub. L. 108–20, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/645"},"text":"117 Stat. 645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
