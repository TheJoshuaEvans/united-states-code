{"tag":"section","attrib":{"id":"idbb377d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1588"},"text":null,"children":[{"tag":"num","attrib":{"value":"1588"},"text":"§ 1588.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of vacant land to local housing authorities; sale of personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb377d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1588/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any land acquired under subchapters II to VII of this chapter or any other Act in connection with war or veterans’ housing, but upon which no dwellings are located at the time of sale, may be sold at fair value, as determined by the Secretary of Housing and Urban Development to any agency organized for slum clearance or to provide subsidized housing for persons of low income.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb377d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1588/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any personal property held under subchapters II to VII of this chapter, and not sold with a project or building, may be sold at fair value, as determined by the Secretary of Housing and Urban Development to any agency organized for slum clearance or to provide subsidized housing for persons of low income. Any sale of personal property under this subsection shall be made on a cash basis, payable at the time of settlement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb377d6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title VI, § 608, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-28/ch688/s7"},"text":"June 28, 1948, ch. 688, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch787"},"text":"Aug. 11, 1955, ch. 787","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/668"},"text":"69 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb377d6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb377d70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb377d71-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters III and VI of this chapter, referred to in text, were comprised of sections 1531 to 1536 and 1571 to 1576, respectively, of this title and have been omitted from the Code. For further details, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb377d72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb377d73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb377d74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
