{"tag":"section","attrib":{"id":"idbc6d8c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058aa–1"},"text":"§ 3058aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to promote comprehensive State elder justice systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6d8c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Assistant Secretary may make grants to States, on a competitive basis, in accordance with this section, to promote the development and implementation, within each such State, of a comprehensive elder justice system, as defined in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive elder justice system defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “comprehensive elder justice system” means an integrated, multidisciplinary, and collaborative system for preventing, detecting, and addressing elder abuse, neglect, and exploitation in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for widespread, convenient public access to the range of available elder justice information, programs, and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates the efforts of public health, social service, and law enforcement authorities, as well as other appropriate public and private entities, to identify and diminish duplication and gaps in the system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a uniform method for the standardization, collection, management, analysis, and reporting of data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such other elements as the Assistant Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section for a fiscal year, a State shall submit an application to the Assistant Secretary, at such time, in such manner, and containing such information and assurances as the Assistant Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant to a State with an application approved under this section for a fiscal year shall be such amount as the Assistant Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives a grant under this section shall use funds made available through such grant to promote the development and implementation of a comprehensive elder justice system by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6d8c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing formal working relationships among public and private providers of elder justice programs, service providers, and stakeholders in order to create a unified elder justice network across such State to coordinate programmatic efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating and supporting the development of a management information system and standard data elements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8c75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for appropriate education (including educating the public about the range of available elder justice information, programs, and services), training, and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8c76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking such other steps as the Assistant Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to States pursuant to this section shall be used to supplement and not supplant other Federal, State, and local funds expended to support activities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8c78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s752"},"text":"Pub. L. 89–73, title VII, § 752","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVII/s704/2"},"text":"Pub. L. 109–365, title VII, § 704(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2593"},"text":"120 Stat. 2593","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
