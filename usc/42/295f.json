{"tag":"section","attrib":{"id":"idb5e88b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f"},"text":null,"children":[{"tag":"num","attrib":{"value":"295f"},"text":"§ 295f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment in tomorrow’s pediatric health care workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out a pediatric specialty loan repayment program under which the eligible individual agrees to be employed full-time for a specified period (which shall not be less than 2 years) in providing pediatric medical subspecialty, pediatric surgical specialty, or child and adolescent mental and behavioral health care, including substance abuse prevention and treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Through the program established under this section, the Secretary shall enter into contracts with qualified health professionals under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such qualified health professionals will agree to provide pediatric medical subspecialty, pediatric surgical specialty, or child and adolescent mental and behavioral health care in an area with a shortage of the specified pediatric subspecialty that has a sufficient pediatric population to support such pediatric subspecialty, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary agrees to make payments on the principal and interest of undergraduate, graduate, or graduate medical education loans of professionals described in paragraph (1) of not more than $35,000 a year for each year of agreed upon service under such paragraph for a period of not more than 3 years during the qualified health professional’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in an accredited pediatric medical subspecialty, pediatric surgical specialty, or child and adolescent mental health subspecialty residency or fellowship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment as a pediatric medical subspecialist, pediatric surgical specialist, or child and adolescent mental health professional serving an area or population described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric medical specialists and pediatric surgical specialists","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of contracts with respect to pediatric medical specialists and pediatric surgical specialists, the term “qualified health professional” means a licensed physician who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5e88b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entering or receiving training in an accredited pediatric medical subspecialty or pediatric surgical specialty residency or fellowship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e88b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed (but not prior to the end of the calendar year in which this section is enacted) the training described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child and adolescent mental and behavioral health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of contracts with respect to child and adolescent mental and behavioral health care, the term “qualified health professional” means a health care professional who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5e88b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received specialized training or clinical experience in child and adolescent mental health in psychiatry, psychology, school psychology, behavioral pediatrics, psychiatric nursing, social work, school social work, substance abuse disorder prevention and treatment, marriage and family therapy, school counseling, or professional counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e88b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a license or certification in a State to practice allopathic medicine, osteopathic medicine, psychology, school psychology, psychiatric nursing, social work, school social work, marriage and family therapy, school counseling, or professional counseling; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e88b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a mental health service professional who completed (but not before the end of the calendar year in which this section is enacted) specialized training or clinical experience in child and adolescent mental health described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into a contract under this subsection with an eligible individual unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual agrees to work in, or for a provider serving, a health professional shortage area or medically underserved area, or to serve a medically underserved population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is a United States citizen or a permanent legal United States resident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual is enrolled in a graduate program, the program is accredited, and the individual has an acceptable level of academic standing (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In entering into contracts under this subsection, the Secretary shall give priority to applicants who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are or will be working in a school or other pre-kindergarten, elementary, or secondary education setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have familiarity with evidence-based methods and cultural and linguistic competence health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate financial need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b71-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 775, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5203"},"text":"Pub. L. 111–148, title V, § 5203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/607"},"text":"124 Stat. 607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3401/13"},"text":"Pub. L. 116–136, div. A, title III, § 3401(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/387"},"text":"134 Stat. 387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88b72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e88b73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5e88b74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The calendar year in which this section is enacted, referred to in subsec. (c)(1)(A)(ii), (B)(iii), probably means the calendar year in which ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" was enacted. Such Act was approved "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e88b75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 295f, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s770"},"text":"act July 1, 1944, ch. 373, title VII, § 770","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/290/s2/a"},"text":"Pub. L. 89–290, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1052"},"text":"79 Stat. 1052","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tI/s111/a"},"text":"Pub. L. 90–490, title I, § 111(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/774"},"text":"82 Stat. 774","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s104/a"},"text":"Pub. L. 92–157, title I, § 104(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/437"},"text":"85 Stat. 437","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tI/s101/k"},"text":"Pub. L. 94–484, title I, § 101(k)","children":[],"tail":", title V, § 501(a)–(c), "},{"tag":"ref","attrib":{"href":"/us/stat/90/2245"},"text":"90 Stat. 2245","children":[],"tail":", 2290, 2291; "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2746/a/1"},"text":"Pub. L. 97–35, title XXVII, § 2746(a)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/927"},"text":"95 Stat. 927","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s211/a/1"},"text":"Pub. L. 99–129, title II, § 211(a)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/537"},"text":"99 Stat. 537","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s606/a"},"text":"Pub. L. 100–607, title VI, § 606(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3127"},"text":"102 Stat. 3127","children":[],"tail":", related to capitation grants for schools of public health, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s773"},"text":"act July 1, 1944, ch. 373, title VII, § 773","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s606/b"},"text":"Pub. L. 100–607, title VI, § 606(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3127"},"text":"102 Stat. 3127","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 775 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 772 by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":", and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295f–2"},"text":"section 295f–2 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s773"},"text":"act July 1, 1944, ch. 373, title VII, § 773","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s606/b"},"text":"Pub. L. 100–607, title VI, § 606(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3127"},"text":"102 Stat. 3127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5e88b76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “such sums as may be necessary for each of fiscal years 2021 through 2025.” for “$30,000,000 for each of fiscal years 2010 through 2014 to carry out subsection (c)(1)(A) and $20,000,000 for each of fiscal years 2010 through 2013 to carry out subsection (c)(1)(B).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
