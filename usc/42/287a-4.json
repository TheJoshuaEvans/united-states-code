{"tag":"section","attrib":{"id":"idb5844a7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"287a–4"},"text":"§ 287a–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General clinical research centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5844a7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Center shall award grants for the establishment of general clinical research centers to provide the infrastructure for clinical research including clinical research training and career enhancement. Such centers shall support clinical studies and career development in all settings of the hospital or academic medical center involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5844a7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287a–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Director of National Institutes of Health shall expand the activities of the general clinical research centers through the increased use of telecommunications and telemedicine initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5844a80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 481B, formerly §