{"tag":"section","attrib":{"id":"idbdbdb30b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838"},"text":null,"children":[{"tag":"num","attrib":{"value":"6838"},"text":"§ 6838.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-effective codes implementation for efficiency and resilience","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbdb30c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb30d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbdb30e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relevant State agency, as determined by the Secretary, such as a State building code agency, State energy office, or Tribal energy office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb30f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb310-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “partnership” means a partnership between an eligible entity described in paragraph (1)(A) and 1 or more of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbdb311-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local building code agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb312-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Codes and standards developers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb313-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Associations of builders and design and construction professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb314-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local and utility energy efficiency programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb315-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumer, energy efficiency, and environmental advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb316-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other entities, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb317-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb318-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb319-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Building Technologies Office of the Department of Energy a program under which the Secretary shall award grants on a competitive basis to eligible entities to enable sustained cost-effective implementation of updated building energy codes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb31a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated building energy code","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An update to a building energy code under this section, including an amendment that results in increased efficiency compared to the previously adopted building energy code, shall include any update made available after the existing building energy code, even if it is not the most recent updated code available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb31b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria; priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb31c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbdb31d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prospective energy savings and plans to measure the savings, including utilizing the Environmental Protection Agency Portfolio Manager, the Home Energy Score rating of the Office of Energy Efficiency and Renewable Energy of the Department of Energy, the Energy Star Building rating methodologies of the Environmental Protection Agency, and other methodologies determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb31e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the long-term sustainability of those measures and savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb31f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prospective benefits, and plans to assess the benefits, including benefits relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdbdb320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resilience and peak load reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdbdb321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupant safety and health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdbdb322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated capacity of the eligible entity to carry out the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need of the eligible entity for assistance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to applications from partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity awarded a grant under this section may use the grant funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbdb328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create or enable State or regional partnerships to provide training and materials to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdbdb329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" builders, contractors and subcontractors, architects, and other design and construction professionals, relating to meeting updated building energy codes in a cost-effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdbdb32a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building code officials, relating to improving implementation of and compliance with building energy codes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb32b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect and disseminate quantitative data on construction and codes implementation, including code pathways, performance metrics, and technologies used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb32c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement a plan for highly effective codes implementation, including measuring compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb32d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address various implementation needs in rural, suburban, and urban areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb32e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to implement updates in energy codes for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbdbdb32f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new residential and commercial buildings (including multifamily buildings); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbdbdb330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additions and alterations to existing residential and commercial buildings (including multifamily buildings).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related topics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Training and materials provided using a grant under this section may include information on the relationship between energy codes and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdbdb332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-effective, high-performance, and zero-net-energy buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving resilience, health, and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water savings and other environmental impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdbdb335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic impacts of energy codes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6838/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $225,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbdb337-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s309"},"text":"Pub. L. 94–385, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40511/a"},"text":"Pub. L. 117–58, div. D, title V, § 40511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1058"},"text":"135 Stat. 1058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbdb338-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbdb339-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdbdb33a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6838, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s309"},"text":"Pub. L. 94–385, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1149"},"text":"90 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1041/a"},"text":"Pub. L. 97–35, title X, § 1041(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/621"},"text":"95 Stat. 621","children":[],"tail":", related to consultations by Secretary with interested and affected groups in developing and promulgating voluntary performance standards and establishment of advisory committees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s101/a/2"},"text":"Pub. L. 102–486, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2783"},"text":"106 Stat. 2783","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdbdb33b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdbdb33c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
