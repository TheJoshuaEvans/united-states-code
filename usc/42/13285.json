{"tag":"section","attrib":{"id":"idbfb9aa8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285"},"text":null,"children":[{"tag":"num","attrib":{"value":"13285"},"text":"§ 13285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aa8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report annually to Congress on the progress being made, through demonstration projects supported under this part, to accelerate the development and use of electric motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on encouraging purchase and use of electric motor vehicles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit to the Congress a report on methods for encouraging the purchase and use of electric motor vehicles. Such report shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aa8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the potential cost of purchasing and maintaining electric motor vehicles, including the initial cost of the batteries and the cost of replacement batteries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify methods for reducing, subsidizing, or sharing such costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13285/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include recommendations for legislative and administrative measures to encourage the purchase and use of electric motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aa90-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s615"},"text":"Pub. L. 102–486, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2903"},"text":"106 Stat. 2903","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
