{"tag":"section","attrib":{"id":"idbd0f9996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5147"},"text":null,"children":[{"tag":"num","attrib":{"value":"5147"},"text":"§ 5147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal agencies may be reimbursed for expenditures under this chapter from funds appropriated for the purposes of this chapter. Any funds received by Federal agencies as reimbursement for services or supplies furnished under the authority of this chapter shall be deposited to the credit of the appropriation or appropriations currently available for such services or supplies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0f9997-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s304"},"text":"Pub. L. 93–288, title III, § 304","children":[],"tail":", formerly § 307, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/149"},"text":"88 Stat. 149","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/d"},"text":"Pub. L. 100–707, title I, § 105(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4691"},"text":"102 Stat. 4691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f9998-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f9999-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"ta