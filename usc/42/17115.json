{"tag":"section","attrib":{"id":"idc0276172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115"},"text":null,"children":[{"tag":"num","attrib":{"value":"17115"},"text":"§ 17115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance program to implement industrial emissions reduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0276173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relevant State or local office, including an energy office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3765"},"text":"section 3765 of title 38","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027617a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education; and ","children":[{"tag":"ref","attrib":{"idref":"fn004254"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004254"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027617b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027617c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade association or technical society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027617d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emissions reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emissions reduction” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/a"},"text":"section 17113(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027617e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc027617f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a program to provide technical assistance to eligible entities to promote the commercial application of emission reduction technologies developed through the program established in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/b"},"text":"section 17113(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring technical assistance under the program shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek applications for technical assistance under the program on a periodic basis, but not less frequently than once every 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities for technical assistance under the program, the Secretary shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0276185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out with technical assistance under the program that have the greatest potential for achieving emissions reduction in nonpower industrial sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out in a State in which there are active or inactive industrial facilities that may be used or retrofitted to carry out activities under the focus areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out in an economically distressed area (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"section 3161(a) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0276189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is geographic diversity among the eligible entities selected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027618a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17115/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities carried out with technical assistance under the program reflect a majority of the focus areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113/c"},"text":"section 17113(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc027618b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s456"},"text":"Pub. L. 110–140, title IV, § 456","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVI/s6005/a"},"text":"Pub. L. 116–260, div. Z, title VI, § 6005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2559"},"text":"134 Stat. 2559","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
