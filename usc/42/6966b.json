{"tag":"section","attrib":{"id":"idbde16784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6966b"},"text":"§ 6966b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of granular mine tailings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbde16785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mine tailings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbde16786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-10"},"text":"August 10, 2005","children":[],"tail":", the Administrator, in consultation with the Secretary of Transportation and heads of other Federal agencies, shall establish criteria (including an evaluation of whether to establish a numerical standard for concentration of lead and other hazardous substances) for the safe and environmentally protective use of granular mine tailings from the Tar Creek, Oklahoma Mining District, known as “chat”, for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde16787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cement or concrete projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde16788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation construction projects (including transportation construction projects involving the use of asphalt) that are carried out, in whole or in part, using Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde16789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing criteria under paragraph (1), the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbde1678a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current and previous uses of granular mine tailings as an aggregate for asphalt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbde1678b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any environmental and public health risks and benefits derived from the removal, transportation, and use in transportation projects of granular mine tailings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde1678c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the criteria under paragraph (1), the Administrator shall solicit and consider comments from the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbde1678d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the establishment of the criteria under paragraph (1), any use of the granular mine tailings described in paragraph (1) in a transportation project that is carried out, in whole or in part, using Federal funds, shall meet the criteria established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbde1678e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6966b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of sections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6966a"},"text":"section 6966a of this title","children":[],"tail":" affects any requirement of any law (including a regulation) in effect on "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"August 10, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbde1678f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s6006"},"text":"Pub. L. 89–272, title II, § 6006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVI/s6018/a"},"text":"Pub. L. 109–59, title VI, § 6018(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1890"},"text":"119 Stat. 1890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbde16790-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbde16791-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbde16792-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6966a"},"text":"Section 6966a of this title","children":[],"tail":", referred to in subsec. (b), was in the original “section 6005” meaning "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/s6005"},"text":"section 6005 of Pub. L. 89–272","children":[],"tail":", which was translated as meaning the "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/s6005"},"text":"section 6005 of Pub. L. 89–272","children":[],"tail":" as added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s6017/a"},"text":"section 6017(a) of Pub. L. 109–59","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
