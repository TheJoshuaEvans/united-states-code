{"tag":"section","attrib":{"id":"idc0144dc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412"},"text":null,"children":[{"tag":"num","attrib":{"value":"16412"},"text":"§ 16412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training guidelines for nonnuclear electric energy industry personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0144dc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor, in consultation with the Secretary and in conjunction with the electric industry and recognized employee representatives, shall develop model personnel training guidelines to support the reliability and safety of the nonnuclear electric system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0144dc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training guidelines under subsection (a) shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144dc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include training requirements for workers engaged in the construction, operation, inspection, or maintenance of nonnuclear electric generation, transmission, or distribution systems, including requirements relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0144dc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144dc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0144dc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assessment, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0144dc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initial and continuous evaluation of workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0144dca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recertification procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0144dcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for examining or testing the qualification of an individual who performs a covered task; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144dcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidate training guidelines in existence on the date on which the guidelines under subsection (a) are developed relating to the construction, operation, maintenance, and inspection of nonnuclear electric generation, transmission, and distribution facilities, such as guidelines established by the National Electric Safety Code and other industry consensus standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144dcd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1103"},"text":"Pub. L. 109–58, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/939"},"text":"119 Stat. 939","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
