{"tag":"section","attrib":{"id":"idbbf8ab2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2161"},"text":null,"children":[{"tag":"num","attrib":{"value":"2161"},"text":"§ 2161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy of Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be the policy of the Commission to control the dissemination and declassification of Restricted Data in such a manner as to assure the common defense and security. Consistent with such policy, the Commission shall be guided by the following principles:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbf8ab2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until effective and enforceable international safeguards against the use of atomic energy for destructive purposes have been established by an international arrangement, there shall be no exchange of Restricted Data with other nations except as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2164"},"text":"section 2164 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbf8ab30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dissemination of scientific and technical information relating to atomic energy should be permitted and encouraged so as to provide that free interchange of ideas and criticism which is essential to scientific and industrial progress and public understanding and to enlarge the fund of technical information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbfb1b31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 141, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/940"},"text":"68 Stat. 940","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbfb1b32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbfb1b33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbfb1b34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1810/a"},"text":"section 1810(a) of this title","children":[],"tail":", prior to the general amendment and renumbering of act "},{"tag":"date","attrib":{"date":"1946-08-01"},"text":"Aug. 1, 1946","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
