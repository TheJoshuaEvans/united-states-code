{"tag":"section","attrib":{"id":"idb54d8372-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n"},"text":null,"children":[{"tag":"num","attrib":{"value":"280n"},"text":"§ 280n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Parkinson’s Project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54d8373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Parkinson’s","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Parkinson’s” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8374-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parkinson’s disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8375-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other neurodegenerative Parkinsonisms, including multiple system atrophy, corticobasal degeneration, progressive supranuclear palsy, and Parkinson’s-related dementia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8376-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a national project, to be known as the National Parkinson’s Project (referred to in this section as the “Project”), to prevent, diagnose, treat, and cure Parkinson’s.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8377-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities carried out through Project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Project, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8378-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create, maintain, and periodically update an integrated national plan to prevent, diagnose, treat, and cure Parkinson’s, ameliorate symptoms, and slow or stop progression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8379-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the annual assessment under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d837a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide information, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d837b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the level of current Federal investment in preventing, diagnosing, treating, and curing Parkinson’s, ameliorating symptoms, and slowing or stopping progression; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d837c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, an estimate of the investment necessary to prevent, diagnose, treat, and cure Parkinson’s, ameliorate symptoms, and slow or stop progression;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d837d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate research and services across all Federal agencies related to Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d837e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the development of safe and effective treatments, strategies, and other approaches to prevent, diagnose, treat, and cure Parkinson’s, ameliorate symptoms, and slow or stop progression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d837f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d8380-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early diagnosis of Parkinson’s; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d8381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of the care and treatment of individuals with Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the impact of Parkinson’s on the physical, mental, and social health of individuals living with Parkinson’s and their caregivers and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with international bodies, to the extent possible, to integrate and inform the mission to prevent, diagnose, treat, and cure Parkinson’s, ameliorate symptoms, and slow or stop progression globally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, collaborate with other entities to prevent duplication of existing research activities for related disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2024-07-02"},"text":"July 2, 2024","children":[],"tail":", and annually thereafter, the Secretary shall carry out an assessment of the Nation’s progress in preparing for, and responding to, the escalating burden of Parkinson’s, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d8386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for priority actions based on the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any steps that are planned or have already been taken to implement such recommendations, including whether such recommendations can be implemented under existing law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d8388-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other items as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d8389-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d838a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain an Advisory Council on Parkinson’s Research, Care, and Services (referred to in this section as the “Advisory Council”) to advise the Secretary on Parkinson’s-related issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d838b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d838c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall be comprised of experts, to be appointed by the Secretary, who collectively are from various backgrounds and perspectives, including at least one member from each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54d838d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d838e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration on Community Living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d838f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8390-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8391-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency for Healthcare Research and Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8392-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8393-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Minority Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d8399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Surgeon General of the Public Health Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d839a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/A/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant Federal departments and agencies as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d839b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-federal members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the members listed in subparagraph (A), the Advisory Council shall include 10 expert members, to be appointed by the Secretary, who shall include representatives of minority communities, communities disproportionately affected by Parkinson’s, and communities underrepresented in Parkinson’s research, who shall each be from outside the Federal Government, and who shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54d839c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Parkinson’s patient advocates, at least 1 of whom is living with young-onset Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d839d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Parkinson’s family caregiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d839e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 health care provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d839f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 biomedical researchers with Parkinson’s-related expertise in basic, translational, clinical, or drug development science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 movement disorder specialist who treats Parkinson’s patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 dementia specialist who treats Parkinson’s patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 representatives from nonprofit organizations that have demonstrated experience in Parkinson’s-related research or Parkinson’s-related patient care and other services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the members of the Advisory Council are collectively representative of agencies, professions, individuals, and entities concerned with, or affected by, activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d83a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d83a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Council shall meet—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54d83a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least once each quarter during the 2-year period beginning on the date on which the Advisory Council is established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Secretary’s discretion after such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual research meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2024-07-02"},"text":"July 2, 2024","children":[],"tail":", and every year thereafter, the Advisory Council shall convene a meeting of Federal and non-Federal organizations to discuss Parkinson’s research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The meetings under subparagraphs (A) and (B) shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d83aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2024-07-02"},"text":"July 2, 2024","children":[],"tail":", and every year thereafter, the Advisory Council shall provide to the Secretary and Congress a report containing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d83ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all federally-funded efforts in Parkinson’s research, prevention, diagnosis, treatment, clinical care, and institutional-, home-, and community-based programs and the outcomes of such efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for priority actions to expand, eliminate, coordinate, refocus, streamline, or condense Federal programs based on each program’s performance, mission, scope, and purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54d83ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the financial impact of Parkinson’s on families living with Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve health outcomes for, and the quality of life of, individuals living with Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent Parkinson’s, ameliorate symptoms, and slow or stop progression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality of care provided to beneficiaries with Parkinson’s who receive coverage through a federally-funded health care program, such as the Medicare program under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.] or the Medicaid program under title XIX of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research the association between environmental triggers and Parkinson’s to help reduce exposure to potential triggers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d83b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and better understand the underlying factors contributing to Parkinson’s;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority actions to improve all federally-funded efforts in Parkinson’s research, prevention, diagnosis, treatment, clinical care, and institutional-, home-, and community-based programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the implementation, including outcomes, of the national plan under subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d83b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation steps to address the recommendations and priority actions under subparagraphs (B), (C), and (D), based in part on the evaluation under subparagraph (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d83b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Council shall terminate at the end of calendar year 2035.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d83b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal department and agency that has information relating to Parkinson’s shall share such information with the Secretary consistent with the statutory obligations of such department or agency regarding disclosure of information, as necessary to enable the Secretary to complete a report under subsection (e)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d83b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280n/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The section shall cease to be effective at the end of calendar year 2035.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54d83ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399OO, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/66/s2"},"text":"Pub. L. 118–66, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-02"},"text":"July 2, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1443"},"text":"138 Stat. 1443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54d83bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54d83bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb54d83bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (e)(4)(C)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Titles XVIII and XIX of the Act are classified generally to subchapters XVIII (§ 1395 et seq.) and XIX (§ 1396 et seq.), respectively, of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
