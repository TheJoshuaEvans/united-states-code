{"tag":"section","attrib":{"id":"idbc855a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3515a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3515a"},"text":"§ 3515a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedicated telephone service between employee residences and computer centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of insuring proper management of federally supported computer systems and data bases, funds appropriated by this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts are available for the purchase of dedicated telephone service between the private residences of employees assigned to computer centers funded under this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts, and the computer centers to which such employees are assigned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc855a38-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394/tII/s210"},"text":"Pub. L. 102–394, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1812"},"text":"106 Stat. 1812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc855a39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc855a3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc855a3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/170/tII/s210"},"text":"Pub. L. 102–170, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1127"},"text":"105 Stat. 1127","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/517/tII/s210"},"text":"Pub. L. 101–517, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2209"},"text":"104 Stat. 2209","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/166/tII/s212"},"text":"Pub. L. 101–166, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1177"},"text":"103 Stat. 1177","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/h/tII/s213"},"text":"Pub. L. 100–202, § 101(h) [title II, § 213]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-256"},"text":"101 Stat. 1329–256","children":[],"tail":", 1329–275."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
