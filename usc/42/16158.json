{"tag":"section","attrib":{"id":"idbff52d30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158"},"text":null,"children":[{"tag":"num","attrib":{"value":"16158"},"text":"§ 16158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Codes and standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff52d31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Task Force, shall provide grants to, or offer to enter into contracts with, such professional organizations, public service organizations, and government agencies as the Secretary determines appropriate to support timely and extensive development of safety codes and standards relating to fuel cell vehicles, hydrogen energy systems, and stationary, portable, and micro fuel cells.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support educational efforts by organizations and agencies described in subsection (a) to share information, including information relating to best practices, among those organizations and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff52d33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff52d34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff52d39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16158/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2011 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff52d3a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s809"},"text":"Pub. L. 109–58, title VIII, § 809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/851"},"text":"119 Stat. 851","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
