{"tag":"section","attrib":{"id":"idb73fdd56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-employment income credited to calendar years","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb73fdd57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable years prior to 1978","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of determining average monthly wage and quarters of coverage the amount of self-employment income derived during any taxable year which begins before 1978 shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb73fdd58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a taxable year which is a calendar year, be credited equally to each quarter of such calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb73fdd59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other taxable year, be credited equally to the calendar quarter in which such taxable year ends and to each of the next three or fewer preceding quarters any part of which is in such taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb73fdd5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxable years after 1977","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), for the purposes of determining average indexed monthly earnings, average monthly wage, and quarters of coverage the amount of self-employment income derived during any taxable year which begins after 1977 shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb73fdd5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a taxable year which is a calendar year or which begins with or during a calendar year and ends with or during such year, be credited to such calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb73fdd5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other taxable year, be allocated proportionately to the two calendar years, portions of which are included within such taxable year, on the basis of the number of months in each such calendar year which are included completely within the taxable year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of clause (2), the calendar month in which a taxable year ends shall be treated as included completely within that taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb73fdd5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportional allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining average indexed monthly earnings, average monthly wage, and quarters of coverage in the case of any individual who elects the option described in clause (ii) or (iv) in the matter following ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s411/a/16"},"text":"section 411(a)(16) of this title","children":[],"tail":" for any taxable year that does not begin with or during a particular calendar year and end with or during such year, the self-employment income of such individual deemed to be derived during such taxable year shall be allocated to the two calendar years, portions of which are included within such taxable year, in the same proportion to the total of such deemed self-employment income as the sum of the amounts applicable under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s413/d"},"text":"section 413(d) of this title","children":[],"tail":" for the calendar quarters ending with or within each such calendar year bears to the lower limit for such taxable year specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s411/k/1"},"text":"section 411(k)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb73fdd5e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title II, § 212, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-28/ch809"},"text":"Aug. 28, 1950, ch. 809","children":[],"tail":", title I, § 104(a), "},{"tag":"ref","attrib":{"href":"/us/stat/64/492"},"text":"64 Stat. 492","children":[],"tail":", 504; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/216/tIII/s351/b"},"text":"Pub. L. 95–216, title III, § 351(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-20"},"text":"Dec. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1549"},"text":"91 Stat. 1549","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXV/s15352/b/3"},"text":"Pub. L. 110–234, title XV, § 15352(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1526"},"text":"122 Stat. 1526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XV, § 15352(b)(3), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2288.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb73fdd5f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb73fdd60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb73fdd61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb73fdd62-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s15352/b/3/A"},"text":"Pub. L. 110–246, § 15352(b)(3)(A)","children":[],"tail":", substituted “Except as provided in subsection (c), for the purposes” for “For the purposes” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s15352/b/3/B"},"text":"Pub. L. 110–246, § 15352(b)(3)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/216"},"text":"Pub. L. 95–216","children":[],"tail":" designated existing provisions as subsec. (a), substituted provisions relating to crediting of self-employment income to calendar years for provisions relating to crediting of self-employment income to calendar quarters, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb73fdd63-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb73fdd64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008