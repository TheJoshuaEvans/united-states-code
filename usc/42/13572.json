{"tag":"section","attrib":{"id":"idbfc80247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572"},"text":null,"children":[{"tag":"num","attrib":{"value":"13572"},"text":"§ 13572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc80248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program of financial assistance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate the production and generation of coal-based power, through the deployment of clean coal electric generating equipment and processes that, compared to equipment or processes that are in operation on a full scale—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc8024a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfc8024b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfc8024c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental performance consistent with relevant Federal and State clean air requirements, including those promulgated under the Clean Air Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc8024d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not yet cost competitive; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8024e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitate the utilization of existing coal-based electricity generation plants through projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc8024f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy advanced air pollution control equipment and processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc80250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed to voluntarily enhance environmental performance above current applicable obligations under the Clean Air Act and State implementation efforts pursuant to such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc80251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As determined by the Secretary for a particular project, financial assistance under this subchapter shall be in the form of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-sharing of an appropriate percentage of the total project cost, not to exceed 50 percent as calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance, including grants, cooperative agreements, or loans as authorized under this Act or other statutory authority of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc80254-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXXI/s3102"},"text":"Pub. L. 102–486, title XXXI, § 3102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s421/a"},"text":"Pub. L. 109–58, title IV, § 421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/757"},"text":"119 Stat. 757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc80255-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc80256-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc80257-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (a)(1)(A)(ii), (2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2776"},"text":"106 Stat. 2776","children":[],"tail":", known as the Energy Policy Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13201"},"text":"section 13201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
