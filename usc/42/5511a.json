{"tag":"section","attrib":{"id":"idbd57293d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5511a"},"text":"§ 5511a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solar Assistance Financing Entity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd57293e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall establish within the Department of Housing and Urban Development the Solar Assistance Financing Entity (in this section referred to as the “Entity”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd57293f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Entity shall be to assist in financing solar and renewable energy capital investments and projects for eligible buildings under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible buildings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Entity may provide assistance under this section only for the following buildings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd572941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single family housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any building consisting of 1 to 4 dwelling units that has a system for heating or cooling, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd572942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multifamily housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any building consisting of more than 4 dwelling units that has a system for heating or cooling, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd572943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any building used primarily to carry on a business (including any nonprofit business) that is not used primarily for the manufacture or production of raw materials, products, or agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd572944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools, hospitals, and agricultural buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any school, any hospital, and any building used exclusively in connection with the harvesting, storage, or drying of agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd572945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any other building of a type that the Entity considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this section by the Entity may be provided only for programs for financing solar and renewable energy capital investments and projects, which may include programs for making loans, making grants, reducing the principal obligations of loans, prepayment of interest on loans, purchase and sale of loans and advances of credit, providing loan guarantees, providing loan downpayment assistance, and providing rebates and other incentives for the purchase and installation of solar and renewable energy measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to leverage other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Entity may encourage or require programs receiving assistance under this section to supplement the assistance received under this section with amounts from other public and private sources, and, in making assistance under this section available, may give preference to programs that leverage amounts from such other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Entity shall provide assistance under this section through State agencies responsible for developing State energy conservation plans pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6322"},"text":"section 6322 of this title","children":[],"tail":", or any other entity or agency authorized to specifically carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd572949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the expiration of the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", the Secretary of Housing and Urban Development, in consultation with the Secretary of Energy, shall issue any regulations necessary to carry out this section, which shall ensure maximum flexibility in utilizing amounts made available under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd57294a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5511a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for fiscal year 1993 and $10,420,000 for fiscal year 1994. Such sums are to be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd57294b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s912"},"text":"Pub. L. 102–550, title IX, § 912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3875"},"text":"106 Stat. 3875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd57294c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd57294d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd57294e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Community Development Act of 1992, and not as part of the Solar Heating and Cooling Demonstration Act of 1974 which comprises this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s912"},"text":"section 912 of Pub. L. 102–550","children":[],"tail":". Subsec. (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/s912"},"text":"section 912 of Pub. L. 102–550","children":[],"tail":" repealed sections 1723g and 1723h and chapter 37 (§ 3601 et seq.) of Title 12, Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
