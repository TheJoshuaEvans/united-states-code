{"tag":"section","attrib":{"id":"idbfab52be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904"},"text":null,"children":[{"tag":"num","attrib":{"value":"12904"},"text":"§ 12904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Grants allocated under this chapter shall be available only for approved activities to carry out strategies designed to prevent homelessness among eligible persons. Approved activities shall include activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab52bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable public and nonprofit organizations or agencies to provide housing information to such persons and coordinate efforts to expand housing assistance resources for such persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12906"},"text":"section 12906 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the development and operation of shelter and services for such persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12907"},"text":"section 12907 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide rental assistance to such persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12908"},"text":"section 12908 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate (through project-based rental assistance or other means) the moderate rehabilitation of single room occupancy dwellings (SROs) that would be made available only to such persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12909"},"text":"section 12909 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the development of community residences for eligible persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12910"},"text":"section 12910 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12904/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other activities that the Secretary develops in cooperation with eligible States and localities, except that activities developed under this paragraph may be assisted only with amounts provided under section 12903(c)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn004139"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004139"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall establish standards and guidelines for approved activities. The Secretary shall permit grantees to refine and adapt such standards and guidelines for individual projects, where such refinements and adaptations are made necessary by local circumstances.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab52c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s855"},"text":"Pub. L. 101–625, title VIII, § 855","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4378"},"text":"104 Stat. 4378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/e"},"text":"Pub. L. 102–550, title VI, § 606(e)","children":[],"tail":", (h)(2), (j)(3), "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3808"},"text":"106 Stat. 3808","children":[],"tail":", 3810.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab52c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab52c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfab52c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12903/c/3"},"text":"Section 12903(c)(3) of this title","children":[],"tail":", referred to in par. (6), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12903/c/5"},"text":"section 12903(c)(5) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/201/tVII/s701/a/1"},"text":"Pub. L. 114–201, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/812"},"text":"130 Stat. 812","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab52c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/j/3/A"},"text":"Pub. L. 102–550, § 606(j)(3)(A)","children":[],"tail":", in introductory provisions, substituted “eligible persons” for “such persons with acquired immunodeficiency syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/h/2"},"text":"Pub. L. 102–550, § 606(h)(2)","children":[],"tail":", struck out “short-term” after “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/j/3/B"},"text":"Pub. L. 102–550, § 606(j)(3)(B)","children":[],"tail":", struck out “with acquired immunodeficiency syndrome” after “persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/s606/e"},"text":"Pub. L. 102–550, § 606(e)","children":[],"tail":", inserted before period at end “, except that activities developed under this paragraph may be assisted only with amounts provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12903/c/3"},"text":"section 12903(c)(3) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
