{"tag":"section","attrib":{"id":"idb495cb9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q"},"text":null,"children":[{"tag":"num","attrib":{"value":"242q"},"text":"§ 242q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force on Aging Research; establishment and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb495cb9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall establish a Task Force on Aging Research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cb9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to aging research (as defined in section 242q–4 ","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title), the Task Force each fiscal year shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb495cba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary specifying the particular projects of research, or the particular categories of research, that should be conducted or supported by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the projects specified under paragraph (1), make recommendations to the Secretary of the projects that should be given priority in the provision of funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary of the amount of funds that should be appropriated for such research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force may make available to health professionals, and to other members of the public, information regarding the research described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb495cba4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIII/s301"},"text":"Pub. L. 101–557, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2768"},"text":"104 Stat. 2768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cba5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cba6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb495cba7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242q–4"},"text":"Section 242q–4 of this title","children":[],"tail":", referred to in subsec. (b), was in the original “section 305”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/557/s305"},"text":"section 305 of Pub. L. 101–557","children":[],"tail":". Section 305 was renumbered section 304 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/3/B"},"text":"Pub. L. 109–482, title I, § 104(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3694"},"text":"120 Stat. 3694","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cba8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Home Health Care and Alzheimer’s Disease Amendments of 1990, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
