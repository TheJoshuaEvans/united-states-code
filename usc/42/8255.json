"},"text":"section 8251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8855ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Each agency, in support of the President’s annual budget request to the Congress, shall specifically set forth and identify funds requested for energy conservation measures.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/615"},"text":"Pub. L. 100–615","children":[],"tail":" amended section generally, substituting provision relating to budget treatment for energy conservation measures for provisions relating to establishment and use of life cycle cost methods, use of life cycle costs, and use in non-Federal structures."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted “average” for “marginal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294"},"text":"Pub. L. 96–294","children":[],"tail":", which directed amendment of par. (1) by inserting provisions setting forth criteria for establishing life-cycle costs for Federal buildings before the period at end, was executed to par. (2) as the probable intent of Congress because par. (1) does not contain a period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
