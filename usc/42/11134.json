{"tag":"section","attrib":{"id":"idbf38e251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134"},"text":null,"children":[{"tag":"num","attrib":{"value":"11134"},"text":"§ 11134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing and form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required to be reported under sections 11131, 11132(a), and 11133 of this title shall be reported regularly (but not less often than monthly) and in such form and manner as the Secretary prescribes. Such information shall first be required to be reported on a date (not later than one year after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":") specified by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To whom reported","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required to be reported under sections 11131, 11132(a), and 11133(b) of this title shall be reported to the Secretary, or, in the Secretary’s discretion, to an appropriate private or public agency which has made suitable arrangements with the Secretary with respect to receipt, storage, protection of confidentiality, and dissemination of the information under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to State licensing boards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Malpractice payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information required to be reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11131"},"text":"section 11131 of this title","children":[],"tail":" shall also be reported to the appropriate State licensing board (or boards) in the State in which the medical malpractice claim arose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11134/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting to other licensing boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information required to be reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11133/b"},"text":"section 11133(b) of this title","children":[],"tail":" shall also be reported to the appropriate State licensing board in the State in which the health care entity is located if it is not otherwise reported to such board under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e257-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s424"},"text":"Pub. L. 99–660, title IV, § 424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3790"},"text":"100 Stat. 3790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
