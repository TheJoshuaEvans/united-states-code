{"tag":"section","attrib":{"id":"idbda12a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6372a"},"text":"§ 6372a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda12a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, by rule, not later than sixty days after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda12a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe guidelines for the conduct of the preliminary energy audits for buildings owned by units of local government and public care institutions, including a description of the type, number and distribution of preliminary energy audits of such buildings that will provide a reasonably accurate evaluation of the energy conservation needs of all such buildings in each State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe guidelines for the conduct of energy audits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of technical assistance programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, by rule, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", prescribe guidelines for State plans for the implementation of technical assistance programs for buildings owned by units of local government and public care institutions. The guidelines shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbda12a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the factors to be considered in determining which technical assistance programs will be given priority in making grants pursuant to this part, including such factors as cost, energy consumption, energy savings, and energy conservation goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the suggested criteria to be used in establishing a State program to identify persons qualified to undertake technical assistance work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbda12a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of energy conservation measures deemed appropriate for each region of the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Guidelines prescribed under this part may be revised from time to time after notice and opportunity for comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda12a45-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400B"},"text":"Pub. L. 94–163, title III, § 400B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIII/s311/a"},"text":"Pub. L. 95–619, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3249"},"text":"92 Stat. 3249","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
