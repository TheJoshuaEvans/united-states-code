{"tag":"section","attrib":{"id":"idbf79464e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12581a"},"text":"§ 12581a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational awards only program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf79464f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated for a fiscal year to provide financial assistance under this division and consistent with the restriction in subsection (b), the Corporation may, through fixed-amount grants (in accordance with section 12581(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title), provide operational support to programs that receive approved national service positions but do not receive funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/a"},"text":"section 12571(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf794650-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on Corporation grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may provide the operational support under this section for a program in an amount that is not more than $800 per individual enrolled in an approved national service position, or not more than $1,000 per such individual if at least 50 percent of the persons enrolled in the program are disadvantaged youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf794651-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicable provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions shall not apply to programs funded under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf794652-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitation on administrative costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/d"},"text":"section 12571(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf794653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The matching funds requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571/e"},"text":"section 12571(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf794654-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12581a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The living allowance and other benefits under sections 12583(e) and 12594 of this title (other than individualized support services for participants with disabilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594/f"},"text":"section 12594(f) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf794655-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s129A"},"text":"Pub. L. 101–610, title I, § 129A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1307"},"text":"Pub. L. 111–13, title I, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1505"},"text":"123 Stat. 1505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf794656-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf794657-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf794658-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
