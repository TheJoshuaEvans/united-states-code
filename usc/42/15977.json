{"tag":"section","attrib":{"id":"idbfee288d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977"},"text":null,"children":[{"tag":"num","attrib":{"value":"15977"},"text":"§ 15977.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy transportation fuels from Illinois basin coal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee288e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to evaluate the commercial and technical viability of advanced technologies for the production of Fischer-Tropsch transportation fuels, and other transportation fuels, manufactured from Illinois basin coal, including the capital modification of existing facilities and the construction of testing facilities under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee288f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of evaluating the commercial and technical viability of different processes for producing Fischer-Tropsch transportation fuels, and other transportation fuels, from Illinois basin coal, the Secretary shall support the use and capital modification of existing facilities and the construction of new facilities at—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Southern Illinois University Coal Research Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University of Kentucky Center for Applied Energy Research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy Center at Purdue University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasification products test center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the activities described in subsections (a) and (b), the Secretary shall construct a test center to evaluate and confirm liquid and gas products from syngas catalysis in order that the system has an output of at least 500 gallons of Fischer-Tropsch transportation fuel per day in a 24-hour operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milestones","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee2895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of processes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall select processes for evaluating the commercial and technical viability of different processes of producing Fischer-Tropsch transportation fuels, and other transportation fuels, from Illinois basin coal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall offer to enter into agreements—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee2897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the activities described in this section, at the facilities described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee2898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the capital modifications or construction of the facilities at the locations described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee2899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall begin, at the facilities described in subsection (b), evaluation of the technical and commercial viability of different processes of producing Fischer-Tropsch transportation fuels, and other transportation fuels, from Illinois basin coal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee289a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of facilities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfee289b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall construct the facilities described in subsection (b) at the lowest cost practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfee289c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants or enter into agreements or contracts with the institutions of higher education described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee289d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost of making grants under this section shall be shared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee289e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15977/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $85,000,000 for the period of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee289f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s417"},"text":"Pub. L. 109–58, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/756"},"text":"119 Stat. 756","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
