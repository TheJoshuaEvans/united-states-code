{"tag":"section","attrib":{"id":"idc0169743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501"},"text":null,"children":[{"tag":"num","attrib":{"value":"16501"},"text":"§ 16501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial byproducts from municipal solid waste and cellulosic biomass loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0169744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of municipal solid waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “municipal solid waste” has the meaning given the term “solid waste” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide guarantees of loans by private institutions for the construction of facilities for the processing and conversion of municipal solid waste and cellulosic biomass into fuel ethanol and other commercial byproducts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a loan guarantee under subsection (b) to an applicant if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a loan guarantee, credit is not available to the applicant under reasonable terms or conditions sufficient to finance the construction of a facility described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective earning power of the applicant and the character and value of the security pledged provide a reasonable assurance of repayment of the loan to be guaranteed in accordance with the terms of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan bears interest at a rate determined by the Secretary to be reasonable, taking into account the current average yield on outstanding obligations of the United States with remaining periods of maturity comparable to the maturity of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016974a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting recipients of loan guarantees from among applicants, the Secretary shall give preference to proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016974b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet all applicable Federal and State permitting requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016974c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to be successful; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016974d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are located in local markets that have the greatest need for the facility because of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc016974e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limited availability of land for waste disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc016974f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of sufficient quantities of cellulosic biomass; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0169750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high level of demand for fuel ethanol or other commercial byproducts of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan guaranteed under subsection (b) shall have a maturity of not more than 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan agreement for a loan guaranteed under subsection (b) shall provide that no provision of the loan agreement may be amended or waived without the consent of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurance of repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that an applicant for a loan guarantee under subsection (b) provide an assurance of repayment in the form of a performance bond, insurance, collateral, or other means acceptable to the Secretary in an amount equal to not less than 20 percent of the amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of a loan guarantee under subsection (b) shall pay the Secretary an amount determined by the Secretary to be sufficient to cover the administrative costs of the Secretary relating to the loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all guarantees made under this section. Any such guarantee made by the Secretary shall be conclusive evidence of the eligibility of the loan for the guarantee with respect to principal and interest. The validity of the guarantee shall be incontestable in the hands of a holder of the guaranteed loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until each guaranteed loan under this section has been repaid in full, the Secretary shall annually submit to Congress a report on the activities of the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16501/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary to issue a loan guarantee under subsection (b) terminates on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0169759-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1510"},"text":"Pub. L. 109–58, title XV, § 1510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1085"},"text":"119 Stat. 1085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
