{"tag":"section","attrib":{"id":"idbc7702e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198"},"text":null,"children":[{"tag":"num","attrib":{"value":"3198"},"text":"§ 3198.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Tribal Economic Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7702e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Economic Development Administration an Office of Tribal Economic Development (referred to in this section as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7702e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Office shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7702e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate all Tribal economic development activities carried out by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help Tribal communities access economic development assistance programs, including the assistance provided under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate Tribal economic development strategies and efforts with other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7702ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be a participant in any negotiated rulemakings or consultations relating to, or having an impact on, projects, programs, or funding that benefit Tribal communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7972eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal economic development strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7972ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Office shall initiate a Tribal consultation process to develop, and not less frequently than every 3 years thereafter, update, a strategic plan for Tribal economic development for the Economic Development Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7972ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", and not less frequently than every 3 years thereafter, the Office shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate the strategic plan for Tribal economic development developed under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7972ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a publicly facing website to help provide a comprehensive, single source of information for Indian tribes, Tribal leaders, Tribal businesses, and citizens in Tribal communities to better understand and access programs that support economic development in Tribal communities, including the economic development programs administered by Federal agencies or departments other than the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7972ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3198/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dedicated staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the Office has sufficient staff to carry out all outreach activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7972f0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s508"},"text":"Pub. L. 89–136, title V, § 508","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2227"},"text":"Pub. L. 118–272, div. B, title II, § 2227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3192"},"text":"138 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
