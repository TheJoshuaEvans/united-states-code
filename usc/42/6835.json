{"tag":"section","attrib":{"id":"idbdbdb2f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6835"},"text":null,"children":[{"tag":"num","attrib":{"value":"6835"},"text":"§ 6835.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdbdb2f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6835/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdbdb2f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6835/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each Federal agency shall adopt procedures necessary to assure that new Federal buildings meet or exceed the Federal building energy standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6834"},"text":"section 6834 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdbdb2f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6835/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal building energy standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6834"},"text":"section 6834 of this title","children":[],"tail":" shall apply to new buildings under the jurisdiction of the Architect of the Capitol. The Architect shall adopt procedures necessary to assure that such buildings meet or exceed such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdbdb2f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6835/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of new buildings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of a Federal agency may expend Federal funds for the construction of a new Federal building only if the building meets or exceeds the appropriate Federal building energy standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6834"},"text":"section 6834 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdbdb2f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s306"},"text":"Pub. L. 94–385, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s101/a/2"},"text":"Pub. L. 102–486, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2785"},"text":"106 Stat. 2785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdbdb2f6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdbdb2f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbdbdb2f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6835, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIII/s306"},"text":"Pub. L. 94–385, title III, § 306","children":[],"tail":", "},{"tag":"