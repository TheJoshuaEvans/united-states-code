{"tag":"section","attrib":{"id":"idbf3d9c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271"},"text":null,"children":[{"tag":"num","attrib":{"value":"11271"},"text":"§ 11271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research program and plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf3d9c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Centers for Medicare & Medicaid Services shall conduct, or make grants for the conduct of, research relevant to appropriate services for individuals with Alzheimer’s disease and related dementias and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9c62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of plan; contents; revision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf3d9c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 6 months after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":", the Administrator of the Centers for Medicare & Medicaid Services shall prepare and transmit to the Chairman of the Council a plan for research to be conducted under (a)."},{"tag":"ref","attrib":{"idref":"fn003992"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003992"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “subsection”."}],"tail":" The plan shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf3d9c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a determination of the types of services required by individuals with Alzheimer’s disease and related dementias and their families to allow such individuals to remain living at home or in a community-based setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a determination of the costs of providing needed services to individuals with Alzheimer’s disease and related dementias and their families, including the expenditures for institutional, home, and community-based services and the source of payment for such expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an assessment of the adequacy of benefits provided through the Medicare and Medicaid programs and through private health insurance for needed services for individuals with Alzheimer’s disease and related dementias and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf3d9c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a determination of the costs to the Medicare and Medicaid programs and to private health insurers (if available) of providing covered benefits to individuals with Alzheimer’s disease and related dementias and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf3d9c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within one year after transmitting the plan required under paragraph (1), and annually thereafter, the Administrator of the Centers for Medicare & Medicaid Services shall prepare and transmit to the Chairman of the Council such revisions of such plan as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf3d9c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11271/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation for preparation and revision of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing and revising the plan required by subsection (b), the Administrator of the Centers for Medicare & Medicaid Services shall consult with the Chairman of the Council and the heads of agencies within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf3d9c6a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s937"},"text":"Pub. L. 99–660, title IX, § 937","children":[],"tail":", formerly § 949A, "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3812"},"text":"100 Stat. 3812","children":[],"tail":"; renumbered § 937, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/c/2/B"},"text":"Pub. L. 100–607, title I, § 142(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/e/5/B"},"text":"Pub. L. 108–173, title IX, § 900(e)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2373"},"text":"117 Stat. 2373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf3d9c6b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf3d9c6c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf3d9c6d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s900/e/5/B/i"},"text":"Pub. L. 108–173, § 900(e)(5)(B)(i)","children":[],"tail":", substituted “Centers for Medicare & Medicaid Services” for “National Health Care Financing Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s900/e/5/B/ii"},"text":"Pub. L. 108–173, § 900(e)(5)(B)(ii)","children":[],"tail":", substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(2), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s900/e/5/B/iii"},"text":"Pub. L. 108–173, § 900(e)(5)(B)(iii)","children":[],"tail":", (iv), substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
