{"tag":"section","attrib":{"id":"idbe9dda44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626"},"text":null,"children":[{"tag":"num","attrib":{"value":"8626"},"text":"§ 8626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States; fiscal year requirements respecting availability, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe9dda45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe9dda46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From its allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623"},"text":"section 8623 of this title","children":[],"tail":", the Secretary shall make payments to each State in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503/a"},"text":"section 6503(a) of title 31","children":[],"tail":", for use under this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9dda47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State shall notify the Secretary, not later than 2 months prior to the close of a fiscal year, of the amount (if any) of its allotment for such year that will not be obligated in such year, and, if such State elects to submit a request described in subsection (b)(2), such State shall submit such request at the same time. The Secretary shall make no payment under paragraph (1) to a State for a fiscal year unless the State has complied with this paragraph with respect to the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe9dda48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe9dda49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe9dda4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that, as of September 1 of any fiscal year, an amount allotted to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623"},"text":"section 8623 of this title","children":[],"tail":" for any fiscal year will not be used by such State during such fiscal year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe9dda4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe9dda4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the chief executive officer of such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe9dda4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishes a timely notice in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that, after the 30-day period beginning on the date of the notice to such chief executive officer, such amount may be reallotted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe9dda4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State does not request, under paragraph (2), that such amount be held available for such State for the following fiscal year;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such amount shall be treated by the Secretary for purposes of this subchapter as an amount appropriated for the following fiscal year to be allotted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623"},"text":"section 8623 of this title","children":[],"tail":" for such following fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe9dda4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe9dda50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State may request that an amount allotted to such State for a fiscal year be held available for such State for the following fiscal year. Such request shall include a statement of the reasons that the amount allotted to such State for a fiscal year will not be used by such State during such fiscal year and a description of the types of assistance to be provided with the amount held available for the following fiscal year. Any amount so held available for the following fiscal year shall not be taken into account in computing the allotment of or the amount payable to such State for such fiscal year under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No amount may be held available under this paragraph for a State from a prior fiscal year to the extent such amount exceeds 10 percent of the amount payable to such State for such prior fiscal year. For purposes of the preceding sentence, the amount payable to a State for a fiscal year shall be determined without regard to any amount held available under this paragraph for such State for such fiscal year from the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall reallot amounts made available under this paragraph for the fiscal year following the fiscal year of the original allotment in accordance with paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the 30-day period described in paragraph (1)(B), comments may be submitted to the Secretary. After considering such comments, the Secretary shall notify the chief executive officer of the State of any decision to reallot funds, and shall publish such decision in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea04a54-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2607"},"text":"Pub. L. 97–35, title XXVI, § 2607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/900"},"text":"95 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tVI/s606"},"text":"Pub. L. 98–558, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2892"},"text":"98 Stat. 2892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tVII/s706"},"text":"Pub. L. 101–501, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1260"},"text":"104 Stat. 1260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIII/s310"},"text":"Pub. L. 103–252, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/661"},"text":"108 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tIII/s307"},"text":"Pub. L. 105–285, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2758"},"text":"112 Stat. 2758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea04a55-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea04a56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbea04a57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503/a"},"text":"section 6503(a) of title 31","children":[],"tail":"” substituted for “section 203 of the Intergovernmental Cooperation Act of 1968 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4213"},"text":"42 U.S.C. 4213","children":[],"tail":"]” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea04a58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":" struck out “and not transferred pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623/f"},"text":"section 8623(f) of this title","children":[],"tail":"” after “such prior fiscal year” in first sentence and “but not transferred by the State” after “the amount payable to a State” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252"},"text":"Pub. L. 103–252","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" substituted “10 percent” for “15 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558/s606/a"},"text":"Pub. L. 98–558, § 606(a)","children":[],"tail":", inserted “Such request shall include a statement of the reasons that the amount allotted to such State for a fiscal year will not be used by such State during such fiscal year and a description of the types of assistance to be provided with the amount held available for the following fiscal year.” and “or the amount payable to” after “computing the allotment of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558/s606/b"},"text":"Pub. L. 98–558, § 606(b)","children":[],"tail":", substituted “15 percent” for “25 percent”, “payable to such State for such prior fiscal year and not transferred pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8623/f"},"text":"section 8623(f) of this title","children":[],"tail":"” for “allotted to such State for such prior fiscal year”, and “payable to a State but not transferred by the State” for “allotted to a State” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558/s606/c"},"text":"Pub. L. 98–558, § 606(c)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea04a59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea04a5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252"},"text":"Pub. L. 103–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s314"},"text":"section 314 of Pub. L. 103–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea04a5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbea04a5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/558"},"text":"Pub. L. 98–558","children":[],"tail":" applicable to amounts held available for fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"Sept. 30, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/s609/c"},"text":"section 609(c) of Pub. L. 98–558","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
