{"tag":"section","attrib":{"id":"idbe0c7001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385b"},"text":"§ 7385b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment in full settlement of claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in part E, the acceptance by an individual of payment of compensation under part B with respect to a covered employee shall be in full satisfaction of all claims of or on behalf of that individual against the United States, against a Department of Energy contractor or subcontractor, beryllium vendor, or atomic weapons employer, or against any person with respect to that person’s performance of a contract with the United States, that arise out of an exposure referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385"},"text":"section 7385 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0c7002-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3643"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3643]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–509; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/c"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c7003-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c7004-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c7005-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “Except as provided in part E, the acceptance” for “The acceptance”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
