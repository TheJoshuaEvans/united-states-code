{"tag":"section","attrib":{"id":"idc056fc30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18373"},"text":null,"children":[{"tag":"num","attrib":{"value":"18373"},"text":"§ 18373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decadal Survey missions implementation for Earth observation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall undertake to implement, as appropriate, missions identified in the National Research Council’s Earth Science Decadal Survey within the scope of the funds authorized for the Earth Science Mission Directorate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc056fc31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tVII/s704"},"text":"Pub. L. 111–267, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2831"},"text":"124 Stat. 2831","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
