{"tag":"section","attrib":{"id":"idbf5f0784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111"},"text":null,"children":[{"tag":"num","attrib":{"value":"12111"},"text":"§ 12111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5f0785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Equal Employment Opportunity Commission established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–4"},"text":"section 2000e–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0786-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered entity” means an employer, employment agency, labor organization, or joint labor-management committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct threat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct threat” means a significant risk to the health or safety of others that cannot be eliminated by reasonable accommodation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee” means an individual employed by an employer. With respect to employment in a foreign country, such term includes an individual who is a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f078a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employer” means a person engaged in an industry affecting commerce who has 15 or more employees for each working day in each of 20 or more calendar weeks in the current or preceding calendar year, and any agent of such person, except that, for two years following the effective date of this subchapter, an employer means a person engaged in an industry affecting commerce who has 25 or more employees for each working day in each of 20 or more calendar weeks in the current or preceding year, and any agent of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f078b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employer” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5f078c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States, a corporation wholly owned by the government of the United States, or an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f078d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bona fide private membership club (other than a labor organization) that is exempt from taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f078e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegal use of drugs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f078f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “illegal use of drugs” means the use of drugs, the possession or distribution of which is unlawful under the Controlled Substances Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.]. Such term does not include the use of a drug taken under supervision by a licensed health care professional, or other uses authorized by the Controlled Substances Act or other provisions of Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drugs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “drug” means a controlled substance, as defined in schedules I through V of section 202 of the Controlled Substances Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"21 U.S.C. 812","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “person”, “labor organization”, “employment agency”, “commerce”, and “industry affecting commerce”, shall have the same meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"section 2000e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified individual” means an individual who, with or without reasonable accommodation, can perform the essential functions of the employment position that such individual holds or desires. For the purposes of this subchapter, consideration shall be given to the employer’s judgment as to what functions of a job are essential, and if an employer has prepared a written description before advertising or interviewing applicants for the job, this description shall be considered evidence of the essential functions of the job.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable accommodation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reasonable accommodation” may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f0794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making existing facilities used by employees readily accessible to and usable by individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job restructuring, part-time or modified work schedules, reassignment to a vacant position, acquisition or modification of equipment or devices, appropriate adjustment or modifications of examinations, training materials or policies, the provision of qualified readers or interpreters, and other similar accommodations for individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5f0796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undue hardship","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5f0797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “undue hardship” means an action requiring significant difficulty or expense, when considered in light of the factors set forth in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5f0798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether an accommodation would impose an undue hardship on a covered entity, factors to be considered include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf5f0799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and cost of the accommodation needed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f079a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall financial resources of the facility or facilities involved in the provision of the reasonable accommodation; the number of persons employed at such facility; the effect on expenses and resources, or the impact otherwise of such accommodation upon the operation of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f079b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall financial resources of the covered entity; the overall size of the business of a covered entity with respect to the number of its employees; the number, type, and location of its facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf5f079c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12111/10/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of operation or operations of the covered entity, including the composition, structure, and functions of the workforce of such entity; the geographic separateness, administrative, or fiscal relationship of the facility or facilities in question to the covered entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5f079d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tI/s101"},"text":"Pub. L. 101–336, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/330"},"text":"104 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s109/a"},"text":"Pub. L. 102–166, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1077"},"text":"105 Stat. 1077","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s5/c/1"},"text":"Pub. L. 110–325, § 5(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3557"},"text":"122 Stat. 3557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5f079e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5f079f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5f07a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subchapter, referred to in par. (5)(A), is 24 months after ","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/336/s108"},"text":"section 108 of Pub. L. 101–336","children":[],"tail":", set out as an Effective Date note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in par. (6)(A), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (10)(B)(i), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"idbf5f07a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the constitutionality of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/s101"},"text":"section 101 of Pub. L. 101–336","children":[],"tail":", see note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12112"},"text":"section 12112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5f07a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/325"},"text":"Pub. L. 110–325","children":[],"tail":" struck out “with a disability” after “individual” in heading and the first two places appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" inserted at end “With respect to employment in a foreign country, such term includes an individual who is a citizen of the United States.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5f07a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5f07a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/325"},"text":"Pub. L. 110–325","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-01-01"},"text":"Jan. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s8"},"text":"section 8 of Pub. L. 110–325","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705"},"text":"section 705 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5f07a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" inapplicable to conduct occurring before "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s109/c"},"text":"section 109(c) of Pub. L. 102–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"section 2000e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf5f07a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tI/s108"},"text":"Pub. L. 101–336, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/337"},"text":"104 Stat. 337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/336/tI/s108"},"text":"“This title [enacting this subchapter] shall become effective 24 months after the date of enactment [","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
