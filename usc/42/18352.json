{"tag":"section","attrib":{"id":"idc056fbc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352"},"text":null,"children":[{"tag":"num","attrib":{"value":"18352"},"text":"§ 18352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum utilization of the International Space Station","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc056fbc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With assembly of the ISS complete, NASA shall take steps to maximize the productivity and use of the ISS with respect to scientific and technological research and development, advancement of space exploration, and international collaboration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fbc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NASA actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), NASA shall, at a minimum, undertake the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fbca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative use of U.S. segment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States segment of the ISS, which has been designated as a National Laboratory, shall be developed, managed and utilized in a manner that enables the effective and innovative use of such facility, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18354"},"text":"section 18354 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ISS shall continue to be utilized as a key component of international efforts to build missions and capabilities that further the development of a human presence beyond near-Earth space and advance United States security and economic goals. The Administrator shall actively seek ways to encourage and enable the use of ISS capabilities to support these efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fbcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The operations, management, and utilization of the ISS shall be conducted in a manner that provides opportunities for collaboration with other research programs and objectives of the United States Government in cooperation with commercial suppliers, users, and developers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fbcd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tV/s502"},"text":"Pub. L. 111–267, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2823"},"text":"124 Stat. 2823","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
