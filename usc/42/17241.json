{"tag":"section","attrib":{"id":"idc030d741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241"},"text":null,"children":[{"tag":"num","attrib":{"value":"17241"},"text":"§ 17241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lightweight materials research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc030d742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary of Energy shall establish a program to determine ways in which the weight of motor vehicles could be reduced to improve fuel efficiency without compromising passenger safety by conducting research, development, and demonstration relating to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of new materials (including cast metal composite materials formed by autocombustion synthesis) and material processes that yield a higher strength-to-weight ratio or other properties that reduce vehicle weight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reducing the cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lightweight materials (including high-strength steel alloys, aluminum, magnesium, metal composites, and carbon fiber reinforced polymer composites) with the properties required for construction of lighter-weight vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials processing, automated manufacturing, joining, and recycling lightweight materials for high-volume applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $80,000,000 for the period of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc030d748-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s651"},"text":"Pub. L. 110–140, title VI, § 651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1694"},"text":"121 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc030d749-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc030d74a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc030d74b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
