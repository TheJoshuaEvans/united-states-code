{"tag":"section","attrib":{"id":"idbfee2850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15964"},"text":null,"children":[{"tag":"num","attrib":{"value":"15964"},"text":"§ 15964.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean coal centers of excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee2851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15964/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the clean coal power initiative, the Secretary shall award competitive, merit-based grants to institutions of higher education for the establishment of centers of excellence for energy systems of the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15964/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section to institutions of higher education that show the greatest potential for advancing new clean coal technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2853-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s404"},"text":"Pub. L. 109–58, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/753"},"text":"119 Stat. 753","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
