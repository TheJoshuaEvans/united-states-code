{"tag":"section","attrib":{"id":"idbda12a71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6372h"},"text":"§ 6372h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration; detailed description in annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda12a72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe such rules as may be necessary in order to carry out the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include in his annual report a detailed description of the actions taken under this part in the preceding fiscal year and the actions planned to be taken in the subsequent fiscal year. Such description shall show the allocations made (including the allocations made to each State) and include information on the technical assistance carried out with funds allocated, and an estimate of the energy savings, if any, achieved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda12a74-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400I"},"text":"Pub. L. 94–163, title III, § 400I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIII/s311/a"},"text":"Pub. L. 95–619, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3253"},"text":"92 Stat. 3253","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tII/s203/a"},"text":"Pub. L. 96–470, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2242"},"text":"94 Stat. 2242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s5/a/13"},"text":"Pub. L. 105–388, § 5(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3479"},"text":"112 Stat. 3479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda12a75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda12a76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbda12a77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" struck out comma after “Secretary shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/470"},"text":"Pub. L. 96–470","children":[],"tail":" substituted “include in his annual report a detailed description” for “within one year after "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", and annually thereafter while funds are available under this part, submit to the Congress a detailed report” and “Such description” for “Such report”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
