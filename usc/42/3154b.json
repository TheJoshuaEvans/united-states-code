{"tag":"section","attrib":{"id":"idbc74b8d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3154b"},"text":"§ 3154b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning performance awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b8d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a planning performance award in connection with a grant made, on or after ","children":[{"tag":"date","attrib":{"date":"2004-10-27"},"text":"October 27, 2004","children":[],"tail":", to an eligible recipient for a project under this subchapter located in an economic development district."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a planning performance award to an eligible recipient under subsection (a) in connection with a grant for a project if the Secretary determines before closeout of the project that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b8d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient actively participated in the economic development activities of the economic development district in which the project is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is consistent with the comprehensive economic development strategy of the district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient worked with Federal, State, and local economic development entities throughout the development of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b8d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project was completed in accordance with the comprehensive economic development strategy of the district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a planning performance award made under subsection (a) in connection with a grant may not exceed 5 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a planning performance award under subsection (a) shall use the award to increase the Federal share of the cost of a project under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3144"},"text":"section 3144 of this title","children":[],"tail":", the funds of a planning performance award may be used to pay up to 100 percent of the cost of a project under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b8da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3154b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use any amounts made available for economic development assistance programs to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7701cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s216"},"text":"Pub. L. 89–136, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s211/a"},"text":"Pub. L. 108–373, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1765"},"text":"118 Stat. 1765","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
