{"tag":"section","attrib":{"id":"idbc8ed046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546"},"text":null,"children":[{"tag":"num","attrib":{"value":"3546"},"text":"§ 3546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of domestic products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc8ed047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against fraudulent use of “Made in America” labels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not intentionally affix a label bearing the inscription of “Made in America”, or any inscription with that meaning, to any product sold in or shipped to the United States, if that product is not a domestic product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development and the Secretary of Agriculture shall each submit, before ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", a report to the Congress on procurements of products that are not domestic products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Domestic product” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “domestic product” means a product—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8ed04a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is manufactured or produced in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed04b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3546/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the cost of the articles, materials, or supplies of which are mined, produced, or manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc8ed04c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s920"},"text":"Pub. L. 102–550, title IX, § 920","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3883"},"text":"106 Stat. 3883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc8ed04d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc8ed04e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc8ed04f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Community Development Act of 1992, and not as part of the Department of Housing and Urban Development Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
