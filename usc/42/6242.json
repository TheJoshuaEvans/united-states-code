{"tag":"section","attrib":{"id":"idbd73d91f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6242"},"text":null,"children":[{"tag":"num","attrib":{"value":"6242"},"text":"§ 6242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with import quota system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No quantitative restriction on the importation of any petroleum product into the United States imposed by law shall apply to volumes of any such petroleum product imported into the United States for storage in the Reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd73d920-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s162"},"text":"Pub. L. 94–163, title I, § 162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/889"},"text":"89 Stat. 889","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
