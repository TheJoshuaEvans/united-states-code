{"tag":"section","attrib":{"id":"idbba532c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962–4"},"text":"§ 1962–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of water resources principles and requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbba532ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall issue final agency-specific procedures necessary to implement the principles and requirements and the interagency guidelines."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba532cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of future water resources development projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures required by subsection (a) shall ensure that the Secretary, in the formulation of future water resources development projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba532cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develops such projects in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbba532cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guiding principles established by the principles and requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbba532ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national water resources planning policy established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–3/a"},"text":"section 1962–3(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba532cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully identifies and analyzes national economic development benefits, regional economic development benefits, environmental quality benefits, and other societal effects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba532d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every 5 years, the Secretary shall review and, where appropriate, revise the procedures required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba532d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public review, notice, and comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing, reviewing, and revising the procedures required by this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba532d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice to interested non-Federal stakeholders of the Secretary’s intent to revise the procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba532d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for interested non-Federal stakeholders to engage with, and provide input and recommendations to, the Secretary on the revision of the procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba532d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit and consider public and expert comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbba532d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbba532d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interagency guidelines” means the interagency guidelines contained in the document finalized by the Council on Environmental Quality pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–3"},"text":"section 1962–3 of this title","children":[],"tail":" in December 2014, to implement the principles and requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbba532d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962–4/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles and requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “principles and requirements” means the principles and requirements contained in the document prepared by the Council on Environmental Quality pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–3"},"text":"section 1962–3 of this title","children":[],"tail":", entitled “Principles and Requirements for Federal Investments in Water Resources”, and dated March 2013."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbba532d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s110"},"text":"Pub. L. 116–260, div. AA, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2624"},"text":"134 Stat. 2624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba532d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba532da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba532db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Water Resources Development Act of 2020, and not as a part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbba532dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbba532dd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
