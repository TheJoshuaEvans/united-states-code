{"tag":"section","attrib":{"id":"idc06553a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724"},"text":null,"children":[{"tag":"num","attrib":{"value":"18724"},"text":"§ 18724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced grid security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06553a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “electric utility” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" E-ISAC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “E-ISAC” means the Electricity Information Sharing and Analysis Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity for the energy sector research, development, and demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Homeland Security and in consultation with, as determined appropriate, other Federal agencies, the energy sector, the States, Indian Tribes, Tribal organizations, territories or freely associated states, and other stakeholders, shall develop and carry out a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop advanced cybersecurity applications and technologies for the energy sector—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06553a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify and mitigate vulnerabilities, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06553a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependencies on other critical infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts from weather and fuel supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased dependence on inverter-based technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vulnerabilities from unpatched hardware and software systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06553ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to advance the security of field devices and third-party control systems, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc06553ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems for generation, transmission, distribution, end use, and market functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific electric grid elements including advanced metering, demand response, distribution, generation, and electricity storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forensic analysis of infected systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure communications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc06553b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application of in-line edge security solutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to leverage electric grid architecture as a means to assess risks to the energy sector, including by implementing an all-hazards approach to communications infrastructure, control systems architecture, and power systems architecture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform pilot demonstration projects with the energy sector to gain experience with new technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop workforce development curricula for energy sector-related cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop improved supply chain concepts for secure design of emerging digital components and power electronics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this subsection $250,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy sector operational support for cyberresilience program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may develop and carry out a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enhance and periodically test—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06553bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emergency response capabilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06553bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of the Department with other agencies, the National Laboratories, and private industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand cooperation of the Department with the intelligence community for energy sector-related threat collection and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the tools of the Department and E-ISAC for monitoring the status of the energy sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand industry participation in E-ISAC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to small electric utilities for purposes of assessing and improving cybermaturity levels and addressing gaps identified in the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this subsection $50,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06553c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modeling and assessing energy infrastructure risk","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06553c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Homeland Security, shall develop and carry out an advanced energy security program to secure energy networks, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil exploration, transmission, and delivery networks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security and resiliency objective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The objective of the program developed under paragraph (1) is to increase the functional preservation of electric grid operations or natural gas and oil operations in the face of natural and human-made threats and hazards, including electric magnetic pulse and geomagnetic disturbances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program developed under paragraph (1), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06553c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop capabilities to identify vulnerabilities and critical components that pose major risks to grid security if destroyed or impaired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide modeling at the national level to predict impacts from natural or human-made events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add physical security to the cybersecurity maturity model;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct exercises and assessments to identify and mitigate vulnerabilities to the electric grid, including providing mitigation recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on hardening solutions for critical components of the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on mitigation and recovery solutions for critical components of the electric grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06553cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to States and other entities for standards and risk analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes new regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06553d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18724/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this subsection $50,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06553d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40125"},"text":"Pub. L. 117–58, div. D, title I, § 40125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/954"},"text":"135 Stat. 954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06553d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06553d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06553d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
