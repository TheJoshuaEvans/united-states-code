{"tag":"section","attrib":{"id":"idbb0a2bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437z–1"},"text":"§ 1437z–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalties against section 1437f owners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb0a2bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties set forth in this section shall be in addition to any other available civil remedy or any available criminal penalty, and may be imposed regardless of whether the Secretary imposes other administrative sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not impose penalties under this section for a violation, if a material cause of the violation is the failure of the Secretary, an agent of the Secretary, or a public housing agency to comply with an existing agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of housing assistance payment contracts for which penalty may be imposed","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liable parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may impose a civil money penalty under this section on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any owner of a property receiving project-based assistance under section 8 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any general partner of a partnership owner of that property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agent employed to manage the property that has an identity of interest with the owner or the general partner of a partnership owner of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A penalty may be imposed under this section for a knowing and material breach of a housing assistance payments contract, including the following—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to provide decent, safe, and sanitary housing pursuant to section 8 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowing or willful submission of false, fictitious, or fraudulent statements or requests for housing assistance payments to the Secretary or to any department or agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a penalty imposed for a violation under this subsection, as determined by the Secretary, may not exceed $25,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations establishing standards and procedures governing the imposition of civil money penalties under subsection (b). These standards and procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the Secretary or other department official to make the determination to impose the penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the imposition of a penalty only after the liable party has received notice and the opportunity for a hearing on the record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for review by the Secretary of any determination or order, or interlocutory ruling, arising from a hearing and judicial review, as provided under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final orders","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a hearing is not requested before the expiration of the 15-day period beginning on the date on which the notice of opportunity for hearing is received, the imposition of a penalty under subsection (b) shall constitute a final and unappealable determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary reviews the determination or order, the Secretary may affirm, modify, or reverse that determination or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary does not review that determination or order before the expiration of the 90-day period beginning on the date on which the determination or order is issued, the determination or order shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors in determining amount of penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a penalty under subsection (b), the Secretary shall take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gravity of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any history of prior offenses by the violator (including offenses occurring before the enactment of this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the violator to pay the penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any injury to tenants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any injury to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefits received by the violator as a result of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deterrence of future violations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary may establish by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment of a civil money penalty levied under this section shall be payable out of project income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of agency determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Judicial review of determinations made under this section shall be carried out in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1735f–15/e"},"text":"section 1735f–15(e) of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for noncompliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial intervention","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person or entity fails to comply with the determination or order of the Secretary imposing a civil money penalty under subsection (b), after the determination or order is no longer subject to review as provided by subsections (c) and (d), the Secretary may request the Attorney General of the United States to bring an action in an appropriate United States district court to obtain a monetary judgment against that person or entity and such other relief as may be available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any monetary judgment awarded in an action brought under this paragraph may, in the discretion of the court, include the attorney’s fees and other expenses incurred by the United States in connection with the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreviewability of determination or order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action under this subsection, the validity and appropriateness of the determination or order of the Secretary imposing the penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may compromise, modify, or remit any civil money penalty which may be, or has been, imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, if the mortgage covering the property receiving assistance under section 8 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"] is insured or was formerly insured by the Secretary, the Secretary shall apply all civil money penalties collected under this section to the appropriate insurance fund or funds established under this chapter, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, if the mortgage covering the property receiving assistance under section 8 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"] is neither insured nor formerly insured by the Secretary, the Secretary shall make all civil money penalties collected under this section available for use by the appropriate office within the Department for administrative costs related to enforcement of the requirements of the various programs administered by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb0a2c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agent employed to manage the property that has an identity of interest” means an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has management responsibility for a project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the ownership entity, including its general partner or partners (if applicable), has an ownership interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over which such ownership entity exerts effective control; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “knowing” means having actual knowledge of or acting with deliberate ignorance of or reckless disregard for the prohibitions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0a2c2c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 29, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/65/tV/s562/a/2"},"text":"Pub. L. 105–65, title V, § 562(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1416"},"text":"111 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0a2c2d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0a2c2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb0a2c2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/65/tV/s562/b"},"text":"Pub. L. 105–65, title V, § 562(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1419"},"text":"111 Stat. 1419","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/65/tV/s562/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by subsection (a) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437z"},"text":"section 1437z of this title","children":[],"tail":"] shall apply only with respect to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violations that occur on or after the effective date of final regulations implementing the amendments made by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a continuing violation (as determined by the Secretary of Housing and Urban Development), any portion of a violation that occurs on or after such date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb0a2c30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/65/tV/s562/c"},"text":"Pub. L. 105–65, title V, § 562(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1419"},"text":"111 Stat. 1419","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/65/tV/s562/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall implement the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437z"},"text":"section 1437z of this title","children":[],"tail":"] by regulation issued after notice and opportunity for public comment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comments sought","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice under subparagraph (A) shall seek comments as to the definitions of the terms ‘ownership interest in’ and ‘effective control’, as such terms are used in the definition of the term ‘agent employed to manage such property that has an identity of interest’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proposed rule implementing the amendments made by this section shall be published not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
