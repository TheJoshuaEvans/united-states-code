{"tag":"section","attrib":{"id":"idbb8faf93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862n–10"},"text":"§ 1862n–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-serving institutions undergraduate program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8faf94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to establish a new program to award grants on a competitive, merit-reviewed basis to Hispanic-serving institutions, Alaska Native-serving institutions, Native Hawaiian-serving institutions, and other institutions of higher education serving a substantial number of minority students to enhance the quality of undergraduate science, mathematics, and engineering education at such institutions and to increase the retention and graduation rates of students pursuing associate’s or baccalaureate degrees in science, mathematics, engineering, or technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8faf96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to improve courses and curriculum in science, mathematics, and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stipends for undergraduate students participating in research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8faf99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities consistent with subsection (a), as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This program shall be coordinated with and in addition to the ongoing Historically Black Colleges and Universities Undergraduate Program and the Tribal Colleges and Universities Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8faf9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862n–10/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding for instrumentation is an allowed use of grants awarded under this section and under the ongoing Historically Black Colleges and Universities Undergraduate Program and the Tribal Colleges and Universities Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8faf9c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s24"},"text":"Pub. L. 107–368, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3066"},"text":"116 Stat. 3066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8faf9d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8faf9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8faf9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 2002, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8fafa0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8fafa1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s4"},"text":"section 4 of Pub. L. 107–368","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n"},"text":"section 1862n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
