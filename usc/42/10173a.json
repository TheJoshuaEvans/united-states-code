{"tag":"section","attrib":{"id":"idbf1776ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10173a"},"text":"§ 10173a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1776ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the benefits to which a State, an affected unit of local government or Indian tribe is entitled under this subchapter, the Secretary shall make payments to a State or Indian tribe that is a party to a benefits agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173"},"text":"section 10173 of this title","children":[],"tail":" in accordance with the following schedule:"},{"tag":"html:table","attrib":{"width":"50%","id":"idbf1776ef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"BENEFITS SCHEDULE","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"(amounts in $ millions)","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Event","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"MRS","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Repository","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(A) Annual payments prior to first spent fuel receipt","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" 5","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(B) Upon first spent fuel receipt","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(C) Annual payments after first spent fuel receipt until closure of the facility","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf1776f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “MRS” means a monitored retrievable storage facility,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1776f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “spent fuel” means high-level radioactive waste or spent nuclear fuel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1776f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “first spent fuel receipt” does not include receipt of spent fuel or high-level radioactive waste for purposes of testing or operational demonstration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual payments prior to first spent fuel receipt under paragraph (1)(A) shall be made on the date of execution of the benefits agreement and thereafter on the anniversary date of such execution. Annual payments after the first spent fuel receipt until closure of the facility under paragraph (1)(C) shall be made on the anniversary date of such first spent fuel receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the first spent fuel payment under paragraph (1)(B) is made within six months after the last annual payment prior to the receipt of spent fuel under paragraph (1)(A), such first spent fuel payment under paragraph (1)(B) shall be reduced by an amount equal to one-twelfth of such annual payment under paragraph (1)(A) for each full month less than six that has not elapsed since the last annual payment under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), (2), or (3), no payment under this section may be made before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", and any payment due under this subchapter before "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", shall be made on or after such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (7), the Secretary may not restrict the purposes for which the payments under this section may be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf1776f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State receiving a payment under this section shall transfer an amount equal to not less than one-third of the amount of such payment to affected units of local government of such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1776fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for this transfer and appropriate allocation of such portion among such governments shall be included in the benefits agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173"},"text":"section 10173 of this title","children":[],"tail":" covering such payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1776fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a dispute concerning such plan, the Secretary shall resolve such dispute, consistent with this chapter and applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A benefits agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173"},"text":"section 10173 of this title","children":[],"tail":" shall provide that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Review Panel be established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173b"},"text":"section 10173b of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or Indian tribe that is party to such agreement waive its rights under this subchapter to disapprove the recommendation of a site for a repository;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties to the agreement shall share with one another information relevant to the licensing process for the repository or monitored retrievable storage facility, as it becomes available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or Indian tribe that is party to such agreement participate in the design of the repository or monitored retrievable storage facility and in the preparation of documents required under law or regulation governing the effects of the facility on the public health and safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf177701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or Indian tribe waive its rights, if any, to impact assistance under sections 10136(c)(1)(B)(ii), 10136(c)(2), 10138(b)(2)(A)(ii), and 10138(b)(3) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf177702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments to the States or affected Indian tribes under a benefits agreement under this section from the Waste Fund. The signature of the Secretary on a valid benefits agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173"},"text":"section 10173 of this title","children":[],"tail":" shall constitute a commitment by the United States to make payments in accordance with such agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf177703-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s171"},"text":"Pub. L. 97–425, title I, § 171","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5031"},"text":"Pub. L. 100–203, title V, § 5031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-237"},"text":"101 Stat. 1330–237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf177704-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf177705-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf177706-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
