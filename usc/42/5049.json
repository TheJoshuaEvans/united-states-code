{"tag":"section","attrib":{"id":"idbcf30fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5049"},"text":null,"children":[{"tag":"num","attrib":{"value":"5049"},"text":"§ 5049.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of Federal control of educational institution or school system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter shall be construed to authorize any department, agency, officer, or employee of the United States to exercise any direction, supervision, or control over the curriculum, program of instruction, administration, or personnel of any education institution or school system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcf30fba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tIV/s409"},"text":"Pub. L. 93–113, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/410"},"text":"87 Stat. 410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf30fbb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf30fbc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf30fbd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":", known as the Domestic Volunteer Service Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
