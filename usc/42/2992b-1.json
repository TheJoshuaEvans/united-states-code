{"tag":"section","attrib":{"id":"idbc31e291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2992b–1"},"text":"§ 2992b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements applicable to rulemaking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc31e292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", and except as otherwise provided in this section, such section 553 shall apply with respect to the establishment and general operation of any program that provides loans, grants, benefits, or contracts authorized by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretative rule or general statement of policy; waiver of notice and public procedure regarding any other rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (A) of the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b"},"text":"section 553(b) of title 5","children":[],"tail":" shall not apply with respect to any interpretative rule or general statement of policy—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc31e295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc31e296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable exclusively to any program, project, or activity authorized by, or carried out under, this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (B) of the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b"},"text":"section 553(b) of title 5","children":[],"tail":", shall not apply with respect to any rule (other than an interpretative rule or a general statement of policy)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc31e298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc31e299-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable exclusively to any program, project, or activity authorized by, or carried out under, this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e29a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first 2 sentences of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b"},"text":"section 553(b) of title 5","children":[],"tail":" shall apply with respect to any rule (other than an interpretative rule, a general statement of policy, or a rule of agency organization, procedure, or practice) that is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc31e29b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc31e29c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable exclusively to any program, project, or activity authorized by, or carried out under, this subchapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the Secretary for good cause finds (and incorporates the finding and a brief statement of the reasons therefor in such rule) that notice and public procedure thereon are contrary to the public interest or would impair the effective administration of any program, project, or activity with respect to which such rule is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e29d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of rule or general statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/d"},"text":"section 553(d) of title 5","children":[],"tail":", no rule (including an interpretative rule) or general statement of policy that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e29e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is issued to carry out this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e29f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies exclusively to any program, project, or activity authorized by, or carried out under, this subchapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may take effect until 30 days after the publication required under the first 2 sentences of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b"},"text":"section 553(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e2a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory citation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each rule (including an interpretative rule) and each general statement of policy to which this section applies shall contain after each of its sections, paragraphs, or similar textual units a citation to the particular provision of statutory or other law that is the legal authority for such section, paragraph, or unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e2a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule or general statement of policy necessary as result of legislation; time for issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), if as a result of the enactment of any law affecting the administration of this subchapter it is necessary or appropriate for the Secretary to issue any rule (including any interpretative rule) or a general statement of policy, the Secretary shall issue such rule or such general statement of policy not later than 180 days after the date of the enactment of such law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e2a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992b–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy of rule or general statement of policy to Congressional leaders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever an agency publishes in the Federal Register a rule (including an interpretative rule) or a general statement of policy to which subsection (c) applies, such agency shall transmit a copy of such rule or such general statement of policy to the Speaker of the House of Representatives and the President pro tempore of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e2a3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s814"},"text":"Pub. L. 88–452, title VIII, § 814","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV/s503/a"},"text":"Pub. L. 100–175, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/974"},"text":"101 Stat. 974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e2a4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc31e2a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc31e2a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/s814"},"text":"section 814 of Pub. L. 88–452","children":[],"tail":" was renumbered section 816 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2992d"},"text":"section 2992d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc31e2a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc31e2a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/s701/a"},"text":"section 701(a) of Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
