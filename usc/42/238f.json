ursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb482b8d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1261"},"text":"Pub. L. 117–328, div. FF, title I, § 1261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5681"},"text":"136 Stat. 5681","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tI/s1261"},"text":"“Notwithstanding any provision of this title [see Tables for classification] and the amendments made by this title, no funds made available to carry out this title or any amendment made by this title shall be used to purchase, procure, or distribute pipes or cylindrical objects intended to be used to smoke or inhale illegal scheduled substances.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb482b8d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Buy American Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2004"},"text":"Pub. L. 103–43, title XX, § 2004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/209"},"text":"107 Stat. 209","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s416/a"},"text":"Pub. L. 105–392, title IV, § 416(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3590"},"text":"112 Stat. 3590","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/392/tIV/s416/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress Regarding Purchase of American-Made Equipment and Products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any equipment or product that may be authorized to be purchased with financial assistance provided pursuant to this Act for any of the fiscal years 1994 through 1996, it is the sense of the Congress that entities receiving such assistance should, in expending the assistance, purchase only American-made equipment and products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Recipients of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing financial assistance pursuant to this Act, the Secretary of Health and Human Services shall provide to each recipient of the assistance a notice describing the statement made in subsection (a) by the Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s416/c"},"text":"Pub. L. 105–392, title IV, § 416(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3591"},"text":"112 Stat. 3591","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/392/tIV/s416/c"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2004"},"text":"section 2004 of Pub. L. 103–43","children":[],"tail":", set out above] is deemed to have taken effect immediately after the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Public Law 103–43","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb482b8d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriations for Active Commissioned Officers and Other Expenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394/tII/s202"},"text":"Pub. L. 102–394, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1810"},"text":"106 Stat. 1810","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dF/tII/s222"},"text":"Pub. L. 111–8, div. F, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/784"},"text":"123 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5209"},"text":"Pub. L. 111–148, title V, § 5209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/613"},"text":"124 Stat. 613","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tV/s5209"},"text":"“Appropriations in this or any other Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts shall be available for expenses for active commissioned officers in the Public Health Service Reserve Corps [now Ready Reserve Corps] and for commissioned officers in the Regular Corps; expenses incident to the dissemination of health information in foreign countries through exhibits and other appropriate means; advances of funds for compensation, travel, and subsistence expenses (or per diem in lieu thereof) for persons coming from abroad to participate in health or scientific activities of the Department pursuant to law; expenses of primary and secondary schooling of dependents in foreign countries, of Public Health Service commissioned officers stationed in foreign countries, at costs for any given area not in excess of those of the Department of Defense for the same area, when it is determined by the Secretary that the schools available in the locality are unable to provide adequately for the education of such dependents, and for the transportation of such dependents, between such schools and their places of residence when the schools are not accessible to such dependents by regular means of transportation; expenses for medical care for civilian and commissioned employees of the Public Health Service and their dependents assigned abroad on a permanent basis in accordance with such regulations as the Secretary may provide; rental or lease of living quarters (for periods not exceeding five years), and provision of heat, fuel, and light and maintenance, improvement, and repair of such quarters, and advance payments therefor, for civilian officers and employees of the Public Health Service who are United States citizens and who have a permanent station in a foreign country; purchase, erection, and maintenance of temporary or portable structures; and for the payment of compensation to consultants or individual scientists appointed for limited periods of time pursuant to section 207(f) or section 207(g) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s209/f"},"text":"42 U.S.C. 209(f)","children":[],"tail":", (g)], at rates established by the Assistant Secretary for Health, or the Secretary where such action is required by statute, not to exceed the per diem rate equivalent to the maximum rate payable for senior-level positions under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"5 U.S.C. 5376","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s5209"},"text":"Pub. L. 111–148, § 5209","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/394/s202"},"text":"Pub. L. 102–394, § 202","children":[],"tail":", set out above, by striking out “not to exceed 2,800”, was executed by striking out “not to exceed 4,000” before “commissioned officers in the Regular Corps”, to reflect the probable intent of Congress.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For reference to maximum rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":", Government Organization and Employees, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/d/3"},"text":"section 2(d)(3) of Pub. L. 110–372","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,