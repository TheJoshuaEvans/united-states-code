{"tag":"section","attrib":{"id":"idbc2140f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342"},"text":null,"children":[{"tag":"num","attrib":{"value":"2342"},"text":"§ 2342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2140f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property under lease or license agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall offer for disposal all real property (including such improvements thereon and such fixtures, equipment, and other personal property incident thereto as it may deem appropriate) within the community which is presently under lease or license agreement with the Commission or its community management contractor for residential, commercial or industrial, agricultural, church or other nonprofit use, or which, in the opinion of the Commission, is appropriate for such use, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2140f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures which in the opinion of the Commission should be removed from the community because of their unsatisfactory type of construction, condition, or location; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2140f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property which in the opinion of the Commission should be transferred pursuant to subchapters VI or VII; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2140fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property which in the opinion of the Commission should be retained by the Commission for its own use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary disposal of other real property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, but shall not be required to, dispose of any other real property at the community, whether within or outside of that community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions; impairment of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such property shall be disposed of on such terms and conditions, consistent with this subchapter, as the Commission shall prescribe in the national interest, and without regard to any preferences or priorities whatever except those provided for pursuant to this chapter. Transfers by the Commission of such property shall not impair rights under existing leases and covenants, including any purchase rights therein conferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2140fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 5, § 52, "},{"tag":"ref","attrib":{"href":"/us/stat/69/476"},"text":"69 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/719/s9"},"text":"Pub. L. 87–719, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/665"},"text":"76 Stat. 665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2140fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc2140ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc214100-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/719"},"text":"Pub. L. 87–719","children":[],"tail":" added cl. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc214101-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc214102-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
