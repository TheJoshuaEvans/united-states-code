{"tag":"section","attrib":{"id":"idc0596cd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445"},"text":null,"children":[{"tag":"num","attrib":{"value":"18445"},"text":"§ 18445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0596cd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring risk","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596cd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update on system implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2010-10-11"},"text":"October 11, 2010","children":[],"tail":", and on a biennial basis thereafter, the chief information officer of NASA, in coordination with other national security agencies, shall provide to the appropriate committees of Congress—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an update on efforts to implement a system to provide dynamic, comprehensive, real-time information regarding risk of unauthorized remote, proximity, and insider use or access, for all information infrastructure under the responsibility of the chief information officer, and mission-related networks, including contractor networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether the system has demonstrably and quantifiably reduced network risk compared to alternative methods of measuring security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596cd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the progress that each center and facility has made toward implementing the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596cda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessments required of the Inspector General under section 3545 ","children":[{"tag":"ref","attrib":{"idref":"fn004359"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004359"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 44 shall evaluate the effectiveness of the system described in this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596cdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information security awareness and education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0596cdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the Department of Education, other national security agencies, and other agency directorates, the chief information officer shall institute an information security awareness and education program for all operators and users of NASA information infrastructure, with the goal of reducing unauthorized remote, proximity, and insider use or access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0596cdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0596cde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall include, at a minimum, ongoing classified and unclassified threat-based briefings, and automated exercises and examinations that simulate common attack techniques.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596cdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All agency employees and contractors engaged in the operation or use of agency information infrastructure shall participate in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596ce0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Access to NASA information infrastructure shall only be granted to operators and users who regularly satisfy the requirements of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0596ce1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief human capital officer of NASA, in consultation with the chief information officer, shall create a system to reward operators and users of agency information infrastructure for continuous high achievement in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0596ce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18445/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information infrastructure defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “information infrastructure” means the underlying framework that information systems and assets rely on to process, transmit, receive, or store information electronically, including programmable electronic devices and communications networks and any associated hardware, software, or data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0596ce3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tXII/s1207"},"text":"Pub. L. 111–267, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2844"},"text":"124 Stat. 2844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0596ce4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0596ce5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0596ce6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3545"},"text":"Section 3545 of title 44","children":[],"tail":", referred to in subsec. (a)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/a"},"text":"Pub. L. 113–283, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3073"},"text":"128 Stat. 3073","children":[],"tail":". Provisions similar to "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3545"},"text":"section 3545 of title 44","children":[],"tail":" are now contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3555"},"text":"section 3555 of title 44","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/113/283"},"text":"Pub. L. 113–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
