{"tag":"section","attrib":{"id":"idb58b4fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a"},"text":null,"children":[{"tag":"num","attrib":{"value":"289a"},"text":"§ 289a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb58b4fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for biomedical and behavioral research grants, cooperative agreements, and contracts; regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58b4fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Director of NIH, shall by regulation require appropriate technical and scientific peer review of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb58b4fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications made for grants and cooperative agreements under this chapter for biomedical and behavioral research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb58b4faa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications made for biomedical and behavioral research and development contracts to be administered through the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58b4fab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations promulgated under paragraph (1) shall require that the review of applications made for grants, contracts, and cooperative agreements required by the regulations be conducted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb58b4fac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practical, in a manner consistent with the system for technical and scientific peer review applicable on ","children":[{"tag":"date","attrib":{"date":"1985-11-20"},"text":"November 20, 1985","children":[],"tail":", to grants under this chapter for biomedical and behavioral research, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb58b4fad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practical, by technical and scientific peer review groups performing such review on or before ","children":[{"tag":"date","attrib":{"date":"1985-11-20"},"text":"November 20, 1985","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and shall authorize such review to be conducted by groups appointed under sections 282(b)(16) and 284(c)(3) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb58b4fae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review of research at National Institutes of Health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of NIH shall establish procedures for periodic technical and scientific peer review of research at the National Institutes of Health. Such procedures shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58b4faf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reviewing entity be provided a written description of the research to be reviewed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58b4fb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reviewing entity provide the advisory council of the national research institute involved with such description and the results of the review by the entity,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and shall authorize such review to be conducted by groups appointed under sections 282(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 284(c)(3) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb58b4fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with requirements for inclusion of women and minorities in clinical research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58b4fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In technical and scientific peer review under this section of proposals for clinical research, the consideration of any such proposal (including the initial consideration) shall, except as provided in paragraph (2), include an evaluation of the technical and scientific merit of the proposal regarding compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"section 289a–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58b4fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply to any proposal for clinical research that, pursuant to subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a–2"},"text":"section 289a–2 of this title","children":[],"tail":", is not subject to the requirement of subsection (a) of such section regarding the inclusion of women and members of minority groups as subjects in clinical research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb58b4fb4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 492, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/874"},"text":"99 Stat. 874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tI/s132"},"text":"Pub. L. 103–43, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/135"},"text":"107 Stat. 135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s102/f/1/B"},"text":"Pub. L. 109–482, title I, § 102(f)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3685"},"text":"120 Stat. 3685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb58b4fb5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb58b4fb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb58b4fb7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/6"},"text":"Section 282(b)(6) of this title","children":[],"tail":", referred to in subsec. (b), was redesignated section 282(b)(16) by "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s102/a/3"},"text":"Pub. L. 109–482, title I, § 102(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3681"},"text":"120 Stat. 3681","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb58b4fb8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" substituted “sections 282(b)(16)” for “sections 282(b)(6)” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb58b4fb9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb58b4fba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
