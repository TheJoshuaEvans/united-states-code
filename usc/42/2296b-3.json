{"tag":"section","attrib":{"id":"idbc17a4e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296b–3"},"text":"§ 2296b–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for the industry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc17a4e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing Secretarial responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have a continuing responsibility for the domestic uranium industry to encourage the use of domestic uranium. The Secretary, in fulfilling this responsibility, shall not use any supervisory authority over the Corporation. The Secretary shall report annually to the appropriate committees of Congress on action taken with respect to the domestic uranium industry, including action to promote the export of domestic uranium pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc17a4e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296b–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encourage export","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department, with the cooperation of the Department of Commerce, the United States Trade Representative and other governmental organizations, shall encourage the export of domestic uranium. Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall develop recommendations and implement government programs to promote the export of domestic uranium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a4e6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1014"},"text":"Pub. L. 102–486, title X, § 1014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2949"},"text":"106 Stat. 2949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4e7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
