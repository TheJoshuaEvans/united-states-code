{"tag":"section","attrib":{"id":"idb6dbc466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–36"},"text":"§ 300jj–36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information technology professionals in health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6dbc467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Director of the National Science Foundation, shall provide assistance to institutions of higher education (or consortia thereof) to establish or expand medical health informatics education programs, including certification, undergraduate, and masters degree programs, for both health care and information technology students to ensure the rapid and effective utilization and development of health information technologies (in the United States health care infrastructure).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities for which assistance may be provided under subsection (a) may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and revising curricula in medical health informatics and related disciplines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruiting and retaining students to the program involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquiring equipment necessary for student instruction in these programs, including the installation of testbed networks for student use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing or enhancing bridge programs in the health informatics fields between community colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing assistance under subsection (a), the Secretary shall give preference to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Existing education and training programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–36/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs designed to be completed in less than six months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6dbc470-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3016, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13301"},"text":"Pub. L. 111–5, div. A, title XIII, § 13301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/257"},"text":"123 Stat. 257","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
