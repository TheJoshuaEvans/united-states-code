{"tag":"section","attrib":{"id":"idbfb9aacf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13314"},"text":null,"children":[{"tag":"num","attrib":{"value":"13314"},"text":"§ 13314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of tax and rate treatment of renewable energy projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in conjunction with State regulatory commissions, shall undertake a study to determine if conventional taxation and ratemaking procedures result in economic barriers to or incentives for renewable energy power plants compared to conventional power plants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit a report to the Congress on the results of the study undertaken under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aad2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXII/s1205"},"text":"Pub. L. 102–486, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2962"},"text":"106 Stat. 2962","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
