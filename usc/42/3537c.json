{"tag":"section","attrib":{"id":"idbc8a1599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3537c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3537c"},"text":"§ 3537c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of lump-sum payments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In providing relocation assistance in connection with any program administered by the Department of Housing and Urban Development, the Secretary may not make lump-sum payments to any displaced residential tenant, except where necessary to cover—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8a159a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3537c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moving expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8a159b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3537c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a downpayment on the purchase of a replacement residence, including a condominium unit or membership in a cooperative housing association; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8a159c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3537c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any incidental expenses related to paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc8a159d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/174/s14"},"text":"Pub. L. 89–174, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s922"},"text":"Pub. L. 102–550, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3884"},"text":"106 Stat. 3884","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
