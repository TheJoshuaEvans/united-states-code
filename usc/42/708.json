{"tag":"section","attrib":{"id":"idb7f01a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708"},"text":null,"children":[{"tag":"num","attrib":{"value":"708"},"text":"§ 708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f01a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally funded activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f01a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of applying the prohibitions against discrimination on the basis of age under the Age Discrimination Act of 1975 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], on the basis of handicap under section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], on the basis of sex under title IX of the Education Amendments of 1972 ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"20 U.S.C. 1681","children":[],"tail":" et seq.], or on the basis of race, color, or national origin under title VI of the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], programs and activities funded in whole or in part with funds made available under this subchapter are considered to be programs and activities receiving Federal financial assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall on the ground of sex or religion be excluded from participation in, be denied the benefits of, or be subjected to discrimination under, any program or activity funded in whole or in part with funds made available under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f01a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary finds that a State, or an entity that has received a payment from an allotment to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/c"},"text":"section 702(c) of this title","children":[],"tail":", has failed to comply with a provision of law referred to in subsection (a)(1), with subsection (a)(2), or with an applicable regulation (including one prescribed to carry out subsection (a)(2)), he shall notify the chief executive officer of the State and shall request him to secure compliance. If within a reasonable period of time, not to exceed sixty days, the chief executive officer fails or refuses to secure compliance, the Secretary may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f01a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer the matter to the Attorney General with a recommendation that an appropriate civil action be instituted,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the powers and functions provided by title VI of the Civil Rights Act of 1964 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], the Age Discrimination Act of 1975 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"42 U.S.C. 6101","children":[],"tail":" et seq.], or section 504 of the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"], as may be applicable, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as may be provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f01a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attorney General; civil actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a matter is referred to the Attorney General pursuant to subsection (b)(1), or whenever he has reason to believe that the entity is engaged in a pattern or practice in violation of a provision of law referred to in subsection (a)(1) or in violation of subsection (a)(2), the Attorney General may bring a civil action in any appropriate district court of the United States for such relief as may be appropriate, including injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f01a22-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2192/a"},"text":"Pub. L. 97–35, title XXI, § 2192(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/825"},"text":"95 Stat. 825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6502/b"},"text":"Pub. L. 101–239, title VI, § 6502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2276"},"text":"103 Stat. 2276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f01a23-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f01a24-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7f01a25-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in subsecs. (a)(1) and (b)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Education Amendments of 1972, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/318"},"text":"Pub. L. 92–318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/235"},"text":"86 Stat. 235","children":[],"tail":". Title IX of the Act, known as the Patsy Takemoto Mink Equal Opportunity in Education Act, is classified principally to chapter 38 (§ 1681 et seq.) of Title 20, Education. For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1681"},"text":"section 1681 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsecs. (a)(1) and (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VI of the Civil Rights Act of 1964 is classified generally to subchapter V (§ 2000d et seq.) of chapter 21 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7f01a26-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 708, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tV/s508"},"text":"act Aug. 14, 1935, ch. 531, title V, § 508","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tIII/s301"},"text":"Pub. L. 90–248, title III, § 301","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/926"},"text":"81 Stat. 926","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1972-07-10"},"text":"July 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/345/s2/d"},"text":"Pub. L. 92–345, § 2(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/457"},"text":"86 Stat. 457","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/53/s4/a/6"},"text":"Pub. L. 93–53, § 4(a)(6)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/135"},"text":"87 Stat. 135","children":[],"tail":", related to special project grants for maturity and infant care, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2192/a"},"text":"section 2192(a) of Pub. L. 97–35","children":[],"tail":". For effective date, savings, and transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2194"},"text":"section 2194 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"section 701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising former section 708 were contained in section 531 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tV"},"text":"act Aug. 14, 1935, ch. 531, title V","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1963-10-24"},"text":"Oct. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/156/s4"},"text":"Pub. L. 88–156, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/274"},"text":"77 Stat. 274","children":[],"tail":" (formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s729"},"text":"section 729 of this title","children":[],"tail":"), prior to the general amendment and renumbering of title V of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/s301"},"text":"Pub. L. 90–248, § 301","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f01a27-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “702(c) of this title” for “702(b) of this title” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f01a28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7f01a29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" applicable to appropriations for fiscal years beginning with fiscal year 1990, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6510/a"},"text":"section 6510(a) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"section 701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
