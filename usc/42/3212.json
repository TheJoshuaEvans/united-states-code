{"tag":"section","attrib":{"id":"idbc797362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3212"},"text":null,"children":[{"tag":"num","attrib":{"value":"3212"},"text":"§ 3212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laborers and mechanics employed by contractors or subcontractors on projects assisted by the Secretary under this chapter shall be paid wages at rates not less than those prevailing on similar construction in the locality as determined by the Secretary of Labor in accordance with subchapter IV of chapter 31 of title 40. The Secretary shall not extend any financial assistance under this chapter for such a project without first obtaining adequate assurance that these labor standards will be maintained upon the construction work. The Secretary of Labor shall have, with respect to the labor standards specified in this provision, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (15 F.R. 3176; ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc797363-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s602"},"text":"Pub. L. 89–136, title VI, § 602","children":[],"tail":", formerly title VII, § 712, "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/575"},"text":"79 Stat. 575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/567/tIII/s302"},"text":"Pub. L. 93–567, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"te