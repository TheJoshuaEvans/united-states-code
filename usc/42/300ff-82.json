{"tag":"section","attrib":{"id":"idb6a28c4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–82"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–82"},"text":"§ 300ff–82.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a28c4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–82/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2009, and each subsequent fiscal year, the Secretary may reduce the amounts of grants under this subchapter to a State or political subdivision of a State for a fiscal year if, with respect to such grants for the second preceding fiscal year, the State or subdivision fails to prepare audits in accordance with the procedures of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s7502"},"text":"section 7502 of title 31","children":[],"tail":". The Secretary shall annually select representative samples of such audits, prepare summaries of the selected audits, and submit the summaries to the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a28c50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–82/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting on the Internet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All audits that the Secretary receives from the State lead agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b/4"},"text":"section 300ff–27(b)(4) of this title","children":[],"tail":" shall be posted, in their entirety, on the Internet website of the Health Resources and Services Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a28c51-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2682, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tV/s501"},"text":"Pub. L. 109–415, title V, § 501","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2813"},"text":"120 Stat. 2813","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28c52-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28c53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6a28c54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300ff–82, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2682, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIV/s411/a"},"text":"Pub. L. 101–381, title IV, § 411(a)","children":[],"tail