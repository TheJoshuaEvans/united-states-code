{"tag":"section","attrib":{"id":"idb5083c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g"},"text":null,"children":[{"tag":"num","attrib":{"value":"256g"},"text":"§ 256g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for innovative programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5083c5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, is authorized to award grants to States for the purpose of helping States develop and implement innovative programs to address the dental workforce needs of designated dental health professional shortage areas in a manner that is appropriate to the States’ individual needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State receiving a grant under subsection (a) may use funds received under the grant for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5083c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" loan forgiveness and repayment programs for dentists who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5083c62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to practice in designated dental health professional shortage areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are dental school graduates who agree to serve as public health dentists for the Federal, State, or local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agree to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5083c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services to patients regardless of such patients’ ability to pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5083c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a sliding payment scale for patients who are unable to pay the total cost of services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dental recruitment and retention efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants and low-interest or no-interest loans to help dentists who participate in the medicaid program under title XIX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.) to establish or expand practices in designated dental health professional shortage areas by equipping dental offices or sharing in the overhead costs of such practices;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or expansion of dental residency programs in coordination with accredited dental training institutions in States without dental schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs developed in consultation with State and local dental societies to expand or establish oral health services and facilities in designated dental health professional shortage areas, including services and facilities for children with special needs, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5083c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion or establishment of a community-based dental facility, free-standing dental clinic, consolidated health center dental facility, school-linked dental facility, or United States dental school-based facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a mobile or portable dental clinic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or expansion of private dental services to enhance capacity through additional equipment or additional hours of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment or development of models for the provision of dental services to children and adults, such as dental homes, including for the elderly, blind, individuals with disabilities, and individuals living in long-term care facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of initiatives to reduce the use of emergency departments by individuals who seek dental services more appropriately delivered in a dental primary care setting;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placement and support of dental students, dental residents, and advanced dentistry trainees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing dental education, including distance-based education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" practice support through teledentistry conducted in accordance with State laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based prevention services such as water fluoridation and dental sealant programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with local educational agencies within the State to foster programs that promote children going into oral health or science professions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of faculty recruitment programs at accredited dental training institutions whose mission includes community outreach and service and that have a demonstrated record of serving underserved States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a State dental officer position or the augmentation of a State dental office to coordinate oral health and access issues in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5083c79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The application shall include assurances that the State will meet the requirements of subsection (d) and that the State possesses sufficient infrastructure to manage the activities to be funded through the grant and to evaluate and report on the outcomes resulting from such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant to a State under this section unless that State agrees that, with respect to the costs to be incurred by the State in carrying out the activities for which the grant was awarded, the State will provide non-Federal contributions in an amount equal to not less than 40 percent of Federal funds provided under the grant. The State may provide the contributions in cash or in kind, fairly evaluated, including plant, equipment, and services and may provide the contributions from State, local, or private sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2002-10-26"},"text":"October 26, 2002","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress a report containing data relating to whether grants provided under this section have increased access to dental services in designated dental health professional shortage areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $13,903,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5083c7e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 340G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIV/s403"},"text":"Pub. L. 107–251, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1661"},"text":"116 Stat. 1661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/355/s5"},"text":"Pub. L. 110–355, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3994"},"text":"122 Stat. 3994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/302/s3"},"text":"Pub. L. 115–302, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-11"},"text":"Dec. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4397"},"text":"132 Stat. 4397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5083c7f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5083c80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5083c81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5083c82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/302/s3/1"},"text":"Pub. L. 115–302, § 3(1)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/302/s3/2"},"text":"Pub. L. 115–302, § 3(2)","children":[],"tail":", substituted “$13,903,000 for each of fiscal years 2019 through 2023” for “$25,000,000 for the 5-fiscal year period beginning with fiscal year 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/355"},"text":"Pub. L. 110–355","children":[],"tail":" substituted “$25,000,000” for “$50,000,000” and “2008” for “2002”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
