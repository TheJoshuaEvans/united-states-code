{"tag":"section","attrib":{"id":"idbb70b607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784"},"text":null,"children":[{"tag":"num","attrib":{"value":"1784"},"text":"§ 1784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb70b608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any of the fifty States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, or the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State educational agency” means, as the State legislature may determine, (A) the chief State school officer (such as the State superintendent of public instruction, commissioner of education, or similar officer), or (B) a board of education controlling the State department of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b60a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “School” means (A) any public or nonprofit private school of high school grade or under, including kindergarten and preschool programs operated by such school, and (B) any public or licensed nonprofit private residential child care institution (including, but not limited to, orphanages and homes for the mentally retarded, but excluding Job Corps Centers funded by the Department of Labor). For purposes of clauses (A) and (B) of this paragraph, the term “nonprofit”, when applied to any such private school or institution, means any such school or institution which is exempt from tax under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b60b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b60c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “School year” means the annual period from July 1 through June 30.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b60d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"section 1786 of this title","children":[],"tail":", the terms “child” and “children” as used in this chapter, shall be deemed to include persons regardless of age who are determined by the State educational agency, in accordance with regulations prescribed by the Secretary, to have 1 or more disabilities and who are attending any nonresidential public or nonprofit private school of high school grade or under for the purpose of participating in a school program established for individuals with disabilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb73270e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1784/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “disability” has the meaning given the term in the Rehabilitation Act of 1973 for purposes of title II of that Act (29 U.S.C 760 et seq.).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb73270f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s15"},"text":"Pub. L. 89–642, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/889"},"text":"80 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/105"},"text":"Pub. L. 94–105","children":[],"tail":", §§ 15(c), 17(b), "},{"tag":"date","attrib":{"date":"1975-10-07"},"text":"Oct. 7, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/522"},"text":"89 Stat. 522","children":[],"tail":", 525; "},{"tag":"ref","attrib":{"href":"/us/pl/95/166/s20/5"},"text":"Pub. L. 95–166, § 20(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-10"},"text":"Nov. 10, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1346"},"text":"91 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/627/s10/c"},"text":"Pub. L. 95–627, § 10(c)","children":[],"tail":", (d)(3), "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3624"},"text":"92 Stat. 3624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/