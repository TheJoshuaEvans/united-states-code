{"tag":"section","attrib":{"id":"idc011dcf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392"},"text":null,"children":[{"tag":"num","attrib":{"value":"16392"},"text":"§ 16392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology Infrastructure Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc011dcf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dcf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Technology Infrastructure Program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dcf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology cluster","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “technology cluster” means a concentration of technology-related business concerns, institutions of higher education, or nonprofit institutions, that reinforce each other’s performance in the areas of technology development through formal or informal relationships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dcf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology-related business concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technology-related business concern” means a for-profit corporation, company, association, firm, partnership, or small business concern that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dcf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts scientific or engineering research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dcf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops new technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dcf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures products based on new technologies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dcf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs technological services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dcf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a Technology Infrastructure Program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dcfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Program shall be to improve the ability of National Laboratories and single-purpose research facilities to support departmental missions by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dcfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulating the development of technology clusters that can support departmental missions at the National Laboratories or single-purpose research facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dcfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the ability of National Laboratories and single-purpose research facilities to leverage and benefit from commercial research, technology, products, processes, and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dcfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encouraging the exchange of scientific and technological expertise between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dcfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories or single-purpose research facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dcff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" entities that can support departmental missions at the National Laboratories or single-purpose research facilities, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc011dd00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc011dd01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology-related business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc011dd02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc011dd03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agencies of State, tribal, or local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall authorize the director of each National Laboratory or single-purpose research facility to implement the Program at the National Laboratory or facility through one or more projects that meet the requirements of subsections (e) and (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each project funded under this section shall meet the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each project shall include at least one of each of the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency of a State, local, or tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The costs of carrying out projects under this section shall be shared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The calculation of costs paid by the non-Federal sources for a project shall include cash, personnel, services, equipment, and other resources expended on the project after the commencement of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Independent research and development expenses of Government contractors that qualify for reimbursement under section 31.205–18(e) of title 48, Code of Federal Regulations, issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1303/a/1"},"text":"section 1303(a)(1) of title 41","children":[],"tail":", may be credited towards costs paid by non-Federal sources to a project, if the expenses meet the other requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section shall be competitively selected using procedures determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any participant that receives funds under this section may use generally accepted accounting principles for maintaining accounts, books, and records relating to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal funds shall be made available under this section for a construction project or for any project with a duration of more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental missions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate funds under this section only if the Director of the National Laboratory or single-purpose research facility managing the project determines that the project is likely to improve the ability of the National Laboratory or single-purpose research facility to achieve technical success in meeting departmental missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting a project to receive Federal funds, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc011dd16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of the project to promote the development of a commercially sustainable technology cluster following the period of investment by the Department, which will derive most of the demand for its products or services from the private sector, and which will support departmental missions at the participating National Laboratory or single-purpose research facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of the project to promote the use of commercial research, technology, products, processes, and services by the participating National Laboratory or single-purpose research facility to achieve its mission or the commercial development of technological innovations made at the participating National Laboratory or single-purpose research facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project involves a wide variety and number of institutions of higher education, nonprofit institutions, and technology-related business concerns that can support the missions of the participating National Laboratory or single-purpose research facility and that will make substantive contributions to achieving the goals of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project focuses on promoting the development of technology-related business concerns that are small businesses or involves such small businesses substantively in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc011dd1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other criteria as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating funds for projects approved under this section, the Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc011dd1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal share of the project costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc011dd1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional funds to the National Laboratory or single-purpose research facility managing the project to permit the National Laboratory or single-purpose research facility to carry out activities relating to the project, and to coordinate the activities with the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", the Secretary shall submit to Congress a report on whether the Program should be continued and, if so, how the program should be managed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc011dd1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16392/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for activities under this section $10,000,000 for each of fiscal years 2006 through 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc011dd20-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tX/s1002"},"text":"Pub. L. 109–58, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/927"},"text":"119 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc011dd21-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc011dd22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc011dd23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (e)(3)(C), “","children":[{"tag":