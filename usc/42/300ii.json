{"tag":"section","attrib":{"id":"idb6d227b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ii"},"text":"§ 300ii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d227b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult with a special need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adult with a special need” means a person 18 years of age or older who requires care or supervision to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the person’s basic needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent physical self-injury or injury to others; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid placement in an institutional facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging and disability resource center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “aging and disability resource center” means an entity administering a program established by the State, as part of the State’s system of long-term care, to provide a coordinated system for providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive information on available public and private long-term care programs, options, and resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal counseling to assist individuals in assessing their existing or anticipated long-term care needs, and developing and implementing a plan for long-term care designed to meet their specific needs and circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer access to the range of publicly supported long-term care programs for which consumers may be eligible, by serving as a convenient point of entry for such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child with a special need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “child with a special need” means an individual less than 18 years of age who requires care or supervision beyond that required of children generally to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the child’s basic needs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent physical injury, self-injury, or injury to others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible State agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible State agency” means a State agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administers the State’s program under the Older Americans Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"42 U.S.C. 3001","children":[],"tail":" et seq.], administers the State’s program under title XIX of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.], or is designated by the Governor of such State to administer the State’s programs under this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an aging and disability resource center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" works in collaboration with a public or private nonprofit statewide respite care coalition or organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ability to work with other State and community-based agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an understanding of respite care and family caregiver issues across all age groups, disabilities, and chronic conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity to ensure meaningful involvement of family members, family caregivers, and care recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family caregiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family caregiver” means an unpaid family member, a foster parent, or another unpaid individual, who provides in-home monitoring, management, supervision, or treatment of a child or adult with a special need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lifespan respite care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lifespan respite care” means a coordinated system of accessible, community-based respite care services for family caregivers of children or adults with special needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Respite care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “respite care” means planned or emergency care provided to a child or adult with a special need in order to provide temporary relief to the family caregiver of that child or adult.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia, the Virgin Islands of the United States, the Commonwealth of Puerto Rico, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d227cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIX, § 2901, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/442/s2"},"text":"Pub. L. 109–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3291"},"text":"120 Stat. 3291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tV/s6506/a"},"text":"Pub. L. 119–75, div. J, title V, § 6506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/693"},"text":"140 Stat. 693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6d227ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6d227cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6d227d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Older Americans Act of 1965, referred to in par. (4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-14"},"text":"July 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/218"},"text":"79 Stat. 218","children":[],"tail":", which is classified generally to chapter 35 (§ 3001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in par. (4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6d227d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" substituted “unpaid individual” for “unpaid adult”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
