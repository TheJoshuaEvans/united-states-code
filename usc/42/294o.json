{"tag":"section","attrib":{"id":"idb5e3a8bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o"},"text":null,"children":[{"tag":"num","attrib":{"value":"294o"},"text":"§ 294o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council on Graduate Medical Education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e3a8bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Council on Graduate Medical Education (in this section referred to as the “Council”). The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make recommendations to the Secretary of Health and Human Services (in this section referred to as the “Secretary”), and to the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce of the House of Representatives, with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply and distribution of physicians in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current and future shortages or excesses of physicians in medical and surgical specialties and subspecialties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues relating to foreign medical school graduates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate Federal policies with respect to the matters specified in subparagraphs (A), (B), and (C), including policies concerning changes in the financing of undergraduate and graduate medical education programs and changes in the types of medical education training in graduate medical education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate efforts to be carried out by hospitals, schools of medicine, schools of osteopathic medicine, and accrediting bodies with respect to the matters specified in subparagraphs (A), (B), and (C), including efforts for changes in undergraduate and graduate medical education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deficiencies in, and needs for improvements in, existing data bases concerning the supply and distribution of, and postgraduate training programs for, physicians in the United States and steps that should be taken to eliminate those deficiencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage entities providing graduate medical education to conduct activities to voluntarily achieve the recommendations of the Council under paragraph (1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, publish, and implement performance measures for programs under this subchapter, except for programs under part C or D;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish guidelines for longitudinal evaluations (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294n/d/2"},"text":"section 294n(d)(2) of this title","children":[],"tail":") for programs under this subchapter, except for programs under part C or D; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriation levels for programs under this subchapter, except for programs under part C or D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Health or the designee of the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Medical Director of the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Health Resources and Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members appointed by the Secretary to include representatives of practicing primary care physicians, national and specialty physician organizations, foreign medical graduates, and medical student and house staff associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members appointed by the Secretary to include representatives of schools of medicine and osteopathic medicine and public and private teaching hospitals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members appointed by the Secretary to include representatives of health insurers, business, and labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of appointed members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general; staggered rotation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council appointed under paragraphs (4), (5), and (6) of subsection (b) shall be appointed for a term of 4 years, except that the term of office of the members first appointed shall expire, as designated by the Secretary at the time of appointment, 4 at the end of 1 year, 4 at the end of 2 years, 3 at the end of 3 years, and 3 at the end of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the first members to the Council under paragraphs (4), (5), and (6) of subsection (b) within 60 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-13"},"text":"October 13, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall elect one of its members as Chairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nine members of the Council shall constitute a quorum, but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Council shall not affect its power to function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council who is not otherwise employed by the United States Government shall receive compensation at a rate equal to the daily rate prescribed for GS–18 under the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for each day, including traveltime,"},{"tag":"ref","attrib":{"idref":"fn002272"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002272"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “travel time,”."}],"tail":" such member is engaged in the actual performance of duties as a member of the Council. A member of the Council who is an officer or employee of the United States Government shall serve without additional compensation. All members of the Council shall be reimbursed for travel, subsistence, and other necessary expenses incurred by them in the performance of their duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain authorities and duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e3a8d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the provisions of this section, the Council is authorized to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e3a8da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect such information, hold such hearings, and sit and act at such times and places, either as a whole or by subcommittee, and request the attendance and testimony of such witnesses and the production of such books, records, correspondence, memoranda, papers, and documents as the Council or such subcommittee may consider available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e3a8db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the cooperation and assistance of Federal departments, agencies, and instrumentalities, and such departments, agencies, and instrumentalities are authorized to provide such cooperation and assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e3a8dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall coordinate its activities with the activities of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k"},"text":"section 295k of this title","children":[],"tail":". The Secretary shall, in cooperation with the Council and pursuant to the recommendations of the Council, take such steps as are practicable to eliminate deficiencies in the data base established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k"},"text":"section 295k of this title","children":[],"tail":" and shall make available in its reports such comprehensive data sets as are developed pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", and not less than every 5 years thereafter, the Council shall submit to the Secretary, and to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives, a report on the recommendations described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e3a8de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294o/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts otherwise appropriated under this subchapter may be utilized by the Secretary to support the activities of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e3a8df-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 762, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tIII/s301"},"text":"Pub. L. 102–408, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2080"},"text":"106 Stat. 2080","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/b"},"text":"Pub. L. 102–531, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":"; renumbered § 762 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s104/b"},"text":"Pub. L. 105–392, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3552"},"text":"112 Stat. 3552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tV/s502"},"text":"Pub. L. 107–251, title V, § 502","children":[],"tail":", "},{