{"tag":"section","attrib":{"id":"idb6a4d6a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–139"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–139"},"text":"§ 300ff–139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions regarding violation of prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d6a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in any court of competent jurisdiction, commence a civil action for the purpose of obtaining temporary or permanent injunctive relief with respect to any violation of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d6a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of information on violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an administrative process for encouraging emergency response employees to provide information to the Secretary regarding violations of this part. As appropriate, the Secretary shall investigate alleged such ","children":[{"tag":"ref","attrib":{"idref":"fn002440"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002440"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" violations and seek appropriate injunctive relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit"