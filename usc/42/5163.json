{"tag":"section","attrib":{"id":"idbd120a5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5163"},"text":null,"children":[{"tag":"num","attrib":{"value":"5163"},"text":"§ 5163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of sliding scales","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No geographic area shall be precluded from receiving assistance under this chapter solely by virtue of an arithmetic formula or sliding scale based on income or population.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd120a5d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s320"},"text":"Pub. L. 93–288, title III, § 320","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/m/1"},"text":"Pub. L. 100–707, title I, § 105(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4696"},"text":"102 Stat. 4696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a5e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120a60-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
