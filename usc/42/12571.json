{"tag":"section","attrib":{"id":"idbf748acd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571"},"text":null,"children":[{"tag":"num","attrib":{"value":"12571"},"text":"§ 12571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide assistance and approved national service positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf748ace-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations for this purpose, the Corporation for National and Community Service may make grants to States, subdivisions of States, territories, Indian tribes, public or private nonprofit organizations, and institutions of higher education for the purpose of assisting the recipients of the grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748acf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out full- or part-time national service programs, including summer programs, described in subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572"},"text":"section 12572 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants in support of other national service programs described in subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12572"},"text":"section 12572 of this title","children":[],"tail":" that are carried out by other entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ad1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on agreements with Federal agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748ad2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may enter into an interagency agreement (other than a grant agreement) with another Federal agency to support a national service program carried out or otherwise supported by the agency. The Corporation, in entering into the interagency agreement may approve positions as approved national service positions for a program carried out or otherwise supported by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may not provide a grant under this section to a Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with State Commissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency carrying out or supporting a national service program shall consult with the State Commissions for those States in which projects will be conducted through that program in order to ensure that the projects do not duplicate projects conducted by State or local national service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for other national service programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency that enters into an interagency agreement under paragraph (1) shall, in an appropriate case, enter into a contract or cooperative agreement with an entity that is carrying out a national service program in a State that is in existence in the State as of the date of the contract or cooperative agreement and is of high quality, in order to support the national service program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A requirement under this chapter that applies to an entity receiving assistance under this section (other than a requirement limited to an entity receiving assistance under subsection (a)) shall be considered to apply to a Federal agency that enters into an interagency agreement under this subsection, even though no Federal agency may receive financial assistance under such an agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ad7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of approved national service positions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the provision of assistance under subsection (a), and in providing approved national service positions under subsection (b), the Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748ad8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the provision of national service educational awards described in division D for the participants who serve in national service programs carried out using such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ad9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deposit in the National Service Trust established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12601/a"},"text":"section 12601(a) of this title","children":[],"tail":" an amount equal to the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748ada-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of a national service educational award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12603"},"text":"section 12603 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748adb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of approved national service positions to be provided or otherwise approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748adc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Five percent limitation on administrative costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748add-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than 5 percent of the amount of assistance provided to the original recipient of a grant or transfer of assistance under subsection (a) for a fiscal year may be used to pay for administrative costs incurred by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748ade-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of the assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748adf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national service programs carried out or supported with the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ae0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules on use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may by rule prescribe the manner and extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748ae1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance provided under subsection (a) may be used to cover administrative costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748ae2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that portion of the assistance available to cover administrative costs should be distributed between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748ae3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original recipient of the grant or transfer of assistance under such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748ae4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national service programs carried out or supported with the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ae5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748ae6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594"},"text":"section 12594 of this title","children":[],"tail":", the Corporation share of the cost (including the costs of member living allowances, employment-related taxes, health care coverage, and workers’ compensation and other necessary operation costs) of carrying out a national service program that receives the assistance under subsection (a), whether the assistance is provided directly or as a subgrant from the original recipient of the assistance, may not exceed 75 percent of such cost."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ae7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing for the remaining share of the cost of carrying out a national service program, the program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748ae8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for such share through a payment in cash or in kind, fairly evaluated, including facilities, equipment, or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748ae9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for such share through State sources, local sources, or other Federal sources (other than the use of funds made available under the national service laws).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost of health care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing a payment in cash under paragraph (2)(A) as part of providing for the remaining share of the cost of carrying out a national service program, the program may count not more than 85 percent of the cost of providing a health care policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594/d/2"},"text":"section 12594(d)(2) of this title","children":[],"tail":" toward such share."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may waive in whole or in part the requirements of paragraph (1) with respect to a national service program in any fiscal year if the Corporation determines that such a waiver would be equitable due to a lack of available financial resources at the local level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748aed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of assistance under this section (other than a recipient of assistance through a fixed-amount grant in accordance with section 12581(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title) shall report to the Corporation the amount and source of any Federal funds used to carry out the program for which the assistance is made available other than those provided by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748aee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall report to the authorizing committees on an annual basis information regarding each recipient of such assistance that uses Federal funds other than those provided by the Corporation to carry out such a program, including the amounts and sources of the other Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748aef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for approved national service positions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748af0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a plan to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748af1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the number of the approved national service positions as 88,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748af2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase the number of the approved positions to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748af3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 115,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 140,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 170,000 for fiscal year 2013;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200,000 for fiscal year 2014;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 210,000 for fiscal year 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 235,000 for fiscal year 2016; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748af9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 250,000 for fiscal year 2017;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the increases described in subparagraph (B) are achieved through an appropriate balance of full- and part-time service positions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2009-04-21"},"text":"April 21, 2009","children":[],"tail":", submit a report to the authorizing committees on the status of the plan described in paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12571/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations and quality service opportunities, implement the plan described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf748afd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s121"},"text":"Pub. L. 101–610, title I, § 121","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1301"},"text":"Pub. L. 111–13, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1484"},"text":"123 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf748afe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf748aff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf748b00-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(5), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3127"},"text":"104 Stat. 3127","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"section 12501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf748b01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12571, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s141"},"text":"Pub. L. 101–610, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3150"},"text":"104 Stat. 3150","children":[],"tail":", related to general authority to make grants for national and community service programs, prior to the general amendment of subtitle D of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":" [formerly part D of this subchapter] by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s102/a"},"text":"Pub. L. 103–82, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s121"},"text":"section 121 of Pub. L. 101–610","children":[],"tail":" was renumbered section 199A, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655"},"text":"section 12655 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf748b02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/1/A"},"text":"Pub. L. 111–13, § 1301(1)(A)","children":[],"tail":", inserted “territories,” after “subdivisions of States,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/1/B"},"text":"Pub. L. 111–13, § 1301(1)(B)","children":[],"tail":", substituted “subsection (a), (b), or (c) of section 12572” for “section 12572(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/A"},"text":"Pub. L. 111–13, § 1301(2)(A)","children":[],"tail":", substituted “Restrictions on agreements with Federal agencies” for “Agreements with Federal agencies” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/B"},"text":"Pub. L. 111–13, § 1301(2)(B)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “The Corporation may enter into a contract or cooperative agreement with another Federal agency to support a national service program carried out by the agency. The support provided by the Corporation pursuant to the contract or cooperative agreement may include the transfer to the Federal agency of funds available to the Corporation under this division.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/C"},"text":"Pub. L. 111–13, § 1301(2)(C)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “A Federal agency receiving assistance under this subsection shall not be required to satisfy the matching funds requirements specified in subsection (e) of this section. However, the supplementation requirements specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12633"},"text":"section 12633 of this title","children":[],"tail":" shall apply with respect to the Federal national service programs supported with such assistance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/D"},"text":"Pub. L. 111–13, § 1301(2)(D)","children":[],"tail":", substituted “carrying out or supporting a national service program” for “receiving assistance under this subsection” and “through that program” for “using such assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/E"},"text":"Pub. L. 111–13, § 1301(2)(E)","children":[],"tail":", substituted “an interagency agreement” for “a contract or cooperative agreement” the first place it appeared."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/2/F"},"text":"Pub. L. 111–13, § 1301(2)(F)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/3/A"},"text":"Pub. L. 111–13, § 1301(3)(A)","children":[],"tail":", substituted “subsection (a), and in providing approved national service positions under subsection (b),” for “subsections (a) and (b) of this section,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/3/B"},"text":"Pub. L. 111–13, § 1301(3)(B)","children":[],"tail":", substituted “to be provided or otherwise approved” for “to be provided”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/4"},"text":"Pub. L. 111–13, § 1301(4)","children":[],"tail":", struck out “or (b) of this section” after “subsection (a)” in introductory provisions of par. (1) and in par. (2)(A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/5/A"},"text":"Pub. L. 111–13, § 1301(5)(A)","children":[],"tail":", substituted “Corporation share of the cost (including the costs of member living allowances, employment-related taxes, health care coverage, and workers’ compensation and other necessary operation costs)” for “Federal share of the cost”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/5/B"},"text":"Pub. L. 111–13, § 1301(5)(B)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1301/6"},"text":"Pub. L. 111–13, § 1301(6)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf748b03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf748b04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf748b05-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","childr