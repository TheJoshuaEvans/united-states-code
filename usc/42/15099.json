{"tag":"section","attrib":{"id":"idbfdfcffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099"},"text":null,"children":[{"tag":"num","attrib":{"value":"15099"},"text":"§ 15099.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfcffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a national evaluation of the program of grants to States authorized by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfcffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct the evaluation under subsection (a) to assess the status and effects of State efforts to develop and implement, or expand and enhance, statewide systems of family support services for families of children with disabilities in a manner consistent with the provisions of this subchapter. In particular, the Secretary shall assess the impact of such efforts on families of children with disabilities, and recommend amendments to this subchapter that are necessary to assist States to accomplish fully the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfcfff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall work with the States to develop an information system designed to compile and report, from information provided by the States, qualitative and quantitative descriptions of the impact of the program of grants to States authorized by this subchapter on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" families of children with disabilities, including families from unserved and underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to and funding for family support services for families of children with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interagency coordination and collaboration between agencies responsible for providing the services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the involvement of families of children with disabilities at all levels of the statewide systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15099/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2½ years after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", the Secretary shall prepare and submit to the appropriate committees of Congress a report concerning the results of the evaluation conducted under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd005-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s210"},"text":"Pub. L. 106–402, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1733"},"text":"114 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
