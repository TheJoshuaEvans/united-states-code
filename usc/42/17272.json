{"tag":"section","attrib":{"id":"idc033472a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272"},"text":null,"children":[{"tag":"num","attrib":{"value":"17272"},"text":"§ 17272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of carbon sequestration and methane and nitrous oxide emissions from ecosystems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc033472b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033472c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adaptation strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adaptation strategy” means a land use and management strategy that can be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033472d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the sequestration capabilities of covered greenhouse gases of any ecosystem; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033472e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the emissions of covered greenhouse gases from any ecosystem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033472f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assessment” means the national assessment authorized under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered greenhouse gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered greenhouse gas” means carbon dioxide, nitrous oxide, and methane gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ecosystem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ecosystem” means any terrestrial, freshwater aquatic, or coastal ecosystem, including an estuary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native plant species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “native plant species” means any noninvasive, naturally occurring plant species within an ecosystem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which the final methodology is published under subsection (f)(3)(D), the Secretary shall complete a national assessment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of carbon stored in and released from ecosystems, including from man-caused and natural fires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual flux of covered greenhouse gases in and out of ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the assessment under subsection (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the processes that control the flux of covered greenhouse gases in and out of each ecosystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the potential for increasing carbon sequestration in natural and managed ecosystems through management activities or restoration activities in each ecosystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033473a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop near-term and long-term adaptation strategies or mitigation strategies that can be employed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033473b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the sequestration of carbon in each ecosystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033473c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce emissions of covered greenhouse gases from ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033473d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adapt to climate change; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033473e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the annual carbon sequestration capacity of ecosystems under a range of policies in support of management activities to optimize sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033473f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of native plant species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing restoration activities under subsection (c)(2) and management strategies and adaptation strategies under subsection (c)(3), the Secretary shall emphasize the use of native plant species (including mixtures of many native plant species) for sequestering covered greenhouse gas in each ecosystem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the assessment under subsection (b) and developing the methodology under subsection (f), the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334745-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, acting through the Under Secretary for Oceans and Atmosphere; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334746-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of other relevant agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334747-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean and coastal ecosystems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section with respect to ocean and coastal ecosystems (including estuaries), the Secretary shall work jointly with the Secretary of Commerce, acting through the Under Secretary for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334748-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0334749-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall develop a methodology for conducting the assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033474a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The methodology developed under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc033474b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc033474c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the method for measuring, monitoring, and quantifying covered greenhouse gas emissions and reductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc033474d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the total capacity of each ecosystem to sequester carbon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc033474e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the ability of each ecosystem to reduce emissions of covered greenhouse gases through management practices; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc033474f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may employ economic and other systems models, analyses, and estimates, to be developed in consultation with each of the individuals described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0334750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External review and publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of a proposed methodology, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0334751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the proposed methodology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least 60 days before the date on which the final methodology is published, solicit comments from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0334753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heads of affected Federal and State agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a panel to review the proposed methodology published under subparagraph (A) and any comments received under subparagraph (B), to be composed of members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0334756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with expertise in the matters described in subsections (c) and (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0334757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are, as appropriate, representatives of Federal agencies, institutions of higher education, nongovernmental organizations, State organizations, industry, and international organizations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0334758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on completion of the review under subparagraph (C), publish in the Federal Register the revised final methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0334759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate; review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc033475a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the assessment, prescribe the data, information, and analysis needed to establish a scientifically sound estimate of the carbon sequestration capacity of relevant ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc033475b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date on which the assessment is completed, submit to the heads of applicable Federal agencies and the appropriate committees of Congress a report that describes the results of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033475c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data and report availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the assessment, the Secretary shall incorporate the results of the assessment into a web-accessible database for public use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc033475d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17272/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for the period of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc033475e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVII/s712"},"text":"Pub. L. 110–140, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1713"},"text":"121 Stat. 1713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc033475f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0334760-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0334761-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
