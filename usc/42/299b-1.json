{"tag":"section","attrib":{"id":"idb6005848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–1"},"text":"§ 299b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private-public partnerships to improve organization and delivery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6005849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for efforts to develop information on quality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb600584a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and technical support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In its role as the principal agency for health care research and quality, the Agency may provide scientific and technical support for private and public efforts to improve health care quality, including the activities of accrediting organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb600584b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of the Agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to paragraph (1), the role of the Agency shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb600584c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification and assessment of methods for the evaluation of the health of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb600584d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees in health plans by type of plan, provider, and provider arrangements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb600584e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other populations, including those receiving long-term care services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb600584f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ongoing development, testing, and dissemination of quality measures, including measures of health and functional outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compilation and dissemination of health care quality measures developed in the private and public sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development of improved health care information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of survey tools for the purpose of measuring participant and beneficiary assessments of their health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and disseminating information on mechanisms for the integration of information on quality into purchaser and consumer decision-making processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6005854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers for education and research on therapeutics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6005855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director and in consultation with the Commissioner of Food and Drugs, shall establish a program for the purpose of making one or more grants for the establishment and operation of one or more centers to carry out the activities specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities referred to in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6005857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The conduct of state-of-the-art research for the following purposes:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6005858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To increase awareness of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6005859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new uses of drugs, biological products, and devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb600585a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to improve the effective use of drugs, biological products, and devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb600585b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risks of new uses and risks of combinations of drugs and biological products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb600585c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide objective clinical information to the following individuals and entities:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb600585d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care practitioners and other providers of health care goods or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb600585e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pharmacists, pharmacy benefit managers and purchasers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb600585f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health maintenance organizations and other managed health care organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6005860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care insurers and governmental agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6005861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patients and consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6005862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To improve the quality of health care while reducing the cost of health care through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6005863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the appropriate use of drugs, biological products, or devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6005864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of adverse effects of drugs, biological products, and devices and the consequences of such effects, such as unnecessary hospitalizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct of research on the comparative effectiveness, cost-effectiveness, and safety of drugs, biological products, and devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6005866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other activities as the Secretary determines to be appropriate, except that a grant may not be expended to assist the Secretary in the review of new drugs, biological products, and devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6005867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reducing errors in medicine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, in accordance with part C, conduct and support research and build private-public partnerships to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6005868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the causes of preventable health care errors and patient injury in health care delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6005869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, demonstrate, and evaluate strategies for reducing errors and improving patient safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb600586a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such effective strategies throughout the health care industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb600586b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 912, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1656"},"text":"113 Stat. 1656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/41/s2/a/1"},"text":"Pub. L. 109–41, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-07-29"},"text":"July 29, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/424"},"text":"119 Stat. 424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb600586c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb600586d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb600586e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299b–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s912"},"text":"act July 1, 1944, ch. 373, title IX, § 912","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/a"},"text":"Pub. L. 101–239, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2192"},"text":"103 Stat. 2192","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/410"},"text":"Pub. L. 102–410","children":[],"tail":", §§ 5(a)(1), (c)(1), 6(b), "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2096"},"text":"106 Stat. 2096","children":[],"tail":", 2097, 2100, related to the duties of the Office of the Forum for Quality and Effectiveness in Health Care, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb600586f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/41"},"text":"Pub. L. 109–41","children":[],"tail":" inserted “, in accordance with part C,” after “The Director shall” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
