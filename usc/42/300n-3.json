{"tag":"section","attrib":{"id":"idb6515f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"300n–3"},"text":"§ 300n–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and provision of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6515f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide training and technical assistance with respect to the planning, development, and operation of any program or service carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":". The Secretary may provide such technical assistance directly or through grants to, or contracts with, public and private entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of supplies and services in lieu of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of a State receiving a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":", the Secretary may, subject to paragraph (2), provide supplies, equipment, and services for the purpose of aiding the State in carrying out such section and, for such purpose, may detail to the State any officer or employee of the Department of Health and Human Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corresponding reduction in payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a request described in paragraph (1), the Secretary shall reduce the amount of payments under the grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":" to the State involved by an amount equal to the costs of detailing personnel (including pay, allowances, and travel expenses) and the fair market value of any supplies, equipment, or services provided by the Secretary. The Secretary shall, for the payment of expenses incurred in complying with such request, expend the amounts withheld."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6515f1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XV, § 1507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/354/s2"},"text":"Pub. L. 101–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-10"},"text":"Aug. 10, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/414"},"text":"104 Stat. 414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6515f1d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6515f1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6515f1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300n–3, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXV/s1534"},"text":"act July 1, 1944, ch. 373, title XV, § 1534","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s3"},"text":"Pub. L. 93–641, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2255"},"text":"88 Stat. 2255","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tI/s102/d"},"text":"Pub. L. 95–83, title I, § 102(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/383"},"text":"91 Stat. 383","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tI"},"text":"Pub. L. 96–79, title I","children":[],"tail":", §§ 125, 127(d), "},{"tag":"ref","attrib":{"href":"/us/stat/93/628"},"text":"93 Stat. 628","children":[],"tail":", 629; "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s933/a/3"},"text":"Pub. L. 97–35, t