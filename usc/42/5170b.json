{"tag":"section","attrib":{"id":"idbd147b57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5170b"},"text":"§ 5170b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd147b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal agencies may on the direction of the President, provide assistance essential to meeting immediate threats to life and property resulting from a major disaster, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd147b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal resources, generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Utilizing, lending, or donating to State and local governments Federal equipment, supplies, facilities, personnel, and other resources, other than the extension of credit, for use or distribution by such governments in accordance with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicine, food, and other consumables","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Distributing or rendering through State and local governments, the American National Red Cross, the Salvation Army, the Mennonite Disaster Service, and other relief and disaster assistance organizations medicine durable medical equipment,,","children":[{"tag":"ref","attrib":{"idref":"fn003403"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003403"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The extra comma probably should follow “medicine”."}],"tail":" food, and other consumable supplies, and other services and assistance to disaster victims."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work and services to save lives and protect property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Performing on public or private lands or waters any work or services essential to saving lives and protecting and preserving property or public health and safety, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debris removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" search and rescue, emergency medical care, emergency mass care, emergency shelter, and provision of food, water, medicine durable medical equipment,,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and other essential needs, including movement of supplies or persons;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearance of roads and construction of temporary bridges necessary to the performance of emergency tasks and essential community services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of temporary facilities for schools and other essential community services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demolition of unsafe structures which endanger the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warning of further risks and hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of public information and assistance regarding health and safety measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of technical advice to State and local governments on disaster management and control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction of immediate threats to life, property, and public health and safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provision of rescue, care, shelter, and essential needs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd147b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to individuals with household pets and service animals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd147b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to such pets and animals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Making contributions to State or local governments or owners or operators of private nonprofit facilities for the purpose of carrying out the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd147b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of assistance under this section shall be not less than 75 percent of the eligible cost of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd147b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of DOD resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd147b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the immediate aftermath of an incident which may ultimately qualify for assistance under this subchapter or subchapter IV-A of this chapter, the Governor of the State in which such incident occurred may request the President to direct the Secretary of Defense to utilize the resources of the Department of Defense for the purpose of performing on public and private lands any emergency work which is made necessary by such incident and which is essential for the preservation of life and property. If the President determines that such work is essential for the preservation of life and property, the President shall grant such request to the extent the President determines practicable. Such emergency work may only be carried out for a period not to exceed 10 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules applicable to debris removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any removal of debris and wreckage carried out under this subsection shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5173/b"},"text":"section 5173(b) of this title","children":[],"tail":", relating to unconditional authorization and indemnification for debris removal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures out of disaster relief funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost of any assistance provided pursuant to this subsection shall be reimbursed out of funds made available to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of assistance under this subsection shall be not less than 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"November 23, 1988","children":[],"tail":", the President shall issue guidelines for carrying out this subsection. Such guidelines shall consider any likely effect assistance under this subsection will have on the availability of other forms of assistance under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department of Defense” has the meaning the term “department” has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency work","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency work” includes clearance and removal of debris and wreckage and temporary restoration of essential public facilities and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd147b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries and benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd147b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President declares a major disaster or emergency for an area within the jurisdiction of a State, tribal, or local government, the President may reimburse the State, tribal, or local government for costs relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" basic pay and benefits for permanent employees of the State, tribal, or local government conducting emergency protective measures under this section, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd147b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work is not typically performed by the employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd147b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of work may otherwise be carried out by contract or agreement with private organizations, firms, or individuals.; ","children":[{"tag":"ref","attrib":{"idref":"fn003404"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003404"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overtime and hazardous duty compensation for permanent employees of the State, tribal, or local government conducting emergency protective measures under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overtime","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines for reimbursement for costs under paragraph (1) shall ensure that no State, tribal, or local government is denied reimbursement for overtime payments that are required pursuant to the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on mutual aid pacts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the ability of the President to reimburse labor force expenses provided pursuant to an authorized mutual aid pact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd147b7b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s403"},"text":"Pub. L. 93–288, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/a/3"},"text":"Pub. L. 100–707, title I, § 106(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4697"},"text":"102 Stat. 4697","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689/b"},"text":"Pub. L. 109–295, title VI, § 689(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1449"},"text":"120 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/308/s4"},"text":"Pub. L. 109–308, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1726"},"text":"120 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1108/b"},"text":"Pub. L. 113–2, div. B, § 1108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/47"},"text":"127 Stat. 47","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1217/d"},"text":"Pub. L. 115–254, div. D, § 1217(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3452"},"text":"132 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd147b7c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd147b7d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd147b7e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c)(1), (3), (5), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd147b7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s403"},"text":"section 403 of Pub. L. 93–288","children":[],"tail":" was renumbered section 407 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5173"},"text":"section 5173 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd147b80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" struck out subpar. (J) added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/308"},"text":"Pub. L. 109–308","children":[],"tail":", which was identical to subpar. (J) added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/2"},"text":"Pub. L. 113–2","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2), (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s689/b/1"},"text":"Pub. L. 109–295, § 689(b)(1)","children":[],"tail":", (2)(A), inserted “durable medical equipment,” after “medicine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s689/b/2/B"},"text":"Pub. L. 109–295, § 689(b)(2)(B)","children":[],"tail":"–(D), and "},{"tag":"ref","attrib":{"href":"/us/pl/109/308"},"text":"Pub. L. 109–308","children":[],"tail":" amended par. (3) by adding identical subpars. (J)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd147b81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd147b82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd16c473-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd16c474-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Maximizing Assistance From the Federal Emergency Management Agency To Respond to COVID–19","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2022-03-01"},"text":"Mar. 1, 2022","children":[],"tail":", 87 F.R. 12391, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of Homeland Security [and] the Administrator of the Federal Emergency Management Agency","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including the Robert T. Stafford Disaster Relief and Emergency Assistance Act, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121–520"},"text":"42 U.S.C. 5121–520","children":[],"tail":"7 (the “Stafford Act”), I hereby order as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Policy","children":[],"tail":". It is the policy of my Administration to combat and respond to the coronavirus disease 2019 (COVID–19) pandemic with the full capacity and capability of the Federal Government to protect and support our families, schools, and businesses, and to assist State, local, Tribal, and territorial governments to do the same, including through emergency and disaster assistance available from the Federal Emergency Management Agency (FEMA) and through Federal support of the Governors’ use of the National Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. "},{"tag":"i","attrib":{},"text":"Assistance for Category B COVID–19 Emergency Protective Measures","children":[],"tail":". FEMA shall provide a 100 percent Federal cost share for all work eligible for assistance under Public Assistance Category B, pursuant to sections 403 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170b"},"text":"42 U.S.C. 5170b","children":[],"tail":"), 502 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5192"},"text":"42 U.S.C. 5192","children":[],"tail":"), and 503 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5193"},"text":"42 U.S.C. 5193","children":[],"tail":") of the Stafford Act, including work described in section 3(a) of the Presidential Memorandum of "},{"tag":"date","attrib":{"date":"2021-01-21"},"text":"January 21, 2021","children":[],"tail":" (Memorandum to Extend Federal Support to Governors’ Use of the National Guard to Respond to COVID–19 and to Increase Reimbursement and Other Assistance Provided to States) ["},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502"},"text":"32 U.S.C. 502","children":[],"tail":" note], and in section 2 of that memorandum on the Governors’ use of the National Guard, performed from "},{"tag":"date","attrib":{"date":"2020-01-20"},"text":"January 20, 2020","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2022-07-01"},"text":"July 1, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. "},{"tag":"i","attrib":{},"text":"General Provisions","children":[],"tail":". (a) Nothing in this memorandum shall be construed to impair or otherwise affect:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) the authority granted by law to an executive department or agency, or the head thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) the functions of the Director of the Office of Management and Budget relating to budgetary, administrative, or legislative proposals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) This memorandum shall be implemented consistent with applicable law and subject to the availability of appropriations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) This memorandum is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, or entities, its officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) The Administrator of FEMA is authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior provisions related to maximizing assistance from the Federal Emergency Management Agency to respond to COVID–19 were contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", 87 F.R. 27."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2021-11-09"},"text":"Nov. 9, 2021","children":[],"tail":", 86 F.R. 64055."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2021-08-17"},"text":"Aug. 17, 2021","children":[],"tail":", 86 F.R. 46759."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2021-02-02"},"text":"Feb. 2, 2021","children":[],"tail":", 86 F.R. 8281."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
