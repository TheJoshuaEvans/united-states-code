{"tag":"section","attrib":{"id":"idb656404e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300s–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"300s–5"},"text":"§ 300s–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of technical and other non­financial assistance to eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide (either through the Department of Health and Human Services or by contract) all necessary technical and other nonfinancial assistance to any public or other entity which is eligible to apply for assistance under this subchapter to assist such entity in developing applications to be submitted to the Secretary under section 300s–1 or 300t–12 of this title. The Secretary shall make every effort to inform eligible applicants of the availability of assistance under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb656404f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XVI, § 1626, formerly § 1635, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/641/s4"},"text":"Pub. L. 93–641, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2273"},"text":"88 Stat. 2273","children":[],"tail":"; renumbered § 1626 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/79/tII"},"text":"Pub. L. 96–79, title II","children":[],"tail":", §§ 202(b), 203(f), "},{"tag":"date","attrib":{"date":"1979-10-04"},"text":"Oct. 4, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/632"},"text":"93 Stat. 632","children":[],"tail":", 635; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–