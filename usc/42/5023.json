{"tag":"section","attrib":{"id":"idbcf09eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5023"},"text":null,"children":[{"tag":"num","attrib":{"value":"5023"},"text":"§ 5023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority population participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall take appropriate steps to insure that special efforts are made to recruit, select, and assign qualified individuals age 55 years or older from minority populations to serve as volunteers under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcf09f00-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s223"},"text":"Pub. L. 93–113, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/404"},"text":"87 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2146/b"},"text":"Pub. L. 111–13, title II, § 2146(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1589"},"text":"123 Stat. 1589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf09f01-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf09f02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf09f03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" substituted “population” for “group” in section catchline and “age 55 years or older from minority populations” for “sixty years and older from minority groups” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf09f04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf09f05-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
