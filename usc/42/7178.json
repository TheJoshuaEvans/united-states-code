{"tag":"section","attrib":{"id":"idbdf95ce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178"},"text":null,"children":[{"tag":"num","attrib":{"value":"7178"},"text":"§ 7178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Energy Regulatory Commission fees and annual charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf95ce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf95ce4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) and beginning in fiscal year 1987 and in each fiscal year thereafter, the Federal Energy Regulatory Commission shall, using the provisions of this section and authority provided by other laws, assess and collect fees and annual charges in any fiscal year in amounts equal to all of the costs incurred by the Commission in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf95ce5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall not affect the authority, requirements, exceptions, or limitations in sections 803(e) and 823a(e) of title 16.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ce6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees or annual charges assessed shall be computed on the basis of methods that the Commission determines, by rule, to be fair and equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ce7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may assess fees and charges under this section by making estimates based on data available to the Commission at the time of assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ce8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall provide that the fees and charges assessed under this section shall be paid by the end of the fiscal year for which they were assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ce9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, after the completion of a fiscal year, make such adjustments in the assessments for such fiscal year as may be necessary to eliminate any overrecovery or underrecovery of its total costs, and any overcharging or undercharging of any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95cea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All moneys received under this section shall be credited to the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ceb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7178/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may waive all or part of any fee or annual charge assessed under this section for good cause shown.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf95cec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3401"},"text":"Pub. L. 99–509, title III, § 3401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1890"},"text":"100 Stat. 1890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf95ced-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf95cee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf95cef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Budget Reconciliation Act of 1986, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
