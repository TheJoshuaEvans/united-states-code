{"tag":"section","attrib":{"id":"idbce24730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4831"},"text":null,"children":[{"tag":"num","attrib":{"value":"4831"},"text":"§ 4831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of lead-based paint","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce24731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition by Secretary of Health and Human Services in application to cooking, drinking, or eating utensils","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall take such steps and impose such conditions as may be necessary or appropriate to prohibit the application of lead-based paint to any cooking utensil, drinking utensil, or eating utensil manufactured and distributed after ","children":[{"tag":"date","attrib":{"date":"1971-01-13"},"text":"January 13, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce24732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition by Secretary of Housing and Urban Development of use in residential structures constructed or rehabilitated by Federal Government or with Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall take steps and impose such conditions as may be necessary or appropriate to prohibit the use of lead-based paint in residential structures constructed or rehabilitated by the Federal Government, or with Federal assistance in any form after ","children":[{"tag":"date","attrib":{"date":"1971-01-13"},"text":"January 13, 1971","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce24733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition by Consumer Product Safety Commission in application to toys or furniture articles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Consumer Product Safety Commission shall take such steps and impose such conditions as may be necessary or appropriate to prohibit the application of lead-based paint to any toy or furniture article.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce24734-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/695/tIV/s401"},"text":"Pub. L. 91–695, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-13"},"text":"Jan. 13, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2079"},"text":"84 Stat. 2079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/151/s5"},"text":"Pub. L. 93–151, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-09"},"text":"Nov. 9, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/566"},"text":"87 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/317/tII/s204/b"},"text":"Pub. L. 94–317, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-23"},"text":"June 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/705"},"text":"90 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce24735-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce24736-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbce24737-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1971-01-13"},"text":"January 13, 1971","children":[],"tail":", referred to in subsecs. (a) and (b), was in the original “the date of enactment of this Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbce24738-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/317"},"text":"Pub. L. 94–317","children":[],"tail":" amended section generally, designating existing provisions as subsec. (a), striking out requirement of consultation with Secretary of Housing and Urban Development and provisions relating to prohibition of use of lead based paint in residential structures constructed or rehabilitated by Federal Government or with Federal assistance, and adding subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/151"},"text":"Pub. L. 93–151","children":[],"tail":" amended section generally, providing for consultation of the Secretaries, incorporating existing provisions as cl. (1), and adding cl. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbce24739-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbce2473a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (a) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
