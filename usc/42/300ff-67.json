{"tag":"section","attrib":{"id":"idb6a01b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–67"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–67"},"text":"§ 300ff–67.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Counseling programs carried out under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–67/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be designed to promote or encourage, directly, intravenous drug abuse or sexual activity, homosexual or heterosexual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–67/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be designed to reduce exposure to and transmission of HIV/AIDS by providing accurate information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–67/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide information on the health risks of promiscuous sexual activity and intravenous drug abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01b09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–67/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide information on the transmission and prevention of hepatitis A, B, and C, including educa