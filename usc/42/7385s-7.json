{"tag":"section","attrib":{"id":"idbe0eb9ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–7"},"text":"§ 7385s–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physicians services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0eb9ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may utilize the services of physicians for purposes of making determinations under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physicians","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any physicians whose services are utilized under subsection (a) of this section shall possess appropriate expertise and experience in the evaluation and determination of the extent of permanent physical impairments or in the evaluation and diagnosis of illnesses or deaths aggravated, contributed to, or caused by exposure to toxic substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may secure the services of physicians utilized under subsection (a) of this section through the appointment of physicians or by contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0eb9b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3678"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3678]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2182"},"text":"118 Stat. 2182","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
