{"tag":"section","attrib":{"id":"idb993dfa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395cc–3"},"text":"§ 1395cc–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care quality demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb993dfa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993dfaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beneficiary” means an individual who is entitled to benefits under part A and enrolled under part B, including any individual who is enrolled in a Medicare Advantage plan under part C.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care group","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb993dfac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health care group” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb993dfad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of physicians that is organized at least in part for the purpose of providing physician’s services under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb993dfae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an integrated health care delivery system that delivers care through coordinated hospitals, clinics, home health agencies, ambulatory surgery centers, skilled nursing facilities, rehabilitation facilities and clinics, and employed, independent, or contracted physicians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb993dfaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization representing regional coalitions of groups or systems described in clause (i) or (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As the Secretary determines appropriate, a health care group may include a hospital or any other individual or entity furnishing items or services for which payment may be made under this subchapter that is affiliated with the health care group under an arrangement structured so that such hospital, individual, or entity participates in a demonstration project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided for by the Secretary, the term “physician” means any individual who furnishes services that may be paid for as physicians’ services under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a demonstration program under which the Secretary shall approve demonstration projects that examine health delivery factors that encourage the delivery of improved quality in patient care, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993dfb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of incentives to improve the safety of care provided to beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate use of best practice guidelines by providers and services by beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced scientific uncertainty in the delivery of care through the examination of variations in the utilization and allocation of services, and outcomes measurement and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage shared decision making between providers and patients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of incentives for improving the quality and safety of care and achieving the efficient allocation of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate use of culturally and ethnically sensitive health care delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial effects on the health care marketplace of altering the incentives for care delivery and changing the allocation of resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993dfbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the Secretary may administer the demonstration program established under this section in a manner that is similar to the manner in which the demonstration program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc–1"},"text":"section 1395cc–1 of this title","children":[],"tail":" is administered in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc–2"},"text":"section 1395cc–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative payment systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health care group that receives assistance under this section may, with respect to the demonstration project to be carried out with such assistance, include proposals for the use of alternative payment systems for items and services provided to beneficiaries by the group that are designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb993dfbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the delivery of high quality care while accomplishing the objectives described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" streamline documentation and reporting requirements otherwise required under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A health care group that receives assistance under this section may, with respect to the demonstration project to be carried out with such assistance, include modifications to the package of benefits available under the original medicare fee-for-service program under parts A and B or the package of benefits available through a Medicare Advantage plan under part C. The criteria employed under the demonstration program under this section to evaluate outcomes and determine best practice guidelines and incentives shall not be used as a basis for the denial of medicare benefits under the demonstration program to patients against their wishes (or if the patient is incompetent, against the wishes of the patient’s surrogate) on the basis of the patient’s age or expected length of life or of the patient’s present or predicted disability, degree of medical dependency, or quality of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive assistance under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993dfc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a health care group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" meet quality standards established by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb993dfc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of continuous quality improvement mechanisms that are aimed at integrating community-based support services, primary care, and referral care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of activities to increase the delivery of effective care to beneficiaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging patient participation in preference-based decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of activities to encourage the coordination and integration of medical service delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb993dfc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of activities to measure and document the financial impact on the health care marketplace of altering the incentives of health care delivery and changing the allocation of resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such other requirements as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive such requirements of this subchapter and subchapter XI as may be necessary to carry out the purposes of the demonstration program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget neutrality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the period of the demonstration program under subsection (b), the aggregate expenditures under this subchapter for such period shall not exceed the aggregate expenditures that would have been expended under this subchapter if the program established under this section had not been implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual that receives health care items or services under a demonstration program carried out under this section, the Secretary shall ensure that such individual is notified of any waivers of coverage or payment rules that are applicable to such individual under this subchapter as a result of the participation of the individual in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb993dfcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation and support by Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the demonstration program under this section, the Secretary may direct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb993dfcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institutes of Health to expand the efforts of the Institutes to evaluate current medical technologies and improve the foundation for evidence-based practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Agency for Healthcare Research and Quality to, where possible and appropriate, use the program under this section as a laboratory for the study of quality improvement strategies and to evaluate, monitor, and disseminate information relevant to such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb993dfcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395cc–3/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Centers for Medicare & Medicaid Services and the Administrator of the Center for Medicare Choices to support linkages of relevant medicare data to registry information from participating health care groups for the beneficiary populations served by the participating groups, for analysis supporting the purposes of the demonstration program, consistent with the applicable provisions of the Health Insurance Portability and Accountability Act of 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb993dfd0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1866C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tVI/s646"},"text":"Pub. L. 108–173, title VI, § 646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2324"},"text":"117 Stat. 2324","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3021/c"},"text":"Pub. L. 111–148, title III, § 3021(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/395"},"text":"124 Stat. 395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb993dfd1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb993dfd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb993dfd3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (h)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s1/a"},"text":"section 1(a) of Pub. L. 104–191","children":[],"tail":", set out as a Short Title of 1996 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb993dfd4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out “5-year” before “demonstration program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" struck out “5-year” before “period of the demonstration program”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
