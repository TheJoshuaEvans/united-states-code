{"tag":"section","attrib":{"id":"idc0465a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022"},"text":null,"children":[{"tag":"num","attrib":{"value":"18022"},"text":"§ 18022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential health benefits requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0465a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential health benefits package","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title,","children":[{"tag":"ref","attrib":{"idref":"fn004301"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004301"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the term “essential health benefits package” means, with respect to any health plan, coverage that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the essential health benefits defined by the Secretary under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits cost-sharing for such coverage in accordance with subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (e), provides either the bronze, silver, gold, or platinum level of coverage described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential health benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary shall define the essential health benefits, except that such benefits shall include at least the following general categories and the items and services covered within the categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ambulatory patient services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospitalization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maternity and newborn care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental health and substance use disorder services, including behavioral health treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prescription drugs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rehabilitative and habilitative services and devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laboratory services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventive and wellness services and chronic disease management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pediatric services, including oral and vision care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the scope of the essential health benefits under paragraph (1) is equal to the scope of benefits provided under a typical employer plan, as determined by the Secretary. To inform this determination, the Secretary of Labor shall conduct a survey of employer-sponsored coverage to determine the benefits typically covered by employers, including multiemployer plans, and provide a report on such survey to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In defining the essential health benefits described in paragraph (1), and in revising the benefits under paragraph (4)(H), the Secretary shall submit a report to the appropriate committees of Congress containing a certification from the Chief Actuary of the Centers for Medicare & Medicaid Services that such essential health benefits meet the limitation described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In defining the essential health benefits described in paragraph (1), and in revising the benefits under paragraph (4)(H), the Secretary shall provide notice and an opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In defining the essential health benefits under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such essential health benefits reflect an appropriate balance among the categories described in such subsection,","children":[{"tag":"ref","attrib":{"idref":"fn004302"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004302"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “paragraph,”."}],"tail":" so that benefits are not unduly weighted toward any category;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not make coverage decisions, determine reimbursement rates, establish incentive programs, or design benefits in ways that discriminate against individuals because of their age, disability, or expected length of life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the health care needs of diverse segments of the population, including women, children, persons with disabilities, and other groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that health benefits established as essential not be subject to denial to individuals against their wishes on the basis of the individuals’ age or expected length of life or of the individuals’ present or predicted disability, degree of medical dependency, or quality of life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that a qualified health plan shall not be treated as providing coverage for the essential health benefits described in paragraph (1) unless the plan provides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coverage for emergency department services will be provided without imposing any requirement under the plan for prior authorization of services or any limitation on coverage where the provider of services does not have a contractual relationship with the plan for the providing of services that is more restrictive than the requirements or limitations that apply to emergency department services received from providers who do have such a contractual relationship with the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such services are provided out-of-network, the cost-sharing requirement (expressed as a copayment amount or coinsurance rate) is the same requirement that would apply if such services were provided in-network;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that if a plan described in section 18031(b)(2)(B)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn004303"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004303"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “18031(d)(2)(B)(ii)”."}],"tail":" of this title (relating to stand-alone dental benefits plans) is offered through an Exchange, another health plan offered through such Exchange shall not fail to be treated as a qualified health plan solely because the plan does not offer coverage of benefits offered through the stand-alone plan that are otherwise required under paragraph (1)(J); and "},{"tag":"ref","attrib":{"idref":"fn004304"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004304"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically review the essential health benefits under paragraph (1), and provide a report to Congress and the public that contains—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether enrollees are facing any difficulty accessing needed services for reasons of coverage or cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether the essential health benefits needs to be modified or updated to account for changes in medical evidence or scientific advancement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on how the essential health benefits will be modified to address any such gaps in access or changes in the evidence base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the potential of additional or expanded benefits to increase costs and the interactions between the addition or expansion of benefits and reductions in existing benefits to meet actuarial limitations described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically update the essential health benefits under paragraph (1) to address any gaps in access to coverage or changes in the evidence base the Secretary identifies in the review conducted under subparagraph (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be construed to prohibit a health plan from providing benefits in excess of the essential health benefits described in this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to cost-sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual limitation on cost-sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2014","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost-sharing incurred under a health plan with respect to self-only coverage or coverage other than self-only coverage for a plan year beginning in 2014 shall not exceed the dollar amounts in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s223/c/2/A/ii"},"text":"section 223(c)(2)(A)(ii) of title 26","children":[],"tail":" for self-only and family coverage, respectively, for taxable years beginning in 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2015 and later","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any plan year beginning in a calendar year after 2014, the limitation under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of self-only coverage, be equal to the dollar amount under subparagraph (A) for self-only coverage for plan years beginning in 2014, increased by an amount equal to the product of that amount and the premium adjustment percentage under paragraph (4) for the calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of other coverage, twice the amount in effect under clause (i).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the amount of any increase under clause (i) is not a multiple of $50, such increase shall be rounded to the next lowest multiple of $50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/93/tII/s213/a/1"},"text":"Pub. L. 113–93, title II, § 213(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-01"},"text":"Apr. 1, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1047"},"text":"128 Stat. 1047","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this title— ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cost-sharing” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deductibles, coinsurance, copayments, or similar charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other expenditure required of an insured individual which is a qualified medical expense (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s223/d/2"},"text":"section 223(d)(2) of title 26","children":[],"tail":") with respect to essential health benefits covered under the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term does not include premiums, balance billing amounts for non-network providers, or spending for non-covered services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium adjustment percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1)(B)(i), the premium adjustment percentage for any calendar year is the percentage (if any) by which the average per capita premium for health insurance coverage in the United States for the preceding calendar year (as estimated by the Secretary no later than October 1 of such preceding calendar year) exceeds such average per capita premium for 2013 (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levels of coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levels of coverage defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The levels of coverage described in this subsection are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bronze level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan in the bronze level shall provide a level of coverage that is designed to provide benefits that are actuarially equivalent to 60 percent of the full actuarial value of the benefits provided under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Silver level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan in the silver level shall provide a level of coverage that is designed to provide benefits that are actuarially equivalent to 70 percent of the full actuarial value of the benefits provided under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gold level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan in the gold level shall provide a level of coverage that is designed to provide benefits that are actuarially equivalent to 80 percent of the full actuarial value of the benefits provided under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Platinum level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan in the platinum level shall provide a level of coverage that is designed to provide benefits that are actuarially equivalent to 90 percent of the full actuarial value of the benefits provided under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actuarial value","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under regulations issued by the Secretary, the level of coverage of a plan shall be determined on the basis that the essential health benefits described in subsection (b) shall be provided to a standard population (and without regard to the population the plan may actually provide benefits to).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations under which employer contributions to a health savings account (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s223"},"text":"section 223 of title 26","children":[],"tail":") may be taken into account in determining the level of coverage for a plan of the employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining under this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], or title 26 the percentage of the total allowed costs of benefits provided under a group health plan or health insurance coverage that are provided by such plan or coverage, the rules contained in the regulations under this paragraph shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable variance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop guidelines to provide for a de minimis variation in the actuarial valuations used in determining the level of coverage of a plan to account for differences in actuarial estimates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" any reference to a bronze, silver, gold, or platinum plan shall be treated as a reference to a qualified health plan providing a bronze, silver, gold, or platinum level of coverage, as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catastrophic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0465a64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health plan not providing a bronze, silver, gold, or platinum level of coverage shall be treated as meeting the requirements of subsection (d) with respect to any plan year if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only individuals who are eligible to enroll in the plan are individuals described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plan provides—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii), the essential health benefits determined under subsection (b), except that the plan provides no benefits for any plan year until the individual has incurred cost-sharing expenses in an amount equal to the annual limitation in effect under subsection (c)(1) for the plan year (except as provided for in section 2713); ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coverage for at least three primary care visits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals eligible for enrollment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is described in this paragraph for any plan year if the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0465a6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained the age of 30 before the beginning of the plan year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0465a6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a certification in effect for any plan year under this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" that the individual is exempt from the requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000A"},"text":"section 5000A of title 26","children":[],"tail":" by reason of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc0465a6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5000A(e)(1) of such title (relating to individuals without affordable coverage); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0465a6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5000A(e)(5) of such title (relating to individuals with hardships).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0465a6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction to individual market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a health insurance issuer offers a health plan described in this subsection, the issuer may only offer the plan in the individual market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child-only plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a qualified health plan is offered through the Exchange in any level of coverage specified under subsection (d), the issuer shall also offer that plan through the Exchange in that level as a plan in which the only enrollees are individuals who, as of the beginning of a plan year, have not attained the age of 21, and such plan shall be treated as a qualified health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0465a70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18022/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to Federally-qualified health centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any item or service covered by a qualified health plan is provided by a Federally-qualified health center (as defined in section 1396d(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of this title) to an enrollee of the plan, the offeror of the plan shall pay to the center for the item or service an amount that is not less than the amount of payment that would have been paid to the center under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a/bb"},"text":"section 1396a(bb) of this title","children":[],"tail":") for such item or service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0465a71-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1302"},"text":"Pub. L. 111–148, title I, § 1302","children":[],"tail":", title X, § 10104(b), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/163"},"text":"124 Stat. 163","children":[],"tail":", 896; "},{"tag":"ref","attrib":{"href":"/us/pl/113/93/tII/s213/a"},"text":"Pub. L. 113–93, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-01"},"text":"Apr. 1, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1047"},"text":"128 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0465a72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0465a73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0465a74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a), (b)(5), (c)(3), (d)(2)(C), (4), and (e)(2)(B), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", which enacted this chapter and enacted, amended, and transferred numerous other sections and notes in the Code. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (d)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to chapter 6A (§ 201 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2713, referred to in subsec. (e)(1)(B)(i), probably means section 2713 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–13"},"text":"section 300gg–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0465a75-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/93/s213/a/1"},"text":"Pub. L. 113–93, § 213(a)(1)","children":[],"tail":", struck out par. (2) which related to annual limitation on deductibles for employer-sponsored plans."}],"tail":"\n"},{"ta