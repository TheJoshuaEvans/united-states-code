{"tag":"section","attrib":{"id":"idb5ead4a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"295f–2"},"text":"§ 295f–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for mid-career public and allied health professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5ead4a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to, or enter into contracts with, any eligible entity to award scholarships to eligible individuals to enroll in degree or professional training programs for the purpose of enabling mid-career professionals in the public health and allied health workforce to receive additional training in the field of public health and allied health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead4aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead4ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” indicates an accredited educational institution that offers a course of study, certificate program, or professional training program in public or allied health or a related discipline, as determined by the Secretary ","children":[{"tag":"ref","attrib":{"idref":"fn002282"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002282"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead4ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible individuals” includes those individuals employed in public and allied health positions at the Federal, State, tribal, or local level who are interested in retaining or upgrading their education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead4ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $60,000,000 for fiscal year 2010 and such sums as may be necessary for each of fiscal years 2011 through 2015. Fifty percent of appropriated funds shall be allotted to public health mid-career professionals and 50 percent shall be allotted to allied health mid-career professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ead4ae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref",