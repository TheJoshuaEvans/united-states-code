{"tag":"section","attrib":{"id":"idc00ab16a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e"},"text":null,"children":[{"tag":"num","attrib":{"value":"16298e"},"text":"§ 16298e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon dioxide removal task force and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab16b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of carbon dioxide removal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “carbon dioxide removal” means the capture of carbon dioxide directly from ambient air or, in dissolved form, from seawater, combined with the sequestration of that carbon dioxide, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab16c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct air capture and sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab16d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced carbon mineralization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab16e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bioenergy with carbon capture and sequestration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab16f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest restoration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil carbon management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct ocean capture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary of Energy (in this section referred to as the “Secretary”), in consultation with the heads of any other relevant Federal agencies, shall prepare a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates the magnitude of excess carbon dioxide in the atmosphere that will need to be removed by 2050 to achieve net-zero emissions and stabilize the climate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inventories current and emerging approaches of carbon dioxide removal and evaluates the advantages and disadvantages of each of the approaches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies recommendations for legislation, funding, rules, revisions to rules, financing mechanisms, or other policy tools that the Federal Government can use to sufficiently advance the deployment of carbon dioxide removal projects in order to meet, in the aggregate, the magnitude of needed removals estimated under paragraph (1), including policy tools, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans or loan guarantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab17a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentives, including subsidized Federal financing mechanisms available to project developers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab17b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance market commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab17c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab17d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other policy mechanism determined by the Secretary to be beneficial for advancing carbon dioxide removal methods and the deployment of carbon dioxide removal projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab17e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission; publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab17f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the report prepared under subsection (b) to the Committee on Energy and Natural Resources of the Senate and the Committees on Energy and Commerce and Science, Space, and Technology of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable after completion of the report, make the report publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation; revision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the Secretary publishes the report under subsection (c)(2), and every 2 years thereafter, the Secretary shall evaluate the findings and recommendations of the report, or the most recent updated report submitted under paragraph (2)(B), as applicable, taking into consideration any issues and recommendations identified by the task force established under subsection (e)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After completing each evaluation under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the report as necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary revises the report under subparagraph (A), submit and publish the updated report in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a task force—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify barriers to advancement of carbon dioxide removal methods and the deployment of carbon dioxide removal projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inventory existing or potential Federal legislation, rules, revisions to rules, financing mechanisms, or other policy tools that are capable of advancing carbon dioxide removal methods and the deployment of carbon dioxide removal projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab18a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in preparing the report described in subsection (b) and any updates to the report under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab18b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Secretary on matters pertaining to carbon dioxide removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab18c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members and selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab18d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop criteria for the selection of members to the task force established under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab18e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select members for the task force in accordance with the criteria developed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab18f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall meet not less frequently than once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reevaluate the need for the task force established under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298e/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a recommendation as to whether the task force should continue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab193-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tV/s5002"},"text":"Pub. L. 116–260, div. Z, title V, § 5002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2550"},"text":"134 Stat. 2550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00ab194-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00ab195-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc00ab196-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
