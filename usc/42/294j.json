, §§ 602("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), 628(6), 629(b)(2), "},{"tag":"ref","attrib":{"href":"/us/stat/102/3124"},"text":"102 Stat. 3124","children":[],"tail":", 3145, 3146, defined “eligible institution”, “eligible lender”, “line of credit”, and “school of allied health”, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1994"},"text":"106 Stat. 1994","children":[],"tail":". See section 292"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 294j–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s737A"},"text":"act July 1, 1944, ch. 373, title VII, § 737A","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2732"},"text":"Pub. L. 97–35, title XXVII, § 2732","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/919"},"text":"95 Stat. 919","children":[],"tail":", which related to determination of eligible students, was omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1994"},"text":"106 Stat. 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
