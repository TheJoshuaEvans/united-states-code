{"tag":"section","attrib":{"id":"idb5e15f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j"},"text":null,"children":[{"tag":"num","attrib":{"value":"294j"},"text":"§ 294j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program to integrate quality improvement and patient safety training into clinical education of health professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e15f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to eligible entities or consortia under this section to carry out demonstration projects to develop and implement academic curricula that integrates ","children":[{"tag":"ref","attrib":{"idref":"fn002270"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002270"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “integrate”."}],"tail":" quality improvement and patient safety in the clinical education of health professionals. Such awards shall be made on a competitive basis and pursuant to peer review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity or consortium shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be or include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professions school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of public health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of social work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of nursing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of pharmacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution with a graduate medical education program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school of health care administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate in the development of curricula described in subsection (a) with an organization that accredits such school or institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the collection of data regarding the effectiveness of the demonstration project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide matching funds in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant to an entity or consortium under this section only if the entity or consortium agrees to make available non-Federal contributions toward the costs of the program to be funded under the grant in an amount that is not less than $1 for each $5 of Federal funds provided under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount contributed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions under paragraph (1) may be in cash or in-kind, fairly evaluated, including equipment or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take such action as may be necessary to evaluate the projects funded under this section and publish, make publicly available, and disseminate the results of such evaluations on as wide a basis as is practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions and the Committee on Finance of the Senate and the Committee on Energy and Commerce and the Committee on Ways and Means of the House of Representatives a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the specific projects supported under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains recommendations for Congress based on the evaluation conducted under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e15f52-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3508"},"text":"Pub. L. 111–148, title III, § 3508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/530"},"text":"124 Stat. 530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e15f53-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e15f54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5e15f55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e15f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 294j, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s737"},"text":"act July 1, 1944, ch. 373, title VII, § 737","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s