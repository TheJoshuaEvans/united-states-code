{"tag":"section","attrib":{"id":"idbf7e00c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12602a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12602a"},"text":"§ 12602a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications of successful completion of terms of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7e00ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12602a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making any authorized disbursement from the National Service Trust in regard to an eligible individual (including disbursement for a designated individual, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12604/f/8"},"text":"section 12604(f)(8) of this title","children":[],"tail":", due to the service of an eligible individual) under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602"},"text":"section 12602 of this title","children":[],"tail":" who served in an approved national service position, an approved summer of service position, or an approved silver scholar position, the Corporation shall rely on a certification. The certification shall be made by the entity that selected the individual for and supervised the individual in the approved national service position in which such individual successfully completed a required term of service, in a national service program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7e00cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12602a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of erroneous certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation determines that the certification under subsection (a) is erroneous or incorrect, the Corporation shall assess against the national service program a charge for the amount of any associated payment or potential payment from the National Service Trust. In assessing the amount of the charge, the Corporation shall consider the full facts and circumstances surrounding the erroneous or incorrect certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7e00cc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s146A"},"text":"Pub. L. 101–610, title I, § 146A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1403"},"text":"Pub. L. 111–13, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1514"},"text":"123 Stat. 1514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7e00cd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7e00ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7e00cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
