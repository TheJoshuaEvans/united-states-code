{"tag":"section","attrib":{"id":"idbb3c3849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1592o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592o"},"text":"§ 1592o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Surgeon General of Public Health Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, all functions, powers, and duties under this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1591b"},"text":"section 1591b of this title","children":[],"tail":" with respect to health, refuse disposal, sewage treatment, and water purification shall be exercised by and vested in the Surgeon General of the Public Health Service: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Surgeon General shall have power to delegate to any other Federal agency functions, powers, and duties with respect to construction."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb3c384a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title III, § 316, "},{"tag":"ref","attrib":{"href":"/us/stat/65/310"},"text":"65 Stat. 310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb3c384b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb3c384c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb3c384d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbb3c384e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb3c384f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Surgeon General abolished by section 3 of 1966 Reorg. Plan No. 3 eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", and functions thereof transferred to Secretary of Health, Education, and Welfare by section 1 of 1966 Reorg. Plan. No. 3, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":". Office of Surgeon General reestablished within the Office of the Assistant Secretary for Health, see Notice of Department of Health and Human Services, Office of the Assistant Secretary for Health, "},{"tag":"date","attrib":{"date":"1987-03-30"},"text":"Mar. 30, 1987","children":[],"tail":", 52 F.R. 11754."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
