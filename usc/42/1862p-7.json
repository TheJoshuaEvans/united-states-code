{"tag":"section","attrib":{"id":"idbb9220d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–7"},"text":"§ 1862p–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM industry internship programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb9220d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may award grants, on a competitive, merit-reviewed basis, to institutions of higher education, or consortia thereof, to establish or expand partnerships with local or regional private sector entities, for the purpose of providing undergraduate students with integrated internship experiences that connect private sector internship experiences with the students’ STEM coursework. The partnerships may also include industry or professional associations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grants awarded under subsection (a) may include internship programs in the manufacturing sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (c) have been enacted."}],"tail":" Use of grant funds"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9220d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement hands-on learning opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop curricula and instructional materials related to industry, including the manufacturing sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform outreach to secondary schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop mentorship programs for students with partner organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct activities to support awareness of career opportunities and skill requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003214"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003214"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two subsecs. (d) have been enacted."}],"tail":" Priority"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Director shall give priority to institutions of higher education or consortia thereof that demonstrate significant outreach to and coordination with local or regional private sector entities and Regional Centers for the Transfer of Manufacturing Technology established by section 278k(a) ","children":[{"tag":"ref","attrib":{"idref":"fn003215"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003215"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of title 15 in developing academic courses designed to provide students with the skills or certifications necessary for employment in local or regional companies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Outreach to rural communities"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall conduct outreach to institutions of higher education and private sector entities in rural areas to encourage those entities to participate in partnerships under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" Cost-share"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall require a 50 percent non-Federal cost-share from partnerships established or expanded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Federal funds provided under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9220e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of providing stipends or compensation to students for private sector internships unless private sector entities match 75 percent of such funding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as payment or reimbursement to private sector entities, except for institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 3 years after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Director shall submit a report to Congress on the number and total value of awards made under this section, the number of students affected by those awards, any evidence of the effect of those awards on workforce preparation and jobs placement for participating students, and an economic and ethnic breakdown of the participating students."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9220e5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s515"},"text":"Pub. L. 111–358, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4012"},"text":"124 Stat. 4012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9220e6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9220e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb9220e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"Section 278k of title 15","children":[],"tail":", referred to in subsec. (d), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tV/s501/b"},"text":"Pub. L. 114–329, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3023"},"text":"130 Stat. 3023","children":[],"tail":", and, as so amended, relates to the Hollings Manufacturing Extension Partnership."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9220e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb9220ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb9220eb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s2"},"text":"section 2 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"section 6621 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
