{"tag":"section","attrib":{"id":"idbe0c7048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385h"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385h"},"text":"§ 7385h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain claims not affected by awards of damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A payment under this subchapter shall not be considered as any form of compensation or reimbursement for a loss for purposes of imposing liability on any individual receiving such payment, on the basis of such receipt, to repay any insurance carrier for insurance payments, or to repay any person on account of worker’s compensation payments; and a payment under this subchapter shall not affect any claim against an insurance carrier with respect to insurance or against any person with respect to worker’s compensation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0c7049-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3649"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3649]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–511; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/g"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c704a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c704b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c704c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “this subchapter” for “part B” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
