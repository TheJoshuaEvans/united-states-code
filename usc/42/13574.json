{"tag":"section","attrib":{"id":"idbfc80274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574"},"text":null,"children":[{"tag":"num","attrib":{"value":"13574"},"text":"§ 13574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air quality enhancement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc80275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/2"},"text":"section 13572(a)(2) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize technologies that meet relevant Federal and State clean air requirements applicable to the unit or facility, including being adequately demonstrated for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7411"},"text":"section 7411 of this title","children":[],"tail":", achievable for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7479"},"text":"section 7479 of this title","children":[],"tail":", or achievable in practice for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7501"},"text":"section 7501 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize equipment or processes that exceed relevant Federal or State clean air requirements applicable to the unit or facilities included in the projects by achieving greater efficiency or environmental performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc80278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in project selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making an award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/2"},"text":"section 13572(a)(2) of this title","children":[],"tail":", the Secretary shall give priority to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects whose installation is likely to result in significant air quality improvements in nonattainment air quality areas or substantially reduce the emission level of criteria pollutants and mercury air emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8027a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects for pollution control that result in the mitigation or collection of more than 1 pollutant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8027b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects designed to allow the use of the waste byproducts or other byproducts of the equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc8027c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13572/a/2"},"text":"section 13572(a)(2) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8027d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8027e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc8027f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13574/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"