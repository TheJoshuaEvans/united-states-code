{"tag":"section","attrib":{"id":"idbcadf167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027b"},"text":"§ 4027b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of claims-paying ability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcadf168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcadf169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment required","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcadf16a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 30 of each year, the Administrator shall conduct an assessment of the ability of the National Flood Insurance Program to pay claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf16b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private market reinsurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment under this paragraph for any year in which the Administrator exercises the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4055/a/2"},"text":"section 4055(a)(2) of this title","children":[],"tail":", as added by this section,"},{"tag":"ref","attrib":{"idref":"fn003342"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003342"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to secure reinsurance of coverage provided by the National Flood Insurance Program from the private market shall include information relating the use of private sector reinsurance and reinsurance equivalents by the Administrator, whether or not the Administrator used the borrowing authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4016"},"text":"section 4016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcadf16c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct the first assessment required under this paragraph not later than ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf16d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting an assessment under subparagraph (A), the Administrator shall take into consideration regional concentrations of coverage written by the National Flood Insurance Program, peak flood zones, and relevant mitigation measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcadf16e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report of the Administrator of activities under the National Flood Insurance Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcadf16f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the results of each assessment in the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4027a"},"text":"section 4027a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcadf170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4027b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date on which the Administrator completes an assessment required under paragraph (1), make the results of the assessment available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcadf171-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100232/e"},"text":"Pub. L. 112–141, div. F, title II, § 100232(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/955"},"text":"126 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcadf172-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcadf173-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcadf174-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in par. (1)(A)(ii), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100232"},"text":"section 100232 of Pub. L. 112–141","children":[],"tail":", which enacted this section and amended sections 4051, 4052, 4055, 4082, and 4121 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcadf175-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Biggert-Waters Flood Insurance Reform Act of 2012, and also as part of the Moving Ahead for Progress in the 21st Century Act, also known as the MAP–21, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcadf176-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcadf177-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4004"},"text":"section 4004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
