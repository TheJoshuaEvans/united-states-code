{"tag":"section","attrib":{"id":"idbb0ee6fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437bbb"},"text":"§ 1437bbb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to demonstrate the effectiveness of authorizing local governments and municipalities, in coordination with the public housing agencies for such jurisdictions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee6fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive and combine program allocations of covered housing assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to design creative approaches for providing and administering Federal housing assistance based on the particular needs of the jurisdictions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0ee6fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives to low-income families with children whose head of the household is employed, seeking employment, or preparing for employment by participating in a job training or educational program, or any program that otherwise assists individuals in obtaining employment and attaining economic self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce costs of Federal housing assistance and achieve greater cost-effectiveness in Federal housing assistance expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the stock of affordable housing and housing choices for low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase homeownership among low-income families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce geographic concentration of assisted families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce homelessness through providing permanent housing solutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve program management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437bbb/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve such other purposes with respect to low-income families, as determined by the participating local governments and municipalities in coordination with the public housing agencies; ","children":[{"tag":"ref","attrib":{"idref":"fn003148"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003148"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0ee706-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title IV, § 401, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2616"},"text":"112 Stat. 2616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0ee707-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0ee708-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb0ee709-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896/tIV/s411"},"text":"Act Sept. 1, 1937, ch. 896, title IV, § 411","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s561"},"text":"Pub. L. 105–276, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2624"},"text":"112 Stat. 2624","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/276/tV/s561"},"text":"“This title [enacting this subchapter] shall take effect on the date of the enactment of the Quality Housing and Work Responsibility Act of 1998 [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
