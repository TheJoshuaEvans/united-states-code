{"tag":"section","attrib":{"id":"idbcbc21e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4155"},"text":null,"children":[{"tag":"num","attrib":{"value":"4155"},"text":"§ 4155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every building designed, constructed, or altered after the effective date of a standard issued under this chapter which is applicable to such building, shall be designed, constructed, or altered in accordance with such standard.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcbc21e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/480/s5"},"text":"Pub. L. 90–480, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-12"},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/719"},"text":"82 Stat. 719","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
