{"tag":"section","attrib":{"id":"idbc68aa5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057g"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057g"},"text":"§ 3057g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds the older Native Hawaiians—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aa5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a life expectancy 10 years less than any other ethnic group in the State of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rank lowest on 9 of 11 standard health indicies ","children":[{"tag":"ref","attrib":{"idref":"fn003311"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003311"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “indices”."}],"tail":" for all ethnic groups in Hawaii;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are often unaware of social services and do not know how to go about seeking such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live in poverty at a rate of 34 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aa63-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s621"},"text":"Pub. L. 89–73, title VI, § 621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/961"},"text":"101 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aa64-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68aa65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc68aa66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3057g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s608"},"text":"Pub. L. 89–73, title VI, § 608","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s106"},"text":"Pub. L. 95–478, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1551"},"text":"92 Stat. 1551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s13/d"},"text":"Pub. L. 97–115, § 13(d)","children":[],"tail":", "},{"tag":"date","attr