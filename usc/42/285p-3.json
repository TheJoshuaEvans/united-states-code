{"tag":"section","attrib":{"id":"idb57d1f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285p–3"},"text":"§ 285p–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office on AIDS","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall establish within the Institute an Office on AIDS. The Office shall be responsible for the coordination of research and determining the direction of the Institute with respect to AIDS research related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57d1f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primary prevention of the spread of HIV, including transmission via sexual behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57d1f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health services research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57d1f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285p–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters determined appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57d1f4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464U, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s124/b"},"text":"Pub. L. 102–321, title I, § 