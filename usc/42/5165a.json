{"tag":"section","attrib":{"id":"idbd120a80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165a"},"text":"§ 5165a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards for public and private structures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120a81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receipt of a disaster loan or grant under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient shall carry out any repair or construction to be financed with the loan or grant in accordance with applicable standards of safety, decency, and sanitation and in conformity with applicable codes, specifications, and standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President may require safe land use and construction practices, after adequate consultation with appropriate State and local government officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a disaster loan or grant under this chapter shall provide such evidence of compliance with this section as the President may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120a85-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s323"},"text":"Pub. L. 93–288, title III, § 323","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tI/s104/a"},"text":"Pub. L. 106–390, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1559"},"text":"114 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a86-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a87-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120a88-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
