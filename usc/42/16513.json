{"tag":"section","attrib":{"id":"idc01907fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513"},"text":null,"children":[{"tag":"num","attrib":{"value":"16513"},"text":"§ 16513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01907fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make guarantees under this section only for projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01907ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid, reduce, utilize, or sequester air pollutants or anthropogenic emissions of greenhouse gases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ new or significantly improved technologies as compared to commercial technologies in service in the United States at the time the guarantee is issued, including projects that employ elements of commercial technologies in combination with new or significantly improved technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects from the following categories shall be eligible for a guarantee under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renewable energy systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced fossil energy technology (including coal gasification meeting the criteria in subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hydrogen fuel cell technology for residential, industrial, or transportation applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced nuclear energy facilities, including manufacturing of nuclear supply components for advanced nuclear reactors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carbon capture, utilization, and sequestration practices and technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0190807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural and forestry practices that store and sequester carbon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthetic technologies to remove carbon from the air and oceans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efficient electrical generation, transmission, and distribution technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efficient end-use energy technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Production facilities for the manufacture of fuel efficient vehicles or parts of those vehicles, including electric drive vehicles and advanced diesel vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pollution control equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refineries, meaning facilities at which crude oil is refined into gasoline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy storage technologies for residential, industrial, transportation, and power generation applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019080f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technologies or processes for reducing greenhouse gas emissions from industrial applications, including iron, steel, cement, and ammonia production, hydrogen production, and the generation of high-temperature heat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects that increase the domestically produced supply of critical minerals (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606/a"},"text":"section 1606(a) of title 30","children":[],"tail":"), including through the production, processing, manufacturing, recycling, or fabrication of mineral alternatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gasification projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make guarantees for the following gasification projects:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated gasification combined cycle projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Integrated gasification combined cycle plants meeting the emission levels under subsection (d), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0190813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" projects for the generation of electricity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0190814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which, during the term of the guarantee—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0190815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal, biomass, petroleum coke, or a combination of coal, biomass, and petroleum coke will account for at least 65 percent of annual heat input; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0190816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electricity will account for at least 65 percent of net useful annual energy output;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have a design that is determined by the Secretary to be capable of accommodating the equipment likely to be necessary to capture the carbon dioxide that would otherwise be emitted in flue gas from the plant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have an assured revenue stream that covers project capital and operating costs (including servicing all debt obligations covered by the guarantee) that is approved by the Secretary and the relevant State public utility commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which construction commences not later than the date that is 3 years after the date of the issuance of the guarantee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019081a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a project to produce energy from coal (of not more than 13,000 Btu/lb and mined in the western United States) using appropriate advanced integrated gasification combined cycle technology that minimizes and offers the potential to sequester carbon dioxide emissions and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc019081b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include repowering of existing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc019081c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be built in stages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc019081d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a combined output of at least 100 megawatts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc019081e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be located in a western State at an altitude greater than 4,000 feet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc019081f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall demonstrate the ability to use coal with an energy content of not more than 9,000 Btu/lb;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project located in a taconite-producing region of the United States that is entitled under the law of the State in which the plant is located to enter into a long-term contract approved by a State public utility commission to sell at least 450 megawatts of output to a utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilities that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0190822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generate one or more hydrogen-rich and carbon monoxide-rich product streams from the gasification of coal or coal waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use those streams to facilitate the production of ultra clean premium fuels through the Fischer-Tropsch process; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a project to produce energy and clean fuels, using appropriate coal liquefaction technology, from Western bituminous or subbituminous coal, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0190825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by a State government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0190826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include tribal and private coal resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial gasification projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Facilities that gasify coal, biomass, or petroleum coke in any combination to produce synthesis gas for use as a fuel or feedstock and for which electricity accounts for less than 65 percent of the useful energy output of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum coke gasification projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is encouraged to make loan guarantees under this subchapter available for petroleum coke gasification projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquefaction project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, funds awarded under the Department of Energy’s Clean Coal Power Initiative for Fischer-Tropsch coal-to-oil liquefaction projects may be used to finance the cost of loan guarantees for projects awarded such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019082a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emission levels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other applicable Federal or State emission limitation requirements, a project shall attain at least—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019082b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total sulfur dioxide emissions in flue gas from the project that do not exceed 0.05 lb/MMBtu;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019082c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 90-percent removal rate (including any fuel pretreatment) of mercury from the coal-derived gas, and any other fuel, combusted by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019082d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total nitrogen oxide emissions in the flue gas from the project that do not exceed 0.08 lb/MMBtu; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019082e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total particulate emissions in the flue gas from the project that do not exceed 0.01 lb/MMBtu.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019082f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification of facilities receiving tax credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that receives tax credits for clean coal technology shall not be disqualified from receiving a guarantee under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional variation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a)(2), the Secretary may, if regional variation significantly affects the deployment of a technology, make guarantees under this subchapter for up to 6 projects that employ the same or similar technology as another project, provided no more than 2 projects that use the same or a similar technology are located in the same region of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0190831-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVII/s1703"},"text":"Pub. L. 109–58, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1120"},"text":"119 Stat. 1120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/168/s1/b/1"},"text":"Pub. L. 109–168, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3580"},"text":"119 Stat. 3580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s134/b"},"text":"Pub. L. 110–140, title I, § 134(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1513"},"text":"121 Stat. 1513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIX/s9010/b"},"text":"Pub. L. 116–260, div. Z, title IX, § 9010(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2605"},"text":"134 Stat. 2605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40401/a/2/A"},"text":"Pub. L. 117–58, div. D, title IV, § 40401(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1034"},"text":"135 Stat. 1034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0190832-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0190833-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0190834-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s9010/b/1/A"},"text":"Pub. L. 116–260, § 9010(b)(1)(A)","children":[],"tail":", inserted “, utilize” after “reduce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s9010/b/1/B"},"text":"Pub. L. 116–260, § 9010(b)(1)(B)","children":[],"tail":", inserted “, including projects that employ elements of commercial technologies in combination with new or si