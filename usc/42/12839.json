rib":{"id":"idbfa42621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VI of the Housing and Community Development Act of 1987;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 8(e)(2) of the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/e/2"},"text":"42 U.S.C. 1437f(e)(2)","children":[],"tail":"], except for funds allocated under such section for single room occupancy dwellings as authorized by title IV of the McKinney-Vento Homeless Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360"},"text":"42 U.S.C. 11360","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 810 of the Housing and Community Development Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1706e"},"text":"12 U.S.C. 1706e","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa42625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), effective on ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", the provisions of law referred to in subsection (a) are repealed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42626-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on SRO program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of law referred to in subsection (a)(4) shall remain in effect with respect to single room occupancy dwellings as authorized by title IV of the McKinney-Vento Homeless Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11360"},"text":"42 U.S.C. 11360","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12839/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts received on or after ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", as repayments or recaptures in connection with the programs referred to in subsection (a) and any other amounts for such programs that remain or become unobligated on or after such date, shall be paid into the general fund of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa42628-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s289"},"text":"Pub. L. 101–625, title II, § 289","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4128"},"text":"104 Stat. 4128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa42629-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa4262a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa4262b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title VI of the Housing and Community Development Act of 1987 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":"], referred to in subsec. (a)(3), is set out as a note under section 1715"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 12, Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The McKinney-Vento Homeless Assistance Act, referred to in subsecs. (a)(4) and (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 11360 et seq.) of chapter 119 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa4262c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsecs. (a)(4), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/400"},"text":"Pub. L. 106–400","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
