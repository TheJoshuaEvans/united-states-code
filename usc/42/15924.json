43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfe94708-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s365"},"text":"section 365 of Pub. L. 109–58","children":[],"tail":". Subsec. (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s365"},"text":"section 365 of Pub. L. 109–58","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s191"},"text":"section 191 of Title 30","children":[],"tail":", Mineral Lands and Mining."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe94709-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/1"},"text":"Pub. L. 113–291, § 3021(a)(1)","children":[],"tail":", struck out “Pilot” before “Project” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/2"},"text":"Pub. L. 113–291, § 3021(a)(2)","children":[],"tail":", substituted “Project” for “Pilot Project” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/3"},"text":"Pub. L. 113–291, § 3021(a)(3)","children":[],"tail":", substituted “the States in which Project offices are located” for “Wyoming, Montana, Colorado, Utah, and New Mexico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/4/A"},"text":"Pub. L. 113–291, § 3021(a)(4)(A)","children":[],"tail":", struck out “Pilot” before “Project” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/2"},"text":"Pub. L. 113–291, § 3021(a)(2)","children":[],"tail":", substituted “Project” for “Pilot Project” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/4/B"},"text":"Pub. L. 113–291, § 3021(a)(4)(B)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/5"},"text":"Pub. L. 113–291, § 3021(a)(5)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which required the Secretary to submit to Congress a report about the Pilot Project not later than 3 years after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e)(1), (2), (f)(1), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/2"},"text":"Pub. L. 113–291, § 3021(a)(2)","children":[],"tail":", substituted “Project” for “Pilot Project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/6"},"text":"Pub. L. 113–291, § 3021(a)(6)","children":[],"tail":", added par. (6) and struck out former par. (6) which read as follows: “the States of Wyoming, Montana, Colorado, Utah, and New Mexico.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/7"},"text":"Pub. L. 113–291, § 3021(a)(7)","children":[],"tail":", (8), redesignated subsec. (j) as (i) and struck out former subsec. (i). Prior to amendment, text read as follows: “During the period in which the Project is authorized, the Secretary shall not implement a rulemaking that would enable an increase in fees to recover additional costs related to processing drilling-related permit applications and use authorizations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/2"},"text":"Pub. L. 113–291, § 3021(a)(2)","children":[],"tail":", substituted “Project” for “Pilot Project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3021/a/2"},"text":"Pub. L. 113–291, § 3021(a)(2)","children":[],"tail":", substituted “Project” for “Pilot Project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/69"},"text":"Pub. L. 113–69","children":[],"tail":" added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The following Bureau of Land Management Field Offices shall serve as the Pilot Project offices:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Rawlins, Wyoming.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Buffalo, Wyoming.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Miles City, Montana.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Farmington, New Mexico.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Carlsbad, New Mexico.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) Grand Junction/Glenwood Springs, Colorado.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) Vernal, Utah.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
