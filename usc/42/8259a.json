{"tag":"section","attrib":{"id":"idbe8ac74b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8259a"},"text":"§ 8259a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy and water savings measures in congressional buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8ac74c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac74d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop, update, and implement a cost-effective energy conservation and management plan (referred to in this section as the “plan”) for all facilities administered by Congress (referred to in this section as “congressional buildings”) to meet the energy performance requirements for Federal buildings established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8253/a/1"},"text":"section 8253(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac74e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit the plan to Congress, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac74f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the life cycle cost analysis used to determine the cost-effectiveness of proposed energy efficiency projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule of energy surveys to ensure complete surveys of all congressional buildings every 5 years to determine the cost and payback period of energy and water conservation measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy for installation of life cycle cost-effective energy and water conservation measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of a study of the costs and benefits of installation of submetering in congressional buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information packages and “how-to” guides for each Member and employing authority of Congress that detail simple, cost-effective methods to save energy and taxpayer dollars in the workplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Architect of the Capitol shall submit to Congress annually a report on congressional energy management and conservation programs required under this section that describes in detail—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8ac756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy expenditures and savings estimates for each facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy management and conservation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8ac758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8259a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" future priorities to ensure compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8ac759-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s552"},"text":"Pub. L. 95–619, title V, § 552","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s101/a"},"text":"Pub. L. 109–58, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/605"},"text":"119 Stat. 605","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
