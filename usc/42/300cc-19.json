{"tag":"section","attrib":{"id":"idb685dc44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–19"},"text":"§ 300cc–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National blood resource education program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After consultation with the Director of the National Heart, Lung, and Blood Institute and the Commissioner of Food and Drugs, the Secretary shall establish a program of research and education regarding blood donations and transfusions to maintain and improve the safety of the blood supply. Education programs shall be directed at health professionals, patients, and the community to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of the public and patients undergoing treatment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness that the process of donating blood is safe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the concept that blood donors are contributors to a national need to maintain an adequate and safe blood supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage blood donors to donate more than once a year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage repeat blood donors to recruit new donors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of health professionals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve knowledge, attitudes, and skills of health professionals in the appropriate use of blood and blood components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the awareness and understanding of health professionals regarding the risks versus benefits of blood transfusion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage health professionals to consider alternatives to the administration of blood or blood components for their patients; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–19/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the community, increase coordination, communication, and collaboration among community, professional, industry, and government organizations regarding blood donation and transfusion issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc4f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2319, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3074"},"text":"102 Stat. 3074","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
