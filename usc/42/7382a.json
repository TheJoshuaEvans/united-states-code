{"tag":"section","attrib":{"id":"idbe07b4f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7382a"},"text":"§ 7382a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose; designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b4f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this subchapter is to establish within the Department of Energy a national fellowship program for elementary and secondary school mathematics and science teachers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b4f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a fellowship under this subchapter shall be known as an “Albert Einstein Fellow”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b4f4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s513"},"text":"Pub. L. 103–382, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4042"},"text":"108 Stat. 4042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
