{"tag":"section","attrib":{"id":"idb6e2f09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–23"},"text":"§ 300mm–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National arrangement for benefits for eligible individuals outside New York","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6e2f09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure reasonable access to benefits under this part for individuals who are enrolled WTC responders, screening-eligible WTC survivors, or certified-eligible WTC survivors and who reside in any State, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201/f"},"text":"section 201(f) of this title","children":[],"tail":", outside the New York metropolitan area, the WTC Program Administrator shall establish a nationwide network of health care providers to provide monitoring and treatment benefits and initial health evaluations near such individuals’ areas of residence in such States. Nothing in this subsection shall be construed as preventing such individuals from being provided such monitoring and treatment benefits or initial health evaluation through any Clinical Center of Excellence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e2f09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any health care provider participating in the network under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e2f09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet criteria for credentialing established by the Data Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follow the monitoring, initial health evaluation, and treatment protocols developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–4/a/2/A/ii"},"text":"section 300mm–4(a)(2)(A)(ii) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and report data in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–3"},"text":"section 300mm–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such fraud, quality assurance, and other requirements as the WTC Program Administrator establishes, including sections 1320a–7 through 1320a–7e of this title, as applied by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm/d"},"text":"section 300mm(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e2f0a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administer ","children":[{"tag":"ref","attrib":{"idref":"fn002546"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002546"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Administrator”."}],"tail":" may provide, including through contract, for the provision of training and technical assistance to health care providers participating in the network under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e2f0a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services through the VA","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6e2f0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The WTC Program Administrator may enter into an agreement with the Secretary of Veterans Affairs for the Secretary to provide services under this section through facilities of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6e2f0a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–23/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Energy and Commerce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report on whether the Department of Veterans Affairs can provide monitoring and treatment services to individuals under this section more efficiently and effectively than through the nationwide network to be established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6e2f0a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/347/tI/s101"},"text":"Pub. L. 111–347, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-02"},"text":"Jan. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3647"},"text":"124 Stat. 3647","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
