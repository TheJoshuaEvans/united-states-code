{"tag":"section","attrib":{"id":"idbf82bc7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631"},"text":null,"children":[{"tag":"num","attrib":{"value":"12631"},"text":"§ 12631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family and medical leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bc7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants in private, State, and local projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of title I of the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611"},"text":"29 U.S.C. 2611","children":[],"tail":" et seq.], if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant has provided service for the period required by section 101(2)(A)(i) (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611/2/A/i"},"text":"29 U.S.C. 2611(2)(A)(i)","children":[],"tail":"), and has met the hours of service requirement of section 101(2)(A)(ii), of such Act with respect to a project authorized under the national service laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service sponsor of the project is an employer described in section 101(4) of such Act (other than an employing agency within the meaning of subchapter V of chapter 63 of title 5),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the participant shall be considered to be an eligible employee of the service sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852c82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants in Federal projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subchapter V of chapter 63 of title 5, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf852c83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant has provided service for the period required by section 6381(1)(B) of such title with respect to a project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf852c84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the service sponsor of the project is an employing agency within the meaning of such subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the participant shall be considered to be an employee of the service sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852c85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of absence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period of any absence of a participant from a service position pursuant to title I of the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611"},"text":"29 U.S.C. 2611","children":[],"tail":" et seq.] or subchapter V of chapter 63 of title 5 shall not be counted toward the completion of the term of service of the participant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12593"},"text":"section 12593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf852c86-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s171"},"text":"Pub. L. 101–610, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3159"},"text":"104 Stat. 3159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s113/a"},"text":"Pub. L. 103–82, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/861"},"text":"107 Stat. 861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1601"},"text":"Pub. L. 111–13, title I, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1529"},"text":"123 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf852c87-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf852c88-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail"