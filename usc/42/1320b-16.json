,"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4321/d/2"},"text":"Pub. L. 105–33, title IV, § 4321(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/395"},"text":"111 Stat. 395","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/33/tIV/s4321/d/2"},"text":"“The Secretary of Health and Human Services shall issue regulations by not later than the date which is 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":"] to carry out the amendments made by subsections (b) and (c) [enacting this section and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc"},"text":"section 1395cc of this title","children":[],"tail":"] and such amendments shall take effect as of such date (on or after the issuance of such regulations) as the Secretary specifies in such regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
