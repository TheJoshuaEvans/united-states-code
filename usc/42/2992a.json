{"tag":"section","attrib":{"id":"idbc31e283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2992a"},"text":"§ 2992a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laborers and mechanics employed by contractors or subcontractors in the construction, alteration, or repair, including painting or decorating, of buildings or other facilities in connection with projects assisted under this subchapter, shall be paid wages at rates not less than those prevailing on similar construction in the locality, as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40. The Secretary of Labor shall have, with respect to such labor standards, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc31e284-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s812"},"text":"Pub. L. 88–452, title VIII, § 812","children":[],"tail":", formerly § 811, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2327"},"text":"88 Stat. 2327","children":[],"tail":"; renumbered § 812, "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV/s502/3"},"text":"Pub. L. 100–175, title V, § 502(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/973"},"text":"