{"tag":"section","attrib":{"id":"idbb32c2c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1549"},"text":null,"children":[{"tag":"num","attrib":{"value":"1549"},"text":"§ 1549.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laborers and mechanics; wages; preference in employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the wages of every laborer and mechanic employed on any construction, repair or demolition work authorized by subchapters II to VII of this chapter shall be computed on a basic day rate of eight hours per day and work in excess of eight hours per day shall be permitted upon compensation for all hours worked in excess of eight hours per day at not less than one and one-half times the basic rate of pay. Not less than the prevailing wages shall be paid in the construction of defense housing authorized herein. Preference in such employment shall be given to qualified local residents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb32c2ca-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title III, § 309, formerly § 12, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1128"},"text":"54 Stat. 1128","children":[],"tail":"; renumbered title III, § 309, "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-28/ch260/s4/b"},"text":"June 28, 1941, ch. 260, § 4(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/363"},"text":"55 Stat. 363","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1942-01-21/ch14/s9"},"text":"Jan. 21, 1942, ch. 14, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/12"},"text":"56 Stat. 12","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb32c2cb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb32c2cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb32c2cd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters III and VI of this chapter, referred to in text, were comprised of sections 1531 to 1536 and 1571 to 1576, respectively, of this title and have been omitted from the Code. For further details, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb32c2ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1942—Act ","children":[{"tag":"date","attrib":{"date":"1942-01-21"},"text":"Jan. 21, 1942","children":[],"tail":", inserted last sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
