{"tag":"section","attrib":{"id":"idbf6d5ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407"},"text":null,"children":[{"tag":"num","attrib":{"value":"12407"},"text":"§ 12407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6d5eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Hydrogen Technical Advisory Panel (the “technical panel”), to advise the Secretary on the programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5eab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The technical panel shall be appointed by the Secretary and shall be comprised of such representatives from domestic industry, universities, professional societies, Government laboratories, financial, environmental, and other organizations as the Secretary deems appropriate based on his assessment of the technical and other qualifications of such representatives. Appointments to the technical panel shall be made within 90 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":". The technical panel shall have a chairman, who shall be elected by the members from among their number."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of the departments, agencies, and instrumentalities of the Executive branch of the Federal Government shall cooperate with the technical panel in carrying out the requirements of this section and shall furnish to the technical panel such information as the technical panel deems necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5ead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The technical panel shall review and make any necessary recommendations to the Secretary on the following items—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6d5eae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation and conduct of programs under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6d5eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic, technological, and environmental consequences of the deployment of hydrogen production and use systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12407/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide such staff, funds and other support as may be necessary to enable the technical panel to carry out the functions described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6d5eb1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/566/s108"},"text":"Pub. L. 101–566, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2800"},"text":"104 Stat. 2800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/271/tI/s102/b"},"text":"Pub. L. 104–271, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3305"},"text":"110 Stat. 3305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6d5eb2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6d5eb3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6d5eb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/271"},"text":"Pub. L. 104–271","children":[],"tail":" struck out par. (3) which read as follows: “comments on and recommendations for improvements in the comprehensive 5-year program management plan required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12402"},"text":"section 12402 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6d5eb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf6d5eb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Panels","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory panels established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a panel established by the President or an officer of the Federal Government, such panel is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a panel established by Congress, its duration is otherwise provided for by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
