{"tag":"section","attrib":{"id":"idb886672c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1394"},"text":null,"children":[{"tag":"num","attrib":{"value":"1394"},"text":"§ 1394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States; adjustments; advances or reimbursement; installments; conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Payment of grants under this subchapter may be made (after necessary adjustment on account of previously made underpayments or overpayments) in advance or by way of reimbursement, and in such installments and on such conditions, as the Secretary may determine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb886672d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVII, § 1704, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/156/s5"},"text":"Pub. L. 88–156, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-24"},"text":"Oct. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/276"},"text":"77 Stat. 276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
