{"tag":"section","attrib":{"id":"idb67c6653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"300aa–25"},"text":"§ 300aa–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recording and reporting of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb67c6654-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each health care provider who administers a vaccine set forth in the Vaccine Injury Table to any person shall record, or ensure that there is recorded, in such person’s permanent medical record (or in a permanent office log or file to which a legal representative shall have access upon request) with respect to each such vaccine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67c6655-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of administration of the vaccine,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c6656-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vaccine manufacturer and lot number of the vaccine,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c6657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address and, if appropriate, the title of the health care provider administering the vaccine, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c6658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other identifying information on the vaccine required pursuant to regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67c6659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67c665a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each health care provider and vaccine manufacturer shall report to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67c665b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occurrence of any event set forth in the Vaccine Injury Table, including the events set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–14/b"},"text":"section 300aa–14(b) of this title","children":[],"tail":" which occur within 7 days of the administration of any vaccine set forth in the Table or within such longer period as is specified in the Table or section,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67c665c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occurrence of any contraindicating reaction to a vaccine which is specified in the manufacturer’s package insert, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67c665d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary may by regulation require.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Reports of the matters referred to in subparagraphs (A) and (B) shall be made beginning 90 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":". The Secretary shall publish in the Federal Register as soon as practicable after such date a notice of the reporting requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c665e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report under paragraph (1) respecting a vaccine shall include the time periods after the administration of such vaccine within which vaccine-related illnesses, disabilities, injuries, or conditions, the symptoms and manifestations of such illnesses, disabilities, injuries, or conditions, or deaths occur, and the manufacturer and lot number of the vaccine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c665f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall issue the regulations referred to in paragraph (1)(C) within 180 days of ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb67c6660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb67c6661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information which is in the possession of the Federal Government and State and local governments under this section and which may identify an individual shall not be made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", or otherwise, to any person except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb67c6662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person who received the vaccine, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb67c6663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal representative of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c6664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), the term “information which may identify an individual” shall be limited to the name, street address, and telephone number of the person who received the vaccine and of that person’s legal representative and the medical records of such person relating to the administration of the vaccine, and shall not include the locality and State of vaccine administration, the name of the health care provider who administered the vaccine, the date of the vaccination, or information concerning any reported illness, disability, injury, or condition resulting from the administration of the vaccine, any symptom or manifestation of such illness, disability, injury, or condition, or death resulting from the administration of the vaccine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb67c6665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300aa–25/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (1), all information reported under this section shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb67c6666-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXI, § 2125, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3774"},"text":"100 Stat. 3774","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4302/b/1"},"text":"Pub. L. 100–203, title IV, § 4302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-221"},"text":"101 Stat. 1330–221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb67c6667-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb67c6668-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb67c6669-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), (3), “","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"” was substituted for “the effective date of this subpart” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s323"},"text":"section 323 of Pub. L. 99–660","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"section 300aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb67c666a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “effective date of this subpart” for “effective date of this part”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb67c666b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb67c666c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart effective ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/s323"},"text":"section 323 of Pub. L. 99–660","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–1"},"text":"section 300aa–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
