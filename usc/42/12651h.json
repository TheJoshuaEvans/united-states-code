{"tag":"section","attrib":{"id":"idbf8ea2df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651h"},"text":"§ 12651h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation State offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea2e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall establish and maintain a decentralized field structure that provides for an office of the Corporation for each State. The office for a State shall be located in, or in reasonable proximity to, such State. Only one such office may carry out the duties described in subsection (b) with respect to a State at any particular time. Such State office may be directed by the representative designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651f/c"},"text":"section 12651f(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea2e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State office established pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea2e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the State Commissions established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12638"},"text":"section 12638 of this title","children":[],"tail":" technical and other assistance for the development and implementation of national service plans under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12638/e/1"},"text":"section 12638(e)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea2e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to community-based agencies and other entities within the State technical assistance for the preparation of applications for assistance under the national service laws, utilizing, as appropriate, information and materials provided by the clearinghouses established pursuant to section 12653a ","children":[{"tag":"ref","attrib":{"idref":"fn004085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea2e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the State Commission and other entities within the State support and technical assistance necessary to assure the existence of an effective system of recruitment, placement, and training of volunteers within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea2e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and evaluate the performance of all programs and projects within the State that receive assistance under the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea2e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties and functions as may be assigned or delegated by the Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8ea2e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s196A"},"text":"Pub. L. 101–610, title I, § 196A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII/s202/a"},"text":"Pub. L. 103–82, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/887"},"text":"107 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8ea2e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8ea2e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8ea2ea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653a"},"text":"Section 12653a of this title","children":[],"tail":", referred to in subsec. (b)(2), was in the original “section 198A”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/610/s198A"},"text":"section 198A of Pub. L. 101–610","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/c"},"text":"section 104(c) of Pub. L. 103–82","children":[],"tail":", which was repealed, and section 198B was redesignated section 198A, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1803/a/1"},"text":"Pub. L. 111–13, title I, § 1803(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1554"},"text":"123 Stat. 1554","children":[],"tail":". Provisions similar to section 12653a are now contained in section 12653"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8ea2eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf8ea2ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s202/i"},"text":"section 202(i) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
