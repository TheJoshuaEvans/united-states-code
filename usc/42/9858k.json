{"tag":"section","attrib":{"id":"idbeffa93b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858k"},"text":"§ 9858k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of financial assistance for certain purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeffa93c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sectarian purposes and activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No financial assistance provided under this subchapter, pursuant to the choice of a parent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/2/A/i/I"},"text":"section 9858c(c)(2)(A)(i)(I) of this title","children":[],"tail":" or through any other grant or contract under the State plan, shall be expended for any sectarian purpose or activity, including sectarian worship or instruction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa93d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tuition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With regard to services provided to students enrolled in grades 1 through 12, no financial assistance provided under this subchapter shall be expended for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa93e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any services provided to such students during the regular school day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa93f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any services for which such students receive academic credit toward graduation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any instructional services which supplant or duplicate the academic program of any public or private school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa941-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658M"},"text":"Pub. L. 97–35, title VI, § 658M","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-244"},"text":"104 Stat. 1388–244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeffa942-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeffa943-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeffa944-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
