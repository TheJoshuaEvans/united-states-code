{"tag":"section","attrib":{"id":"idb5cbdac3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"291j–1"},"text":"§ 291j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees and loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5cbdac4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5cbdac5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to assist nonprofit private agencies to carry out needed projects for the modernization or construction of nonprofit private hospitals, facilities for long-term care, outpatient facilities, and rehabilitation facilities, the Secretary, during the period ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", may, in accordance with the provisions of this part, guarantee to non-Federal lenders making loans to such agencies for such projects, payment of principal of and interest on loans, made by such lenders, which are approved under this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5cbdac6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to assist public agencies to carry out needed projects for the modernization or construction of public health centers, and public hospitals, facilities for long-term care, outpatient facilities, and rehabilitation facilities, the Secretary, during the period ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", may, in accordance with the provisions of this part, make loans to such agencies which shall be sold and guaranteed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s291j–7"},"text":"section 291j–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5cbdac7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5cbdac8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No loan guarantee under this part with respect to any modernization or construction project may apply to so much of the principal amount thereof as, when added to the amount of any grant or loan under part A with respect to such project, exceeds 90 per centum of the cost of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5cbdac9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No loan to a public agency under this part shall be made in an amount which, when added to the amount of any grant or loan under part A with respect to such project, exceeds 90 per centum of the cost of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5cbdaca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s291j–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, with the consent of the Secretary of Housing and Urban Development, shall obtain from the Department of Housing and Urban Development such assistance with respect to the administration of this part as will promote efficiency and economy thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5cbdacb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VI, § 621, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/296/tII/s201"},"text":"Pub. L. 91–296, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/344"},"text":"84 Stat. 344","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/45/tI/s108/b/1"},"text":"Pub. L. 93–45, title I, § 108(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/93"},"text":"87 Stat. 93","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5cbdacc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5cbdacd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5cbdace-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/45"},"text":"Pub. L. 93–45","children":[],"tail":" extended termination date of guarantee and loan making period in pars. (1) and (2) from "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
