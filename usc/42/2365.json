{"tag":"section","attrib":{"id":"idbc21415f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2365"},"text":null,"children":[{"tag":"num","attrib":{"value":"2365"},"text":"§ 2365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of indemnity","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The indemnity obligation of the Commission specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2363"},"text":"section 2363 of this title","children":[],"tail":" shall be for such amount, less the sales price of the property, as would have remained unpaid under a loan entered into on the date of the execution of the original deed by the Commission—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc214160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2365/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was in the amount of the purchase price from the Commission and provided for equal monthly payments of principal and interest over a period of twenty years computed on the basis of the average interest and other charges recorded for property of the same class at the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc214161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2365/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which all payments due to the date when notice was received by the Commission had been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc214162-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 6, § 65, "},{"tag":"ref","attrib":{"href":"/us/stat/69/479"},"text":"69 Stat. 479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc214163-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc214164-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc214165-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
