{"tag":"section","attrib":{"id":"idc0144e7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16441"},"text":null,"children":[{"tag":"num","attrib":{"value":"16441"},"text":"§ 16441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding new interconnection and transmission upgrades","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may approve a participant funding plan that allocates costs related to transmission upgrades or new generator interconnection, without regard to whether an applicant is a member of a Commission-approved Transmission Organization, if the plan results in rates that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0144e7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16441/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are just and reasonable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16441/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not unduly discriminatory or preferential; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0144e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16441/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are otherwise consistent with sections 824d and 824e of title 16.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0144e7f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXII/s1242"},"text":"Pub. L. 109–58, title XII, § 1242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/962"},"text":"119 Stat. 962","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
