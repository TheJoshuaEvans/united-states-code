{"tag":"section","attrib":{"id":"idc020350e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17031"},"text":null,"children":[{"tag":"num","attrib":{"value":"17031"},"text":"§ 17031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc020350f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall submit to Congress a report on any research and development challenges inherent in increasing the proportion of diesel fuel sold in the United States that is biodiesel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material for the establishment of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Standards and Technology, in consultation with the Secretary, shall make publicly available the physical property data and characterization of biodiesel and other biofuels as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203511-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s221"},"text":"Pub. L. 110–140