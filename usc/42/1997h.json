{"tag":"section","attrib":{"id":"idbbb38c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1997h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1997h"},"text":"§ 1997h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Federal departments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the time of notification of the commencement of an investigation of an institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1997a"},"text":"section 1997a of this title","children":[],"tail":" or of the notification of an intention to file a motion to intervene under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1997c"},"text":"section 1997c of this title","children":[],"tail":", and if the relevant institution receives Federal financial assistance from the Department of Health and Human Services or the Department of Education, the Attorney General shall notify the appropriate Secretary of the action and the reasons for such action and shall consult with such officials. Following such consultation, the Attorney General may proceed with an action under this subchapter if the Attorney General is satisfied that such action is consistent with the policies and goals of the executive branch."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbb38c0e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/247/s10"},"text":"Pub. L. 96–247, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-23"},"text":"May 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/354"},"text":"94 Stat. 354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title VIII, § 803(f)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–73; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb38c0f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb38c10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbb38c11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" substituted “the action” for “his action” and “the Attorney General is satisfied” for “he is satisfied”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
