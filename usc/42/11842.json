{"tag":"section","attrib":{"id":"idbf57dbd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11842"},"text":null,"children":[{"tag":"num","attrib":{"value":"11842"},"text":"§ 11842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of drug abuse education and prevention efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf57dbd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall develop and conduct a structured evaluation of the different approaches utilized across the Nation to reduce drug abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services may make grants to or enter into contracts with appropriate entities for the purpose of conducting the evaluations required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11842/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit a report based on the evaluations prepared under subsection (a) not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":", and another report based on such evaluations not later than 3 years after "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"November 18, 1988","children":[],"tail":". A third report based on such evaluations shall be submitted by the Secretary not later than "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11842/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $12,000,000 in fiscal year 1989, and $15,000,000 for each of the fiscal years 1990 through 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57dbda-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3522"},"text":"Pub. L. 100–690, title III, § 3522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4260"},"text":"102 Stat. 4260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s4/2"},"text":"Pub. L. 101–93, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/611"},"text":"103 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tX/s1001/c/1"},"text":"Pub. L. 101–204, title X, § 1001(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1826"},"text":"103 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57dbdb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf57dbdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf57dbdd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93"},"text":"Pub. L. 101–93","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/s1001/c/1/A/ii"},"text":"Pub. L. 101–204, § 1001(c)(1)(A)(ii)","children":[],"tail":", made identical amendments, striking out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11851/6"},"text":"section 11851(6) of this title","children":[],"tail":")” after “drug abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204/s1001/c/1/A/i"},"text":"Pub. L. 101–204, § 1001(c)(1)(A)(i)","children":[],"tail":", struck out “, acting through the Administrator,” before “shall develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204/s1001/c/1/B"},"text":"Pub. L. 101–204, § 1001(c)(1)(B)","children":[],"tail":", substituted “Secretary of Health and Human Services” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
