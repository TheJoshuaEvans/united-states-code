{"tag":"section","attrib":{"id":"idb69b602a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–29a"},"text":"§ 300ff–29a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69b602b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of providing services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/a"},"text":"section 300ff–22(a) of this title","children":[],"tail":", the Secretary shall make grants to States—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b602c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27"},"text":"section 300ff–27 of this title","children":[],"tail":" have demonstrated the need in the State, on an objective and quantified basis, for supplemental financial assistance to provide such services; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b602d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that did not, for the most recent grant year pursuant to section 300ff–28(a)(1) or 300ff–28(a)(2)(F)(i) of this title for which data is available, have more than 5 percent of grant funds under such sections canceled, offset under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31a/e"},"text":"section 300ff–31a(e) of this title","children":[],"tail":", or covered by any waivers under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31a/c"},"text":"section 300ff–31a(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b602e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstrated need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The factors considered by the Secretary in determining whether an eligible area has a demonstrated need for purposes of subsection (a)(1) may include any or all of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b602f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The unmet need for such services, as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–27/b"},"text":"section 300ff–27(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increasing need for HIV/AIDS-related services, including relative rates of increase in the number of cases of HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The relative rates of increase in the number of cases of HIV/AIDS within new or emerging subpopulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current prevalence of HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relevant factors related to the cost and complexity of delivering health care to individuals with HIV/AIDS in the eligible area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The impact of co-morbid factors, including co-occurring conditions, determined relevant by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prevalence of homelessness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prevalence of individuals described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–12/b/2/M"},"text":"section 300ff–12(b)(2)(M) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The relevant factors that limit access to health care, including geographic variation, adequacy of health insurance coverage, and language barriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The impact of a decline in the amount received pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28"},"text":"section 300ff–28 of this title","children":[],"tail":" on services available to all individuals with HIV/AIDS identified and eligible under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in making grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide funds under this section to a State to address the decline in services related to the decline in the amounts received pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28"},"text":"section 300ff–28 of this title","children":[],"tail":" consistent with the grant award to the State for fiscal year 2006, to the extent that the factor under subsection (b)(10) (relating to a decline in funding) applies to the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b603a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on the awarding of supplemental funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the awarding of supplemental funds under this section, the Secretary shall submit to Congress a report concerning such funds. Such report shall include information detailing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b603b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of supplemental funds available under this section for the year involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b603c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of supplemental funds used in accordance with the hold harmless provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/2"},"text":"section 300ff–28(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b603d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of supplemental funds disbursed pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b603e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disbursement of the remainder of the supplemental funds after taking into account the uses described in paragraphs (2) and (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b603f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale used for the amount of funds disbursed as described under paragraphs (2), (3), and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core medical services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–22/b"},"text":"section 300ff–22(b) of this title","children":[],"tail":" apply with respect to a grant under this section to the same extent and in the same manner as such provisions apply with respect to a grant made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/1"},"text":"section 300ff–28(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–29a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to make grants under this section applies beginning with the first fiscal year for which amounts are made available for such grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b/b/1"},"text":"section 300ff–31b(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69b6042-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2620, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII/s205/2"},"text":"Pub. L. 109–415, title II, § 205(2)","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2797"},"text":"120 Stat. 2797","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", §§ 2(a)(1), (3)(A), 5(c)(2), 8(a)(2), (b)(2)(D), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":", 2891, 2893, 2894.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69b6043-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69b6044-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb69b6045-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2620 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 2621 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–30"},"text":"section 300ff–30 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2620 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–30"},"text":"section 300ff–30 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69b6046-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", §§ 5(c)(2), 8(a)(2), (b)(2)(D), substituted “300ff–28(a)(2)(F)(i)” for “300ff–28(a)(2)(G)(i)”, “5 percent” for “2 percent”, and “canceled, offset under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31a/e"},"text":"section 300ff–31a(e) of this title","children":[],"tail":",” for “canceled”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69b6047-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69b6048-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, and that amendment by sections 5(c)(2) and 8(a)(2), (b)(2)(D) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" be applicable to this section as so revived and effective as if enacted on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see section 2(a)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
