{"tag":"section","attrib":{"id":"idbf748a7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563"},"text":null,"children":[{"tag":"num","attrib":{"value":"12563"},"text":"§ 12563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative and community-based service-learning programs and research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf748a7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748a7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a State educational agency, a State Commission, a territory, an Indian tribe, an institution of higher education, or a public or private nonprofit organization (including community-based entities), a public or private elementary school or secondary school, a local educational agency, a consortium of such entities, or a consortium of 2 or more such entities and a for-profit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible partnership” means a partnership that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748a81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748a82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more community-based entities that have demonstrated records of success in carrying out service-learning programs with economically disadvantaged students, and that meet such criteria as the Chief Executive Officer may establish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a local educational agency for which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf748a84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high number or percentage, as determined by the Corporation, of the students served by the agency are economically disadvantaged students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf748a85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the four-year adjusted cohort graduation rate (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":") for the secondary school students served by the agency is less than 70 percent; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748a86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may also include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748a87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local government agency that is not described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office of the chief executive officer of a unit of general local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State Commission or State educational agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 1 local educational agency described in subclause (I).","children":[{"tag":"ref","attrib":{"idref":"fn004058"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Clause (v) does not contain subclauses."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth engagement zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “youth engagement zone” means the area in which a youth engagement zone program is carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth engagement zone program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “youth engagement zone program” means a service-learning program in which members of an eligible partnership collaborate to provide coordinated school-based or community-based service-learning opportunities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to address a specific community challenge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an increasing percentage of out-of-school youth and secondary school students served by a local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in circumstances under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 90 percent of such students participate in service-learning activities as part of the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service-learning is a part of the curriculum in all of the secondary schools served by the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts appropriated to carry out this part for a fiscal year, the Corporation may make grants (which may include approved summer of service positions in the case of a grant for a program described in subsection (c)(8)) and fixed-amount grants (in accordance with section 12581(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title) to eligible entities or eligible partnerships, as appropriate, for programs and activities described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds under this part may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate service-learning programs into the science, technology, engineering, and mathematics (referred to in this part as “STEM”) curricula at the elementary, secondary, postsecondary, or postbaccalaureate levels in coordination with practicing or retired STEM professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve students in service-learning programs focusing on energy conservation in their community, including conducting educational outreach on energy conservation and working to improve energy efficiency in low-income housing and in public spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve students in service-learning programs in emergency and disaster preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve students in service-learning programs aimed at improving access to and obtaining the benefits from computers and other emerging technologies, including improving such access for individuals with disabilities, in low-income or rural communities, in senior centers and communities, in schools, in libraries, and in other public spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve high school age youth in the mentoring of middle school youth while involving all participants in service-learning to seek to meet unmet human, educational, environmental, public safety, or emergency and disaster preparedness needs in their community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research and evaluations on service-learning, including service-learning in middle schools, and disseminate such research and evaluations widely;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct innovative and creative activities as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a"},"text":"section 12523(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish or implement summer of service programs (giving priority to programs that enroll youth who will be enrolled in any of grades 6 through 9 at the end of the summer concerned) during the summer months (including recruiting, training, and placing service-learning coordinators)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for youth who will be enrolled in any of grades 6 through 12 at the end of the summer concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for community-based service-learning projects—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf748aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet unmet human, educational, environmental (including energy conservation and stewardship), and emergency and disaster preparedness and other public safety needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf748aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be intensive, structured, supervised, and designed to produce identifiable improvements to the community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748aa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may include the extension of academic year service-learning programs into the summer months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which a student who completes 100 hours of service as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602/b/2"},"text":"section 12602(b)(2) of this title","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn004059"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Comma probably should not appear."}],"tail":" shall be eligible for a summer of service educational award of $500 or $750 as described in sections 12602(a)(2)(C) and 12603(d) of this title;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish or implement youth engagement zone programs in youth engagement zones, for students in secondary schools served by local educational agencies for which a majority of such students do not participate in service-learning activities that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out by eligible partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf748aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve all students in secondary schools served by the local educational agency in service-learning to address a specific community challenge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve student engagement, including student attendance and student behavior, and student achievement, graduation rates, and college-going rates at secondary schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf748aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve an increasing percentage of students in secondary school and out-of-school youth in the community in school-based or community-based service-learning activities each year, with the goal of involving all students in secondary schools served by the local educational agency and involving an increasing percentage of the out-of-school youth in service-learning activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct semester of service programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf748aab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for secondary school students to participate in a semester of coordinated school-based or community-based service-learning opportunities for a minimum of 70 hours (of which at least a third will be spent participating in field-based activities) over a semester, to address specific community challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748aac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage as participants high percentages or numbers of economically disadvantaged students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748aad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow participants to receive academic credit, for the time spent in the classroom and in the field for the program, that is equivalent to the academic credit for any class of equivalent length and with an equivalent time commitment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf748aae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the classroom-based instruction component of the program is integrated into the academic program of the local educational agency involved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748aaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other innovative service-learning programs or research that the Corporation considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ab0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant to carry out a program or activity under this part, an entity or partnership, as appropriate, shall prepare and submit to the Corporation an application at such time and in such manner as the Chief Executive Officer may reasonably require, and obtain approval of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ab1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this part, the Corporation shall give priority to applicants proposing to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748ab2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve students and community stakeholders in the design and implementation of service-learning programs carried out using funds received under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement service-learning programs in low-income or rural communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize adult volunteers, including tapping the resources of retired and retiring adults, in the planning and implementation of service-learning programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748ab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf748ab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each program or activity funded under this part shall be carried out over a period of 3 years, which may include 1 planning year. In the case of a program funded under this part, the 3-year period may be extended by 1 year, if the program meets performance levels established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12639/k"},"text":"section 12639(k) of this title","children":[],"tail":" and any other criteria determined by the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration encouraged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity carrying out a program or activity funded under this part shall, to the extent practicable, collaborate with entities carrying out programs under this division, division C, and titles I and II of the Domestic Volunteer Service Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq., 5001 et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf748ab8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12563/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after the effective date of the Serve America Act, the Corporation shall conduct an independent evaluation of the programs and activities carried out using funds made available under this part, and determine best practices relating to service-learning and recommendations for improvement of those programs and activities. The Corporation shall widely disseminate the results of the evaluations, and information on the best practices and recommendations to the service community through multiple channels, including the Corporation’s Resource Center or a clearinghouse of effective strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf748ab9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s119"},"text":"Pub. L. 101–610, title I, § 119","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1204"},"text":"Pub. L. 111–13, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1479"},"text":"123 Stat. 1479","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/bbb/3"},"text":"Pub. L. 114–95, title IX, § 9215(bbb)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2185"},"text":"129 Stat. 2185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf748aba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf748abb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf748abc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Titles I and II of the Act are classified generally to subchapters I (§ 4951 et seq.) and II (§ 5000 et seq.), respectively, of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the effective date of the Serve America Act, referred to in subsec. (f)(3), as ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf748abd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s119"},"text":"section 119 of Pub. L. 101–610","children":[],"tail":" was renumbered section 118 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12561"},"text":"section 12561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf748abe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2)(A)(ii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “the four-year adjusted cohort graduation rate (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":")” for “the graduation rate (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/C/vi"},"text":"section 6311(b)(2)(C)(vi) of title 20","children":[],"tail":" and as clarified in applicable regulations promulgated by the Department of Education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf748abf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"childre