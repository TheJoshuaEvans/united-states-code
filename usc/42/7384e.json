{"tag":"section","attrib":{"id":"idbe09feb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384e"},"text":"§ 7384e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Energy Employees Occupational Illness Compensation Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe09feb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established on the books of the Treasury a fund to be known as the “Energy Employees Occupational Illness Compensation Fund” (in this subchapter referred to as the “compensation fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09feb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts in compensation fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The compensation fund shall consist of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09feb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated to the compensation fund pursuant to the authorization of appropriations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384g/b"},"text":"section 7384g(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09feb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to the compensation fund under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09feb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing of compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the exhaustion of amounts in the compensation fund attributable to the authorization of appropriations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384g/b"},"text":"section 7384g(b) of this title","children":[],"tail":", the Secretary of the Treasury shall transfer directly to the compensation fund from the General Fund of the Treasury, without further appropriation, such amounts as are further necessary to carry out the compensation program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09feb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), amounts in the compensation fund shall be used to carry out the compensation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09feb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs not paid from compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No cost incurred in carrying out the compensation program, or in administering the compensation fund, shall be paid from the compensation fund or set off against or otherwise deducted from any payment to any individual under the compensation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09feba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts in compensation fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the compensation fund shall be invested in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9702"},"text":"section 9702 of title 31","children":[],"tail":", and any interest on, and proceeds from, any such investment shall be credited to and become a part of the compensation fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe09febb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3612"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3612]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–497.)"}],"tail":"\n"}],"tail":null}
