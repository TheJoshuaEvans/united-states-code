{"tag":"section","attrib":{"id":"idbc1a1570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2297f–1"},"text":"§ 2297f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of other technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1a1571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Corporation facilities using alternative technologies for uranium enrichment, including AVLIS, shall be licensed under sections 2073, 2093, and 2243 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1a1572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2297f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs for decontamination and decommissioning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall provide for the costs of decontamination and decommissioning of any Corporation facilities described in subsection (a) in accordance with the requirements of the amendments made by section 5 of the Solar, Wind, Waste, and Geothermal Power Production Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1a1573-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title II, § 1702, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXI/s1101"},"text":"Pub. L. 102–486, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2953"},"text":"106 Stat. 2953","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s3116/b/4"},"text":"Pub. L. 104–134, title III, § 3116(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-349"},"text":"110 Stat. 1321–349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1a1574-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1a1575-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc1a1576-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of the Solar, Wind, Waste, and Geothermal Power Production Act of 1990, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/575/s5"},"text":"section 5 of Pub. L. 101–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2835"},"text":"104 Stat. 2835","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2243"},"text":"section 2243 of this title","children":[],"tail":" and amended sections 2014, 2061, 2201, and 2284 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc1a1577-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" substituted “including” for “other than” and “sections 2073, 2093, and 2243” for “sections 2073 and 2093”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc1a1578-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc1a1579-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to United States Enrichment Corporation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to the Corporation, meaning the United States Enrichment Corporation, deemed, as of the privatization date (","children":[{"tag":"date","attrib":{"date":"1998-07-28"},"text":"July 28, 1998","children":[],"tail":"), to be references to the private corporation, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/s3116/e"},"text":"section 3116(e) of Pub. L. 104–134","children":[],"tail":", set out as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297"},"text":"section 2297 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
