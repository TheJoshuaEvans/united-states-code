{"tag":"section","attrib":{"id":"idc054b1b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18341"},"text":null,"children":[{"tag":"num","attrib":{"value":"18341"},"text":"§ 18341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial Cargo Development program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall continue to support the existing Commercial Resupply Services program, aimed at enabling the commercial space industry in support of NASA to develop reliable means of launching cargo and supplies to the ISS throughout the duration of the facility’s operation. The Administrator may apply funds towards the reduction of risk to the timely start of these services, specifically—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b1b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18341/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to conduct a flight test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18341/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18341/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the ground infrastructure needed for commercial cargo capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc054b1b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIV/s401"},"text":"Pub. L. 111–267, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2820"},"text":"124 Stat. 2820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/10/tIII/s302/f"},"text":"Pub. L. 115–10, title III, § 302(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-03-21"},"text":"Mar. 21, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/26"},"text":"131 Stat. 26","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc054b1b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc054b1b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc054b1ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/10"},"text":"Pub. L. 115–10","children":[],"tail":" substituted “Commercial Resupply Services” for “Commercial Orbital Transportation Services” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
