{"tag":"section","attrib":{"id":"idbf06d58e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910"},"text":null,"children":[{"tag":"num","attrib":{"value":"9910"},"text":"§ 9910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tripartite boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf06d58f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private nonprofit entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for a private, nonprofit entity to be considered to be an eligible entity for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/1"},"text":"section 9902(1) of this title","children":[],"tail":", the entity shall administer the community services block grant program through a tripartite board described in paragraph (2) that fully participates in the development, planning, implementation, and evaluation of the program to serve low-income communities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and composition of board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the board referred to in paragraph (1) shall be selected by the entity and the board shall be composed so as to assure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of the members of the board are elected public officials, holding office on the date of selection, or their representatives, except that if the number of such elected officials reasonably available and willing to serve on the board is less than ⅓ of the membership of the board, membership on the board of appointive public officials or their representatives may be counted in meeting such ⅓ requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf06d594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than ⅓ of the members are persons chosen in accordance with democratic selection procedures adequate to assure that these members are representative of low-income individuals and families in the neighborhood served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each representative of low-income individuals and families selected to represent a specific neighborhood within a community under clause (i) resides in the neighborhood represented by the member; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder of the members are officials or members of business, industry, labor, religious, law enforcement, education, or other major groups and interests in the community served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for a public organization to be considered to be an eligible entity for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/1"},"text":"section 9902(1) of this title","children":[],"tail":", the entity shall administer the community services block grant program through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a tripartite board, which shall have members selected by the organization and shall be composed so as to assure that not fewer than ⅓ of the members are persons chosen in accordance with democratic selection procedures adequate to assure that these members—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are representative of low-income individuals and families in the neighborhood served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d59a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reside in the neighborhood served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d59b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are able to participate actively in the development, planning, implementation, and evaluation of programs funded under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d59c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another mechanism specified by the State to assure decisionmaking and participation by low-income individuals in the development, planning, implementation, and evaluation of programs funded under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091e8d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s676B"},"text":"Pub. L. 97–35, title VI, § 676B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2740"},"text":"112 Stat. 2740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf091e8e-3