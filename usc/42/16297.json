{"tag":"section","attrib":{"id":"idc00ab05c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16297"},"text":null,"children":[{"tag":"num","attrib":{"value":"16297"},"text":"§ 16297.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complex Well Technology Testing Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with industry leaders in extended research drilling technology, shall establish a Complex Well Technology Testing Facility at the Rocky Mountain Oilfield Testing Center to increase the range of extended drilling technologies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc00ab05d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s967"},"text":"Pub. L. 109–58, title IX, § 967","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/894"},"text":"119 Stat. 894","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
