{"tag":"section","attrib":{"id":"idbd1b7fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5174a"},"text":"§ 5174a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1b7fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1b7fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered assistance” means assistance provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7faa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in relation to a major disaster or emergency declared by the President under section 5170 or 5191, respectively, of this title on or after ","children":[{"tag":"date","attrib":{"date":"2012-10-28"},"text":"October 28, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716/e"},"text":"section 3716(e) of title 31","children":[],"tail":", the Administrator—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7fad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in subparagraph (B), shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1b7fae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive a debt owed to the United States related to covered assistance provided to an individual or household if the covered assistance was distributed based on an error by the Agency and such debt shall be construed as a hardship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1b7faf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive a debt owed to the United States related to covered assistance provided to an individual or household if such assistance is subject to a claim or legal action, including in accordance with section ","children":[{"tag":"ref","attrib":{"idref":"fn003406"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003406"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be a reference to section 317 of the Act."}],"tail":" of the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5160"},"text":"42 U.S.C. 5160","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not waive a debt under subparagraph (A) if the debt involves fraud, the presentation of a false claim, or misrepresentation by the debtor or any party having an interest in the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of covered assistance distributed based on error","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Homeland Security shall monitor the distribution of covered assistance to individuals and households to determine the percentage of such assistance distributed based on an error.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on waiver authority based on excessive error rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Inspector General of the Department of Homeland Security determines, with respect to any 12-month period, that the amount of covered assistance distributed based on an error by the Agency exceeds 4 percent of the total amount of covered assistance distributed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd1b7fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General shall notify the Administrator and publish the determination in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1b7fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any major disaster or emergency declared by the President under section 5170 or section 5191, respectively, of this title after the date on which the determination is published under subparagraph (A), the Administrator shall report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate actions that the Administrator will take to reduce the error rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b7fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment of certain assistance prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1b7fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716/e"},"text":"section 3716(e) of title 31","children":[],"tail":", and unless there is evidence of civil or criminal fraud, the Agency may not take any action to recoup covered assistance from the recipient of such assistance if the receipt of such assistance occurred on a date that is more than 3 years before the date on which the Agency first provides to the recipient written notification of an intent to recoup."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered assistance defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered assistance” means assistance provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in relation to a major disaster or emergency declared by the President under section 5170 or 5191 of this title, respectively, on or after ","children":[{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b7fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1b7fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1b7fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1b7fbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to disaster or emergency assistance provided to a State or local government on or after ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbd1b7fbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no administrative action may be taken to recover a payment of such assistance after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", if the action is prohibited under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5205/a/1"},"text":"section 5205(a)(1) of this title","children":[],"tail":", as amended by paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd1b7fc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any administrative action to recover a payment of such assistance that is pending on such date of enactment shall be terminated if the action is prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5205/a/1"},"text":"section 5205(a)(1) of this title","children":[],"tail":", as amended by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1b7fc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5174a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section, including the amendments made by this section, may not be construed to invalidate or otherwise affect any administration action completed before ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1b7fc2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1216"},"text":"Pub. L. 115–254, div. D, § 1216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3449"},"text":"132 Stat. 3449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVI/s5602/a"},"text":"Pub. L. 117–263, div. E, title LVI, § 5602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3404"},"text":"136 Stat. 3404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b7fc3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b7fc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd1b7fc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Disaster Recovery Reform Act of 2018 and as part of the FAA Reauthorization Act of 2018, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1216"},"text":"section 1216 of Pub. L. 115–254","children":[],"tail":". Subsec. (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1216"},"text":"section 1216 of Pub. L. 115–254","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5205"},"text":"section 5205 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1b7fc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5602/a/1"},"text":"Pub. L. 117–263, § 5602(a)(1)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) subject to subparagraph (B), may waive a debt owed to the United States related to covered assistance provided to an individual or household if—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the covered assistance was distributed based on an error by the Agency;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) there was no fault on behalf of the debtor; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) the collection of the debt would be against equity and good conscience; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5602/a/2/A"},"text":"Pub. L. 117–263, § 5602(a)(2)(A)","children":[],"tail":", substituted “Report on” for “Removal of” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5602/a/2/B"},"text":"Pub. L. 117–263, § 5602(a)(2)(B)","children":[],"tail":", substituted “the Administrator shall report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate actions that the Administrator will take to reduce the error rate” for “the authority of the Administrator to waive debt under paragraph (2) shall no longer be effective”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1b7fc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd1b7fc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authorities provided under div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which enacted this section, applicable to each major disaster and emergency declared by the President under "},{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202/b"},"text":"section 1202(b) of Pub. L. 115–254","children":[],"tail":", set out in an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd1b7fc9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1203"},"text":"section 1203 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
