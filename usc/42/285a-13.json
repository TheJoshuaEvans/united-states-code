{"tag":"section","attrib":{"id":"idb56a0c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–13"},"text":"§ 285a–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific framework for recalcitrant cancers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56a0c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of scientific framework","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each recalcitrant cancer identified under subsection (b), the Director of the Institute shall develop (in accordance with subsection (c)) a scientific framework for the conduct or support of research on such cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The scientific framework with respect to a recalcitrant cancer shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current status","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of literature","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A summary of findings from the current literature in the areas of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb56a0c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention, diagnosis, and treatment of such cancer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fundamental biologic processes that regulate such cancer (including similarities and differences of such processes from the biological processes that regulate other cancers); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the epidemiology of such cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identification of relevant emerging scientific areas and promising scientific advances in basic, translational, and clinical science relating to the areas described in subclauses (I) and (II) of clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Researchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A description of the availability of qualified individuals to conduct scientific research in the areas described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated research initiatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identification of the types of initiatives and partnerships for the coordination of intramural and extramural research of the Institute in the areas described in clause (i) with research of the relevant national research institutes, Federal agencies, and non-Federal public and private entities in such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identification of public and private resources, such as patient registries and tissue banks, that are available to facilitate research relating to each of the areas described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of research questions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The identification of research questions relating to basic, translational, and clinical science in the areas described in subclauses (I) and (II) of subparagraph (A)(i) that have not been adequately addressed with respect to such recalcitrant cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recommendations for appropriate actions that should be taken to advance research in the areas described in subparagraph (A)(i) and to address the research questions identified in subparagraph (B), as well as for appropriate benchmarks to measure progress on achieving such actions, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Researchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ensuring adequate availability of qualified individuals described in subparagraph (A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated research initiatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Promoting and developing initiatives and partnerships described in subparagraph (A)(iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Developing additional public and private resources described in subparagraph (A)(v) and strengthening existing resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial development and subsequent update","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each recalcitrant cancer identified under subsection (b)(1), the Director of the Institute shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a scientific framework under this subsection not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and update the scientific framework not later than 5 years after its initial development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute may review and update each scientific framework developed under this subsection as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each scientific framework developed under subsection (a), not later than 30 days after the date of completion of the framework, the Director of the Institute shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such framework to the Committee on Energy and Commerce and Committee on Appropriations of the House of Representatives, and the Committee on Health, Education, Labor, and Pensions and Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such framework publically available on the Internet website of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of recalcitrant cancer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0c41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", the Director of the Institute shall identify two or more recalcitrant cancers that each—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a 5-year relative survival rate of less than 20 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are estimated to cause the death of at least 30,000 individuals in the United States per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional cancers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute may, at any time, identify other recalcitrant cancers for purposes of this section. In identifying a recalcitrant cancer pursuant to the previous sentence, the Director may consider additional metrics of progress (such as incidence and mortality rates) against such type of cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each recalcitrant cancer identified under subsection (b), the Director of the Institute shall convene a working group comprised of representatives of appropriate Federal agencies and other non-Federal entities to provide expertise on, and assist in developing, a scientific framework under subsection (a). The Director of the Institute (or the Director’s designee) shall participate in the meetings of each such working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0c47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of NIH shall ensure that each biennial report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"section 283 of this title","children":[],"tail":" includes information on actions undertaken to carry out each scientific framework developed under subsection (a) with respect to a recalcitrant cancer, including the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on research grants awarded by the National Institutes of Health for research relating to such cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the progress made in improving outcomes (including relative survival rates) for individuals diagnosed with such cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An update on activities pertaining to such cancer under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285a–2/b/7"},"text":"section 285a–2(b)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional one-time report for certain frameworks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each recalcitrant cancer identified under subsection (b)(1), the Director of the Institute shall, not later than 6 years after the initial development of a scientific framework under subsection (a), submit a report to the Congress on the effectiveness of the framework (including the update required by subsection (a)(3)(A)(ii)) in improving the prevention, detection, diagnosis, and treatment of such cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations for exception funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall consider each relevant scientific framework developed under subsection (a) when making recommendations for exception funding for grant applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–13/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “recalcitrant cancer” means a cancer for which the five-year relative survival rate is below 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56a0c4e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 417G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1083"},"text":"Pub. L. 112–239, div. A, title X, § 1083","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1960"},"text":"126 Stat. 1960","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
