{"tag":"section","attrib":{"id":"idbcb4f648-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101e"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101e"},"text":"§ 4101e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from fees for certain map change requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a requester shall be exempt from submitting a review or processing fee for a request for a flood insurance rate map change based on a habitat restoration project that is funded in whole or in part with Federal or State funds, including dam removal, culvert redesign or installation, or the installation of fish passage.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcb4f649-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s22"},"text":"Pub. L. 113–89, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1028"},"text":"128 Stat. 1028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb4f64a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb4f64b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcb4f64c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Homeowner Flood Insurance Affordability Act of 2014, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
