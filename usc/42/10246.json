{"tag":"section","attrib":{"id":"idbf1c317d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10246"},"text":null,"children":[{"tag":"num","attrib":{"value":"10246"},"text":"§ 10246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitored retrievable storage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c317e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10246/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon enactment of legislation to implement an agreement negotiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10243/a"},"text":"section 10243(a) of this title","children":[],"tail":" to site a monitored retrievable storage facility, the Secretary shall construct and operate such facility as part of an integrated nuclear waste management system in accordance with the terms and conditions of such agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c317f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10246/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to any State, Indian tribe, or affected unit of local government to assess the feasibility of siting a monitored retrievable storage facility under this section at a site under the jurisdiction of such State, tribe, or affected unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c3180-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tIV/s406"},"text":"Pub. L. 97–425, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5041"},"text":"Pub. L. 100–203, title V, § 5041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-246"},"text":"101 Stat. 1330–246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c3181-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c3182-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c3183-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
