", "},{"tag":"ref","attrib":{"href":"/us/stat/85/437"},"text":"85 Stat. 437","children":[],"tail":", provided for technical assistance in connection with grants for construction of health research facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s201/a"},"text":"Pub. L. 94–484, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
