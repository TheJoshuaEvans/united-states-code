{"tag":"section","attrib":{"id":"idb78c016d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal loans for State welfare programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78c016e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78c016f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make loans to any loan-eligible State, for a period to maturity of not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78c0170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan-eligible State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in paragraph (1), the term “loan-eligible State” means a State against which a penalty has not been imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s609/a/1"},"text":"section 609(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge and collect interest on any loan made under this section at a rate equal to the current average market yield on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the period to maturity of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall use a loan made to the State under this section only for any purpose for which grant amounts received by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603/a"},"text":"section 603(a) of this title","children":[],"tail":" may be used, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78c0173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" welfare anti-fraud activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78c0174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of assistance under the State program to Indian families that have moved from the service area of an Indian tribe with a tribal family assistance plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s612"},"text":"section 612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on total amount of loans to State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cumulative dollar amount of all loans made to a State under this section during fiscal years 1997 through 2003 shall not exceed 10 percent of the State family assistance grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on total amount of outstanding loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total dollar amount of loans outstanding under this section may not exceed $1,700,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s606/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated such sums as may be necessary for the cost of loans under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78c0178-3a70-11f1-ae07-e4213316b5fa"},