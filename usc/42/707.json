{"tag":"section","attrib":{"id":"idb7f01a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s707"},"text":null,"children":[{"tag":"num","attrib":{"value":"707"},"text":"§ 707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty for false statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f01a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f01a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully makes or causes to be made any false statement or representation of a material fact in connection with the furnishing of items or services for which payment may be made by a State from funds allotted to the State under this subchapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having knowledge of the occurrence of any event affecting his initial or continued right to any such payment conceals or fails to disclose such event with an intent fraudulently to secure such payment either in a greater amount than is due or when no such payment is authorized,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $25,000 or imprisoned for not more than five years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f01a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For civil monetary penalties for certain submissions of false claims, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f01a15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 507, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2192/a"},"text":"Pub. L. 97–35, title XXI, § 2192(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/824"},"text":"95 Stat. 824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f01a16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f01a17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7f01a18-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 707, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tV/s507"},"text":"act Aug. 14, 1935, ch. 531, title V, § 507","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tIII/s301"},"text":"Pub. L. 90–248, title III, § 301","c