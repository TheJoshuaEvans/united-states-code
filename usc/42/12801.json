{"tag":"section","attrib":{"id":"idbfa1b55e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12801"},"text":null,"children":[{"tag":"num","attrib":{"value":"12801"},"text":"§ 12801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Among the alternative model programs that the Secretary shall make available for use by participating jurisdictions under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12743"},"text":"section 12743 of this title","children":[],"tail":" shall be model programs specified in this part. The Secretary shall keep these specified model programs under review and submit to Congress such recommendations for change as the Secretary determines to be appropriate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfa1b55f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s251"},"text":"Pub. L. 101–625, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4119"},"text":"104 Stat. 4119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
