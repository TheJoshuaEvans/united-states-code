{"tag":"section","attrib":{"id":"idbdfba706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7257d"},"text":"§ 7257d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded research by Secretary of Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdfba707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detection and identification research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdfba708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the working group under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6/a"},"text":"section 247d–6(a) of this title","children":[],"tail":", the Secretary of Energy and the Administrator of the National Nuclear Security Administration shall expand, enhance, and intensify research relevant to the rapid detection and identification of pathogens likely to be used in a bioterrorism attack or other agents that may cause a public health emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities carried out under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdfba70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of methods for detecting biological agents or toxins of potential use in a biological attack and the testing of such methods under variable conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfba70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement or pursuit of methods for testing, verifying, and calibrating new detection and surveillance tools and techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdfba70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out other research activities in relevant areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdfba70d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", the Administrator of the National Nuclear Security Administration shall submit to the Committee on Energy and Natural Resources and the Committee on Armed Services of the Senate, and the Committee on Energy and Commerce and the Committee on Armed Services of the House of Representatives, a report setting forth the programs and projects that will be funded prior to the obligation of funds appropriated under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdfba70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7257d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary in each of fiscal years 2002 through 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdfba70f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s152"},"text":"Pub. L. 107–188, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/630"},"text":"116 Stat. 630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdfba710-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdfba711-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdfba712-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
