{"tag":"section","attrib":{"id":"idbbfd65f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183"},"text":null,"children":[{"tag":"num","attrib":{"value":"2183"},"text":"§ 2183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmilitary utilization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbfd65f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of public interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, after giving the patent owner an opportunity for a hearing, declare any patent to be affected with the public interest if (1) the invention or discovery covered by the patent is of primary importance in the production or utilization of special nuclear material or atomic energy; and (2) the licensing of such invention or discovery under this section is of primary importance to effectuate the policies and purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any patent has been declared affected with the public interest, pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission is licensed to use the invention or discovery covered by such patent in performing any of its powers under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person may apply to the Commission for a nonexclusive patent license to use the invention or discovery covered by such patent, and the Commission shall grant such patent license to the extent that it finds that the use of the invention or discovery is of primary importance to the conduct of an activity by such person authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd65fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for patent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd65fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has made application to the Commission for a license under sections 2073, 2092, 2093, 2111, 2133 or 2134 of this title, or a permit or lease under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2097"},"text":"section 2097 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom such license, permit, or lease has been issued by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd65ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is authorized to conduct such activities as such applicant is conducting or proposes to conduct under a general license issued by the Commission under sections 2092 or 2111 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose activities or proposed activities are authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2051"},"text":"section 2051 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may at any time make application to the Commission for a patent license for the use of an invention or discovery useful in the production or utilization of special nuclear material or atomic energy covered by a patent. Each such application shall set forth the nature and purpose of the use which the applicant intends to make of the patent license, the steps taken by the applicant to obtain a patent license from the owner of the patent, and a statement of the effects, as estimated by the applicant, on the authorized activities which will result from failure to obtain such patent license and which will result from the granting of such patent license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd6601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any person has made an application to the Commission for a patent license pursuant to subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd6602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission, within 30 days after the filing of such application, shall make available to the owner of the patent all of the information contained in such application, and shall notify the owner of the patent of the time and place at which a hearing will be held by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission shall hold a hearing within 60 days after the filing of such application at a time and place designated by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event an applicant applies for two or more patent licenses, the Commission may, in its discretion, order the consolidation of such applications, and if the patents are owned by more than one owner, such owners may be made parties to one hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd6605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission’s findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after any hearing conducted pursuant to subsection (d), the Commission finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbfd6606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the invention or discovery covered by the patent is of primary importance in the production or utilization of special nuclear material or atomic energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the licensing of such invention or discovery is of primary importance to the conduct of the activities of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities to which the patent license are proposed to be applied by such applicant are of primary importance to the furtherance of policies and purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbfd6609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such applicant cannot otherwise obtain a patent license from the owner of the patent on terms which the Commission deems to be reasonable for the intended use of the patent to be made by such applicant,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commission shall license the applicant to use the invention or discovery covered by the patent for the purposes stated in such application on terms deemed equitable by the Commission and generally not less fair than those granted by the patentee or by the Commission to similar licensees for comparable use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd660a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on issuance of patent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not grant any patent license pursuant to subsection (e) for any other purpose than that stated in the application. Nor shall the Commission grant any patent license to any other applicant for a patent license on the same patent without an application being made by such applicant pursuant to subsection (c), and without separate notification and hearing as provided in subsection (d), and without a separate finding as provided in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd660b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Royalty fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner of the patent affected by a declaration or a finding made by the Commission pursuant to subsection (b) or (e) shall be entitled to a reasonable royalty fee from the licensee for any use of an invention or discovery licensed by this section. Such royalty fee may be agreed upon by such owner and the patent licensee, or in the absence of such agreement shall be determined for each patent license by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2187/c"},"text":"section 2187(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbfd660c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2183/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall apply to any patent the application for which shall have been filed before ","children":[{"tag":"date","attrib":{"date":"1979-09-01"},"text":"September 1, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbfd660d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 153, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-20/ch1073/s1"},"text":"Aug. 20, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/945"},"text":"68 Stat. 945","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/50/s114"},"text":"Pub. L. 86–50, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-23"},"text":"June 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/87"},"text":"73 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/394/s1"},"text":"Pub. L. 88–394, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-01"},"text":"Aug. 1, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/376"},"text":"78 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/161/s1"},"text":"Pub. L. 91–161, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-12-24"},"text":"Dec. 24, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/444"},"text":"83 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/377/s6"},"text":"Pub. L. 93–377, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-17"},"text":"Aug. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/475"},"text":"88 Stat. 475","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbfd660e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbfd660f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbfd6610-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), and (e)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", known as the Atomic Energy Act of 1954, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbfd6611-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in section 1811(c)(1), (2) of this title, prior to the general amendment and renumbering of act ","children":[{"tag":"date","attrib":{"date":"1946-08-01"},"text":"Aug. 1, 1946","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbfd6612-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/377"},"text":"Pub. L. 93–377","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1979-09-01"},"text":"September 1, 1979","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1974-09-01"},"text":"September 1, 1974","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/161"},"text":"Pub. L. 91–161","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1974-09-01"},"text":"September 1, 1974","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1969-09-01"},"text":"September 1, 1969","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/394"},"text":"Pub. L. 88–394","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1969-09-01"},"text":"September 1, 1969","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1964-09-01"},"text":"September 1, 1964","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/50"},"text":"Pub. L. 86–50","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1964-09-01"},"text":"September 1, 1964","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1959-09-01"},"text":"September 1, 1959","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
