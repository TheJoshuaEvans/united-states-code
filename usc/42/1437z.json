{"tag":"section","attrib":{"id":"idbb0a2bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437z"},"text":"§ 1437z.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of information with law enforcement agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, each public housing agency that enters into a contract for assistance under section 1437d or 1437f of this title with the Secretary shall furnish any Federal, State, or local law enforcement officer, upon the request of the officer, with the current address, Social Security number, and photograph (if applicable) of any recipient of assistance under this chapter, if the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0a2bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes the public housing agency with the name of the recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0a2bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notifies the agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0a2bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such recipient—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb0a2bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is fleeing to avoid prosecution, or custody or confinement after conviction, under the laws of the place from which the individual flees, for a crime, or attempt to commit a crime, which is a felony under the laws of the place from which the individual flees, or which, in the case of the State of New Jersey, is a high misdemeanor under the laws of such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb0a2bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is violating a condition of probation or parole imposed under Federal or State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb0a2bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has information that is necessary for the officer to conduct the officer’s official duties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location or apprehension of the recipient is within such officer’s official duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0a2bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437z/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request is made in the proper exercise of the officer’s official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0a2bfb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 28, formerly § 27, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIX/s903/b"},"text":"Pub. L. 104–193, title IX, § 903(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2348"},"text":"110 Stat. 2348","children":[],"tail":"; renumbered § 28, "},{"tag":"ref","attrib":{"href":"/us/pl/105/65/tV/s562/a/1"},"text":"Pub. L. 105–65, title V, § 562(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-27"},"text":"Oct. 27, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1416"},"text":"111 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
