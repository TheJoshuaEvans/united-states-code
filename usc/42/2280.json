{"tag":"section","attrib":{"id":"idbc12e905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2280"},"text":null,"children":[{"tag":"num","attrib":{"value":"2280"},"text":"§ 2280.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever in the judgment of the Commission any person has engaged or is about to engage in any acts or practices which constitute or will constitute a violation of any provision of this chapter, or any regulation or order issued thereunder, the Attorney General on behalf of the United States may make application to the appropriate court for an order enjoining such acts or practices, or for an order enforcing compliance with such provision, and upon a showing by the Commission that such person has engaged or is about to engage in any such acts or practices, a permanent or temporary injunction, restraining order, or other order may be granted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc12e906-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 232, formerly § 230, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/959"},"text":"68 Stat. 959","children":[],"tail":"; renumbered § 232, "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-06/ch1015/s6"},"text":"Aug. 6, 1956, ch. 1015, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1070"},"text":"70 Stat. 1070","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-