{"tag":"section","attrib":{"id":"idbf5320af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11505"},"text":null,"children":[{"tag":"num","attrib":{"value":"11505"},"text":"§ 11505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with CDBG and UDAG programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the policy of the Congress that amounts provided under the community development block grant and urban development action grant programs under title I of the Housing and Community Development Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"42 U.S.C. 5301","children":[],"tail":" et seq.] shall not be reduced in any fiscal year in which the provisions of this chapter are in effect."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf5320b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tVII/s706"},"text":"Pub. L. 100–242, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1964"},"text":"101 Stat. 1964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5320b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5320b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf5320b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Housing and Community Development Act of 1974, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":". Title I of the Housing and Community Development Act of 1974 is classified principally to chapter 69 (§ 5301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"section 5301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
