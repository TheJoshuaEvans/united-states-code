{"tag":"section","attrib":{"id":"idc035910d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321"},"text":null,"children":[{"tag":"num","attrib":{"value":"17321"},"text":"§ 17321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035910e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc035910f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359110-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Energy and Natural Resources, the Committee on Environment and Public Works, and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359111-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean and efficient energy technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clean and efficient energy technology” means an energy supply or end-use technology that, compared to a similar technology already in widespread commercial use in a recipient country, will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359112-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce emissions of greenhouse gases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359113-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0359114-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase efficiency of energy production; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0359115-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decrease intensity of energy usage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359116-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “greenhouse gas” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359117-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon dioxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359118-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methane;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359119-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nitrous oxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035911a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrofluorocarbons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035911b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perfluorocarbons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc035911c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17321/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc035911d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl