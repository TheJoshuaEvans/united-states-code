{"tag":"section","attrib":{"id":"idbcb03aeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4056"},"text":null,"children":[{"tag":"num","attrib":{"value":"4056"},"text":"§ 4056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency implementation of flood insurance program; applicability of other provisions of law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcb03aec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provisions of this chapter, for the purpose of providing flood insurance coverage at the earliest possible time, the Administrator shall carry out the flood insurance program authorized under subchapter I during the period ending on the date specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4026"},"text":"section 4026 of this title","children":[],"tail":", in accordance with the provisions of this part and the other provisions of this chapter insofar as they relate to this part but subject to the modifications made by or under subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb03aed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the flood insurance program pursuant to subsection (a), the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb03aee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4056/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide insurance coverage without regard to any estimated risk premium rates which would otherwise be determined under ","c