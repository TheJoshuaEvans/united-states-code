{"tag":"section","attrib":{"id":"idc07ad71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19101"},"text":null,"children":[{"tag":"num","attrib":{"value":"19101"},"text":"§ 19101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established within the Foundation the Directorate for Technology, Innovation, and Partnerships to advance research and development, technology development, and related solutions to address United States societal, national, and geostrategic challenges, for the benefit of all Americans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc07ad720-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10381"},"text":"Pub. L. 117–167, div. B, title III, § 10381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1576"},"text":"136 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
