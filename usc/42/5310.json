{"tag":"section","attrib":{"id":"idbd441683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310"},"text":null,"children":[{"tag":"num","attrib":{"value":"5310"},"text":"§ 5310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards; rate of wages; exceptions; enforcement powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd441684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All laborers and mechanics employed by contractors or subcontractors in the performance of construction work financed in whole or in part with assistance received under this chapter shall be paid wages at rates not less than those prevailing on similar construction in the locality as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this section shall apply to the rehabilitation of residential property only if such property contains not less than 8 units. The Secretary of Labor shall have, with respect to such labor standards, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (15 F.R. 3176; "},{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":") and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd441685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) shall not apply to any individual that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd441686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs services for which the individual volunteered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd441687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd441688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not receive compensation for such services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd441689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is paid expenses, reasonable benefits, or a nominal fee for such services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd44168a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not otherwise employed at any time in the construction work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd44168b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s110"},"text":"Pub. L. 93–383, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/649"},"text":"88 Stat. 649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s309/j"},"text":"Pub. L. 97–35, title III, § 309(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/397"},"text":"95 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tV/s523"},"text":"Pub. L. 100–242, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1939"},"text":"101 Stat. 1939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIX/s955/a"},"text":"Pub. L. 101–625, title IX, § 955(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4420"},"text":"104 Stat. 4420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd44168c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd44168d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd44168e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 14 of 1950, referred to in subsec. (a), is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd44168f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “sections 3141–3144, 3146, and 3147 of title 40” substituted for “the Davis-Bacon Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":"—276a–5)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/s2"},"text":"section 2 of the Act of June 13, 1934","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/48/948"},"text":"48 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276/c"},"text":"40 U.S.C. 276(c)","children":[],"tail":")”, meaning 276c, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd441690-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":", which directed the substitution of “contains not less than 8 units” for “is designed for residential use of eight or more families”, was executed by making the substitution for “is designed for residential use for eight or more families” as the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “assistance” for “grants”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd441691-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd441692-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" applicable to any volunteer services provided before, on, or after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", except that such amendment may not be construed to require repayment of any wages paid before "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", for services provided before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/s955/d"},"text":"section 955(d) of Pub. L. 101–625","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437j"},"text":"section 1437j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd441693-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s371"},"text":"section 371 of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3701"},"text":"section 3701 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
