{"tag":"section","attrib":{"id":"idbdb8f8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6724"},"text":null,"children":[{"tag":"num","attrib":{"value":"6724"},"text":"§ 6724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State and local government shall use payments made under this subchapter for the maintenance of basic services customarily provided to persons in that State or in the area under the jurisdiction of that local government, as the case may be. State and local governments may not use emergency support payments made under this subchapter for the acquisition of supplies and materials or for construction, except for normal supplies or repairs necessary to maintain basic services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdb8f8c0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tII/s204"},"text":"Pub. L. 94–369, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1006"},"text":"90 Stat. 1006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/447/tII/s201/4"},"text":"Pub. L. 94–447, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1498"},"text":"90 Stat. 1498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tVI/s604"},"text":"Pub. L. 95–30, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/166"},"text":"91 Stat. 166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb8f8c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb8f8c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdb8f8c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" substituted “or for construction, except for normal supplies or repairs necessary to maintain basic services” for “and for construction, unless such supplies and materials or construction are to maintain basic services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/447"},"text":"Pub. L. 94–447","children":[],"tail":" substituted “support payments” for “support grants”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
