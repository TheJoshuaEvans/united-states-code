{"tag":"section","attrib":{"id":"idbf36712f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041"},"text":null,"children":[{"tag":"num","attrib":{"value":"11041"},"text":"§ 11041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf367130-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf367131-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempt any State or local law,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf367132-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), otherwise affect any State or local law or the authority of any State or local government to adopt or enforce any State or local law, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf367133-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect or modify in any way the obligations or liabilities of any person under other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf367134-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on MSDS requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State or local law enacted after ","children":[{"tag":"date","attrib":{"date":"1985-08-01"},"text":"August 1, 1985","children":[],"tail":", which requires the submission of a material safety data sheet from facility owners or operators shall require that the data sheet be identical in content and format to the data sheet required under subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11021"},"text":"section 11021 of this title","children":[],"tail":". In addition, a State or locality may require the submission of information which is supplemental to the information required on the data sheet (including information on the location and quantity of hazardous chemicals present at the facility), through additional sheets attached to the data sheet or such other means as the State or locality considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf367135-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tIII/s321"},"text":"Pub. L. 99–499, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1747"},"text":"100 Stat. 1747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
