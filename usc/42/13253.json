{"tag":"section","attrib":{"id":"idbfb4c973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13253"},"text":null,"children":[{"tag":"num","attrib":{"value":"13253"},"text":"§ 13253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement fuel demand estimates and supply information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb4c974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", and annually thereafter, the Secretary, in consultation with the Administrator, the Secretary of Transportation, and other appropriate State and Federal officials, shall estimate for the following calendar year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb73975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of each type of alternative fueled vehicle likely to be in use in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probable geographic distribution of such vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"