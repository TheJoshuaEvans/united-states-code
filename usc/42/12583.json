{"tag":"section","attrib":{"id":"idbf7b8f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583"},"text":null,"children":[{"tag":"num","attrib":{"value":"12583"},"text":"§ 12583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service program assistance requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7b8f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact on communities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall include an assurance by the applicant that any national service program carried out by the applicant using assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" and any national service program supported by a grant made by the applicant using such assistance will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address unmet human, educational, environmental, or public safety needs through services that provide a direct benefit to the community in which the service is performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the nonduplication and nondisplacement requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":" and the grievance procedure requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12636/f"},"text":"section 12636(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact on participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall also include an assurance by the applicant that any national service program carried out by the applicant using assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" and any national service program supported by a grant made by the applicant using such assistance will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide participants in the national service program with the training, skills, and knowledge necessary for the projects that participants are called upon to perform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide support services to participants, such as the provision of appropriate information and support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to those participants who are completing a term of service and making the transition to other educational and career opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to those participants who are school dropouts in order to assist those participants in earning the equivalent of a high school diploma; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, if appropriate, structured opportunities for participants to reflect on their service experiences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall also include an assurance by the applicant that any national service program carried out by the applicant using assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" and any national service program supported by a grant made by the applicant using such assistance will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide in the design, recruitment, and operation of the program for broad-based input from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community served, the municipality and government of the county (if appropriate) in which the community is located, and potential participants in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based agencies with a demonstrated record of experience in providing services and local labor organizations representing employees of service sponsors, if these entities exist in the area to be served by the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the placement of participants, consult with the appropriate local labor organization, if any, representing employees in the area who are engaged in the same or similar work as that proposed to be carried out by such program to ensure compliance with the nondisplacement requirements specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program that is not funded through a State (including a national service program that a nonprofit organization seeks to operate in 2 or more States), consult with and coordinate activities with the State Commission for each State in which the program will operate, and the Corporation shall obtain confirmation from the State Commission that the applicant seeking assistance under this chapter has consulted with and coordinated with the State Commission when seeking to operate the program in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and performance goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall also include an assurance by the applicant that the applicant will—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b8f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for an independent evaluation of any national service program carried out using assistance provided to the applicant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or, with the approval of the Corporation, conduct an internal evaluation of the program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" apply measurable performance goals and evaluation methods (such as the use of surveys of participants and persons served), which are to be used as part of such evaluation to determine the impact of the program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf7b8f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on communities and persons served by the projects performed by the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7b8f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on participants who take part in the projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7b8f95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such other areas as the Corporation may require; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b8f96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with any evaluation activities undertaken by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), the Corporation shall develop evaluation criteria and performance goals applicable to all national service programs carried out with assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative evaluation requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may establish alternative evaluation requirements for national service programs based upon the amount of assistance received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or received by a grant made by a recipient of assistance under such section. The determination of whether a national service program is covered by this paragraph shall be made in such manner as the Corporation may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Living allowances and other inservice benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594/c"},"text":"section 12594(c) of this title","children":[],"tail":", an application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12582"},"text":"section 12582 of this title","children":[],"tail":" shall also include an assurance by the applicant that the applicant will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b8f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the provision of a living allowance and other benefits specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594"},"text":"section 12594 of this title","children":[],"tail":" to participants in any national service program carried out by the applicant using assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b8f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that each national service program that receives a grant from the applicant using such assistance will also provide a living allowance and other benefits specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12594"},"text":"section 12594 of this title","children":[],"tail":" to participants in the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b8f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12583/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of participants from individuals recruited by Corporation or State Commissions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may also require an assurance by the applicant that any national service program carried out by the applicant using assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" and any national service program supported by a grant made by the applicant using such assistance will select a portion of the participants for the program from among prospective participants recruited by the Corporation or State Commissions under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12592/d"},"text":"section 12592(d) of this title","children":[],"tail":". The Corporation may specify a minimum percentage of participants to be selected from the national leadership pool established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12592/e"},"text":"section 12592(e) of this title","children":[],"tail":" and may vary the percentage for different types of national service programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7b8f9d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s131"},"text":"Pub. L. 101–610, title I, § 131","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/803"},"text":"107 Stat. 803","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1309"},"text":"Pub. L. 111–13, title I, § 1309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1507"},"text":"123 Stat. 1507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7b8f9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7b8f9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf7b8fa0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3127"},"text":"104 Stat. 3127","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"section 12501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf7b8fa1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s131"},"text":"section 131 of Pub. L. 101–610","children":[],"tail":" was renumbered section 199J and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12655j"},"text":"section 12655j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf7b8fa2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1309/1"},"text":"Pub. L. 111–13, § 1309(1)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “the community served and potential participants in the program; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1309/2"},"text":"Pub. L. 111–13, § 1309(2)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “in the case of a program that is not funded through a State, consult with and coordinate activities with the State Commission for the State in which the program operates.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7b8fa3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf7b8fa4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7b8fa5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
