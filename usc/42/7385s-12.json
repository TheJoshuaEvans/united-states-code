{"tag":"section","attrib":{"id":"idbe0eb9ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–12"},"text":"§ 7385s–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum aggregate compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For each individual whose illness or death serves as the basis for compensation or benefits under this part, the total amount of compensation (other than medical benefits) paid under this part, to all persons, in the aggregate, on the basis of that illness or death shall not exceed $250,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0eb9cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3683"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3683]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2184"},"text":"118 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
