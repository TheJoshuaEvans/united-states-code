{"tag":"section","attrib":{"id":"idbe09fece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384l"},"text":"§ 7384l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions for program administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09fecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered employee” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered beryllium employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered employee with cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384r"},"text":"section 7384r of this title","children":[],"tail":", a covered employee with chronic silicosis (as defined in that section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “atomic weapon” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/d"},"text":"section 2014(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “atomic weapons employee” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual employed by an atomic weapons employer during a period when the employer was processing or producing, for the use by the United States, material that emitted radiation and was used in the production of an atomic weapon, excluding uranium mining and milling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual employed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09fed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a facility with respect to which the National Institute for Occupational Safety and Health, in its report dated October 2003 and titled “Report on Residual Radioactive and Beryllium Contamination at Atomic Weapons Employer Facilities and Beryllium Vendor Facilities”, or any update to that report, found that there is a potential for significant residual contamination outside of the period in which weapons-related production occurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09fed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an atomic weapons employer or subsequent owner or operators of a facility described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09fed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period, as specified in such report or any update to such report, of potential for significant residual radioactive contamination at such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09feda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “atomic weapons employer” means an entity, other than the United States, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fedb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processed or produced, for use by the United States, material that emitted radiation and was used in the production of an atomic weapon, excluding uranium mining and milling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fedc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated by the Secretary of Energy as an atomic weapons employer for purposes of the compensation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fedd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “atomic weapons employer facility” means a facility, owned by an atomic weapons employer, that is or was used to process or produce, for use by the United States, material that emitted radiation and was used in the production of an atomic weapon, excluding uranium mining or milling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “beryllium vendor” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fedf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Atomics International.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brush Wellman, Incorporated, and its predecessor, Brush Beryllium Company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Atomics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Electric Company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NGK Metals Corporation and its predecessors, Kawecki-Berylco, Cabot Corporation, BerylCo, and Beryllium Corporation of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nuclear Materials and Equipment Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" StarMet Corporation and its predecessor, Nuclear Metals, Incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wyman Gordan, Incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other vendor, processor, or producer of beryllium or related products designated as a beryllium vendor for purposes of the compensation program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384m"},"text":"section 7384m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered beryllium employee” means the following, if and only if the employee is determined to have been exposed to beryllium in the performance of duty in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384n/a"},"text":"section 7384n(a) of this title","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former employee (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/1"},"text":"section 8101(1) of title 5","children":[],"tail":") who may have been exposed to beryllium at a Department of Energy facility or at a facility owned, operated, or occupied by a beryllium vendor."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09feea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A current or former employee of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09feeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity that contracted with the Department of Energy to provide management and operation, management and integration, or environmental remediation of a Department of Energy facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09feec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contractor or subcontractor that provided services, including construction and maintenance, at such a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09feed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former employee of a beryllium vendor, or of a contractor or subcontractor of a beryllium vendor, during a period when the vendor was engaged in activities related to the production or processing of beryllium for sale to, or use by, the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09feee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered beryllium illness” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09feef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beryllium sensitivity as established by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09fef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an abnormal beryllium lymphocyte proliferation test performed on either blood or lung lavage cells; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09fef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three borderline beryllium lymphocyte proliferation tests performed on blood cells over a period of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Established chronic beryllium disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any injury, illness, impairment, or disability sustained as a consequence of a covered beryllium illness referred to in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered employee with cancer” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual with a specified cancer who is a member of the Special Exposure Cohort, if and only if that individual contracted that specified cancer after beginning employment at a Department of Energy facility (in the case of a Department of Energy employee or Department of Energy contractor employee) or at an atomic weapons employer facility (in the case of an atomic weapons employee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09fef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09fef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual with cancer specified in subclause (I), (II), or (III) of clause (ii), if and only if that individual is determined to have sustained that cancer in the performance of duty in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384n/b"},"text":"section 7384n(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09fef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Clause (i) applies to any of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbe09fef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Energy employee who contracted that cancer after beginning employment at a Department of Energy facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09fefa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Energy contractor employee who contracted that cancer after beginning employment at a Department of Energy facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09fefb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/9/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An atomic weapons employee who contracted that cancer after beginning employment at an atomic weapons employer facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fefc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department of Energy” includes the predecessor agencies of the Department of Energy, including the Manhattan Engineering District.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fefd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Department of Energy contractor employee” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09fefe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is or was in residence at a Department of Energy facility as a researcher for one or more periods aggregating at least 24 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09feff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual who is or was employed at a Department of Energy facility by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that contracted with the Department of Energy to provide management and operating, management and integration, or environmental remediation at the facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor or subcontractor that provided services, including construction and maintenance, at the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Department of Energy facility” means any building, structure, or premise, including the grounds upon which such building, structure, or premise is located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09ff03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which operations are, or have been, conducted by, or on behalf of, the Department of Energy (except for buildings, structures, premises, grounds, or operations covered by Executive Order No. 12344, dated ","children":[{"tag":"date","attrib":{"date":"1982-02-01"},"text":"February 1, 1982","children":[],"tail":", pertaining to the Naval Nuclear Propulsion Program); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with regard to which the Department of Energy has or had—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proprietary interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entered into a contract with an entity to provide management and operation, management and integration, environmental remediation services, construction, or maintenance services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “established chronic beryllium disease” means chronic beryllium disease as established by the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09ff08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For diagnoses on or after ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", beryllium sensitivity (as established in accordance with paragraph (8)(A)), together with lung pathology consistent with chronic beryllium disease, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lung biopsy showing granulomas or a lymphocytic process consistent with chronic beryllium disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a computerized axial tomography scan showing changes consistent with chronic beryllium disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pulmonary function or exercise testing showing pulmonary deficits consistent with chronic beryllium disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For diagnoses before ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the presence of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupational or environmental history, or epidemiologic evidence of beryllium exposure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any three of the following criteria:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbe09ff0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Characteristic chest radiographic (or computed tomography (CT)) abnormalities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09ff10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restrictive or obstructive lung physiology testing or diffusing lung capacity defect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09ff11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lung pathology consistent with chronic beryllium disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09ff12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical course consistent with a chronic respiratory disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe09ff13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/13/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Immunologic tests showing beryllium sensitivity (skin patch test or beryllium blood test preferred).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “member of the Special Exposure Cohort” means a Department of Energy employee, Department of Energy contractor employee, or atomic weapons employee who meets any of the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09ff15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employee was so employed for a number of work days aggregating at least 250 work days before ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"February 1, 1992","children":[],"tail":", at a gaseous diffusion plant located in Paducah, Kentucky, Portsmouth, Ohio, or Oak Ridge, Tennessee, and, during such employment—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was monitored through the use of dosimetry badges for exposure at the plant of the external parts of employee’s body to radiation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" worked in a job that had exposures comparable to a job that is or was monitored through the use of dosimetry badges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee was so employed before ","children":[{"tag":"date","attrib":{"date":"1974-01-01"},"text":"January 1, 1974","children":[],"tail":", by the Department of Energy or a Department of Energy contractor or subcontractor on Amchitka Island, Alaska, and was exposed to ionizing radiation in the performance of duty related to the Long Shot, Milrow, or Cannikin underground nuclear tests."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe09ff1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clause (ii), the employee is an individual designated as a member of the Special Exposure Cohort by the President for purposes of the compensation program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384q"},"text":"section 7384q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe09ff1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/14/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A designation under clause (i) shall, unless Congress otherwise provides, take effect on the date that is 30 days after the date on which the President submits to Congress a report identifying the individuals covered by the designation and describing the criteria used in designating those individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “occupational illness” means a covered beryllium illness, cancer referred to in paragraph (9)(B), specified cancer, or chronic silicosis, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “radiation” means ionizing radiation in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09ff1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alpha particles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beta particles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neutrons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gamma rays; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/16/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerated ions or subatomic particles from accelerator machines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09ff23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “specified cancer” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe09ff24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A specified disease, as that term is defined in section 4(b)(2) of the Radiation Exposure Compensation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2210"},"text":"42 U.S.C. 2210","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bone cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/17/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renal cancers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe09ff27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384l/17/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leukemia (other than chronic lymphocytic leukemia), if initial occupational exposure occurred before 21 years of age and onset occurred more than two years after initial occupational exposure."