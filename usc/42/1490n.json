{"tag":"section","attrib":{"id":"idbb2b9740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490n"},"text":"§ 1490n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb2b9741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication for public comment in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no rule or regulation pursuant to this subchapter may become effective unless it has first been published for public comment in the Federal Register for at least 60 days, and published in final form for at least 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b9742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal to Congressional committee members prior to publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit to the chairman and ranking Member of the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Banking, Finance and Urban Affairs of the House, all rules and regulations at least 15 days before they are sent to the Federal Register for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b9743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations issued on emergency basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not apply to a rule or regulation which the Secretary certifies is issued on an emergency basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2b9744-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include with each rule or regulation required to be transmitted to the Committees under this section a detailed summary of all changes required by the Office of Management and Budget that prohibit, modify, postpone, or disapprove such rule or regulation in whole or part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb2b9745-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 534, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title V, § 523], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1254"},"text":"97 Stat. 1254","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/242/tV/s563/b"},"text":"Pub. L. 100–242, title V, § 563(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1944"},"text":"101 Stat. 1944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb2b9746-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb2b9747-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb2b9748-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242"},"text":"Pub. L. 100–242","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb2b9749-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb2b974a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Banking, Finance and Urban Affairs of House of Representatives treated as referring to Committee on Banking and Financial Services of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Banking and Financial Services of House of Representatives abolished and replaced by Committee on Financial Services of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred from Committee on Energy and Commerce of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
