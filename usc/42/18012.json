{"tag":"section","attrib":{"id":"idc043e8c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18012"},"text":null,"children":[{"tag":"num","attrib":{"value":"18012"},"text":"§ 18012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rating reforms must apply uniformly to all health insurance issuers and group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any standard or requirement adopted by a State pursuant to this title,","children":[{"tag":"ref","attrib":{"idref":"fn004298"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004298"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or any amendment made by this title,"},{"tag":"ref","attrib":{"idref":"fn004298"},"text":"1","children":[],"tail":" shall be applied uniformly to all health plans in each insurance market to which the standard and requirements apply. The preceding sentence shall also apply to a State standard or requirement relating to the standard or requirement required by this title "},{"tag":"ref","attrib":{"idref":"fn004298"},"text":"1","children":[],"tail":" (or any such amendment) that is not the same as the standard or requirement but that is not preempted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18041/d"},"text":"section 18041(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc043e8c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1252"},"text":"Pub. L. 111–148, title I, § 1252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/162"},"text":"124 Stat. 162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote