{"tag":"section","attrib":{"id":"idbd4ffd99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407"},"text":null,"children":[{"tag":"num","attrib":{"value":"5407"},"text":"§ 5407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, testing, development, and training by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4ffd9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct research, testing, development, and training necessary to carry out the purposes of this chapter, including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4ffd9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting data from any source for the purpose of determining the relationship between manufactured home performance characteristics and (A) accidents involving manufactured homes, and (B) the occurrence of death, personal injury, or damage resulting from such accidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procuring (by negotiation or otherwise) experimental and other manufactured homes for research and testing purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling or otherwise disposing of test manufactured homes and reimbursing the proceeds of such sale or disposal into the current appropriation available for the purpose of carrying out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the government-sponsored housing entities to actively develop and implement secondary market securitization programs for the FHA manufactured home loans and those of other loan programs, as appropriate, thereby promoting the availability of affordable manufactured homes to increase homeownership for all people in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffd9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the programs for FHA manufactured home loans and developing any changes to such programs to promote the affordability of manufactured homes, including changes in loan terms, amortization periods, regulations, and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4ffda0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and grants with States, interstate agencies, and independent institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to conduct research, testing, development, and training as authorized to be carried out by subsection (a) of this section by contracting for or making grants for the conduct of such research, testing, development, and training to States, interstate agencies, and independent institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4ffda1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4ffda2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government-sponsored housing entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “government-sponsored housing entities” means the Government National Mortgage Association of the Department of Housing and Urban Development, the Federal National Mortgage Association, and the Federal Home Loan Mortgage Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4ffda3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FHA manufactured home loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “FHA manufactured home loan” means a loan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4ffda4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is insured under title I of the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1702"},"text":"12 U.S.C. 1702","children":[],"tail":" et seq.] and is made for the purpose of financing alterations, repairs, or improvements on or in connection with an existing manufactured home, the purchase of a manufactured home, the purchase of a manufactured home and a lot on which to place the home, or the purchase only of a lot on which to place a manufactured home; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd526da5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5407/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise insured under the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"12 U.S.C. 1701","children":[],"tail":" et seq.] and made for or in connection with a manufactured home."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd526da6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s608"},"text":"Pub. L. 93–383, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/704"},"text":"88 Stat. 704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s339B/c"},"text":"Pub. L. 97–35, title III, § 339B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/417"},"text":"95 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s607"},"text":"Pub. L. 106–569, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3009"},"text":"114 Stat. 3009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd526da7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd526da8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd526da9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Housing Act, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1246"},"text":"48 Stat. 1246","children":[],"tail":", which is classified principally to chapter 13 (§ 1701 et seq.) of Title 12, Banks and Banking. Title I of the Act is classified generally to subchapter I (§ 1702 et seq.) of chapter 13 of Title 12. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd526daa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to “mobile homes”, wherever appearing in subsec. (a)(1) to (3), changed to “manufactured homes” in view of the amendment of title VI of the Housing and Community Development Act of 1974 (this chapter) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s308/c/4"},"text":"section 308(c)(4) of Pub. L. 96–399","children":[],"tail":" requiring the substitution of “manufactured home” for “mobile home” wherever appearing in title VI of the Housing and Community Development Act of 1974, and "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s339B/c"},"text":"section 339B(c) of Pub. L. 97–35","children":[],"tail":" (set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1703"},"text":"section 1703 of Title 12","children":[],"tail":", Banks and Banking) providing that the terms “mobile home” and “manufactured home” shall be deemed to include the terms “mobile homes” and “manufactured homes”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd526dab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s607/a"},"text":"Pub. L. 106–569, § 607(a)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s607/b"},"text":"Pub. L. 106–569, § 607(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd526dac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd526dad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", except that amendment has no effect on any order or interpretative bulletin issued under this chapter and published as a proposed rule pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"5 U.S.C. 553","children":[],"tail":" on or before "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s612"},"text":"section 612 of Pub. L. 106–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd526dae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of 180 days following ","children":[{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/s627"},"text":"section 627 of Pub. L. 93–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
