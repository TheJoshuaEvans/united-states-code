{"tag":"section","attrib":{"id":"idbfa1b5b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808"},"text":null,"children":[{"tag":"num","attrib":{"value":"12808"},"text":"§ 12808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second mortgage assistance for first-time homebuyers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b5b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program under which units of general local government provide loans (secured by second mortgages) with deferred payment of interest and principal to first-time homebuyers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeownership counseling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under this section shall provide for homeownership counseling to first-time homebuyers assisted, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling before and after purchase of the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting first-time homebuyers in identifying the most suitable and affordable properties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing homebuyers with financial management assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting homebuyers in understanding mortgage transactions and home sales contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting homebuyers with eliminating any credit problems that may prevent the homebuyers from purchasing the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Deferred payment loans secured by second mortgages may be provided under the model program under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the homebuyer assisted is a first-time homebuyer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property secured by the second mortgage is a single-family residence and is the principal residence of the homebuyer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal obligation of the deferred payment loan secured by a second mortgage does not exceed 30 percent of the acquisition price of the residence to the homebuyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of deferral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment of any principal and interest on a loan under this section shall be deferred for not less than the 5-year period beginning on the date of the acquisition of the residence by the homebuyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rate on the unpaid balance of a loan under this section shall be at least 4 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A deferred payment loan secured by a second mortgage shall be repayable over the 15-year period beginning at the end of the deferral period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12808/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A deferred payment loan assisted with amount ","children":[{"tag":"ref","attrib":{"idref":"fn004116"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004116"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “amounts”."}],"tail":" provided under a grant under this section shall be secured by a lien on the property involved, which lien shall be subordinate to the first mortgage on the property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5c4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s258"},"text":"Pub. L. 101–625, title II, § 258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4123"},"text":"104 Stat. 4123","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
