{"tag":"section","attrib":{"id":"idc029aaa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17143"},"text":null,"children":[{"tag":"num","attrib":{"value":"17143"},"text":"§ 17143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government efficiency status reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aaa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal agency subject to any of the requirements of this title ","children":[{"tag":"ref","attrib":{"idref":"fn004259"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004259"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or the amendments made by this title "},{"tag":"ref","attrib":{"idref":"fn004259"},"text":"1","children":[],"tail":" shall compile and submit to the Director of the Office of Management and Budget an annual Government efficiency status report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aaaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance by the agency with each of the requirements of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and the amendments made by this title; "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aaab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":nu