{"tag":"section","attrib":{"id":"idbeffa921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858j"},"text":"§ 9858j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports, hotline, and Web site","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeffa922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-07-31"},"text":"July 31, 2016","children":[],"tail":", and biennially thereafter, the Secretary shall prepare and submit to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate a report that contains a summary and analysis of the data and information provided to the Secretary in the State reports submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858i"},"text":"section 9858i of this title","children":[],"tail":". Such report shall include an assessment, and where appropriate, recommendations for the Congress concerning efforts that should be undertaken to improve the access of the public to quality and affordable child care in the United States. Such report shall contain a determination around whether each State that uses amounts provided under this subchapter has complied with the priority for services described in sections 9858c(c)(2)(Q) and 9858c(c)(3)(B) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeffa923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National toll-free hotline and Web site","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeffa924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall operate, directly or through the use of grants or contracts, a national toll-free hotline and Web site, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and disseminate publicly available child care consumer education information for parents and help parents access safe and quality child care services in their community, with a range of price options, that best suits ","children":[{"tag":"ref","attrib":{"idref":"fn003912"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003912"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “suit”."}],"tail":" their family’s needs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow persons to report (anonymously if desired) suspected child abuse or neglect, or violations of health and safety requirements, by an eligible child care provider that receives assistance under this subchapter or a member of the provider’s staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the hotline and Web site meet the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeffa928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to local child care providers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Web site shall be hosted by “childcare.gov”. The Web site shall enable a child care consumer to enter a zip code and obtain a referral to local child care providers described in subparagraph (B) within a specified search radius.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Web site shall provide to consumers, directly or through linkages to State databases, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeffa92a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a localized list of all eligible child care providers, differentiating between licensed and license-exempt providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa92b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provider-specific information from a Quality Rating and Improvement System or information about other quality indicators, to the extent the information is publicly available and to the extent practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provider-specific information about compliance with licensing, and health and safety requirements to the extent the information is publicly available and to the extent practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals to local resource and referral organizations from which consumers can find more information about child care providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeffa92e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State information about child care subsidy programs and other financial supports available to families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa92f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Web site and hotline shall have the capacity to help families in every State and community in the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information at all hours","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Web site shall provide, to parents and families, access to information about child care services 24 hours a day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services in different languages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Web site and hotline shall ensure the widest possible access to services for families who speak languages other than English.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeffa932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-quality consumer education and referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Web site and hotline shall ensure that families have access to easy-to-understand child care consumer education and referral services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeffa933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to allow the Secretary to compel States to provide additional data and information that is currently (as of ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":") not publicly available, or is not required by this subchapter, unless such additional data are related to the purposes and scope of this subchapter, and are subject to a notice and comment period of no less than 90 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeffa934-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658L"},"text":"Pub. L. 97–35, title VI, § 658L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-244"},"text":"104 Stat. 1388–244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s612"},"text":"Pub. L. 104–193, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2285"},"text":"110 Stat. 2285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5602/3"},"text":"Pub. L. 105–33, title V, § 5602(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/646"},"text":"111 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s8/d"},"text":"Pub. L. 113–186, § 8(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1997"},"text":"128 Stat. 1997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeffa935-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeffa936-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeffa937-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186"},"text":"Pub. L. 113–186","children":[],"tail":" substituted “Reports, hotline, and Web site” for “Report by Secretary” in section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “2016” for “1998” and “to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate” for “to the Committee on Economic and Educational Opportunities of the House of Representatives and the Committee on Labor and Human Resources of the Senate”, inserted at end of subsec. (a) “Such report shall contain a determination around whether each State that uses amounts provided under this subchapter has complied with the priority for services described in sections 9858c(c)(2)(Q) and 9858c(c)(3)(B) of this title.”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" substituted “1998” for “1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1997-07-31"},"text":"July 31, 1997","children":[],"tail":", and biennially thereafter” for “"},{"tag":"date","attrib":{"date":"1993-07-31"},"text":"July 31, 1993","children":[],"tail":", and annually thereafter” and “Committee on Economic and Educational Opportunities” for “Committee on Education and Labor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbeffa938-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbeffa939-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title VI of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5603"},"text":"section 5603 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s618"},"text":"section 618 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbeffa93a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s615"},"text":"section 615 of Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
