{"tag":"section","attrib":{"id":"idc00ab075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16298a"},"text":"§ 16298a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon utilization program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program of research, development, and demonstration for carbon utilization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assess and monitor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential changes in lifecycle carbon dioxide and other greenhouse gas emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other environmental safety indicators of new technologies, practices, processes, or methods used in enhanced hydrocarbon recovery as part of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16293"},"text":"section 16293 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab07a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and assess novel uses for carbon, including the conversion of carbon and carbon oxides for commercial and industrial products and other products with potential market value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab07b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or obtain, in coordination with other applicable Federal agencies and standard-setting organizations, standards and certifications, as appropriate, to facilitate the commercialization of the products and technologies described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab07c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and assess carbon capture technologies for industrial systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab07d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and assess alternative uses for raw coal and processed coal products in all phases that result in no significant emissions of carbon dioxide or other pollutants, including products derived from carbon engineering, carbon fiber, and coal conversion methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab07e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration programs for the purpose of commercialization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab07f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", as part of the program established under subsection (a), the Secretary shall establish a 2-year demonstration program in each of the 2 major coal-producing regions of the United States for the purpose of partnering with private institutions in coal mining regions to accelerate the commercial deployment of coal-carbon products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall establish a program to provide grants to eligible entities to use in accordance with subparagraph (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this paragraph, an entity shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public utility or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible entities desiring a grant under this paragraph shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall use a grant received under this paragraph to procure and use commercial or industrial products that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use or are derived from anthropogenic carbon oxides; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate significant net reductions in lifecycle greenhouse gas emissions compared to incumbent technologies, processes, and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab08a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under this subsection shall be subject to the cost-sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab08b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon Utilization Research Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab08c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary shall establish and operate a national Carbon Utilization Research Center (referred to in this subsection as the “Center”), which shall focus on early stage research and development activities including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab08d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-combustion and pre-combustion capture of carbon dioxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab08e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced compression technologies for new and existing fossil fuel-fired power plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab08f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies to convert carbon dioxide to valuable products and commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced carbon dioxide storage technologies that consider a range of storage regimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the Center under this subsection on a competitive, merit-reviewed basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applications from the National Laboratories, institutions of higher education, multiinstitutional collaborations, and other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting the Center under this subsection, the Secretary shall prioritize carbon utilization research centers in existence on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center established under this subsection shall receive support for a period of not more than 5 years, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the expiration of any period of support of the Center, the Secretary may renew support for the Center, on a merit-reviewed basis, for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the existing authorities of the Department, the Secretary may terminate the Center for cause during the performance period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $41,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab09a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $65,250,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab09b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $66,562,500 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $67,940,625 for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $69,387,656 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the activities authorized in this section with the activities authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16298"},"text":"section 16298 of this title","children":[],"tail":" as part of one consolidated program at the Department. Nothing in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16298"},"text":"section 16298 of this title","children":[],"tail":" shall be construed as limiting the authorities provided in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab09f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s969A"},"text":"Pub. L. 109–58, title IX, § 969A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4004/a/1"},"text":"Pub. L. 116–260, div. Z, title IV, § 4004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2539"},"text":"134 Stat. 2539","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40302"},"text":"Pub. L. 117–58, div. D, title III, § 40302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/987"},"text":"135 Stat. 987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00ab0a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00ab0a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00ab0a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40302/1"},"text":"Pub. L. 117–58, § 40302(1)","children":[],"tail":", added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40302/2"},"text":"Pub. L. 117–58, § 40302(2)","children":[],"tail":", added par. (2), redesignated former par. (2) as (3), and, in par. (3), substituted “this subsection” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40302/3"},"text":"Pub. L. 117–58, § 40302(3)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which provided appropriations for fiscal years 2021 to 2025."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc00ab0a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc00ab0a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
