{"tag":"section","attrib":{"id":"idbf1776dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173"},"text":null,"children":[{"tag":"num","attrib":{"value":"10173"},"text":"§ 10173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1776de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may enter into a benefits agreement with the State of Nevada concerning a repository or with a State or an Indian tribe concerning a monitored retrievable storage facility for the acceptance of high-level radioactive waste or spent nuclear fuel in that State or on the reservation of that tribe, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State or Indian tribe may enter into such an agreement only if the State Attorney General or the appropriate governing authority of the Indian tribe or the Secretary of the Interior, in the absence of an appropriate governing authority, as appropriate, certifies to the satisfaction of the Secretary that the laws of the State or Indian tribe provide adequate authority for that entity to enter into the benefits agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any benefits agreement with a State under this section shall be negotiated in consultation with affected units of local government in such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits and payments under this part may be made available only in accordance with a benefits agreement under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A benefits agreement entered into under subsection (a) may be amended only by the mutual consent of the parties to the agreement and terminated only in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10173c"},"text":"section 10173c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with Nevada","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer to enter into a benefits agreement with the Governor of Nevada. Any benefits agreement with a State under this subsection shall be negotiated in consultation with any affected units of local government in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitored retrievable storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer to enter into a benefits agreement relating to a monitored retrievable storage facility with the governing body of the Indian tribe on whose reservation the site for such facility is located, or, if the site is not located on a reservation, with the Governor of the State in which the site is located and in consultation with affected units of local government in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only one benefits agreement for a repository and only one benefits agreement for a monitored retrievable storage facility may be in effect at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Secretary under this section are not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1776e8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s170"},"text":"Pub. L. 97–425, title I, § 170","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5031"},"text":"Pub. L. 100–203, title V, § 5031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-237"},"text":"101 Stat. 1330–237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1776e9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1776ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1776eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
