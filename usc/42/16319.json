{"tag":"section","attrib":{"id":"idc00d2184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319"},"text":null,"children":[{"tag":"num","attrib":{"value":"16319"},"text":"§ 16319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy and water supplies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d2185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program of research, development, demonstration, and commercial application to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address energy-related issues associated with provision of adequate water supplies, optimal management, and efficient use of water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address water-related issues associated with the provision of adequate supplies, optimal management, and efficient use of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of existing programs within the Department and other Federal agencies to address these energy and water related issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d218a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arsenic treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d218b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desalination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d218c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, analysis, and modeling of energy and water supply and demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d218d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the Administrator of the Environmental Protection Agency, the Secretary of the Interior, the Chief Engineer of the Army Corps of Engineers, the Secretary of Commerce, the Secretary of Defense, and other Federal agencies as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d218e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may utilize all existing facilities within the Department and may design and construct additional facilities as needed to carry out the purposes of this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d218f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish or utilize an advisory committee to provide independent advice and review of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16319/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall submit to Congress a report on the assessment described in subsection (b) and recommendations for future actions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d2191-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s979"},"text":"Pub. L. 109–58, title IX, § 979","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/905"},"text":"119 Stat. 905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
