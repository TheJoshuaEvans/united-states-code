{"tag":"section","attrib":{"id":"idbf5c95cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004"},"text":null,"children":[{"tag":"num","attrib":{"value":"12004"},"text":"§ 12004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency authorizations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for the following energy efficiency research, development, and demonstration programs: transportation, industrial, buildings and community systems, multi-sector, and policy and management—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5c95d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not to exceed $201,100,000 for fiscal year 1991, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed $68,300,000 shall be available for the transportation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed $53,500,000 shall be available for the industrial program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5c95d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not to exceed $210,600,000 for fiscal year 1992, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf5c95d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed $71,000,000 shall be available for the transportation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf5c95d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12004/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed $54,700,000 shall be available for the industrial program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5c95d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/218/s5"},"text":"Pub. L. 101–218, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1862"},"text":"103 Stat. 1862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2125/4"},"text":"Pub. L. 102–486, title XXI, § 2125(4)","children":[],"tail":"–(6), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3085"},"text":"106 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5c95d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5c95d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5c95d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" struck out par. (3) which read as follows: “not to exceed $225,000,000 for fiscal year 1993, of which—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) not to exceed $73,900,000 shall be available for the transportation program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not to exceed $56,900,000 shall be available for the industrial program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
