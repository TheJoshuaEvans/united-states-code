{"tag":"section","attrib":{"id":"idbf938594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655i"},"text":"§ 12655i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age and citizenship criteria for enrollment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf938595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age and citizenship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Enrollment in programs that receive assistance under this division shall be limited to individuals who, at the time of enrollment, are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 16 years nor more than 25 years of age, except that summer programs may include individuals not less than 14 years nor more than 21 years of age at the time of the enrollment of such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citizens or nationals of the United States or lawful permanent resident aliens of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of disadvantaged youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs that receive assistance under this division shall ensure that educationally and economically disadvantaged youth, including youth in foster care who are becoming too old for foster care, youth with disabilities, youth with limited English proficiency, youth with limited basic skills or learning disabilities and homeless youth, are offered opportunities to enroll.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf938599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special corps members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a)(1), program agencies may enroll a limited number of special corps members over age 25 so that the corps may draw on their special skills to fulfill the purposes of this chapter. Programs are encouraged to consider senior citizens as special corps members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93859a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint projects with senior citizens organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Program agencies shall use not more than 2 percent of amounts received under this division to conduct joint projects with senior citizens organizations to enable senior citizens to serve as mentors for youth participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93859b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) shall be construed to prohibit any program agency from limiting enrollment to any age subgroup within the range specified in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf93859c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199I"},"text":"Pub. L. 101–610, title I, § 199I","children":[],"tail":", formerly § 130, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3146"},"text":"104 Stat. 3146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s6"},"text":"Pub. L. 102–384, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1456"},"text":"106 Stat. 1456","children":[],"tail":"; renumbered § 199J, renumbered § 199I, "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (e)(8)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":", 816.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf93859d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf93859e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf93859f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3127"},"text":"104 Stat. 3127","children":[],"tail":", known as the National and Community Service Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12501"},"text":"section 12501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf9385a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12550"},"text":"section 12550 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/a"},"text":"Pub. L. 103–82, § 101(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf9385a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/384"},"text":"Pub. L. 102–384","children":[],"tail":" substituted “14” for “15”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
