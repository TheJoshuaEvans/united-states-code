{"tag":"section","attrib":{"id":"idb541756b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–15"},"text":"§ 280g–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State demonstration programs to evaluate alternatives to current medical tort litigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb541756c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award demonstration grants to States for the development, implementation, and evaluation of alternatives to current tort litigation for resolving disputes over injuries allegedly caused by health care providers or health care organizations. In awarding such grants, the Secretary shall ensure the diversity of the alternatives so funded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb541756d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants under subsection (a) for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb541756e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for demonstration grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb541756f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State desiring a grant under subsection (a) shall develop an alternative to current tort litigation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5417570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for the resolution of disputes over injuries allegedly caused by health care providers or health care organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes a reduction of health care errors by encouraging the collection and analysis of patient safety data related to disputes resolved under subparagraph (A) by organizations that engage in efforts to improve patient safety and the quality of health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative to current tort litigation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State desiring a grant under subsection (a) shall demonstrate how the proposed alternative described in paragraph (1)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5417573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the medical liability system more reliable by increasing the availability of prompt and fair resolution of disputes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages the efficient resolution of disputes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages the disclosure of health care errors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhances patient safety by detecting, analyzing, and helping to reduce medical errors and adverse events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves access to liability insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully informs patients about the differences in the alternative and current tort litigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides patients the ability to opt out of or voluntarily withdraw from participating in the alternative at any time and to pursue other options, including litigation, outside the alternative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb541757a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not conflict with State law at the time of the application in a way that would prohibit the adoption of an alternative to current tort litigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb541757b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not limit or curtail a patient’s existing legal rights, ability to file a claim in or access a State’s legal system, or otherwise abrogate a patient’s ability to file a medical malpractice claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb541757c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State desiring a grant under subsection (a) shall identify the sources from and methods by which compensation would be paid for claims resolved under the proposed alternative to current tort litigation, which may include public or private funding sources, or a combination of such sources. Funding methods shall to the extent practicable provide financial incentives for activities that improve patient safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb541757d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb541757e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State desiring a grant under subsection (a) shall establish a scope of jurisdiction (such as Statewide, designated geographic region, a designated area of health care practice, or a designated group of health care providers or health care organizations) for the proposed alternative to current tort litigation that is sufficient to evaluate the effects of the alternative. No scope of jurisdiction shall be established under this paragraph that is based on a health care payer or patient population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb541757f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of patients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall demonstrate how patients would be notified that they are receiving health care services that fall within such scope, and the process by which they may opt out of or voluntarily withdraw from participating in the alternative. The decision of the patient whether to participate or continue participating in the alternative process shall be made at any time and shall not be limited in any way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in awarding demonstration grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Secretary shall give preference to States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5417581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have developed the proposed alternative through substantive consultation with relevant stakeholders, including patient advocates, health care providers and health care organizations, attorneys with expertise in representing patients and health care providers, medical malpractice insurers, and patient safety experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that make proposals that are likely to enhance patient safety by detecting, analyzing, and helping to reduce medical errors and adverse events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that make proposals that are likely to improve access to liability insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5417585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State desiring a grant under subsection (a) shall submit to the Secretary an application, at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5417587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing applications under paragraph (1), the Secretary shall consult with a review panel composed of relevant experts appointed by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5417589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall solicit nominations from the public for individuals to serve on the review panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb541758a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall appoint, at least 9 but not more than 13, highly qualified and knowledgeable individuals to serve on the review panel and shall ensure that the following entities receive fair representation on such panel:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb541758b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patient advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb541758c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health care providers and health care organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb541758d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attorneys with expertise in representing patients and health care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb541758e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical malpractice insurers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb541758f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5417590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patient safety experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall designate a member of the review panel to be the chairperson of the review panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the review panel such information, personnel, and administrative services and assistance as the review panel may reasonably require to carry out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5417593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The review panel may request directly from any department or agency of the United States any information that such panel considers necessary to carry out its duties. To the extent consistent with applicable laws and regulations, the head of such department or agency shall furnish the requested information to the review panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5417595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State receiving a grant under subsection (a) shall submit to the Secretary an annual report evaluating the effectiveness of activities funded with grants awarded under such subsection. Such report shall, at a minimum, include the impact of the activities funded on patient safety and on the availability and price of medical liability insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to Congress an annual compendium of the reports submitted under paragraph (1) and an analysis of the activities funded under subsection (a) that examines any differences that result from such activities in terms of the quality of care, number and nature of medical errors, medical resources used, length of time for dispute resolution, and the availability and price of liability insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5417597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5417598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance to the States applying for or awarded grants under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5417599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Technical assistance under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb541759a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on non-economic damages, including the consideration of individual facts and circumstances in determining appropriate payment, guidance on identifying avoidable injuries, and guidance on disclosure to patients of health care errors and adverse events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb541759b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, in consultation with States, of common definitions, formats, and data collection infrastructure for States receiving grants under this section to use in reporting to facilitate aggregation and analysis of data both within and between States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb541759c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of common definitions, formats, and data collection infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States not receiving grants under this section may also use the common definitions, formats, and data collection infrastructure developed under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb541759d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb541759e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the review panel established under subsection (d)(2), shall enter into a contract with an appropriate research organization to conduct an overall evaluation of the effectiveness of grants awarded under subsection (a) and to annually prepare and submit a report to Congress. Such an evaluation shall begin not later than 18 months following the date of implementation of the first program funded by a grant under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb541759f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effects of the grants awarded under subsection (a) with regard to the measures described in paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each State, an analysis of the extent to which the alternative developed under subsection (c)(1) is effective in meeting the elements described in subsection (c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison among the States receiving grants under subsection (a) of the effectiveness of the various alternatives developed by such States under subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison, considering the measures described in paragraph (3), of States receiving grants approved under subsection (a) and similar States not receiving such grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a comparison, with regard to the measures described in paragraph (3), of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54175a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States receiving grants under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54175a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that enacted, prior to ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", any cap on non-economic damages; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54175a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that have enacted, prior to ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", a requirement that the complainant obtain an opinion regarding the merit of the claim, although the substance of such opinion may have no bearing on whether the complainant may proceed with a case."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluations under paragraph (2) shall analyze and make comparisons on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and number of disputes over injuries allegedly caused by health care providers or health care organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and number of claims in which tort litigation was pursued despite the existence of an alternative under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of disputes and claims, including the length of time and estimated costs to all parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical liability environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient safety in terms of detecting, analyzing, and helping to reduce medical errors and adverse events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient and health care provider and organization satisfaction with the alternative under subsection (a) and with the medical liability environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impact on utilization of medical services, appropriately adjusted for risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve 5 percent of the amount appropriated in each fiscal year under subsection (k) to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MedPAC and MACPAC reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MedPAC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Medicare Payment Advisory Commission shall conduct an independent review of the alternatives to current tort litigation that are implemented under grants under subsection (a) to determine the impact of such alternatives on the Medicare program under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.], and its beneficiaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MACPAC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Medicaid and CHIP Payment and Access Commission shall conduct an independent review of the alternatives to current tort litigation that are implemented under grants under subsection (a) to determine the impact of such alternatives on the Medicaid or CHIP programs under titles XIX and XXI of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq., 1397aa et seq.], and their beneficiaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", the Medicare Payment Advisory Commission and the Medicaid and CHIP Payment and Access Commission shall each submit to Congress a report that includes the findings and recommendations of each respective Commission based on independent reviews conducted under paragraphs (1) and (2), including an analysis of the impact of the alternatives reviewed on the efficiency and effectiveness of the respective programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to provide for initial planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated pursuant to subsection (k), the Secretary may use a portion not to exceed $500,000 per State to provide planning grants to such States for the development of demonstration project applications meeting the criteria described in subsection (c). In selecting States to receive such planning grants, the Secretary shall give preference to those States in which State law at the time of the application would not prohibit the adoption of an alternative to current tort litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54175b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health care services” means any services provided by a health care provider, or by any individual working under the supervision of a health care provider, that relate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis, prevention, or treatment of any human disease or impairment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of the health of human beings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care organization” means any individual or entity which is obligated to provide, pay for, or administer health benefits under any health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54175bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health care provider” means any individual or entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54175bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed, registered, or certified under Federal or State laws or regulations to provide health care services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54175be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to be so licensed, registered, or certified but that is exempted by other statute or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, $50,000,000 for the 5-fiscal year period beginning with fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current State efforts to establish alternative to tort litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit any prior, current, or future efforts of any State to establish any alternative to tort litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54175c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–15/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as limiting states’ ","children":[{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"t