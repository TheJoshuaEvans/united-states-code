{"tag":"section","attrib":{"id":"idbda12a62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6372e"},"text":"§ 6372e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda12a63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to States and to units of local government and public care institutions in payment of technical assistance program costs for buildings owned by units of local government and public care institutions the applications for which have been approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6372d"},"text":"section 6372d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available for purposes of this section (together with any amounts available for such purposes from other Federal sources) may not be used to pay more than 50 percent of technical assistance program costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this section in any State in any year shall be made in accordance with the requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6372g"},"text":"section 6372g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda12a66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6372e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription of rules limiting allocations to States for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe rules limiting the amount of funds allocated to a State which may be expended for administrative expenses by such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda12a67-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400F"},"text":"Pub. L. 94–163, title III, § 400F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tIII/s311/a"},"text":"Pub. L. 95–619, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3252"},"text":"92 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
