{"tag":"section","attrib":{"id":"idb5d57816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t"},"text":null,"children":[{"tag":"num","attrib":{"value":"292t"},"text":"§ 292t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals from disadvantaged backgrounds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d57817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund agreements regarding certain amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to amounts appropriated under subsection (f), each agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q"},"text":"section 292q of this title","children":[],"tail":" with a school shall provide (in addition to the provisions required in subsection (b) of such section) that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any Federal capital contribution made to the student loan fund of the school from such amounts, together with the school contribution appropriate under subsection (b)(2)(B) of such section to the amount of the Federal capital contribution, will be utilized only for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d57819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making loans to individuals from disadvantaged backgrounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d5781a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the collection of the loans and interest on the loans; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d5781b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collections of principal and interest on loans made pursuant to paragraph (1), and any other earnings of the student loan fund attributable to amounts that are in the fund pursuant to such paragraph, will be utilized only for the purpose described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5781c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum qualifications for schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a Federal capital contribution for purposes of subsection (a) for a fiscal year unless the health professions school involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d5781d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carrying out a program for recruiting and retaining students from disadvantaged backgrounds, including racial and ethnic minorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d5781e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carrying out a program for recruiting and retaining minority faculty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5781f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain agreements regarding education of students; date certain for compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a Federal capital contribution for purposes of subsection (a) for a fiscal year unless the health professions school involved agrees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that adequate instruction regarding minority health issues is provided for in the curricula of the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to health clinics providing services to a significant number of individuals who are from disadvantaged backgrounds, including members of minority groups, to enter into arrangements with 1 or more such clinics for the purpose of providing students of the school with experience in providing clinical services to such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to public or nonprofit private secondary educational institutions and undergraduate institutions of higher education, to enter into arrangements with 1 or more such institutions for the purpose of carrying out programs regarding the educational preparation of disadvantaged students, including minority students, to enter the health professions and regarding the recruitment of such individuals into the health professions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a mentor program for assisting disadvantaged students, including minority students, regarding the completion of the educational requirements for degrees from the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be carrying out each of the activities specified in any of paragraphs (1) through (4) by not later than 1 year after the date on which the first Federal capital contribution is made to the school for purposes of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue carrying out such activities, and the activities specified in paragraphs (1) and (2) of subsection (b), throughout the period during which the student loan fund established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b"},"text":"section 292q(b) of this title","children":[],"tail":" is in operation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d57826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of other amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to Federal capital contributions to student loan funds under agreements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q/b"},"text":"section 292q(b) of this title","children":[],"tail":", any such contributions made before "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", together with the school contributions appropriate under paragraph (2)(B) of such section to the amount of the Federal capital contributions, may be utilized for the purpose of making loans to individuals from disadvantaged backgrounds, subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292s/a/2/B"},"text":"section 292s(a)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d57827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Disadvantaged” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “disadvantaged”, with respect to an individual, shall be defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d57828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s132/b"},"text":"Pub. L. 105–392, title I, § 132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3575"},"text":"112 Stat. 3575","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d5782a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292t/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration for certain schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making Federal capital contributions to student loan funds for purposes of subsection (a), the Secretary shall give special consideration to health professions schools that have enrollments of underrepresented minorities above the national average for health professions schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d5782b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 724, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2018"},"text":"106 Stat. 2018","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s132"},"text":"Pub. L. 105–392, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3575"},"text":"112 Stat. 3575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d5782c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d5782d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d5782e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 724 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s293d"},"text":"section 293d of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5d5782f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s132/b"},"text":"Pub. L. 105–392, § 132(b)","children":[],"tail":", struck out heading and text of par. (1). Text read as follows: “With respect to making Federal capital contributions to student loan funds for purposes of subsection (a) of this section, there is authorized to be appropriated for such contributions $8,000,000 for each of the fiscal years 1998 through 2002.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s132/a"},"text":"Pub. L. 105–392, § 132(a)","children":[],"tail":", substituted “$8,000,000 for each of the fiscal years 1998 through 2002” for “$15,000,000 for fiscal year 1993”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5d57830-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5d57831-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s132/b"},"text":"Pub. L. 105–392, title I, § 132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3575"},"text":"112 Stat. 3575","children":[],"tail":", provided that the repeal of subsec. (f)(1) of this section is effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
