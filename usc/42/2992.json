{"tag":"section","attrib":{"id":"idbc31e273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992"},"text":null,"children":[{"tag":"num","attrib":{"value":"2992"},"text":"§ 2992.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc31e274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description and measurement of project impact, effectiveness, and structure and mechanisms for delivery of services; frequency of evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner shall provide, directly or through grants or contracts, for the evaluation of projects assisted under this subchapter including evaluations that describe and measure the impact of such projects, their effectiveness in achieving stated goals, their impact on related programs, and their structure and mechanisms for delivery of services, including, where appropriate, comparisons with appropriate control groups composed of persons who have not participated in such projects. Evaluations shall be conducted by persons not directly involved in the administration of the program or project evaluated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The projects assisted under this subchapter shall be evaluated in accordance with this section not less frequently than at 3-year intervals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General standards for evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to obligating funds for the programs and projects covered by this subchapter with respect to fiscal year 1976, the Commissioner shall develop and publish general standards for evaluation of program and project effectiveness in achieving the objectives of this subchapter. The extent to which such standards have been met shall be considered in deciding whether to renew or supplement financial assistance authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out evaluations under this subchapter, the Commissioner may require agencies which receive assistance under this subchapter to provide for independent evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specificity of views","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out evaluations under this subchapter, the Commissioner shall, whenever feasible, arrange to obtain the specific views of persons participating in and served by programs and projects assisted under this subchapter about such programs and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e27a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of results; submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall publish the results of evaluative research and summaries of evaluations of program and project impact and effectiveness not later than ninety days after the completion thereof. The Commissioner shall submit to the appropriate committees of the Congress copies of all such research studies and evaluation summaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e27b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2992/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation results as United States property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall take the necessary action to assure that all studies, evaluations, proposals, and data produced or developed with assistance under this subchapter shall become the property of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e27c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s811"},"text":"Pub. L. 88–452, title VIII, § 811","children":[],"tail":