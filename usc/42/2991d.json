{"tag":"section","attrib":{"id":"idbc2f722b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991d"},"text":"§ 2991d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, demonstration, and pilot projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2f722c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner may provide financial assistance through grants or contracts for research, demonstration, or pilot projects conducted by public or private agencies which are designed to test or assist in the development of new approaches or methods that will aid in overcoming special problems or otherwise furthering the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2f722d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner shall establish an overall plan to govern the approval of research, demonstration, and pilot projects and the use of all research authority under this subchapter. The plan shall set forth specific objectives to be achieved and priorities among such objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2f722e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s805"},"text":"Pub. L. 88–452, title VIII, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2324"},"text":"88 Stat. 2324","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/5"},"text":"Pub. L. 102–375, title VIII, § 822(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1298"},"text":"106 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2f722f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc2f7230-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc2f7231-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2991d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s805"},"text":"Pub. L. 88–452, title VIII, § 805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/794/tVIII/s801"},"text":"Pub. L. 89–794, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-08"},"text":"Nov. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1474"},"text":"80 Stat. 1474","children":[],"tail":", provided for special programs and projects and placing limitations on the use of appropriated funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/90/222/tI/s110"},"text":"Pub. L. 90–222, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-23"},"text":"Dec. 23, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/722"},"text":"81 Stat. 722","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc2f7232-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":" substituted “Commissioner” for “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
