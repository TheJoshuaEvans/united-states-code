{"tag":"section","attrib":{"id":"idbd1b800c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5179"},"text":null,"children":[{"tag":"num","attrib":{"value":"5179"},"text":"§ 5179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits and distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1b800d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the President determines that, as a result of a major disaster, low-income households are unable to purchase adequate amounts of nutritious food, he is authorized, under such terms and conditions as he may prescribe, to distribute through the Secretary of Agriculture or other appropriate agencies benefit allotments to such households pursuant to the provisions of the Food and Nutrition Act of 2008 of 1964 ","children":[{"tag":"ref","attrib":{"idref":"fn003407"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003407"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See 2008 Amendment note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/91/671"},"text":"P.L. 91–671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/84/2048"},"text":"84 Stat. 2048","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.] and to make surplus commodities available pursuant to the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b800e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assistance; factors considered","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, through the Secretary of Agriculture or other appropriate agencies, is authorized to continue to make such benefit allotments and surplus commodities available to such households for so long as he determines necessary, taking into consideration such factors as he deems appropriate, including the consequences of the major disaster on the earning power of the households, to which assistance is made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1b800f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5179/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and Nutrition Act provisions unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as amending or otherwise changing the provisions of the Food and Nutrition Act of 2008 of 1964 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.] except as they relate to the availability of supplemental nutrition assistance program benefits in an area affected by a major disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1b8010-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s412"},"text":"Pub. L. 93–288, title IV, § 412","children":[],"tail":", formerly § 409, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":