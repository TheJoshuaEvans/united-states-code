{"tag":"section","attrib":{"id":"idbc4766c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3020e"},"text":"§ 3020e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition education","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, in consultation with the Secretary of Agriculture, shall conduct outreach and provide technical assistance to agencies and organizations that serve older individuals to assist such agencies and organizations to carry out integrated health promotion and disease prevention programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed for older individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc4766c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrition education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities to modify behavior and to improve health literacy, including providing information on optimal nutrient intake, through nutrition education and nutrition assessment and counseling, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030g–21/2/J"},"text":"section 3030g–21(2)(J) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc4766c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s214"},"text":"Pub. L. 89–73, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tII/s209"},"text":"Pub. L. 102–375, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1215"},"text":"106 Stat. 1215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVIII/s801/b/5"},"text":"Pub. L. 106–501, title VIII, § 801(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2292"},"text":"114 Stat. 2292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tII/s208"},"text":"Pub. L. 109–365, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2537"},"text":"120 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc4766c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc4766c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc4766ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Assistant Secretary and the Secretary of Agriculture may provide technical assistance and appropriate material to agencies carrying out nutrition education programs in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030g–21/2/J"},"text":"section 3030g–21(2)(J) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":" substituted “3030g–21(2)(J)” for “3027(a)(13)(J)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
