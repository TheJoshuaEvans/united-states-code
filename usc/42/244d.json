{"tag":"section","attrib":{"id":"idb49aadce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d"},"text":null,"children":[{"tag":"num","attrib":{"value":"244d"},"text":"§ 244d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting student access to AEDs and CPR","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49aadcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to eligible entities to develop and implement a comprehensive program to promote student access to automated external defibrillators (in this section referred to as “AEDs”) and cardiopulmonary resuscitation (in this section referred to as “CPR”) in public elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under subsection (a) may use funds received through such grant to carry out any of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and providing comprehensive materials to establish AED and CPR programs in public elementary schools and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing support for CPR and AED training programs in such schools for students, staff, and related sports volunteers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing support for developing a cardiac emergency response plan within such schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchasing AEDs that have been approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360e"},"text":"section 360e of title 21","children":[],"tail":", cleared under section 360(k) of such title, or classified under section 360c(f)(2) of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchasing necessary AED batteries and performing necessary AED maintenance (such as by replacing AED pads) in accordance with the labeling of the AED involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Replacing old and outdated AED and CPR equipment, machinery, and educational materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a local educational agency (including a public charter school operating as a local educational agency under State law), in consultation with a qualified health care entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aaddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESEA terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “elementary school”, “local educational agency”, and “secondary school” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aaddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified health care entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified health care entity” means a health care entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aaddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb49aadde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb49aaddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from taxation under section 501(a) of such title;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aade0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates an ability to develop, train, and implement a comprehensive program to promote student access to defibrillation in public elementary and secondary schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aade1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244d/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified in providing technical assistance in AED and CPR training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49aade2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/176/s2/a"},"text":"Pub. L. 118–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2608"},"text":"138 Stat. 2608","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
