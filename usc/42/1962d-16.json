dren":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2013"},"text":"Pub. L. 110–114, title II, § 2013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1075"},"text":"121 Stat. 1075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3015"},"text":"Pub. L. 113–121, title III, § 3015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1288"},"text":"128 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI"},"text":"Pub. L. 114–322, title I","children":[],"tail":", §§ 1128, 1129, "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1649"},"text":"130 Stat. 1649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1159"},"text":"Pub. L. 115–270, title I, § 1159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3795"},"text":"132 Stat. 3795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8119/a"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3711"},"text":"136 Stat. 3711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1127"},"text":"Pub. L. 118–272, div. A, title I, § 1127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3018"},"text":"138 Stat. 3018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9eea8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9eea9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbba9eeaa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 160 of the Water Resources Development Act of 2020, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s160"},"text":"section 160 of Pub. L. 116–260","children":[],"tail":", div. AA, title I, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2665"},"text":"134 Stat. 2665","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9eeab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1974, and not as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbba9eeac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" inserted “and title research for abandoned structures” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8119/a/1/A"},"text":"Pub. L. 117–263, § 8119(a)(1)(A)","children":[],"tail":", inserted “local government,” after “State or group of States,” and after “such State, interest,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8119/a/1/B"},"text":"Pub. L. 117–263, § 8119(a)(1)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4141"},"text":"section 4141 of title 10","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s236"},"text":"section 236 of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8119/a/1/C"},"text":"Pub. L. 117–263, § 8119(a)(1)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8119/a/2"},"text":"Pub. L. 117–263, § 8119(a)(2)","children":[],"tail":", substituted “$30,000,000” for “$15,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8119/a/3"},"text":"Pub. L. 117–263, § 8119(a)(3)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1159/1"},"text":"Pub. L. 115–270, § 1159(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “The Secretary of the Army, acting through the Chief of Engineers, is authorized to cooperate with any State, group of States, or non-Federal interest working with a State or group of States in the preparation of comprehensive plans for the development, utilization, and conservation of the water and related resources of drainage basins, watersheds, or ecosystems located within the boundaries of such State or group of States, including plans to comprehensively address water resources challenges, and to submit to Congress reports and recommendations with respect to appropriate Federal participation in carrying out such plans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1159/2"},"text":"Pub. L. 115–270, § 1159(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1128/1"},"text":"Pub. L. 114–322, § 1128(1)","children":[],"tail":", substituted “, group of States, or non-Federal interest” for “or other non-Federal interest” and inserted “or group of States” after “working with a State” and after “boundaries of such State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1128/2"},"text":"Pub. L. 114–322, § 1128(2)","children":[],"tail":", inserted at end “The Secretary may allow 2 or more States to combine all or a portion of the funds that the Secretary makes available to the States in carrying out subsection (a)(1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1129"},"text":"Pub. L. 114–322, § 1129","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/1/A"},"text":"Pub. L. 113–121, § 3015(1)(A)","children":[],"tail":", inserted “or other non-Federal interest working with a State” after “cooperate with any State” and “, including plans to comprehensively address water resources challenges,” after “of such State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/1/B"},"text":"Pub. L. 113–121, § 3015(1)(B)","children":[],"tail":", struck out “, at Federal expense,” after “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/2/A"},"text":"Pub. L. 113–121, § 3015(2)(A)","children":[],"tail":", substituted “subsection (a)” for “subsection (a)(1)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/2/B"},"text":"Pub. L. 113–121, § 3015(2)(B)","children":[],"tail":", (C), added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/3/A"},"text":"Pub. L. 113–121, § 3015(3)(A)","children":[],"tail":", substituted “$30,000,000” for “$10,000,000” and “$5,000,000 in Federal funds” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3015/3/B"},"text":"Pub. L. 113–121, § 3015(3)(B)","children":[],"tail":", substituted “$15,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2013/1"},"text":"Pub. L. 110–114, § 2013(1)","children":[],"tail":", (2), designated existing provisions as par. (1), inserted headings for subsec. (a) and par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2013/3"},"text":"Pub. L. 110–114, § 2013(3)","children":[],"tail":", 