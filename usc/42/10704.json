{"tag":"section","attrib":{"id":"idbf2cfb0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704"},"text":null,"children":[{"tag":"num","attrib":{"value":"10704"},"text":"§ 10704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2cfb0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director; appointment and removal of employees; political tests or qualifications prohibited","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfb0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, subject to general policies established by the Board, shall supervise the activities of persons employed by the Institute and may appoint and remove such employees as he determines necessary to carry out the purposes of the Institute. The Director shall be responsible for the executive and administrative operations of the Institute, and shall perform such duties as are delegated to such Director by the Board and the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfb0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No political test or political qualification shall be used in selecting, appointing, promoting, or taking any other personnel action with respect to any officer, agent, or employee of the Institute, or in selecting or monitoring any grantee, contractor, person, or entity receiving financial assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfb10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officers and employees of the Institute shall be compensated at rates determined by the Board, but not in excess of the rate of level V of the Executive Schedule specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfb11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Institute as department, agency, or instrumentality of Federal Government; authority of Office of Management and Budget","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfb12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically provided in this chapter, the Institute shall not be considered a department, agency, or instrumentality of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfb13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not limit the authority of the Office of Management and Budget to review and submit comments upon the Institute’s annual budget request at the time it is transmitted to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfb14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute may purchase goods and services from the General Services Administration in order to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfb15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of officers and employees of Institute as officers and employees of United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2cfb16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), officers and employees of the Institute shall not be considered officers or employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2cfb17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers and employees of the Institute shall be considered officers and employees of the United States solely for the purposes of the following provisions of title 5: Subchapter I of chapter 81 (relating to compensation for work injuries); chapters 83 and 84 (relating to civil service retirement); chapter 87 (relating to life insurance); and chapter 89 (relating to health insurance), notwithstanding section 8914 of such title. The Institute shall make contributions under the provisions referred to in this subsection at the same rates applicable to agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2cfb18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freedom of information requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute and its officers and employees shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" relating to freedom of information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2cfb19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tII/s205"},"text":"Pub. L. 98–620, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3339"},"text":"98 Stat. 3339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7321/b/2"},"text":"Pub. L. 100–690, title VII, § 7321(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4466"},"text":"102 Stat. 4466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tVI/s602"},"text":"Pub. L. 100–702, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4653"},"text":"102 Stat. 4653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/372/s3/a"},"text":"Pub. L. 108–372, § 3(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1754"},"text":"118 Stat. 1754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2cfb1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2cfb1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2cfb1c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(2) and (c)(1), (2), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3336"},"text":"98 Stat. 3336","children":[],"tail":", known as the State Justice Institute Act of 1984, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf2cfb1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/372/s3/a"},"text":"Pub. L. 108–372, § 3(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/372/s3/b"},"text":"Pub. L. 108–372, § 3(b)","children":[],"tail":", inserted “, notwithstanding section 8914 of such title” after “(relating to health insurance)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" amended par. (2) identically, substituting “chapters 83 and 84” for “chapter 83”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf2cfb1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf2cfb1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s216"},"text":"section 216 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
