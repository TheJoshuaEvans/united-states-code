{"tag":"section","attrib":{"id":"idc00f6b51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358"},"text":null,"children":[{"tag":"num","attrib":{"value":"16358"},"text":"§ 16358.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic research portfolio analysis and coordination plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00f6b52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically review all of the science and technology activities of the Department in a strategic framework that takes into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frontiers of science to which the Department can contribute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national needs relevant to the statutory missions of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global energy dynamics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination analysis and plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the review under subsection (a), the Secretary shall develop a plan to improve coordination and collaboration in research, development, demonstration, and commercial application activities across organizational boundaries of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under paragraph (1) shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crosscutting scientific and technical issues and research questions that span more than one program or major office of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways in which the applied technology programs of the Department are coordinating activities and addressing the questions referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways in which the technical interchange within the Department, particularly between the Office of Science and the applied technology programs, could be enhanced, including ways in which the research agendas of the Office of Science and the applied programs could better interact and assist each other;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways in which the Secretary would ensure that the overall research agenda of the Department includes, in addition to fundamental, curiosity-driven research, fundamental research related to topics of concern to the applied programs, and applications in Departmental technology programs of research results generated by fundamental, curiosity-driven research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical assessments of any ongoing programs that have experienced subpar performance or cost overruns of 10 percent or more over 1 or more years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activities that may be more effectively left to the States, industry, nongovernmental organizations, institutions of higher education, or other stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" detailed evaluations and proposals for innovation hubs, institutes, and research centers of the Department, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an affirmation that the hubs, institutes, and research centers will—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/G/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the mission of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/G/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize research, development, and demonstration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affirmation that any hubs, institutes, or research centers that are established or renewed within the Office of Science are consistent with the mission of the Office of Science described in subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7139"},"text":"section 7139 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every 4 years, the Secretary shall submit to Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the review under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16358/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination plan under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6b67-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s994"},"text":"Pub. L. 109–58, title IX, § 994","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tII/s204"},"text":"Pub. L. 115–246, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3136"},"text":"132 Stat. 3136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6b68-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6b69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc00f6b6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 16358, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s994"},"text":"Pub. L. 109–58, title IX, § 994","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/914"},"text":"119 Stat. 914","children":[],"tail":", which required the Secretary to periodically review Department of Energy science and technology activities taking into account the frontiers of science to which the Department can contribute and the national needs relevant to the Department’s statutory missions, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tII/s204"},"text":"Pub. L. 115–246, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3135"},"text":"132 Stat. 3135","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
