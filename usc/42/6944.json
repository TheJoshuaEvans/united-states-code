{"tag":"section","attrib":{"id":"idbdda62fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6944"},"text":null,"children":[{"tag":"num","attrib":{"value":"6944"},"text":"§ 6944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for sanitary landfills; sanitary landfills required for all disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdda62fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for sanitary landfills","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"October 21, 1976","children":[],"tail":", after consultation with the States, and after notice and public hearings, the Administrator shall promulgate regulations containing criteria for determining which facilities shall be classified as sanitary landfills and which shall be classified as open dumps within the meaning of this chapter. At a minimum, such criteria shall provide that a facility may be classified as a sanitary landfill and not an open dump only if there is no reasonable probability of adverse effects on health or the environment from disposal of solid waste at such facility. Such regulations may provide for the classification of the types of sanitary landfills."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdda62fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal required to be in sanitary landfills, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of complying with section 6943(2) ","children":[{"tag":"ref","attrib":{"idref":"fn003530"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003530"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title each State plan shall prohibit the establishment of open dumps and contain a requirement that disposal of all solid waste within the State shall be in compliance with such section 6943(2) "},{"tag":"ref","attrib":{"idref":"fn003530"},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdda62ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition contained in subsection (b) shall take effect on the date six months after the date of promulgation of regulations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdda6300-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s4004"},"text":"Pub. L. 89–272, title II, § 4004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2815"},"text":"90 Stat. 2815","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tIII/s302/b"},"text":"Pub. L. 98–616, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3268"},"text":"98 Stat. 3268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdda6301-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdda6302-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdda6303-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6943/2"},"text":"Section 6943(2) of this title","children":[],"tail":", referred to in subsec. (b), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6943/a/2"},"text":"section 6943(a)(2) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/96/463/s5/b"},"text":"Pub. L. 96–463, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2056"},"text":"94 Stat. 2056","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/96/482/s32/d/2"},"text":"Pub. L. 96–482, § 32(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2353"},"text":"94 Stat. 2353","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdda6304-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616"},"text":"Pub. L. 98–616","children":[],"tail":" struck out “or on the date of approval of the State plan, whichever is later” at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdda6305-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbdda6306-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Administrator or other official of Environmental Protection Agency under this chapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
