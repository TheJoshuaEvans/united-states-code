{"tag":"section","attrib":{"id":"idbf01f289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858n"},"text":"§ 9858n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f28a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caregiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “caregiver” means an individual who provides a service directly to an eligible child on a person-to-person basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f28b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child care certificate” means a certificate (that may be a check or other disbursement) that is issued by a State or local government under this subchapter directly to a parent who may use such certificate only as payment for child care services or as a deposit for child care services if such a deposit is required of other children being cared for by the provider. Nothing in this subchapter shall preclude the use of such certificates for sectarian child care services if freely chosen by the parent. For purposes of this subchapter, child care certificates shall not be considered to be grants or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f28c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child with a disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “child with a disability” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f28d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child with a disability, as defined in section 602 of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401"},"text":"20 U.S.C. 1401","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f28e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who is eligible for early intervention services under part C of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1431"},"text":"20 U.S.C. 1431","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f28f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child who is less than 13 years of age and who is eligible for services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child with a disability, as defined by the State involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible child” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is less than 13 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose family income does not exceed 85 percent of the State median income for a family of the same size, and whose family assets do not exceed $1,000,000 (as certified by a member of such family); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides with a parent or parents who are working or attending a job training or educational program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is receiving, or needs to receive, protective services and resides with a parent or parents not described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" English learner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “English learner” means an individual who is an English learner, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":", or who is limited English proficient, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9832"},"text":"section 9832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible child care provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f299-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a center-based child care provider, a group home child care provider, a family child care provider, or other provider of child care services for compensation that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f29a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed, regulated, or registered under State law as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/2/F"},"text":"section 9858c(c)(2)(F) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f29b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the State and local requirements, including those referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/c/2/I"},"text":"section 9858c(c)(2)(I) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"applicable to the child care services it provides; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f29c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child care provider that is 18 years of age or older who provides child care services only to eligible children who are, by affinity or consanguinity, or by court decree, the grandchild, great grandchild, sibling (if such provider lives in a separate residence), niece, or nephew of such provider, if such provider complies with any applicable requirements that govern child care provided by the relative involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f29d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family child care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family child care provider” means one individual who provides child care services for fewer than 24 hours per day, as the sole caregiver, and in a private residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f29e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f29f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lead agency” means the agency designated or established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858b/a"},"text":"section 9858b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “parent” includes a legal guardian, foster parent, or other person standing in loco parentis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientifically valid research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “scientifically valid research” includes applied research, basic research, and field-initiated research, for which the rationale, design, and interpretation are soundly developed in accordance with principles of scientific research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services unless the context specifies otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sliding fee scale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sliding fee scale” means a system of cost sharing by a family based on income and size of the family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia, the Virgin Islands of the United States, the Commonwealth of Puerto Rico, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f2a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the meaning given it in section 5304(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 25."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f2a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858n/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term includes a Native Hawaiian Organization, as defined in section 4909(4) ","children":[{"tag":"ref","attrib":{"idref":"fn003914"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003914"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 20 and a private nonprofit organization established for the purpose of serving youth who are Indians or Native Hawaiians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf01f2a8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658P"},"text":"Pub. L. 97–35, title VI, § 658P","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-248"},"text":"104 Stat. 1388–248","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3"},"text":"Pub. L. 102–401, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c"},"text":"Pub. L. 102–586, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s8"},"text":"Pub. L. 103–171, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1994"},"text":"107 Stat. 1994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s614"},"text":"Pub. L. 104–193, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2287"},"text":"110 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5602/5"},"text":"Pub. L. 105–33, title V, § 5602(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/646"},"text":"111 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10"},"text":"Pub. L. 113–186, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2000"},"text":"128 Stat. 2000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/p/2"},"text":"Pub. L. 114–95, title IX, § 9215(p)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2170"},"text":"129 Stat. 2170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf01f2a9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf01f2aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf01f2ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in par. (3)(B), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":". Part C of the Act is classified generally to subchapter III (§ 1431 et seq.) of chapter 33 of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4909"},"text":"Section 4909 of title 20","children":[],"tail":", referred to in par. (15)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s363"},"text":"Pub. L. 103–382, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3975"},"text":"108 Stat. 3975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf01f2ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “an individual who is an English learner, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":", or who is limited English proficient, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9832"},"text":"section 9832 of this title","children":[],"tail":"” for “an individual who is limited English proficient, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9832"},"text":"section 9832 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10/1"},"text":"Pub. L. 113–186, § 10(1)","children":[],"tail":", added pars. (3) and (4) and struck out former par. (4) which defined “eligible child”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10/3"},"text":"Pub. L. 113–186, § 10(3)","children":[],"tail":", added par. (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10/2"},"text":"Pub. L. 113–186, § 10(2)","children":[],"tail":", (4), redesignated par. (5) as (6) and substituted “9858c(c)(2)(F)” for “9858c(c)(2)(E)” in subpar. (A)(i) and “9858c(c)(2)(I)” for “9858c(c)(2)(F)” in subpar. (A)(ii). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10/2"},"text":"Pub. L. 113–186, § 10(2)","children":[],"tail":", redesignated pars. (6) and (7) as (7) and (8), respectively. Former pars. (7) and (8) redesignated (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s10/2"},"text":"Pub. L. 113–186, § 10(2)","children":[],"tail":", (5), redesignated par. (8) as (9) and substituted “designated or established