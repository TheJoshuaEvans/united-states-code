{"tag":"section","attrib":{"id":"idbf06d4da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903"},"text":null,"children":[{"tag":"num","attrib":{"value":"9903"},"text":"§ 9903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf06d4db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of fiscal years 1999 through 2003 to carry out the provisions of this chapter (other than sections 9922 and 9923 of this title).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d4dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated under subsection (a) for each fiscal year, the Secretary shall reserve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d4dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ½ of 1 percent for carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9905"},"text":"section 9905 of this title","children":[],"tail":" (relating to payments for territories);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1½ percent for activities authorized in sections 9913 through 9918 of this title, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d4df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than ½ of the amount reserved by the Secretary under this paragraph shall be distributed directly to eligible entities, organizations, or associations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9913/c/2"},"text":"section 9913(c)(2) of this title","children":[],"tail":" for the purpose of carrying out activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9913/c"},"text":"section 9913(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d4e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ½ of the remainder of the amount reserved by the Secretary under this paragraph shall be used by the Secretary to carry out evaluation and to assist States in carrying out corrective action activities and monitoring (to correct programmatic deficiencies of eligible entities), as described in sections 9914(c) and 9913 of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 percent for carrying out ","children":[{"tag":"ref","attrib":{"href":"/u