{"tag":"section","attrib":{"id":"idbf0b8fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003"},"text":null,"children":[{"tag":"num","attrib":{"value":"10003"},"text":"§ 10003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless otherwise expressly provided, for purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “radiation” means ionizing and nonionizing radiation in amounts beyond normal background levels from sources such as medical and dental radiologic procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “radiologic procedure” means any procedure or article intended for use in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf0b8fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis of disease or other medical or dental conditions in humans (including diagnostic X-rays or nuclear medicine procedures); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf0b8fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cure, mitigation, treatment, or prevention of disease in humans;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that achieves its intended purpose through the emission of radiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “radiologic equipment” means any radiation electronic product which emits or detects radiation and which is used or intended for use to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf0b8fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnose disease or other medical or dental conditions (including diagnostic X-ray equipment); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf0b8fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cure, mitigate, treat, or prevent disease in humans;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that achieves its intended purpose through the emission or detection of radiation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “practitioner” means any licensed doctor of medicine, osteopathy, dentistry, podiatry, or chiropractic, who prescribes radiologic procedures for other persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “persons who administer radiologic procedures” means any person, other than a practitioner, who intentionally administers radiation to other persons for medical purposes, and includes medical radiologic technologists (including dental hygienists and assistants), radiation therapy technologists, and nuclear medicine technologists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10003/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the Virgin Islands, Guam, American Samoa, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8fe2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s978"},"text":"Pub. L. 97–35, title IX, § 978","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/599"},"text":"95 Stat. 599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b8fe3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbf0b8fe4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf0b8fe5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
