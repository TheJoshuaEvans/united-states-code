{"tag":"section","attrib":{"id":"idc02c1b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158"},"text":null,"children":[{"tag":"num","attrib":{"value":"17158"},"text":"§ 17158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary for the provision of grants under the program $2,000,000,000 for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for administrative expenses of the program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2008 and 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for each of fiscal years 2010 and 2011; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funding provided under this section shall supplement (and not supplant) other Federal funding provided under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State energy conservation plan established under part D of title III of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6321"},"text":"42 U.S.C. 6321","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Weatherization Ass