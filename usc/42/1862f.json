{"tag":"section","attrib":{"id":"idbb863a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862f"},"text":"§ 1862f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research center consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In Foundation programs making grants to research centers, the Director shall encourage the formation of consortia that include research universities, two-year and four-year colleges, and the private sector.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb863a01-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/570/tI/s110"},"text":"Pub. L. 100–570, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2869"},"text":"102 Stat. 2869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb863a02-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb863a03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb863a04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1988, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
