{"tag":"section","attrib":{"id":"idbfe48b86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851"},"text":null,"children":[{"tag":"num","attrib":{"value":"15851"},"text":"§ 15851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of renewable energy resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and each year thereafter, the Secretary shall review the available assessments of renewable energy resources within the United States, including solar, wind, biomass, marine, geothermal, and hydroelectric energy resources, and undertake new assessments as necessary, taking into account changes in market conditions, available technologies, and other relevant factors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and each year thereafter, the Secretary shall publish a report based on the assessment under subsection (a). The report shall contain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed inventory describing the available amount and characteristics of the renewable energy resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary believes would be useful in developing such renewable energy resources, including descriptions of surrounding terrain, population and load centers, nearby energy infrastructure, location of energy and water resources, and available estimates of the costs needed to develop each resource, together with an identification of any barriers to providing adequate transmission for remote sources of renewable energy resources to current and emerging markets, recommendations for removing or addressing such barriers, and ways to provide access to the grid that do not unfairly disadvantage renewable or other energy producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15851/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, there are authorized to be appropriated to the Secretary $10,000,000 for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b8c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s201"},"text":"Pub. L. 109–58, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/650"},"text":"119 Stat. 650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3006/b/1"},"text":"Pub. L. 116–260, div. Z, title III, § 3006(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2512"},"text":"134 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe48b8d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe48b8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe48b8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “marine” for “ocean (including tidal, wave, current, and thermal)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
