{"tag":"section","attrib":{"id":"idbd8e176a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6299"},"text":null,"children":[{"tag":"num","attrib":{"value":"6299"},"text":"§ 6299.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to obtain information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8e176b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6299/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this part, the Commission and the Secretary may each sign and issue subpenas for the attendance and testimony of witnesses and the production of relevant books, records, papers, and other documents, and may each administer oaths. Witnesses summoned under the provisions of this section shall be paid the same fees and mileage as are paid to witnesses in the courts of the United States. In case of contumacy by, or refusal to obey a subpena served, upon any persons subject to this part, the Commission and the Secretary may each seek an order from the district court of the United States for any district in which such person is found or resides or transacts business requiring such person to appear and give testimony, or to appear and produce documents. Failure to obey any such order is punishable by such court as a contempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8e176c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6299/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information submitted by any person to the Secretary or the Commission under this part shall not be considered energy information as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s796/e/1"},"text":"section 796(e)(1) of title 15","children":[],"tail":" for purposes of any verification examination authorized to be conducted by the Comptroller General under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6381"},"text":"section 6381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8e176d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s329"},"text":"Pub. L. 94–163, title III, § 329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/928"},"text":"89 Stat. 928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/b/4"},"text":"Pub. L. 100–12, § 11(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-03-17"},"text":"Mar. 17, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/125"},"text":"101 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8e176e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8e176f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd8e1770-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12"},"text":"Pub. L. 100–12","children":[],"tail":" inserted headings for subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration, wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
