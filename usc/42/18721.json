{"tag":"section","attrib":{"id":"idc062e345-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721"},"text":null,"children":[{"tag":"num","attrib":{"value":"18721"},"text":"§ 18721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancing grid security through public-private partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc062e346-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e347-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk-power system; Electric Reliability Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “bulk-power system” and “Electric Reliability Organization” has the meaning given the terms in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of title 16."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e348-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric utility; State regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “electric utility” and “State regulatory authority” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e349-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to promote and advance physical security and cybersecurity of electric utilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e34a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Homeland Security and in consultation with, as the Secretary determines to be appropriate, the heads of other relevant Federal agencies, State regulatory authorities, industry stakeholders, and the Electric Reliability Organization, shall carry out a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e34b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, and provide for voluntary implementation of, maturity models, self-assessments, and auditing methods for assessing the physical security and cybersecurity of electric utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e34c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist with threat assessment and cybersecurity training for electric utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e34d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance for electric utilities subject to the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e34e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training to electric utilities to address and mitigate cybersecurity supply chain management risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e34f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance, in partnership with electric utilities, the cybersecurity of third-party vendors that manufacture components of the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e350-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase opportunities for sharing best practices and data collection within the electric sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist, in the case of electric utilities that own defense critical electric infrastructure (as defined in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1(a) of title 16), with full engineering reviews of critical functions and operations at both the utility and defense infrastructure levels—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc062e352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify unprotected avenues for cyber-enabled sabotage that would have catastrophic effects to national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend and implement engineering protections to ensure continued operations of identified critical functions even in the face of constant cyber attacks and achieved perimeter access by sophisticated adversaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc062e356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the different sizes of electric utilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regions that electric utilities serve;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize electric utilities with fewer available resources due to size or region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the maximum extent practicable, use and leverage—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc062e35a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Department and Department of Homeland Security programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc062e35b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing programs of the Federal agencies determined to be appropriate under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e35c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on cybersecurity of distribution systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary, in coordination with the Secretary of Homeland Security and in consultation with, as the Secretary determines to be appropriate, the heads of other Federal agencies, State regulatory authorities, and industry stakeholders, shall submit to Congress a report that assesses—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e35d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priorities, policies, procedures, and actions for enhancing the physical security and cybersecurity of electricity distribution systems, including behind-the-meter generation, storage, and load management devices, to address threats to, and vulnerabilities of, electricity distribution systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e35e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the implementation of the priorities, policies, procedures, and actions assessed under paragraph (1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e35f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of potential costs and benefits of the implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of any public-private cost-sharing opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information provided to, or collected by, the Federal Government pursuant to this section the disclosure of which the Secretary reasonably foresees could be detrimental to the physical security or cybersecurity of any electric utility or the bulk-power system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18721/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made available by any Federal agency, State, political subdivision of a State, or Tribal authority pursuant to any Federal, State, political subdivision of a State, or Tribal law, respectively, requiring public disclosure of information or records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc062e364-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40121"},"text":"Pub. L. 117–58, div. D, title I, § 40121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/949"},"text":"135 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc062e365-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc062e366-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc062e367-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
