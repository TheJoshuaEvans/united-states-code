attrib":{"href":"/us/usc/t42/s1396u–5"},"text":"section 1396u–5 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb84f7934-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tIX/s911/c"},"text":"Pub. L. 106–554, § 1(a)(6) [title IX, § 911(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–584, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/6/tIX/s911/c"},"text":"“The amendments made by subsection (a) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"section 1396d of this title","children":[],"tail":"] shall take effect one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb84f7935-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"GAO Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tIX/s911/b"},"text":"Pub. L. 106–554, § 1(a)(6) [title IX, § 911(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–584, required the Comptroller General of the United States to conduct a study of the impact of this section on the enrollment of individuals for medicare cost-sharing under the medicaid program and to submit a report on the study no later than 18 months after the initial outreach."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
