{"tag":"section","attrib":{"id":"idb6515f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"300n–4"},"text":"§ 300n–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6515f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, directly or through contracts with public or private entities, provide for annual evaluations of programs carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":". Such evaluations shall include evaluations of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which States carrying out such programs are in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a/2"},"text":"section 300k(a)(2) of this title","children":[],"tail":" and with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300n/c"},"text":"section 300n(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which each State receiving a grant under this subchapter is in compliance with section 300","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, including identification of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6515f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the non-Federal contributions by the State for the preceding fiscal year, disaggregated according to the source of the contributions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6515f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proportion of such amount of non-Federal contributions relative to the amount of Federal funds provided through the grant to the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-04-20"},"text":"April 20, 2007","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002358"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002358"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and annually thereafter, submit to the Committee on Energy and Commerce of the House of Representatives, and to the Committee on Labor and Human Resources of the Senate, a report summarizing evaluations carried out pursuant to subsection (a) during the preceding fiscal year and making such recommendations for administrative and legislative initiatives with respect to this subchapter as the Secretary determines to be appropriate, including recommendations regarding compliance by the States with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k/a/2"},"text":"section 300k(a)(2) of this title","children":[],"tail":" and with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300n/c"},"text":"section 300n(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6515f27-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XV, § 1508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/354/s2"},"text":"Pub. L. 101–354, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-10"},"text":"Aug. 10, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/415"},"text":"104 Stat. 415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tI/s101/e"},"text":"Pub. L. 103–183, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2228"},"text":"107 Stat. 2228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/18/s2/3"},"text":"Pub. L. 110–18, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-04-20"},"text":"Apr. 20, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/83"},"text":"121 Stat. 83","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6515f28-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHea