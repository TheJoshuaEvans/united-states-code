{"tag":"section","attrib":{"id":"idbfee28c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16011"},"text":null,"children":[{"tag":"num","attrib":{"value":"16011"},"text":"§ 16011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration hydrogen production at existing nuclear power plants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee28c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the establishment of 2 projects in geographic areas that are regionally and climatically diverse to demonstrate the commercial production of hydrogen at existing nuclear power plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to making an award under subsection (a), the Secretary shall determine whether the use of existing nuclear power plants is a cost-effective means of producing hydrogen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee28c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for the purposes of carrying out this section not more than $100,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee28c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s634"},"text":"Pub. L. 109–58, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/790"},"text":"119 Stat. 790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
