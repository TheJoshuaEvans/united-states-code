{"tag":"section","attrib":{"id":"idbf80725f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612"},"text":null,"children":[{"tag":"num","attrib":{"value":"12612"},"text":"§ 12612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Civilian Community Corps Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf807260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may establish the National Civilian Community Corps Program to carry out the purpose of this division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the National Civilian Community Corps Program authorized by subsection (a), the members of a National Civilian Community Corps shall receive training and perform service in at least one of the following two program components:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf807262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national service program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf807263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summer national service program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Both programs referred to in subsection (b) may include a residential component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf807265-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s152"},"text":"Pub. L. 101–610, title I, § 152","children":[],"tail":", formerly § 195A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2523"},"text":"106 Stat. 2523","children":[],"tail":"; renumbered § 152 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", title IV, § 402(b)(2), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 919; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1502"},"text":"Pub. L. 111–13, title I, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1521"},"text":"123 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf807266-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf807267-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf807268-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653a"},"text":"section 12653a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf807269-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12612, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s161"},"text":"Pub. L. 101–610, title I, § 161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3157"},"text":"104 Stat. 3157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s7/a"},"text":"Pub. L. 102–384, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1456"},"text":"106 Stat. 1456","children":[],"tail":", related to eligibility and selection procedures, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/a"},"text":"Pub. L. 103–82, § 104(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf80726a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1502/1"},"text":"Pub. L. 111–13, § 1502(1)","children":[],"tail":", amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1502/2"},"text":"Pub. L. 111–13, § 1502(2)","children":[],"tail":", substituted “National Civilian Community Corps Program” for “Civilian Community Corps Demonstration Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1502/3"},"text":"Pub. L. 111–13, § 1502(3)","children":[],"tail":", in introductory provisions, substituted “National Civilian Community Corps Program” for “Civilian Community Corps Demonstration Program” and “a National Civilian Community Corps” for “a Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1502/4"},"text":"Pub. L. 111–13, § 1502(4)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “Both program components are residential programs. The members of the Corps in each program shall reside with other members of the Corps in Corps housing during the periods of the members’ agreed service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/2"},"text":"Pub. L. 103–82, § 402(b)(2)","children":[],"tail":", substituted “Corporation” for “Commission on National and Community Service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf80726b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf80726c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf80726d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/2"},"text":"section 402(b)(2) of Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s406/a"},"text":"section 406(a) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5061"},"text":"section 5061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf80726e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report and Study Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/b"},"text":"Pub. L. 102–484, div. A, title X, § 1092(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2534"},"text":"106 Stat. 2534","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/e/1/B"},"text":"Pub. L. 103–82, title I, § 104(e)(1)(B)","children":[],"tail":", (C), title IV, § 402(a)(1), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/846"},"text":"107 Stat. 846","children":[],"tail":", 918, related to a progress report to be submitted to the appropriate committees of Congress assessing the activities undertaken in establishing and administering Civilian Community Corps camps and analyzing the level of coordination of Corps activities with activities of other departments or agencies of the Federal Government and a report to be submitted to the appropriate committees of Congress concerning the desirability and feasibility of establishing the Civilian Community Corps as an independent agency of the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf80726f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1093"},"text":"Pub. L. 102–484, div. A, title X, § 1093","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2534"},"text":"106 Stat. 2534","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/e/1/B"},"text":"Pub. L. 103–82, title I, § 104(e)(1)(B)","children":[],"tail":", title IV, § 402(a)(2), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/846"},"text":"107 Stat. 846","children":[],"tail":", 918, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/82/tI/s104/e/1/B"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordinated Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent practicable, the Chief of the National Guard Bureau, the Board of Directors and Chief Executive Officer of the Corporation for National and Community Service, and the Director of the Civilian Community Corps shall coordinate the National Guard Youth Opportunities Program established pursuant to section 1091 [of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s501"},"text":"32 U.S.C. 501","children":[],"tail":" note] and the Civilian Community Corps Demonstration Program established pursuant to the authorization contained in section 152 of the National and Community Service Act of 1990 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12612"},"text":"42 U.S.C. 12612","children":[],"tail":"] (as added by section 1092(a))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials referred to in subsection (a) shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs referred to in subsection (a) are conducted in such a manner in relationship to each other that the public benefit of those programs is maximized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent appropriate to meet the needs of program participants, persons who complete participation in the National Guard Youth Opportunities Program and are eligible and apply to participate in the Civilian Community Corps under the Civilian Community Corps Demonstration Program are accepted for participation in that Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs referred to in subsection (a) are conducted simultaneously in competition with each other in the same immediate area of the United States only when the population of eligible participants in that area is sufficient to justify the simultaneous conduct of such programs in that area.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
