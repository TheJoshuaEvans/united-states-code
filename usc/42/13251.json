{"tag":"section","attrib":{"id":"idbfb4c94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251"},"text":null,"children":[{"tag":"num","attrib":{"value":"13251"},"text":"§ 13251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandate for alternative fuel providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb4c94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, before ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", issue regulations requiring that of the new light duty motor vehicles acquired by a covered person described in paragraph (2), the following percentages shall be alternative fueled vehicles for the following model years:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 percent for model year 1996.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent for model year 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent for model year 1998.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent for model year 1999 and thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, a person referred to in paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c954-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered person whose principal business is producing, storing, refining, processing, transporting, distributing, importing, or selling at wholesale or retail any alternative fuel other than electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c955-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-Federal covered person whose principal business is generating, transmitting, importing, or selling at wholesale or retail electricity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c956-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a covered person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb4c957-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who produces, imports, or produces and imports in combination, an average of 50,000 barrels per day or more of petroleum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb4c958-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial portion of whose business is producing alternative fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c959-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c95a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a covered person described in paragraph (2) with more than one affiliate, division, or other business unit, only an affiliate, division, or business unit which is substantially engaged in the alternative fuels business (as determined by the Secretary by rule) shall be subject to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c95b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No covered person or affiliate, division, or other business unit of such person whose principal business is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb4c95c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transforming alternative fuels into a product that is not an alternative fuel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb4c95d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consuming alternative fuels as a feedstock or fuel in the manufacture of a product that is not an alternative fuel,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c95e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vehicles purchased pursuant to this section shall be operated solely on alternative fuels except when operating in an area where the appropriate alternative fuel is unavailable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c95f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations issued under paragraph (1) shall provide for the prompt exemption by the Secretary, through a simple and reasonable process, from the requirements of paragraph (1) of any covered person, in whole or in part, if such person demonstrates to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c960-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative fueled vehicles that meet the normal requirements and practices of the principal business of that person are not reasonably available for acquisition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c961-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative fuels that meet the normal requirements and practices of the principal business of that person are not available in the area in which the vehicles are to be operated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c962-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions and extensions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to model years 1997 and thereafter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c963-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the percentage requirements under subsection (a)(1) downward, except that under no circumstances shall the percentage requirement for a model year be less than 20 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c964-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the time under subsection (a)(1) for up to 2 model years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c965-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option for electric utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", issue regulations requiring that, in the case of a covered person whose principal business is generating, transmitting, importing, or selling at wholesale or retail electricity, the requirements of subsection (a)(1) shall not apply until after "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":", with respect to electric motor vehicles. Any covered person described in this subsection which plans to acquire electric motor vehicles to comply with the requirements of this section shall so notify the Secretary before "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, before ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", submit a report to the Congress providing detailed information on actions taken to carry out this section, and the progress made and problems encountered thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb4c967-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s501"},"text":"Pub. L. 102–486, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2887"},"text":"106 Stat. 2887","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
