{"tag":"section","attrib":{"id":"idbf556aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709"},"text":null,"children":[{"tag":"num","attrib":{"value":"11709"},"text":"§ 11709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian health scholarships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf556aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of funds appropriated under the authority of subsection (c) of this section, the Secretary shall provide funds through a direct grant or a cooperative agreement to Papa Ola Lokahi for the purpose of providing scholarship assistance to students who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of paragraphs (1), (3), and (4) of section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b) of this title, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are Native Hawaiians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf556aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The scholarship assistance provided under subsection (a) of this section shall be provided under the same terms and subject to the same conditions, regulations, and rules that apply to scholarship assistance provided under section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, provided that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf556aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of scholarships in each type of health care profession training shall correspond to the need for each type of health care professional identified in the Native Hawaiian comprehensive health care master plan implemented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11703"},"text":"section 11703 of this title","children":[],"tail":" to serve the Native Hawaiian health care systems, as identified by Papa Ola Lokahi;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556aaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary health services covered under the scholarship assistance program under this section shall be the services included under the definition of that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11711/8"},"text":"section 11711(8) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556aab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, the Secretary shall select scholarship recipients from a list of eligible applicants submitted by the Papa Ola Lokahi;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556aac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the obligated service requirement for each scholarship recipient shall be fulfilled through the full-time clinical or nonclinical practice of the health profession of the scholarship recipient, in an order of priority that would provide for practice—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf556aad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first, in any one of the five Native Hawaiian health care systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf556aae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" second, in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf556aaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professional shortage area or medically underserved area located in the State of Hawaii; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf556ab0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a geographic area or facility that is—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf556ab1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the State of Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf556ab2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/D/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a designation that is similar to a designation described in subclause (I) made by the Secretary, acting through the Public Health Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556ab3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of counseling, retention and other support services shall not be limited to scholarship recipients, but shall also include recipients of other scholarship and financial aid programs enrolled in appropriate health professions training programs,","children":[{"tag":"ref","attrib":{"idref":"fn004013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556ab4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligated service of a scholarship recipient shall not be performed by the recipient through membership in the National Health Service Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf556ab5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of sections 254d through 254k of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254m"},"text":"section 254m of this title","children":[],"tail":", other than subsection (b)(5) of that section, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254n"},"text":"section 254n of this title","children":[],"tail":" applicable to scholarship assistance provided under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title shall not apply to the scholarship assistance provided under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf556ab6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Native Hawaiian Health Scholarship program shall not be administered by or through the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf556ab7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal years 1993 through 2019 for the purpose of funding the scholarship assistance provided under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf556ab8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s10"},"text":"Pub. L. 100–579, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9168"},"text":"Pub. L. 102–396, title IX, § 9168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1948"},"text":"106 Stat. 1948","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12"},"text":"Pub. L. 105–256, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-14"},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1899"},"text":"112 Stat. 1899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/116/tV/s514/a"},"text":"Pub. L. 107–116, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2219"},"text":"115 Stat. 2219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10221/a"},"text":"Pub. L. 111–148, title X, § 10221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/935"},"text":"124 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf556ab9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf556aba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf556abb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" is based on section 202(a) of title II of S. 1790, One Hundred Eleventh Congress, as reported by the Committee on Indian Affairs of the Senate in Dec. 2009, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10221/a"},"text":"section 10221(a) of Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section enacted by section 1 of S. 2681, One Hundred Second Congress, as passed by the Senate on ","children":[{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/s9168"},"text":"section 9168 of Pub. L. 102–396","children":[],"tail":". Section 9168, which referred to S. 2681, as passed by the Senate on “"},{"tag":"date","attrib":{"date":"1992-09-12"},"text":"September 12, 1992","children":[],"tail":"”, has been treated as referring to S. 2681, as passed by the Senate on "},{"tag":"date","attrib":{"date":"1992-08-07"},"text":"Aug. 7, 1992","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf556abc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11709, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s11"},"text":"Pub. L. 100–579, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2923"},"text":"102 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2311"},"text":"Pub. L. 100–690, title II, § 2311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4229"},"text":"102 Stat. 4229","children":[],"tail":", which related to compliance with Budget Act, was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9168"},"text":"Pub. L. 102–396, title IX, § 9168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1948"},"text":"106 Stat. 1948","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11710"},"text":"section 11710 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/579/s10"},"text":"section 10 of Pub. L. 100–579","children":[],"tail":" repealed former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1621d"},"text":"section 1621d of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf556abd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", which directed the amendment of section 10(c) of the Native Hawaiian Health Care Act of 1988 by substituting “2019” for “2001”, was executed by making the amendment to this section, which is section 10 of the Native Hawaiian Health Care Improvement Act, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116/s514/a/1"},"text":"Pub. L. 107–116, § 514(a)(1)","children":[],"tail":", substituted “Papa Ola Lokahi” for “Kamehameha School/Bishop Estate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116/s514/a/2"},"text":"Pub. L. 107–116, § 514(a)(2)","children":[],"tail":", which directed the substitution of “Papa Ola Lokahi” for “Kamehameha School/Bishop Estate”, was executed by making the substitution for “Kamehameha Schools/Bishop Estate” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/a"},"text":"Pub. L. 105–256, § 12(a)","children":[],"tail":", which directed amendment of subsec. (a)(1) by substituting “meet the requirements of paragraphs (1), (3), and (4) of section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b) of this title” for “meet the requirements of section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title”, was executed by making the substitution for “meet the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/1"},"text":"Pub. L. 105–256, § 12(b)(1)","children":[],"tail":", inserted “identified in the Native Hawaiian comprehensive health care master plan implemented under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11703"},"text":"section 11703 of this title","children":[],"tail":"” after “health care professional”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/2"},"text":"Pub. L. 105–256, § 12(b)(2)","children":[],"tail":", (3), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/2"},"text":"Pub. L. 105–256, § 12(b)(2)","children":[],"tail":", redesignated subpar. (B) as (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/4"},"text":"Pub. L. 105–256, § 12(b)(4)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “the obligated service requirement for each scholarship recipient shall be fulfilled through service, in order of priority, in (i) any one of the five Native Hawaiian health care systems, or (ii) health professions shortage areas, medically underserved areas, or geographic areas or facilities similarly designated by the United States Public Health Service in the State of Hawaii; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/2"},"text":"Pub. L. 105–256, § 12(b)(2)","children":[],"tail":", redesignated subpar. (C) as (D). Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/2"},"text":"Pub. L. 105–256, § 12(b)(2)","children":[],"tail":", redesignated subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/256/s12/b/5"},"text":"Pub. L. 105–256, § 12(b)(5)","children":[],"tail":", (6), added subpars. (F) and (G)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
