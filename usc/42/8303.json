{"tag":"section","attrib":{"id":"idbe8f82b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8303"},"text":null,"children":[{"tag":"num","attrib":{"value":"8303"},"text":"§ 8303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter shall only apply within the contiguous 48 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe8f82b9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tI/s104"},"text":"Pub. L. 95–620, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3298"},"text":"92 Stat. 3298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/3"},"text":"Pub. L. 100–42, § 1(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/311"},"text":"101 Stat. 311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8f82ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8f82bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe8f82bc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8f82bd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42"},"text":"Pub. L. 100–42","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The provisions of this chapter shall apply in all the States, Puerto Rico, and the territories and possessions of the United States, except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the provisions of subchapters II and III of this chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8341"},"text":"section 8341 of this title","children":[],"tail":") shall only apply to powerplants and installations situated within the contiguous 48 States, Alaska, and the District of Columbia; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8341"},"text":"section 8341 of this title","children":[],"tail":" shall only apply to powerplants situated within the contiguous 48 States and the District of Columbia.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
