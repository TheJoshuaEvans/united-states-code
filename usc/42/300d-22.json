{"tag":"section","attrib":{"id":"idb615dcb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–22"},"text":"§ 300d–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", the Secretary shall report to the appropriate committees of Congress on the activities of the States carried out pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11"},"text":"section 300d–11 of this title","children":[],"tail":". Such report shall include an assessment of the extent to which Federal and State efforts to develop systems of trauma care and to designate trauma centers have reduced the incidence of mortality, and the incidence of permanent disability, resulting from trauma. Such report may include any recommendations of the Secretary for appropriate administrative and legislative initiatives with respect to trauma care."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb615dcb6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2926"},"text":"104 Stat. 2926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tVI/s601/d"},"text":"Pub. L. 103–183, title VI, § 601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref",