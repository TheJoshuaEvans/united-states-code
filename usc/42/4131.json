{"tag":"section","attrib":{"id":"idbcb9d7b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131"},"text":null,"children":[{"tag":"num","attrib":{"value":"4131"},"text":"§ 4131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee certifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcb9d7b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Flood Protection Structure Accreditation Task Force","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100226"},"text":"section 100226 of Public Law 112–141","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4101"},"text":"42 U.S.C. 4101","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/126/942"},"text":"126 Stat. 942","children":[],"tail":"), the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb9d7b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that at least 1 program activity carried out for levee systems under the levee safety and dam safety programs of the Corps of Engineers provides adequate information to the Secretary to reach a levee accreditation decision under section 65.10 of title 44, Code of Federal Regulations (or successor regulation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb9d7b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, carry out the activities referred to in paragraph (1) in alignment with the schedule established for the national flood insurance program established under chapter I of the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4011"},"text":"42 U.S.C. 4011","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb9d7b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a levee system that is operated and maintained by the Corps of Engineers, to the maximum extent practicable, cooperate with local governments seeking a levee accreditation decision for the levee to provide information necessary to support the accreditation decision in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb9d7b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated levee system evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb9d7b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receipt of a request from a non-Federal interest, the Secretary may carry out a levee system evaluation of a federally authorized levee for purposes of the national flood insurance program established under chapter 1 ","children":[{"tag":"ref","attrib":{"idref":"fn003352"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003352"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “chapter I”."}],"tail":" of the National Flood Insurance Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4011"},"text":"42 U.S.C. 4011","children":[],"tail":" et seq.) if the evaluation will be carried out earlier than such an evaluation would be carried out under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb9d7ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A levee system evaluation under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb9d7bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a minimum, comply with section 65.10 of title 44, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb9d7bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be carried out in accordance with such procedures as the Secretary, in consultation with the Administrator of the Federal Emergency Management Agency, may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb9d7bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb9d7be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–16"},"text":"section 1962d–16 of this title","children":[],"tail":" to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb9d7bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the cost share under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–16/b"},"text":"section 1962d–16(b) of this title","children":[],"tail":" to any activities carried out under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb9d7c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4131/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributed funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (B), a non-Federal interest may fund up to 100 percent of the cost of any activity carried out under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcb9d7c1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3014"},"text":"Pub. L. 113–121, title III, § 3014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1287"},"text":"128 Stat. 1287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s142/b"},"text":"Pub. L. 116–260, div. AA, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2653"},"text":"134 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb9d7c2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb9d7c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcb9d7c4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act of 1968, referred to in subsecs. (a)(2) and (b)(1), is title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to this chapter. Chapter I of the Act is classified principally to subchapter I (§ 4011 et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcb9d7c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcb9d7c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s142/b/1/A"},"text":"Pub. L. 116–260, § 142(b)(1)(A)","children":[],"tail":", substituted “for levee systems under the levee safety and dam safety programs” for “under the inspection of completed works program” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s142/b/1/B"},"text":"Pub. L. 116–260, § 142(b)(1)(B)","children":[],"tail":", substituted “the activities referred to in paragraph (1)” for “activities under the inspection of completed works program of the Corps of Engineers”, “chapter I” for “chapter 1”, and “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s142/b/1/C"},"text":"Pub. L. 116–260, § 142(b)(1)(C)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s142/b/2"},"text":"Pub. L. 116–260, § 142(b)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcb9d7c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcb9d7c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
