{"tag":"section","attrib":{"id":"idbc797322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200"},"text":null,"children":[{"tag":"num","attrib":{"value":"3200"},"text":"§ 3200.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Assistance Liaisons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc797323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Regional Director of a regional office of the Economic Development Administration may designate a staff member to act as a “Technical Assistance Liaison” for any State served by the regional office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Technical Assistance Liaison shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc797325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in coordination with an Economic Development Representative to provide technical assistance, in addition to technical assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3147"},"text":"section 3147 of this title","children":[],"tail":", to eligible recipients that are underresourced communities, as determined by the Technical Assistance Liaison, that submit applications for assistance under subchapter II; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc797326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of an eligible recipient that submitted an application for assistance under subchapter II, provide technical feedback on unsuccessful grant applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc797327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3200/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a contract or cooperative agreement with an eligible recipient for the purpose of providing technical assistance to eligible recipients that are underresourced communities that have submitted or may submit an application for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc797328-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tV/s510"},"text":"Pub. L. 89–136, title V, § 510","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2229"},"text":"Pub. L. 118–272, div. B, title II, § 2229","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3195"},"text":"138 Stat. 3195","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
