{"tag":"section","attrib":{"id":"idbabde06c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397ff"},"text":"§ 1397ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for submission, approval, and amendment of State child health plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbabde06d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbabde06e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving payment under subsection (a) or (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of this title","children":[],"tail":", a State shall submit to the Secretary a State child health plan that meets the applicable requirements of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde06f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as the Secretary may provide under subsection (e), a State plan submitted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbabde070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be approved for purposes of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbabde071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be effective beginning with a calendar quarter that is specified in the plan, but in no case earlier than ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbabde072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbabde073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may amend, in whole or in part, its State child health plan at any time through transmittal of a plan amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as the Secretary may provide under subsection (e), an amendment to a State plan submitted under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbabde075-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be approved for purposes of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbabde076-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be effective as provided in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde077-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates for amendments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbabde078-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the succeeding provisions of this paragraph, an amendment to a State plan shall take effect on one or more effective dates specified in the amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbabde079-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments relating to eligibility or benefits","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbabde07a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan amendment that eliminates or restricts eligibility or benefits under the plan may not take effect unless the State certifies that it has provided prior public notice of the change, in a form and manner provided under applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbabde07b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan amendment that eliminates or restricts eligibility or benefits under the plan shall not be effective for longer than a 60-day period unless the amendment has been transmitted to the Secretary before the end of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbabde07c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan amendment that is not described in subparagraph (B) and that becomes effective in a State fiscal year may not remain in effect after the end of such fiscal year (or, if later, the end of the 90-day period on which it becomes effective) unless the amendment has been transmitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbabde07d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of plans and plan amendments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbabde07e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt review of plan submittals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promptly review State plans and plan amendments submitted under this section to determine if they substantially comply with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde07f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 90-day approval deadlines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State plan or plan amendment is considered approved unless the Secretary notifies the State in writing, within 90 days after receipt of the plan or amendment, that the plan or amendment is disapproved (and the reasons for disapproval) or that specified additional information is needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a disapproval of a plan or plan amendment, the Secretary shall provide a State with a reasonable opportunity for correction before taking financial sanctions against the State on the basis of such disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbabde081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program operation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbabde082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall conduct the program in accordance with the plan (and any amendments) approved under subsection (c) and with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbabde083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a process for enforcing requirements under this subchapter. Such process shall provide for the withholding of funds in the case of substantial noncompliance with such requirements. In the case of an enforcement action against a State under this paragraph, the Secretary shall provide a State with a reasonable opportunity for correction before taking financial sanctions against the State on the basis of such an action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbabde084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397ff/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An approved State child health plan shall continue in effect unless and until the State amends the plan under subsection (b) or the Secretary finds, under subsection (d), substantial noncompliance of the plan with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbabde085-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XXI, § 2106, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4901/a"},"text":"Pub. L. 105–33, title IV, § 4901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/563"},"text":"111 Stat. 563","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tVII/s71401/b/3"},"text":"Pub. L. 119–21, title VII, § 71401(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/332"},"text":"139 Stat. 332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbabde086-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbabde087-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbabde088-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" inserted “subsection (a) or (g) of” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
