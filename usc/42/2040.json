{"tag":"section","attrib":{"id":"idbbe0dc80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2040"},"text":null,"children":[{"tag":"num","attrib":{"value":"2040"},"text":"§ 2040.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program of Advisory Committee on Reactor Safeguards; selection of fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To assist the Advisory Committee on Reactor Safeguards in carrying out its function, the committee shall establish a fellowship program under which persons having appropriate engineering or scientific expertise are assigned particular tasks relating to the functions of the committee. Such fellowship shall be for 2-year periods and the recipients of such fellowships shall be selected pursuant to such criteria as may be established by the committee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbe0dc81-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/209/s6"},"text":"Pub. L. 95–209, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-13"},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1483"},"text":"91 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbe0dc82-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbe0dc83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbe0dc84-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Atomic Energy Act of 1954.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
