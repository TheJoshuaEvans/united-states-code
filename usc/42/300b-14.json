{"tag":"section","attrib":{"id":"idb610f9eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–14"},"text":"§ 300b–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National contingency plan for newborn screening","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb610f9ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-04-24"},"text":"April 24, 2008","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention and in consultation with the Administrator and State departments of health (or related agencies), shall develop a national contingency plan for newborn screening for use by a State, region, or consortium of States in the event of a public health emergency. The plan shall be updated as needed and at least every five years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb610f9ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contingency plan developed under subsection (a) shall include a plan for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb610f9ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection and transport of specimens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment of specimens to State newborn screening laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing of specimens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reporting of screening results to physicians and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnostic confirmation of positive screening results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the availability of treatment and management resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating families about newborn screening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610f9f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–14/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out other activities determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb610f9f6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1115, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/204/s7"},"text":"Pub. L. 110–204, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-24"},"text":"Apr. 24, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/711"},"text":"122 Stat. 711","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/240/s8"},"text":"Pub. L. 113–240, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2855"},"text":"128 Stat. 2855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb610f9f7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb610f9f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb610f9f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240"},"text":"Pub. L. 113–240","children":[],"tail":" substituted “consortium” for “consortia” and inserted at end “The plan shall be updated as needed and at least every five years.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
