{"tag":"section","attrib":{"id":"idb618261f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–45"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–45"},"text":"§ 300d–45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this part, there are authorized to be appropriated $100,000,000 for fiscal year 2009, and such sums as may be necessary for each of fiscal years 2010 through 2015. Such authorization of appropriations is in addition to any other authorization of appropriations or amounts that are available for such purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6182620-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1245, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tVI/s601"},"text":"Pub. L. 102–321, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/435"},"text":"106 Stat. 435","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3505/a/5"},"text":"Pub. L. 111–148, title III, § 3505(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/525"},"text":"124 Stat. 525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6182621-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6182622-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"tex