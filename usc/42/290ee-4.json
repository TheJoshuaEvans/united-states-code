{"tag":"section","attrib":{"id":"idb5bff442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–4"},"text":"§ 290ee–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental and behavioral health outreach and education at institutions of higher education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5bff443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to increase access to, and reduce the stigma associated with, mental health services to ensure that students at institutions of higher education have the support necessary to successfully complete their studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National public education campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Assistant Secretary and in collaboration with the Director of the Centers for Disease Control and Prevention, shall convene an interagency, public-private sector working group to plan, establish, and begin coordinating and evaluating a targeted public education campaign that is designed to focus on mental and behavioral health on the campuses of institutions of higher education. Such campaign shall be designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the general understanding of mental health and mental disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage help-seeking behaviors relating to the promotion of mental health, prevention of mental disorders, and treatment of such disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the connection between mental and behavioral health and academic success; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the general public in identifying the early warning signs and reducing the stigma of mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group convened under subsection (b) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health consumers, including students and family members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff44b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of institutions of higher education, including minority-serving institutions as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":" and community colleges;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff44c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of national mental and behavioral health associations and associations of institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff44d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of health promotion and prevention organizations at institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff44e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of mental health providers, including community mental health centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff44f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of private-sector and public-sector groups with experience in the development of effective public health education campaigns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff450-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group under subsection (b) shall develop a plan that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5bff451-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targets promotional and educational efforts to the age population of students at institutions of higher education and individuals who are employed in settings of institutions of higher education, including through the use of roundtables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops and proposes the implementation of research-based public health messages and activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff453-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides support for local efforts to reduce stigma by using the National Health Information Center as a primary point of contact for information, publications, and service program referrals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5bff454-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops and proposes the implementation of a social marketing campaign that is targeted at the population of students attending institutions of higher education and individuals who are employed in settings of institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff455-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5bff456-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $1,000,000 for the period of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5bff457-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 549, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9033"},"text":"Pub. L. 114–255, div. B, title IX, § 9033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1261"},"text":"130 Stat. 1261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1424"},"text":"Pub. L. 117–328, div. FF, title I, § 1424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5704"},"text":"136 Stat. 5704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5bff458-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5bff459-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5bff45a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1424/1"},"text":"Pub. L. 117–328, § 1424(1)","children":[],"tail":", substituted “at institutions of higher education” for “on college campuses” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1424/2"},"text":"Pub. L. 117–328, § 1424(2)","children":[],"tail":", inserted “, including minority-serving institutions as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":" and community colleges” after “higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1424/3"},"text":"Pub. L. 117–328, § 1424(3)","children":[],"tail":", substituted “2023 through 2027” for “2018 through 2022”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
