{"tag":"section","attrib":{"id":"idbce2474b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4842"},"text":null,"children":[{"tag":"num","attrib":{"value":"4842"},"text":"§ 4842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation by Secretary with other departments and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out their respective authorities under this chapter, the Secretary of Housing and Urban Development and the Secretary of Health and Human Services shall each cooperate with and seek the advice of the heads of any other departments or agencies regarding any programs under their respective responsibilities which are related to, or would be affected by, such authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce2474c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/695/tV/s502"},"text":"Pub. L. 91–695, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-13"},"text":"Jan. 13, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2080"},"text":"84 Stat. 2080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/317/tII/s204/d"},"text":"Pub. L. 94–317, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-23"},"text":"June 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/706"},"text":"90 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce2474d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce2474e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbce2474f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/317"},"text":"Pub. L. 94–317","children":[],"tail":" substituted “In carrying out their respective authorities under this chapter, the Secretary of Housing and Urban Development and the Secretary of Health, Education, and Welfare shall each” for “In carrying out the authority under this chapter, the Secretary of Health, Education, and Welfare shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbce24750-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbce24751-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted in text for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
