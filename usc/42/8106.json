{"tag":"section","attrib":{"id":"idbe7ee05c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106"},"text":null,"children":[{"tag":"num","attrib":{"value":"8106"},"text":"§ 8106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe7ee05d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall publish an annual report which shall be transmitted by the corporation to the President and the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee05e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audit of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The accounts of the corporation shall be audited annually. Such audits shall be conducted in accordance with generally accepted auditing standards by independent certified public accountants who are certified by a regulatory authority of the jurisdiction in which the audit is undertaken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee05f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional audits by Government Accountability Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the annual audit, the financial transactions of the corporation for any fiscal year during which Federal funds are available to finance any portion of its operations may be audited by the Government Accountability Office in accordance with such rules and regulations as may be prescribed by the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of grantees and contractors of corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year during which Federal funds are available to finance any portion of the corporation’s grants or contracts, the Government Accountability Office, in accordance with such rules and regulations as may be prescribed by the Comptroller General of the United States, may audit the grantees or contractors of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe7ee061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual financial audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall conduct or require each grantee or contractor to provide for an annual financial audit. The report of each such audit shall be maintained for a period of at least five years at the principal office of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe7ee062-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tVI/s607"},"text":"Pub. L. 95–557, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2118"},"text":"92 Stat. 2118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2161"},"text":"Pub. L. 104–66, title II, § 2161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/731"},"text":"109 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe7ee063-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe7ee064-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe7ee065-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out at end “The financial transactions of the corporation shall be audited by the General Accounting Office at least once during each three years.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe7ee066-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe7ee067-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Demonstration Program of Mutual Housing Associations; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s316"},"text":"Pub. L. 96–399, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1645"},"text":"94 Stat. 1645","children":[],"tail":", directed submission to Congress, not later than "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":", of report by Neighborhood Reinvestment Corporation, in conjunction with the National Consumer Cooperative Bank and the Secretary of Housing and Urban Development, on the findings, conclusions, and legislative recommendations reached as a result of the national demonstration program of mutual housing associations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
