{"tag":"section","attrib":{"id":"idbf6aee62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337"},"text":null,"children":[{"tag":"num","attrib":{"value":"12337"},"text":"§ 12337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State coordination of services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aee63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall make grants under this section to States on a formula basis for the purpose of improving the coordination of services provided to children, youth, and families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, the chief executive officer of a State shall prepare and submit to the Commissioner an application containing a plan providing assurances that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent State body is committed to interagency planning that results in statewide policies promoting systematic collaboration among agencies on behalf of young individuals as demonstrated by joint planning, joint financing, joint service delivery, common intake and assessment, and other arrangements that reduce barriers to services and promote more effective local service delivery systems for young individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such plan will be based on needs as identified through an analysis of updated reports (such as “State of the Child” reports) prepared by the State, including detailed information gathered by the State, to the extent practicable, on young individuals and the families of such individuals concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age, sex, race, and ethnicity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residences of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence of homelessness among such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the composition of families of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic situations of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence of poverty among such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experiences in the care of such individuals away from home;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violence in the homes or communities of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the attachment of such individuals to school and work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dropout rates of such individuals from school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the character of the communities in which such individuals reside;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the system to be used for the distribution of funds within the State will require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each area have an equal opportunity to apply for or receive funds under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public be given an opportunity to express views concerning the development and administration of such plan;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent State body will provide an inventory of existing public and private services for children, youth and their families and will evaluate the need for supportive services within the State to address the purposes of this chapter and determine the extent to which existing public and private programs meet such need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent State body will make such reports, in such form, and containing such information, as the Commissioner may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such fiscal control and fund accounting procedures will be adopted as may be necessary to ensure proper disbursement of, and accounting for, Federal funds paid under this part to the chief executive officer of the State, including any such funds paid to the recipients of a grant or contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent State body will conduct periodic evaluations of activities and projects carried out pursuant to this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":" and will report the results and recommendations to the chief executive officer of the State and the State legislature;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief executive officer of the State will provide technical assistance or in-service training opportunities for personnel responsible for carrying out the purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief executive officer of each State will provide for the implementation of the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":", relating to supportive services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12340/g"},"text":"section 12340(g) of this title","children":[],"tail":", the amounts made available to each State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12340/a"},"text":"section 12340(a) of this title","children":[],"tail":" may be used to make grants to a State to enable such State to pay such percentages as the independent State body of such State determines to be appropriate, of the cost of administering the State plan of such State including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the preparation of such plan and the provision of technical assistance to local areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the evaluation of activities carried out under such plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the collection of data and the carrying out of analyses related to the need for supportive services within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the dissemination of information obtained under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the provision of short-term training to personnel of public or nonprofit private agencies and organizations engaged in the operation of programs authorized by this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (d) has been enacted."}],"tail":" Supplement not supplant"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received by a State under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":" shall be used only to supplement, not to supplant, the amount of Federal, State, and local funds expended for the purposes for which grants are made under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":". In no event shall such expenditures be used to satisfy the matching requirements of any other Federal program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12337/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to family resource and support program grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State intends to apply for a grant under section 12339 ","children":[{"tag":"ref","attrib":{"idref":"fn004045"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title to be used for the same calendar year as the grant under this section, such State shall include in the application for a grant under this section a description of plans for family resource and support programs and for the coordination of the use of all funds received under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aee84-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s931"},"text":"Pub. L. 101–501, title IX, § 931","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1271"},"text":"104 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aee85-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aee86-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6aee87-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12339"},"text":"Section 12339 of this title","children":[],"tail":", referred to in subsec. (f), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s401/b/1"},"text":"Pub. L. 103–252, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/672"},"text":"108 Stat. 672","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aee88-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aee89-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
