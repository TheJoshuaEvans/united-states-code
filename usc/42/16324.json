{"tag":"section","attrib":{"id":"idc00d21cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324"},"text":null,"children":[{"tag":"num","attrib":{"value":"16324"},"text":"§ 16324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy research fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d21ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postdoctoral fellowship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program under which the Secretary provides fellowships to encourage outstanding young scientists and engineers to pursue postdoctoral research appointments in energy research and development at institutions of higher education of their choice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d21cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior research fellowships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d21d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program under which the Secretary provides fellowships to allow outstanding senior researchers and their research groups in energy research and development to explore research and development topics of their choosing for a period of not less than 3 years, to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d21d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing a fellowship under the program described in paragraph (1), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d21d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past scientific or technical accomplishment of a senior researcher; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d21d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16324/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for continued accomplishment by the researcher during the period of the fellowship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d21d4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s984"},"text":"Pub. L. 109–58, title IX, § 984","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/908"},"text":"119 Stat. 908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
