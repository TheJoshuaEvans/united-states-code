{"tag":"section","attrib":{"id":"idbd6cac9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6106a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6106a"},"text":"§ 6106a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to the Secretary and Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6cac9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6106a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 31 of each year (beginning in 1979), the head of each Federal department or agency shall submit to the Secretary of Health and Human Services a report (1) describing in detail the steps taken during the preceding fiscal year by such department or agency to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":"; and (2) containing specific data about program participants or beneficiaries, by age, sufficient to permit analysis of how well the department or agency is carrying out the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6cac9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6106a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 31 of each year (beginning in 1980), the Secretary of Health and Human Services shall compile the reports made pursuant to subsection (a) and shall submit them to the Congress, together with an evaluation of the performance of each department or agency with respect to carrying out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6cac9d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135/tIII/s308"},"text":"Pub. L. 94–135, title III, § 308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tIV/s401/e"},"text":"Pub. L. 95–478, title IV, § 401(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1556"},"text":"92 Stat. 1556","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd6cac9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6cac9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd6caca0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135/s308"},"text":"section 308 of Pub. L. 94–135","children":[],"tail":" was renumbered section 309 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6107"},"text":"section 6107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statuto