{"tag":"section","attrib":{"id":"idbd599b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5811"},"text":null,"children":[{"tag":"num","attrib":{"value":"5811"},"text":"§ 5811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Energy Research and Development Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established an independent executive agency to be known as the Energy Research and Development Administration (hereinafter in this chapter referred to as the “Administration”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd599b6f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tI/s101"},"text":"Pub. L. 93–438, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1234"},"text":"88 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd599b70-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd599b71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd599b72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438"},"text":"Pub. L. 93–438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1233"},"text":"88 Stat. 1233","children":[],"tail":", which enacted this chapter, amended sections 5313 to 5316 of Title 5, Government Organization and Employees, repealed sections 2031 and 2032 of this title, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"section 5801 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd599b73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd599b74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Energy Research and Development Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
