{"tag":"section","attrib":{"id":"idbffc59a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251"},"text":null,"children":[{"tag":"num","attrib":{"value":"16251"},"text":"§ 16251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production incentives for cellulosic biofuels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffc59a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate deployment and commercialization of biofuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver the first 1,000,000,000 gallons in annual cellulosic biofuels production by 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure biofuels produced after 2015 are cost competitive with gasoline and diesel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that small feedstock producers and rural small businesses are full participants in the development of the cellulosic biofuels industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellulosic biofuels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cellulosic biofuels” means any fuel that is produced from cellulosic feedstocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a producer of fuel from cellulosic biofuels the production facility of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all applicable Federal and State permitting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any financial criteria established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Agriculture, the Secretary of Defense, and the Administrator of the Environmental Protection Agency, shall establish an incentive program for the production of cellulosic biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of incentives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall award production incentives on a per gallon basis of cellulosic biofuels from eligible entities, through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set payments per gallon of cellulosic biofuels produced in an amount determined by the Secretary, until initiation of the first reverse auction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reverse auction thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First reverse auction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The first reverse auction shall be held on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the first year of annual production in the United States of 100,000,000 gallons of cellulosic biofuels, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reverse auction procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On initiation of the first reverse auction, and each year thereafter until the earlier of the first year of annual production in the United States of 1,000,000,000 gallons of cellulosic biofuels, as determined by the Secretary, or 10 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall conduct a reverse auction at which—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbffc59ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall solicit bids from eligible entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffc59bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" eligible entities shall submit—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbffc59bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a desired level of production incentive on a per gallon basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbffc59bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimated annual production amount in gallons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffc59be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall issue awards for the production amount submitted, beginning with the eligible entity submitting the bid for the lowest level of production incentive on a per gallon basis and meeting such other criteria as are established by the Secretary, until the amount of funds available for the reverse auction is committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of incentive received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity selected by the Secretary through a reverse auction shall receive the amount of performance incentive requested in the auction for each gallon produced and sold by the entity during the first 6 years of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of production of cellulosic biofuels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the receipt of an award under this section, an eligible entity shall enter into an agreement with the Secretary under which the eligible entity agrees to begin production of cellulosic biofuels not later than 3 years after the date of the reverse auction in which the eligible entity participates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Awards under this section shall be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a per gallon amount determined by the Secretary during the first 4 years of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a declining per gallon cap over the remaining lifetime of the program, to be established by the Secretary so that cellulosic biofuels produced after the first year of annual cellulosic biofuels production in the United States in excess of 1,000,000,000 gallons are cost competitive with gasoline and diesel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 25 percent of the funds committed within each reverse auction to any 1 project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $100,000,000 in any 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $1,000,000,000 over the lifetime of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting a project under the program, the Secretary shall give priority to projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate outstanding potential for local and regional economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include agricultural producers or cooperatives of agricultural producers as equity partners in the ventures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a strategic agreement in place to fairly reward feedstock suppliers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16251/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $250,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffc59cc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s942"},"text":"Pub. L. 109–58, title IX, § 942","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/878"},"text":"119 Stat. 878","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
