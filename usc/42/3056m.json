{"tag":"section","attrib":{"id":"idbc6660a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056m"},"text":"§ 3056m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on service to minority individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6660aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually prepare a report on the levels of participation and performance outcomes of minority individuals served by the program carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6660ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6660ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization and data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such report shall present information on the levels of participation and the outcomes achieved by such minority individuals with respect to each grantee under this subchapter, by service area, and in the aggregate, beginning with data that applies to program year 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6660ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall also include a description of each grantee’s efforts to serve minority individuals, based on information submitted to the Secretary by each grantee at such time and in such manner as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6660ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Related matters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall also include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6660af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of individual grantees based on the criteria established under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6660b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of whether any changes in grantees have affected participation rates of such minority individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6660b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on factors affecting participation rates among such minority individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6660b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for increasing participation of minority individuals in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6660b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria for determining the effectiveness of grantees in serving minority individuals in accordance with the goals set forth in section 3056(a)(1) of title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6660b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually submit such a report to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6660b5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s515"},"text":"Pub. L. 89–73, title V, § 515","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2587"},"text":"120 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6660b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6660b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc6660b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3056m, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s515"},"text":"Pub. L. 89–73, title V, § 515","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tV/s501"},"text":"Pub. L. 106–501, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2286"},"text":"114 Stat. 2286","children":[],"tail":", related to authorization of appropriations, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":". See section 3056"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
