{"tag":"section","attrib":{"id":"idbf89e7be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651a"},"text":"§ 12651a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf89e7bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e7c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be in the Corporation a Board of Directors (referred to in this division as the “Board”) that shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf89e7c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 15 members, including an individual between the ages of 16 and 25 who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf89e7c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served in a school-based or community-based service-learning program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf89e7c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is or was a participant or a supervisor in a program;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to be appointed by the President, by and with the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ex officio nonvoting members described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the President shall appoint members—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf89e7c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have extensive experience in volunteer or service activities, which may include programs funded under one of the national service laws, and in State government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who represent a broad range of viewpoints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are experts in the delivery of human, educational, environmental, or public safety services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so that the Board shall be diverse according to race, ethnicity, age, gender, and disability characteristics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf89e7ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so that no more than 50 percent of the appointed members of the Board, plus 1 additional appointed member, are from a single political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Education, the Secretary of Health and Human Services, the Secretary of Labor, the Secretary of the Interior, the Secretary of Agriculture, the Secretary of Housing and Urban Development, the Secretary of Defense, the Attorney General, the Director of the Peace Corps, the Administrator of the Environmental Protection Agency, and the Chief Executive Officer shall serve as ex officio nonvoting members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e7cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint a member of the Board to serve as the initial Chairperson of the Board. Each subsequent Chairperson shall be elected by the Board from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall elect a Vice Chairperson from among its membership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e7cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may elect from among its membership such additional officers of the Board as the Board determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), each appointed member shall serve for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a vacancy occurs on the Board, a new member shall be appointed by the President, by and with the advice and consent of the Senate, and serve for the remainder of the term for which the predecessor of such member was appointed. The vacancy shall not affect the power of the remaining members to execute the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e7d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service until appointment of successor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voting member of the Board whose term has expired may continue to serve on the Board until the date on which the member’s successor takes office, which period shall not exceed 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf89e7d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s192"},"text":"Pub. L. 101–610, title I, § 192","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII/s202/a"},"text":"Pub. L. 103–82, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/873"},"text":"107 Stat. 873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1701"},"text":"Pub. L. 111–13, title I, § 1701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1544"},"text":"123 Stat. 1544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf89e7d4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf89e7d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf89e7d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1701/1"},"text":"Pub. L. 111–13, § 1701(1)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c), which provided term lengths for members first appointed to the Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1701/2"},"text":"Pub. L. 111–13, § 1701(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf89e7d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf89e7d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf89e7d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s202/i/2"},"text":"section 202(i)(2) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
