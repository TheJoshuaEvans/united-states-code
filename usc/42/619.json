{"tag":"section","attrib":{"id":"idb797e833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s619"},"text":null,"children":[{"tag":"num","attrib":{"value":"619"},"text":"§ 619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb797e834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s619/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adult” means an individual who is not a minor child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb797e835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s619/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor child","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “minor child” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb797e836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s619/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained 18 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb797e837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s619/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained 19 years of age and is a full-time student in a secondary school (or in the equivalent level of vocational or technical training).","chi