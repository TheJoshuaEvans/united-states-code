{"tag":"section","attrib":{"id":"idb495cbc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"242q–2"},"text":"§ 242q–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative staff and support","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through either the Assistant Secretary for Health or the Director of the National Institute on Aging, shall appoint an Executive Secretary for the Task Force and shall provide the Task Force with such administrative staff and support as may be necessary to enable the Task Force to carry out subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s242q"},"text":"section 242q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb495cbca-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIII/s303"},"text":"Pub. L. 101–557, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2770"},"text":"104 Stat. 2770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cbcb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cbcc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cbcd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Home Health Care and Alzheimer’s Disease Amendments of 1990, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
