{"tag":"section","attrib":{"id":"idbdb6868f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632"},"text":null,"children":[{"tag":"num","attrib":{"value":"6632"},"text":"§ 6632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdb68690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition; appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb68691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Science and Technology Policy established under subchapter II of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb68692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than eight nor more than fourteen other members appointed by the President not more than sixty days after the Director has assumed office (as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6612"},"text":"section 6612 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb68693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee appointed by the President pursuant to subsection (a)(2) of this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb68694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be qualified and distinguished in one or more of the following areas: science, engineering, technology, information dissemination, education, management, labor, or public affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb68695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of critically assessing the policies, priorities, programs, and activities of the Nation, with respect to the findings, policies, and purposes set forth in subchapter I; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb68696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall collectively constitute a balanced composition with respect to (A) fields of science and engineering, (B) academic, industrial, and government experience, and (C) business, labor, consumer, and public interest points of view.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb68697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; Vice Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint one member of the Committee to serve as Chairman and another member to serve as Vice Chairman for such periods as the President may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb68698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6632/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Committee who is not an officer of the Federal Government shall, while serving on business of the Committee, be entitled to receive compensation at a rate not to exceed the daily rate prescribed for GS–18 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", including traveltime, and while so serving away from his home or regular place of business he may be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as the expenses authorized by section 5703(b) "},{"tag":"ref","attrib":{"idref":"fn003500"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003500"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5 for persons in Government service employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdb68699-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/282/tIII/s302"},"text":"Pub. L. 94–282, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/468"},"text":"90 Stat. 468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb6869a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb6869b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdb6869c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"Section 5703 of title 5","children":[],"tail":", referred to in subsec. (d), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/22/s4"},"text":"Pub. L. 94–22, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-05-19"},"text":"May 19, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/95"},"text":"89 Stat. 95","children":[],"tail":", and, as so amended, does not contain a subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdb6869d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdb6869e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdb6869f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbdb686a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of President’s Committee on Science and Technology; Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6631"},"text":"section 6631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
