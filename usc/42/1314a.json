{"tag":"section","attrib":{"id":"idb8249794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1314a"},"text":"§ 1314a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurement and reporting of welfare receipt","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8249795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress hereby declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8249796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is the policy and responsibility of the Federal Government to reduce the rate at which and the degree to which families depend on income from welfare programs and the duration of welfare receipt, consistent with other essential national goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8249797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is the policy of the United States to strengthen families, to ensure that children grow up in families that are economically self-sufficient and that the life prospects of children are improved, and to underscore the responsibility of parents to support their children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8249798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government should help welfare recipients as well as individuals at risk of welfare receipt to improve their education and job skills, to obtain child care and other necessary support services, and to take such other steps as may be necessary to assist them to become financially independent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8249799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is the purpose of this section to provide the public with generally accepted measures of welfare receipt so that it can track such receipt over time and determine whether progress is being made in reducing the rate at which and, to the extent feasible, the degree to which, families depend on income from welfare programs and the duration of welfare receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb824979a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of welfare indicators and predictors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services (in this section referred to as the “Secretary”) in consultation with the Secretary of Agriculture shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb824979b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb824979c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicators of the rate at which and, to the extent feasible, the degree to which, families depend on income from welfare programs and the duration of welfare receipt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb824979d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictors of welfare receipt;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb824979e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the data needed to report annually on the indicators and predictors, including the ability of existing data collection efforts to provide such data and any additional data collection needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb824979f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":", provide an interim report containing conclusions resulting from the development and assessment described in paragraphs (1) and (2), to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82497a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Education and Labor of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Labor and Human Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82497a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board on Welfare Indicators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82497a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an Advisory Board on Welfare Indicators (in this subsection referred to as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be composed of 12 members with equal numbers to be appointed by the House of Representatives, the Senate, and the President. The Board shall be composed of experts in the fields of welfare research and welfare statistical methodology, representatives of State and local welfare agencies, and organizations concerned with welfare issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy occurring in the membership of the Board shall be filled in the same manner as the original appointment for the position being vacated. The vacancy shall not affect the power of the remaining members to execute the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Duties of the Board shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82497ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice and recommendations to the Secretary on the development of indicators of the rate at which and, to the extent feasible, the degree to which, families depend on income from welfare programs and the duration of welfare receipt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice on the development and presentation of annual reports required under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall not be compensated, but shall receive travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 for each day the member is engaged in the performance of duties away from the home or regular place of business of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall detail, without reimbursement, any of the personnel of the Department of Health and Human Services to the Board to assist the Board in carrying out its duties. Any detail shall not interrupt or otherwise affect the civil service status or privileges of the Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Board may accept the voluntary services provided by a member of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be terminated at such time as the Secretary determines the duties described in paragraph (4) have been completed, but in any case prior to the submission of the first report required under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82497b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual welfare indicators report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82497b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare annual reports on welfare receipt in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall include analysis of families and individuals receiving assistance under means-tested benefit programs, including the program of aid to families with dependent children under part A of subchapter IV of this chapter, the supplemental nutrition assistance program under the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.), and the Supplemental Security Income program under subchapter XVI of this chapter, or as general assistance under programs administered by State and local governments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report shall set forth for each of the means-tested benefit programs described in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82497b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" indicators of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb82497b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which and, to the extent feasible, the degree to which, families depend on income from welfare programs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82497b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of welfare receipt;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends in indicators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictors of welfare receipt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the causes of welfare receipt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patterns of multiple program receipt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary deems relevant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82497be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such recommendations for legislation, which shall not include proposals to reduce eligibility levels or impose barriers to program access, as the Secretary may determine to be necessary or desirable to reduce—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb82497bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which and the degree to which families depend on income from welfare programs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82497c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of welfare receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82497c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit such a report not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1994-10-31"},"text":"October 31, 1994","children":[],"tail":", and annually thereafter, to the committees specified in subsection (b)(3). Each such report shall be transmitted during the first 60 days of each regular session of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82497c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1314a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Welfare Indicators Act of 1994”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82497c3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tII/s232"},"text":"Pub. L. 103–432, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4462"},"text":"108 Stat. 4462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/200/tIV/s410/h"},"text":"Pub. L. 105–200, title IV, § 410(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/674"},"text":"112 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4002/b/1/A"},"text":"Pub. L. 110–234, title IV, § 4002(b)(1)(A)","children":[],"tail":", (B), (2)(X), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1095-1097"},"text":"122 Stat. 1095–1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4002(b)(1)(A), (B), (2)(X), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1857, 1859.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82497c4-3a70-11f1-ae07-e4213316b5