{"tag":"section","attrib":{"id":"idbfee28b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16001"},"text":null,"children":[{"tag":"num","attrib":{"value":"16001"},"text":"§ 16001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency in federally assisted housing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Housing and Urban Development shall promote energy conservation in housing that is located on Indian land and assisted with Federal resources through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee28b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of energy-efficient technologies and innovations (including the procurement of energy-efficient refrigerators and other appliances);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of shared savings contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee28bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use and implementation of such other similar technologies and innovations as the Secretary of Housing and Urban Development considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee28bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tV/s506/a"},"text":"Pub. L. 109–58, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/779"},"text":"119 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfee28bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfee28be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfee28bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which enacted this subchapter, as the “Indian Tribal Energy Development and Self-Determination Act of 2005”, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s501"},"text":"section 501 of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
