{"tag":"section","attrib":{"id":"idbfb9aa78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283"},"text":null,"children":[{"tag":"num","attrib":{"value":"13283"},"text":"§ 13283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discount payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb9aa79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide a discount payment to a proposer of a proposal selected under this part for purposes of reimbursing the proposer for a discount provided to the users if the proposer certifies to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aa7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the electric motor vehicles have been purchased or leased by a user or users in accordance with the requirements of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposer has provided to the user or users a discount payment in accordance with the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after receipt from the proposer of certification that the Secretary determines satisfies the requirements of subsection (a), the Secretary shall pay to the proposer the full amount of the discount payment, to the extent provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb9aa7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculations of discount payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb9aa7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The discount payment shall be no greater than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb9aa7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price differential; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb9aa80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price of the comparable conventionally fueled motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purchase price of the electric motor vehicle, less the discount payment and less any additional reduction in the purchase price of the electric motor vehicle that may result from contributions provided by other parties, may not be less than the manufacturer’s suggested retail price of a comparable conventionally fueled motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb9aa82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13283/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum discount payment shall be no greater than $10,000 per electric motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb9aa83-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s613"},"text":"Pub. L. 102–486, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2902"},"text":"106 Stat. 2902","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
