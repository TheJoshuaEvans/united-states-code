{"tag":"section","attrib":{"id":"idbfa8e17f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12891"},"text":null,"children":[{"tag":"num","attrib":{"value":"12891"},"text":"§ 12891.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12891/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning grants to help applicants develop homeownership programs in accordance with this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12891/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation grants to enable applicants to carry out homeownership programs in accordance with this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa8e182-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s441"},"text":"Pub. L. 101–625, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4172"},"text":"104 Stat. 4172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s181/a/2/B/ii"},"text":"Pub. L. 102–550, title I, § 181(a)(2)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3735"},"text":"106 Stat. 3735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa8e183-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa8e184-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa8e185-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" struck out “(a) "},{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":"” before “The Secretary is authorized” and subsec. (b) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—There are authorized to be appropriated for grants under this part $36,000,000 for fiscal year 1991, and $195,000,000 for fiscal year 1992. Any amounts appropriated pursuant to this subsection shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
