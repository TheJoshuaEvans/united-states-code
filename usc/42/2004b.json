{"tag":"section","attrib":{"id":"idbbd284f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2004b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004b"},"text":"§ 2004b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of education, hospital and health facility, etc., contracts and grants by Public Health Service personnel; request for detail of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s215"},"text":"section 215 of this title","children":[],"tail":", upon the request of any Indian tribe, band, group, or community, commissioned officers of the Service may be assigned by the Secretary for the purpose of assisting such Indian tribe, group, band, or community in carrying out the provisions of contracts with, or grants to, tribal organizations pursuant to sections 5321 and 5322 of title 25."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbd284f5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-05/ch658/s8"},"text":"Aug. 5, 1954, ch. 658, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/tI/s104/b"},"text":"Pub. L. 93–638, title I, § 104(b)","children":[],"tail":", formerly § 105(b), "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2208"},"text":"88 Stat. 2208","children":[],"tail":"; renumbered § 104(b) and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s203/a"},"text":"Pub. L. 100–472, title II, § 203(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2290"},"text":"102 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd284f6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbd284f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbd284f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/472"},"text":"Pub. L. 100–472","children":[],"tail":", which directed amendment of this section by substituting reference to sections 5321 and 5322 of title 25 for reference to section 5321, former section 450g, “and” "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5322"},"text":"section 5322 of title 25","children":[],"tail":", was executed by making the substitution for reference to section 5321, former section 450g, “or” "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5322"},"text":"section 5322 of title 25","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
