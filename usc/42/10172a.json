{"tag":"section","attrib":{"id":"idbf1776d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10172a"},"text":"§ 10172a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Siting a second repository","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1776d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional action required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not conduct site-specific activities with respect to a second repository unless Congress has specifically authorized and appropriated funds for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report to the President and to Congress on or after ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", but not later than "},{"tag":"date","attrib":{"date":"2010-01-01"},"text":"January 1, 2010","children":[],"tail":", on the need for a second repository."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of granite research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", the Secretary shall phase out in an orderly manner funding for all research programs in existence on "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", designed to evaluate the suitability of crystalline rock as a potential repository host medium."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1776d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional siting criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that the Secretary at any time after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", considers any sites in crystalline rock for characterization or selection as a repository, the Secretary shall consider (as a supplement to the siting guidelines under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10132"},"text":"section 10132 of this title","children":[],"tail":") such potentially disqualifying factors as—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1776d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seasonal increases in population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proximity to public drinking water supplies, including those of metropolitan areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1776d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10172a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact that characterization or siting decisions would have on lands owned or placed in trust by the United States for Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1776d8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s161"},"text":"Pub. L. 97–425, title I, § 161","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII/s300"},"text":"Pub. L. 100–202, § 101(d) [title III, § 300]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5012"},"text":"Pub. L. 100–203, title V, § 5012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-231"},"text":"101 Stat. 1330–231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1776d9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1776da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1776db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
