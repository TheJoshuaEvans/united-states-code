{"tag":"section","attrib":{"id":"idbe054461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381e"},"text":"§ 7381e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science of the Department of Energy in a fiscal year, there are authorized to be appropriated to the Secretary for carrying out university research support and other science, mathematics, and engineering education programs authorized by this part and administered by the Office of Science of the Department of Energy, $40,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe054462-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3169"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3169","children":[],"tail":", formerly § 3168, "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1843"},"text":"104 Stat. 1843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/245/tIII/s309/b/2/D"},"text":"Pub. L. 105–245, title III, § 309(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1853"},"text":"112 Stat. 1853","children":[],"tail":"; renumbered § 3169, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1105/b/1"},"text":"Pub. L. 109–58, title XI, § 1105(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/939"},"text":"119 Stat. 939","chil