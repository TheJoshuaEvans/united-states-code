{"tag":"section","attrib":{"id":"idb5b40d91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–36d"},"text":"§ 290bb–36d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment Referral Routing Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b40d92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary, shall maintain the National Treatment Referral Routing Service (referred to in this section as the “Routing Service”) to assist individuals and families in locating mental and substance use disorders treatment providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To maintain the Routing Service, the activities of the Assistant Secretary shall include administering—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40d94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nationwide, telephone number providing year-round access to information that is updated on a regular basis regarding local behavioral health providers and community-based organizations in a manner that is confidential, without requiring individuals to identify themselves, is in languages that include at least English and Spanish, and is at no cost to the individual using the Routing Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Internet website to provide a searchable, online treatment services locator of behavioral health treatment providers and community-based organizations, which shall include information on the name, location, contact information, and basic services provided by such providers and organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removing practitioner contact information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that the Internet website described in subsection (b)(2) contains information on any practitioner who prescribes narcotic drugs in schedule III, IV, or V of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"section 812 of title 21","children":[],"tail":" for the purpose of maintenance or detoxification treatment, the Assistant Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40d97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide an opportunity to such practitioner to have the contact information of the practitioner removed from the website at the request of the practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may evaluate other methods to periodically update the information displayed on such website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prevent the Assistant Secretary from using any unobligated amounts otherwise made available to the Administration to maintain the Routing Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b40d9a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520E–4, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9006"},"text":"Pub. L. 114–255, div. B, title IX, § 9006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1239"},"text":"130 Stat. 1239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/215/tI/s103/b/3/A"},"text":"Pub. L. 117–215, title I, § 103(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-02"},"text":"Dec. 2, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2263"},"text":"136 Stat. 2263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1262/b/3"},"text":"Pub. L. 117–328, div. FF, title I, § 1262(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5682"},"text":"136 Stat. 5682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iv"},"text":"Pub. L. 119–26, § 4(2)(B)(iv)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-16"},"text":"July 16, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/417"},"text":"139 Stat. 417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b40d9b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b40d9c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b40d9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iv"},"text":"Pub. L. 119–26, § 4(2)(B)(iv)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1262/b/3"},"text":"Pub. L. 117–328, § 1262(b)(3)","children":[],"tail":". See 2022 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1262/b/3"},"text":"Pub. L. 117–328, § 1262(b)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4/2/B/iv"},"text":"Pub. L. 119–26, § 4(2)(B)(iv)","children":[],"tail":", substituted “information on any practitioner who prescribes narcotic drugs in schedule III, IV, or V of "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"section 812 of title 21","children":[],"tail":" for the purpose of maintenance or detoxification treatment” for “information on any qualified practitioner that is certified to prescribe medication for opioid dependency under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s823/h/2/B"},"text":"section 823(h)(2)(B) of title 21","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/215"},"text":"Pub. L. 117–215","children":[],"tail":" substituted “823(h)(2)(B)” for “823(g)(2)(B)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5b40d9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5b40d9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/26/s4"},"text":"Pub. L. 119–26, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-16"},"text":"July 16, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/416"},"text":"139 Stat. 416","children":[],"tail":", provided that the amendment made by section 4(2)(B)(iv) is effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
