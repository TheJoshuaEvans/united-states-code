{"tag":"section","attrib":{"id":"idbf938535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655c"},"text":"§ 12655c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus of programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf938536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Programs that receive assistance under this division may carry out activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf938537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of conservation corps programs, focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf938538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation, rehabilitation, and the improvement of wildlife habitat, rangelands, parks, and recreational areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urban and rural revitalization, historical and cultural site preservation, and reforestation of both urban and rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish culture, wildlife habitat maintenance and improvement, and other fishery assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" road and trail maintenance and improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" erosion, flood, drought, and storm damage assistance and controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stream, lake, waterfront harbor, and port improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wetlands protection and pollution control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93853f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insect, disease, rodent, and fire prevention and control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of abandoned railroad beds and rights-of-way;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy conservation projects, renewable resource enhancement, and recovery of biomass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reclamation and improvement of strip-mined land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forestry, nursery, and cultural operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making public facilities accessible to individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf938545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of youth service corps programs, include participant service in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf938546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and regional governmental agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nursing homes, hospices, senior centers, hospitals, local libraries, parks, recreational facilities, child and adult day care centers, programs serving individuals with disabilities, and schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement agencies,","children":[{"tag":"ref","attrib":{"idref":"fn004093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" and penal and probation systems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf938549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private nonprofit organizations that primarily focus on social service such as community action agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93854a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that focus on the rehabilitation or improvement of public facilities, neighborhood improvements, literacy training that benefits educationally disadvantaged individuals, weatherization of and basic repairs to low-income housing including housing occupied by older adults, energy conservation (including solar energy techniques), removal of architectural barriers to access by individuals with disabilities to public facilities, activities that focus on drug and alcohol abuse education, prevention and treatment, and conservation, maintenance, or restoration of natural resources on publicly held lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf93854b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other nonpartisan civic activities and services that the Corporation determines to be of a substantial social benefit in meeting unmet human, educational, or environmental needs (particularly needs related to poverty) or in the community where volunteer service is to be performed; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf93854c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encompass the focuses and services described in both paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf93854d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No participant shall perform any specific activity for more than a 6-month period. No participant shall remain enrolled in programs assisted under this division for more than 24 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf93854e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199D"},"text":"Pub. L. 101–610, title I, § 199D","children":[],"tail":", formerly § 124, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3143"},"text":"104 Stat. 3143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/10/s5/4"},"text":"Pub. L. 102–10, § 5(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-12"},"text":"Mar. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/30"},"text":"105 Stat. 30","children":[],"tail":"; renumbered § 199D and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (e)(1), (5), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/788"},"text":"107 Stat. 788","children":[],"tail":", 815, 816.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf93854f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf938550-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf938551-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12544"},"text":"section 12544 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/a"},"text":"Pub. L. 103–82, § 101(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf938552-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/e/1"},"text":"Pub. L. 103–82, § 101(e)(1)","children":[],"tail":", substituted “Corporation” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s101/e/5"},"text":"Pub. L. 103–82, § 101(e)(5)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to ineligible service categories."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/10/s5/4/A"},"text":"Pub. L. 102–10, § 5(4)(A)","children":[],"tail":", substituted “youth service” for “human services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/10/s5/4/B"},"text":"Pub. L. 102–10, § 5(4)(B)","children":[],"tail":", substituted “any specific activity for more than a 6-month period. No participant shall remain enrolled in programs” for “services in any project for more than a 6-month period. No participant shall remain enrolled in projects”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf938553-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf938554-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
