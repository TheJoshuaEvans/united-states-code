{"tag":"section","attrib":{"id":"idb5e15f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k"},"text":null,"children":[{"tag":"num","attrib":{"value":"294k"},"text":"§ 294k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e15f58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a training demonstration program to award grants to eligible entities to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for medical residents and fellows to practice psychiatry and addiction medicine in underserved, community-based settings that integrate primary care with mental health and substance use disorder prevention and treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training (including for individuals completing clinical training requirements for licensure) for nurse practitioners, physician assistants, health service psychologists, counselors, nurses, and social workers to provide mental health and substance use disorder services in underserved community-based settings that integrate primary care and mental health and substance use disorder services, including such settings that serve pediatric populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing, maintaining, or improving academic units or programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training for students or faculty, including through clinical experiences and research, to improve the ability to be able to recognize, diagnose, and treat mental health and substance use disorders, with a special focus on addiction or pediatric populations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop evidence-based practices or recommendations for the design of the units or programs described in subparagraph (A), including curriculum content standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for residents and fellows","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under subsection (a)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the grant funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5e15f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5e15f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan, develop, and operate a training program for medical psychiatry residents and fellows in addiction medicine practicing in eligible entities described in subsection (c)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5e15f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train new psychiatric residents and fellows in addiction medicine to provide and expand access to integrated mental health and substance use disorder services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e15f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide at least 1 training track that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5e15f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a virtual training track that includes an in-person rotation at a teaching health center or in a community-based setting, followed by a virtual rotation in which the resident or fellow continues to support the care of patients at the teaching health center or in the community-based setting through the use of health information technology and, as appropriate, telehealth services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5e15f66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an in-person training track that includes a rotation, during which the resident or fellow practices at a teaching health center or in a community-based setting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5e15f67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an in-person training track that includes a rotation during which the resident practices in a community-based setting that specializes in the treatment of infants, children, adolescents, or pregnant or postpartum women; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the grant funds to provide additional support for the administration of the program or to meet the costs of projects to establish, maintain, or improve faculty development, or departments, divisions, or other units necessary to implement such training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for other providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under subsection (a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use the grant funds to plan, develop, or operate a training program to provide mental health and substance use disorder services in underserved, community-based settings (including such settings that serve pediatric populations), as appropriate, that integrate primary care and mental health and substance use disorder prevention and treatment services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the grant funds to provide additional support for the administration of the program or to meet the costs of projects to establish, maintain, or improve faculty development, or departments, divisions, or other units necessary to implement such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic units or programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant under subsection (a)(3) shall enter into a partnership with organizations such as an education accrediting organization (such as the Liaison Committee on Medical Education, the Accreditation Council for Graduate Medical Education, the Commission on Osteopathic College Accreditation, the Accreditation Commission for Education in Nursing, the Commission on Collegiate Nursing Education, the Accreditation Council for Pharmacy Education, the Council on Social Work Education, American Psychological Association Commission on Accreditation, or the Accreditation Review Commission on Education for the Physician Assistant) to carry out activities under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for residents and fellows","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a)(1), an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be a consortium consisting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5e15f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one teaching health center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e15f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sponsoring institution (or parent institution of the sponsoring institution) of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5e15f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a psychiatry residency program that is accredited by the Accreditation Council of Graduate Medical Education (or the parent institution of such a program); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5e15f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fellowship in addiction medicine, as determined appropriate by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an entity described in subparagraph (A)(ii) that provides opportunities for residents or fellows to train in community-based settings that integrate primary care with mental health and substance use disorder prevention and treatment services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for other providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a)(2), an entity shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a teaching health center (as defined in section 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(f) of this title);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federally qualified health center (as defined in section 1396d(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of this title);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community mental health center (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/ff/3/B"},"text":"section 1395x(ff)(3)(B) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural health clinic (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health center operated by the Indian Health Service, an Indian tribe, a tribal organization, or an urban Indian organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity with a demonstrated record of success in providing training for nurse practitioners, physician assistants, health service psychologists counselors, nurses,,","children":[{"tag":"ref","attrib":{"idref":"fn002271"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002271"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and social workers, including such entities that serve pediatric populations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic units or programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a)(3), an entity shall be a school of medicine or osteopathic medicine, a nursing school, a physician assistant training program, a school of pharmacy, a school of social work, an accredited public or nonprofit private hospital, an accredited medical residency program, or a public or private nonprofit entity which the Secretary has determined is capable of carrying out such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a)(1) or (a)(2), the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate sufficient size, scope, and capacity to undertake the requisite training of an appropriate number of psychiatric residents, fellows, health service psychologists, nurses nurse ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" practitioners, physician assistants counselors,,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or social workers in addiction medicine per year to meet the needs of the area served;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate experience in training providers to practice team-based care that integrates mental health and substance use disorder prevention and treatment services with primary care in community-based settings, which may include such settings that serve pediatric populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate experience in using health information technology and, as appropriate, telehealth to support—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5e15f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery of mental health and substance use disorder services at the eligible entities described in subsections (c)(1) and (c)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5e15f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community health centers in integrating primary care and mental health and substance use disorder treatment; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capacity to expand access to mental health and substance use disorder services in areas with demonstrated need, as determined by the Secretary, such as tribal, rural, or other underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic units or programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a)(3), the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a record of training the greatest percentage of mental health and substance use disorder providers who enter and remain in these fields or who enter and remain in settings with integrated primary care and mental and substance use disorder prevention and treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a record of training individuals who are from underrepresented minority groups, including native populations, or from a rural or disadvantaged background;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training in the care (which may include trauma-informed care, as appropriate) of vulnerable populations such as infants, children, adolescents, pregnant and postpartum women, older adults, homeless individuals, victims of abuse or trauma, individuals with disabilities, and other groups as defined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" teach trainees the skills to provide interprofessional, integrated care through collaboration among health professionals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training in cultural competency and health literacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be for a minimum of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e15f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration, shall conduct a study on the results of the demonstration program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the completion of the first year of the training program and each subsequent year that the program is in effect, each recipient of a grant under subsection (a) shall submit to the Secretary such data as the Secretary may require for analysis for the report described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e15f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after receipt of the data described in paragraph (1)(B), the Secretary shall submit to Congress a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e15f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effect of the demonstration program under this section on the quality, quantity, and distribution of mental health and substance use disorder services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the effect of the demonstration program on the prevalence of untreated mental health and substance use disorders in the surrounding communities of health centers participating in the demonstration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e15f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on whether the demonstration program should be expanded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e15f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294k/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, and ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" $31,700,000 for each of fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e15f95-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 760, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9022"},"text":"Pub. L. 114–255, div. B, title IX, § 9022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1250"},"text":"130 Stat. 1250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1311/b"},"text":"Pub. L. 117–328, div. FF, title I, § 1311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5696"},"text":"136 Stat. 5696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e15f96-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e15f97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"