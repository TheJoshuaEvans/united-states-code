{"tag":"section","attrib":{"id":"idb647e973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–18a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–18a"},"text":"§ 300j–18a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual study on boil water advisories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb647e974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–18a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", and annually thereafter, the Administrator shall conduct a study on the prevalence of boil water advisories issued in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–18a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–18a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to Congress a report describing the results of the most recent study conducted under subsection (a) as part of the annual budget request transmitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–18a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the annual report required under paragraph (1), the Administrator shall include a description of the reasons for which boil water advisories were issued during the year covered by the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb647e978-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50115"},"text":"Pub. L. 117–58, div. E, title I, § 50115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1157"},"text":"135 Stat. 1157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb647e979-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb647e97a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb647e97b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section enacted as part of the Drinking Water and Wastewater Infrastructure Act of 2021 and also as part of the Infrastructure Investment and Jobs Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb647e97c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb647e97d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definition of Administrator","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/s50002"},"text":"Pub. L. 117–58, div. E, § 50002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1135"},"text":"135 Stat. 1135","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dE/s50002"},"text":"“In this division [see Short Title of 2021 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":", Navigation and Navigable Waters], the term ‘Administrator’ means the Administrator of the Environmental Protection Agency.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
