{"tag":"section","attrib":{"id":"idb590800e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"289g–3"},"text":"§ 289g–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breast implant research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb590800f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of NIH may conduct or support research to examine the long-term health implications of silicone breast implants, both gel and saline filled. Such research studies may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5908010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and examining techniques to measure concentrations of silicone in body fluids and tissues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590a621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surveillance of recipients of silicone breast implants, including long-term outcomes and local complications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb590a622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “breast implant” means a breast prosthesis that is implanted to augment or reconstruct the female breast.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb590a623-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 498C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/250/tII/s215/b"},"text":"Pub. L. 107–250, title II, § 215(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1615"},"text":"116 Stat. 1615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb590a624-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb590a625-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb590a626-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Breast Implants; Study by Comptroller General","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/250/tII/s214"},"text":"Pub. L. 107–250, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1615"},"text":"116 Stat. 1615","children":[],"tail":", which provided that the Comptroller General was to conduct a study of information typically provided by health professionals to women on breast implant surgery and to report the findings of the study to Congress, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dG/tI/s1301/g"},"text":"Pub. L. 111–8, div. G, title I, § 1301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/829"},"text":"123 Stat. 829","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
