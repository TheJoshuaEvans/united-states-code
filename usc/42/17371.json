{"tag":"section","attrib":{"id":"idc0380184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371"},"text":null,"children":[{"tag":"num","attrib":{"value":"17371"},"text":"§ 17371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy diplomacy and security within the Department of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0380185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Department Coordinator for International Energy Affairs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0380186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State should ensure that energy security is integrated into the core mission of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinator for International Energy Affairs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the Office of the Secretary of State a Coordinator for International Energy Affairs, who shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representing the Secretary of State in interagency efforts to develop the international energy policy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that analyses of the national security implications of global energy and environmental developments are reflected in the decision making process within the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038018a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating energy security priorities into the activities of the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038018b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating energy activities of the Department of State with relevant Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038018c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinating energy security and other relevant functions within the Department of State currently undertaken by offices within—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc038018d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Economic, Energy and Business Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc038018e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Oceans and International Environmental and Scientific Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc038018f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other offices within the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy experts in key embassies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary of State shall submit a report to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0380192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the Department of State personnel who are dedicated to energy matters and are stationed at embassies and consulates in countries that are major energy producers or consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the need for Federal energy specialist personnel in United States embassies and other United States diplomatic missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0380194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for increasing energy expertise within United States embassies among foreign service officers and options for assigning to such embassies energy attachés from the National Laboratories or other agencies within the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy advisors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may make appropriate arrangements with the Secretary of State to assign personnel from the Department of Energy or the National Laboratories of the Department of Energy to serve as dedicated advisors on energy matters in embassies of the United States or other United States diplomatic missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0380196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and every 2 years thereafter for the following 20 years, the Secretary of State shall submit a report to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0380197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the energy-related activities being conducted by the Department of State, including activities within—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0380198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Economic, Energy and Business Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0380199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Oceans and Environmental and Scientific Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc038019a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other offices within the Department of State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038019b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds spent on each activity within each office described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc038019c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17371/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and qualification of personnel in each embassy (or relevant foreign posting) of the United States whose work is dedicated exclusively to energy matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc038019d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s931"},"text":"Pub. L. 110–140, title IX, § 931","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1739"},"text":"121 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc038019e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc038019f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03801a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
