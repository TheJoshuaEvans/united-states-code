{"tag":"section","attrib":{"id":"idbff79e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163"},"text":null,"children":[{"tag":"num","attrib":{"value":"16163"},"text":"§ 16163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may represent the United States interests with respect to activities and programs under this subchapter, in coordination with the Department of Transportation, the National Institute of Standards and Technology, and other relevant Federal agencies, before governments and nongovernmental organizations including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, State, regional, and local governments and their representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry and its representatives, including members of the energy and transportation industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Department of State, foreign governments and their representatives including international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to alter the regulatory authority of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79e10-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s819"},"text":"Pub. L. 109–58, title VIII, § 819","children":[],"tail":", formerly § 814, "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/855"},"text":"119 Stat. 855","children":[],"tail":"; renumbered § 819, "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40314/1"},"text":"Pub. L. 117–58, div. D, title III, § 40314(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1008"},"text":"135 Stat. 1008","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
