{"tag":"section","attrib":{"id":"idb9000465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w"},"text":"§ 1395w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations to cover Government contributions and contingency reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9000466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated from time to time, out of any moneys in the Treasury not otherwise appropriated, to the Federal Supplementary Medical Insurance Trust Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9000467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9000468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a Government contribution equal to the aggregate premiums payable for a month for enrollees age 65 and over under this part and deposited in the Trust Fund, multiplied by the ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9000469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the dollar amount of the actuarially adequate rate per enrollee age 65 and over as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/1"},"text":"section 1395r(a)(1) of this title","children":[],"tail":" for such month minus the dollar amount of the premium per enrollee for such month, as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/3"},"text":"section 1395r(a)(3) of this title","children":[],"tail":", to"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb900046a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar amount of the premium per enrollee for such month, plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb900046b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a Government contribution equal to the aggregate premiums payable for a month for enrollees under age 65 under this part and deposited in the Trust Fund, multiplied by the ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb900046c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the dollar amount of the actuarially adequate rate per enrollee under age 65 as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/4"},"text":"section 1395r(a)(4) of this title","children":[],"tail":" for such month minus the dollar amount of the premium per enrollee for such month, as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/3"},"text":"section 1395r(a)(3) of this title","children":[],"tail":", to"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb900046d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar amount of the premium per enrollee for such month; minus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb900046e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of additional premium payments attributable to the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i"},"text":"section 1395r(i) of this title","children":[],"tail":"; plus"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900046f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as the Secretary deems necessary to place the Trust Fund, at the end of any fiscal year occurring after ","children":[{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", in the same position in which it would have been at the end of such fiscal year if (A) a Government contribution representing the excess of the premiums deposited in the Trust Fund during the fiscal year ending "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", over the Government contribution actually appropriated to the Trust Fund during such fiscal year had been appropriated to it on "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", and (B) the Government contribution for premiums deposited in the Trust Fund after "},{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":", had been appropriated to it when such premiums were deposited; plus"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9000470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government contribution equal to the amount of payment incentives payable under sections 1395w–4(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") and 1395w–23("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3) of this title; plus"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9000471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government contribution equal to the estimated aggregate reduction in premiums payable under part B that results from establishing the premium at 15 percent of the actuarial rate (as would be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/1"},"text":"section 1395r(a)(1) of this title","children":[],"tail":" if the reference to “one-half” in such section were a reference to “100 percent”) under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/j"},"text":"section 1395r(j) of this title","children":[],"tail":" instead of 25 percent of such rate (as so determined) for individuals enrolled only for the purpose of coverage of immunosuppressive drugs under section 1395"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In applying paragraph (1), the amounts transferred under subsection (d)(1) with respect to enrollees described in subparagraphs (A) and (B) of such subsection shall be treated as premiums payable and deposited in the Trust Fund under subparagraphs (A) and (B), respectively, of paragraph (1). In applying paragraph (1), the amounts transferred under subsection (e)(1) with respect to enrollees described in subparagraphs (A) and (B) of such subsection shall be treated as premiums payable and deposited in the Trust Fund under subparagraphs (A) and (B), respectively, of paragraph (1). The Government contribution under paragraph (4) shall be treated as premiums payable and deposited for purposes of subparagraphs (A) and (B) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9000472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingency reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assure prompt payment of benefits provided under this part and the administrative expenses thereunder during the early months of the program established by this part, and to provide a contingency reserve, there is also authorized to be appropriated, out of any moneys in the Treasury not otherwise appropriated, to remain available through the calendar year 1969 for repayable advances (without interest) to the Trust Fund, an amount equal to $18 multiplied by the number of individuals (as estimated by the Secretary) who could be covered in July 1966 by the insurance program established by this part if they had theretofore enrolled under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9000473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election under section 1395w–24","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the Government contribution under subparagraphs (A) and (B) of subsection (a)(1) without regard to any premium reduction resulting from an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–24/f/1/E"},"text":"section 1395w–24(f)(1)(E) of this title","children":[],"tail":" or any credits provided under section 1395w–24(b)(1)(C)(iv) "},{"tag":"ref","attrib":{"idref":"fn002822"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002822"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and without regard to any premium adjustment effected under sections 1395r(h) and 1395w–29(f) "},{"tag":"ref","attrib":{"idref":"fn002822"},"text":"1","children":[],"tail":" of this title and without regard to any premium adjustment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i"},"text":"section 1395r(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9000474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain General Fund amounts for 2016","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9000475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For 2016, there shall be transferred from the General Fund to the Trust Fund an amount, as estimated by the Chief Actuary of the Centers for Medicare & Medicaid Services, equal to the reduction in aggregate premiums payable under this part for a month in such year (excluding any changes in amounts collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i"},"text":"section 1395r(i) of this title","children":[],"tail":") that is attributable to the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/5/A"},"text":"section 1395r(a)(5)(A) of this title","children":[],"tail":" with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9000476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees age 65 and over; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9000477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees under age 65.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amounts shall be transferred from time to time as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9000478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium increases affected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/6"},"text":"section 1395r(a)(6) of this title","children":[],"tail":" shall not be taken into account in applying subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9000479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be transferred from the Trust Fund to the General Fund of the Treasury amounts equivalent to the additional premiums payable as a result of the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/6"},"text":"section 1395r(a)(6) of this title","children":[],"tail":", excluding the aggregate payments attributable to the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i/3/A/ii/II"},"text":"section 1395r(i)(3)(A)(ii)(II) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900047a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain General Fund amounts for 2021","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb900047b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For 2021, there shall be transferred from the General Fund to the Trust Fund an amount, as estimated by the Chief Actuary of the Centers for Medicare & Medicaid Services, equal to the reduction in aggregate premiums payable under this part for a month in such year (excluding any changes in amounts collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i"},"text":"section 1395r(i) of this title","children":[],"tail":") that are attributable to the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/7"},"text":"section 1395r(a)(7) of this title","children":[],"tail":" with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb900047c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees age 65 and over; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb900047d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees under age 65.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amounts shall be transferred from time to time as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900047e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium increases affected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/6"},"text":"section 1395r(a)(6) of this title","children":[],"tail":" shall not be taken into account in applying subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900047f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be transferred from the Trust Fund to the General Fund of the Treasury amounts equivalent to the additional premiums payable as a result of the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/a/6"},"text":"section 1395r(a)(6) of this title","children":[],"tail":", excluding the aggregate payments attributable to the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/i/3/A/ii/II"},"text":"section 1395r(i)(3)(A)(ii)(II) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9000480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain General Fund amounts for COVID–19 public health emergency period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9000481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be transferred from the General Fund of the Treasury to the Trust Fund an amount, as estimated by the Chief Actuary of the Centers for Medicare & Medicaid Services, equal to amounts paid in advance for items and services under this part during the period beginning on the first day of the emergency period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5/g/1/B"},"text":"section 1320b–5(g)(1)(B) of this title","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9000482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be transferred from the Trust Fund to the General Fund of the Treasury amounts equivalent to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9000483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts by which claims have offset (in whole or in part) the amount of such payments described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9000484-3a70-