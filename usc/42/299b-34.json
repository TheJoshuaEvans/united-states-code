{"tag":"section","attrib":{"id":"idb6051351-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34"},"text":null,"children":[{"tag":"num","attrib":{"value":"299b–34"},"text":"§ 299b–34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality improvement technical assistance and implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6051352-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, through the Center for Quality Improvement and Patient Safety of the Agency for Healthcare Research and Quality (referred to in this section as the “Center”), shall award—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6051353-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance grants or contracts to eligible entities to provide technical support to institutions that deliver health care and health care providers (including rural and urban providers of services and suppliers with limited infrastructure and financial resources to implement and support quality improvement activities, providers of services and suppliers with poor performance scores, and providers of services and suppliers for which there are disparities in care among subgroups of patients) so that such institutions and providers understand, adapt, and implement the models and practices identified in the research conducted by the Center, including the Quality Improvement Networks Research Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6051354-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation grants or contracts to eligible entities to implement the models and practices described under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051355-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6051356-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a technical assistance grant or contract under subsection (a)(1), an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6051357-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be a health care provider, health care provider association, professional society, health care worker organization, Indian health organization, quality improvement organization, patient safety organization, local quality improvement collaborative, the Joint Commission, academic health center, university, physician-based research network, primary care extension program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–12"},"text":"section 280g–12 of this title","children":[],"tail":", a Federal Indian Health Service program or a health program operated by an Indian tribe (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"), or any other entity identified by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051358-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have demonstrated expertise in providing information and technical support and assistance to health care providers regarding quality improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6051359-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive an implementation grant or contract under subsection (a)(2), an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb605135a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be a hospital or other health care provider or consortium or ","children":[{"tag":"ref","attrib":{"idref":"fn002317"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002317"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" providers, as determined by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb605135b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have demonstrated expertise in providing information and technical support and assistance to health care providers regarding quality improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb605135c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb605135d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a technical assistance grant or contract under subsection (a)(1), an eligible entity shall submit an application to the Secretary at such time, in such manner, and containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb605135e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan for a sustainable business model that may include a system of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb605135f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charging fees to institutions and providers that receive technical support from the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6051360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing or eliminating such fees for such institutions and providers that serve low-income populations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6051362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a grant or contract under subsection (a)(2), an eligible entity shall submit an application to the Secretary at such time, in such manner, and containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6051363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan for implementation of a model or practice identified in the research conducted by the Center including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6051364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial cost, staffing requirements, and timeline ","children":[{"tag":"ref","attrib":{"idref":"fn002318"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002318"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “a timeline”."}],"tail":" for implementation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6051365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre- and projected post-implementation quality measure performance data in targeted improvement areas identified by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6051366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051367-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may not award a grant or contract under this section to an entity unless the entity agrees that it will make available (directly or through contributions from other public or private entities) non-Federal contributions toward the activities to be carried out under the grant or contract in an amount equal to $1 for each $5 of Federal funds provided under the grant or contract. Such non-Federal matching funds may be provided directly or through donations from public or private entities and may be in cash or in-kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6051368-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6051369-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall evaluate the performance of each entity that receives a grant or contract under this section. The evaluation of an entity shall include a study of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb605136a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the success of such entity in achieving the implementation, by the health care institutions and providers assisted by such entity, of the models and practices identified in the research conducted by the Center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–33"},"text":"section 299b–33 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb605136b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the perception of the health care institutions and providers assisted by such entity regarding the value of the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb605136c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where practicable, better patient health outcomes and lower cost resulting from the assistance provided by such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb605136d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the outcome of the evaluation of the entity under paragraph (1), the Director shall determine whether to renew a grant or contract with such entity under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb605136e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s299b–34/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The entities that receive a grant or contract under this section shall coordinate with health information technology regional extension centers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–32/c"},"text":"section 300jj–32(c) of this title","children":[],"tail":" and the primary care extension program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–12"},"text":"section 280g–12 of this title","children":[],"tail":" regarding the dissemination of quality improvement, system delivery reform, and best practices information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb605136f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IX, § 934, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3501"},"text":"Pub. L. 111–148, title III, § 3501","children":[],"tail":", title X, § 10501(f)(3), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/511"},"text":"124 Stat. 511","children":[],"tail":", 996.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6051370-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6051371-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6051372-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 934 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 944 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–3"},"text":"section 299c–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6051373-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b)(1)(A), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10501/f/3"},"text":"Pub. L. 111–148, § 10501(f)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–12"},"text":"section 280g–12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
