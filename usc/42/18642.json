{"tag":"section","attrib":{"id":"idc05bb6fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642"},"text":null,"children":[{"tag":"num","attrib":{"value":"18642"},"text":"§ 18642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced scientific computing research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc05bb6ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7139"},"text":"section 7139 of this title","children":[],"tail":", the Director shall carry out, in coordination with academia and relevant public and private sector entities, a research, development, and demonstration program—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to steward applied mathematics, computational science, and computer science research relevant to the missions of the Department and the competitiveness of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop modeling, simulation, and other computational tools relevant to other scientific disciplines and to the development of new energy technologies and other technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance computing and networking capabilities for data-driven discovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop advanced scientific computing hardware and software tools for science and engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance computing and networking research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall support research in high-performance computing and networking relevant to energy applications, including modeling, simulation, and advanced data analytics for basic and applied energy research programs carried out by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Science shall ensure the coordination of the activities of the Department, including activities under this section, to determine and meet the computational and networking research and facility needs of the Office of Science and all other relevant energy technology and energy efficiency programs within the Department and with other Federal agencies as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied mathematics and software development for high-end computing systems and computer sciences research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall carry out activities to develop, test, and support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mathematics, statistics, and algorithms for modeling complex systems relevant to the missions of the Department, including on advanced computing architectures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools, languages, programming environments, and operations for high-end computing systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5541"},"text":"section 5541 of title 15","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio balance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb70d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall maintain a balanced portfolio within the advanced scientific computing research and development program established under section 976 of the Energy Policy Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16316"},"text":"42 U.S.C. 16316","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn004361"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004361"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" that supports robust investment in—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc05bb70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied mathematical, computational, and computer sciences research needs relevant to the mission of the Department, including foundational areas that are critical to the advancement of energy sciences and technologies and new and emerging computing technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb70f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated high-performance computing hardware and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exascale ecosystem sustainment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc05bb711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Exascale Computing Project has successfully created a broad ecosystem that provides shared software packages, novel evaluation systems, and applications relevant to the science and engineering requirements of the Department, and that such products must be maintained and improved in order that the full potential of the deployed systems can be continuously realized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to sustain and evolve the ecosystem described in clause (i) to ensure that the exascale software stack and other research software will continue to be maintained, hardened, and otherwise optimized for long-term use on exascale systems and beyond and reliable availability to the user community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced computing program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to develop and implement a strategy for achieving computing systems with capabilities beyond exascale computing systems. In establishing this program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain foundational research programs in mathematical, computational, and computer sciences focused on new and emerging computing needs within the mission of the Department, including post-Moore’s law computing architectures, novel approaches to modeling and simulation, artificial intelligence and scientific machine learning, quantum computing, edge computing, extreme heterogeneity, including potential quantum accelerators, and distributed high-performance computing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain best practices and maintain support for essential hardware, applications, and software elements of the Exascale Computing Program that are necessary for sustaining the vitality of a long-term capable software ecosystem for exascale and beyond; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a Department-wide strategy for balancing on-premises and cloud-based computing and scientific data management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report on the development and implementation of the strategy described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance on mitigation of bias in high-performance computing capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In leveraging high-performance computing systems for research purposes, including through the use of machine learning algorithms for data analysis and artificial intelligence, the Secretary shall issue, and ensure adherence to, guidance for the Department, the National Laboratories, and users as to how those capabilities should be employed in a manner that mitigates and, to the maximum extent practicable, avoids harmful algorithmic bias.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architectural research in heterogeneous computing systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program of research and development in heterogeneous and reconfigurable computing systems to expand understanding of the potential for heterogeneous and reconfigurable computing systems to deliver high performance, high efficiency computing for Department mission challenges. The program shall include research and development that explores the convergence of big data analytics, simulations, and artificial intelligence to drive the design of heterogeneous computing system architectures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb71c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program described in paragraph (1), the Secretary shall ensure coordination between research activities undertaken by the Advanced Scientific Computing Research program and materials research supported by the Basic Energy Sciences program within the Office of Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb71d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficient computing program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb71e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support a program of fundamental research, development, and demonstration of energy efficient computing and data center technologies relevant to advanced computing applications, including high-performance computing, artificial intelligence, and scientific machine learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc05bb721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a partnership for National Laboratories, industry partners, and institutions of higher education for codesign of energy efficient hardware, technology, software, and applications across all applicable program offices of the Department, and provide access to energy efficient computing resources to such partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop hardware and software technologies that decrease the energy needs of advanced computing practices, including through data center codesign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider multiple heterogeneous computing architectures in collaboration with the program established under subsection (g), including neuromorphic computing, persistent computing, and ultrafast networking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, as appropriate, on a competitive, merit-reviewed basis, access for researchers from institutions of higher education, National Laboratories, industry, and other Federal agencies to the energy efficient computing technologies developed pursuant to clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting participants for the partnership established under subparagraph (A)(i), the Secretary shall select participants through a competitive, merit review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report on—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc05bb727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities conducted under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc05bb728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/h/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination and management of the program under subparagraph (A) to ensure an integrated research program across the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy Sciences Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb72a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for upgrades to the Energy Sciences Network user facility in order to meet the research needs of the Department for highly reliable data transport capabilities optimized for the requirements of large-scale science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb72b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall ensure the following capabilities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb72c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide high bandwidth scientific networking across the continental United States and the Atlantic Ocean.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb72d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure network reliability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb72e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To protect the network infrastructure from cyberattacks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb72f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To manage transport of exponentially increasing levels of data from the Department’s National Laboratories and sites, user facilities, experiments, and sensors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To contribute to the integration of heterogeneous computing frameworks and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computational Science Graduate Fellowship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support the Computational Science Graduate Fellowship program in order to facilitate collaboration between graduate students and researchers at the National Laboratories, and contribute to the development of a diverse and inclusive computational workforce to help advance research in all areas of computational science relevant to the mission of the Department, including quantum computing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds authorized to be appropriated for the Advanced Scientific Computing Research Program, there are authorized to be appropriated to the Secretary for carrying out activities under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc05bb734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,750,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $16,537,500 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $17,364,375 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $18,232,594 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc05bb738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/j/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $19,144,223 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05bb739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds authorized to be appropriated for the Office of Science in a fiscal year, there are authorized to be appropriated to the Secretary to carry out the activities described in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc05bb73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,126,950,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,194,109,500 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb73c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,265,275,695 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb73d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,340,687,843 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc05bb73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18642/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,420,599,500 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05bb73f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s304"},"text":"Pub. L. 115–246, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3145"},"text":"132 Stat. 3145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10104/a"},"text":"Pub. L. 117–167, div. B, title I, § 10104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1433"},"text":"136 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc05bb740-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc05bb741-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc05bb742-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 976 of the Energy Policy Act of 2005, referred to in subsec. (d)(2)(A), enacted ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16316"},"text":"section 16316 of this title","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5523"},"text":"section 5523 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc05bb743-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s304"},"text":"section 304 of Pub. L. 115–246","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/s304"},"text":"section 304 of Pub. L. 115–246","children":[],"tail":" amended sections 16316 of this title, sections 5541 and 5542 of Title 15, Commerce and Trade, and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5501"},"text":"section 5501 of Title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc05bb744-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10104/a/1"},"text":"Pub. L. 117–167, § 10104(a)(1)","children":[],"tail":", (2), added subsec. (a) and redesignated former subsec. (a) as (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10104/a/1"},"text":"Pub. L. 117–167, § 10104(a)(1)","children":[],"tail":", (3), redesignated subsec. (b) as (c), designated existing provisions par. (1) and inserted heading, and added par. (2). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10104/a/1"},"text":"Pub. L. 117–167, § 10104(a)(1)","children":[],"tail":", (4), redesignated subsec. (c) as (d) and amended it generally. Prior to amendment, text read as follows: “The Director shall carry out activities to develop, test, and support—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) mathematics, models, and algorithms for complex systems and programming environments; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) tools, languages, and operating systems for high-end computing systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5541"},"text":"section 5541 of title 15","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10104/a/5"},"text":"Pub. L. 117–167, § 10104(a)(5)","children":[],"tail":", added subsecs. (e) to (k)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
