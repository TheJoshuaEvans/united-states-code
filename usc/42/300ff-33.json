{"tag":"section","attrib":{"id":"idb69b6093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–33"},"text":"§ 300ff–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early diagnosis grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69b6094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of States whose laws or regulations are in accordance with subsection (b), the Secretary, acting through the Centers for Disease Control and Prevention, shall make grants to such States for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b6095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of compliant States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the laws or regulations of a State are in accordance with this subsection if, under such laws or regulations (including programs carried out pursuant to the discretion of State officials), both of the policies described in paragraph (1) are in effect, or both of the policies described in paragraph (2) are in effect, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b6096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69b6097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary opt-out testing of pregnant women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69b6098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Universal testing of newborns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b6099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69b609a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary opt-out testing of clients at sexually transmitted disease clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69b609b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary opt-out testing of clients at substance abuse treatment centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall periodically ensure that the applicable policies are being carried out and recertify compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b609c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use funds provided under subsection (a) for HIV/AIDS testing (including rapid testing), prevention counseling, treatment of newborns exposed to HIV/AIDS, treatment of mothers infected with HIV/AIDS, and costs associated with linking those diagnosed with HIV/AIDS to care and treatment for HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b609d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that is eligible for the grant under subsection (a) shall submit an application to the Secretary, in such form, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b609e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under subsection (a) to a State for a fiscal year may not be made in an amount exceeding $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b609f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to pre-empt State laws regarding HIV/AIDS counseling and testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b60a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69b60a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “voluntary opt-out testing” means HIV/AIDS testing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69b60a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is administered to an individual seeking other health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69b60a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb69b60a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-test counseling is not required but the individual is informed that the individual will receive an HIV/AIDS test and the individual may opt out of such testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb69b60a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for those individuals with a positive test result, post-test counseling (including referrals for care) is provided and confidentiality is protected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69b60a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “universal testing of newborns” means HIV/AIDS testing that is administered within 48 hours of delivery to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69b60a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all infants born in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69b60a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all infants born in the State whose mother’s HIV/AIDS status is unknown at the time of delivery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69b60a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–33/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated annually to the Centers for Disease Control and Prevention for HIV/AIDS prevention activities, $30,000,000 shall be made available for each of the fiscal years 2007 through 2009 for grants under subsection (a), of which $20,000,000 shall be made available for grants to States with the policies described in subsection (b)(1), and $10,000,000 shall be made available for grants to States with the policies described in subsection (b)(2). Funds provided under this section are available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69b60aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2625, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s7/b/3"},"text":"Pub. L. 104–146, § 7(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1369"},"text":"110 Stat. 1369","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tII/s212/a"},"text":"Pub. L. 106–345, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1339"},"text":"114 Stat. 1339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tII/s209"},"text":"Pub. L. 109–415, title II, § 209","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2802"},"text":"120 Stat. 2802","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69b60ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69b60ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69b60ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s209"},"text":"Pub. L. 109–415, § 209","children":[],"tail":", amended section catchline and text generally, substituting provisions relating to early diagnosis grant program for provisions requiring State certification of measures to adopt CDC guidelines for pregnant women not later than 120 days after "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", and authorizing additional funds if such certification was provided."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s212/a/1"},"text":"Pub. L. 106–345, § 212(a)(1)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s212/a/2"},"text":"Pub. L. 106–345, § 212(a)(2)","children":[],"tail":", amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “For purposes of carrying out this subsection, there are authorized to be appropriated $10,000,000 for each of the fiscal years 1996 through 2000. Amounts made available under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–77"},"text":"section 300ff–77 of this title","children":[],"tail":" for carrying out this part are not available for carrying out this section unless otherwise authorized.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s212/a/3"},"text":"Pub. L. 106–345, § 212(a)(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69b60ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69b60af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb69b60b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s13"},"text":"section 13 of Pub. L. 104–146","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb69b60b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Perinatal Transmission of HIV Disease; Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146/s7/a"},"text":"Pub. L. 104–146, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1368"},"text":"110 Stat. 1368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/146/s7/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds as follows:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research studies and statewide clinical experiences have demonstrated that administration of anti-retroviral medication during pregnancy can significantly reduce the transmission of the human immunodeficiency virus (commonly known as HIV) from an infected mother to her baby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Disease Control and Prevention have recommended that all pregnant women receive HIV counseling; voluntary, confidential HIV testing; and appropriate medical treatment (including anti-retroviral therapy) and support services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of such testing without access to such counseling, treatment, and services will not improve the health of the woman or the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of such counseling, testing, treatment, and services can reduce the number of pediatric cases of acquired immune deficiency syndrome, can improve access to and provision of medical care for the woman, and can provide opportunities for counseling to reduce transmission among adults, and from mother to child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of such counseling, testing, treatment, and services can reduce the overall cost of pediatric cases of acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cancellation or limitation of health insurance or other health coverage on the basis of HIV status should be impermissible under applicable law. Such cancellation or limitation could result in disincentives for appropriate counseling, testing, treatment, and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the reasons specified in paragraphs (1) through (6)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routine HIV counseling and voluntary testing of pregnant women should become the standard of care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant medical organizations as well as public health officials should issue guidelines making such counseling and testing the standard of care.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
