{"tag":"section","attrib":{"id":"idbd67f2c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5913"},"text":null,"children":[{"tag":"num","attrib":{"value":"5913"},"text":"§ 5913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by National Institute of Standards and Technology of energy-related inventions prior to awarding of grants by Secretary; promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Institute of Standards and Technology shall give particular attention to the evaluation of all promising energy-related inventions, particularly those submitted by individual inventors and small companies for the purpose of obtaining direct grants from the Secretary. The National Institute of Standards and Technology is authorized to promulgate regulations in the furtherance of this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd67f2c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/577/s14"},"text":"Pub. L. 93–577, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1894"},"text":"88 Stat. 1894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s301/a"},"text":"Pub. L. 95–91, title III, § 301(a)","children":[],"tail":", title VII, §§ 703, 707, "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":", 606, 607; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd67f2c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd67f2c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd67f2ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “National Bureau of Standards” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd67f2cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd67f2cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary”, meaning Secretary of Energy, substituted in text for “Administrator”, meaning Administrator of Energy Research and Development Administration, pursuant to sections 301(a), 703, and 707 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91"},"text":"Pub. L. 95–91","children":[],"tail":", which are classified to sections 7151(a), 7293, and 7297 of this title and which terminated Energy Research and Development Administration and transferred its functions and functions of Administrator thereof (with certain exceptions) to Secretary of Energy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
