{"tag":"section","attrib":{"id":"idb5b8c834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28"},"text":null,"children":[{"tag":"num","attrib":{"value":"290cc–28"},"text":"§ 290cc–28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reports by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b8c835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees that, by not later than January 31 of each fiscal year, the State will prepare and submit to the Secretary a report in such form and containing such information as the Secretary determines (after consultation with the Assistant Secretary for Mental Health and Substance Use) to be necessary for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b8c836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing a record and a description of the purposes for which amounts received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" were expended during the preceding fiscal year and of the recipients of such amounts; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b8c837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether such amounts were expended in accordance with the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–21"},"text":"section 290cc–21 of this title","children":[],"tail":" unless the State involved agrees to make copies of the reports described in subsection (a) available for public inspection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b8c839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290cc–28/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Mental Health and Substance Use shall evaluate at least once every 3 years the expenditures of grants under this part by eligible entities in order to ensure that expenditures are consistent with the provisions of this part, and shall include in such evaluation recommendations regarding changes needed in program design or operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b8c83a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 528, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/