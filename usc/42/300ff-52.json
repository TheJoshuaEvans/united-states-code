{"tag":"section","attrib":{"id":"idb69daa36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–52"},"text":"§ 300ff–52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum qualifications of grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb69daa37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entities referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51/a"},"text":"section 300ff–51(a) of this title","children":[],"tail":" are public entities and nonprofit private entities that are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally-qualified health centers under section 1905(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"42 U.S.C. 1396d","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B)];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300"},"text":"section 300 of this title","children":[],"tail":" (regarding family planning) other than States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive hemophilia diagnostic and treatment centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural health clinics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health facilities operated by or pursuant to a contract with the Indian Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations, clinics, hospitals and other health facilities that provide early intervention services to those persons infected with HIV/AIDS through intravenous drug use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit private entities that provide comprehensive primary care services to populations at risk of HIV/AIDS, including faith-based and community-based organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities described in paragraph (1) shall serve underserved populations which may include minority populations and Native American populations, ex-offenders, individuals with comorbidities including hepatitis B or C, mental illness, or substance abuse, low-income populations, inner city populations, and rural populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb69daa41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as medicaid provider","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb69daa42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51"},"text":"section 300ff–51 of this title","children":[],"tail":" for the provision of services described in subsection (b) of such section in a State unless, in the case of any such service that is available pursuant to the State plan approved under title XIX of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] for the State—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant for the grant will provide the service directly, and the applicant has entered into a participation agreement under the State plan and is qualified to receive payments under such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant for the grant will enter into an agreement with a public or nonprofit private entity, or a private for-profit entity if such entity is the only available provider of quality HIV care in the area, under which the entity will provide the service, and the entity has entered into such a participation agreement and is qualified to receive such payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb69daa45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver regarding certain secondary agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb69daa46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an entity making an agreement pursuant to paragraph (1)(B) regarding the provision of services, the requirement established in such paragraph regarding a participation agreement shall be waived by the Secretary if the entity does not, in providing health care services, impose a charge or accept reimbursement available from any third-party payor, including reimbursement under any insurance policy or under any Federal or State health benefits program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb69daa47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–52/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the Secretary of whether an entity referred to in subparagraph (A) meets the criteria for a waiver under such subparagraph shall be made without regard to whether the entity accepts voluntary donations regarding the provision of services to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb69daa48-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2652, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/607"},"text":"104 Stat. 607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIV/s401/b/3"},"text":"Pub. L. 101–557, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2771"},"text":"104 Stat. 2771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/146/s3/d/2"},"text":"Pub. L. 104–146, § 3(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-20"},"text":"May 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1357"},"text":"110 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tVI/s601/a"},"text":"Pub. L. 107–251, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1664"},"text":"116 Stat. 1664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/m/3"},"text":"Pub. L. 108–163, § 2(m)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2023"},"text":"117 Stat. 2023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII/s302/a"},"text":"Pub. L. 109–415, title III, § 302(a)","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2806"},"text":"120 Stat. 2806","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb69daa49-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb69daa4a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb69daa4b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Social Security Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb69daa4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s302/a"},"text":"Pub. L. 109–415, § 302(a)","children":[],"tail":", amended heading and text of subsec. (a) generally, substituting provisions listing eligible entities and directing that such entities serve underserved populations for provisions listing eligible entities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163"},"text":"Pub. L. 108–163","children":[],"tail":" substituted “254b(h)” for “256”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":", which directed the substitution of “254b(h)” for “256” in subsec. (2), could not be executed because section does not contain a subsec. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/146"},"text":"Pub. L. 104–146","children":[],"tail":" inserted “, or a private for-profit entity if such entity is the only available provider of quality HIV care in the area,” after “nonprofit private entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557"},"text":"Pub. L. 101–557","children":[],"tail":" substituted “referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–51/a"},"text":"section 300ff–51(a) of this title","children":[],"tail":"” for “referred to in subsection (b) of this section”, redesignated pars. (A) to (F) as (1) to (6), respectively, and substituted “nonprofit private entities that provide” for “a nonprofit private entity that provides” in par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb69daa4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69daa4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69daa4f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/163"},"text":"Pub. L. 108–163","children":