{"tag":"section","attrib":{"id":"idbf2f44e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804"},"text":null,"children":[{"tag":"num","attrib":{"value":"10804"},"text":"§ 10804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2f44e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f44e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An eligible system may use its allotment under this subchapter to enter into contracts with State agencies and nonprofit organizations which operate throughout the State. In order to be eligible for a contract under this paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2f44e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such an agency shall be independent of any agency which provides treatment or services (other than advocacy services) to individuals with mental illness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2f44e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such an agency or organization shall have the capacity to protect and advocate the rights of individuals with mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out paragraph (1), an eligible system should consider entering into contracts with organizations including, in particular, groups run by individuals who have received or are receiving mental health services, or the family members of such individuals, which,","children":[{"tag":"ref","attrib":{"idref":"fn003974"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003974"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" provide protection or advocacy services to individuals with mental illness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f44e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation of allotments; technical assistance and training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2f44ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an eligible system is a public entity, the government of the State in which the system is located may not require the system to obligate more than 5 percent of its allotment under this subchapter in any fiscal year for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2f44eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible system may not use more than 10 percent of any allotment under this subchapter for any fiscal year for the costs of providing technical assistance and training to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f44ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of individuals with mental illness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible system may use its allotment under this subchapter to provide representation to individuals with mental illness in Federal facilities who request representation by the eligible system. Representatives of such individuals from such system shall be accorded all the rights and authority accorded to other representatives of residents of such facilities pursuant to State law and other Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2f44ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition for purposes of representation of individuals with mental illness; priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The definition of “individual with a mental illness” contained in section 10802(4)(B)(iii) ","children":[{"tag":"ref","attrib":{"idref":"fn003975"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003975"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall apply, and thus an eligible system may use its allotment under this subchapter to provide representation to such individuals, only if the total allotment under this subchapter for any fiscal year is $30,000,000 or more, and in such case, an eligible system must give priority to representing persons with mental illness as defined in subparagraphs (A) and (B)(i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10802/4"},"text":"section 10802(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2f44ee-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s104"},"text":"Pub. L. 99–319, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/479"},"text":"100 Stat. 479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/509/s7/a"},"text":"Pub. L. 100–509, § 7(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1988-10-20"},"text":"Oct. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2544"},"text":"102 Stat. 2544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", §§ 5, 10(2), "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1217"},"text":"105 Stat. 1217","children":[],"tail":", 1219; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/c"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1194"},"text":"114 Stat. 1194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2f44ef-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2f44f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2f44f1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10802/4/B/iii"},"text":"Section 10802(4)(B)(iii) of this title","children":[],"tail":", referred to in subsec. (d), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10802/4/B/i/III"},"text":"section 10802(4)(B)(i)(III) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3206/b/1/B/i"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3206(b)(1)(B)(i)","children":[],"tail":", (ii), "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1194"},"text":"114 Stat. 1194","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf2f44f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/2"},"text":"Pub. L. 102–173, § 10(2)","children":[],"tail":", substituted “individuals with mental illness” for “mentally ill individuals” in three places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s5"},"text":"Pub. L. 102–173, § 5","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s7/a"},"text":"Pub. L. 100–509, § 7(a)","children":[],"tail":", substituted “including, in particular, groups run by individuals who have received or are receiving mental health services, or the family members of such individuals, which” for “which, on "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509/s7/b/1"},"text":"Pub. L. 100–509, § 7(b)(1)","children":[],"tail":", substituted “10” for “5”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
