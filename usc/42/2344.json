{"tag":"section","attrib":{"id":"idbc21410e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2344"},"text":null,"children":[{"tag":"num","attrib":{"value":"2344"},"text":"§ 2344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All sales shall be for cash, and the buyer shall arrange for the necessary financing, except as provided in subchapter V of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc21410f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 5, § 54, "},{"tag":"ref","attrib":{"href":"/us/stat/69/477"},"text":"69 Stat. 477","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
