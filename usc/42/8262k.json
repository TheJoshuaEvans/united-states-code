{"tag":"section","attrib":{"id":"idbe8d3825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262k"},"text":null,"children":[{"tag":"num","attrib":{"value":"8262k"},"text":"§ 8262k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contract incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8d3826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency, in consultation with the Federal Acquisition Regulatory Council, shall establish criteria for the improvement of energy efficiency in Federal facilities operated by Federal Government contractors or subcontractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d3827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria established under subsection (a) shall be used to encourage Federal contractors, and their subcontractors, which manage and operate federally-owned facilities, to adopt and utilize energy conservation measures designed to reduce energy costs in Government-owned and contractor-operated facilities and which are ultimately borne by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d3828-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s167"},"text":"Pub. L. 102–486, title I, § 167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2862"},"text":"106 Stat. 2862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d3829-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d382a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d382b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
