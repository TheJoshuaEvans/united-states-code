{"tag":"section","attrib":{"id":"idbb51bc18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1758b"},"text":"§ 1758b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local school wellness policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb51bc19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local educational agency participating in a program authorized by this chapter or the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.) shall establish a local school wellness policy for all schools under the jurisdiction of the local educational agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb51bc1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations that provide the framework and guidelines for local educational agencies to establish local school wellness policies, including, at a minimum,—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb51bc1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goals for nutrition promotion and education, physical activity, and other school-based activities that promote student wellness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for all foods available on each school campus under the jurisdiction of the local educational agency during the school day, nutrition guidelines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb51bc1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with sections 1758 and 1766 of this title, and sections 4 and 10 of the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1773"},"text":"42 U.S.C. 1773","children":[],"tail":", 1779); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote student health and reduce childhood obesity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the local educational agency permit parents, students, representatives of the school food authority, teachers of physical education, school health professionals, the school board, school administrators, and the general public to participate in the development, implementation, and periodic review and update of the local school wellness policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the local educational agency inform and update the public (including parents, students, and others in the community) about the content and implementation of the local school wellness policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a requirement that the local educational agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb51bc22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically measure and make available to the public an assessment on the implementation of the local school wellness policy, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb51bc23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which schools under the jurisdiction of the local educational agency are in compliance with the local school wellness policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb51bc24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the local school wellness policy of the local educational agency compares to model local school wellness policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb51bc25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress made in attaining the goals of the local school wellness policy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate 1 or more local educational agency officials or school officials, as appropriate, to ensure that each school complies with the local school wellness policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb51bc27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local discretion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency shall use the guidelines promulgated by the Secretary under subsection (b) to determine specific policies appropriate for the schools under the jurisdiction of the local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb51bc28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb51bc29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education and the Secretary of Health and Human Services, acting through the Centers for Disease Control and Prevention, shall provide information and technical assistance to local educational agencies, school food authorities, and State educational agencies for use in establishing healthy school environments that are intended to promote student health and wellness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide technical assistance that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb51bc2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes resources and training on designing, implementing, promoting, disseminating, and evaluating local school wellness policies and overcoming barriers to the adoption of local school wellness policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes model local school wellness policies and best practices recommended by Federal agencies, State agencies, and nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes such other technical assistance as is required to promote sound nutrition and establish healthy school nutrition environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the specific needs and requirements of local educational agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb51bc2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb51bc30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary, in conjunction with the Director of the Centers for Disease Control and Prevention, shall prepare a report on the implementation, strength, and effectiveness of the local school wellness policies carried out in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of local school wellness policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study described in subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb51bc32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the strength and weaknesses of local school wellness policies and how the policies compare with model local wellness policies recommended under paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb51bc33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of the local school wellness policies in addressing the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", the Secretary shall submit to the Committee on Education and Labor of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the findings of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb51bc35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1758b/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this paragraph $3,000,000 for fiscal year 2011, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb51bc36-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s9A"},"text":"June 4, 1946, ch. 281, § 9A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tII/s204/a"},"text":"Pub. L. 111–296, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3216"},"text":"124 Stat. 3216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb51bc37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb51bc38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb51bc39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb51bc3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb51bc3b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbb51bc3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
