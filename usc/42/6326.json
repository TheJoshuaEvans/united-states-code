{"tag":"section","attrib":{"id":"idbd99fded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326"},"text":null,"children":[{"tag":"num","attrib":{"value":"6326"},"text":"§ 6326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State energy security plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd99fdee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fdef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bulk-power system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bulk-power system” has the meaning given the term in section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of title 16."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fdf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State energy security plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State energy security plan” means a State energy security plan described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fdf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance for State energy security plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal financial assistance made available to a State under this part may be used for the development, implementation, review, and revision of a State energy security plan that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fdf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the existing circumstances in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fdf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" proposes methods to strengthen the ability of the State, in consultation with owners and operators of energy infrastructure in the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fdf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure the energy infrastructure of the State against all physical and cybersecurity threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fdf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fdf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate the risk of energy supply disruptions to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fdf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the response to, and recovery from, energy disruptions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fdf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the State has reliable, secure, and resilient energy infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fdf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State energy security plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fdfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address all energy sources and regulated and unregulated energy providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fdfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a State energy profile, including an assessment of energy production, transmission, distribution, and end-use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fdfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address potential hazards to each energy sector or system, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fdfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical threats and vulnerabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fdfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cybersecurity threats and vulnerabilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fdff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a risk assessment of energy infrastructure and cross-sector interdependencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a risk mitigation approach to enhance reliability and end-use resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd99fe03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-State and regional coordination, planning, and response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd99fe04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with Indian Tribes with respect to planning and response; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, encourage mutual assistance in cyber and physical response plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing or revising a State energy security plan, the State energy office of the State shall coordinate, to the extent practicable, with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public utility or service commission of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy providers from the private and public sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other entities responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining fuel or electric reliability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing energy infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State is not eligible to receive Federal financial assistance under this part for any purpose for a fiscal year unless the Governor of the State submits to the Secretary, with respect to that fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State energy security plan that meets the requirements of subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after an annual review, carried out by the Governor, of a State energy security plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any necessary revisions to the State energy security plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that no revisions to the State energy security plan are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Governor of a State, the Secretary, in consultation with the Secretary of Homeland Security, may provide information, technical assistance, and other assistance in the development, implementation, or revision of a State energy security plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State receiving Federal financial assistance under this part shall provide reasonable assurance to the Secretary that the State has established policies and procedures designed to assure that the financial assistance will be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplement, and not to supplant, State and local funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, to increase the amount of State and local funds that otherwise would be available, in the absence of the Federal financial assistance, for the implementation of a State energy security plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information provided to, or collected by, the Federal Government pursuant to this section the disclosure of which the Secretary reasonably foresees could be detrimental to the physical security or cybersecurity of any electric utility or the bulk-power system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made available by any Federal agency, State, political subdivision of a State, or Tribal authority pursuant to any Federal, State, political subdivision of a State, or Tribal law, respectively, requiring public disclosure of information or records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6326/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall expire on ","children":[{"tag":"date","attrib":{"date":"2025-10-31"},"text":"October 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd99fe19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s366"},"text":"Pub. L. 94–163, title III, § 366","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/935"},"text":"89 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s431"},"text":"Pub. L. 94–385, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1158"},"text":"90 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/440/s2/b"},"text":"Pub. L. 101–440, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-18"},"text":"Oct. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1006"},"text":"104 Stat. 1006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40108/a/2"},"text":"Pub. L. 117–58, div. D, title I, § 40108(a)(2)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/941"},"text":"135 Stat. 941","children":[],"tail":", 942.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd99fe1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd99fe1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd99fe1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40108/a/4"},"text":"Pub. L. 117–58, § 40108(a)(4)","children":[],"tail":", amended section generally. Prior to amendment, section defined terms used in this part."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40108/a/3"},"text":"Pub. L. 117–58, § 40108(a)(3)","children":[],"tail":", redesignated pars. (1) to (8) as pars. (1) to (8) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6321/c"},"text":"section 6321(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40108/a/2/B"},"text":"Pub. L. 117–58, § 40108(a)(2)(B)","children":[],"tail":", inserted headings in pars. (1) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40108/a/2/A"},"text":"Pub. L. 117–58, § 40108(a)(2)(A)","children":[],"tail":", substituted “; and” for “approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6327"},"text":"section 6327 of this title","children":[],"tail":", and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40108/a/2/C"},"text":"Pub. L. 117–58, § 40108(a)(2