{"tag":"section","attrib":{"id":"idbe0c7006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385c"},"text":"§ 7385c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity of remedy against the United States and against contractors and subcontractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c7007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The liability of the United States or an instrumentality of the United States under this subchapter with respect to a cancer (including a specified cancer), chronic silicosis, covered beryllium illness, or death related thereto of a covered employee is exclusive and instead of all other liability—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c7009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c700a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any instrumentality of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c700b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor that contracted with the Department of Energy to provide management and operation, management and integration, or environmental remediation of a Department of Energy facility (in its capacity as a contractor);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c700c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subcontractor that provided services, including construction, at a Department of Energy facility (in its capacity as a subcontractor); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c700d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee, agent, or assign of an entity specified in subparagraphs (A) through (D);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c700e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c700f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c7010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered employee’s legal representative, spouse, dependents, survivors, and next of kin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c7011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person, including any third party as to whom the covered employee, or the covered employee’s legal representative, spouse, dependents, survivors, or next of kin, has a cause of action relating to the cancer (including a specified cancer), chronic silicosis, covered beryllium illness, or death, otherwise entitled to recover damages from the United States, the instrumentality, the contractor, the subcontractor, or the employee, agent, or assign of one of them,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"because of the cancer (including a specified cancer), chronic silicosis, covered beryllium illness, or death in any proceeding or action including a direct judicial proceeding, a civil action, a proceeding in admiralty, or a proceeding under a tort liability statute or the common law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to all cases filed on or after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers’ compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to an administrative or judicial proceeding under a Federal or State workers’ compensation law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c7014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to part E","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies with respect to part E to the covered medical condition or covered illness or death of a covered DOE contractor employee on the same basis as it applies with respect to part B to the cancer (including a specified cancer), chronic silicosis, covered beryllium illness, or death of a covered employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c7015-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3644"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3644]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–509; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3162/d"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3162(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2186"},"text":"118 Stat. 2186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c7016-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0c7017-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0c7018-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
