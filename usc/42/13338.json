{"tag":"section","attrib":{"id":"idbfbbf491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13338"},"text":null,"children":[{"tag":"num","attrib":{"value":"13338"},"text":"§ 13338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of coal wastes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal waste utilization program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall establish a research, development, demonstration, and commercial application program on coal waste utilization for the purpose of developing techniques that will lead to the greater and more efficient utilization of coal wastes from mining and processing, other than coal ash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use as boiler fuel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program referred to in subsection (a) shall include projects to facilitate the use of coal wastes from mining and processing as a boiler fuel for the purpose of generating steam to produce electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf494-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1308"},"text":"Pub. L. 102–486, title XIII, § 1308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2975"},"text":"106 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
