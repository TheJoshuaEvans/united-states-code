/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6205, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1971; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dA/tIII"},"text":"Pub. L. 115–141, div. A, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/365"},"text":"132 Stat. 365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tI/s101/f/1"},"text":"Pub. L. 116–260, div. Q, title I, § 101(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2164"},"text":"134 Stat. 2164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/tVI/s601/e/1"},"text":"Pub. L. 117–328, div. AA, title VI, § 601(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5546"},"text":"136 Stat. 5546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb1fb04e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb1fb04f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb1fb050-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1005a and 1005c(a), (b), and (c) of title 7, referred to in subsec. (b), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/s341/a"},"text":"section 341(a) of Pub. L. 87–128","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/318"},"text":"75 Stat. 318","children":[],"tail":" (set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of Title 7","children":[],"tail":", Agriculture), which also provided that references in other laws to the Bankhead-Jones Farm Tenant Act shall be construed as referring to appropriate provisions of section 1921 et seq. of Title 7. The fund established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1005a"},"text":"section 1005a of Title 7","children":[],"tail":" was renamed the Agricultural Credit Insurance Fund. See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1929"},"text":"section 1929 of Title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb1fb051-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/s801/b"},"text":"section 801(b) of Pub. L. 91–609","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1460/c/1"},"text":"section 1460(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb1fb052-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":" substituted “United States,” for “United States” and inserted “, or a person legally admitted to the United States and authorized to work in agriculture” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6205"},"text":"Pub. L. 110–246, § 6205","children":[],"tail":", substituted “, the handling of agricultural or aquacultural commodities in the unprocessed stage, or the processing of agricultural or aquacultural commodities” for “or the handling of such commodities in the unprocessed stage” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s703"},"text":"Pub. L. 106–569, § 703","children":[],"tail":", substituted “limited partnership” for “nonprofit limited partnership” in first sentence of introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s708/b"},"text":"Pub. L. 106–569, § 708(b)","children":[],"tail":", struck out heading and text of subsec. (j). Text read as follows: “Whoever, as an owner, agent, or manger, or who is otherwise in custody, control, or possession of property that is security for a loan made or insured under this section willfully uses, or authorizes the use, of any part of the rents, assets, proceeds, income, or other funds derived from such property, for any purpose other than to meet actual or necessary expenses of the property, or for any other purpose not authorized by this subchapter or the regulations adopted pursuant to this subchapter, shall be fined not more than $250,000 or imprisoned not more than 5 years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" inserted “, or any nonprofit limited partnership in which the general partner is a nonprofit entity,” after “private nonprofit organization” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/180"},"text":"Pub. L. 104–180","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s316/b"},"text":"Pub. L. 100–242, § 316(b)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/s305/a"},"text":"Pub. L. 100–242, § 305(a)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “the term ‘domestic farm labor’ means persons who receive a substantial portion (as determined by the Secretary) of their income as laborers on farms situated in the United States, Puerto Rico, or the Virgin Islands and either (A) are citizens of the United States, or (B) reside in the United States, Puerto Rico, or the Virgin Islands after being legally admitted for permanent residence therein.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/181"},"text":"Pub. L. 98–181","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" inserted reference to Indian tribe."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" repealed subsec. (d) which provided for a maximum of $38,000,000 for the aggregate amount of principal obligations of loans insured under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/s501/d"},"text":"Pub. L. 95–557, § 501(d)","children":[],"tail":", substituted “$38,000,000 (subject to approval in an appropriation Act)” for “$25,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/s504"},"text":"Pub. L. 95–557, § 504","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/128"},"text":"Pub. L. 95–128","children":[],"tail":" extended definition of “domestic farm labor” to include laborers on farms situated in Puerto Rico and the Virgin Islands and the residents of the islands after being legally admitted for permanent residence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/s801/a"},"text":"Pub. L. 91–609, § 801(a)","children":[],"tail":", authorized insurance of loans to broad-based nonprofit organizations and nonprofit organizations of farmworkers incorporated within the State and provided for housing and related facilities for domestic farm labor any place within the State where need exists."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/s801/b"},"text":"Pub. L. 91–609, § 801(b)","children":[],"tail":", substituted “1” for “5” per centum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609/s801/c"},"text":"Pub. L. 91–609, § 801(c)","children":[],"tail":", substituted “structures (including household furnishings)” for “structures” in cls. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" included land necessary for an adequate site within the definition of “related facilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/560"},"text":"Pub. L. 88–560","children":[],"tail":" included residents of the United States after being legally admitted for permanent residence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb1fb053-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb1fb054-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment