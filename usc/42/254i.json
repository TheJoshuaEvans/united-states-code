{"tag":"section","attrib":{"id":"idb4f52a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i"},"text":null,"children":[{"tag":"num","attrib":{"value":"254i"},"text":"§ 254i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress; contents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit an annual report to Congress, and shall include in such report with respect to the previous calendar year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f52a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, identity, and priority of all health professional shortage areas designated in such year and the number of health professional shortage areas which the Secretary estimates will be designated in the subsequent year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254f"},"text":"section 254f of this title","children":[],"tail":" in such year for assignment of Corps members and the action taken on each such application;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of Corps members assigned in such year to health professional shortage areas, the number and types of additional Corps members which the Secretary estimates will be assigned to such areas in the subsequent year, and the need for additional members for the Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment efforts engaged in for the Corps in such year and the number of qualified individuals who applied for service in the Corps in such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of patients seen and the number of patient visits recorded during such year with respect to each health professional shortage area to which a Corps member was assigned during such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Corps members who elected, and the number of Corps members who did not elect, to continue to provide health services in health professional shortage areas after termination of their service in the Corps and the reasons (as reported to the Secretary) of members who did not elect for not making such election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of evaluations and determinations made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254f/a/1/D"},"text":"section 254f(a)(1)(D) of this title","children":[],"tail":" during such year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f52a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254i/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount charged during such year for health services provided by Corps members, the amount which was collected in such year by entities in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254g"},"text":"section 254g of this title","children":[],"tail":", and the amount which was paid to the Secretary in such year under such agreements."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f52a97-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 336A, formerly § 336, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s407/b/3"},"text":"Pub. L. 94–484, title IV, § 407(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2277"},"text":"90 Stat. 2277","children":[],"tail":", renumbered § 336A, "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2706/a"},"text":"Pub. L. 97–35, title XXVII, § 2706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/907"},"text":"95 Stat. 907","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s206/a"},"text":"Pub. L. 97–375, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1823"},"text":"96 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tIV/s401/b"},"text":"Pub. L. 101–597, title IV, § 401(b)[(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3035"},"text":"104 Stat. 3035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIII/s307/b"},"text":"Pub. L. 107–251, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1649"},"text":"116 Stat. 1649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f52a98-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f52a99-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f52a9a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":" struck out “agreements under” after “in accordance with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (1), (3), (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/597"},"text":"Pub. L. 101–597","children":[],"tail":" substituted reference to health professional shortage area for reference to health manpower shortage area wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out “on May 1 of each year” after “report to Congress”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
