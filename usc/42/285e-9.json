{"tag":"section","attrib":{"id":"idb573a879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–9"},"text":"§ 285e–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alzheimer’s disease registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573a87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute may make a grant to develop a registry for the collection of epidemiological data about Alzheimer’s disease and its incidence in the United States, to train personnel in the collection of such data, and for other matters respecting such disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify for a grant under subsection (a) an applicant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573a87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an accredited school of medicine or public health which has expertise in the collection of epidemiological data about individuals with Alzheimer’s disease and in the development of disease registries, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573a87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to a large patient population, including a patient population representative of diverse ethnic backgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb573a87e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445G, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s12"},"text":"Pub. L. 99–158, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/885"},"text":"99 Stat. 885","children":[],"tail":"; renumbered § 445G of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVIII/s801"},"text":"Pub. L. 103–43, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/163"},"text":"107 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a87f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a880-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb573a881-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a882-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s801/b/1"},"text":"Pub. L. 103–43, § 801(b)(1)","children":[],"tail":", reenacted section catchline without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s801/b/1"},"text":"Pub. L. 103–43, § 801(b)(1)","children":[],"tail":", substituted in heading “In general” for “Grant authority” and in text substituted “Director of the Institute” for “Director of the National Institute on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s801/b/2"},"text":"Pub. L. 103–43, § 801(b)(2)","children":[],"tail":", struck out subsec. (c) which authorized appropriations of $2,500,000 for grants to remain available until expended or through fiscal year 1989, whichever occurred first."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
