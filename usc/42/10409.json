{"tag":"section","attrib":{"id":"idbf2a894c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409"},"text":null,"children":[{"tag":"num","attrib":{"value":"10409"},"text":"§ 10409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2a894d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with tribal governments pursuant to Executive Order No. 13175 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn003966"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003966"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20126"},"text":"section 20126 of title 34","children":[],"tail":", shall continue to award grants for Indian tribes from amounts appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10403/a/2/B"},"text":"section 10403(a)(2)(B) of this title","children":[],"tail":" to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a894e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be an Indian tribe, or a tribal organization or nonprofit private organization authorized by an Indian tribe. An Indian tribe shall have the option to authorize a tribal organization or a nonprofit private organization to submit an application and administer the grant funds awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a894f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of such a grant shall comply with requirements that are consistent with the requirements applicable to grantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406"},"text":"section 10406 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a8950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall submit an application to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10407"},"text":"section 10407 of this title","children":[],"tail":" at such time, in such manner, and containing such information as the Secretary determines to be essential to carry out the objectives and provisions of this chapter. The Secretary shall approve any application that meets requirements consistent with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/c"},"text":"section 10406(c) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10407/a"},"text":"section 10407(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a8951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10409/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount provided under a grant to an eligible entity shall be used for the services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10408/b"},"text":"section 10408(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2a8952-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s309"},"text":"Pub. L. 98–457, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3496"},"text":"124 Stat. 3496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2a8953-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2a8954-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf2a8955-3a70-11f1-ae07-e4213316b5fa"},"tex