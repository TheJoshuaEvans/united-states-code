{"tag":"section","attrib":{"id":"idbe07b4e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382"},"text":null,"children":[{"tag":"num","attrib":{"value":"7382"},"text":"§ 7382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b4e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy has unique and extensive mathematics and science capabilities that contribute to mathematics and science education programs throughout the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a need exists to increase understanding, communication, and cooperation between the Congress, the Department of Energy, other Federal agencies, and the mathematics and science education community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elementary and secondary school mathematics and science teachers can provide practical insight to the legislative and executive branches in establishing and operating education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b4ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pilot program that placed elementary and secondary school mathematics and science teachers in professional staff positions in the Senate and the House of Representatives has proven successful and demonstrated the value of expanding the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b4ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s512"},"text":"Pub. L. 103–382, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4042"},"text":"108 Stat. 4042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe07b4ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe07b4ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbe07b4f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s511"},"text":"Pub. L. 103–382, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4042"},"text":"108 Stat. 4042","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/382/tV/s511"},"text":"“This part [part A (§§ 511–518) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":", enacting this subchapter] may be cited as the ‘Albert Einstein Distinguished Educator Fellowship Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
