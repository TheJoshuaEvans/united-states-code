{"tag":"section","attrib":{"id":"idbf5a4bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901"},"text":null,"children":[{"tag":"num","attrib":{"value":"11901"},"text":"§ 11901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf5a4bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government has a duty to provide public and other federally assisted low-income housing that is decent, safe, and free from illegal drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and other federally assisted low-income housing in many areas suffers from rampant drug-related or violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug dealers are increasingly imposing a reign of terror on public and other federally assisted low-income housing tenants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increase in drug-related and violent crime not only leads to murders, muggings, and other forms of violence against tenants, but also to a deterioration of the physical environment that requires substantial government expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local law enforcement authorities often lack the resources to deal with the drug problem in public and other federally assisted low-income housing, particularly in light of the recent reductions in Federal aid to cities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government should provide support for effective safety and security measures to combat drug-related and violent crime, primarily in and around public housing proj­ects with severe crime problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closer cooperation should be encouraged between public and assisted housing managers, local law enforcement agencies, and residents in developing and implementing anti-crime programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf5a4c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anti-crime strategies should be improved through the expansion of community-oriented policing initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf5a4c06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5122"},"text":"Pub. L. 100–690, title V, § 5122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4301"},"text":"102 Stat. 4301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4245"},"text":"104 Stat. 4245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s586/b"},"text":"Pub. L. 105–276, title V, § 586(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2646"},"text":"112 Stat. 2646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf5a4c07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf5a4c08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf5a4c09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/b/1"},"text":"Pub. L. 105–276, § 586(b)(1)","children":[],"tail":", inserted “or violent” after “drug-related”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/b/2/A"},"text":"Pub. L. 105–276, § 586(b)(2)(A)","children":[],"tail":", inserted “and violent” after “drug-related”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/s586/b/2/B"},"text":"Pub. L. 105–276, § 586(b)(2)(B)","children":[],"tail":", (3), (4), added pars. (6) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Congress finds that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Federal Government has a duty to provide public housing that is decent, safe, and free from illegal drugs;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) public housing projects in many areas suffer from rampant drug-related crime;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) drug dealers are increasingly imposing a reign of terror on public housing tenants;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the increase in drug-related crime not only leads to murders, muggings, and other forms of violence against tenants, but also to a deterioration of the physical environment that requires substantial government expenditures; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) local law enforcement authorities often lack the resources to deal with the drug problem in public housing, particularly in light of the recent reductions in Federal aid to cities.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf5a4c0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf5a4c0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" effective and applicable beginning upon "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", except as otherwise provided, with provision that Secretary may implement amendment before such date, except to extent that such amendment provides otherwise, and with savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/s503"},"text":"section 503 of Pub. L. 105–276","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf5a4c0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s586/a"},"text":"Pub. L. 105–276, title V, § 586(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2646"},"text":"112 Stat. 2646","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/276/tV/s586/a"},"text":"“This section [enacting sections 11906 to 11908 of this title, amending this section and sections 11902, 11903, 11904, and 11905 of this title, and repealing sections 11906 to 11909 of this title] may be cited as the ‘Public and Assisted Housing Drug Elimination Program Amendments of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbf5a4c0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227/tX/s1051"},"text":"Pub. L. 103–227, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/274"},"text":"108 Stat. 274","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/227/tX/s1051"},"text":"“This part [part D (§§ 1051–1053) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/227"},"text":"Pub. L. 103–227","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11903a"},"text":"section 11903a of this title","children":[],"tail":"] may be cited as the ‘Midnight Basketball League Training and Partnership Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf5a4c0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5121"},"text":"Pub. L. 100–690, title V, § 5121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4301"},"text":"102 Stat. 4301","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tV/s581/a"},"text":"Pub. L. 101–625, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4245"},"text":"104 Stat. 4245","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/625/tV/s581/a"},"text":"“This chapter [chapter 2 (§§ 5121–5130) of subtitle C of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", enacting this subchapter] may be cited as the ‘Public and Assisted Housing Drug Elimination Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tV/s5141"},"text":"Pub. L. 100–690, title V, § 5141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4303"},"text":"102 Stat. 4303","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tV/s5141"},"text":"“This chapter [chapter 3 (§§ 5141–5146) of subtitle C of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", enacting subchapter II of this chapter] may be cited as the ‘Drug-Free Public Housing Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
