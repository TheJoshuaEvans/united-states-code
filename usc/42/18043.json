{"tag":"section","attrib":{"id":"idc04b151d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043"},"text":null,"children":[{"tag":"num","attrib":{"value":"18043"},"text":"§ 18043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for the territories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04b151e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A territory that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b151f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects consistent with subsection (b) to establish an Exchange in accordance with part B of this subchapter and establishes such an Exchange in accordance with such part shall be treated as a State for purposes of such part and shall be entitled to payment from the amount allocated to the territory under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not make such election shall be entitled to an increase in the dollar limitation applicable to the territory under subsections (f) and (g) of section 1108 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1308"},"text":"42 U.S.C. 1308","children":[],"tail":") for such period in such amount for such territory and such increase shall not be taken into account in computing any other amount under such subsections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election under subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be effective unless the election is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18041"},"text":"section 18041 of this title","children":[],"tail":" and is received not later than "},{"tag":"date","attrib":{"date":"2013-10-01"},"text":"October 1, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be contingent upon entering into an agreement between the territory and the Secretary that requires that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b1524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds provided under the agreement shall be used only to provide premium and cost-sharing assistance to residents of the territory obtaining health insurance coverage through the Exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b1525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the premium and cost-sharing assistance provided under such agreement shall be structured in such a manner so as to prevent any gap in assistance for individuals between the income level at which medical assistance is available through the territory’s Medicaid plan under title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] and the income level at which premium and cost-sharing assistance is available under the agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation and allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, there is appropriated for purposes of payment pursuant to subsection (a) $1,000,000,000, to be available during the period beginning with 2014 and ending with 2019.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allocate the amount appropriated under paragraph (1) among the territories for purposes of carrying out this section as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b1529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For Puerto Rico, $925,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b152a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18043/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For another territory, the portion of $75,000,000 specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04b152b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1323"},"text":"Pub. L. 111–148, title I, § 1323","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/152/tI/s1204/a"},"text":"Pub. L. 111–152, title I, § 1204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-30"},"text":"Mar. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1055"},"text":"124 Stat. 1055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04b152c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04b152d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc04b152e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc04b152f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 18043, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1323"},"text":"Pub. L. 111–148, title I, § 1323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/192"},"text":"124 Stat. 192","children":[],"tail":", which related to establishment of community health insurance option, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10104/m"},"text":"Pub. L. 111–148, title X, § 10104(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/902"},"text":"124 Stat. 902","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
