{"tag":"section","attrib":{"id":"idbe0c6fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384v"},"text":"§ 7384v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for claimants and potential claimants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c6fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for claimants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall, upon the receipt of a request for assistance from a claimant under the compensation program, provide assistance to the claimant in connection with the claim, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6fdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in securing medical testing and diagnostic services necessary to establish the existence of a covered beryllium illness, chronic silicosis, or cancer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other assistance as may be required to develop facts pertinent to the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for potential claimants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall take appropriate actions to inform and assist covered employees who are potential claimants under the compensation program, and other potential claimants under the compensation program, of the availability of compensation under the compensation program, including actions to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c6fe0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the ready availability, in paper and electronic format, of forms necessary for making claims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fe1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide such covered employees and other potential claimants with information and other support necessary for making claims, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c6fe2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical protocols for medical testing and diagnosis to establish the existence of a covered beryllium illness, chronic silicosis, or cancer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0c6fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists of vendors approved for providing laboratory services related to such medical testing and diagnosis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0c6fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional assistance to such covered employees and other potential claimants as may be required for the development of facts pertinent to a claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0c6fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384v/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from beryllium vendors and other contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the assistance program provided under subsections (a) and (b), and as permitted by law, the Secretary of Energy shall, upon the request of the President, require a beryllium vendor or other Department of Energy contractor or subcontractor to provide information relevant to a claim or potential claim under the compensation program to the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0c6fe6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3631"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3631]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–508.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0c6fe7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbe0c6fe8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idbe0c6fe9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of the President under this section, see Ex. Ord. No. 13179, ","children":[{"tag":"date","attrib":{"date":"2000-12-07"},"text":"Dec. 7, 2000","children":[],"tail":", 65 F.R. 77487, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384"},"text":"section 7384 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
