{"tag":"section","attrib":{"id":"idbf25ceb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366"},"text":null,"children":[{"tag":"num","attrib":{"value":"10366"},"text":"§ 10366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate change and water intragovernmental panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf25ceb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Administrator shall establish and lead a climate change and water intragovernmental panel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25ceb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the current scientific understanding of each impact of global climate change on the quantity and quality of freshwater resources of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop any strategy that the panel determines to be necessary to improve observational capabilities, expand data acquisition, or take other actions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25ceb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the reliability and accuracy of modeling and prediction systems to benefit water managers at the Federal, State, and local levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25ceb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the understanding of the impacts of climate change on aquatic ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ceb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel shall be comprised of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25ceb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ceba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture (acting through the Under Secretary for Natural Resources and Environment);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army, acting through the Chief of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the review and developing the strategy under subsection (a), the panel shall consult with State water resource agencies, the Advisory Committee, drinking water utilities, water research organizations, and relevant water user, environmental, and other nongovernmental organizations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the extent to which the conduct of measures of streamflow, groundwater levels, soil moisture, evapotranspiration rates, evaporation rates, snowpack levels, precipitation amounts, flood risk, and glacier mass is necessary to improve the understanding of the Federal Government and the States with respect to each impact of global climate change on water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify data gaps in current water monitoring networks that must be addressed to improve the capability of the Federal Government and the States to measure, analyze, and predict changes to the quality and quantity of water resources, including flood risks, that are directly or indirectly affected by global climate change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish data management and communication protocols and standards to increase the quality and efficiency by which each Federal agency acquires and reports relevant data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to consider options for the establishment of a data portal to enhance access to water resource data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to each nationally significant freshwater watershed and aquifer located in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is collected by each Federal agency and any other public or private entity for each nationally significant freshwater watershed and aquifer located in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the development of hydrologic and other models to integrate data that reflects groundwater and surface water interactions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apply the hydrologic and other models developed under paragraph (5) to water resource management problems identified by the panel, including the need to maintain or improve ecological resiliency at watershed and aquifer system scales.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", the Secretary shall submit to the appropriate committees of Congress a report that describes the review conducted, and the strategy developed, by the panel under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25ceca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration, research, and methodology development projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25cecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the panel and the Advisory Committee, may provide grants to, or enter into any contract, cooperative agreement, interagency agreement, or other transaction with, an appropriate entity to carry out any demonstration, research, or methodology development project that the Secretary determines to be necessary to assist in the implementation of the strategy developed by the panel under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25cecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf25cecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any demonstration, research, or methodology development project that is the subject of any grant, contract, cooperative agreement, interagency agreement, or other transaction entered into between the Secretary and an appropriate entity under paragraph (1) shall not exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf25cece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appropriate entity that receives funds from a grant, contract, cooperative agreement, interagency agreement, or other transaction entered into between the Secretary and the appropriate entity under paragraph (1) shall submit to the Secretary a report describing the results of the demonstration, research, or methodology development project conducted by the appropriate entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf25cecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf25ced0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out subsections (a) through (d) $2,000,000 for each of fiscal years 2009 through 2011, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf25ced1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10366/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration, research, and methodology development projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out subsection (e) $10,000,000 for the period of fiscal years 2009 through 2013, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf25ced2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tIX/s9506"},"text":"Pub. L. 111–11, title IX, § 9506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1338"},"text":"123 Stat. 1338","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
