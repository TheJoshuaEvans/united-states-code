{"tag":"section","attrib":{"id":"idbc5cc3e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032a"},"text":"§ 3032a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career preparation for the field of aging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5cc3e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall make grants to institutions of higher education, including historically Black colleges or universities, Hispanic-serving institutions, and Hispanic Centers of Excellence in Applied Gerontology, to provide education and training that prepares students for careers in the field of aging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc3e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc3ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic Center of Excellence in Applied Gerontology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Hispanic Center of Excellence in Applied Gerontology” means an institution of higher education with a program in applied gerontology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc3eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a significant number of Hispanic individuals enrolled in the program, including individuals accepted for enrollment in the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been effective in assisting Hispanic students of the program to complete the program and receive the degree involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been effective in recruiting Hispanic individuals to attend the program, including providing scholarships and other financial assistance to such individuals and encouraging Hispanic students of secondary educational institutions to attend the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made significant recruitment efforts to increase the number and placement of Hispanic individuals serving in faculty or administrative positions in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically Black college or university","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historically Black college or university” has the meaning given the term “part B institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"section 1061(2) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5cc3f0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s412"},"text":"Pub. L. 89–73, title IV, § 412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2258"},"text":"114 Stat. 2258","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s403"},"text":"Pub. L. 109–365, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2553"},"text":"120 Stat. 2553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5cc3f1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5cc3f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc5cc3f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s412"},"text":"section 412 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3032"},"text":"section 3032 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s412"},"text":"section 412 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s104/b/3"},"text":"Pub. L. 95–478, title I, § 104(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1539"},"text":"92 Stat. 1539","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc5cc3f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Assistant Secretary shall make grants to institutions of higher education, historically Black colleges or universities, Hispanic Centers of Excellence in Applied Gerontology, and other educational institutions that serve the needs of minority students, to provide education and training to prepare students for careers in the field of aging.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
