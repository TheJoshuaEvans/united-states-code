{"tag":"section","attrib":{"id":"idbfd3e9ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924"},"text":null,"children":[{"tag":"num","attrib":{"value":"14924"},"text":"§ 14924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial oversight of accreditation and approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd3ea00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight of accrediting entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3ea01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the performance by each accrediting entity of its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14922"},"text":"section 14922 of this title","children":[],"tail":" and its compliance with the requirements of the Convention, this chapter, other applicable laws, and implementing regulations under this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3ea02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or cancel the designation of an accrediting entity found to be substantially out of compliance with the Convention, this chapter, other applicable laws, or implementing regulations under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3ea03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or cancellation of accreditation or approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3ea04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall suspend or cancel the accreditation or approval granted by an accrediting entity to an agency or person pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14922"},"text":"section 14922 of this title","children":[],"tail":" when the Secretary finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd3ea05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency or person is substantially out of compliance with applicable requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3ea06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accrediting entity has failed or refused, after consultation with the Secretary, to take appropriate enforcement action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd632f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of deficiency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At any time when the Secretary is satisfied that the deficiencies on the basis of which an adverse action is taken under paragraph (1) have been corrected, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd632f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the accrediting entity that the deficiencies have been corrected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd632f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfd632fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a suspension, terminate the suspension; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfd632fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cancellation, notify the agency or person that the agency or person may re-apply to the accrediting entity for accreditation or approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd632fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debarment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd632fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary’s authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the initiative of the Secretary, or on request of an accrediting entity, the Secretary may temporarily or permanently debar an agency from accreditation or a person from approval under this subchapter, but only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd632fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is substantial evidence that the agency or person is out of compliance with applicable requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd632ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been a pattern of serious, willful, or grossly negligent failures to comply or other aggravating circumstances indicating that continued accreditation or approval would not be in the best interests of the children and families concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63300-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of debarment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary’s debarment order shall state whether the debarment is temporary or permanent. If the debarment is temporary, the Secretary shall specify a date, not earlier than 3 years after the date of the order, on or after which the agency or person may apply to the Secretary for withdrawal of the debarment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63301-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of debarment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An accrediting entity may take into account the circumstances of the debarment of an agency or person that has been debarred pursuant to this subsection in considering any subsequent application of the agency or person, or of any other entity in which the agency or person has an ownership or control interest, for accreditation or approval under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63302-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person (other than a prospective adoptive parent), an agency, or an accrediting entity who is the subject of a final action of suspension, cancellation, or debarment by the Secretary under this subchapter may petition the United States District Court for the District of Columbia or the United States district court in the judicial district in which the person resides or the agency or accrediting entity is located to set aside the action. The court shall review the action in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63303-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to ensure a full and complete home study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd63304-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Willful, grossly negligent, or repeated failure to ensure the completion and transmission of a background report (home study) that fully complies with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923/b/1/A/ii"},"text":"section 14923(b)(1)(A)(ii) of this title","children":[],"tail":" shall constitute substantial noncompliance with applicable requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63305-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923"},"text":"section 14923 of this title","children":[],"tail":" shall provide for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd63306-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frequent and careful monitoring of compliance by agencies and approved persons with the requirements of section 14923(b)(A)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn004188"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004188"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “14923(b)(1)(A)(ii)”."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63307-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation between the Secretary and the accrediting entity where an agency or person has engaged in substantial noncompliance with the requirements of section 14923(b)(A)(ii) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, unless the accrediting entity has taken appropriate corrective action and the noncompliance has not recurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63308-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeated failures to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repeated serious, willful, or grossly negligent failures to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923/b/1/A/ii"},"text":"section 14923(b)(1)(A)(ii) of this title","children":[],"tail":" by an agency or person after consultation between Secretary and the accrediting entity with respect to previous noncompliance by such agency or person shall constitute a pattern of serious, willful, or grossly negligent failures to comply under subsection (c)(1)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63309-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14924/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with certain requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A failure to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923/b/1/A/ii"},"text":"section 14923(b)(1)(A)(ii) of this title","children":[],"tail":" shall constitute a serious failure to comply under subsection (c)(1)(B) unless it is shown by clear and convincing evidence that such noncompliance had neither the purpose nor the effect of determining the outcome of a decision or proceeding by a court or other competent authority in the United States or the child’s country of origin."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd6330a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tII/s204"},"text":"Pub. L. 106–279, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/835"},"text":"114 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd6330b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd6330c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd6330d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", known as the Intercountry Adoption Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (c)(1), (3) and (d), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/830"},"text":"114 Stat. 830","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd6330e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd6330f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", with transition rule, see section 505(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
