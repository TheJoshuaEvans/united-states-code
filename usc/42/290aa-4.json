{"tag":"section","attrib":{"id":"idb59e89e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–4"},"text":"§ 290aa–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for behavioral health statistics and quality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59e89e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall maintain within the Administration a Center for Behavioral Health Statistics and Quality (in this section referred to as the “Center”). The Center shall be headed by a Director (in this section referred to as the “Director”) appointed by the Secretary from among individuals with extensive experience and academic qualifications in research and analysis in behavioral health care or related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e89ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of annual collection of data on mental illness and substance abuse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59e89eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate the Administration’s integrated data strategy, including by collecting data each year on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59e89ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national incidence and prevalence of the various forms of mental illness and substance abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incidence and prevalence of such various forms in major metropolitan areas selected by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide statistical and analytical support for activities of the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend a core set of performance metrics to evaluate activities supported by the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Assistant Secretary, the Assistant Secretary for Planning and Evaluation, and the Chief Medical Officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa/g"},"text":"section 290aa(g) of this title","children":[],"tail":", as appropriate, to improve the quality of services provided by programs of the Administration and the evaluation of activities carried out by the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e89f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the activities of the Director under subsection (b)(1) relating to mental health, the Director shall ensure that such activities include, at a minimum, the collection of data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59e89f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and variety of public and nonprofit private treatment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and demographic characteristics of individuals receiving treatment through such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of care received by such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e89f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other data as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e89f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substance abuse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59e89f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the activities of the Director under subsection (b)(1) relating to substance abuse, the Director shall ensure that such activities include, at a minimum, the collection of data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59e89f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals admitted to the emergency rooms of hospitals as a result of the abuse of alcohol or other drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of deaths occurring as a result of substance abuse, as indicated in reports by coroners in coordination with the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and variety of public and private nonprofit treatment programs, including the number and type of patient slots available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals seeking treatment through such programs, the number and demographic characteristics of individuals receiving such treatment, the percentage of individuals who complete such programs, and, with respect to individuals receiving such treatment, the length of time between an individual’s request for treatment and the commencement of treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such individuals who return for treatment after the completion of a prior treatment in such programs and the method of treatment utilized during the prior treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals receiving public assistance for such treatment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of the different types of treatment modalities for drug and alcohol abuse and the aggregate relative costs of each such treatment modality provided within a State in each fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e89ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent of available information, the number of individuals receiving treatment for alcohol or drug abuse who have private insurance coverage for the costs of such treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e8a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of alcohol and drug abuse among high school students and among the general population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e8a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of alcohol and drug abuse counselors and other substance abuse treatment personnel employed in public and private treatment facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual surveys; public availability of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Annual surveys shall be carried out in the collection of data under this subsection. Summaries and analyses of the data collected shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e8a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consultation with the States and with appropriate national organizations, the Assistant Secretary shall use existing standards and best practices to develop uniform criteria for the collection of data, using the best available technology, pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb59e8a04-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 505, formerly § 509D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2052/a"},"text":"Pub. L. 100–690, title II, § 2052(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4207"},"text":"102 Stat. 4207","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s3/b"},"text":"Pub. L. 101–93, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/609"},"text":"103 Stat. 609","children":[],"tail":"; renumbered § 505, "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s105"},"text":"Pub. L. 102–321, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/334"},"text":"106 Stat. 334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2010/b/7"},"text":"Pub. L. 103–43, title XX, § 2010(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/214"},"text":"107 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVI"},"text":"Pub. L. 114–255, div. B, title VI","children":[],"tail":", §§ 6001(c)(2), 6004, "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1203"},"text":"130 Stat. 1203","children":[],"tail":", 1207.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb59e8a05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb59e8a06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb59e8a07-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–11"},"text":"section 290aa–11 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb59e8a08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290aa–4, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s506"},"text":"act July 1, 1944, ch. 373, title V, § 506","children":[],"tail":", formerly § 505, as added "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/b/7"},"text":"Pub. L. 98–24, § 2(b)(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/178"},"text":"97 Stat. 178","children":[],"tail":"; renumbered § 506, "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4004/a"},"text":"Pub. L. 99–570, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-109"},"text":"100 Stat. 3207–109","children":[],"tail":", which related to reports on alcoholism and alcohol and drug abuse, was renumbered section 503 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–2"},"text":"section 290aa–2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 505 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 502 by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/s102"},"text":"section 102 of Pub. L. 102–321","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–1"},"text":"section 290aa–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 505 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s223"},"text":"section 223 of this title","children":[],"tail":", was renumbered section 2105 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–4"},"text":"section 300aa–4 of this title","children":[],"tail":", renumbered section 2305 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–4"},"text":"section 300cc–4 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/117/s12/f"},"text":"Pub. L. 99–117, § 12(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-07"},"text":"Oct. 7, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/495"},"text":"99 Stat. 495","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb59e8a09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/1"},"text":"Pub. L. 114–255, § 6004(1)","children":[],"tail":", substituted “Center for behavioral health statistics and quality” for “Data collection” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/3"},"text":"Pub. L. 114–255, § 6004(3)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator” in introductory provisions and in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/4"},"text":"Pub. L. 114–255, § 6004(4)","children":[],"tail":", substituted “The Director shall—” for “The Secretary, acting through the Assistant Secretary, shall collect data each year on—”, added par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B) of par. (1), respectively, substituted “Director” for “Assistant Secretary” in subpar. (B), and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/2"},"text":"Pub. L. 114–255, § 6004(2)","children":[],"tail":", redesignated subsec. (a) as (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/5"},"text":"Pub. L. 114–255, § 6004(5)","children":[],"tail":", inserted heading and in introductory provisions substituted “subsection (b)(1)” for “subsection (a)” and “Director” for “Assistant Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/2"},"text":"Pub. L. 114–255, § 6004(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/6"},"text":"Pub. L. 114–255, § 6004(6)","children":[],"tail":", inserted heading, in par. (1) inserted heading and in introductory provisions substituted “subsection (b)(1)” for “subsection (a)” and “Director” for “Assistant Secretary” in two places, in par. (1)(B) inserted “in coordination with the Centers for Disease Control and Prevention” before semicolon at end, and in par. (2) inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/2"},"text":"Pub. L. 114–255, § 6004(2)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/7"},"text":"Pub. L. 114–255, § 6004(7)","children":[],"tail":", inserted heading and substituted “Assistant Secretary shall use existing standards and best practices to develop” for “Assistant Secretary shall develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6004/2"},"text":"Pub. L. 114–255, § 6004(2)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s2010/b/7"},"text":"Pub. L. 103–43, § 2010(b)(7)","children":[],"tail":", which directed the substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"section 238 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa"},"text":"section 300aaa of this title","children":[],"tail":"” in section 505(a)(2) of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":" (this section), could not be executed because the language did not appear. Amendment was probably intended for prior section 505 which was renumbered section 502 and amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/s102"},"text":"Pub. L. 102–321, § 102","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–1"},"text":"section 290aa–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93/s3/b/1"},"text":"Pub. L. 101–93, § 3(b)(1)","children":[],"tail":", substituted “alcohol or” for “alcohol and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93/s3/b/2"},"text":"Pub. L. 101–93, § 3(b)(2)","children":[],"tail":", substituted “this subsection” for “this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb59e8a0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59e8a0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Survey on Drug Use and Health","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/358/s5"},"text":"Pub. L. 108–358, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1664"},"text":"118 Stat. 1664","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/358/s5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services shall ensure that the National Survey on Drug Use and Health includes questions concerning the use of anabolic steroids.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $1,000,000 for each of fiscal years 2005 through 2010.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59e8a0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Consumption of Methamphetamine and Other Illicit Drugs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXVI/s3641"},"text":"Pub. L. 106–310, div. B, title XXXVI, § 3641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1237"},"text":"114 Stat. 1237","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/310/dB/tXXXVI/s3641"},"text":"“The Secretary of Health and Human Services shall include in each National Household Survey on Drug Abuse appropriate prevalence data and information on the consumption of methamphetamine and other illicit drugs in rural areas, metropolitan areas, and consolidated metropolitan areas.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59e8a0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public Health Monitoring of Methamphetamine Abuse","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/237/tV/s502"},"text":"Pub. L. 104–237, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3112"},"text":"110 Stat. 3112","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/237/tV/s502"},"text":"“The Secretary of Health and Human Services shall develop a public health monitoring program to monitor methamphetamine abuse in the United States. The program shall include the collection and dissemination of data related to methamphetamine abuse which can be used by public health officials in policy development.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
