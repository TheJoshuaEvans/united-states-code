{"tag":"section","attrib":{"id":"idbc17a494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296a"},"text":"§ 2296a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedial action program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc17a495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the costs of decontamination, decommissioning, reclamation, and other remedial action at an active uranium or thorium processing site shall be borne by persons licensed under section 2092 or 2111 of this title for any activity at such site which results or has resulted in the production of byproduct material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc17a496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc17a497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall, subject to paragraph (2), reimburse at least annually a licensee described in subsection (a) for such portion of the costs described in such subsection as are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc17a498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be attributable to byproduct material generated as an incident of sales to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc17a49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred by such licensee not later than ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred by a licensee after ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":", in accordance with a plan for subsequent decontamination, decommissioning, reclamation, and other remedial action approved by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc17a49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To individual active site uranium licensees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of reimbursement paid to any licensee under paragraph (1) shall be determined by the Secretary in accordance with regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2296a–1"},"text":"section 2296a–1 of this title","children":[],"tail":" and, for uranium mill tailings only, shall not exceed an amount equal to $6.25 multiplied by the dry short tons of byproduct material located on "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", at the site of the activities of such licensee described in subsection (a), and generated as an incident of sales to the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To all active site uranium licensees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made under paragraph (1) to active site uranium licensees shall not in the aggregate exceed $350,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a49f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To thorium licensees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made under paragraph (1) to the licensee of the active thorium site shall not exceed $365,000,000, and may only be made for off-site disposal. Such payments shall not exceed the following amounts:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc17a4a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $90,000,000 in fiscal year 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 in fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 in fiscal year 2004.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 in fiscal year 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 in fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 in fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any amounts authorized to be paid in a fiscal year under this subparagraph that are not paid in that fiscal year may be paid in subsequent fiscal years.","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a4a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation escalation index","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts in subparagraphs (A), (B), and (C) of this paragraph shall be increased annually based upon an inflation index. The Secretary shall determine the appropriate index to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc17a4a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reimbursement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc17a4a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of excess","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine as of ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", whether the amount authorized to be appropriated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2296a–2"},"text":"section 2296a–2 of this title","children":[],"tail":", when considered with the $6.25 per dry short ton limit on reimbursement, exceeds the amount reimbursable to the licensees under subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc17a4a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In the event of excess","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under clause (i) that there is an excess, the Secretary may allow reimbursement in excess of $6.25 per dry short ton on a prorated basis at such sites where the costs reimbursable under subsection (b)(1) exceed the $6.25 per dry short ton limitation described in paragraph (2) of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc17a4aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Byproduct location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the requirement of paragraph (2)(A) that byproduct material be located at the site on ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", byproduct material moved from the site of the Edgemont Mill to a disposal site as the result of the decontamination, decommissioning, reclamation, and other remedial action of such mill shall be eligible for reimbursement to the extent eligible under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc17a4ab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1001"},"text":"Pub. L. 102–486, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2946"},"text":"106 Stat. 2946","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/259/s3/a"},"text":"Pub. L. 104–259, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3173"},"text":"110 Stat. 3173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s11/a"},"text":"Pub. L. 105–388, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3484"},"text":"112 Stat. 3484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/317/s1"},"text":"Pub. L. 106–317, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-19"},"text":"Oct. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1277"},"text":"114 Stat. 1277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/222/s1/a"},"text":"Pub. L. 107–222, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1336"},"text":"116 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4ac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc17a4af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/222"},"text":"Pub. L. 107–222","children":[],"tail":" substituted “$365,000,000” for “$140,000,000” and inserted at end “Such payments shall not exceed the following amounts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) $90,000,000 in fiscal year 2002.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $55,000,000 in fiscal year 2003.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) $20,000,000 in fiscal year 2004.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) $20,000,000 in fiscal year 2005.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(v) $20,000,000 in fiscal year 2006.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(vi) $20,000,000 in fiscal year 2007.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any amounts authorized to be paid in a fiscal year under this subparagraph that are not paid in that fiscal year may be paid in subsequent fiscal years.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/317/s1/1"},"text":"Pub. L. 106–317, § 1(1)","children":[],"tail":", substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/317/s1/2"},"text":"Pub. L. 106–317, § 1(2)","children":[],"tail":", substituted “incurred by a licensee after "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":",” for “placed in escrow not later than "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/317/s1/3"},"text":"Pub. L. 106–317, § 1(3)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2005-07-31"},"text":"July 31, 2005","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" substituted “$140,000,000” for “$65,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/259/s3/a/1"},"text":"Pub. L. 104–259, § 3(a)(1)","children":[],"tail":", substituted “$6.25” for “$5.50”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/259/s3/a/2"},"text":"Pub. L. 104–259, § 3(a)(2)","children":[],"tail":", substituted “$350,000,000” for “$270,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/259/s3/a/3"},"text":"Pub. L. 104–259, § 3(a)(3)","children":[],"tail":", substituted “$65,000,000” for “$40,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/259/s3/a/4"},"text":"Pub. L. 104–259, § 3(a)(4)","children":[],"tail":", (5), substituted “$6.25” for “$5.50” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
