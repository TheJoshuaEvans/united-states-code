{"tag":"section","attrib":{"id":"idbcdffdd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4770"},"text":null,"children":[{"tag":"num","attrib":{"value":"4770"},"text":"§ 4770.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on availability of funds for cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal funds made available to State or local governments under other programs may not be used by the State or local government for cost-sharing purposes under grant provisions of this chapter, except that Federal funds of a program financed wholly by Federal funds may be used to pay a pro-rata share of such cost sharing. State or local government funds used for cost sharing on other federally assisted programs may not be used for cost sharing under grant provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcdffdda-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tV/s511"},"text":"Pub. L. 91–648, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1928"},"text":"84 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdffddb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdffddc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcdffddd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, means the provisions of subchapters I, II, III, and IV of this chapter. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4761"},"text":"section 4761 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
