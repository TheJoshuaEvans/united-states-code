{"tag":"section","attrib":{"id":"idc02c1b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155"},"text":null,"children":[{"tag":"num","attrib":{"value":"17155"},"text":"§ 17155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for eligible entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under the program, each eligible applicant shall submit to the Secretary a written assurance that all laborers and mechanics employed by any contractor or subcontractor of the eligible entity during any construction, alteration, or repair activity funded, in whole or in part, by the grant shall be paid wages at rates not less than the prevailing wages for similar construction activities in the locality, as determined by the Secretary of Labor, in accordance with sections 3141 through 3144, 3146, and 3147 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Labor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the labor standards referred to in paragraph (1), the Secretary of Labor shall have the authority and functions described in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reorganization Plan Numbered 14 of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s903"},"text":"5 U.S.C. 903","children":[],"tail":" note); "},{"tag":"ref","attrib":{"idref":"fn004261"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004261"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible units of local government and Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed strategy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which an eligible unit of local government or Indian tribe receives a grant under this part, the eligible unit of local government or Indian tribe shall submit to the Secretary a proposed energy efficiency and conservation strategy in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proposed strategy under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the goals of the eligible unit of local government or Indian tribe, in accordance with the purposes of this part, for increased energy efficiency and conservation in the jurisdiction of the eligible unit of local government or Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the use of the grant to assist the eligible unit of local government or Indian tribe in achieving those goals, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17154"},"text":"section 17154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for eligible units of local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy under subparagraph (A), an eligible unit of local government shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account any plans for the use of funds by adjacent eligible units of local governments that receive grants under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and share information with the State in which the eligible unit of local government is located regarding activities carried out using the grant to maximize the energy efficiency and conservation benefits under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve or disapprove a proposed strategy under paragraph (1) by not later than 120 days after the date of submission of the proposed strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary disapproves a proposed strategy under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall provide to the eligible unit of local government or Indian tribe the reasons for the disapproval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible unit of local government or Indian tribe may revise and resubmit the proposed strategy as many times as necessary until the Secretary approves a proposed strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide to an eligible unit of local government or Indian tribe any grant under the program until a proposed strategy of the eligible unit of local government or Indian tribe is approved by the Secretary under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts provided to an eligible unit of local government or Indian tribe under the program, an eligible unit of local government or Indian tribe may use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for administrative expenses, excluding the cost of meeting the reporting requirements of this part, an amount equal to the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent; and ","children":[{"tag":"ref","attrib":{"idref":"fn004262"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004262"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “or”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the establishment of revolving loan funds, an amount equal to the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent; and ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the provision of subgrants to nongovernmental organizations for the purpose of assisting in the implementation of the energy efficiency and conservation strategy of the eligible unit of local government or Indian tribe, an amount equal to the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent; and ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which funds are initially provided to an eligible unit of local government or Indian tribe under the program, and annually thereafter, the eligible unit of local government or Indian tribe shall submit to the Secretary a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of development and implementation of the energy efficiency and conservation strategy of the eligible unit of local government or Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as practicable, an assessment of energy efficiency gains within the jurisdiction of the eligible unit of local government or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under the program shall use not less than 60 percent of the amount received to provide subgrants to units of local government in the State that are not eligible units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall provide the subgrants required under subparagraph (A) by not later than 180 days after the date on which the Secretary approves a proposed energy efficiency and conservation strategy of the State under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of conservation plan; proposed strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", each State shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the State energy conservation plan of the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6322"},"text":"section 6322 of this title","children":[],"tail":" to establish additional goals for increased energy efficiency and conservation in the State; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary a proposed energy efficiency and conservation strategy that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a process for providing subgrants as required under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan of the State for the use of funds received under the program to assist the State in achieving the goals established under subparagraph (A), in accordance with sections 17152(b) and 17154 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve or disapprove a proposed strategy under paragraph (2)(B) by not later than 120 days after the date of submission of the proposed strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary disapproves a proposed strategy under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02c1b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall provide to the State the reasons for the disapproval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02c1b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State may revise and resubmit the proposed strategy as many times as necessary until the Secretary approves a proposed strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide to a State any grant under the program until a proposed strategy of the State is approved by the Secretary under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use not more than 10 percent of amounts provided under the program for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that receives a grant under the program shall submit to the Secretary an annual report that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02c1b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of development and implementation of the energy efficiency and conservation strategy of the State during the preceding calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the subgrant program of the State under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy efficiency gains achieved through the energy efficiency and conservation strategy of the State during the preceding calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02c1b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17155/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific energy efficiency and conservation goals of the State for subsequent calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1b77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s545"},"text":"Pub. L. 110–140, title V, § 545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1670"},"text":"121 Stat. 1670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1b78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02c1b79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc02c1b7a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 14 of 1950, referred to in subsec. (a)(2)(A), is set out in the Appendix to Title 5, Government Organization and Employees. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s903"},"text":"Section 903 of Title 5","children":[],"tail":" relates to Presidential authority regarding reorganization plans."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1b7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1b7c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
