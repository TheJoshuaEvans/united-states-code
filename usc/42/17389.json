{"tag":"section","attrib":{"id":"idc03a7381-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389"},"text":null,"children":[{"tag":"num","attrib":{"value":"17389"},"text":"§ 17389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology demonstration on the distribution grid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03a7382-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a grant program to carry out eligible projects related to the modernization of the electric grid, including the application of technologies to improve observability, advanced controls, and prediction of system performance on the distribution system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03a7383-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under subsection (a), a project shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03a7384-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to improve the performance and efficiency of the future electric grid, while ensuring the continued provision of safe, secure, reliable, and affordable power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03a7385-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03a7386-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure integration and management of two or more energy resources, including distributed energy generation, combined heat and power, micro-grids, energy storage, electric vehicles, energy efficiency, demand response, and intelligent loads; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03a7387-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17389/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure integration and interoperability of communications and information technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03a7388-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8007"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2586"},"text":"134 Stat. 2586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03a7389-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03a738a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc03a738b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03a738c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc03a738d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3212"},"text":"section 3212 of this title","children":[],"tail":" applicable to construction, alteration, or repair work of demonstration projects funded by grants or contracts authorized under this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/s9006/b"},"text":"section 9006(b) of div. Z of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16237"},"text":"section 16237 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
