{"tag":"section","attrib":{"id":"idb78c015e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605"},"text":null,"children":[{"tag":"num","attrib":{"value":"605"},"text":"§ 605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78c015f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay each grant payable to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s603"},"text":"section 603 of this title","children":[],"tail":" in quarterly installments, subject to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 months before the payment of any such quarterly installment to a State, the Secretary shall notify the State of the amount of any reduction determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s612/a/1/B"},"text":"section 612(a)(1)(B) of this title","children":[],"tail":" with respect to the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation and certification of payments to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78c0162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall estimate the amount to be paid to each eligible State for each quarter under this part, such estimate to be based on a report filed by the State containing an estimate by the State of the total sum to be expended by the State in the quarter under the State program funded under this part and such other information as the Secretary may find necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78c0163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall certify to the Secretary of the Treasury the amount estimated under paragraph (1) with respect to a State, reduced or increased to the extent of any overpayment or underpayment which the Secretary of Health and Human Services determines was made under this part to the State for any prior quarter and with respect to which adjustment has not been made under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78c0164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a certification under subsection (c)(2) with respect to a State, the Secretary of the Treasury shall, through the Fiscal Service of the Department of the Treasury and before audit or settlement by the Government Accountability Office, pay to the State, at the time or times fixed by the Secretary of Health and Human Services, the amount so certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78c0165-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 405, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s103/a/1"},"text":"Pub. L. 104–193, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2128"},"text":"110 Stat. 2128","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5514/c"},"text":"Pub. L. 105–33, title V, § 5514(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/620"},"text":"111 Stat. 620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78c0166-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb78c0167-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"h