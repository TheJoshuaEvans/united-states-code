{"tag":"section","attrib":{"id":"idbbe5974a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2077a"},"text":"§ 2077a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency review of applications for the transfer of United States civil nuclear technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbe5974b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on transfers to covered foreign countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the same time as the President submits to Congress the annual budget request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for a fiscal year, the Secretary of Energy shall submit to the appropriate congressional committees a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5974c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the authorizations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" to transfer United States civil nuclear technology to a covered foreign country during the preceding year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe5974d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of whether any agency required to be consulted under that section or pursuant to regulation objected to or sought conditions on each such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe5974e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of technologies to be protected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5974f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", and every five years thereafter, the Secretary of Energy shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe59750-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary of State, the Secretary of Commerce, the Secretary of Defense, the Director of National Intelligence, and the Nuclear Regulatory Commission, determine the critical United States civil nuclear technologies that should be protected from diversion to a military program of a covered foreign country, including with respect to a naval propulsion or weapons program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate congressional committees with respect to the determination and the technologies covered by the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe59753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), not later than 14 days before making an authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" for the transfer of a technology covered by a determination under paragraph (1) to a covered foreign country, the Secretary of Energy shall submit to the appropriate congressional committees a report that includes—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbbe59754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification of the intention of the Secretary to make the authorization for the transfer of such technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbe59755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of whether any agency required to be consulted under such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" or pursuant to regulation objected to or sought conditions on the transfer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the requirement under subparagraph (A) to submit the report required by that subparagraph not later than 14 days before making an authorization for the transfer of a technology covered by a determination under paragraph (1) to a covered foreign country if the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbe59757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that an imminent radiological hazard exists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbe59758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 7 days after determining that such hazard exists, submits to the appropriate congressional committees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbbe59759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the hazard exists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbe5975a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for the waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbbe5975b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notification required by clause (i) of subparagraph (A) and the statement required by clause (ii) of that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe5975c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with intelligence community","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5975d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall expeditiously revise part 810 of title 10, Code of Federal Regulations, to ensure that the Director of National Intelligence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe5975e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consulted with respect to the views of the intelligence community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of title 50","children":[],"tail":") with respect to each authorization issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" for the transfer of United States civil nuclear technology to a covered foreign country before the determination to approve or disapprove the request for the authorization; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5975f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided with an opportunity to present the views of the Director and the intelligence community on the national security risks of the transfer, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, jointly with the Director of National Intelligence, shall include the results of consultations conducted under paragraph (1) in each report under subsection (a) and each notification under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe59761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on compliance of covered foreign countries and end-users","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Secretary of Energy shall submit to the appropriate congressional committees a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe59762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether each covered foreign country is in compliance with its obligations under any authorization for the transfer of United States civil nuclear technology under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any covered foreign country that is not in compliance with such obligations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe59764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description the efforts of the United States to bring the country into compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the result of such efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the options available to the Secretary as a result of the country not being in compliance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether each end-user to which United States civil nuclear technology is transferred pursuant to an authorization under such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" is in compliance with the obligations of the end-user under that authorization; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any consequences for the end-user or the exporter of the technology if the end-user is not in compliance with such obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe59769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on transfers to all foreign countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5976a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrent with the submission to Congress of the budget of the President for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Secretary of Energy shall submit to the appropriate congressional committees a report on the activities of the Department of Energy associated with the review of applications for authorization under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" to transfer United States civil nuclear technology to any foreign country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe5976b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe5976c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" to transfer United States civil nuclear technology to a foreign country submitted during the year preceding the submission of the report;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5976d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time each such application was under review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5976e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each such application, an identification of any officer to which the authorization under such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":" was delegated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2201/n"},"text":"section 2201(n) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5976f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such applications that were granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of efforts to streamline the review of such applications, taking into account the proliferation and diversion potential of end-users in the country to which United States civil nuclear technology would be transferred pursuant to such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe59771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications of potential diversions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall notify the Department of Energy and the appropriate congressional committees not later than 30 days after the date on which the Director determines that there is credible intelligence that United States civil nuclear technology is being or has been diverted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe59772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a military program in a foreign country to which the transfer of the technology was authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a foreign country to which the transfer of the technology was not so authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe59774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", the Secretary of Energy shall issue guidance with respect to the use of the clear and intended authority of the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2282"},"text":"section 2282 of this title","children":[],"tail":" to impose civil penalties, including fines and debarment, and to make referrals to the Attorney General for prosecution, for violations of the terms of authorizations for the transfer of United States civil nuclear technology issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe59775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on transfer of sensitive items","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe59776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", and annually thereafter, the President shall submit to the appropriate congressional committees a report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe59777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the efforts of covered foreign countries to prevent the transfer of sensitive items, including efforts to improve the prevention of the transfer of such items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe59778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the adequacy of such efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive items defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “sensitive items” means goods, services, and technologies described in section 2(a) of the Iran, North Korea, and Syria Nonproliferation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/178"},"text":"Public Law 106–178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe5977a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combination of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may submit the annual reports required by subsections (a), (d), and (e) as a single annual report, including by providing portions of the information so required as an annex to the single annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe5977b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5977c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe5977d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5977e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe5977f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce, the Committee on Foreign Affairs, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe59780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2077a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered foreign country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered foreign country” means a foreign country that is a nuclear-weapon state, as defined by Article IX(3) of the Treaty on the Non-Proliferation of Nuclear Weapons, signed at Washington, London, and Moscow ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":", but does not include the United States, the United Kingdom, or France."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbe59781-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3136"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1209"},"text":"129 Stat. 1209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXI/s3116/c"},"text":"Pub. L. 115–232, div. C, title XXXI, § 3116(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2291"},"text":"132 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXI/s3131/b"},"text":"Pub. L. 117–81, div. C, title XXXI, § 3131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2230"},"text":"135 Stat. 2230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXI/s3131/b"},"text":"Pub. L. 117–263, div. C, title XXXI, § 3131(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3059"},"text":"136 Stat. 3059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbe59782-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbe59783-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbe59784-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2016, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbe59785-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (i) and redesignated former subsec. (i) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “Annual reports” for “Report” in heading, “At the same time as the President submits to Congress the annual budget request under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for a fiscal year,” for “Not less frequently than every 90 days,” in introductory provisions, and “the preceding year” for “the preceding 90 days” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added subpar. (C) and redesignated former subpars. (C) and (D) as (D) and (E), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbe59786-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbe59787-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Congressional Defense Committees” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Congressional defense committees means the Committees on Armed Services and Appropriations of the Senate and the House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s3"},"text":"section 3 of Pub. L. 114–92","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/745"},"text":"129 Stat. 745","children":[],"tail":". See note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbbe59788-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbe59789-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority Pursuant to Section 3136(h) of the National Defense Authorization Act for Fiscal Year 2016","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-05-10"},"text":"May 10, 2016","children":[],"tail":", 81 F.R. 31161, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby order as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"I hereby delegate functions and authorities vested in the President by section 3136(h) of the National Defense Authorization Act for Fiscal Year 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":") (the “Act”) to the Secretary of State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference in this memorandum to the Act shall be deemed to be a reference to any future act that is the same or substantially the same as such provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
