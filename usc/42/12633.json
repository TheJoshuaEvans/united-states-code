{"tag":"section","attrib":{"id":"idbf852ca1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12633"},"text":null,"children":[{"tag":"num","attrib":{"value":"12633"},"text":"§ 12633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf852ca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this subchapter shall be used to supplement the level of State and local public funds expended for services of the type assisted under this subchapter in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf852ca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall be satisfied, with respect to a particular program, if the aggregate expenditure for such program for the fiscal year in which services are to be provided will not be less than the aggregate expenditure for such program in the previous fiscal year, excluding the amount of Federal assistance provided and any other amounts used to pay the remainder of the costs of programs assisted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf852ca4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s173"},"text":"Pub. L. 101–610, title I, § 173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3160"},"text":"104 Stat. 3160","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
