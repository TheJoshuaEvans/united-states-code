{"tag":"section","attrib":{"id":"idbe8d3815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j"},"text":null,"children":[{"tag":"num","attrib":{"value":"8262j"},"text":"§ 8262j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy management requirements for United States Postal Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8d3816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy management requirements for postal facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d3817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postmaster General shall, to the maximum extent practicable, ensure that each United States Postal Service facility meets the energy management requirements for Federal buildings and agencies specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8253"},"text":"section 8253 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postmaster General may exclude from the requirements of such section any facility or collection of facilities, and the associated energy consumption and gross square footage if the Postmaster General finds that compliance with the requirements of such section would be impracticable. A finding of impracticability shall be based on the energy intensiveness of activities carried out in such facility or collection of facilities, the type and amount of energy consumed, or the technical feasibility of making the desired changes. The Postmaster General shall identify and list in the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8262i"},"text":"section 8262i of this title","children":[],"tail":" the facilities designated by it for such exclusion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8d3819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation steps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying ","children":[{"tag":"ref","attrib":{"idref":"fn003827"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003827"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by the word “out”."}],"tail":" subsection (a), the Postmaster General shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d381a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", prepare or update, as appropriate, a plan (which may be submitted as part of the first report submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8262i"},"text":"section 8262i of this title","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe8d381b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing how this section will be implemented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8d381c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating personnel primarily responsible for achieving the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe8d381d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying high priority projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d381e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform energy surveys of United States Postal Service facilities as necessary to achieve the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d381f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" install those energy conservation measures that will attain the requirements of this section in a cost-effective manner as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8254"},"text":"section 8254 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d3820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the operation and maintenance procedures applied under this section are continued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d3821-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s166"},"text":"Pub. L. 102–486, title I, § 166","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2861"},"text":"106 Stat. 2861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d3822-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d3823-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d3824-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
