{"tag":"section","attrib":{"id":"idbfe9463a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910"},"text":null,"children":[{"tag":"num","attrib":{"value":"15910"},"text":"§ 15910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced oil and natural gas production through carbon dioxide injection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe9463b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production incentive","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe9463c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9463d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Approximately two-thirds of the original oil in place in the United States remains unproduced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9463e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhanced oil and natural gas production from the sequestering of carbon dioxide and other appropriate gases has the potential to increase oil and natural gas production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9463f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capturing and productively using carbon dioxide would help reduce the carbon intensity of the economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the capturing, transportation, and injection of produced carbon dioxide, natural carbon dioxide, and other appropriate gases or other matter for sequestration into oil and gas fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote oil and natural gas production from the outer Continental Shelf and onshore Federal lands under lease by providing royalty incentives to use enhanced recovery techniques using injection of the substances referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of royalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe94644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that reduction of the royalty under a Federal oil and gas lease that is an eligible lease is in the public interest and promotes the purposes of this section, the Secretary shall undertake a rulemaking to provide for such reduction for an eligible lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemakings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish the advanced notice of proposed rulemaking within 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and complete the rulemaking implementing this section within 365 days after "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94646-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible leases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lease shall be an eligible lease for purposes of this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94647-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a lease for production of oil and gas from the outer Continental Shelf or Federal onshore lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94648-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the injection of the substances referred to in subsection (a)(2)(A) will be used as an enhanced recovery technique on such lease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94649-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the lease contains oil or gas that would not likely be produced without the royalty reduction provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9464a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rulemaking shall provide for a suspension volume, which shall not exceed 5,000,000 barrels of oil equivalent for each eligible lease. Such suspension volume shall be applied to any production from an eligible lease occurring on or after the date of publication of any advanced notice of proposed rulemaking under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9464b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may place limitations on the royalty reduction granted under this section based on market price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9464c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to any eligible lease issued before, on, or after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe9464d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe9464e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9464f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall establish a competitive grant program to provide grants to producers of oil and gas to carry out projects to inject carbon dioxide for the purpose of enhancing recovery of oil or natural gas while increasing the sequestration of carbon dioxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94650-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The demonstration program shall provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe94651-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 projects in the Willistin Basin in North Dakota and Montana; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94652-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 project in the Cook Inlet Basin in Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94653-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94654-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall issue requirements relating to applications for grants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94655-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuance of requirements under subparagraph (A) shall not require a rulemaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94656-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the Secretary shall require under subparagraph (A) that an application for a grant include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe94657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project proposed in the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the production increase and the duration of the production increase from the project, as compared to conventional recovery techniques, including water flooding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the carbon dioxide sequestered by project, over the life of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9465a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to collect and disseminate data relating to each project to be funded by the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9465b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the means by which the project will be sustainable without Federal assistance after the completion of the term of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9465c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete description of the costs of the project, including acquisition, construction, operation, and maintenance costs over the expected life of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9465d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which costs of the project will be supported by Federal assistance under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9465e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/2/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any secondary or tertiary recovery efforts in the field and the efficacy of water flood recovery techniques used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9465f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant for a grant under paragraph (1) may carry out a project under a pilot program in partnership with 1 or more other public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications under this subsection, the Secretary of Energy shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the previous experience with similar projects of each applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority consideration to applications that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe94663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to maximize production of oil and gas in a cost-effective manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sequester significant quantities of carbon dioxide from anthropogenic sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest commitment on the part of the applicant to ensure funding for the proposed project and the greatest likelihood that the project will be maintained or expanded after Federal assistance under this section is completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe94666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize any adverse environmental effects from the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe94667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe94668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall not provide more than $3,000,000 in Federal assistance under this subsection to any applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall require cost-sharing under this subsection in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe9466a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of grants","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfe9466b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project funded by a grant under this subsection shall begin construction not later than 2 years after the date of provision of the grant, but in any case not later than ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfe9466c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide grant funds to any applicant under this subsection for a period of more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9466d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of information and knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall establish mechanisms to ensure that the information and knowledge gained by participants in the program under this subsection are transferred among other participants and interested persons, including other applicants that submitted applications for a grant under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe9466e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe9466f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of Energy shall publish in the Federal Register, and elsewhere, as appropriate, a request for applications to carry out projects under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date for applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be submitted not later than 180 days after the date of publication of the request under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe94671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date by which applications for grants are required to be submitted under subparagraph (B), the Secretary of Energy, in a timely manner, shall select, after peer review and based on the criteria under paragraph (4), those projects to be awarded a grant under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Interior, acting through the Bureau of Land Management, shall maintain records on, and an inventory of, the quantity of carbon dioxide stored within Federal mineral leaseholds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe94673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe94674-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s354"},"text":"Pub. L. 109–58, title III, § 354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/715"},"text":"119 Stat. 715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVII/s713"},"text":"Pub. L. 110–140, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1715"},"text":"121 Stat. 1715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfe94675-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfe94676-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfe94677-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfe94678-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfe94679-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
