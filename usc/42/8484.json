{"tag":"section","attrib":{"id":"idbe991f6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484"},"text":null,"children":[{"tag":"num","attrib":{"value":"8484"},"text":"§ 8484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric utility conservation plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe991f6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An electric utility is subject to this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn003841"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003841"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utility owns or operates any existing electric powerplant in which natural gas was used as a primary energy source at any time during the 1-year period ending on ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utility plans to use natural gas as a primary energy source in any electric powerplant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe991f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and approval of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require each electric utility subject to this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit, within 1 year after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", and have approved by the Secretary, a conservation plan which meets the requirements of subsection (c); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement such plan during the 5-year period beginning on the date of the initial approval of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe991f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any conservation plan under this section shall set forth means determined by the utility to achieve conservation of electric energy not later than the 5th year after its initial approval at a level, measured on an annual basis, at least equal to 10 percent of the electric energy output of that utility during the most recent 4 calendar quarters ending prior to ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"August 13, 1981","children":[],"tail":", which is attributable to natural gas."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The conservation plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe991f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities required for such utility by part 1 of title II of the National Energy Conservation Policy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8211"},"text":"42 U.S.C. 8211","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an effective public information program for conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other measures as the utility may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such plan may set forth a program for the use of renewable energy sources (other than hydroelectric power).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such plan shall contain procedures to permit the amounts expended by such utility in developing and implementing the plan to be recovered in a manner specified by the appropriate State regulatory authority (or by the utility in the case of a nonregulated utility).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe991f79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, by order, approve or disapprove any conservation plan proposed under this subsection ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" by an electric utility within 120 days after its submission. The Secretary shall approve any such proposed plan unless the Secretary finds that such plan does not meet the requirements of subsection (c) and states in writing the reasons therefor."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event the Secretary disapproves under paragraph (1) the plan originally submitted, the Secretary shall provide a reasonable period of time for resubmission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8484/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An electric utility may amend any approved plan, except that the plan as amended shall be subject to approval in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe991f7d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVIII/s808"},"text":"Pub. L. 95–620, title VIII, § 808","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tX/s1023/a"},"text":"Pub. L. 97–35, title X, § 1023(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/616"},"text":"95 Stat. 616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe991f7e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe991f7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe991f80-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Energy Conservation Policy Act, referred to in subsec. (c)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3208"},"text":"92 Stat. 3208","children":[],"tail":". Part 1 of title II of the National Energy Conservation Policy Act was classified generally to part A (§ 8211 et seq.) of subchapter II of chapter 91 of this title, and was omitted from the Code pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8229"},"text":"section 8229 of this title","children":[],"tail":" which terminated authority under that part "},{"tag":"date","attrib":{"date":"1989-06-30"},"text":"June 30, 1989","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8201"},"text":"section 8201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe991f81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe991f82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1038"},"text":"section 1038 of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6240"},"text":"section 6240 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
