{"tag":"section","attrib":{"id":"idbcc83011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4363"},"text":null,"children":[{"tag":"num","attrib":{"value":"4363"},"text":"§ 4363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing and long-term environmental research and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall establish a separately identified program of continuing, long-term environmental research and development for each activity listed in section 2(a) of this Act. Unless otherwise specified by law, at least 15 per centum of funds appropriated to the Administrator for environmental research and development for each activity listed in section 2(a) of this Act shall be obligated and expended for such long-term environmental research and development under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcc83012-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/569/s2/f"},"text":"Pub. L. 96–569, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3337"},"text":"94 Stat. 3337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc83013-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc83014-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcc83015-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2(a) of this Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/569/s2/a"},"text":"section 2(a) of Pub. L. 96–569","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3335"},"text":"94 Stat. 3335","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcc83016-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1981, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbcc83017-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior authorization acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/229/s2/e"},"text":"Pub. L. 96–229, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-04-07"},"text":"Apr. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/327"},"text":"94 Stat. 327","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/155/s6"},"text":"Pub. L. 95–155, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-08"},"text":"Nov. 8, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1259"},"text":"91 Stat. 1259","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
