{"tag":"section","attrib":{"id":"idbb32c28b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1542"},"text":null,"children":[{"tag":"num","attrib":{"value":"1542"},"text":"§ 1542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds from other Federal agencies to Secretary of Housing and Urban Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where any Federal agency has funds for the provision of housing in connection with national-defense activities it may, in its discretion, make transfers of those funds, in whole or in part, to the Secretary of Housing and Urban Development, and the funds so transferred shall be available for, but only for, any or all of the objects and purposes of and in accordance with all the authority and limitations contained in subchapters II to VII of this chapter, and for administrative expenses in connection therewith.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb32c28c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title III, § 302, formerly § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1127"},"text":"54 Stat. 1127","children":[],"tail":"; renumbered title III, § 302, "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-28/ch260/s4/b"},"text":"June 28, 1941, ch. 260, § 4(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/363"},"text":"55 Stat. 363","children":[],"tail":"; amended Ex. Ord. No. 9070, § 1, eff. "},{"tag":"date","attrib":{"date":"1942-02-24"},"text":"Feb. 24, 1942","children":[],"tail":", 7 F.R. 1529; "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/64/73"},"text":"64 Stat. 73","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb32c28d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb32c28e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb32c28f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters III and VI of this chapter, referred to in text, were comprised of sections 1531 to 1536 and 1571 to 1576, respectively, of this title and have been omitted from the Code. For further details, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb32c290-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"Apr. 20, 1950","children":[],"tail":", substituted “Housing and Home Finance Administrator” for “National Housing Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb32c291-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb32c292-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbb32c293-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb32c294-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Federal Works Administrator relating to defense housing consolidated with other agencies into National Housing Agency during World War II by Ex. Ord. No. 9070.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
