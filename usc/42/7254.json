{"tag":"section","attrib":{"id":"idbdfba6a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7254"},"text":null,"children":[{"tag":"num","attrib":{"value":"7254"},"text":"§ 7254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to prescribe such procedural and administrative rules and regulations as he may deem necessary or appropriate to administer and manage the functions now or hereafter vested in him.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdfba6a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVI/s644"},"text":"Pub. L. 95–91, title VI, § 644","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/599"},"text":"91 Stat. 599","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
