{"tag":"section","attrib":{"id":"idbaaace10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397h"},"text":"§ 1397h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for early detection of certain medical conditions related to environmental health hazards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaaace11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program in accordance with this section to make competitive grants to eligible entities specified in subsection (b) for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening at-risk individuals (as defined in subsection (c)(1)) for environmental health conditions (as defined in subsection (c)(3)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing and disseminating public information and education concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of screening under the program under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection, prevention, and treatment of environmental health conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of Medicare benefits for certain individuals diagnosed with environmental health conditions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395rr–1"},"text":"section 1395rr–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an eligible entity is an entity described in paragraph (2) which submits an application to the Secretary in such form and manner, and containing such information and assurances, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entities described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A hospital or community health center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federally qualified health center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A facility of the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A National Cancer Institute-designated cancer center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency of any State or local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other entity the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" At-risk individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “at-risk individual” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as demonstrated in such manner as the Secretary determines appropriate, has been present for an aggregate total of 6 months in the geographic area subject to an emergency declaration specified under paragraph (2), during a period ending—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbaaace25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 years prior to the date of such individual’s application under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaaace26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the implementation of all the remedial and removal actions specified in the Record of Decision for Operating Unit 4 and the Record of Decision for Operating Unit 7; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary determines appropriate considering the type of environmental health condition at issue; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has submitted an application (or has an application submitted on the individual’s behalf), to an eligible entity receiving a grant under this section, for screening under the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency declaration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emergency declaration” means a declaration of a public health emergency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9604/a"},"text":"section 9604(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental health condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “environmental health condition” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" asbestosis, pleural thickening, or pleural plaques, as established by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretation by a “B Reader” qualified physician of a plain chest x-ray or interpretation of a computed tomographic radiograph of the chest by a qualified physician, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other diagnostic standards as the Secretary specifies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" mesothelioma, or malignancies of the lung, colon, rectum, larynx, stomach, esophagus, pharynx, or ovary, as established by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pathologic examination of biopsy tissue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cytology from bronchioalveolar lavage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other diagnostic standards as the Secretary specifies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other medical condition which the Secretary determines is caused by exposure to a hazardous substance or pollutant or contaminant at a Superfund site to which an emergency declaration applies, based on such criteria and as established by such diagnostic standards as the Secretary specifies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous substance; pollutant; contaminant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “hazardous substance”, “pollutant”, and “contaminant” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superfund site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Superfund site” means a site included on the National Priorities List developed by the President in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9605/a/8/B"},"text":"section 9605(a)(8)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health coverage unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect any coverage obligation of a governmental or private health plan or program relating to an at-risk individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, there are appropriated to the Secretary, to carry out the program under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $23,000,000 for the period of fiscal years 2010 through 2014; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each 5-fiscal year period thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the preceding sections of this subchapter shall not apply to grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397h/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397d/a"},"text":"Section 1397d(a) of this title","children":[],"tail":" shall apply to a grant awarded under this section to the same extent and in the same manner as such section applies to payments to States under this subchapter, except that paragraph (4) of such section shall not be construed to prohibit grantees from conducting screening for environmental health conditions as authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaace3e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2009, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10323/b"},"text":"Pub. L. 111–148, title X, § 10323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/957"},"text":"124 Stat. 957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaaace3f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaaace40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbaaace41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10323/b"},"text":"Pub. L. 111–148, title X, § 10323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/957"},"text":"124 Stat. 957","children":[],"tail":", which directed amendment of title XX of act "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", by adding this section at the end, was executed by adding this section at the end of subtitle A of title XX of that Act, which is this division, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
