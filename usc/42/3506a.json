{"tag":"section","attrib":{"id":"idbc82e9e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506a"},"text":"§ 3506a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific engagement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc82e9e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Scientific meetings that are attended by scientific or medical personnel, or other professionals, of the Department of Health and Human Services for whom attendance at such meeting is directly related to their professional duties and the mission of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc82e9e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered conferences for the purposes of complying with Federal reporting requirements contained in annual appropriations Acts or in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered conferences for purposes of a restriction contained in an annual appropriations Act, based on Office of Management and Budget Memorandum M-12-12 or any other regulation restricting travel to such meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc82e9e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to exempt travel for scientific meetings from Federal regulations relating to travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc82e9e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of the fiscal year, each operating division of the Department of Health and Human Services shall prepare, and post on an Internet website of the operating division, an annual report on scientific meeting attendance and related travel spending for each fiscal year. Such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc82e9e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general information concerning the scientific meeting activities involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information concerning the total amount expended for such meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of all such meetings that were attended by scientific or medical personnel, or other professionals, of each such operating division where the total amount expended by the operating division associated with each such meeting were in excess of $30,000, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc82e9eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of meeting expenses incurred by the operating division for such meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc82e9ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of such meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc82e9ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of such meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc82e9ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief explanation on how such meeting advanced the mission of the operating division; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc82e9ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals whose travel expenses or other scientific meeting expenses were paid by the operating division; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc82e9f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3506a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any such meeting where the total expenses to the operating division exceeded $150,000, a description of the exceptional circumstances that necessitated the expenditure of such amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc82e9f1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3074"},"text":"Pub. L. 114–255, div. A, title III, § 3074","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1137"},"text":"130 Stat. 1137","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
