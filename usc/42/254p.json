{"tag":"section","attrib":{"id":"idb4fc55c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p"},"text":null,"children":[{"tag":"num","attrib":{"value":"254p"},"text":"§ 254p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special loans for former Corps members to enter private practice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fc55c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entitled; conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, out of appropriations authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254k"},"text":"section 254k of this title","children":[],"tail":", make one loan to a Corps member who has agreed in writing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to engage in the private full-time clinical practice of the profession of the member in a health professional shortage area (designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254e"},"text":"section 254e of this title","children":[],"tail":") for a period of not less than 2 years which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc55c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Corps member who is required to complete a period of obligated service under this subpart, begins not later than 1 year after the date on which such individual completes such period of obligated service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc55c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who is not required to complete a period of obligated service under this subpart, begins at such time as the Secretary considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct such practice in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254n/b/1"},"text":"section 254n(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to such additional conditions as the Secretary may require to carry out this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such a loan shall be used to assist such individual in meeting the costs of beginning the practice of such individual’s profession in accordance with such agreement, including the costs of acquiring equipment and renovating facilities for use in providing health services, and of hiring nurses and other personnel to assist in providing health services. Such loan may not be used for the purchase or construction of any building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of loan; maximum interest rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a loan under subsection (a) to an individual shall not exceed $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest rate for any such loan shall not exceed an annual rate of 5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for loan; submission and approval; interest rates and repayment terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a loan under this section unless an application therefor has been submitted to, and approved by, the Secretary. The Secretary shall, by regulation, set interest rates and repayment terms for loans under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc55cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of agreement; notice; determination of liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that an individual has breached a written agreement entered into under subsection (a), he shall, as soon as practicable after making such determination, notify the individual of such determination. If within 60 days after the date of giving such notice, such individual is not practicing his profession in accordance with the agreement under such subsection and has not provided assurances satisfactory to the Secretary that he will not knowingly violate such agreement again, the United States shall be entitled to recover from such individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc55cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who has received a grant under this section (as in effect prior to ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"), an amount determined under section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title, except that in applying the formula contained in such section “ϕ” shall be the sum of the amount of the grant made under subsection (a) to such individual and the interest on such amount which would be payable if at the time it was paid it was a loan bearing interest at the maximum legal prevailing rate, “t” shall be the number of months that such individual agreed to practice his profession under such agreement, and “s” shall be the number of months that such individual practices his profession in accordance with such agreement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc55ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254p/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who has received a loan under this section, the full amount of the principal and interest owed by such individual under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fc55cf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338G, formerly title VII, § 755, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s408/b/1"},"text":"Pub. L. 94–484, title IV, § 408(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2287"},"text":"90 Stat. 2287","children":[],"tail":"; renumbered § 338E and amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2709/a"},"text":"Pub. L. 97–35, title XXVII, § 2709(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/908"},"text":"95 Stat. 908","children":[],"tail":", 911; "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s8/g/3"},"text":"Pub. L. 97–414, § 8(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2061"},"text":"96 Stat. 2061","children":[],"tail":"; renumbered § 338F and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tII/s201/2"},"text":"Pub. L. 100–177, title II, § 201(2)","children":[],"tail":", title III, § 309, "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/992"},"text":"101 Stat. 992","children":[],"tail":", 1006; renumbered § 338G and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tII/s204"},"text":"Pub. L. 101–597, title II, § 204","children":[],"tail":", title IV, § 401(b)[(a)], "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3027"},"text":"104 Stat. 3027","children":[],"tail":", 3035.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fc55d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fc55d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4fc55d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294x"},"text":"section 294x of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4fc55d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 338G of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 338H by "},{"tag":"ref","attrib":{"href":"/us/pl/101/597"},"text":"Pub. L. 101–597","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254q"},"text":"section 254q of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 338G of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 338I by "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/s201/1"},"text":"section 201(1) of Pub. L. 100–177","children":[],"tail":" and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254r"},"text":"section 254r of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tI/s104/b/1"},"text":"Pub. L. 100–713, title I, § 104(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4787"},"text":"102 Stat. 4787","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 338G of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254q"},"text":"section 254q of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/177/tII/s203"},"text":"Pub. L. 100–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-01"},"text":"Dec. 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/999"},"text":"101 Stat. 999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4fc55d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/597/s401/b"},"text":"Pub. L. 101–597, § 401(b)[(a)]","children":[],"tail":", substituted reference to health professional shortage area for reference to health manpower shortage area."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s309/1"},"text":"Pub. L. 100–177, § 309(1)","children":[],"tail":", substituted subsec. (a) consisting of pars. (1) to (3) for former subsec. (a) consisting of pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s309/1"},"text":"Pub. L. 100–177, § 309(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “The amount of the grant or loan under subsection (a) of this section to an individual shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $12,500 if the individual agrees to practice his profession in accordance with the agreement for a period of at least one year, but less than two years; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $25,000 if the individual agrees to practice his profession in accordance with the agreement for a period of at least two years.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s309/2"},"text":"Pub. L. 100–177, § 309(2)","children":[],"tail":", struck out “grant or” before “loan” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/177/s309/3"},"text":"Pub. L. 100–177, § 309(3)","children":[],"tail":", substituted “under this section (as in effect prior to "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":")” for “under this section”, and made technical amendment to reference to section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b) of this title to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":" substituted “section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)” for “section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2709/f/2"},"text":"Pub. L. 97–35, § 2709(f)(2)","children":[],"tail":"–(4), made numerous changes to reflect renumbering of subpart sections, among them inserting references to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254k"},"text":"section 254k of this title","children":[],"tail":" and striking out references to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294v"},"text":"section 294v of this title","children":[],"tail":", and added applicability to loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2709/f/5"},"text":"Pub. L. 97–35, § 2709(f)(5)","children":[],"tail":", inserted applicability to loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2709/f/6"},"text":"Pub. L. 97–35, § 2709(f)(6)","children":[],"tail":", inserted provisions relating to loans and interest rates, etc."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s2709/f/7"},"text":"Pub. L. 97–35, § 2709(f)(7)","children":[],"tail":", restructured and revised criteria determining amount of liability of individual within 60 days after the date of notice instead of within 120 days after the date of notice."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4fc55d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb4fc55d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/s408/b/1"},"text":"section 408(b)(1) of Pub. L. 94–484","children":[],"tail":", set out in part as a note under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb4fc55d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Savings Provision; Credit for Period of Internship or Residency Before ","children":[{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", Towards Service Obligation"}],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/484/s408/b/2"},"text":"section 408(b)(2) of Pub. L. 94–484","children":[],"tail":", set out as a note under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
