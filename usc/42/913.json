{"tag":"section","attrib":{"id":"idb8059eac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s913"},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"§ 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall perform the duties imposed upon the Secretary by this chapter. The Secretary is authorized to appoint and fix the compensation of such officers and employees, and to make such expenditures as may be necessary for carrying out the functions of the Secretary under this chapter. The Secretary may appoint attorneys and experts without regard to the civil service laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8059ead-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VII, § 712, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/a/1"},"text":"Pub. L. 103–296, title I, § 108(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1481"},"text":"108 Stat. 1481","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
