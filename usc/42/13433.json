{"tag":"section","attrib":{"id":"idbfc0d713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433"},"text":null,"children":[{"tag":"num","attrib":{"value":"13433"},"text":"§ 13433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fuel vehicle program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program, in accordance with sections 13541 and 13542 of this title, on techniques related to improving natural gas and other alternative fuel vehicle technology, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel injection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carburetion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manifolding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combustion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power optimization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lubricants and detergents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engine durability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ignition, including fuel additives to assist ignition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multifuel engines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emissions control, including catalysts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" novel gas compression concepts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced storage systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced gaseous fueling technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of advanced materials in these areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements and assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with, and provide financial assistance to, public or private entities willing to provide 50 percent of the costs of a program to perform activities under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “alternative fuel vehicle” means a motor vehicle that operates on alternative fuels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13433/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “motor vehicle” includes any automobile, truck, bus, van, or other on-road or off-road motor vehicle, including a boat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d728-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2023"},"text":"Pub. L. 102–486, title XX, § 2023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3062"},"text":"106 Stat. 3062","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
