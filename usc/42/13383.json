{"tag":"section","attrib":{"id":"idbfbe65ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13383"},"text":null,"children":[{"tag":"num","attrib":{"value":"13383"},"text":"§ 13383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Climate Protection","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 6 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall establish, within the Department of Energy, a Director of Climate Protection (in this section referred to as the “Director”). The Director shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbe65ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13383/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of the Secretary, serve as the Secretary’s representative for interagency and multilateral policy discussions of global climate change, including the activities of the Committee on Earth and Environmental Sciences as established by the Global Change Research Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606"},"text":"Public Law 101–606","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2921"},"text":"15 U.S.C. 2921","children":[],"tail":" et seq.] and the Policy Coordinating Committee Working Group on Climate Change;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe65ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13383/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor, in cooperation with other Federal agencies, domestic and international policies for their effects on the generation of greenhouse gases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe65ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13383/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the authority to participate in the planning activities of relevant Department of Energy programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbe65f0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXVI/s1603"},"text":"Pub. L. 102–486, title XVI, § 1603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3001"},"text":"106 Stat. 3001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfbe65f1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfbe65f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfbe65f3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Global Change Research Act of 1990, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606"},"text":"Pub. L. 101–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3096"},"text":"104 Stat. 3096","children":[],"tail":", which is classified generally to chapter 56A (§ 2921 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2921"},"text":"section 2921 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
