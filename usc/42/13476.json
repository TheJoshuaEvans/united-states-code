{"tag":"section","attrib":{"id":"idbfc32139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13476"},"text":null,"children":[{"tag":"num","attrib":{"value":"13476"},"text":"§ 13476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental restoration and waste management program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3213a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13476/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for fiscal year 1993 $70,000,000 for the Fast Flux Test Facility to maintain the operational status of the reactor, such sums to be derived from amounts appropriated to the Secretary for the environmental restoration and waste management program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3213b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13476/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term missions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall aggressively pursue the development and implementation of long-term missions for the Fast Flux Test Facility. Within 6 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall submit to the Congress a report on the progress made in carrying out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc3213c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2116"},"text":"Pub. L. 102–486, title XXI, § 2116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3075"},"text":"106 Stat. 3075","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
