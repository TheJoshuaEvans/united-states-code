{"tag":"section","attrib":{"id":"idbbd284a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000gg–3"},"text":"§ 2000gg–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbd284a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EEOC rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Commission shall issue regulations in an accessible format in accordance with subchapter II of chapter 5 of title 5 to carry out this chapter. Such regulations shall provide examples of reasonable accommodations addressing known limitations related to pregnancy, childbirth, or related medical conditions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbd284a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OCWR rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbd284aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the Commission issues regulations under subsection (a), the Board (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of title 2","children":[],"tail":") shall (in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1384"},"text":"section 1384 of title 2","children":[],"tail":"), issue regulations to implement the provisions of this chapter made applicable to employees described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000gg/3/B"},"text":"section 2000gg(3)(B) of this title","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000gg–2/b"},"text":"section 2000gg–2(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbd284ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000gg–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parallel with agency regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations issued by the Commission under subsection (a) except to the extent that the Board may determine, for good cause shown and stated together with the regulations issued under paragraph (1) that a modification of such substantive regulations would be more effective for the implementation of the rights and protection under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbd284ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s105"},"text":"Pub. L. 117–328, div. II, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6088"},"text":"136 Stat. 6088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbd284ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbd284ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbbd284af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dII/s109"},"text":"section 109 of div. II of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000gg"},"text":"section 2000gg of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
