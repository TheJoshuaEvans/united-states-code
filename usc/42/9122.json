{"tag":"section","attrib":{"id":"idbeae7b8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122"},"text":null,"children":[{"tag":"num","attrib":{"value":"9122"},"text":"§ 9122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and public access to information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeae7b90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each licensee shall establish and maintain such records, make such reports, and provide such information as the Administrator, after consultation with other interested Federal departments and agencies, shall by regulation prescribe to carry out the provisions of this chapter. Each licensee shall submit such reports and shall make available such records and information as the Administrator may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeae7b91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any information reported to or collected by the Administrator under this chapter which is exempt from disclosure pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" (relating to trade secrets and commercial or financial information which is privileged or confidential) shall not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbeae7b92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be publicly disclosed by the Administrator or by any other officer or employee of the United States, unless the Administrator has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeae7b93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined that the disclosure is necessary to protect the public health or safety or the environment against an unreasonable risk of injury, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeae7b94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notified the person who submitted the information 10 days before the disclosure is to be made, unless the delay resulting from such notice would be detrimental to the public health or safety or the environment, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbeae7b95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be otherwise disclosed except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbeae7b96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbeae7b97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to other Federal and adjacent coastal State government departments and agencies for official use,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeae7b98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any committee of the Congress of appropriate jurisdiction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbeae7b99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to court order, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbeae7b9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the Administrator has taken appropriate steps to inform the recipient of the confidential nature of the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeae7b9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/tI/s112"},"text":"Pub. L. 96–320, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/989"},"text":"94 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tVI/s602/e/3"},"text":"Pub. L. 98–623, title VI, § 602(e)(3)","children":[],"tail":", (18), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3412"},"text":"98 Stat. 3412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeae7b9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeae7b9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbeae7b9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320"},"text":"Pub. L. 96–320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/974"},"text":"94 Stat. 974","children":[],"tail":", known as the Ocean Thermal Energy Conversion Act of 1980, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9101"},"text":"section 9101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeae7b9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/s602/e/3"},"text":"Pub. L. 98–623, § 602(e)(3)","children":[],"tail":", substituted “(relating to trade secrets and commercial or financial information which is privileged or confidential)” for “(relating to trade secrets and confidential commercial and financial information)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/s602/e/18"},"text":"Pub. L. 98–623, § 602(e)(18)","children":[],"tail":", substituted “Administrator” for “administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
