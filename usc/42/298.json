{"tag":"section","attrib":{"id":"idb5fb9dc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298"},"text":null,"children":[{"tag":"num","attrib":{"value":"298"},"text":"§ 298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive geriatric education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5fb9dca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to eligible entities to develop and implement, in coordination with programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s294c"},"text":"section 294c of this title","children":[],"tail":", programs and initiatives to train and educate individuals in providing geriatric care for the elderly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9dcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under subsection (a) shall use funds under such grant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5fb9dcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to individuals who will provide geriatric care for the elderly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9dcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and disseminate curricula relating to the treatment of the health problems of elderly individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9dce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train faculty members in geriatrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9dcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide continuing education to individuals who provide geriatric care; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5fb9dd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish traineeships for individuals who are preparing for advanced education nursing degrees in geriatric nursing, long-term care, gero-psychiatric nursing or other nursing areas that specialize in the care of the elderly population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring a grant under subsection (a) shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9dd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible entity” includes a school of nursing, a health care facility, a program leading to certification as a certified nurse assistant, a partnership of such a school and facility, or a partnership of such a program and facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5fb9dd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s298/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5fb9dd4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VIII, § 865, formerly § 855, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/205/tII/s202/a"},"text":"Pub. L. 107–205, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-01"},"text":"Aug. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1