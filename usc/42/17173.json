{"tag":"section","attrib":{"id":"idc02c1bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173"},"text":null,"children":[{"tag":"num","attrib":{"value":"17173"},"text":"§ 17173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daylighting systems and direct solar light pipe technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of research and development to provide assistance in the demonstration and commercial application of direct solar renewable energy sources to provide alternatives to traditional power generation for lighting and illumination, including light pipe technology, and to promote greater energy conservation and improved efficiency. All direct solar renewable energy devices supported under this program shall have the capability to provide measurable data on the amount of kilowatt-hours saved over the traditionally powered light sources they have replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transmit to Congress an annual report assessing the measurable data derived from each project in the direct solar renewable energy sources program and the energy savings resulting from its use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1bc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “direct solar renewable energy” means energy from a device that converts sunlight into useable light within a building, tunnel, or other enclosed structure, replacing artificial light generated by a light fixture and doing so without the conversion of the sunlight into another form of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “light pipe” means a device designed to transport visible solar radiation from its collection point to the interior of a building while excluding interior heat gain in the nonheating season.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $3,500,000 for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1bc5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s605"},"text":"Pub. L. 110–140, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1676"},"text":"121 Stat. 1676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1bc6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1bc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1bc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
