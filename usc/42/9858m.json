{"tag":"section","attrib":{"id":"idbf01f247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858m"},"text":"§ 9858m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts reserved; allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf01f248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts reserved","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories and possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve not to exceed one half of 1 percent of the amount appropriated under this subchapter in each fiscal year for payments to Guam, American Samoa, the Virgin Islands of the United States, and the Commonwealth of the Northern Mariana Islands to be allotted in accordance with their respective needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f24a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indians ","children":[{"tag":"ref","attrib":{"idref":"fn003913"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003913"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Indian”."}],"tail":" tribes"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f24b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve not less than 2 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":" in each fiscal year for payments to Indian tribes and tribal organizations with applications approved under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f24c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary shall only reserve an amount that is greater than 2 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":", for payments described in subparagraph (A), for a fiscal year (referred to in this subparagraph as the “reservation year”) if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f24d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":" for the reservation year is greater than the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":" for fiscal year 2014; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f24e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary ensures that the amount allotted to States under subsection (b) for the reservation year is not less than the amount allotted to States under subsection (b) for fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f24f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National toll-free hotline and Web site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve up to $1,500,000 of the amount appropriated under this subchapter for each fiscal year for the operation of a national toll-free hotline and Web site, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858j/b"},"text":"section 9858j(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve up to ½ of 1 percent of the amount appropriated under this subchapter for each fiscal year to support technical assistance and dissemination activities under paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858g/a"},"text":"section 9858g(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, demonstration, and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reserve ½ of 1 percent of the amount appropriated under this subchapter for each fiscal year to conduct research and demonstration activities, as well as periodic external, independent evaluations of the impact of the program described by this subchapter on increasing access to child care services and improving the safety and quality of child care services, using scientifically valid research methodologies, and to disseminate the key findings of those evaluations widely and on a timely basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":" for each fiscal year remaining after reservations under subsection (a), the Secretary shall allot to each State an amount equal to the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 50 percent of such remainder as the product of the young child factor of the State and the allotment percentage of the State bears to the sum of the corresponding products for all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that bears the same ratio to 50 percent of such remainder as the product of the school lunch factor of the State and the allotment percentage of the State bears to the sum of the corresponding products for all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Young child factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “young child factor” means the ratio of the number of children in the State under 5 years of age to the number of such children in all States as provided by the most recent annual estimates of population in the States by the Census Bureau of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School lunch factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school lunch factor” means the ratio of the number of children in the State who are receiving free or reduced price lunches under the school lunch program established under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) to the number of such children in all the States as determined annually by the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allotment percentage for a State is determined by dividing the per capita income of all individuals in the United States, by the per capita income of all individuals in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f25a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an allotment percentage determined under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f25b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeds 1.2 percent, then the allotment percentage of that State shall be considered to be 1.2 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f25c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is less than 0.8 percent, then the allotment percentage of the State shall be considered to be 0.8 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f25d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per capita income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), per capita income shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f25e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined at 2-year intervals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f25f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied for the 2-year period beginning on October 1 of the first fiscal year beginning on the date such determination is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to the average of the annual per capita incomes for the most recent period of 3 consecutive years for which satisfactory data are available from the Department of Commerce at the time such determination is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for benefit of Indian children","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts reserved under subsection (a)(2), the Secretary may make grants to or enter into contracts with Indian tribes or tribal organizations that submit applications under this section, for the planning and carrying out of programs or activities consistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications and requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant or contract under this section shall provide that:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicant will coordinate, to the maximum extent feasible, with the lead agency in the State or States in which the applicant will carry out programs or activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services on reservations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an applicant located in a State other than Alaska, California, or Oklahoma, programs and activities under this section will be carried out on the Indian reservation for the benefit of Indian children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The applicant will make such reports on, and conduct such audits of, programs and activities under a grant or contract under this section as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing and standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of any licensing and regulatory requirements applicable under State or local law, the Secretary, in consultation with Indian tribes and tribal organizations, shall develop minimum child care standards that shall be applicable to Indian tribes and tribal organizations receiving assistance under this subchapter. Such standards shall appropriately reflect Indian tribe and tribal organization needs and available resources, and shall include standards requiring a publicly available application, health and safety standards, and standards requiring a reservation of funds for activities to improve the quality of child care services provided to Indian children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of secretarial approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to approve an application for a grant or contract under this section, the Secretary shall take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of child care services provided in accordance with this subchapter by the State or States in which the applicant proposes to carry out a program to provide child care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f26a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the applicant has the ability (including skills, personnel, resources, community support, and other necessary components) to satisfactorily carry out the proposed program or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f26b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three-year limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants or contracts under this section shall be for periods not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f26c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual eligibility of Indian children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The awarding of a grant or contract under this section for programs or activities to be conducted in a State or States shall not affect the eligibility of any Indian child to receive services provided or to participate in programs and activities carried out under a grant to the State or States under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f26d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction or renovation of facilities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f26e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe or tribal organization may submit to the Secretary a request to use amounts provided under this subsection for construction or renovation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f26f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a request submitted under subparagraph (A), and except as provided in subparagraph (C), upon a determination by the Secretary that adequate facilities are not otherwise available to an Indian tribe or tribal organization to enable such tribe or organization to carry out child care programs in accordance with this subchapter, and that the lack of such facilities will inhibit the operation of such programs in the future, the Secretary may permit the tribe or organization to use assistance provided under this subsection to make payments for the construction or renovation of facilities that will be used to carry out such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf01f271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), the Secretary may not permit an Indian tribe or tribal organization to use amounts provided under this subsection for construction or renovation if the use will result in a decrease in the level of child care services provided by the Indian tribe or tribal organization as compared to the level of child care services provided by the Indian tribe or tribal organization in the fiscal year preceding the year for which the determination under subparagraph (B) is being made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf01f272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive the limitation described in clause (i) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf01f273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the decrease in the level of child care services provided by the Indian tribe or tribal organization is temporary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf01f274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Indian tribe or tribal organization submits to the Secretary a plan that demonstrates that after the date on which the construction or renovation is completed—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbf01f275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of child care services will increase; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbf01f276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of child care services will improve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement uniform procedures for the solicitation and consideration of requests under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall obtain from each appropriate Federal agency, the most recent data and information necessary to determine the allotments provided for in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f27a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of the allotment under subsection (b) to a State that the Secretary determines is not required to carry out a State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/d"},"text":"section 9858c(d) of this title","children":[],"tail":", in the period for which the allotment is made available, shall be reallotted by the Secretary to other States in proportion to the original allotments to the other States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f27b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f27c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any reallotment to which a State is entitled to under paragraph (1) shall be reduced to the extent that it exceeds the amount that the Secretary estimates will be used in the State to carry out a State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858c/d"},"text":"section 9858c(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f27d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of such reduction shall be similarly reallotted among States for which no reduction in an allotment or reallotment is required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f27e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts reallotted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any other section of this subchapter, any amount reallotted to a State under this subsection shall be considered to be part of the allotment made under subsection (b) to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f27f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes or tribal organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of a grant or contract made to an Indian tribe or tribal organization under subsection (c) that the Secretary determines is not being used in a manner consistent with the provision of this subchapter in the period for which the grant or contract is made available, shall be allotted by the Secretary to other tribes or organizations that have submitted applications under subsection (c) in accordance with their respective needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “State” includes only the 50 States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf01f281-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658O"},"text":"Pub. L. 97–35, title VI, § 658O","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-246"},"text":"104 Stat. 1388–246","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s613"},"text":"Pub. L. 104–193, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2286"},"text":"110 Stat. 2286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5602/4"},"text":"Pub. L. 105–33, title V, § 5602(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/646"},"text":"111 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/17"},"text":"Pub. L. 106–78, title VII, § 752(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1170"},"text":"113 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s9"},"text":"Pub. L. 113–186, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1998"},"text":"128 Stat. 1998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf01f282-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf01f283-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf01f284-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf01f285-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s9/1/A"},"text":"Pub. L. 113–186, § 9(1)(A)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, substituted “2 percent” for “1 percent, and not more than 2 percent,”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s9/1/B"},"text":"Pub. L. 113–186, § 9(1)(B)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s9/2/A"},"text":"Pub. L. 113–186, § 9(2)(A)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s9/2/B"},"text":"Pub. L. 113–186, § 9(2)(B)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C). Prior to amendment, text read as follows: “The Secretary may not permit an Indian tribe or tribal organization to use amounts provided under this subsection for construction or renovation if such use will result in a decrease in the level of child care services provided by the tribe or organization as compared to the level of such services provided by the tribe or organization in the fiscal year preceding the year for which the determination under subparagraph (B) is being made.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" substituted “subparagraph (B)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s613/1/A"},"text":"Pub. L. 104–193, § 613(1)(A)","children":[],"tail":", made technical amendment to heading, inserted “and” before “the Commonwealth of the Northern Marianna Islands”, and struck out “, and the Trust Territory of the Pacific Islands” before “to be allotted in accordance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s613/1/B"},"text":"Pub. L. 104–193, § 613(1)(B)","children":[],"tail":", substituted “less than 1 percent, and not more than 2 percent,” for “more than 3 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s613/2/A"},"text":"Pub. L. 104–193, § 613(2)(A)","children":[],"tail":", substituted “activities carried out” for “activities carried our”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s613/2/B"},"text":"Pub. L. 104–193, § 613(2)(B)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s613/3"},"text":"Pub. L. 104–193, § 613(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf01f286-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf01f287-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title VI of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5603"},"text":"section 5603 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s618"},"text":"section 618 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf01f288-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s615"},"text":"section 615 of Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
