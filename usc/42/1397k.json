{"tag":"section","attrib":{"id":"idbaad3e92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397k"},"text":"§ 1397k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elder Justice Coordinating Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3e93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Secretary an Elder Justice Coordinating Council (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3e94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3e95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (or the Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General (or the Attorney General’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each Federal department or agency or other governmental entity identified by the Chair referred to in subsection (d) as having responsibilities, or administering programs, relating to elder abuse, neglect, and exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3e99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council shall be an officer or employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Council shall not affect its powers, but shall be filled in the same manner as the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3e9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The member described in subsection (b)(1)(A) shall be Chair of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3e9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at least 2 times per year, as determined by the Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3e9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3e9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall make recommendations to the Secretary for the coordination of activities of the Department of Health and Human Services, the Department of Justice, and other relevant Federal, State, local, and private agencies and entities, relating to elder abuse, neglect, and exploitation and other crimes against elders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3e9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and every 2 years thereafter, the Council shall submit to the Committee on Finance of the Senate and the Committee on Ways and Means and the Committee on Energy and Commerce of the House of Representatives a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3ea0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes the activities and accomplishments of, and challenges faced by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaad3ea1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3ea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entities represented on the Council; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes such recommendations for legislation, model laws, or other action as the Council determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3ea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397j–1/a"},"text":"section 1397j–1(a) of this title","children":[],"tail":", the Council may secure directly from any Federal department or agency such information as the Council considers necessary to carry out this section. Upon request of the Chair of the Council, the head of such department or agency shall furnish such information to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may use the United States mails in the same manner and under the same conditions as other departments and agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Council shall not receive compensation for the performance of services for the Council. The members shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Council. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary may accept the voluntary and uncompensated services of the members of the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee may be detailed to the Council without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as permanent Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3eab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2021, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/786"},"text":"124 Stat. 786","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/256"},"text":"Pub. L. 117–286, § 4(a)(256)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4334"},"text":"136 Stat. 4334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaad3eac-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaad3ead-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaad3eae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
