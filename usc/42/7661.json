{"tag":"section","attrib":{"id":"idbe64a1e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661"},"text":null,"children":[{"tag":"num","attrib":{"value":"7661"},"text":"§ 7661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe64a1e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affected source” shall have the meaning given such term in subchapter IV–A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe64a1e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major source","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major source” means any stationary source (or any group of stationary sources located within a contiguous area and under common control) that is either of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe64a1e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A major source as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7412"},"text":"section 7412 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe64a1e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A major stationary source as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7602"},"text":"section 7602 of this title","children":[],"tail":" or part D of subchapter I."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe64a1e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “schedule of compliance” means a schedule of remedial measures, including an enforceable sequence of actions or operations, leading to compliance with an applicable implementation plan, emission standard, emission limitation, or emission prohibition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe64a1e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “permitting authority” means the Administrator or the air pollution control agency authorized by the Administrator to carry out a permit program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe64a1e9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title V, § 501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tV/s501"},"text":"Pub. L. 101–549, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2635"},"text":"104 Stat. 2635","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
