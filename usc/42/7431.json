{"tag":"section","attrib":{"id":"idbe3023c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7431"},"text":null,"children":[{"tag":"num","attrib":{"value":"7431"},"text":"§ 7431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land use authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter constitutes an infringement on the existing authority of counties and cities to plan or control land use, and nothing in this chapter provides or transfers authority over such land use.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe3023c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 131, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVIII/s805"},"text":"Pub. L. 101–549, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2689"},"text":"104 Stat. 2689","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
