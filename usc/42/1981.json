{"tag":"section","attrib":{"id":"idbbaea9c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1981"},"text":null,"children":[{"tag":"num","attrib":{"value":"1981"},"text":"§ 1981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equal rights under the law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbaea9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of equal rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All persons within the jurisdiction of the United States shall have the same right in every State and Territory to make and enforce contracts, to sue, be parties, give evidence, and to the full and equal benefit of all laws and proceedings for the security of persons and property as is enjoyed by white citizens, and shall be subject to like punishment, pains, penalties, taxes, licenses, and exactions of every kind, and to no other.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Make and enforce contracts” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “make and enforce contracts” includes the making, performance, modification, and termination of contracts, and the enjoyment of all benefits, privileges, terms, and conditions of the contractual relationship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbaea9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against impairment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights protected by this section are protected against impairment by nongovernmental discrimination and impairment under color of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbaea9cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(R.S. § 1977; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s101"},"text":"Pub. L. 102–166, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1071"},"text":"105 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbaea9ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbaea9cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbaea9d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1977 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1870-05-31/ch114/s16"},"text":"act May 31, 1870, ch. 114, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/144"},"text":"16 Stat. 144","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s41"},"text":"section 41 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbaea9d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbaea9d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbbaea9d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tIV/s402"},"text":"Pub. L. 102–166, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1099"},"text":"105 Stat. 1099","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/tIV/s402"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically provided, this Act [see Short Title of 1991 Amendment note below] and the amendments made by this Act shall take effect upon enactment [","children":[{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Disparate Impact Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this Act, nothing in this Act shall apply to any disparate impact case for which a complaint was filed before ","children":[{"tag":"date","attrib":{"date":"1975-03-01"},"text":"March 1, 1975","children":[],"tail":", and for which an initial decision was rendered after "},{"tag":"date","attrib":{"date":"1983-10-30"},"text":"October 30, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbbaea9d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s1"},"text":"Pub. L. 102–166, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1071"},"text":"105 Stat. 1071","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981a"},"text":"section 1981a of this title","children":[],"tail":" and sections 60"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 1201 to 1224 of Title 2, The Congress, amending this section and sections 1988, 2000e, 2000e–1, 2000e–2, 2000e–4, 2000e–5, 2000e–16, 12111, 12112, and 12209 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s626"},"text":"section 626 of Title 29","children":[],"tail":", Labor, and enacting provisions set out as notes under this section and sections 2000e and 2000e–4 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–5"},"text":"section 1a–5 of Title 16","children":[],"tail":", Conservation] may be cited as the ‘Civil Rights Act of 1991’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbbaea9d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/559"},"text":"Pub. L. 94–559","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1988"},"text":"section 1988 of this title","children":[],"tail":", is known as “The Civil Rights Attorney’s Fees Awards Act of 1976”, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1988"},"text":"section 1988 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idbbaea9d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tIV/s401"},"text":"Pub. L. 102–166, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1099"},"text":"105 Stat. 1099","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/tIV/s401"},"text":"“If any provision of this Act [see Short Title of 1991 Amendment note above], or an amendment made by this Act, or the application of such provision to any person or circumstances is held to be invalid, the remainder of this Act and the amendments made by this Act, and the application of such provision to other persons and circumstances, shall not be affected.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbaea9d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s2"},"text":"Pub. L. 102–166, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1071"},"text":"105 Stat. 1071","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional remedies under Federal law are needed to deter unlawful harassment and intentional discrimination in the workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision of the Supreme Court in Wards Cove Packing Co. v. Atonio, 490 U.S. 642 (1989) has weakened the scope and effectiveness of Federal civil rights protections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislation is necessary to provide additional protections against unlawful discrimination in employment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbaea9d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s3"},"text":"Pub. L. 102–166, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1071"},"text":"105 Stat. 1071","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see Short Title of 1991 Amendment note above] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide appropriate remedies for intentional discrimination and unlawful harassment in the workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to codify the concepts of ‘business necessity’ and ‘job related’ enunciated by the Supreme Court in Griggs v. Duke Power Co., 401 U.S. 424 (1971), and in the other Supreme Court decisions prior to Wards Cove Packing Co. v. Atonio, 490 U.S. 642 (1989);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to confirm statutory authority and provide statutory guidelines for the adjudication of disparate impact suits under title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to recent decisions of the Supreme Court by expanding the scope of relevant civil rights statutes in order to provide adequate protection to victims of discrimination.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbaea9d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Legislative History for 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s105/b"},"text":"Pub. L. 102–166, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1075"},"text":"105 Stat. 1075","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/tI/s105/b"},"text":"“No statements other than the interpretive memorandum appearing at Vol. 137 Congressional Record S 15276 (daily ed. ","children":[{"tag":"date","attrib":{"date":"1991-10-25"},"text":"Oct. 25, 1991","children":[],"tail":") [Cong. Rec., vol. 137, pt. 19, p. 28680, "},{"tag":"date","attrib":{"date":"1991-10-25"},"text":"Oct. 25, 1991","children":[],"tail":"] shall be considered legislative history of, or relied upon in any way as legislative history in construing or applying, any provision of this Act [see Short Title of 1991 Amendment note above] that relates to Wards Cove—Business necessity/cumulation/alternative business practice.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbb119da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s116"},"text":"Pub. L. 102–166, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1079"},"text":"105 Stat. 1079","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/tI/s116"},"text":"“Nothing in the amendments made by this title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981a"},"text":"section 1981a of this title","children":[],"tail":" and amending this section, sections 1988, 2000e, 2000e–1, 2000e–2, 2000e–4, 2000e–5, 2000e–16, 12111, and 12112 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s626"},"text":"section 626 of Title 29","children":[],"tail":", Labor] shall be construed to affect court-ordered remedies, affirmative action, or conciliation agreements, that are in accordance with the law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbbb119db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alternative Means of Dispute Resolution","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/tI/s118"},"text":"Pub. L. 102–166, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1081"},"text":"105 Stat. 1081","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/166/tI/s118"},"text":"“Where appropriate and to the extent authorized by law, the use of alternative means of dispute resolution, including settlement negotiations, conciliation, facilitation, mediation, factfinding, minitrials, and arbitration, is encouraged to resolve disputes arising under the Acts or provisions of Federal law amended by this title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981a"},"text":"section 1981a of this title","children":[],"tail":" and amending this section, sections 1988, 2000e, 2000e–1, 2000e–2, 2000e–4, 2000e–5, 2000e–16, 12111, and 12112 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s626"},"text":"section 626 of Title 29","children":[],"tail":", Labor].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbbb119dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idbbb119dd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 13050","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13050, ","children":[{"tag":"date","attrib":{"date":"1997-06-13"},"text":"June 13, 1997","children":[],"tail":", 62 F.R. 32987, which established the President’s Advisory Board on Race, was revoked by Ex. Ord. No. 13138, § 3(e), "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", 64 F.R. 53880, formerly set out as a note under section 14 of the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
