{"tag":"section","attrib":{"id":"idbffc59cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16252"},"text":null,"children":[{"tag":"num","attrib":{"value":"16252"},"text":"§ 16252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16252/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Architect of the Capitol shall establish in the Capitol Complex a program of public education regarding use by the Architect of the Capitol of biobased products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16252/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16252/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the Capitol Complex as a showcase for the existence and benefits of biobased products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16252/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide access to further information on biobased products to occupants and visitors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffc59d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s943/c"},"text":"Pub. L. 109–58, title IX, § 943(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/881"},"text":"119 Stat. 881","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
