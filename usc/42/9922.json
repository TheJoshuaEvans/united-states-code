{"tag":"section","attrib":{"id":"idbf091f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922"},"text":null,"children":[{"tag":"num","attrib":{"value":"9922"},"text":"§ 9922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community food and nutrition programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf091f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, through grants to public and private, nonprofit agencies, provide for community-based, local, statewide, and national programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate private and public food assistance resources, wherever the grant recipient involved determines such coordination to be inadequate, to better serve low-income populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist low-income communities to identify potential sponsors of child nutrition programs and to initiate such programs in underserved or unserved areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop innovative approaches at the State and local level to meet the nutrition needs of low-income individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments and distribution of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not to exceed $6,000,000 in appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated for a fiscal year to carry out this section (but not to exceed $6,000,000), the Secretary shall distribute funds for grants under subsection (a) as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From a portion equal to 60 percent of such amount (but not to exceed $3,600,000), the Secretary shall allot for grants to eligible agencies for statewide programs in each State the amount that bears the same ratio to such portion as the low-income and unemployed population of such State bears to the low-income and unemployed population of all the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From a portion equal to 40 percent of such amount (but not to exceed $2,400,000), the Secretary shall make grants on a competitive basis to eligible agencies for local and statewide programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greater available appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amounts appropriated for a fiscal year to carry out this section in excess of $6,000,000 shall be allotted as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use 40 percent of such excess to allot for grants under subsection (a) to eligible agencies for statewide programs in each State an amount that bears the same ratio to 40 percent of such excess as the low-income and unemployed population of such State bears to the low-income and unemployed population of all the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for local and statewide programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use 40 percent of such excess to make grants under subsection (a) on a competitive basis to eligible agencies for local and statewide programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants for nationwide programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the remaining 20 percent of such excess to make grants under subsection (a) on a competitive basis to eligible agencies for nationwide programs, including programs benefiting Indians, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9911"},"text":"section 9911 of this title","children":[],"tail":", and migrant or seasonal farmworkers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for allotments for statewide programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive an allotment under paragraph (1)(A) or (2)(A), an eligible agency shall demonstrate that the proposed program is statewide in scope and represents a comprehensive and coordinated effort to alleviate hunger within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments for statewide programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf091f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts allotted under paragraphs (1)(A) and (2)(A), the minimum total allotment for each State for each fiscal year shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf091f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000 if the total amount appropriated to carry out this section is not less than $7,000,000 but less than $10,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf091f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000 if the total amount appropriated to carry out this section is not less than $10,000,000 but less than $15,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf091f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000 if the total amount appropriated to carry out this section is not less than $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf091f4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “State” does not include Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds made available under paragraphs (1)(B) and (2)(B) for any fiscal year, the Secretary may not make grants under subsection (a) to an eligible agency in an aggregate amount exceeding $50,000. From funds made available under paragraph (2)(C) for any fiscal year, the Secretary may not make grants under subsection (a) to an eligible agency in an aggregate amount exceeding $300,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Secretary shall prepare and submit, to the Committee on Education and the Workforce of the House of Representatives and the Committee on Labor and Human Resources of the Senate, a report concerning the grants made under this section. Such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf091f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the amount of funding awarded to each grant recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf091f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities performed by the grant recipients with funding awarded under this section and a description of the manner in which such activities meet the objectives described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf091f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 1999 through 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf091f53-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s681"},"text":"Pub. L. 97–35, title VI, § 681","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2752"},"text":"112 Stat. 2752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf091f54-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf091f55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf091f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/s681"},"text":"section 681 of Pub. L. 97–35","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910"},"text":"section 9910 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf0b8f57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbf0b8f58-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
