{"tag":"section","attrib":{"id":"idbc6d8c99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058ee"},"text":"§ 3058ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6d8c9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, the Comptroller General of the United States, and any duly authorized representative of the Assistant Secretary or the Comptroller shall have access, for the purpose of conducting an audit or examination, to any books, documents, papers, and records that are pertinent to financial assistance received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058ee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State agencies and area agencies on aging shall not request information or data from providers that is not pertinent to services furnished under this subchapter or to a payment made for the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8c9c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s764"},"text":"Pub. L. 89–73, title VII, § 764","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s707"},"text":"Pub. L. 102–375, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1291"},"text":"106 Stat. 1291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVIII/s801/e/6"},"text":"Pub. L. 106–501, title VIII, § 801(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2293"},"text":"114 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6d8c9d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6d8c9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc6d8c9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":" substituted “and area agencies on aging” for “, area agencies on aging, and entities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058aa/c"},"text":"section 3058aa(c) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[