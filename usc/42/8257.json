{"tag":"section","attrib":{"id":"idbe8855d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257"},"text":null,"children":[{"tag":"num","attrib":{"value":"8257"},"text":"§ 8257.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Energy Management Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8855d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the interagency committee organized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7266"},"text":"section 7266 of this title","children":[],"tail":" to coordinate the activities of the Federal Government in promoting energy conservation and the efficient use of energy and in informing non-Federal entities of the Federal experience in energy conservation, the Secretary shall establish an Interagency Energy Management Task Force (hereafter in this section referred to as the “Task Force”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8855d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall be composed of the chief energy managers of agencies represented on the interagency committee organized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7266"},"text":"section 7266 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8855d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall meet when the Secretary requests, but not less often than twice a year, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8855da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the progress of the various agencies in achieving energy savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8855db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate information to agencies, States, local governments, and the public on effective survey techniques, innovative approaches to the efficient use of energy, incentive programs developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8256"},"text":"section 8256 of this title","children":[],"tail":", innovative contracting methods developed under subchapter VII of this chapter, the use of cogeneration facilities and renewable resources, and other technologies that promote the conservation and efficient use of energy;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8855dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate energy surveys conducted by the agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8855dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop options for use in conserving energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8855de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the committee organized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7266"},"text":"section 7266 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8855df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8257/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, from time to time as may be necessary, the regulations relating to building temperature settings to determine whether changes in such regulations would be appropriate to assist in meeting the goals specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8253"},"text":"section 8253 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8855e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s547"},"text":"Pub. L. 95–619, title V, § 547","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3279"},"text":"92 Stat. 3279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/615/s2/a"},"text":"Pub. L. 100–615, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-05"},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3187"},"text":"102 Stat. 3187","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8855e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8855e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8855e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/615"},"text":"Pub. L. 100–615","children":[],"tail":" amended section generally, substituting provisions relating to creation of an Interagency Energy Management Task Force for provisions relating to energy audits and retrofitting of existing Federal buildings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
