{"tag":"section","attrib":{"id":"idb56ec79b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d–3"},"text":"§ 285d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data system and information clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56ec79c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute shall establish the National Arthritis and Musculoskeletal and Skin Diseases Data System for the collection, storage, analysis, retrieval, and dissemination of data derived from patient populations with arthritis and musculoskeletal and skin diseases, including where possible, data involving general populations for the purpose of detection of individuals with a risk of developing arthritis and musculoskeletal and skin diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56ec79d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Institute shall establish the National Arthritis and Musculoskeletal and Skin Diseases Information Clearinghouse to facilitate and enhance, through the effective dissemination of information, knowledge and understanding of arthritis and musculoskeletal and skin diseases, including juvenile arthritis and related conditions, by health professionals, patients, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56ec79e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 438, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/849"},"text":"99 Stat. 849","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tIII/s302"},"text":"Pub. L. 106–310, div. A, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1111"},"text":"114 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56ec79f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56ec7a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56ec7a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" inserted “, including juvenile arthritis and related conditions,” after “skin diseases”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
