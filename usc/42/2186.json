{"tag":"section","attrib":{"id":"idbbfd661d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2186"},"text":null,"children":[{"tag":"num","attrib":{"value":"2186"},"text":"§ 2186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission patent licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall establish standard specifications upon which it may grant a patent license to use any patent declared to be affected with the public interest pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2183/a"},"text":"section 2183(a) of this title","children":[],"tail":". Such a patent license shall not waive any of the other provisions of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbfd661e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 156, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/947"},"text":"68 Stat. 947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s7/a"},"text":"Pub. L. 96–517, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3027"},"text":"94 Stat. 3027","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote",