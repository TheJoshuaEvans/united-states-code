{"tag":"section","attrib":{"id":"idb4edfe07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–18"},"text":"§ 254c–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telemedicine; incentive grants regarding coordination among States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4edfe08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to State professional licensing boards to carry out programs under which such licensing boards of various States cooperate to develop and implement State policies that will reduce statutory and regulatory barriers to telemedicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edfe09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out subsection (a), there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2002 through 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4edfe0a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 330L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s2/e/1"},"text":"Pub. L. 108–163, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2021"},"text":"117 Stat. 2021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4edfe0b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4edfe0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb4edfe0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section deemed to have taken effect immediately after the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/251"},"text":"Pub. L. 107–251","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/163/s3"},"text":"section 3 of Pub. L. 108–163","children":[],"tail":", set out as an Effective Date of 2003 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s233"},"text":"section 233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
