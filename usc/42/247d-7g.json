{"tag":"section","attrib":{"id":"idb4d8a189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g"},"text":null,"children":[{"tag":"num","attrib":{"value":"247d–7g"},"text":"§ 247d–7g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Biodefense Science Board and working groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d8a18a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a18b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the National Biodefense Science Board (referred to in this section as the “Board”) to provide expert advice and guidance to the Secretary on scientific, technical and other matters of special interest to the Department of Health and Human Services regarding current and future chemical, biological, nuclear, and radiological agents, whether naturally occurring, accidental, or deliberate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a18c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Board shall be comprised of individuals who represent the Nation’s preeminent scientific, public health, and medical experts, as follows—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a18d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Federal officials as the Secretary may determine are necessary to support the functions of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a18e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four individuals representing the pharmaceutical, biotechnology, and device industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a18f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four individuals representing academia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" five other members as determined appropriate by the Secretary, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4d8a191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one such member shall be a practicing healthcare professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one such member shall be an individual from an organization representing healthcare consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one such member shall be an individual with pediatric subject matter expertise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4d8a194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one such member shall be a State, tribal, territorial, or local public health official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this paragraph shall preclude a member of the Board from satisfying two or more of the requirements described in subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board described in subparagraph (B), (C), or (D) of paragraph (2) shall serve for a term of 3 years, except that the Secretary may adjust the terms of the initial Board appointees in order to provide for a staggered term of appointment for all members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consecutive appointments; maximum terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member may be appointed to serve not more than 3 terms on the Board and may serve not more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary on current and future trends, challenges, and opportunities presented by advances in biological and life sciences, biotechnology, and genetic engineering with respect to threats posed by naturally occurring infectious diseases and chemical, biological, radiological, and nuclear agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the Secretary, review and consider any information and findings received from the working groups established under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a19a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the Secretary, provide recommendations and findings for expanded, intensified, and coordinated biodefense research and development activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any recommendation, finding, or report provided to the Secretary under this paragraph to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2006-12-19"},"text":"December 19, 2006","children":[],"tail":", the Secretary shall hold the first meeting of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at the call of the Secretary, but in no case less than twice annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Board shall not affect its powers, but shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint a chairperson from among the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Board considers advisable to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may use the United States mails in the same manner and under the same conditions as other departments and agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of the Federal Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board that is an employee of the Federal Government may not receive additional pay, allowances, or benefits by reason of the member’s service on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board that is not an employee of the Federal Government may be compensated at a rate not to exceed the daily equivalent of the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":" for each day (including travel time) during which the member is engaged in the actual performance of duties as a member of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Board shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d8a1a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee may be detailed to the Board with the approval for the contributing agency without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other working groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish a working group of experts, or may use an existing working group or advisory committee, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d8a1aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify innovative research with the potential to be developed as a qualified countermeasure or a qualified pandemic or epidemic product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify accepted animal models for particular diseases and conditions associated with any biological, chemical, radiological, or nuclear agent, any toxin, or any potential pandemic infectious disease, and identify strategies to accelerate animal model and research tool development and validation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d8a1ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain advice regarding supporting and facilitating advanced research and development related to qualified countermeasures and qualified pandemic or epidemic products that are likely to be safe and effective with respect to children, pregnant women, and other vulnerable populations, and other issues regarding activities under this section that affect such populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any term that is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7e"},"text":"section 247d–7e of this title","children":[],"tail":" and that is used in this section shall have the same meaning in this section as such term is given in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7e"},"text":"section 247d–7e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d8a1ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $1,000,000 to carry out this section for fiscal year 2007 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d8a1af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 319M, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tIV/s402"},"text":"Pub. L. 109–417, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2872"},"text":"120 Stat. 2872","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tIV/s404"},"text":"Pub. L. 113–5, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/197"},"text":"127 Stat. 197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4d8a1b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4d8a1b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4d8a1b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–7f"},"text":"section 247d–7f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4d8a1b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s404/1/B"},"text":"Pub. L. 113–5, § 404(1)(B)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s404/1/A"},"text":"Pub. L. 113–5, § 404(1)(A)","children":[],"tail":", added cls. (iii) and (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s404/2"},"text":"Pub. L. 113–5, § 404(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
