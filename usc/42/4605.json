{"tag":"section","attrib":{"id":"idbcd660ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605"},"text":null,"children":[{"tag":"num","attrib":{"value":"4605"},"text":"§ 4605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Displaced persons not eligible for assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd660ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), a displaced person shall not be eligible to receive relocation payments or any other assistance under this chapter if the displaced person is an alien not lawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd660ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd660af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1997-11-21"},"text":"November 21, 1997","children":[],"tail":", after providing notice and an opportunity for public comment, the head of the lead agency shall promulgate regulations to carry out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd660b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations promulgated under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd660b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the processes, procedures, and information that a displacing agency must use in determining whether a displaced person is an alien not lawfully present in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd660b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a displacing agency from discriminating against any displaced person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd660b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each eligibility determination is fair and based on reliable information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd660b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe standards for a displacing agency to apply in making determinations relating to exceptional and extremely unusual hardship under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd660b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptional and extremely unusual hardship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a displacing agency determines by clear and convincing evidence that a determination of the ineligibility of a displaced person under subsection (a) would result in exceptional and extremely unusual hardship to an individual who is the displaced person’s spouse, parent, or child and who is a citizen of the United States or an alien lawfully admitted for permanent residence in the United States, the displacing agency shall provide relocation payments and other assistance to the displaced person under this chapter if the displaced person would be eligible for the assistance but for subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd660b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects any right available to a displaced person under any other provision of Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd8d0b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646/tI/s104"},"text":"Pub. L. 91–646, title I, § 104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/117/s1"},"text":"Pub. L. 105–117, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2384"},"text":"111 Stat. 2384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd8d0b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd8d0b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcd8d0ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Pub. L. 91–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1894"},"text":"84 Stat. 1894","children":[],"tail":", known as the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
