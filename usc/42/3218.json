{"tag":"section","attrib":{"id":"idbc7973c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218"},"text":null,"children":[{"tag":"num","attrib":{"value":"3218"},"text":"§ 3218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc7973c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and disclosure requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of assistance under this chapter shall keep such records as the Secretary shall require, including records that fully disclose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7973c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and the disposition by the recipient of the proceeds of the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project in connection with which the assistance is given or used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of the portion of the cost of the project provided by other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7973cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc7973cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to books for examination and audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Inspector General of the Department, and the Comptroller General of the United States, or any duly authorized representative, shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipient that relate to assistance received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7973cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s608"},"text":"Pub. L. 89–136, title VI, § 608","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3616"},"text":"112 Stat. 3616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc7973d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3218, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVII/s708"},"text":"Pub. L. 89–136, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/573"},"text":"79 Stat. 573","children":[],"tail":", authorized delegation of functions and transfer of funds, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/b/3"},"text":"Pub. L. 105–393, § 102(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7973d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7973d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
