{"tag":"section","attrib":{"id":"idbf532091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11503"},"text":null,"children":[{"tag":"num","attrib":{"value":"11503"},"text":"§ 11503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction with other Federal programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf532092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with relocation assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The designation of an enterprise zone under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11501"},"text":"section 11501 of this title","children":[],"tail":" shall not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf532093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitute approval of a Federal or federally assisted program or project (within the meaning of the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"42 U.S.C. 4601","children":[],"tail":" et seq.)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf532094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitle any person displaced from real property located in such zone to any rights or any benefits under such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf532095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise zones treated as labor surplus areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any area that is designated as an enterprise zone under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11501"},"text":"section 11501 of this title","children":[],"tail":" shall be treated for all purposes under Federal law as a labor surplus area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf532096-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/242/tVII/s703"},"text":"Pub. L. 100–242, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-02-05"},"text":"Feb. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1961"},"text":"101 Stat. 1961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf532097-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf532098-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf532099-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Relocation Assistance and Real Property Acquisition Policy Act of 1970, referred to in subsec. (a), probably means the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/646"},"text":"Pub. L. 91–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1894"},"text":"84 Stat. 1894","children":[],"tail":", which is classified principally to chapter 61 (§ 4601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"section 4601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
