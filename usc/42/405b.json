{"tag":"section","attrib":{"id":"idb72a59e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b"},"text":null,"children":[{"tag":"num","attrib":{"value":"405b"},"text":"§ 405b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reducing identity fraud","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb72a59e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to reduce the prevalence of synthetic identity fraud, which disproportionally affects vulnerable populations, such as minors and recent immigrants, by facilitating the validation by permitted entities of fraud protection data, pursuant to electronically received consumer consent, through use of a database maintained by the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a59e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a59e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of the Social Security Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” has the meaning given the term in section 509 of the Gramm-Leach-Bliley Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6809"},"text":"15 U.S.C. 6809","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud protection data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fraud protection data” means a combination of the following information with respect to an individual:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a59e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the individual (including the first name and any family forename or surname of the individual).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a59e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The social security number of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a59e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of birth (including the month, day, and year) of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “permitted entity” means a financial institution or a service provider, subsidiary, affiliate, agent, subcontractor, or assignee of a financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a59eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficiency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a59ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reliance on existing methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall evaluate the feasibility of making modifications to any database that is in existence as of ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", or a similar resource such that the database or resource—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a59ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonably designed to effectuate the purpose of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a59ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall make the modifications necessary to any database that is in existence as of ","children":[{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", or similar resource, or develop a database or similar resource, to effectuate the requirements described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a59f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of vulnerable consumers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The database or similar resource described in subsection (c) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a59f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compare fraud protection data provided in an inquiry by a permitted entity against such information maintained by the Commissioner in order to confirm (or not confirm) the validity of the information provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be scalable and accommodate reasonably anticipated volumes of verification requests from permitted entities with commercially reasonable uptime and availability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow permitted entities to submit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a59f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more individual requests electronically for real-time machine-to-machine (or similar functionality) accurate responses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a59f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple requests electronically, such as those provided in a batch format, for accurate electronic responses within a reasonable period of time from submission, not to exceed 24 hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a59f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before providing confirmation of fraud protection data to a permitted entity, the Commissioner shall ensure that the Commissioner has a certification from the permitted entity that is dated not more than 2 years before the date on which that confirmation is provided that includes the following declarations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a59f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity is a permitted entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity is in compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity is, and will remain, in compliance with its privacy and data security requirements, as described in title V of the Gramm-Leach-Bliley Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6801"},"text":"15 U.S.C. 6801","children":[],"tail":" et seq.), with respect to information the entity receives from the Commissioner pursuant to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entity will retain sufficient records to demonstrate its compliance with its certification and this section for a period of not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a59fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer consent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a59fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law or regulation, a permitted entity may submit a request to the database or similar resource described in subsection (c) only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a59fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the written, including electronic, consent received by a permitted entity from the individual who is the subject of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a59fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a credit transaction or any circumstance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a59ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic consent requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a permitted entity to use the consent of an individual received electronically pursuant to paragraph (1)(A), the permitted entity must obtain the individual’s electronic signature, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7006"},"text":"section 7006 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a5a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectuating electronic consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of law or requirement, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", shall prevent the use of electronic consent for purposes of this subsection or for use in any other consent based verification under the discretion of the Commissioner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a5a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance and enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a5a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits and monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a5a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct audits and monitoring to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb72a5a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure proper use by permitted entities of the database or similar resource described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb72a5a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deter fraud and misuse by permitted entities with respect to the database or similar resource described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a5a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate services for any permitted entity that prevents or refuses to allow the Commissioner to carry out the activities described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a5a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a5a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, including the matter preceding paragraph (1) of section 505(a) of the Gramm-Leach-Bliley Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6805/a"},"text":"15 U.S.C. 6805(a)","children":[],"tail":"), any violation of this section and any certification made under this section shall be enforced in accordance with paragraphs (1) through (7) of such section 505(a) by the agencies described in those paragraphs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a5a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon discovery by the Commissioner, pursuant to an audit described in paragraph (1), of any violation of this section or any certification made under this section, the Commissioner shall forward any relevant information pertaining to that violation to the appropriate agency described in subparagraph (A) for evaluation by the agency for purposes of enforcing this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb72a5a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb72a5a0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb72a5a0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts obligated to carry out this section shall be fully recovered from the users of the database or verification system by way of advances, reimbursements, user fees, or other recoveries as determined by the Commissioner. The funds recovered under this paragraph shall be deposited as an offsetting collection to the account providing appropriations for the Social Security Administration, to be used for the administration of this section without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb72a5a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prices fixed by Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall establish the amount to be paid by the users under this paragraph, including the costs of any services or work performed, such as any appropriate upgrades, maintenance, and associated direct and indirect administrative costs, in support of carrying out the purposes described in this section, by reimbursement or in advance as determined by the Commissioner. The amount of such prices shall be periodically adjusted by the Commissioner to ensure that amounts collected are sufficient to fully offset the cost of the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a5a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall not begin development of a verification system to carry out this section until the Commissioner determines that amounts equal to at least 50 percent of program start-up costs have been collected under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a5a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may use funds designated for information technology modernization to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb72a5a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s405b/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall annually submit to the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate a report on the amount of indirect costs to the Social Security Administration arising as a result of the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb72a5a11-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tII/s215"},"text":"Pub. L. 115–174, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1323"},"text":"132 Stat. 1323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb72a5a12-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb72a5a13-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb72a5a14-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Gramm-Leach-Bliley Act, referred to in subsec. (e)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1338"},"text":"113 Stat. 1338","children":[],"tail":". Title V of the Act is classified principally to chapter 94 (§ 6801 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title of 1999 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of Title 12","children":[],"tail":", Banks and Banking, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb72a5a15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Growth, Regulatory Relief, and Consumer Protection Act, and not as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
