{"tag":"section","attrib":{"id":"idb56a0bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–12"},"text":"§ 285a–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Breast Cancer and Environmental Research Coordinating Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56a0bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Breast Cancer and Environmental Research Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2008-10-08"},"text":"October 8, 2008","children":[],"tail":", the Secretary shall establish a committee, to be known as the Interagency Breast Cancer and Environmental Research Coordinating Committee (in this section referred to as the “Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share and coordinate information on existing research activities, and make recommendations to the National Institutes of Health and other Federal agencies regarding how to improve existing research programs, that are related to breast cancer research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a comprehensive strategy and advise the National Institutes of Health and other Federal agencies in the solicitation of proposals for collaborative, multidisciplinary research, including proposals to evaluate environmental and genomic factors that may be related to the etiology of breast cancer that would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in innovative approaches to study emerging scientific opportunities or eliminate knowledge gaps in research to improve the research portfolio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline key research questions, methodologies, and knowledge gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the number of research proposals that involve collaboration between 2 or more national research institutes or national centers, including proposals for Common Fund research described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7"},"text":"section 282(b)(7) of this title","children":[],"tail":" to improve the research portfolio; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the number of collaborative, multidisciplinary, and multi-institutional research grants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a summary of advances in breast cancer research supported or conducted by Federal agencies relevant to the diagnosis, prevention, and treatment of cancer and other diseases and disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 2 years after the date of the establishment of the Committee, make recommendations to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding any appropriate changes to research activities, including recommendations to improve the research portfolio of the National Institutes of Health to ensure that scientifically-based strategic planning is implemented in support of research priorities that impact breast cancer research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the activities of the National Institutes of Health and other Federal agencies, including the Department of Defense, are free of unnecessary duplication of effort;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding public participation in decisions relating to breast cancer research to increase the involvement of patient advocacy and community organizations representing a broad geographical area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how best to disseminate information on breast cancer research progress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how to expand partnerships between public entities, including Federal agencies, and private entities to expand collaborative, cross-cutting research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of the Committee, when focusing on research to evaluate environmental and genomic factors that may be related to the etiology of breast cancer, nothing in this section shall be construed to restrict the Secretary from including other forms of cancer, as appropriate, when doing so may advance research in breast cancer or advance research in other forms of cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of the following voting members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not more than 7 voting Federal representatives as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb56a0c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health and the directors of such national research institutes and national centers (which may include the National Institute of Environmental Health Sciences) as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative from the National Cancer Institute Board of Scientific Advisors, appointed by the Director of the National Cancer Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heads of such other agencies of the Department of Health and Human Services as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of other Federal agencies that conduct or support cancer research, including the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 additional voting members appointed under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall include additional voting members appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 6 members shall be appointed from among scientists, physicians, and other health professionals, who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb56a0c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not officers or employees of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent multiple disciplines, including clinical, basic, and public health sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent different geographical regions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are from practice settings, academia, or other research settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb56a0c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are experienced in scientific peer review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members shall be appointed from members of the general public, who represent individuals with breast cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall include such nonvoting members as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting members of the Committee shall select a chairperson from among such members. The selection of a chairperson shall be subject to the approval of the Director of NIH.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet at the call of the chairperson of the Committee or upon the request of the Director of NIH, but in no case less often than once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the necessity of the Committee in calendar year 2011 and, thereafter, at least once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56a0c25-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 417F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/354/s2/a"},"text":"Pub. L. 110–354, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3984"},"text":"122 Stat. 3984","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
