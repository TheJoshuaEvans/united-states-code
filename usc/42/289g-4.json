{"tag":"section","attrib":{"id":"idb590a627-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"289g–4"},"text":"§ 289g–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for emergency medicine research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb590a628-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency medical research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall support Federal programs administered by the National Institutes of Health, the Agency for Healthcare Research and Quality, the Health Resources and Services Administration, the Centers for Disease Control and Prevention, and other agencies involved in improving the emergency care system to expand and accelerate research in emergency medical care systems and emergency medicine, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb590a629-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic science of emergency medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590a62a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the model of service delivery and the components of such models that contribute to enhanced patient health outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590a62b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the translation of basic scientific research into improved practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590a62c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of timely and efficient delivery of health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb590a62d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric emergency medical research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall support Federal programs administered by the National Institutes of Health, the Agency for Healthcare Research and Quality, the Health Resources and Services Administration, the Centers for Disease Control and Prevention, and other agencies to coordinate and expand research in pediatric emergency medical care systems and pediatric emergency medicine, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb590a62e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of the gaps and opportunities in pediatric emergency care research and a strategy for the optimal organization and funding of such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590cd3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of pediatric emergency services as an integrated component of the overall health system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590cd40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" system-wide pediatric emergency care planning, preparedness, coordination, and funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590cd41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pediatric training in professional education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb590cd42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research in pediatric emergency care, specifically on the efficacy, safety, and health outcomes of medications used for infants, children, and adolescents in emergency care settings in order to improve patient safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb590cd43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support research to determine the estimated economic impact of, and savings that result from, the implementation of coordinated emergency care systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb590cd44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289g–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2010 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb590cd45-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 498D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3504/b"},"text":"Pub. L. 111–148, title III, § 3504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/521"},"text":"124 Stat. 521","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
