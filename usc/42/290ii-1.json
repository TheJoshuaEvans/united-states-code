{"tag":"section","attrib":{"id":"idb5c7205c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ii–1"},"text":"§ 290ii–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c7205d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each facility to which the Protection and Advocacy for Mentally Ill Individuals Act of 1986 ","children":[{"tag":"ref","attrib":{"idref":"fn002248"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002248"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10801"},"text":"42 U.S.C. 10801","children":[],"tail":" et seq.] applies shall notify the appropriate agency, as determined by the Secretary, of each death that occurs at each such facility while a patient is restrained or in seclusion, of each death occurring within 24 hours after the patient has been removed from restraints and seclusion, or where it is reasonable to assume that a patient’s death is a result of such seclusion or restraint. A notification under this section shall include the name of the resident and shall be provided not later than 7 days after the date of the death of the individual involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c7205e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ii–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"hea