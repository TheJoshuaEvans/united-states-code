{"tag":"section","attrib":{"id":"idb6705878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y"},"text":null,"children":[{"tag":"num","attrib":{"value":"300y"},"text":"§ 300y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data infrastructure development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6705879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to, and enter into contracts or cooperative agreements with States for the purpose of developing and operating mental health or substance use data collection, analysis, and reporting systems with regard to performance measures including capacity, process, and outcomes measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb670587a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria to ensure that services will be available under this section to States that have a fundamental basis for the collection, analysis, and reporting of mental health and substance use performance measures and States that do not have such basis. The Secretary will establish criteria for determining whether a State has a fundamental basis for the collection, analysis, and reporting of data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb670587b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of receipt of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the receipt of an award under this section a State shall agree to collect, analyze, and report to the Secretary within 2 years of the date of the award on a core set of performance measures to be determined by the Secretary in conjunction with the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb670587c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb670587d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the costs of the program to be carried out under subsection (a) by a State, the Secretary may make an award under such subsection only if the applicant agrees to make available (directly or through donations from public or private entities) non-Federal contributions toward such costs in an amount that is not less than 50 percent of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb670587e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount contributed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions under paragraph (1) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb670587f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period during which payments may be made for a project under subsection (a) may be not less than 3 years nor more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6705880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6705881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2001, 2002 and 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6705882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300y/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under paragraph (1) for a fiscal year, 50 percent shall be expended to support data infrastructure development for mental health and 50 percent shall be expended to support data infrastructure development for substance use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6705883-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1971, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIV/s3404/2"},"text":"Pub. L. 106–310, div. B, title XXXIV, § 3404(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1220"},"text":"114 Stat. 1220","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1241/b/2"},"text":"Pub. L. 117–328, div. FF, title I, § 1241(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5678"},"text":"136 Stat. 5678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6705884-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6705885-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial 