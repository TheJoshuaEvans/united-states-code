{"tag":"section","attrib":{"id":"idb5c264aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a"},"text":null,"children":[{"tag":"num","attrib":{"value":"290ee–5a"},"text":"§ 290ee–5a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sobriety treatment and recovery teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5c264ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to States, units of local government, or tribal governments to establish or expand Sobriety Treatment And Recovery Team (referred to in this section as “START”) or other similar programs to determine the effectiveness of pairing social workers or mentors with families that are struggling with a substance use disorder and child abuse or neglect in order to help provide peer support, intensive treatment, and child welfare services to such families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this section may be used for one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c264ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training eligible staff, including social workers, social services coordinators, child welfare specialists, substance use disorder treatment professionals, and mentors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expanding access to substance use disorder treatment services and drug testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing data sharing with law enforcement agencies, child welfare agencies, substance use disorder treatment providers, judges, and court personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program evaluation and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, unit of local government, or tribal government receiving a grant under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5c264b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve only families for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5c264b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an open record with the child welfare agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5c264b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance use disorder was a reason for the record or finding described in paragraph (1); ","children":[{"tag":"ref","attrib":{"idref":"fn002243"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002243"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparagraph (A)”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5c264b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate any grants awarded under this section with any grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s629g/f"},"text":"section 629g(f) of this title","children":[],"tail":" focused on improving outcomes for children affected by substance abuse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5c264b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290ee–5a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reserve not more than 5 percent of funds provided under this section to provide technical assistance on the establishment or expansion of programs funded under this section from the National Center on Substance Abuse and Child Welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5c264b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 550A, formerly § 550, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8214"},"text":"Pub. L. 115–271, title VIII, § 8214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4116"},"text":"132 Stat. 4116","children":[],"tail":"; renumbered § 550A, "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1237"},"text":"Pub. L. 117–328, div. FF, title I, § 1237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5677"},"text":"136 Stat. 5677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5c264b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5c264b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5c264ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–10"},"text":"section 290ee–10 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
