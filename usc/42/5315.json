{"tag":"section","attrib":{"id":"idbd4687d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5315"},"text":null,"children":[{"tag":"num","attrib":{"value":"5315"},"text":"§ 5315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate agreements or compacts; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The consent of the Congress is hereby given to any two or more States to enter into agreements or compacts, not in conflict with any law of the United States, for cooperative effort and mutual assistance in support of community development planning and programs carried out under this chapter as they pertain to interstate areas and to localities within such States, and to establish such agencies, joint or otherwise, as they may deem desirable for making such agreements and compacts effective.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd4687d4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s115"},"text":"Pub. L. 93–383, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/651"},"text":"88 Stat. 651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4687d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4687d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd4687d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383"},"text":"Pub. L. 93–383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/633"},"text":"88 Stat. 633","children":[],"tail":", which is classified principally to this chapter. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
