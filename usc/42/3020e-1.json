{"tag":"section","attrib":{"id":"idbc4766cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3020e–1"},"text":"§ 3020e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension counseling and information programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc4766cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension and other retirement benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pension and other retirement benefits” means private, civil service, and other public pensions and retirement benefits, including benefits provided under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc4766ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Social Security program under title II of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the railroad retirement program under the Railroad Retirement Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s231"},"text":"45 U.S.C. 231","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government retirement benefits programs under the Civil Service Retirement System set forth in chapter 83 of title 5, the Federal Employees Retirement System set forth in chapter 84 of title 5, or other Federal retirement systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee pension benefit plans as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/2"},"text":"section 1002(2) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension counseling and information program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pension counseling and information program” means a program described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall award grants to eligible entities to establish and carry out pension counseling and information programs that create or continue a sufficient number of pension assistance and counseling programs to provide outreach, information, counseling, referral, and other assistance regarding pension and other retirement benefits, and rights related to such benefits, to individuals in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall award grants under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies or area agencies on aging; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nonprofit organizations with a proven record of providing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc4766d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services related to retirement of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services to Native Americans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific pension counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen advisory panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall establish a citizen advisory panel to advise the Assistant Secretary regarding which entities should receive grant awards under this section. Such panel shall include representatives of business, labor, national senior advocates, and national pension rights advocates. The Assistant Secretary shall consult such panel prior to awarding grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall submit an application to the Assistant Secretary at such time, in such manner, and containing such information as the Assistant Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan to establish a pension counseling and information program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc4766dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes or continues a State or area pension counseling and information program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves a specific geographic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides counseling (including direct counseling and assistance to individuals who need information regarding pension and other retirement benefits) and information that may assist individuals in obtaining, or establishing rights to, and filing claims or complaints regarding, pension and other retirement benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information on sources of pension and other retirement benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a system to make referrals for legal services and other advocacy programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a system of referral to Federal, State, and local departments or agencies related to pension and other retirement benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a sufficient number of staff positions (including volunteer positions) to ensure information, counseling, referral, and assistance regarding pension and other retirement benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training programs for staff members, including volunteer staff members, of pension and other retirement benefits programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes recommendations to the Administration, the Department of Labor and other Federal, State, and local agencies concerning issues for older individuals related to pension and other retirement benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes or continues an outreach program to provide information, counseling, referral and assistance regarding pension and other retirement benefits, with particular emphasis on outreach to women, minorities, older individuals residing in rural areas, low-income retirees, and older individuals with limited English proficiency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that staff members (including volunteer staff members) have no conflict of interest in providing the services described in the plan described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall consider the following criteria in awarding grants under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence of a commitment by the entity to carry out a proposed pension counseling and information program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the entity to perform effective outreach to affected populations, particularly populations with limited English proficiency and other populations that are identified as in need of special outreach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reliable information that the population to be served by the entity has a demonstrable need for the services proposed to be provided under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the entity to provide services under the program on a statewide or regional basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall award grants to eligible entities to establish training and technical assistance programs that shall provide information and technical assistance to the staffs of entities operating pension counseling and information programs described in subsection (b), and general assistance to such entities, including assistance in the design of program evaluation tools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities that are eligible to receive a grant under this subsection include nonprofit private organizations with a record of providing national information, referral, and advocacy in matters related to pension and other retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, an entity shall submit an application to the Assistant Secretary at such time, in such manner, and containing such information as the Assistant Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension assistance hotline and intragency coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hotline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall enter into agreements with other Federal agencies to establish and administer a national telephone hotline that shall provide information regarding pension and other retirement benefits, and rights related to such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such hotline described in paragraph (1) shall provide information for individuals (including individuals with limited English proficiency) seeking outreach, information, counseling, referral, and assistance regarding pension and other retirement benefits, and rights related to such benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary may enter into agreements with the Secretary of Labor and the heads of other Federal agencies that regulate the provision of pension and other retirement benefits in order to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2000-11-13"},"text":"November 13, 2000","children":[],"tail":", the Assistant Secretary shall submit to the Committee on Education and Labor of the House of Representatives and the Committee on Health, Education, Labor and Pensions of the Senate a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the distribution of funds authorized for grants under this section and the expenditure of such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the scope and content of training and assistance provided under a program carried out under this section and the degree to which the training and assistance can be replicated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the problems that individuals participating in programs funded under this section encountered concerning rights related to pension and other retirement benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes recommendations regarding the manner in which services provided in programs funded under this section can be incorporated into the ongoing programs of State agencies, area agencies on aging, multipurpose senior centers and other similar entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3020f"},"text":"section 3020f of this title","children":[],"tail":" to carry out this section for a fiscal year, not more than $100,000 may be used by the Administration for administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc4766fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Resource Center for Women and Retirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc4766fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall, directly or by grant or contract, operate the National Resource Center for Women and Retirement (in this subsection referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc4766fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Center shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc4766fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide tools, such as basic financial management, retirement planning, and other tools that promote financial literacy and help to identify and prevent exploitation (including fraud), and integrate these with information on health and long-term care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc4766ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually disseminate a summary of outreach activities provided, including work to provide user-friendly consumer information and public education materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop targeted outreach strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to State agencies and to other public and nonprofit private agencies and organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc476702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020e–1/k/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop partnerships and collaborations to address program objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc476703-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s215"},"text":"Pub. L. 89–73, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tII/s202/5"},"text":"Pub. L. 106–501, title II, § 202(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2231"},"text":"114 Stat. 2231","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tII/s209"},"text":"Pub. L. 109–365, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2537"},"text":"120 Stat. 2537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tI/s121"},"text":"Pub. L. 116–131, title I, § 121","children":[],"tail":", title VII, § 701(4), "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/247"},"text":"134 Stat. 247","children":[],"tail":", 271.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc476704-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc476705-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc476706-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"tex