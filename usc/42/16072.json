{"tag":"section","attrib":{"id":"idbff071e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072"},"text":null,"children":[{"tag":"num","attrib":{"value":"16072"},"text":"§ 16072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff071e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which grants are awarded under this subpart, the Secretary shall submit to Congress a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the grant recipients and a description of the projects to be funded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of other applicants that submitted applications for the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the mechanisms used by the Secretary to ensure that the information and knowledge gained by participants in the pilot program are transferred among the pilot program participants and to other interested parties, including other applicants that submitted applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and annually thereafter until the pilot program ends, the Secretary shall submit to Congress a report containing an evaluation of the effectiveness of the pilot program, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the benefits to the environment derived from the projects included in the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16072/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the potential benefits to the environment to be derived from widespread application of alternative fueled vehicles and ultra-low sulfur diesel vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff071ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s722"},"text":"Pub. L. 109–58, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/820"},"text":"119 Stat. 820","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
