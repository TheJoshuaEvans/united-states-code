{"tag":"section","attrib":{"id":"idbdc750ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6911a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6911a"},"text":"§ 6911a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Administrator of Environmental Protection Agency; appointment, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Assistant Administrator of the Environmental Protection Agency appointed to head the Office of Solid Waste shall be in addition to the five Assistant Administrators of the Environmental Protection Agency provided for in section 1(d) of Reorganization Plan Numbered 3 of 1970 and the additional Assistant Administrator provided by the Toxic Substances Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"15 U.S.C. 2601","children":[],"tail":" et seq.], shall be appointed by the President by and with the advice and consent of the Senate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdc999db-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tIII/s307/b"},"text":"Pub. L. 96–510, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2810"},"text":"94 Stat. 2810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/80/s2/c/2/B"},"text":"Pub. L. 98–80, § 2(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-23"},"text":"Aug. 23, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/485"},"text":"97 Stat. 485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc999dc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc999dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdc999de-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 3 of 1970, referred to in text, is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Toxic Substances Control Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469"},"text":"Pub. L. 94–469","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":", which is classified generally to chapter 53 (§ 2601 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdc999df-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980, and not as part of the Solid Waste Disposal Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc999e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/80"},"text":"Pub. L. 98–80","children":[],"tail":" struck out “, and shall be compensated at the rate provided for Level IV of the Executive Schedule pay rates under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"” after “advice and consent of the Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdc999e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbdc999e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9652"},"text":"section 9652 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
