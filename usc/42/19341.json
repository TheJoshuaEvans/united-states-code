{"tag":"section","attrib":{"id":"idc08dea13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341"},"text":null,"children":[{"tag":"num","attrib":{"value":"19341"},"text":"§ 19341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applied laboratories infrastructure restoration and modernization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08dea14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of National Laboratory.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “National Laboratory” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Renewable Energy Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Energy Technology Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Idaho National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Savannah River National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sandia National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Los Alamos National Laboratory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Lawrence Livermore National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration and modernization projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall fund projects described in paragraph (2) as needed to address the deferred maintenance, critical infrastructure needs, and modernization of National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The projects referred to in paragraph (1) are, as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08dea1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority deferred maintenance projects at National Laboratories, including facilities sustainment for, upgrade of, and construction of research laboratories, administrative and support buildings, utilities, roads, power plants, and any other critical infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" lab modernization projects at National Laboratories, including projects relating to core infrastructure needed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc08dea21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support existing and emerging science missions with new and specialized requirements for world-leading scientific user facilities and computing capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08dea22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain safe, efficient, reliable, and environmentally responsible operations, including pilot projects to demonstrate net-zero emissions with resilient operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall use all available approaches and mechanisms, as the Secretary determines to be appropriate, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08dea24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital line items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minor construction projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy savings performance contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utility energy service contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative financing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08dea29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expense funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year through fiscal year 2027, at the same time as the annual budget submission of the President, the Secretary shall submit to the Committee on Appropriations and the Committee on Energy and Natural Resources of the Senate and the Committee on Appropriations and the Committee on Science, Space, and Technology of the House of Representatives a list of projects for which the Secretary will provide funding under this section, including a description of each project and the funding profile for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08dea2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out the activities described in this section $800,000,000 for each of fiscal years 2023 through 2027, of which, in each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $640,000,000 is authorized to be appropriated for projects at National Laboratories described in paragraphs (1) through (4) of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19341/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $160,000,000 is authorized to be appropriated for projects at National Laboratories described in paragraphs (5) through (7) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08dea2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10761"},"text":"Pub. L. 117–167, div. B, title VI, § 10761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1725"},"text":"136 Stat. 1725","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
