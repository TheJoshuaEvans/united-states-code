{"tag":"section","attrib":{"id":"idbc68aaa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057k–21"},"text":"§ 3057k–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68aaa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary may carry out a competitive demonstration program for making grants to tribal organizations or organizations serving Native Hawaiians with applications approved under parts A and B, to pay for the Federal share of carrying out programs, to enable the organizations described in this subsection to build their capacity to provide a wider range of in-home and community supportive services to enable older individuals to maintain their health and independence and to avoid long-term care facility placement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68aaa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aaaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), supportive services described in subsection (a) may include any of the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030d/a"},"text":"section 3030d(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aaab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, in making grants under this section, shall give priority to organizations that will use the grant funds for supportive services described in subsection (a) that are for in-home assistance, transportation, information and referral, case management, health and wellness programs, legal services, family caregiver support services, and other services that directly support the independence of the older individuals served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aaac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057k–21/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed or interpreted to prohibit the provision of supportive services under part A or B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aaad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s636"},"text":"Pub. L. 89–73, title VI, § 636","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tV/s501/3"},"text":"Pub. L. 116–131, title V, § 501(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/268"},"text":"134 Stat. 268","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
