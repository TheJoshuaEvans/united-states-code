{"tag":"section","attrib":{"id":"idbcca79d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c"},"text":null,"children":[{"tag":"num","attrib":{"value":"4370c"},"text":"§ 4370c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental Protection Agency fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcca79d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall, by regulation, assess and collect fees and charges for services and activities carried out pursuant to laws administered by the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of fees and charges","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees and charges assessed pursuant to this section shall be in such amounts as may be necessary to ensure that the aggregate amount of fees and charges collected pursuant to this section, in excess of the amount of fees and charges collected under current law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcca79d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fiscal year 1991, is not less than $28,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca79d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each of fiscal years 1992, 1993, 1994, and 1995, is not less than $38,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on fees and charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcca79db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The maximum aggregate amount of fees and charges in excess of the amounts being collected under current law which may be assessed and collected pursuant to this section in a fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcca79dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for services and activities carried out pursuant ot ","children":[{"tag":"ref","attrib":{"idref":"fn003363"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003363"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “to”."}],"tail":" the Federal Water Pollution Control Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.] is $10,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcca79dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for services and activities in programs within the jurisdiction of the House Committee on Energy and Commerce and administered by the Environmental Protection Agency through the Administrator, shall be limited to such sums collected as of ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", pursuant to sections 2625(b) and 2665(e)(2) "},{"tag":"ref","attrib":{"idref":"fn003364"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003364"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 15, and such sums specifically authorized by the Clean Air Act Amendments of 1990."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcca79de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any remaining amounts required to be collected under this section shall be collected from services and programs administered by the Environmental Protection Agency other than those specified in subparagraphs (A) and (B) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section increases or diminishes the authority of the Administrator to promulgate regulations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4370c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees and charges collected pursuant to this section shall be deposited into a special account for environmental services in the Treasury of the United States. Subject to appropriation Acts, such funds shall be available to the Environmental Protection Agency to carry out the activities for which such fees and charges are collected. Such funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcca79e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6501"},"text":"Pub. L. 101–508, title VI, § 6501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-320"},"text":"104 Stat. 1388–320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcca79e2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcca79e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcca79e4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (c)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2665/e/2"},"text":"Section 2665(e)(2) of title 15","children":[],"tail":", referred to in subsec. (c)(1)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2665/d/2"},"text":"section 2665(d)(2) of Title 15","children":[],"tail":", Commerce and Trade, by "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2021"},"text":"Pub. L. 104–66, title II, § 2021","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/728"},"text":"109 Stat. 728","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Clean Air Act Amendments of 1990, referred to in subsec. (c)(1)(B), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549"},"text":"Pub. L. 101–549","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2399"},"text":"104 Stat. 2399","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1990 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcca79e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":"” was in the original “the Independent Office Appropriations Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"31 U.S.C. 9701","children":[],"tail":")” and substitution was made as if it read for “title V of the Independent Offices Appropriation Act of 1952” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Omnibus Budget Reconciliation Act of 1990, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcca79e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbcca79e7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Energy and Commerce of House of Representatives treated as referring to Committee on Commerce of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
