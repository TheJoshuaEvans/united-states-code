{"tag":"section","attrib":{"id":"idb54b133f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280l–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"280l–2"},"text":"§ 280l–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of evaluation by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate, in accordance with this part, all programs funded through the Centers for Disease Control and Prevention before conducting such an evaluation of privately funded programs unless an entity with a privately funded wellness program requests such an evaluation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb54b1340-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399MM–2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4303"},"text":"Pub. L. 111–148, title IV, § 4303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/583"},"text":"124 Stat. 583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
