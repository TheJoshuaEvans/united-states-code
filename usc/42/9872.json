{"tag":"section","attrib":{"id":"idbf046436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9872"},"text":null,"children":[{"tag":"num","attrib":{"value":"9872"},"text":"§ 9872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf046437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9871"},"text":"section 9871 of this title","children":[],"tail":" for each fiscal year, the Secretary shall allot to each State an amount which bears the same ratio to the total amount appropriated under such section for such fiscal year as the population of the State bears to the population of all States, except that no State may receive less than $50,000 in each fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf046438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of the exception contained in subsection (a), the term “State” does not include Guam, American Samoa, the Virgin Islands, the Trust Territory of the Pacific Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf046439-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s670B"},"text":"Pub. L. 97–35, title VI, § 670B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/558/tI/s109"},"text":"Pub. L. 98–558, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2880"},"text":"98 Stat. 2880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf04643a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbf04643b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf04643c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
