],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411"},"text":"section 411 of Pub. L. 100–360","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G"},"text":"section 411(g)(3)(G) of Pub. L. 100–360","children":[],"tail":", as it relates to a provision in the Omnibus Budget Reconciliation Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", effective as if included in the enactment of that provision in "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/a"},"text":"section 411(a) of Pub. L. 100–360","children":[],"tail":", set out as a Reference to OBRA; Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s106"},"text":"section 106 of Title 1","children":[],"tail":", General Provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb90004af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4064/d/2"},"text":"Pub. L. 100–203, title IV, § 4064(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-111"},"text":"101 Stat. 1330–111","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tIV/s4064/d/2"},"text":"“The amendment made by paragraph (1) [enacting this section] shall become effective on ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}]