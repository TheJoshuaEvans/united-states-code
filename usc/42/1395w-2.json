{"tag":"section","attrib":{"id":"idb9000499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–2"},"text":"§ 1395w–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate sanctions for providers or suppliers of clinical diagnostic laboratory tests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb900049a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that any provider or clinical laboratory approved for participation under this subchapter no longer substantially meets the conditions of participation or for coverage specified under this subchapter with respect to the provision of clinical diagnostic laboratory tests under this part, the Secretary may (for a period not to exceed one year) impose intermediate sanctions developed pursuant to subsection (b), in lieu of terminating immediately the provider agreement or cancelling immediately approval of the clinical laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900049b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb900049c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall develop and implement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb900049d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a range of intermediate sanctions to apply to providers or clinical laboratories under the conditions described in subsection (a), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb900049e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate procedures for appealing determinations relating to the imposition of such sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900049f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90004a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The intermediate sanctions developed under paragraph (1) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90004a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directed plans of correction,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90004a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil money penalties in an amount not to exceed $10,000 for each day of substantial noncompliance,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90004a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment for the costs of onsite monitoring by an agency responsible for conducting surveys, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90004a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of all or part of the payments to which a provider or clinical laboratory would otherwise be entitled under this subchapter with respect to clinical diagnostic laboratory tests furnished on or after the date on which the Secretary determines that intermediate sanctions should be imposed pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" (other than subsections (a) and (b)) shall apply to a civil money penalty under clause (ii) in the same manner as such provisions apply to a penalty or proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/a"},"text":"section 1320a–7a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90004a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sanctions specified in subparagraph (A) are in addition to sanctions otherwise available under State or Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90004a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall develop and implement specific procedures with respect to when and how each of the intermediate sanctions developed under paragraph (1) is to be applied, the amounts of any penalties, and the severity of each of these penalties. Such procedures shall be designed so as to minimize the time between identification of violations and imposition of these sanctions and shall provide for the imposition of incrementally more severe penalties for repeated or uncorrected deficiencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90004a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1846, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4064/d/1"},"text":"Pub. L. 100–203, title IV, § 4064(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-111"},"text":"101 Stat. 1330–111","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/tII/s203/e/4"},"text":"Pub. L. 100–360, title II, § 203(e)(4)","children":[],"tail":", title IV, § 411(g)(3)(G), "},{"tag":"date","attrib":{"date":"1988-07-01"},"text":"July 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/725"},"text":"102 Stat. 725","children":[],"tail":", 784; "},{"tag":"ref","attrib":{"href":"/us/pl/100/485/tVI/s608/d/22/C"},"text":"Pub. L. 100–485, title VI, § 608(d)(22)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2421"},"text":"102 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/234/tII/s201/a"},"text":"Pub. L. 101–234, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-13"},"text":"Dec. 13, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1981"},"text":"103 Stat. 1981","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4154/e/2"},"text":"Pub. L. 101–508, title IV, § 4154(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-86"},"text":"104 Stat. 1388–86","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90004a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90004a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90004aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" substituted “providers or suppliers of” for “providers of” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/234"},"text":"Pub. L. 101–234","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s203/e/4"},"text":"Pub. L. 100–360, § 203(e)(4)","children":[],"tail":", and provided that the provisions of law amended or repealed by such section are restored or revived as if such section had not been enacted, see 1988 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s203/e/4/A"},"text":"Pub. L. 100–360, § 203(e)(4)(A)","children":[],"tail":", inserted “and for qualified home intravenous drug therapy providers” at end of section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/i/I"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(i)(I)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":", substituted “approved” for “certified”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/i/II"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(i)(II)","children":[],"tail":", inserted “or for coverage” after “conditions of participation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/i/III"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(i)(III)","children":[],"tail":", which directed amendment of subsec. (a) by substituting “terminating immediately the provider agreement or cancelling immediately approval of the clinical laboratory” for “cancelling immediately the certification of the provider or clinical laboratory”, was executed by making the substitution for “canceling immediately the certification of the provider or clinical laboratory” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s203/e/4/B"},"text":"Pub. L. 100–360, § 203(e)(4)(B)","children":[],"tail":", inserted “or that a qualified home intravenous drug therapy provider that is certified for participation under this subchapter no longer substantially meets the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/jj/3"},"text":"section 1395x(jj)(3) of this title","children":[],"tail":"” after “under this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/ii"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(ii)","children":[],"tail":", struck out “certified” before “clinical laboratories”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/iv"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(iv)","children":[],"tail":", inserted at end “The provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" (other than subsections (a) and (b)) shall apply to a civil money penalty under clause (ii) in the same manner as such provisions apply to a penalty or proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/a"},"text":"section 1320a–7a(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/iii"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(iii)","children":[],"tail":", substituted “civil money penalties in an amount not to exceed $10,000 for each day of substantial noncompliance” for “civil fines and penalties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/v"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(v)","children":[],"tail":", struck out “certification” before “surveys”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/ii"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(ii)","children":[],"tail":", (vi), struck out “certified” before “clinical laboratory” and substituted “furnished on or after the date on” for “provided on or after the date in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s203/e/4/C"},"text":"Pub. L. 100–360, § 203(e)(4)(C)","children":[],"tail":", inserted “or home intravenous drug therapy services” after “clinical diagnostic laboratory tests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/g/3/G/vii"},"text":"Pub. L. 100–360, § 411(g)(3)(G)(vii)","children":[],"tail":", substituted “any penalties” for “any fines” and “severe penalties” for “severe fines”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90004ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90004ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective as if included in the enactment of the Omnibus Budget Reconciliation Act of 1989, "},{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4154/e/5"},"text":"section 4154(e)(5) of Pub. L. 101–508","children":[],"tail":", set out as a note under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90004ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib"