{"tag":"section","attrib":{"id":"idc0786647-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059"},"text":null,"children":[{"tag":"num","attrib":{"value":"19059"},"text":"§ 19059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable chemistry research and education","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9303"},"text":"section 9303 of title 15","children":[],"tail":", the Director shall carry out activities in support of sustainable chemistry, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0786648-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing a program to make awards, on a competitive basis, to institutions of higher education or non-profit organizations (or consortia of such institutions or organizations) to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0786649-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual investigators and teams of investigators, including to the extent practicable, early career investigators for research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc078664a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative research and development partnerships among universities, industry, and non-profit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc078664b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating sustainable chemistry principles into elementary, secondary, undergraduate, and graduate chemistry and chemical engineering curriculum and research training, as appropriate to that level of education and training; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc078664c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19059/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating sustainable chemistry into existing Foundation research and development programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc078664d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10350"},"text":"Pub. L. 117–167, div. B, title III, § 10350","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1560"},"text":"136 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
