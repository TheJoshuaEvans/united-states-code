{"tag":"section","attrib":{"id":"idbe07b585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i"},"text":null,"children":[{"tag":"num","attrib":{"value":"7383i"},"text":"§ 7383i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions of national laboratory and nuclear weapons production facility","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “national laboratory” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Lawrence Livermore National Laboratory, Livermore, California.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Los Alamos National Laboratory, Los Alamos, New Mexico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Sandia National Laboratories, Albuquerque, New Mexico and Livermore, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b58a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “nuclear weapons production facility” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b58b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Kansas City Plant, Kansas City, Missouri.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b58c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Pantex Plant, Amarillo, Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b58d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Y–12 Plant, Oak Ridge, Tennessee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b58e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tritium operations at the Savannah River Site, Aiken, South Carolina.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b58f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7383i/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nevada Test Site, Nevada.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b590-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXI/s3155"},"text":"Pub. L. 106–65, div. C, title XXXI, § 3155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/942"},"text":"113 Stat. 942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe07b591-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe07b592-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe07b593-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle D of title XXXI of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/931"},"text":"113 Stat. 931","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle D to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7383"},"text":"section 7383 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
