{"tag":"section","attrib":{"id":"idb4983d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244"},"text":null,"children":[{"tag":"num","attrib":{"value":"244"},"text":"§ 244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access defibrillation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4983d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to States, political subdivisions of States, Indian tribes, and tribal organizations to develop and implement public access defibrillation programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4983d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by training and equipping local emergency medical services personnel, including firefighters, police officers, paramedics, emergency medical technicians, and other first responders, to administer immediate care, including cardiopulmonary resuscitation and automated external defibrillation, to cardiac arrest victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchasing automated external defibrillators, placing the defibrillators in public places where cardiac arrests are likely to occur, and training personnel in such places to administer cardiopulmonary resuscitation and automated external defibrillation to cardiac arrest victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by setting procedures for proper maintenance and testing of such devices, according to the guidelines of the manufacturers of the devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing training to members of the public in cardiopulmonary resuscitation and automated external defibrillation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by integrating the emergency medical services system with the public access defibrillation programs so that emergency medical services personnel, including dispatchers, are informed about the location of automated external defibrillators in their community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by encouraging private companies, including small businesses, to purchase automated external defibrillators and provide training for their employees to administer cardiopulmonary resuscitation and external automated defibrillation to cardiac arrest victims in their community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Secretary shall give a preference to a State, political subdivision of a State, Indian tribe, or tribal organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4983d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a particularly low local survival rate for cardiac arrests, or a particularly low local response rate for cardiac arrest victims; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates in its application the greatest commitment to establishing and maintaining a public access defibrillation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, political subdivision of a State, Indian tribe, or tribal organization that receives a grant under subsection (a) may use funds received through such grant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4983d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase automated external defibrillators that have been approved, or cleared for marketing, by the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide automated external defibrillation and basic life support training in automated external defibrillator usage through nationally recognized courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to community members about the public access defibrillation program to be funded with the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to the local emergency medical services system regarding the placement of automated external defibrillators in public places;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce materials to encourage private companies, including small businesses, to purchase automated external defibrillators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an information clearinghouse, that shall be administered by an organization that has substantial expertise in pediatric education, pediatric medicine, and electrophysiology and sudden death, that provides information to increase public access to defibrillation in schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further develop strategies to improve access to automated external defibrillators in public places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4983d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a), a State, political subdivision of a State, Indian tribe, or tribal organization shall prepare and submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4983d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4983d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the comprehensive public access defibrillation program to be funded with the grant and demonstrate how such program would make automated external defibrillation accessible and available to cardiac arrest victims in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4983d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain procedures for implementing appropriate nationally recognized training courses in performing cardiopulmonary resuscitation and the use of automated external defibrillators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4983d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain procedures for ensuring direct involvement of a licensed medical professional and coordination with the local emergency medical services system in the oversight of training and notification of incidents of the use of the automated external defibrillators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4983d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain procedures for proper maintenance and testing of the automated external defibrillators, according to the labeling of the manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4983d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain procedures for ensuring notification of local emergency medical services system personnel, including dispatchers, of the location and type of devices used in the public access defibrillation program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4983d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the collection of data regarding the effectiveness of the public access defibrillation program to be funded with the grant in affecting the out-of-hospital cardiac arrest survival rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4983d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated $25,000,000 for for ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" each of fiscal years 2003 through 2014. Not more than 10 percent of amounts received under a grant awarded under this section may be used for administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4983d7c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s159/c"},"text":"Pub. L. 107–188, title I, § 159(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/634"},"text":"116 Stat. 634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/41/s2"},"text":"Pub. L. 108–41, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-07-01"},"text":"July 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/839"},"text":"117 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10412"},"text":"Pub. L. 111–148, title X, § 10412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/990"},"text":"124 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4983d7d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4983d7e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4983d7f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 244, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312, "},{"tag":"ref","attrib":{"href":"/us/stat/58/693"},"text":"58 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-03/ch538/s8"},"text":"July 3, 1946, ch. 538, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/424"},"text":"60 Stat. 424","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s12/b"},"text":"Pub. L. 90–174, § 12(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/541"},"text":"81 Stat. 541","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-10-30"},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/515/tII/s282"},"text":"Pub. L. 91–515, title II, § 282","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1308"},"text":"84 Stat. 1308","children":[],"tail":", provided for health conferences, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tI/s102/a"},"text":"Pub. L. 93–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/362"},"text":"88 Stat. 362","children":[],"tail":". See section 242"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 312 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s244–1"},"text":"section 244–1 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4983d80-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10412/1"},"text":"Pub. L. 111–148, § 10412(1)","children":[],"tail":", inserted “, that shall be administered by an organization that has substantial expertise in pediatric education, pediatric medicine, and electrophysiology and sudden death,” after “clearinghouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10412/2"},"text":"Pub. L. 111–148, § 10412(2)","children":[],"tail":", substituted “for each of fiscal years 2003 through 2014” for “fiscal year 2003, and such sums as may be necessary for each of the fiscal years 2004 through 2006”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/41"},"text":"Pub. L. 108–41","children":[],"tail":" added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4983d81-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4983d82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s159/b"},"text":"Pub. L. 107–188, title I, § 159(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/634"},"text":"116 Stat. 634","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/188/tI/s159/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over 220,000 Americans die each year from cardiac arrest. Every 2 minutes, an individual goes into cardiac arrest in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chance of successfully returning to a normal heart rhythm diminishes by 10 percent each minute following sudden cardiac arrest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eighty percent of cardiac arrests are caused by ventricular fibrillation, for which defibrillation is the only effective treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sixty percent of all cardiac arrests occur outside the hospital. The average national survival rate for out-of-hospital cardiac arrest is only 5 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communities that have established and implemented public access defibrillation programs have achieved average survival rates for out-of-hospital cardiac arrest as high as 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the American Heart Association, wide use of defibrillators could save as many as 50,000 lives nationally each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Successful public access defibrillation programs ensure that cardiac arrest victims have access to early 911 notification, early cardiopulmonary resuscitation, early defibrillation, and early advanced care.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
