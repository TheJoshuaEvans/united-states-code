{"tag":"section","attrib":{"id":"idbce728d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4908"},"text":null,"children":[{"tag":"num","attrib":{"value":"4908"},"text":"§ 4908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall, in consultation with the Administrator, issue regulations to carry out the provisions of this chapter with respect to new products imported or offered for importation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce728d1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/574/s9"},"text":"Pub. L. 92–574, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1242"},"text":"86 Stat. 1242","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
