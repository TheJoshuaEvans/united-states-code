{"tag":"section","attrib":{"id":"idbf6aeec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351"},"text":null,"children":[{"tag":"num","attrib":{"value":"12351"},"text":"§ 12351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aeec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fundamental changes in the demographics and economics of family life in the United States over the past 20 years have had a profound effect on children and their parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since 1966, the number of women working outside the home has increased by 92 percent and the number of two earner families has increased by over 50 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 61 percent of the children born today will live in a single-parent family before reaching the age of 20, with one out of every three single female heads of households living on income below the Federal poverty level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one out of every four children under the age of 6 in the United States currently lives below the Federal poverty level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the past 10 years, parents have increasingly come together with other parents to organize family resource and support programs that promote healthy child development and increase parental competency, particularly families at risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal investment in promoting the development of family resource and support programs will reap long-term benefits for individual families and the nation as a whole.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this part ","children":[{"tag":"ref","attrib":{"idref":"fn004047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeeca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate the development and expansion of family resource and support programs that are prevention oriented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage early intervention of such programs with families to ameliorate problem situations before such situations become crises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist parents in enhancing their children’s development to ensure that their children enter school prepared and ready to learn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aeecd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s956"},"text":"Pub. L. 101–501, title IX, § 956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1278"},"text":"104 Stat. 1278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aeece-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aeecf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6aeed0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b), was in the original “this Act”, and was translated as reading “this chapter”, meaning chapter 3 (§§ 955–960) of subtitle A of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":", known as the Family Resources Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aeed1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aeed2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
