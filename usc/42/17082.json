{"tag":"section","attrib":{"id":"idc0227ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082"},"text":null,"children":[{"tag":"num","attrib":{"value":"17082"},"text":"§ 17082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero Net Energy Commercial Buildings Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consortium” means a High-Performance Green Building Consortium selected by the Commercial Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “initiative” means the Zero-Net-Energy Commercial Buildings Initiative established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-net-energy commercial building","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-net-energy commercial building” means a high-performance commercial building that is designed, constructed, and operated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a greatly reduced quantity of energy to operate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the balance of energy needs from sources of energy that do not produce greenhouse gases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that will result in no net emissions of greenhouse gases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be economically viable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commercial Director shall establish an initiative, to be known as the “Zero-Net-Energy Commercial Buildings Initiative”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the quantity of energy consumed by commercial buildings located in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve the development of zero net energy commercial buildings in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consortium","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227ed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Commercial Director shall competitively select, and enter into an agreement with, a consortium to develop and carry out the initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In entering into an agreement with a consortium under subparagraph (A), the Commercial Director shall use the authority described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7256/g"},"text":"section 7256(g) of this title","children":[],"tail":", to the maximum extent practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal of initiative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goal of the initiative shall be to develop and disseminate technologies, practices, and policies for the development and establishment of zero net energy commercial buildings for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commercial building newly constructed in the United States by 2030;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the commercial building stock of the United States by 2040; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all commercial buildings in the United States by 2050.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the initiative, the Commercial Director, in consultation with the consortium, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research and development on building science, design, materials, components, equipment and controls, operation and other practices, integration, energy use measurement, and benchmarking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct pilot programs and demonstration projects to evaluate replicable approaches to achieving energy efficient commercial buildings for a variety of building types in a variety of climate zones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct deployment, dissemination, and technical assistance activities to encourage widespread adoption of technologies, practices, and policies (including demand-response technologies, practices, and policies) to achieve energy efficient commercial buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct other research, development, demonstration, and deployment activities necessary to achieve each goal of the initiative, as determined by the Commercial Director, in consultation with the consortium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop training materials and courses for building professionals and trades on achieving cost-effective high-performance energy efficient buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and disseminate public education materials to share information on the benefits and cost-effectiveness of high-performance energy efficient buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support code-setting organizations and State and local governments in developing minimum performance standards in building codes that recognize the ready availability of many technologies utilized in high-performance energy efficient buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop strategies for overcoming the split incentives between builders and purchasers, and landlords and tenants, to ensure that energy efficiency and high-performance investments are made that are cost-effective on a lifecycle basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop improved means of measurement and verification of energy savings and performance for public dissemination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024eee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Commercial Director shall require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024eee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024eee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eeea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for each of fiscal years 2009 and 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eeeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for each of fiscal years 2011 and 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024eeec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17082/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 for each of fiscal years 2013 through 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc024eeed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s422"},"text":"Pub. L. 110–140, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1604"},"text":"121 Stat. 1604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tI/s40104/d"},"text":"Pub. L. 117–58, div. D, title I, § 40104(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/933"},"text":"135 Stat. 933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc024eeee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc024eeef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc024eef0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" inserted “(including demand-response technologies, practices, and policies)” after “policies”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc024eef1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc024eef2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc024eef3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
