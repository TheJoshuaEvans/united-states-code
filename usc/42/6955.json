{"tag":"section","attrib":{"id":"idbddf1dd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6955"},"text":null,"children":[{"tag":"num","attrib":{"value":"6955"},"text":"§ 6955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing policies, establishment; nondiscrimination requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In establishing any policies which may affect the development of new markets for recovered materials and in making any determination concerning whether or not to impose monitoring or other controls on any marketing or transfer of recovered materials, the Secretary of Commerce may consider whether to establish the same or similar policies or impose the same or similar monitoring or other controls on virgin materials.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbddf1dd2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s5005"},"text":"Pub. L. 89–272, title II, § 5005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/482/s21/c/1"},"text":"Pub. L. 96–482, § 21(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2346"},"text":"94 Stat. 2346","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
