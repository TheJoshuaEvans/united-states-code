{"tag":"section","attrib":{"id":"idbda12a7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6373"},"text":null,"children":[{"tag":"num","attrib":{"value":"6373"},"text":"§ 6373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Off-highway motor vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", the Secretary of Transportation shall complete a study of the energy conservation potential of recreational motor vehicles, including, but not limited to, aircraft and motor boats which are designed for recreational use, and shall submit a report to the President and to the Congress containing the results of such study."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbda12a7f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s385"},"text":"Pub. L. 94–163, title III, § 385","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s681/a"},"text":"Pub. L. 95–619, title VI, § 681(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3286"},"text":"92 Stat. 3286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
