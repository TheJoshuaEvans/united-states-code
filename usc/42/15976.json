{"tag":"section","attrib":{"id":"idbfee288b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15976"},"text":null,"children":[{"tag":"num","attrib":{"value":"15976"},"text":"§ 15976.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electron scrubbing demonstration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall use $5,000,000 from amounts appropriated to initiate, through the Chicago Operations Office, a project to demonstrate the viability of high-energy electron scrubbing technology on commercial-scale electrical generation using high-sulfur coal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfee288c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s416"},"text":"Pub. L. 109–58, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/756"},"text":"119 Stat. 756","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
