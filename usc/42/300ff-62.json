{"tag":"section","attrib":{"id":"idb6a01a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–62"},"text":"§ 300ff–62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certain counseling services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a01a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling of individuals with negative test results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, if the results of testing conducted for HIV/AIDS indicate that an individual does not have such condition, the applicant will provide the individual information, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for prevention of, exposure to, and transmission of HIV/AIDS, hepatitis B, hepatitis C, and other sexually transmitted diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy and reliability of results of testing for HIV/AIDS, hepatitis B, and hepatitis C;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the results of such testing, including the potential for developing AIDS, hepatitis B, or hepatitis C;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of further counseling, testing, and education of the individual regarding HIV/AIDS and other sexually transmitted diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if diagnosed with chronic hepatitis B or hepatitis C co-infection, the potential of developing hepatitis-related liver disease and its impact on HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the availability of hepatitis B vaccine and information about hepatitis treatments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling of individuals with positive test results","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, if the results of testing for HIV/AIDS indicate that the individual has such condition, the applicant will provide to the individual appropriate counseling regarding the condition, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a01a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for prevention of, exposure to, and transmission of HIV/AIDS, hepatitis B, and hepatitis C;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy and reliability of results of testing for HIV/AIDS, hepatitis B, and hepatitis C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the results of such testing, including the potential for developing AIDS, hepatitis B, or hepatitis C;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the appropriateness of further counseling, testing, and education of the individual regarding HIV/AIDS and other sexually transmitted diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01aa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing counseling—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a01aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the availability, through the applicant, of early intervention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the availability in the geographic area of appropriate health care, mental health care, and social and support services, including providing referrals for such services, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a01aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that explains the benefits of locating and counseling any individual by whom the infected individual may have been exposed to HIV/AIDS, hepatitis B, or hepatitis C and any individual whom the infected individual may have exposed to HIV/AIDS, hepatitis B, or hepatitis C; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a01aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that emphasizes it is the duty of infected individuals to disclose their infected status to their sexual partners and their partners in the sharing of hypodermic needles; that provides advice to infected individuals on the manner in which such disclosures can be made; and that emphasizes that it is the continuing duty of the individuals to avoid any behaviors that will expose others to HIV/AIDS, hepatitis B, or hepatitis C; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a01aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the availability of the services of public health authorities with respect to locating and counseling any individual described in subparagraph (C);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if diagnosed with chronic hepatitis B or hepatitis C co-infection, the potential of developing hepatitis-related liver disease and its impact on HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a01aaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the availability of hepatitis B vaccine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01aab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements regarding appropriate counseling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part unless the applicant for the grant agrees that, in counseling individuals with respect to HIV/AIDS, the applicant will ensure that the counseling is provided under conditions appropriate to the needs of the individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01aac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling of emergency response employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this part to a State unless the State agrees that, in counseling individuals with respect to HIV/AIDS, the State will ensure that, in the case of emergency response employees, the counseling is provided to such employees under conditions appropriate to the needs of the employees regarding the counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a01aad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–62/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding counseling without testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agreements made pursuant to this section may not be construed to prohibit any grantee under this part from expending the grant for the purpose of providing counseling services described in this section to an individual who does not undergo testing for HIV/AIDS as a result of the grantee or the individual determining that such testing of the individual is not appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a01aae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2662, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tIII/s301/a"},"text":"Pub. L. 101–381, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/610"},"text":"104 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/345/tIII/s321"},"text":"Pub. L. 106–345, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-20"},"text":"Oct. 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1346"},"text":"114 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tIII/s305"},"text":"Pub. L. 109–415, title III, § 305","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2807"},"text":"120 Stat. 2807","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a01aaf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a01ab0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a01ab1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s305"},"text":"Pub. L. 109–415, § 305","children":[],"tail":", reenacted heading without change and amended text generally, substituting provisions relating to counseling of individuals after testing for HIV/AIDS, appropriateness of conditions, counseling of emergency response employees, and counseling without testing, for provisions relating to counseling of individuals before and after testing, appropriateness of conditions, counseling of emergency response employees, and counseling without testing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s321/1"},"text":"Pub. L. 106–345, § 321(1)","children":[],"tail":", in introductory provisions struck out “on” after “counseling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s321/2"},"text":"Pub. L. 106–345, § 321(2)","children":[],"tail":", inserted “on” before “the availability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s321/3"},"text":"Pub. L. 106–345, § 321(3)","children":[],"tail":", designated existing provisions as cl. (i), inserted “that explains” before “the benefits”, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/345/s321/2"},"text":"Pub. L. 106–345, § 321(2)","children":[],"tail":", inserted “on” before “the availability”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a01ab2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6a01ab3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", and that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, see section 2(a)(2), (3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
