{"tag":"section","attrib":{"id":"idb5b40d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–36c"},"text":"§ 290bb–36c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Suicide Prevention Lifeline program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b40d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary, shall maintain the National Suicide Prevention Lifeline program (referred to in this section as the “program”), authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–32"},"text":"section 290bb–32 of this title","children":[],"tail":" and in effect prior to "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In maintaining the program, the activities of the Secretary shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and coordinating a network of crisis centers across the United States for providing suicide prevention and mental health crisis intervention services, including appropriate follow-up services, to individuals seeking help at any time, day or night;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a suicide prevention hotline to link callers to local emergency, mental health, and social services resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with the Secretary of Veterans Affairs to ensure that veterans calling the suicide prevention hotline have access to a specialized veterans’ suicide prevention hotline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving awareness of the program for suicide prevention and mental health crisis intervention services, including by conducting an awareness initiative and ongoing outreach to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the collection and analysis of demographic information, in a manner that protects personal privacy, consistent with applicable Federal and State privacy laws, in order to understand disparities in access to the program among individuals who are seeking help; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking such steps as may be necessary to ensure the suicide prevention hotline is protected from cybersecurity incidents and eliminates known cybersecurity vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of supporting the crisis centers under subsection (b)(1) and maintaining the suicide prevention hotline under subsection (b)(2), the Secretary shall develop and implement a plan to ensure the provision of high-quality services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program evaluation, including performance measures to assess progress toward the goals and objectives of the program and to improve the responsiveness and performance of the hotline, including at all backup call centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Requirements that crisis centers and backup centers must meet—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b40d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in the network under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b40d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that each telephone call and applicable other communication received by the hotline, including at backup call centers, is answered in a timely manner, consistent with evidence-based guidance or other guidance or best practices, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specific recommendations and strategies for implementing evidence-based practices, including with respect to followup and communicating the availability of resources in the community for individuals in need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria for carrying out periodic testing of the hotline during each fiscal year, including at crisis centers and backup centers, to identify and address any problems in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing requirements under paragraph (2)(B), the Secretary shall consult with State departments of health, local governments, Indian Tribes, and Tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial plan; updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", complete development of the initial plan under paragraph (1) and make such plan publicly available; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically thereafter, update such plan and make the updated plan publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving epidemiological data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate, formalize and strengthen agreements between the Suicide Prevention Lifeline program and the Centers for Disease Control and Prevention with respect to the secure sharing of de-identified epidemiological data. Such agreements shall include appropriate privacy and security protections that meet the requirements of applicable Federal law, at a minimum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data to assist State and local suicide prevention activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the aggregated information collected and any applicable analyses conducted under subsection (b)(5), including from local call centers, as applicable, are made available in a usable format to State and local agencies in order to inform suicide prevention activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program’s network administrator receiving Federal funding pursuant to subsection (a) shall report to the Assistant Secretary, in a manner that protects personal privacy, consistent with applicable Federal and State privacy laws—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b40d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified cybersecurity vulnerabilities to the program within a reasonable amount of time after identification of such a vulnerability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b40d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified cybersecurity incidents to the program within a reasonable amount of time after identification of such incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and regional crisis centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Local and regional crisis centers participating in the program shall report to the program’s network administrator identified under subparagraph (A), in a manner that protects personal privacy, consistent with applicable Federal and State privacy laws—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b40d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified cybersecurity vulnerabilities to the program within a reasonable amount of time after identification of such vulnerability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b40d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified cybersecurity incidents to the program within a reasonable amount of time after identification of such incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the program’s network administrator receiving funding pursuant to subsection (a) discovers, or is informed by a local or regional crisis center pursuant to paragraph (1)(B) of, a cybersecurity vulnerability or incident, within a reasonable amount of time after such discovery or receipt of information, such entity shall report the vulnerability or incident to the Assistant Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b40d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and regional crisis centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), local and regional crisis centers participating in the program shall oversee all technology each center employs in the provision of services as a participant in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b40d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program’s network administrator receiving Federal funding pursuant to subsection (a) shall oversee the technology each crisis center employs in the provision of services as a participant in the program if such oversight responsibilities are established in the applicable network participation agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cybersecurity incident reporting requirements under this subsection shall supplement, and not supplant, cybersecurity incident reporting requirements under other provisions of applicable Federal law that are in effect on ","children":[{"tag":"date","attrib":{"date":"2025-12-01"},"text":"December 1, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40d8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–36c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $101,621,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b40d8b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520E–3, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9005"},"text":"Pub. L. 114–255, div. B, title IX, § 9005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1239"},"text":"130 Stat. 1239","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1103/a"},"text":"Pub. L. 117–328, div. FF, title I, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5637"},"text":"136 Stat. 5637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/44/tI/s108/a"},"text":"Pub. L. 119–44, title I, § 108(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2025-12-01"},"text":"Dec. 1, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/675"},"text":"139 Stat. 675","children":[],"tail":", 676.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b40d8c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b40d8d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b40d8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s108/a"},"text":"Pub. L. 119–44, § 108(a)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/44/s108/b"},"text":"Pub. L. 119–44, § 108(b)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/1/A"},"text":"Pub. L. 117–328, § 1103(a)(1)(A)","children":[],"tail":", inserted “supporting and” before “coordinating” and substituted “mental health crisis intervention services, including appropriate follow-up services,” for “crisis intervention services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/1/B"},"text":"Pub. L. 117–328, § 1103(a)(1)(B)","children":[],"tail":"–(D), added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/2/B"},"text":"Pub. L. 117–328, § 1103(a)(2)(B)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/3"},"text":"Pub. L. 117–328, § 1103(a)(3)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/4"},"text":"Pub. L. 117–328, § 1103(a)(4)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “To carry out this section, there are authorized to be appropriated $7,198,000 for each of fiscal years 2018 through 2022.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1103/a/2/A"},"text":"Pub. L. 117–328, § 1103(a)(2)(A)","children":[],"tail":", redesignated subsec. (c) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5b40d8f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5b40d90-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Innovative Technologies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1103/b"},"text":"Pub. L. 117–328, div. FF, title I, § 1103(b)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5639"},"text":"136 Stat. 5639","children":[],"tail":", 5640, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dFF/tI/s1103/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot Program on Innovative Technologies.—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Assistant Secretary for Mental Health and Substance Use, shall, as appropriate, carry out a pilot program to research, analyze, and employ various technologies and platforms of communication (including social media platforms, texting platforms, and email platforms) for suicide prevention in addition to the telephone and online chat service provided by the Suicide Prevention Lifeline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 24 months after the date on which the pilot program under paragraph (1) commences, the Secretary of Health and Human Services, acting through the Assistant Secretary for Mental Health and Substance Use, shall submit to the Congress a report on the pilot program. With respect to each platform of communication employed pursuant to the pilot program, the report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full description of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals served by the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average wait time for each individual to receive a response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the program, including the cost per individual served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Suicide Prevention Lifeline’ means the suicide prevention hotline maintained pursuant to section 520E–3 of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–36c"},"text":"42 U.S.C. 290bb–36c","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
