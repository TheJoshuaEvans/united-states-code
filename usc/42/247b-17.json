{"tag":"section","attrib":{"id":"idb4ab5027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–17"},"text":"§ 247b–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human papillomavirus (Johanna’s Law)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4ab5028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveillance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab5029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab502a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements with States and other entities to conduct sentinel surveillance or other special studies that would determine the prevalence in various age groups and populations of specific types of human papillomavirus (referred to in this section as “HPV”) in different sites in various regions of the United States, through collection of special specimens for HPV using a variety of laboratory-based testing and diagnostic tools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab502b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and analyze data from the HPV sentinel surveillance system described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab502c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a progress report to the Congress with respect to paragraph (1) no later than 1 year after the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab502d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention activities; education program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab502e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Centers for Disease Control and Prevention, shall conduct prevention research on HPV, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab502f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavioral and other research on the impact of HPV-related diagnosis on individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formative research to assist with the development of educational messages and information for the public, for patients, and for their partners about HPV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveys of physician and public knowledge, attitudes, and practices about genital HPV infection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the completion of and based on the findings under subparagraphs (A) through (C), develop and disseminate educational materials for the public and health care providers regarding HPV and its impact and prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab5033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report; final proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a progress report to the Congress with respect to paragraph (1) not later than 1 year after the effective date of this section, and shall develop a final report not later than 3 years after such effective date, including a detailed summary of the significant findings and problems and the best strategies to prevent future infections, based on available science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab5034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HPV education and prevention","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab5035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare and distribute educational materials for health care providers and the public that include information on HPV. Such materials shall address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab5036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modes of transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consequences of infection, including the link between HPV and cervical cancer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the available scientific evidence on the effectiveness or lack of effectiveness of condoms in preventing infection with HPV; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of regular Pap smears, and other diagnostics for early intervention and prevention of cervical cancer purposes in preventing cervical cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab503a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medically accurate information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Educational material under paragraph (1), and all other relevant educational and prevention materials prepared and printed from this date forward for the public and health care providers by the Secretary (including materials prepared through the Food and Drug Administration, the Centers for Disease Control and Prevention, and the Health Resources and Services Administration), or by contractors, grantees, or subgrantees thereof, that are specifically designed to address STDs including HPV shall contain medically accurate information regarding the effectiveness or lack of effectiveness of condoms in preventing the STD the materials are designed to address. Such requirement only applies to materials mass produced for the public and health care providers, and not to routine communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab503b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Johanna’s Law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab503c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National public awareness campaign","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4ab503d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a national campaign to increase the awareness and knowledge of health care providers and women with respect to gynecologic cancers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab503e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under the national campaign under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4ab503f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a supply of written materials that provide information to the public on gynecologic cancers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4ab5040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributing the materials to members of the public upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4ab5041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public service announcements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under the national campaign under subparagraph (A) shall, in accordance with applicable law and regulations, include developing and placing, in telecommunications media, public service announcements intended to encourage women to discuss with their physicians their risks of gynecologic cancers. Such announcements shall inform the public on the manner in which the written materials referred to in subparagraph (B) can be obtained upon request, and shall call attention to early warning signs and risk factors based on the best available medical information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and strategy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4adc043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2007-01-12"},"text":"January 12, 2007","children":[],"tail":", the Secretary shall submit to the Congress a report including the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idb4adc044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the past and present activities of the Department of Health and Human Services to increase awareness and knowledge of the public with respect to different types of cancer, including gynecologic cancers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4adc045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the past and present activities of the Department of Health and Human Services to increase awareness and knowledge of health care providers with respect to different types of cancer, including gynecologic cancers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4adc046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each activity described pursuant to clause (i) or (ii), a description of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4adc047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The funding for such activity for fiscal year 2006 and the cumulative funding for such activity for previous fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4adc048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The background and history of such activity, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb4adc049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of such activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4adc04a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communications objectives of such activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4adc04b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of each agency within the Department of Health and Human Services responsible for any aspect of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4adc04c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such activity is or was expected to result in change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4adc04d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How long the activity lasted or is expected to last.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4adc04e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The outcomes observed and the evaluation methods, if any, that have been, are being, or will be used with respect to such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4adc04f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/A/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each such outcome or evaluation method, a description of the associated results, analyses, and conclusions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4adc050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4adc051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development; submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 months after submitting the report required by subparagraph (A), the Secretary shall develop and submit to the Congress a strategy for improving efforts to increase awareness and knowledge of the public and health care providers with respect to different types of cancer, including gynecological cancers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4adc052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the strategy under clause (i), the Secretary should consult with qualified private sector groups, including nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full compliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4adc054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-03-01"},"text":"March 1, 2008","children":[],"tail":", the Secretary shall ensure that all provisions of this section, including activities directed to be carried out by the Centers for Disease Control and Prevention and the Food and Drug Administration, are fully implemented and being complied with. Not later than "},{"tag":"date","attrib":{"date":"2008-04-30"},"text":"April 30, 2008","children":[],"tail":", the Secretary shall submit to Congress a report that certifies compliance with the preceding sentence and that contains a description of all activities undertaken to achieve such compliance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4adc055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary fails to submit the certification as provided for under subparagraph (A), the Secretary shall, not later than 3 months after the date on which the report is to be submitted under subparagraph (A), and every 3 months thereafter, submit to Congress an explanation as to why the Secretary has not yet complied with the first sentence of subparagraph (A), a detailed description of all actions undertaken within the month for which the report is being submitted to bring the Secretary into compliance with such sentence, and the anticipated date the Secretary expects to be in full compliance with such sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with nonprofit gynecologic cancer organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the national campaign under this subsection, the Secretary shall consult with nonprofit gynecologic cancer organizations, with a mission both to conquer ovarian or other gynecologic cancer and to provide outreach to State and local governments and communities, for the purpose of determining the best practices for providing gynecologic cancer information and outreach services to varied populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4adc057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–17/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (5) has been enacted."}],"tail":" Authorization of appropriations"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subsection, there is authorized to be appropriated $16,500,000 for the period of fiscal years 2007 through 2009 and $18,000,000 for the period of fiscal years 2012 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4adc058-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 317P, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tV/s516/a"},"text":"Pub. L. 106–554, § 1(a)(1) [title V, § 516(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–72; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/475/s2"},"text":"Pub. L. 109–475, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3565"},"text":"120 Stat. 3565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/324/s1"},"text":"Pub. L. 111–324, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3536"},"text":"124 Stat. 3536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4adc059-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4adc05a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4adc05b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Johanna’s Law, referred to in section catchline and subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/475"},"text":"Pub. L. 109–475","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3565"},"text":"120 Stat. 3565","children":[],"tail":", also known as the Gynecologic Cancer Education and Awareness Act of 2005, which amended this section. For complete classification of this Act to the Code, see Short Title of 2007 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsecs. (a)(2) and (b)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4adc05c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/324/s1/b"},"text":"Pub. L. 111–324, § 1(b)","children":[],"tail":", added par. (4). Former par. (4) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/324/s1/a/1"},"text":"Pub. L. 111–324, § 1(a)(1)","children":[],"tail":", inserted “and $18,000,000 for the period of fiscal years 2012 through 2014” after “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/324/s1/a/2"},"text":"Pub. L. 111–324, § 1(a)(2)","children":[],"tail":", redesignated par. (4) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/475/s2/1"},"text":"Pub. L. 109–475, § 2(1)","children":[],"tail":", inserted “(Johanna’s Law)” after “papillomavirus” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/475/s2/2"},"text":"Pub. L. 109–475, § 2(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
