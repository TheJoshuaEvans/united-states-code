{"tag":"section","attrib":{"id":"idbfa1b5a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807"},"text":null,"children":[{"tag":"num","attrib":{"value":"12807"},"text":"§ 12807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income housing conservation and efficiency grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa1b5a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available a model program to provide safe, energy-efficient affordable housing for low-income persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa1b5a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The model program shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa1b5a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identification of housing that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa1b5aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned and occupied by low-income families who have received, are currently receiving, or are scheduled to receive assistance under the weatherization assistance for low-income persons program under part A of title IV of the Energy Conservation and Production Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6861"},"text":"42 U.S.C. 6861","children":[],"tail":" et seq.] (or a comparable Federal or State program);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b5ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in danger of becoming uninhabitable within a 5-year period because of structural weaknesses or problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa1b5ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not sufficiently sound to permit energy conservation improvements without other repair or rehabilitation measures to protect such energy investments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repairs that will significantly prolong the habitability of units identified under paragraph (1), including roofing, electrical, plumbing, furnace, and foundation repairs or replacement that will prolong the use of the unit as a safe and energy-efficient residence for low-income persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa1b5ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12807/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable steps to ensure that any units so repaired will remain occupied by persons or families eligible for assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa1b5af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tII/s257"},"text":"Pub. L. 101–625, title II, § 257","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4122"},"text":"104 Stat. 4122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa1b5b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa1b5b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa1b5b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Energy Conservation and Production Act, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385"},"text":"Pub. L. 94–385","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1142"},"text":"90 Stat. 1142","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 6861 et seq.) of subchapter III of chapter 81 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6801"},"text":"section 6801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
