{"tag":"section","attrib":{"id":"idbb888394-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862l"},"text":"§ 1862l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National research facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb888395-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb888396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall prepare, and include as part of the Foundation’s annual budget request to Congress, a plan for the proposed construction of, and repair and upgrades to, national research facilities, including full life-cycle cost information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb888397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of the plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb888398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of the costs for the construction, repairs, and upgrades described in paragraph (1), including costs for instrumentation development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb888399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of the costs for the operation and maintenance of existing and proposed new facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb88839a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of proposed new construction and for major upgrades to existing facilities, funding profiles, by fiscal year, and milestones for major phases of the construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb88839b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each project funded under the major research equipment and facilities construction account and for major upgrades of facilities in support of Antarctic research programs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb88839c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of the total project cost (from planning to commissioning); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb88839d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of funds, including Federal funding identified by appropriations category and non-Federal funding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb88839e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of the full life-cycle cost of each national research facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb88839f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on any plans to retire national research facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8883a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of funding levels for grants supporting research that will be conducted using each national research facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8883a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall include cost estimates in the categories of construction, repair, and upgrades—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8883a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the year in which the plan is submitted to Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8883a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for not fewer than the succeeding 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8883a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of facilities under construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan required under subsection (a) shall include a status report for each uncompleted construction project included in current and previous plans. The status report shall include data on cumulative construction costs by project compared with estimated costs, and shall compare the current and original schedules for achievement of milestones for the major phases of the construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8883a5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/207/tII/s201"},"text":"Pub. L. 105–207, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/872"},"text":"112 Stat. 872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14/b/1"},"text":"Pub. L. 107–368, § 14(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3056"},"text":"116 Stat. 3056","children":[],"tail":", 3057; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7014/b"},"text":"Pub. L. 110–69, title VII, § 7014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/682"},"text":"121 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8883a6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8883a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8883a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Science Foundation Authorization Act of 1998, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb8883a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" inserted “and for major upgrades of facilities in support of Antarctic research programs” after “facilities construction account” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14/b/1"},"text":"Pub. L. 107–368, § 14(b)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Not later than December 1, of each year, the Director shall, as part of the annual budget request, prepare and submit to Congress a plan for the proposed construction of, and repair and upgrades to, national research facilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14/b/2/A"},"text":"Pub. L. 107–368, § 14(b)(2)(A)","children":[],"tail":", substituted “(1), including costs for instrumentation development;” for “(1);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/368/s14/b/2/B"},"text":"Pub. L. 107–368, § 14(b)(2)(B)","children":[],"tail":"–(D), added subpars. (D) to (G)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
