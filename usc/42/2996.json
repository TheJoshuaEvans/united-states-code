{"tag":"section","attrib":{"id":"idbc31e2ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996"},"text":null,"children":[{"tag":"num","attrib":{"value":"2996"},"text":"§ 2996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e2eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a need to provide equal access to the system of justice in our Nation for individuals who seek redress of grievances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a need to provide high quality legal assistance to those who would be otherwise unable to afford adequate legal counsel and to continue the present vital legal services program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing legal assistance to those who face an economic barrier to adequate legal counsel will serve best the ends of justice and assist in improving opportunities for low-income persons consistent with the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for many of our citizens, the availability of legal services has reaffirmed faith in our government of laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve its strength, the legal services program must be kept free from the influence of or use by it of political pressures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e2f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2996/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attorneys providing legal assistance must have full freedom to protect the best interests of their clients in keeping with the Code of Professional Responsibility, the Canons of Ethics, and the high standards of the legal profession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e2f1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tX/s1001"},"text":"Pub. L. 88–452, title X, § 1001","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/355/s2"},"text":"Pub. L. 93–355, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-25"},"text":"July 25, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/378"},"text":"88 Stat. 378","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/222/s2"},"text":"Pub. L. 95–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1619"},"text":"91 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e2f2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc31e2f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc31e2f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/222"},"text":"Pub. L. 95–222","children":[],"tail":" inserted provision relating to assistance in improving opportunities for low-income persons consistent with this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc31e2f5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc31e2f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/222/s17/b"},"text":"Pub. L. 95–222, § 17(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1624"},"text":"91 Stat. 1624","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/222/s17/b"},"text":"“The amendments made by provisions of this Act other than sections 11 and 15 [amending this section and sections 2996c, 2996e, 2996f, 2996g, 2996h, 2996i, and 2996j of this title] shall be effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbc31e2f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter is known as the “Legal Services Corporation Act”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2701"},"text":"section 2701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
