{"tag":"section","attrib":{"id":"idb66e0f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–63"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–63"},"text":"§ 300x–63.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of certain programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–63/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount allotted to the State of Hawaii under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":", and the amount allotted to such State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":", an amount equal to the proportion of Native Hawaiians residing in the State to the total population of the State shall be available, respectively, for carrying out the program involved for Native Hawaiians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–63/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount made available under subsection (a) may be expended only through contracts entered into by the State of Hawaii with public and private nonprofit organizations to enable such organizations to plan, conduct, and administer comprehensive substance use disorder and treatment programs for the benefit of Native Hawaiians. In entering into contracts under this section, the State of Hawaii shall give preference to Native Hawaiian organizations and Native Hawaiian health centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–63/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subsection,","children":[{"tag":"ref","attrib":{"idref":"fn002398"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002398"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section,”."}],"tail":" the terms “Native Hawaiian”, “Native Hawaiian organization”, and “Native Hawaiian health center” have the meaning given such terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11707"},"text":"section 11707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0f43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1953, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s203/a"},"text":"Pub. L. 102–321, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/409"},"text":"106 Stat. 409","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8003/2"},"text":"Pub. L. 114–255, div. B, title VIII, § 8003(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1233"},"text":"130 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66e0f44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66e0f45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66e0f46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “substance use disorder” for “substance abuse”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
