{"tag":"section","attrib":{"id":"idbfc59160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491"},"text":null,"children":[{"tag":"num","attrib":{"value":"13491"},"text":"§ 13491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc59161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Secretary to carry out civilian nuclear programs in a way that will lead toward the commercial availability of advanced nuclear reactor technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize such activities to further the timely availability of advanced nuclear reactor technologies, including technologies that utilize standardized designs or exhibit passive safety features.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc59164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc59165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “advanced nuclear reactor technologies” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc59166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced light water reactors that may be commercially available in the near-term, including but not limited to mid-sized reactors with passive safety features for the generation of commercial electric power from nuclear fission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc59167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other advanced nuclear reactor technologies that may require prototype demonstration prior to commercial availability in the mid- or long-term, including but not limited to high-temperature, gas-cooled reactors and liquid metal reactors, for the generation of commercial electric power from nuclear fission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Nuclear Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc59169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “standardized design” means a design for a nuclear power plant that may be utilized for a multiple number of units or a multiple number of sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc5916a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13491/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “certification” means approval by the Commission of a standardized design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc5916b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2121"},"text":"Pub. L. 102–486, title XXI, § 2121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3081"},"text":"106 Stat. 3081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfc5916c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfc5916d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfc5916e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle” meaning subtitle C of title XXI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3081"},"text":"106 Stat. 3081","children":[],"tail":", which enacted this part and amended sections 12003 and 12004 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
