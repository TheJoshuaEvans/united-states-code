{"tag":"section","attrib":{"id":"idb7bb9cef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656"},"text":null,"children":[{"tag":"num","attrib":{"value":"656"},"text":"§ 656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support obligation as obligation to State; amount; discharge in bankruptcy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7bb9cf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection processes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bb9cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The support rights assigned to the State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s608/a/3"},"text":"section 608(a)(3) of this title","children":[],"tail":" or secured on behalf of a child receiving foster care maintenance payments shall constitute an obligation owed to such State by the individual responsible for providing such support. Such obligation shall be deemed for collection purposes to be collectible under all applicable State and local processes."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bb9cf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of such obligation shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7bb9cf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified in a court order which covers the assigned support rights, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7bb9cf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no court order, an amount determined by the State in accordance with a formula approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bb9cf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts collected from a noncustodial parent under the plan shall reduce, dollar for dollar, the amount of his obligation under subparagraphs (A) and (B) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bb9cf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondischargeability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A debt (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of title 11","children":[],"tail":") owed under State law to a State (as defined in such section) or municipality (as defined in such section) that is in the nature of support and that is enforceable under this part is not released by a discharge in bankruptcy under title 11."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bb9cf7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"te