{"tag":"section","attrib":{"id":"idbc74b843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149"},"text":null,"children":[{"tag":"num","attrib":{"value":"3149"},"text":"§ 3149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for economic adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants for development of public facilities, public services, business development (including funding of a revolving loan fund), planning, technical assistance, training, and any other assistance to alleviate long-term economic deterioration and sudden and severe economic dislocation and further the economic adjustment objectives of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide assistance under this section only if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project will help the area to meet a special need arising from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened severe unemployment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic adjustment problems resulting from severe changes in economic conditions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area for which a project is to be carried out has a comprehensive economic development strategy and the project is consistent with the strategy, except that this paragraph shall not apply to planning projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b84a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particular community assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance under this section may include assistance provided for activities identified by communities, the economies of which are injured by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b84b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military base closures or realignments, defense contractor reductions in force, or Department of Energy defense-related funding reductions, for help in diversifying their economies through projects to be carried out on Federal Government installations or elsewhere in the communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b84c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disasters or emergencies, in areas with respect to which a major disaster or emergency has been declared under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.), for post-disaster economic recovery;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b84d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international trade, for help in economic restructuring of the communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b84e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fishery failures, in areas with respect to which a determination that there is a commercial fishery failure has been made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1861a/a"},"text":"section 1861a(a) of title 16","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b84f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss of manufacturing, travel and tourism, natural resource-based, blue economy, or agricultural jobs, for reinvesting in and diversifying the economies of the communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic dislocation in the steel industry due to the closure of a steel plant, primary steel economy contraction events (including temporary layoffs and shifts to part-time work), or job losses in the steel industry or associated with the departure or contraction of the steel industry, for help in economic restructuring of the communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limited water for industrial consumption in areas impacted by decreased water supplies due to drought or extreme heat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to coal communities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coal economy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coal economy” means the complete supply chain of coal-reliant industries, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc74b855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal mining;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal-fired power plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation or logistics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contraction event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contraction event” means the closure of a facility or a reduction in activity relating to a coal-reliant industry, including an industry described in any of clauses (i) through (iv) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b85a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants for projects in areas adversely impacted by a contraction event in the coal economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b85b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b85c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall determine the eligibility of an area based on whether the eligible recipient can reasonably demonstrate that the area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc74b85d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been adversely impacted by a contraction event in the coal economy within the previous 25 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b85e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be adversely impacted by a contraction event in the coal economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b85f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No regulation or other policy of the Secretary may limit the eligibility of an eligible recipient for a grant under this subsection based on the date of a contraction event except as provided in subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstrating adverse impact","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this paragraph, an eligible recipient may demonstrate an adverse impact by demonstrating—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc74b861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loss in employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in tax revenue; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/d/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor, as determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to nuclear host communities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Nuclear Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community advisory board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community advisory board” means a community committee or other advisory organization that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc74b868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily focuses on the economic impacts of decommissioning activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aims to foster communication and information exchange between a licensee planning for and involved in decommissioning activities and members of the community that decommissioning activities may affect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b86a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decommission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “decommission” has the meaning given the term in section 50.2 of title 10, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b86b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “licensee” has the meaning given the term in section 50.2 of title 10, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b86c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear host community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nuclear host community” means an eligible recipient that has been economically impacted, or reasonably demonstrates to the satisfaction of the Secretary that it will be economically impacted, by a nuclear power plant licensed by the Commission that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc74b86d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not co-located with an operating nuclear power plant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b86e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at a site with spent nuclear fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc74b86f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbc74b870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc74b871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/1/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided a written notification to the Commission that it will cease operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist with economic development in nuclear host communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund community advisory boards in nuclear host communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, to the maximum extent practicable, the Secretary shall implement the recommendations described in the report submitted to Congress under section 108 of the Nuclear Energy Innovation and Modernization Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/439"},"text":"Public Law 115–439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/132/5577"},"text":"132 Stat. 5577","children":[],"tail":") entitled “Best Practices for Establishment and Operation of Local Community Advisory Boards Associated with Decommissioning Activities at Nuclear Power Plants”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a methodology to ensure, to the maximum extent practicable, geographic diversity among grant recipients under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions relating to revolving loan fund grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to maintain the proper operation and financial integrity of revolving loan funds established by recipients with assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficient administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of a grantee, amend and consolidate grant agreements governing revolving loan funds to provide flexibility with respect to lending areas and borrower criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign or transfer assets of a revolving loan fund to third party for the purpose of liquidation, and the third party may retain assets of the fund to defray costs related to liquidation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such actions as are appropriate to enable revolving loan fund operators to sell or securitize loans (except that the actions may not include issuance of a Federal guaranty by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action taken by the Secretary under this subsection with respect to a revolving loan fund shall not constitute a new obligation if all grant funds associated with the original grant award have been disbursed to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of securities laws","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not treated as exempted securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No securities issued pursuant to paragraph (2)(C) shall be treated as exempted securities for purposes of the Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.) or the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.), unless exempted by rule or regulation of the Securities and Exchange Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (A), no provision of this subsection or any regulation promulgated by the Secretary under this subsection supersedes or otherwise affects the application of the securities laws (as the term is defined in section 3(a) of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"15 U.S.C. 78c(a)","children":[],"tail":")) or the rules, regulations, or orders of the Securities and Exchange Commission or a self-regulatory organization under that Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3149/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster mitigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance pursuant to subsection (c)(2), if appropriate and as applicable, the Secretary may encourage hazard mitigation in assistance provided pursuant to such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b882-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s209"},"text":"Pub. L. 89–136, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3605"},"text":"112 Stat. 3605","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s207"},"text":"Pub. L. 108–373, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1762"},"text":"118 Stat. 1762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1217/a"},"text":"Pub. L. 115–254, div. D, § 1217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3451"},"text":"132 Stat. 3451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2219"},"text":"Pub. L. 118–272, div. B, title II, § 2219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3183"},"text":"138 Stat. 3183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b883-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b884-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc74b885-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 108 of the Nuclear Energy Innovation and Modernization Act, referred to in subsec. (e)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/439/s108"},"text":"section 108 of Pub. L. 115–439","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5577"},"text":"132 Stat. 5577","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in subsec. (f)(4)(A), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsec. (f)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc74b886-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2219/1/B/i"},"text":"Pub. L. 118–272, § 2219(1)(B)(i)","children":[],"tail":", inserted “, travel and tourism, natural resource-based, blue economy, or agricultural” after “manufacturing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2219/1/A"},"text":"Pub. L. 118–272, § 2219(1)(A)","children":[],"tail":", (B)(ii), (C), added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2219/2"},"text":"Pub. L. 118–272, § 2219(2)","children":[],"tail":", (3), added subsecs. (d) and (e) and redesignated former subsecs. (d) and (e) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s207/a"},"text":"Pub. L. 108–373, § 207(a)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s207/b"},"text":"Pub. L. 108–373, § 207(b)","children":[],"tail":", added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Subject to paragraph (2), an eligible recipient of a grant under this section may directly expend the grant funds or may redistribute the funds to public and private entities in the form of a grant, loan, loan guarantee, payment to reduce interest on a loan guarantee, or other appropriate assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—Under paragraph (1), an eligible recipient may not provide any grant to a private for-profit entity.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc74b887-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc74b888-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
