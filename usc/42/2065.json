{"tag":"section","attrib":{"id":"idbbe326b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065"},"text":null,"children":[{"tag":"num","attrib":{"value":"2065"},"text":"§ 2065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving the reliability of domestic medical isotope supply","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbe326b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical isotope development projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe326b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a technology-neutral program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate and support projects for the production in the United States, without the use of highly enriched uranium, of significant quantities of molybdenum-99 for medical uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be carried out in cooperation with non-Federal entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of which shall be shared in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects shall be evaluated against the following primary criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The length of time necessary for the proposed project to begin production of molybdenum-99 for medical uses within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability of the proposed project to produce a significant percentage of United States demand for molybdenum-99 for medical uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability of the proposed project to produce molybdenum-99 in a cost-effective manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An existing reactor in the United States fueled with highly enriched uranium shall not be disqualified from the program if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no alternative nuclear reactor fuel, enriched in the isotope U–235 to less than 20 percent, that can be used in that reactor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reactor operator has provided assurances that, whenever an alternative nuclear reactor fuel, enriched in the isotope U–235 to less than 20 percent, can be used in that reactor, it will use that alternative in lieu of highly enriched uranium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reactor operator has provided a current report on the status of its efforts to convert the reactor to an alternative nuclear reactor fuel enriched in the isotope U–235 to less than 20 percent, and an anticipated schedule for completion of conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation and review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a program plan and annually update the program plan through public workshops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the Nuclear Science Advisory Committee to conduct triennial reviews of the progress made in achieving the program goals and make recommendations to improve program effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe326c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to provide assistance for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe326c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of fuels, targets, and processes for domestic molybdenum-99 production that do not use highly enriched uranium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial operations using the fuels, targets, and processes described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe326ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uranium lease and take-back","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe326cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to make low enriched uranium available, through lease contracts, for irradiation for the production of molybdenum-99 for medical uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The lease contracts shall provide for the producers of the molybdenum-99 to take title to and be responsible for the molybdenum-99 created by the irradiation, processing, or purification of uranium leased under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lease contracts shall require the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbe326cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retain responsibility for the final disposition of spent nuclear fuel created by the irradiation, processing, or purification of uranium leased under this section for the production of medical isotopes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbe326d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take title to and be responsible for the final disposition of radioactive waste created by the irradiation, processing, or purification of uranium leased under this section for which the Secretary determines the producer does not have access to a disposal path.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The producer of the spent nuclear fuel and radioactive waste shall accurately characterize, appropriately package, and transport the spent nuclear fuel and radioactive waste prior to acceptance by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the lease contracts shall provide for compensation in cash amounts equivalent to prevailing market rates for the sale of comparable uranium products and for compensation in cash amounts equivalent to the net present value of the cost to the Federal Government for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbe326d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final disposition of spent nuclear fuel and radioactive waste for which the Department is responsible under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbe326d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other costs associated with carrying out the uranium lease and take-back program authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discount rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The discount rate used to determine the net present value of costs described in subparagraph (A)(ii) shall be not greater than the average interest rate on marketable Treasury securities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary may obligate and expend funds received under leases entered into under this subsection, which shall remain available until expended, for the purpose of carrying out the activities authorized by this subtitle, including activities related to the final disposition of spent nuclear fuel and radioactive waste for which the Department is responsible under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe326d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of uranium for services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not barter or otherwise sell or transfer uranium in any form in exchange for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbe326d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services related to the final disposition of the spent nuclear fuel and radioactive waste for which the Department is responsible under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbe326da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other services associated with carrying out the uranium lease and take-back program authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe326db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of environmental reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department and the Nuclear Regulatory Commission shall ensure to the maximum extent practicable that environmental reviews for the production of the medical isotopes shall complement and not duplicate each review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe326dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program as described in subsection (c)(3) not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe326dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2065/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radioactive waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10101"},"text":"section 10101 of this title","children":[],"tail":", radioactive material resulting from the production of medical isotopes that has been permanently removed from a reactor or subcritical assembly and for which there is no further use shall be considered low-level radioactive waste if the material is acceptable under Federal requirements for disposal as low-level radioactive waste."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbe326de-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXI/s3173"},"text":"Pub. L. 112–239, div. C, title XXXI, § 3173","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2211"},"text":"126 Stat. 2211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXI/s3131/c"},"text":"Pub. L. 117–81, div. C, title XXXI, § 3131(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2230"},"text":"135 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbe326df-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbe326e0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbe326e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (c)(5), is subtitle F (§§ 3171–3178) of title XXXI of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":". For complete classification of this subtitle to the Code, see Short Title of 2013 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbe326e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Medical Isotopes Production Act of 2012 and also as part of the National Defense Authorization Act for Fiscal Year 2013, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbe326e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “triennial reviews” for “annual reviews”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbbe326e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbbe326e5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXI/s3172"},"text":"Pub. L. 112–239, div. C, title XXXI, § 3172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2211"},"text":"126 Stat. 2211","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dC/tXXXI/s3172"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle F (§§ 3171–3178), see Short Title of 2013 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Department’ means the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Highly enriched uranium","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘highly enriched uranium’ means uranium enriched to 20 percent or greater in the isotope U–235.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Low enriched uranium","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘low enriched uranium’ means uranium enriched to less than 20 percent in the isotope U–235.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Energy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
