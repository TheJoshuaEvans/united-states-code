{"tag":"section","attrib":{"id":"idbfb73a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a"},"text":null,"children":[{"tag":"num","attrib":{"value":"13263a"},"text":"§ 13263a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb73a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any covered person subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13251"},"text":"section 13251 of this title","children":[],"tail":" and any State subject to section 13257("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title may petition the Secretary for a waiver of the applicable requirements of section 13251 or 13257("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall grant a waiver of the requirements of section 13251 or 13257(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title on a showing that the fleet owned, operated, leased, or otherwise controlled by the State or covered person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb73a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will achieve a reduction in the annual consumption of petroleum fuels by the fleet equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb73a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction in consumption of petroleum that would result from 100 percent cumulative compliance with the fuel use requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13251"},"text":"section 13251 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb73a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an entity covered under section 13257(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of this title, a reduction equal to the annual consumption by the State entity of alternative fuels if all of the cumulative alternative fuel vehicles of the State entity given credit under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13258"},"text":"section 13258 of this title","children":[],"tail":" were to use alternative fuel 100 percent of the time; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with all applicable vehicle emission standards established by the Administrator of the Environmental Protection Agency under the Clean Air Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than December 31 of a model year, any State or covered person granted a waiver under this section for the preceding model year shall submit to the Secretary an annual report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb73a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies the quantity of the petroleum motor fuel reduction of the State or covered person during the preceding model year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects the baseline quantity of the petroleum motor fuel reduction of the State or covered person during the following model year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State or covered person that receives a waiver under this section fails to comply with this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb73a36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall revoke the waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb73a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13263a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may impose on the State or covered person a penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13262"},"text":"section 13262 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb73a38-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s514"},"text":"Pub. L. 102–486, title V, § 514","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s703/a/2"},"text":"Pub. L. 109–58, title VII, § 703(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/815"},"text":"119 Stat. 815","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb73a39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb73a3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb73a3b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbfb73a3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s514"},"text":"section 514 of Pub. L. 102–486","children":[],"tail":" was renumbered 515 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13264"},"text":"section 13264 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
