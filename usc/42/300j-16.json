{"tag":"section","attrib":{"id":"idb647e949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–16"},"text":"§ 300j–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to colonias","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb647e94a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e94b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “border State” means Arizona, California, New Mexico, and Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e94c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible community” means a low-income community with economic hardship that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e94d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is commonly referred to as a colonia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e94e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located along the United States-Mexico border (generally in an unincorporated area); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e94f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lacks a safe drinking water supply or adequate facilities for the provision of safe drinking water for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to alleviate health risks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency and the heads of other appropriate Federal agencies are authorized to award grants to a border State to provide assistance to eligible communities to facilitate compliance with national primary drinking water regulations or otherwise significantly further the health protection objectives of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant awarded pursuant to subsection (b) shall be used to provide assistance to one or more eligible communities with respect to which the residents are subject to a significant health risk (as determined by the Administrator or the head of the Federal agency making the grant) attributable to the lack of access to an adequate and affordable drinking water supply system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant awarded pursuant to this section shall not exceed 50 percent of the costs of carrying out the project that is the subject of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–16/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $25,000,000 for each of the fiscal years 1997 through 1999.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb647e954-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1456, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tI/s135"},"text":"Pub. L. 104–182, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1679"},"text":"110 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
