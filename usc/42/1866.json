{"tag":"section","attrib":{"id":"idbb994cbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1866"},"text":null,"children":[{"tag":"num","attrib":{"value":"1866"},"text":"§ 1866.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Divisions within Foundation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be within the Foundation such Divisions as the Director, in consultation with the Board, may from time to time determine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb994cbc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-10/ch171/s8"},"text":"May 10, 1950, ch. 171, § 8","children":[],"tail":", formerly § 7, "},{"tag":"ref","attrib":{"href":"/us/stat/64/152"},"text":"64 Stat. 152","children":[],"tail":"; renumbered § 8 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/407"},"text":"Pub. L. 90–407","children":[],"tail":", §§ 4, 6, "},{"tag":"date","attrib":{"date":"1968-07-18"},"text":"July 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/363"},"text":"82 Stat. 363","children":[],"tail":", 364.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb994cbd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb994cbe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbb994cbf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8 of act ","children":[{"tag":"date","attrib":{"date":"1950-05-10"},"text":"May 10, 1950","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1867"},"text":"section 1867 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/407/s4"},"text":"Pub. L. 90–407, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-18"},"text":"July 18, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/363"},"text":"82 Stat. 363","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb994cc0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/407/s6"},"text":"Pub. L. 90–407, § 6","children":[],"tail":", substituted provisions that there be within the Foundation such divisions as the Director, in consultation with the Board, may from time to time determine for provisions that, unless otherwise provided by the Board, there be within the Foundation a Division of Medical Research, a Division of Mathematical, Physical, and Engineering Sciences, a Division of Biological Sciences, a Division of Scientific Personnel and Education, and such other divisions as the Board deems necessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb994cc1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb994cc2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consolidation of Directorates","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/516/s18"},"text":"Pub. L. 96–516, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3009"},"text":"94 Stat. 3009","children":[],"tail":", directed National Science Foundation to consolidate all Directorates, including Science Education Directorate, under one roof, in present location of central administrative offices, on or before "},{"tag":"date","attrib":{"date":"1982-08-01"},"text":"Aug. 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb994cc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Existing Offices, Procedures, and Organization of the National Science Foundation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/407"},"text":"Pub. L. 90–407","children":[],"tail":" intended to continue in effect the existing offices, procedures, and organization of the Foundation, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/407/s16"},"text":"section 16 of Pub. L. 90–407","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862"},"text":"section 1862 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
