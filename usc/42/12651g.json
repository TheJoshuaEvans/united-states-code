{"tag":"section","attrib":{"id":"idbf8ea2c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651g"},"text":"§ 12651g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8ea2c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf8ea2c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea2c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizations and individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Corporation may solicit and accept the services of organizations and individuals (other than participants) to assist the Corporation in carrying out the duties of the Corporation under the national service laws, and may provide to such individuals the travel expenses described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651b/d"},"text":"section 12651b(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea2c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who provides assistance, either individually or as a member of an organization, in accordance with subparagraph (A) shall not be considered to be a Federal employee and shall not be subject to the provisions of law relating to Federal employment, including those relating to hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea2c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes of the tort claims provisions of chapter 171 of title 28, such a person shall be considered to be a Federal employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea2c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes of subchapter I of chapter 81 of title 5 relating to compensation to Federal employees for work injuries, such persons shall be considered to be employees, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/1/B"},"text":"section 8101(1)(B) of title 5","children":[],"tail":" and the provisions of such subchapter shall apply; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea2c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of the provisions of chapter 11 of part I of title 18, such a person (to whom such provisions would not otherwise apply except for this subsection) shall be a special Government employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea2c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inherently governmental function","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea2c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such a person shall not carry out an inherently governmental function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea2ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall promulgate regulations to carry out this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea2cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Inherently governmental function” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subparagraph, the term “inherently governmental function” means any activity that is so intimately related to the public interest as to mandate performance by an officer or employee of the Federal Government, including an activity that requires either the exercise of discretion in applying the authority of the Government or the use of value judgment in making a decision for the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8ea2cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8ea2cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may solicit, accept, hold, administer, use, and dispose of, in furtherance of the purposes of the national service laws, donations of any money or property, real, personal, or mixed, tangible or intangible, received by gift, devise, bequest, or otherwise. Donations accepted under this subparagraph shall be used as nearly as possible in accordance with the terms, if any, of such donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea2ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any donation accepted under subparagraph (A) shall be considered to be a gift, devise, or bequest to, or for the use of, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea2cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Executive Officer shall establish written rules to ensure that the solicitation, acceptance, holding, administration, and use of property described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf8ea2d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not reflect unfavorably upon the ability of the Corporation, or of any officer or employee of the Corporation, to carry out the responsibilities or official duties of the Corporation in a fair and objective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf8ea2d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not compromise the integrity of the programs of the Corporation or any official or employee of the Corporation involved in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8ea2d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the use by the Corporation of any property accepted pursuant to subparagraph (A) (other than money or monetary proceeds from sales of property so accepted), such completion shall be reported to the General Services Administration and such property shall be disposed of in accordance with title II of the Federal Property and Administrative Services Act of 1949.","children":[{"tag":"ref","attrib":{"idref":"fn004084"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004084"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea2d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41, the Corporation may enter into contracts, and cooperative and interagency agreements, with Federal and State agencies, private firms, institutions, and individuals to conduct activities necessary to assist the Corporation in carrying out the duties of the Corporation under the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8ea2d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Management and Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate circulars of the Office of Management and Budget shall apply to the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8ea2d5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s196"},"text":"Pub. L. 101–610, title I, § 196","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII"},"text":"Pub. L. 103–82, title II","children":[],"tail":", §§ 202(a), 203(a)(1)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/885"},"text":"107 Stat. 885","children":[],"tail":", 891; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1707"},"text":"Pub. L. 111–13, title I, § 1707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1548"},"text":"123 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8ea2d6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8ea2d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf8ea2d8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Property and Administrative Services Act of 1949, referred to in subsec. (a)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"act June 30, 1949, ch. 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/377"},"text":"63 Stat. 377","children":[],"tail":". Title II of the Act, which was classified principally to subchapter II (§§ 481, 483, 484, 485, 486, 487 to 490, 491, 492) of chapter 10 and section 758 of former Title 40, Public Buildings, Property, and Works, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s6/b"},"text":"Pub. L. 107–217, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1304"},"text":"116 Stat. 1304","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works. For disposition of sections of former Title 40 to revised Title 40, see Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s101"},"text":"section 101 of Title 40","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf8ea2d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” substituted for “the Federal Property and Administrative Services Act of 1949” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf8ea2da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/A"},"text":"Pub. L. 111–13, § 1707(1)(A)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A). Prior to amendment, text read as follows: “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Corporation may solicit and accept the voluntary services of individuals to assist the Corporation in carrying out the duties of the Corporation under the national service laws, and may provide to such individuals the travel expenses described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651b/d"},"text":"section 12651b(d) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/B/i"},"text":"Pub. L. 111–13, § 1707(1)(B)(i)","children":[],"tail":", substituted “A person who provides assistance, either individually or as a member of an organization, in accordance with subparagraph (A)” for “Such a volunteer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/B/ii"},"text":"Pub. L. 111–13, § 1707(1)(B)(ii)","children":[],"tail":", substituted “such a person” for “a volunteer under this division”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/B/iii"},"text":"Pub. L. 111–13, § 1707(1)(B)(iii)","children":[],"tail":", substituted “such persons” for “volunteers under this division”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/B/iv"},"text":"Pub. L. 111–13, § 1707(1)(B)(iv)","children":[],"tail":", substituted “such a person” for “such a volunteer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/1/C"},"text":"Pub. L. 111–13, § 1707(1)(C)","children":[],"tail":", substituted “Such a person” for “Such a volunteer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1707/2"},"text":"Pub. L. 111–13, § 1707(2)","children":[],"tail":", struck out par. (3). Text read as follows: “As used in this subsection, the term ‘volunteer’ does not include a participant.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (a)(1)(A), (2)(A), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s203/a/1/B"},"text":"Pub. L. 103–82, § 203(a)(1)(B)","children":[],"tail":", which directed amendment of section 196(a) and (b) of subtitle I of the National and Community Service Act of 1990 by substituting “the national service laws” for “this chapter”, was executed to subsecs. (a)(1)(A), (2)(A) and (b) of this section, which is section 196 of subtitle G of title I of the National Community Service Act of 1990, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8ea2db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf8ea2dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf8ea2dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s203/a/1/B"},"text":"section 203(a)(1)(B) of Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-04-04"},"text":"Apr. 4, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s203/d"},"text":"section 203(d) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf8ea2de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s202/i"},"text":"section 202(i) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651"},"text":"section 12651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
