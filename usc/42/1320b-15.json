{"tag":"section","attrib":{"id":"idb84f7936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–15"},"text":"§ 1320b–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of social security and medicare trust funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb84f7937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No officer or employee of the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f7938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delay the deposit of any amount into (or delay the credit of any amount to) any Federal fund or otherwise vary from the normal terms, procedures, or timing for making such deposits or credits,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f7939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refrain from the investment in public debt obligations of amounts in any Federal fund, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f793a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeem prior to maturity amounts in any Federal fund which are invested in public debt obligations for any purpose other than the payment of benefits or administrative expenses from such Federal fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f793b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Public debt obligation” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “public debt obligation” means any obligation subject to the public debt limit established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3101"},"text":"section 3101 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f793c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Federal fund” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “Federal fund” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f793d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Old-Age and Survivors Insurance Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f793e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Disability Insurance Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f793f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Hospital Insurance Trust Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f7940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–15/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Supplementary Medical Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb84f7941-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1145, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/121/tI/s107/a"},"text":"Pub. L. 104–121, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/856"},"text":"110 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb84f7942-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb84f7943-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb84f7944-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tI/s107/b"},"text":"Pub. L. 104–121, title I, § 107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/857"},"text":"110 Stat. 857","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/121/tI/s107/b"},"text":"“The amendment made by this section [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
