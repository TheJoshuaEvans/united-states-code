{"tag":"section","attrib":{"id":"idb6836b9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–12"},"text":"§ 300cc–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of investigational new drugs with respect to acquired immune deficiency syndrome","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836b9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of applications with respect to clinical trials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836ba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If, in the determination of the Secretary, there is preliminary evidence that a new drug has effectiveness in humans with respect to the prevention or treatment of acquired immune deficiency syndrome, the Secretary shall, through statements published in the Federal Register—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836ba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announce the fact of such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836ba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the new drug involved, encourage an application for an exemption for investigational use of the new drug under regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836ba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836ba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The AIDS Research Advisory Committee established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–3"},"text":"section 300cc–3 of this title","children":[],"tail":" shall make recommendations to the Secretary with respect to new drugs appropriate for determinations described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836ba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, as soon as is practicable, determine the merits of recommendations received by the Secretary pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836ba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of applications with respect to treatment use in circumstances other than clinical trials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836ba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a new drug with respect to which the Secretary has made a determination described in subsection (a) and with respect to which an exemption is in effect for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355/i"},"text":"section 355(i) of title 21","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836ba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as appropriate, encourage the sponsor of the investigation of the new drug to submit to the Secretary, in accordance with regulations issued under such section, an application to use the drug in the treatment of individuals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6836ba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are infected with the etiologic agent for acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6836baa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are not participating in the clinical trials conducted pursuant to such exemption; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such an application is approved, encourage, as appropriate, licensed medical practitioners to obtain, in accordance with such regulations, the new drug from such sponsor for the purpose of treating such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the sponsor of the investigation of a new drug described in paragraph (1) does not submit to the Secretary an application described in such paragraph (relating to treatment use), the Secretary shall, through statements published in the Federal Register, encourage, as appropriate, licensed medical practitioners to submit to the Secretary such applications in accordance with regulations described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance with respect to treatment use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a new drug with respect to which the Secretary has made a determination described in subsection (a), the Secretary may, directly or through grants or contracts, provide technical assistance with respect to the process of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the Secretary applications for exemptions described in paragraph (1)(B) of such subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the Secretary applications described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to sponsors of investigations of new drugs, facilitating the transfer of new drugs from such sponsors to licensed medical practitioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “New drug” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “new drug” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836bb2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2312, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3066"},"text":"102 Stat. 3066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/d/2"},"text":"Pub. L. 103–43, title XX, § 2008(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/212"},"text":"107 Stat. 212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6836bb3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6836bb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6836bb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–12, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2313, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238j"},"text":"section 238j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6836bb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “AIDS Research Advisory Committee” for “AIDS Clinical Research Review Committee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
