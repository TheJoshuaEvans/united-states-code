{"tag":"section","attrib":{"id":"idbe6bcd6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671q"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671q"},"text":"§ 7671q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7416"},"text":"section 7416 of this title","children":[],"tail":", requirements concerning the areas addressed by this subchapter for the protection of the stratosphere against ozone layer depletion shall be treated as requirements for the control and abatement of air pollution. For purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7418"},"text":"section 7418 of this title","children":[],"tail":", the requirements of this subchapter and corresponding State, interstate, and local requirements, administrative authority, and process, and sanctions respecting the protection of the stratospheric ozone layer shall be treated as requirements for the control and abatement of air pollution within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7418"},"text":"section 7418 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe6bcd6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 618, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2670"},"text":"104 Stat. 2670","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
