{"tag":"section","attrib":{"id":"idbfd8a448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003"},"text":null,"children":[{"tag":"num","attrib":{"value":"15003"},"text":"§ 15003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd8a449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of assistance under this subchapter shall keep such records as the Secretary shall prescribe, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd8a44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" records that fully disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd8a44b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and disposition by such recipient of the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd8a44c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project or undertaking in connection with which such assistance is given or used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd8a44d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of that portion of the cost of the project or undertaking that is supplied by other sources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd8a44e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd8a44f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipients of assistance under this subchapter that are pertinent to such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd8a450-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s103"},"text":"Pub. L. 106–402, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1688"},"text":"114 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
