{"tag":"section","attrib":{"id":"idbfa42688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854"},"text":null,"children":[{"tag":"num","attrib":{"value":"12854"},"text":"§ 12854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa42689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board of Directors” or “Board” means the Board of Directors of the National Homeownership Trust under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12851/b"},"text":"section 12851(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4268a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Displaced homemaker","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “displaced homemaker” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa4268b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an adult;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa4268c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not worked full-time full-year in the labor force for a number of years, but has during such years, worked primarily without remuneration to care for the home and family; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa4268d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unemployed or underemployed and is experiencing difficulty in obtaining or upgrading employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4268e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the National Homeownership Trust Fund established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12853"},"text":"section 12853 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa6978f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single parent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “single parent” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa69790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unmarried or legally separated from a spouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa69791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfa69792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has 1 or more minor children for whom the individual has custody or joint custody; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfa69793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is pregnant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means the States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, Guam, the Virgin Islands, American Samoa, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa69795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12854/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust","children":[],"tail":null},