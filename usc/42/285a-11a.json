{"tag":"section","attrib":{"id":"idb56a0bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a"},"text":null,"children":[{"tag":"num","attrib":{"value":"285a–11a"},"text":"§ 285a–11a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancer survivorship programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56a0bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research to evaluate model systems of care for pediatric cancer survivors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall, as appropriate, make awards to eligible entities to conduct or support research to develop, study, or evaluate approaches for monitoring and caring for childhood and adolescent cancer survivors throughout their lifespan, including transition to adult care and care coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this subsection, the Secretary shall, to the extent practicable, within the existing peer review process, include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small, medium, and large-sized eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sites located in different geographic areas, including rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a children’s hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cancer center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based medical facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity with significant experience and expertise in carrying out the activities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded under this subsection may be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, study, or evaluate one or more models for monitoring and caring for cancer survivors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in developing, studying, and evaluating such models, to give special emphasis to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56a0be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design of models of follow-up care, monitoring, and other survivorship programs (including peer support and mentoring programs);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of models for providing multidisciplinary care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of information to health care providers about culturally and linguistically appropriate follow-up care for cancer survivors and their families, as appropriate and practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of psychosocial and support programs to improve the quality of life of cancer survivors and their families, which may include peer support and mentoring programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design tools to support the secure electronic transfer of treatment information and care summaries between health care providers or, as applicable and appropriate, longitudinal childhood cancer survivorship cohorts (including risk factors and a plan for recommended follow-up care);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissemination of the information and programs described in clauses (i) through (v) to other health care providers (including primary care physicians and internists) and to cancer survivors and their families, where appropriate and in accordance with Federal and State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56a0be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/a/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of initiatives that promote the coordination and effective transition of care between cancer care providers, primary care physicians, mental health professionals, and other health care professionals, as appropriate, including models that use a team-based or multi-disciplinary approach to care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56a0be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce development for health care providers on medical and psychosocial care for childhood cancer survivors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56a0be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", conduct a review of the activities of the Department of Health and Human Services related to workforce development for health care providers who treat pediatric cancer patients and survivors. Such review shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56a0be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of existing models relevant to providing medical and psychosocial services to individuals surviving pediatric cancers, and programs related to training for health professionals who provide such services to individuals surviving pediatric cancers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56a0bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for enhancing or promoting activities of the Department of Health and Human Services related to workforce development for health care providers who provide psychosocial care to pediatric cancer patients and survivors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56a0beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285a–11a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":", the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and Committee on Energy and Commerce of the House of Representatives, a report concerning the findings and recommendations from the review conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56a0bec-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/180/tII/s201"},"text":"Pub. L. 115–180, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1387"},"text":"132 Stat. 1387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b"},"text":"Pub. L. 117–350, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6263"},"text":"136 Stat. 6263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56a0bed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56a0bee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb56a0bef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Childhood Cancer Survivorship, Treatment, Access, and Research Act of 2018, also known as the Childhood Cancer STAR Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56a0bf0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/1/A"},"text":"Pub. L. 117–350, § 2(b)(1)(A)","children":[],"tail":", substituted “Research to evaluate” for “Pilot programs to explore” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/1/B"},"text":"Pub. L. 117–350, § 2(b)(1)(B)","children":[],"tail":", substituted “shall, as appropriate, make awards to eligible entities to conduct or support research” for “may make awards to eligible entities to establish pilot programs” and “approaches” for “model systems”, inserted “and adolescent” after “childhood”, and struck out “evaluation of models for” before “transition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/1/C/i"},"text":"Pub. L. 117–350, § 2(b)(1)(C)(i)","children":[],"tail":", inserted “within the existing peer review process,” after “practicable,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/1/C/ii"},"text":"Pub. L. 117–350, § 2(b)(1)(C)(ii)","children":[],"tail":", substituted “in carrying out the activities described in paragraph (1)” for “in treating survivors of childhood cancers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/1/D"},"text":"Pub. L. 117–350, § 2(b)(1)(D)","children":[],"tail":", substituted “design tools to support the secure electronic transfer of treatment information and care summaries between health care providers or, as applicable and appropriate, longitudinal childhood cancer survivorship cohorts” for “design of systems for the effective transfer of treatment information and care summaries from cancer care providers to other health care providers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/2/A"},"text":"Pub. L. 117–350, § 2(b)(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/2/B"},"text":"Pub. L. 117–350, § 2(b)(2)(B)","children":[],"tail":", added subpar. (B), redesignated former subpar. (B) as (A), and struck out former subpars. (A) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) an assessment of the effectiveness of supportive psychosocial care services for pediatric cancer patients and survivors, including pediatric cancer survivorship care patient navigators and peer support programs;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) recommendations for improving the provision of psychosocial care for pediatric cancer survivors and patients.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/350/s2/b/2/A"},"text":"Pub. L. 117–350, § 2(b)(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"January 5, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-06-05"},"text":"June 5, 2018","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
