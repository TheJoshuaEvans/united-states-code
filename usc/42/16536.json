{"tag":"section","attrib":{"id":"idc01b524c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536"},"text":null,"children":[{"tag":"num","attrib":{"value":"16536"},"text":"§ 16536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protecting America’s Competitive Edge (PACE) graduate fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01b524d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible student” means a student who attends an institution of higher education that offers a doctoral degree in a field relevant to a mission area of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b524e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a graduate fellowship program for eligible students pursuing a doctoral degree in a mission area of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b524f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award fellowships to eligible students under this section through a competitive merit review process, involving written and oral interviews, that will result in a wide distribution of awards throughout the United States, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish selection criteria for awarding fellowships under this section that require an eligible student—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b5252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pursue a field of science or engineering of importance to a mission area of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to demonstrate to the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b5254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the eligible student to understand technical topics relating to the fellowship that can be derived from the first principles of the technical topics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imagination and creativity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership skills in organizations or intellectual endeavors, demonstrated through awards and past experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b5257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excellent verbal and communication skills to explain, defend, and demonstrate an understanding of technical subjects relating to the fellowship; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b5258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be a citizen or legal permanent resident of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b525a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fellowship awarded under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01b525b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an annual living stipend; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01b525c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cover—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc01b525d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" graduate tuition at an institution of higher education described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc01b525e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental expenses associated with curricula and research at the institution of higher education (including books, computers, and software).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b525f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellowship awarded under this section shall be up to 3 years duration within a 5-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellowship awarded under this section shall be portable with the eligible student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of Science, Engineering, and Mathematics Education—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall administer the program established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into a contract with a nonprofit entity to administer the program, including the selection and award of fellowships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,500,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 for fiscal year 2009, including nonexpiring fellowships for the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2010, including nonexpiring fellowships for preceding fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5268-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,600,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $21,200,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b526a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16536/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $21,900,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01b526b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5009"},"text":"Pub. L. 110–69, title V, § 5009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/618"},"text":"121 Stat. 618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s902/d"},"text":"Pub. L. 111–358, title IX, § 902(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4045"},"text":"124 Stat. 4045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01b526c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01b526d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc01b526e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (f)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" added pars. (4) to (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
