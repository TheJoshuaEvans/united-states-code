{"tag":"section","attrib":{"id":"idbe4818f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543"},"text":null,"children":[{"tag":"num","attrib":{"value":"7543"},"text":"§ 7543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe4818f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State or any political subdivision thereof shall adopt or attempt to enforce any standard relating to the control of emissions from new motor vehicles or new motor vehicle engines subject to this part. No State shall require certification, inspection, or any other approval relating to the control of emissions from any new motor vehicle or new motor vehicle engine as condition precedent to the initial retail sale, titling (if any), or registration of such motor vehicle, motor vehicle engine, or equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe4818f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe4818f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall, after notice and opportunity for public hearing, waive application of this section to any State which has adopted standards (other than crankcase emission standards) for the control of emissions from new motor vehicles or new motor vehicle engines prior to ","children":[{"tag":"date","attrib":{"date":"1966-03-30"},"text":"March 30, 1966","children":[],"tail":", if the State determines that the State standards will be, in the aggregate, at least as protective of public health and welfare as applicable Federal standards. No such waiver shall be granted if the Administrator finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe4818f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the State is arbitrary and capricious,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe4818f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State does not need such State standards to meet compelling and extraordinary conditions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe4818f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such State standards and accompanying enforcement procedures are not consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521/a"},"text":"section 7521(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe4818fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If each State standard is at least as stringent as the comparable applicable Federal standard, such State standard shall be deemed to be at least as protective of health and welfare as such Federal standards for purposes of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe4818fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any new motor vehicle or new motor vehicle engine to which State standards apply pursuant to a waiver granted under paragraph (1), compliance with such State standards shall be treated as compliance with applicable Federal standards for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe4818fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of vehicle parts or engine parts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a regulation with respect to any motor vehicle part or motor vehicle engine part is in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7541/a/2"},"text":"section 7541(a)(2) of this title","children":[],"tail":", no State or political subdivision thereof shall adopt or attempt to enforce any standard or any requirement of certification, inspection, or approval which relates to motor vehicle emissions and is applicable to the same aspect of such part. The preceding sentence shall not apply in the case of a State with respect to which a waiver is in effect under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe4818fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control, regulation, or restrictions on registered or licensed motor vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall preclude or deny to any State or political subdivision thereof the right otherwise to control, regulate, or restrict the use, operation, or movement of registered or licensed motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe4818fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonroad engines or vehicles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe4818ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain State standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No State or any political subdivision thereof shall adopt or attempt to enforce any standard or other requirement relating to the control of emissions from either of the following new nonroad engines or nonroad vehicles subject to regulation under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe481900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New engines which are used in construction equipment or vehicles or used in farm equipment or vehicles and which are smaller than 175 horsepower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe481901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New locomotives or new engines used in locomotives.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subsection (b) shall not apply for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe481902-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other nonroad engines or vehicles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe481903-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any nonroad vehicles or engines other than those referred to in subparagraph (A) or (B) of paragraph (1), the Administrator shall, after notice and opportunity for public hearing, authorize California to adopt and enforce standards and other requirements relating to the control of emissions from such vehicles or engines if California determines that California standards will be, in the aggregate, at least as protective of public health and welfare as applicable Federal standards. No such authorization shall be granted if the Administrator finds that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe481904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of California is arbitrary and capricious,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe481905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" California does not need such California standards to meet compelling and extraordinary conditions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe481906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" California standards and accompanying enforcement procedures are not consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe481907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any State other than California which has plan provisions approved under part D of subchapter I may adopt and enforce, after notice to the Administrator, for any period, standards relating to control of emissions from nonroad vehicles or engines (other than those referred to in subparagraph (A) or (B) of paragraph (1)) and take such other actions as are referred to in subparagraph (A) of this paragraph respecting such vehicles or engines if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe481908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such standards and implementation and enforcement are identical, for the period concerned, to the California standards authorized by the Administrator under subparagraph (A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe481909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7543/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" California and such State adopt such standards at least 2 years before commencement of the period for which the standards take effect.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator shall issue regulations to implement this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe48190a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 209, formerly § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/501"},"text":"81 Stat. 501","children":[],"tail":"; renumbered and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":", §§ 8(a), 11(a)(2)(A), 15(c)(2), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1694"},"text":"84 Stat. 1694","children":[],"tail":", 1705, 1713; "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tII"},"text":"Pub. L. 95–95, title II","children":[],"tail":", §§ 207, 221, "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/755"},"text":"91 Stat. 755","children":[],"tail":", 762; "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tII/s222/b"},"text":"Pub. L. 101–549, title II, § 222(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2502"},"text":"104 Stat. 2502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe48190b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe48190c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe48190d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857f–6a"},"text":"section 1857f–6a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe48190e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 209 of act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/502"},"text":"81 Stat. 502","children":[],"tail":", was renumbered section 210 by "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7544"},"text":"section 7544 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 209 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360/tII"},"text":"act July 14, 1955, ch. 360, title II","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/tI/s101/8"},"text":"Pub. L. 89–272, title I, § 101(8)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/995"},"text":"79 Stat. 995","children":[],"tail":", related to appropriations for the fiscal years ending "},{"tag":"date","attrib":{"date":"1966-06-30"},"text":"June 30, 1966","children":[],"tail":", 1967, 1968, and 1969, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857f–8"},"text":"section 1857f–8 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/675/s2/b"},"text":"Pub. L. 89–675, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/954"},"text":"80 Stat. 954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe48190f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549"},"text":"Pub. L. 101–549","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s207"},"text":"Pub. L. 95–95, § 207","children":[],"tail":", designated existing provisions as par. (1), substituted “"},{"tag":"date","attrib":{"date":"1966-03-30"},"text":"March 30, 1966","children":[],"tail":", if the State determines that the State standards will be, in the aggregate, at least as protective of public health and welfare as applicable Federal standards” for “"},{"tag":"date","attrib":{"date":"1966-03-30"},"text":"March 30, 1966","children":[],"tail":", unless he finds that such State does not require standards more stringent than applicable Federal standards to meet compelling the extraordinary conditions or that such State standards and accompanying enforcement procedures are not consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7521/a"},"text":"section 7521(a) of this title","children":[],"tail":"”, added subpars. (A), (B), and (C), and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s221"},"text":"Pub. L. 95–95, § 221","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s11/a/2/A"},"text":"Pub. L. 91–604, § 11(a)(2)(A)","children":[],"tail":", substituted “part” for “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s11/a/2/A"},"text":"Pub. L. 91–604, § 11(a)(2)(A)","children":[],"tail":", substituted “part” for “subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe481910-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe481911-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe481912-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification or Rescission of Rules, Regulations, Orders, Determinations, Contracts, Certifications, Authorizations, Delegations, and Other Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"All rules, regulations, orders, determinations, contracts, certifications, authorizations, delegations, or other actions duly issued, made, or taken by or pursuant to act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", the Clean Air Act, as in effect immediately prior to the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":"] to continue in full force and effect until modified or rescinded in accordance with act "},{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" [this chapter], see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/b"},"text":"section 406(b) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
