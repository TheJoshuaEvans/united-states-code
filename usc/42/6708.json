{"tag":"section","attrib":{"id":"idbdb8f872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6708"},"text":null,"children":[{"tag":"num","attrib":{"value":"6708"},"text":"§ 6708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage standards for laborers and mechanics; enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laborers and mechanics employed on projects assisted by the Secretary under this chapter shall be paid wages at rates not less than those prevailing on similar construction in the locality as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40. The Secretary shall not extend any financial assistance under this chapter for such project without first obtaining adequate assurance that these labor standards will be maintained upon the construction work. The Secretary of Labor shall have, with respect to the labor standards specified in this provision, the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (15 F.R. 3176; ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbdb8f873-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/369/tI/s109"},"text":"Pub. L. 94–369, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-22"},"text":"July 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1001"},"text":"90 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/28/tI/s108"},"text":"Pub. L. 95–28, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-13"},"text":"May 13, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/119"},"text":"91 Stat. 119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb8f874-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb8f875-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdb8f876-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 14 of 1950, referred to in text, is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdb8f877-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “sections 3141–3144, 3146, and 3147 of title 40” substituted for “the Davis-Bacon Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":"—276a–5)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1964-06-13/s2"},"text":"section 2 of the Act of June 13, 1964","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276c"},"text":"40 U.S.C. 276c","children":[],"tail":")”, meaning "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/s2"},"text":"section 2 of the Act of June 13, 1934","children":[],"tail":", on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdb8f878-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/28"},"text":"Pub. L. 95–28","children":[],"tail":" substituted “All laborers and mechanics employed” for “All laborers and mechanics employed by contractors or subcontractors”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
