{"tag":"section","attrib":{"id":"idbe8151c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8146"},"text":null,"children":[{"tag":"num","attrib":{"value":"8146"},"text":"§ 8146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for carrying out the purposes of this subchapter not to exceed $5,000,000 for fiscal year 1979, and not to exceed $5,000,000 for fiscal year 1980. Any amounts appropriated under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe8151c2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/557/tVIII/s807"},"text":"Pub. L. 95–557, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-31"},"text":"Oct. 31, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2124"},"text":"92 Stat. 2124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tI/s108"},"text":"Pub. L. 96–153, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1105"},"text":"93 Stat. 1105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8151c3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8151c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8151c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" reduced authorization of appropriation for fiscal year 1980 from “$10,000,000” to “$5,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
