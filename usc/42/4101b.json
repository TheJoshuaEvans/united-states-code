{"tag":"section","attrib":{"id":"idbcb4f5e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101b"},"text":"§ 4101b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Flood Mapping Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcb4f5ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewing, updating, and maintaining maps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the Technical Mapping Advisory Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4101a"},"text":"section 4101a of this title","children":[],"tail":", shall establish an ongoing program under which the Administrator shall review, update, and maintain National Flood Insurance Program rate maps in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f5eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb4f5ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f5ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify, review, update, maintain, and publish National Flood Insurance Program rate maps with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f5ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all populated areas and areas of possible population growth located within the 100-year floodplain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all populated areas and areas of possible population growth located within the 500-year floodplain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of residual risk, including areas that are protected by levees, dams, and other flood control structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas that could be inundated as a result of the failure of a levee, dam, or other flood control structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas that are protected by non-structural flood mitigation features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of protection provided by flood control structures and by non-structural flood mitigation features;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f5f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or update flood-risk zone data in all such areas, and make estimates with respect to the rates of probable flood caused loss for the various flood risk zones for each such area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f5f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, in identifying, reviewing, updating, maintaining, or publishing any National Flood Insurance Program rate map required under this section or under the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4011"},"text":"42 U.S.C. 4011","children":[],"tail":" et seq.), the most accurate topography and elevation data available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f5f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each map updated under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f5f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the accuracy of current ground elevation data used for hydrologic and hydraulic modeling of flooding sources and mapping of the flood hazard and wherever necessary acquire new ground elevation data utilizing the most up-to-date geospatial technologies in accordance with guidelines and specifications of the Federal Emergency Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f5f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop National Flood Insurance Program flood data on a watershed basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f5f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the most technically effective and efficient studies and hydrologic and hydraulic modeling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eliminate, to the maximum extent possible, discrepancies in base flood elevations between adjacent political subdivisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f5fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In updating maps under this section, the Administrator shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f5fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any relevant information on coastal inundation from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f5fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable inundation map of the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f5fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data of the National Oceanic and Atmospheric Administration relating to storm surge modeling;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f5ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant information of the United States Geological Survey on stream flows, watershed characteristics, and topography that is useful in the identification of flood hazard areas, as determined by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant information on land subsidence, coastal erosion areas, changing lake levels, and other flood-related hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant information or data of the National Oceanic and Atmospheric Administration and the United States Geological Survey relating to the best available science regarding future changes in sea levels, precipitation, and intensity of hurricanes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information as may be recommended by the Technical Mapping Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In updating and maintaining maps under this section, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb4f604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish standards to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that maps are adequate for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood risk determinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use by State and local governments in managing development to reduce the risk of flooding; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate identification and use of consistent methods of data collection and analysis by the Administrator, in conjunction with State and local governments, in developing maps for communities with similar flood risks, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish maps in a format that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f60a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" digital geospatial data compliant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f60b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliant with the open publishing and data exchange standards established by the Open Geospatial Consortium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f60c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligned with official data defined by the National Geodetic Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f60d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication and outreach","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcb4f60e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f60f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before commencement of any mapping or map updating process, notify each community affected of the model or models that the Administrator plans to use in such process and provide an explanation of why such model or models are appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide each community affected a 30-day period beginning upon notification under subparagraph (A) to consult with the Administrator regarding the appropriateness, with respect to such community, of the mapping model or models to be used; provided that consultation by a community pursuant to this subparagraph shall not waive or otherwise affect any right of the community to appeal any flood hazard determinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completion of the first Independent Data Submission, transmit a copy of such Submission to the affected community, provide the affected community a 30-day period during which the community may provide data to Administrator ","children":[{"tag":"ref","attrib":{"idref":"fn003348"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003348"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" that can be used to supplement or modify the existing data, and incorporate any data that is consistent with prevailing engineering principles;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States, local communities, and property owners to identify areas and features described in subsection (b)(1)(A)(v);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work to enhance communication and outreach to States, local communities, and property owners about the effects—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any potential changes to National Flood Insurance Program rate maps that may result from the mapping program required under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f615-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any such changes may have on flood insurance purchase requirements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f616-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with local communities to enhance communication and outreach to the residents of such communities, including tenants (with regard to contents insurance), on the matters described under subparagraph (E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f617-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less than 30 days before issuance of any preliminary map, notify the Senators for each State affected and each Member of the House of Representatives for each congressional district affected by the preliminary map in writing of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcb4f618-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the estimated schedule for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcb4f619-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community meetings regarding the preliminary map;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcb4f61a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publication of notices regarding the preliminary map in local newspapers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcb4f61b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commencement of the appeals process regarding the map; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcb4f61c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number of homes and businesses that will be affected by changes contained in the preliminary map, including how many structures will be ","children":[{"tag":"ref","attrib":{"idref":"fn003349"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003349"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The words “will be” probably should not appear."}],"tail":" that were not previously located in an area having special flood hazards will be located within such an area under the preliminary map; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f61d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the issuance of any proposed map and any notice of an opportunity to make an appeal relating to the proposed map, notify the Senators for each State affected and each Member of the House of Representatives for each congressional district affected by the proposed map of any action taken by the Administrator with respect to the proposed map or an appeal relating to the proposed map.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb4f61e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The communication and outreach activities required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcb4f61f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying property owners when their properties become included in, or when they are excluded from, an area covered by the mandatory flood insurance purchase requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4012a"},"text":"section 4012a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f620-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating property owners regarding the flood risk and reduction of this risk in their community, including the continued flood risks to areas that are no longer subject to the flood insurance mandatory purchase requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f621-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating property owners regarding the benefits and costs of maintaining or acquiring flood insurance, including, where applicable, lower-cost preferred risk policies under the National Flood Insurance Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4011"},"text":"42 U.S.C. 4011","children":[],"tail":" et seq.) for such properties and the contents of such properties;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f622-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating property owners about flood map revisions and the process available to such owners to appeal proposed changes in flood elevations through their community, including by notifying local radio and television stations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb4f623-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging property owners to maintain or acquire flood insurance coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f624-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community remapping request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the adoption by the Administrator of any recommendation by the Technical Mapping Advisory Council for reviewing, updating, or maintaining National Flood Insurance Program rate maps in accordance with this section, a community that believes that its flood insurance rates in effect prior to adoption would be affected by the adoption of such recommendation may submit a request for an update of its rate maps, which may be considered at the Administrator’s sole discretion. The Administrator shall establish a protocol for the evaluation of such community map update requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb4f625-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4101b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section $400,000,000 for each of fiscal years 2013 through 2017.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcb4f626-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tII/s100216"},"text":"Pub. L. 112–141, div. F, title II, § 100216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/927"},"text":"126 Stat. 927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/89"},"text":"Pub. L. 113–89","children":[],"tail":", §§ 27, 30, "},{"tag":"date","attrib":{"date":"2014-03-21"},"text":"Mar. 21, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1033"},"text":"128 Stat. 1033","children":[],"tail":", 1034.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcb4f627-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcb4f628-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcb4f629-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Flood Insurance Act of 1968, referred to in subsecs. (b)(1)(C) and (d)(2)(C), is title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/572"},"text":"82 Stat. 572","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4001"},"text":"section 4001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcb4f62a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Biggert-Waters Flood Insurance Reform Act of 2012, and also as part of the Moving Ahead for Progress in the 21st Century Act, also known as the MAP–21, and not as part of the National Flood Insurance Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcb4f62b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(A)(v), (vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s27/1"},"text":"Pub. L. 113–89, § 27(1)","children":[],"tail":", added cl. (v), redesignated former cl. (v) as (vi), and, in cl. (vi), inserted “and by non-structural flood mitigation features” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/3"},"text":"Pub. L. 113–89, § 30(3)","children":[],"tail":", added subpar. (A). Former subpar. (A) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s27/2/C"},"text":"Pub. L. 113–89, § 27(2)(C)","children":[],"tail":", added subpar. (A). Former subpar. (A) redesignated (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/3"},"text":"Pub. L. 113–89, § 30(3)","children":[],"tail":", added subpar. (B). Former subpar. (B) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s27/2/A"},"text":"Pub. L. 113–89, § 27(2)(A)","children":[],"tail":", redesignated subpar. (A) as (B). Former subpar. (B) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/3"},"text":"Pub. L. 113–89, § 30(3)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/1"},"text":"Pub. L. 113–89, § 30(1)","children":[],"tail":", substituted “subparagraph (E)” for “subparagraph (B)” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s27/2/A"},"text":"Pub. L. 113–89, § 27(2)(A)","children":[],"tail":", (B), redesignated subpar. (B) as (C) and substituted “subparagraph (B)” for “subparagraph (A)”. Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/2"},"text":"Pub. L. 113–89, § 30(2)","children":[],"tail":", redesignated subpar. (A) as (D). Former subpar. (D) redesignated (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s27/2/A"},"text":"Pub. L. 113–89, § 27(2)(A)","children":[],"tail":", redesignated subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/2"},"text":"Pub. L. 113–89, § 30(2)","children":[],"tail":", redesignated subpars. (B) and (C) as (E) and (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/4"},"text":"Pub. L. 113–89, § 30(4)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/89/s30/2"},"text":"Pub. L. 113–89, § 30(2)","children":[],"tail":", redesignated subpar. (D) as (H)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcb4f62c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbcb4f62d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4004"},"text":"section 4004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
