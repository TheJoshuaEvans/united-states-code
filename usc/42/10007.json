{"tag":"section","attrib":{"id":"idbf0b8ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007"},"text":null,"children":[{"tag":"num","attrib":{"value":"10007"},"text":"§ 10007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal radiation guidelines","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in conjunction with the Radiation Policy Council, the Secretary of Veterans Affairs, the Administrator of the Environmental Protection Agency, appropriate agencies of the States, and appropriate professional organizations, promulgate Federal radiation guidelines with respect to radiologic procedures. Such guidelines shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the level of radiation exposure due to radiologic procedures which is unnecessary and specify the techniques, procedures, and methods to minimize such unnecessary exposure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b9000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the elimination of the need for retakes of diagnostic radiologic procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b9001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the elimination of unproductive screening programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b9002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the optimum diagnostic information with minimum radiologic exposure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b9003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10007/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the therapeutic application of radiation to individuals in the treatment of disease, including nuclear medicine applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b9004-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s982"},"text":"Pub. L. 97–35, title IX, § 982","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/601"},"text":"95 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/q/13/B"},"text":"Pub. L. 102–54, § 13(q)(13)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/281"},"text":"105 Stat. 281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b9005-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf0b9006-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf0b9007-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
