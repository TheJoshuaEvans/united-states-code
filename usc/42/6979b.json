{"tag":"section","attrib":{"id":"idbde3d889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6979b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6979b"},"text":"§ 6979b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General of the United States shall, at the request of the Administrator and on the basis of a showing of need, deputize qualified employees of the Environmental Protection Agency to serve as special deputy United States marshals in criminal investigations with respect to violations of the criminal provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbde3d88a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s7010"},"text":"Pub. L. 89–272, title II, § 7010","children":[],"tail":", formerly § 7012, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tIV/s403/b/1"},"text":"Pub. L. 98–616, title IV, § 403(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3272"},"text":"98 Stat. 3272","children":[],"tail":"; renumbered § 7010, "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tII/s201/c/2"},"text":"Pub. L. 99–339, title II, § 201(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/654"},"text":"100 Stat. 654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbde3d88b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbde3d88c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":