{"tag":"section","attrib":{"id":"idbd193630-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173"},"text":null,"children":[{"tag":"num","attrib":{"value":"5173"},"text":"§ 5173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debris removal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd193631-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, whenever he determines it to be in the public interest, is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd193632-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the use of Federal departments, agencies, and instrumentalities, to clear debris and wreckage resulting from a major disaster from publicly and privately owned lands and waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd193633-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants to any State or local government or owner or operator of a private nonprofit facility for the purpose of removing debris or wreckage resulting from a major disaster from publicly or privately owned lands and waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd193634-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization by State or local government; indemnification agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No authority under this section shall be exercised unless the affected State or local government shall first arrange an unconditional authorization for removal of such debris or wreckage from public and private property, and, in the case of removal of debris or wreckage from private property, shall first agree to indemnify the Federal Government against any claim arising from such removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd193635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to large lots","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall issue rules which provide for recognition of differences existing among urban, suburban, and rural lands in implementation of this section so as to facilitate adequate removal of debris and wreckage from large lots.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd193636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of assistance under this section shall be not less than 75 percent of the eligible cost of debris and wreckage removal carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd193637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd193638-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a grant under subsection (a)(2), the President shall provide not less than 50 percent of the President’s initial estimate of the Federal share of assistance as an initial payment in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd193639-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5173/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of the estimate described in paragraph (1) and not later than 90 days after the date on which the State or local government or owner or operator of a private nonprofit facility applies for assistance under this section, an initial payment described in paragraph (1) shall be paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd19363a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s407"},"text":"Pub. L. 93–288, title IV, § 407","children":[],"tail":", formerly § 403, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/154"},"text":"88 Stat. 154","children":[],"tail":"; renumbered § 407 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/c"},"text":"Pub. L. 100–707, title I, § 106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4701"},"text":"102 Stat. 4701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVI/s610"},"text":"Pub. L. 109–347, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1942"},"text":"120 Stat. 1942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd19363b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd19363c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd19363d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s407"},"text":"section 407 of Pub. L. 93–288","children":[],"tail":" was renumbered section 410 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5177"},"text":"section 5177 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd19363e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/s106/c/2"},"text":"Pub. L. 100–707, § 106(c)(2)","children":[],"tail":", inserted “or owner or operator of a private nonprofit facility” after “local government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/s106/c/3"},"text":"Pub. L. 100–707, § 106(c)(3)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd19363f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd193640-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disaster Contract Improvement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/153"},"text":"Pub. L. 118–153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-17"},"text":"Dec. 17, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1688"},"text":"138 Stat. 1688","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/153"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Disaster Contract Improvement Act’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OVERSIGHT ON DEBRIS REMOVAL.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administrator’ means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Debris removal program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘debris removal program’ means the program established under section 407 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5173"},"text":"42 U.S.C. 5173","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Working Group.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish an advisory working group to encourage and foster collaborative efforts among individuals and entities engaged in disaster recovery relating to debris removal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory working group established under paragraph (1) shall be comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the Army Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the Natural Resources Conservation Service of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of States, Tribal governments, and units of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject matter experts in debris removal, including not less than 1 representative from the debris services contractor industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-17"},"text":"Dec. 17, 2024","children":[],"tail":"], the Administrator, in consultation with the advisory working group established under subsection (b)(1), shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether guidance and procedures in effect as of the date of enactment of this Act with respect to the oversight and cost of debris removal contracts entered into under the debris removal program are sufficient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Administrator, in consultation with the advisory working group established under subsection (b)(1), determines that the guidance and procedures described in paragraph (1) are insufficient, develop and implement additional such guidance and procedures, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that each State, Tribal government, and unit of local government receiving a grant under the debris removal program take the primary role in the oversight function of debris removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance for State, Tribal, and local debris monitors relating to debris removal operations, debris operations oversight, and contractor oversight, including contractor monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance for streamlining the reimbursement of debris costs overall, including debris management planning and support for resilience in debris removal operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" checklists, job aids, eligibility requirements, contract requirements, debris management planning guidance, sample bids, and other items, as determined necessary by the Administrator, for State and local debris monitors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the specific debris removal monitoring responsibilities expected to be completed by a State that receives a grant under the debris removal program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the specific debris removal monitoring responsibilities expected to be completed by recipients of a grant under the debris removal program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance for State and Tribal governments and units of local government to reduce duplication and inefficiency in debris removal contracting across the Federal Government, State and Tribal governments, and units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall conduct outreach to States, Tribal governments, and units of local government with respect to any guidance or support materials developed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"GAO Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-17"},"text":"Dec. 17, 2024","children":[],"tail":"], the Comptroller General of the United States shall conduct a study that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies the use and adoption rate of advance contracts for debris removal by selected States, Tribal governments, and units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the benefits and challenges of advance contracts for debris removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the reporting and information sharing processes, as of the date of enactment of this Act, for advance contracts for debris removal between States and units of local government and Federal partners—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses those processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any necessary recommendations for those processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" studies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process for setting Federal reimbursement rates for the debris removal program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of penalties, as of the date of enactment of this Act, for violations of law and regulations relating to debris removal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraud, waste, and abuse relating to the debris removal program, including case studies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any necessary recommendations for improvements to oversight and fraud prevention across the debris removal program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
