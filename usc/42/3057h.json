{"tag":"section","attrib":{"id":"idbc68aa69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057h"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057h"},"text":"§ 3057h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A public or nonprofit private organization having the capacity to provide services under this part for Native Hawaiians is eligible for assistance under this part only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68aa6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization will serve at least 50 individuals who have attained 60 years of age or older; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68aa6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization demonstrates the ability to deliver supportive services, including nutrition services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68aa6c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s622"},"text":"Pub. L. 89–73, title VI, § 622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/961"},"text":"101 Stat. 961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68aa6d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc68aa6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc68aa6f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"section 3026(a) of this title","children":[],"tail":" or any State plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a"},"text":"section 3027(a) of this title","children":[],"tail":" and approved for any fiscal year beginning before "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", see section 701(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
