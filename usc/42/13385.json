{"tag":"section","attrib":{"id":"idbfbe65f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385"},"text":null,"children":[{"tag":"num","attrib":{"value":"13385"},"text":"§ 13385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National inventory and voluntary reporting of greenhouse gases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbe65fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, through the Energy Information Administration, shall develop, based on data available to, and obtained by, the Energy Information Administration, an inventory of the national aggregate emissions of each greenhouse gas for each calendar year of the baseline period of 1987 through 1990. The Administrator of the Energy Information Administration shall annually update and analyze such inventory using available data. This subsection does not provide any new data collection authority."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbe65fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbe65fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall, after opportunity for public comment, issue guidelines for the voluntary collection and reporting of information on sources of greenhouse gases. Such guidelines shall establish procedures for the accurate voluntary reporting of information on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfbe65fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" greenhouse gas emissions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfbe65fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the baseline period of 1987 through 1990; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfbe65ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for subsequent calendar years on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6600-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual reductions of greenhouse gas emissions and carbon fixation achieved through any measures, including fuel switching, forest management practices, tree planting, use of renewable energy, manufacture or use of vehicles with reduced greenhouse gas emissions, appliance efficiency, energy efficiency, methane recovery, cogeneration, chlorofluorocarbon capture and replacement, and power plant heat rate improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6601-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reductions in greenhouse gas emissions achieved as a result of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfbe6602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary reductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfbe6603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant or facility closings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfbe6604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or Federal requirements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfbe6605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aggregate calculation of greenhouse gas emissions by each reporting entity.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such guidelines shall also establish procedures for taking into account the differential radiative activity and atmospheric lifetimes of each greenhouse gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe6606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Energy Information Administration shall develop forms for voluntary reporting under the guidelines established under paragraph (1), and shall make such forms available to entities wishing to report such information. Persons reporting under this subsection shall certify the accuracy of the information reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe6607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trade secret and commercial or financial information that is privileged or confidential shall be protected as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbe6608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of data base","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary, through the Administrator of the Energy Information Administration, shall establish a data base comprised of information voluntarily reported under this subsection. Such information may be used by the reporting entity to demonstrate achieved reductions of greenhouse gases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbe6609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult, as appropriate, with the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d60a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXVI/s1605"},"text":"Pub. L. 102–486, title XVI, § 1605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3002"},"text":"106 Stat. 3002","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
