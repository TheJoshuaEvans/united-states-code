{"tag":"section","attrib":{"id":"idb647e8fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–14"},"text":"§ 300j–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source water petition program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb647e8fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e8fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e8fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may establish a program under which an owner or operator of a community water system in the State, or a municipal or local government or political subdivision of a State (including a county that is designated by the State to act on behalf of an unincorporated area within that county, with the agreement of that unincorporated area), may submit a source water quality protection partnership petition to the State requesting that the State assist in the local development of a voluntary, incentive-based partnership, among the owner, operator, or government and other persons likely to be affected by the recommendations of the partnership, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e8ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the presence in drinking water of contaminants that may be addressed by a petition by considering the origins of the contaminants, including to the maximum extent practicable the specific activities that affect the drinking water supply of a community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e900-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain financial or technical assistance necessary to facilitate establishment of a partnership, or to develop and implement recommendations of a partnership for the protection of source water to assist in the provision of drinking water that complies with national primary drinking water regulations with respect to contaminants addressed by a petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e901-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations regarding voluntary and incentive-based strategies for the long-term protection of the source water of community water systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e902-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e903-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use funds set aside pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12/k/1/A/iii"},"text":"section 300j–12(k)(1)(A)(iii) of this title","children":[],"tail":" by the State to carry out a program described in subparagraph (A), including assistance to voluntary local partnerships for the development and implementation of partnership recommendations for the protection of source water such as source water quality assessment, contingency plans, and demonstration projects for partners within a source water area delineated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–13/a"},"text":"section 300j–13(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e904-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance in response to a petition submitted under this subsection using funds referred to in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e905-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of a petition submitted under this subsection shall be to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e906-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the local development of voluntary, incentive-based partnerships among owners and operators of community water systems, governments, and other persons in source water areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e907-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain assistance from the State in identifying resources which are available to implement the recommendations of the partnerships to address the origins of drinking water contaminants that may be addressed by a petition (including to the maximum extent practicable the specific activities contributing to the presence of the contaminants) that affect the drinking water supply of a community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e908-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contaminants addressed by a petition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A petition submitted to a State under this subsection may address only those contaminants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are pathogenic organisms for which a national primary drinking water regulation has been established or is required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–1"},"text":"section 300g–1 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e90a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which a national primary drinking water regulation has been promulgated or proposed and that are detected by adequate monitoring methods in the source water at the intake structure or in any collection, treatment, storage, or distribution facilities by the community water systems at levels—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e90b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" above the maximum contaminant level; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e90c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are not reliably and consistently below the maximum contaminant level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e90d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A petition submitted under this subsection shall, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e90e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a delineation of the source water area in the State that is the subject of the petition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e90f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, to the maximum extent practicable, the origins of the drinking water contaminants that may be addressed by a petition (including to the maximum extent practicable the specific activities contributing to the presence of the contaminants) in the source water area delineated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–13"},"text":"section 300j–13 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e910-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any deficiencies in information that will impair the development of recommendations by the voluntary local partnership to address drinking water contaminants that may be addressed by a petition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e911-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specify the efforts made to establish the voluntary local partnership and obtain the participation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e912-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the municipal or local government or other political subdivision of the State (including a county that is designated by the State to act on behalf of an unincorporated area within that county) with jurisdiction over the source water area delineated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–13"},"text":"section 300j–13 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e913-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each person in the source water area delineated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–13"},"text":"section 300j–13 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb647e914-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is likely to be affected by recommendations of the voluntary local partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb647e915-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose participation is essential to the success of the partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e916-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline how the voluntary local partnership has or will, during development and implementation of recommendations of the voluntary local partnership, identify, recognize and take into account any voluntary or other activities already being undertaken by persons in the source water area delineated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–13"},"text":"section 300j–13 of this title","children":[],"tail":" under Federal or State law to reduce the likelihood that contaminants will occur in drinking water at levels of public health concern; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e917-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the technical, financial, or other assistance that the voluntary local partnership requests of the State to develop the partnership or to implement recommendations of the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise provided within the agreement, an agreement between an unincorporated area and a county for the county to submit a petition under paragraph (1)(A) on behalf of the unincorporated area shall not authorize the county to act on behalf of the unincorporated area in any matter not within a program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or disapproval of petitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e91a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After providing notice and an opportunity for public comment on a petition submitted under subsection (a), the State shall approve or disapprove the petition, in whole or in part, not later than 120 days after the date of submission of the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e91b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State may approve a petition if the petition meets the requirements established under subsection (a). The notice of approval shall, at a minimum, include for informational purposes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e91c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of technical, financial, or other assistance that the State will provide to assist in addressing the drinking water contaminants that may be addressed by a petition based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e91d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative priority of the public health concern identified in the petition with respect to the other water quality needs identified by the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e91e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any necessary coordination that the State will perform of the program established under this section with programs implemented or planned by other States under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e91f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds available (including funds available from a State revolving loan fund established under title VI of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.)) or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of technical or financial assistance pursuant to Federal and State programs that is available to assist in implementing recommendations of the partnership in the petition, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb647e921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program established under the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1455b"},"text":"section 1455b of title 16","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural water quality protection program established under chapter 2 of subtitle D of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3838"},"text":"16 U.S.C. 3838","children":[],"tail":" et seq.);"},{"tag":"ref","attrib":{"idref":"fn002353"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002353"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sole source aquifer protection program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300h–6"},"text":"section 300h–6 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community wellhead protection program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300h–7"},"text":"section 300h–7 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide or ground water management plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any voluntary agricultural resource management plan or voluntary whole farm or whole ranch management plan developed and implemented under a process established by the Secretary of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb647e928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any abandoned well closure program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of activities that will be undertaken to coordinate Federal and State programs to respond to the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e92a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the State disapproves a petition submitted under subsection (a), the State shall notify the entity submitting the petition in writing of the reasons for disapproval. A petition may be resubmitted at any time if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e92b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new information becomes available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e92c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conditions affecting the source water that is the subject of the petition change; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e92d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications are made in the type of assistance being requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e92e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to support State programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e92f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make a grant to each State that establishes a program under this section that is approved under paragraph (2). The amount of each grant shall not exceed 50 percent of the cost of administering the program for the year in which the grant is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive grant assistance under this subsection, a State shall submit to the Administrator for approval a plan for a source water quality protection partnership program that is consistent with the guidance published under subsection (d). The Administrator shall approve the plan if the plan is consistent with the guidance published under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", the Administrator, in consultation with the States, shall publish guidance to assist—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States in the development of a source water quality protection partnership program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipal or local governments or political subdivisions of a State and community water systems in the development of source water quality protection partnerships and in the assessment of source water quality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of the guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance shall, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend procedures for the approval or disapproval by a State of a petition submitted under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend procedures for the submission of petitions developed under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend criteria for the assessment of source water areas within a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe technical or financial assistance pursuant to Federal and State programs that is available to address the contamination of sources of drinking water and to develop and respond to petitions submitted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e93a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of the fiscal years 2020 through 2026. Each State with a plan for a program approved under subsection (b) shall receive an equitable portion of the funds available for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb647e93b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb647e93c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb647e93d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates or conveys new authority to a State, political subdivision of a State, or community water system for any new regulatory measure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb647e93e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits any authority of a State, political subdivision, or community water system; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb647e93f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–14/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precludes a community water system, municipal or local government, or political subdivision of a government from locally developing and carrying out a voluntary, incentive-based, source water quality protection partnership to address the origins of drinking water contaminants of public health concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb647e940-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1454, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tI/s133/a"},"text":"Pub. L. 104–182, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1675"},"text":"110 Stat. 1675","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2016"},"text":"Pub. L. 115–270, title II, § 2016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3856"},"text":"132 Stat. 3856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50103"},"text":"Pub. L. 117–58, div. E, title I, § 50103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1137"},"text":"135 Stat. 1137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb647e941-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb647e942-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb647e943-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (b)(2)(A)(iii), (B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. Title VI of the Act is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of Title 33. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (b)(2)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Chapter 2 of subtitle D of title XII of the Act means chapter 2 of subtitle D of title XII of "},{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1439"},"text":"Pub. L. 101–624, title XIV, § 1439","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3590"},"text":"104 Stat. 3590","children":[],"tail":", which was classified generally to part II (§ 3838 et seq.) of subchapter IV of chapter 58 of Title 16, Conservation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIII/s336/h"},"text":"Pub. L. 104–127, title III, § 336(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1007"},"text":"110 Stat. 1007","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of Title 7","children":[],"tail":", Agriculture, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb647e944-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50103/1/A"},"text":"Pub. L. 117–58, § 50103(1)(A)","children":[],"tail":", substituted “political subdivision of a State (including a county that is designated by the State to act on behalf of an unincorporated area within that county, with the agreement of that unincorporated area),” for “political subdivision of a State,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50103/1/B"},"text":"Pub. L. 117–58, § 50103(1)(B)","children":[],"tail":", inserted “(including a county that is designated by the State to act on behalf of an unincorporated area within that county)” after “of the State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50103/1/C"},"text":"Pub. L. 117–58, § 50103(1)(C)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50103/2"},"text":"Pub. L. 117–58, § 50103(2)","children":[],"tail":", substituted “2026” for “2021”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" substituted “2020 through 2021” for “1997 through 2003”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
