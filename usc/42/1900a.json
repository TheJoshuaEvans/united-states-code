{"tag":"section","attrib":{"id":"idbba07839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1900a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1900a"},"text":"§ 1900a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such rules and regulations as he deems necessary to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba0783a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/672/s2"},"text":"Pub. L. 89–672, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/951"},"text":"80 Stat. 951","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
