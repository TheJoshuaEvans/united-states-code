{"tag":"section","attrib":{"id":"idbfe48b6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833"},"text":null,"children":[{"tag":"num","attrib":{"value":"15833"},"text":"§ 15833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a pilot program under which the Secretary provides financial assistance to at least 3, but not more than 7, States to carry out pilot projects in the States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" planning and adopting statewide programs that encourage, for each year in which the pilot project is carried out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48b72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduction of consumption of electricity or natural gas in the State by at least 0.75 percent, as compared to a baseline determined by the Secretary for the period preceding the implementation of the program; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any State that has adopted a statewide program as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", activities that reduce energy consumption in the State by expanding and improving the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives financial assistance under subsection (a)(1) shall submit to the Secretary independent verification of any energy savings achieved through the statewide program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15833/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2006 through 2010, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s140"},"text":"Pub. L. 109–58, title I, § 140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/647"},"text":"119 Stat. 647","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
