{"tag":"section","attrib":{"id":"idbfc0d6b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411"},"text":null,"children":[{"tag":"num","attrib":{"value":"13411"},"text":"§ 13411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced oil recovery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d6b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, on technologies to increase the recoverability of domestic oil resources to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve reservoir characterization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve analysis and field verification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field test and demonstrate enhanced oil recovery processes, including advanced processes, in reservoirs the Secretary considers to be of high priority, ranked primarily on the basis of oil recovery potential and risk of abandonment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer proven recovery technologies to producers and operators of wells, including stripper wells, that would otherwise be likely to be abandoned in the near term due to declining production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve enhanced oil recovery process technology for more economic and efficient oil production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and develop new recovery technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study reservoir properties and how they affect oil recovery from porous media;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve techniques for meeting environmental requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve data bases of reservoir and environmental conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower lifting costs on stripper wells by utilizing advanced renewable energy technologies such as small wind turbines and others.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Near-term priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The near-term priorities of the program include preserving access to high potential reservoirs, identifying available technologies that can extend the lifetime of wells and of stripper well property, and developing environmental field operations for waste disposal and injection practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mid-term priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mid-term priorities of the program include developing and testing identified but unproven technologies, and transferring those technologies for widespread use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The long-term priorities of the program include developing advanced techniques to recover oil not recoverable by other techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated program plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall prepare and submit to the Congress a plan for carrying out under this section the accelerated field testing of technologies to achieve the priorities stated in subsection (b). In preparing the plan, the Secretary shall consult with appropriate representatives of industry, institutions of higher education, Federal agencies, including national laboratories, and professional and technical societies, and with the Advisory Board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13522"},"text":"section 13522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this section, the Secretary shall consult representatives of the oil and gas industry with respect to innovative research and development proposals to improve oil and gas recovery and shall consider relevant technical data from industry and other research and information centers and institutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13411/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section, including advanced extraction and process technology, $57,250,000 for fiscal year 1993 and $70,000,000 for fiscal year 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d6c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2011"},"text":"Pub. L. 102–486, title XX, § 2011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3057"},"text":"106 Stat. 3057","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
