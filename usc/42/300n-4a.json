{"tag":"section","attrib":{"id":"idb6515f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300n–4a"},"text":"§ 300n–4a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grants for additional preventive health services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6515f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":", the Secretary, acting through the Director of the Centers for Disease Control and Prevention, may make grants to not more than 3 such States to carry out demonstration projects for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing preventive health services in addition to the services authorized in such section, including screenings regarding blood pressure and cholesterol, and including health education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing appropriate referrals for medical treatment of women receiving services pursuant to paragraph (1) and ensuring, to the extent practicable, the provision of appropriate follow-up services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating activities conducted under paragraphs (1) and (2) through appropriate surveillance or program-monitoring activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as participant in program regarding breast and cervical cancer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the State involved agrees that services under the grant will be provided only through entities that are screening women for breast or cervical cancer pursuant to a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of provisions of general program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter applies to a grant under subsection (a) to the same extent and in the same manner as such subchapter applies to a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300k"},"text":"section 300k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6515f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6515f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), for the purpose of carrying out this section, there are authorized to be appropriated $3,000,000 for fiscal year 1994, and such sums as may be necessary for each of the fiscal years 1995 through 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6515f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300n–4a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation regarding funding with respect to breast and cervical cancer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorization of appropriations established in paragraph (1) is not effective for a fiscal year unless the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300n–5/a"},"text":"section 300n–5(a) of this title","children":[],"tail":" for the fiscal year is equal to or greater than $100,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6515f39-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XV, § 1509, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tI/s102/a/2"},"text":"Pub. L. 103–183, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2229"},"text":"107 Stat. 2229","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/340/tII/s203/c/1"},"text":"Pub. L. 105–340, title II, § 203(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3194"},"text":"112 Stat. 3194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6515f3a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6515f3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6515f3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1509 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 1510 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300n–5"},"text":"section 300n–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6515f3d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/340"},"text":"Pub. L. 105–340","children":[],"tail":" substituted “2003” for “1998”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
