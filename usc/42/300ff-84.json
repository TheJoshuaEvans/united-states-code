{"tag":"section","attrib":{"id":"idb6a28c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–84"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–84"},"text":"§ 300ff–84.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on promotion of certain activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the funds appropriated under this subchapter shall be used to fund AIDS programs, or to develop materials, designed to promote or encourage, directly, intravenous drug use or sexual activity, whether homosexual or heterosexual. Funds authorized under this subchapter may be used to provide medical treatment and support services for individuals with HIV.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6a28c6b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2684, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tV/s501"},"text":"Pub. L. 109–415, title V, § 501","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2814"},"text":"120 Stat. 2814","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a28c6c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a28c6d-3a70-11f1-ae07-e4213316b5fa"},"t