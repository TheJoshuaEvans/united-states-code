{"tag":"section","attrib":{"id":"idc0227e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063"},"text":null,"children":[{"tag":"num","attrib":{"value":"17063"},"text":"§ 17063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy information for commercial buildings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0227e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", the Secretary of Energy, in collaboration with the Administrator of the Environmental Protection Agency, shall complete a study—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the impact of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227e21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local performance benchmarking and disclosure policies, and any associated building efficiency policies, for commercial and multifamily buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and systems in which utilities provide aggregated information regarding whole building energy consumption and usage information to owners of multitenant commercial, residential, and mixed-use buildings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that identifies best practice policy approaches studied under subparagraph (A) that have resulted in the greatest improvements in building energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that considers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance rates and the benefits and costs of the policies and programs on building owners, utilities, tenants, and other parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utility practices, programs, and systems that provide aggregated energy consumption information to multitenant building owners, and the impact of public utility commissions and State privacy laws on those practices, programs, and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceptions to compliance in existing laws where building owners are not able to gather or access whole building energy information from tenants or utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the treatment of buildings with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0227e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple uses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses for which baseline information is not available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0227e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses that require high levels of energy intensities, such as data centers, trading floors, and televisions ","children":[{"tag":"ref","attrib":{"idref":"fn004242"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004242"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “television”."}],"tail":" studios;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation practices, including disclosure methods and phase-in of compliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and security of benchmarking tools offered by government agencies, and the resiliency of those tools against cyber attacks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international experiences with regard to building benchmarking and disclosure laws and data aggregation for multitenant buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the conclusion of the study, the Secretary shall submit to the Committee on Energy and Commerce of the House of Representatives and Committee on Energy and Natural Resources of the Senate a report on the results of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation and maintenance of database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0227e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", and following opportunity for public notice and comment, the Secretary of Energy, in coordination with other relevant agencies, shall maintain, and if necessary create, a database for the purpose of storing and making available public energy-related information on commercial and multifamily buildings, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data provided under Federal, State, local, and other laws or programs regarding building benchmarking and energy information disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on buildings that have disclosed energy ratings and certifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy-related information on buildings provided voluntarily by the owners of the buildings, only in an anonymous form unless the owner provides otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complementary programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The database maintained pursuant to paragraph (1) shall complement and not duplicate the functions of the Environmental Protection Agency’s Energy Star Portfolio Manager tool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Input from stakeholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall seek input from stakeholders to maximize the effectiveness of the actions taken under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17063/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", and every 2 years thereafter, the Secretary of Energy shall submit to the Committee on Energy and Commerce of the House of Representatives and Committee on Energy and Natural Resources of the Senate a report on the progress made in complying with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227e38-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/11/tIII/s301"},"text":"Pub. L. 114–11, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-30"},"text":"Apr. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/189"},"text":"129 Stat. 189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227e39-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0227e3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0227e3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/11/s301"},"text":"section 301 of Pub. L. 114–11","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/11/s301"},"text":"section 301 of Pub. L. 114–11","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17091"},"text":"section 17091 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Efficiency Improvement Act of 2015, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
