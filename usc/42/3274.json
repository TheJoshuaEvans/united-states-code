{"tag":"section","attrib":{"id":"idbc7bbd58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3274"},"text":null,"children":[{"tag":"num","attrib":{"value":"3274"},"text":"§ 3274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the purposes of this chapter, such sums to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc7bbd59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/560/s4"},"text":"Pub. L. 89–560, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-07"},"text":"Sept. 7, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/706"},"text":"80 Stat. 706","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
