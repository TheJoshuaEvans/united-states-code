{"tag":"section","attrib":{"id":"idbe58bb17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7611"},"text":null,"children":[{"tag":"num","attrib":{"value":"7611"},"text":"§ 7611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe58bb18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients of assistance to keep prescribed rec­ords","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of assistance under this chapter shall keep such records as the Administrator shall prescribe, including records which fully disclose the amount and disposition by such recipient of the proceeds of such assistance, the total cost of the project or undertaking in connection with which such assistance is given or used, and the amount of that portion of the cost of the project or undertaking supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe58bb19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examinations to any books, documents, papers, and records of the recipients that are pertinent to the grants received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe58bb1a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 311, formerly § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/206/s1"},"text":"Pub. L. 88–206, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-17"},"text":"Dec. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/401"},"text":"77 Stat. 401","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/tI/s101/4"},"text":"Pub. L. 89–272, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/992"},"text":"79 Stat. 992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/505"},"text":"81 Stat. 505","children":[],"tail":"; renumbered § 311 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":", §§ 12(a), 15(c)(2), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1705"},"text":"84 Stat. 1705","children":[],"tail":", 1713.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe58bb1b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe58bb1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic