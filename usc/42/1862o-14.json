{"tag":"section","attrib":{"id":"idbb8fb053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862o–14"},"text":"§ 1862o–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major research instrumentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb8fb054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum amount of an award under the Major Research Instrumentation program shall be $100,000. The maximum amount of an award under the program shall be $4,000,000 except if the total amount appropriated for the program for a fiscal year exceeds $125,000,000, in which case the maximum amount of an award shall be $6,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8fb055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the acquisition of instrumentation and equipment, funds made available by awards under the Major Research Instrumentation program may be used to support the operations and maintenance of such instrumentation and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb8fb056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8fb057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education receiving an award under the Major Research Instrumentation program shall provide at least 30 percent of the cost from private or non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fb058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Institutions of higher education that are not Ph.D.-granting institutions are exempt from the cost sharing requirement in paragraph (1), and the Director may reduce or waive the cost sharing requirement for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb8fb059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" institutions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb8fb05a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are not ranked among the top 100 institutions receiving Federal research and development funding, as documented by the statistical data published by the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb8fb05b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the proposed project will make a substantial improvement in the institution’s capabilities to conduct leading edge research, to provide research experiences for undergraduate students using leading edge facilities, and to broaden the participation in science and engineering research by individuals identified in section 1885a or 1885b of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb8fb05c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–14/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consortia of institutions of higher education that include at least one institution that is not a Ph.D.-granting institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8fb05d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7036"},"text":"Pub. L. 110–69, title VII, § 7036","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/714"},"text":"121 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8fb05e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8fb05f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8fb060-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Act, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8fb061-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8fb062-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/s7001"},"text":"section 7001 of Pub. L. 110–69","children":[],"tail":", set out as a note under section 1862"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
