{"tag":"section","attrib":{"id":"idbd630ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852"},"text":null,"children":[{"tag":"num","attrib":{"value":"5852"},"text":"§ 5852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd630ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for salaries and expenses; additional purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated for “Nuclear Regulatory Commission—Salaries and Expenses” shall be available to the Commission for the following additional purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd630ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employment of aliens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd630ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd630ffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publication and dissemination of atomic information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd630ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase, repair, and cleaning of uniforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd630fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursements to the General Services Administration for security guard services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd631000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hire of passenger motor vehicles and aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd631001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfers of funds to other agencies of the Federal Government for the performance of the work for which such funds are appropriated, and such transferred funds may be merged with the appropriations to which they are transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd631002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfers to the Office of Inspector General of the Commission, not to exceed an additional amount equal to 5 percent of the amount otherwise appropriated to the Office for the fiscal year. Notice of such transfers shall be submitted to the Committees on Appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd631003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for Office of Inspector General; additional purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated for “Nuclear Regulatory Commission—Office of Inspector General” shall be available to the Office for the additional purposes described in paragraphs (2) and (7) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd631004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of program funds for salaries and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Moneys received by the Commission for the cooperative nuclear research program, services rendered to State governments, foreign governments, and international organizations, and the material and information access authorization programs, including criminal history checks under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2169"},"text":"section 2169 of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn003440"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003440"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" may be retained and used for salaries and expenses associated with those activities, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", and shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd631005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds to provide voluntary separation incentive payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663/c/2/D"},"text":"section 663(c)(2)(D) of Public Law 104–208","children":[],"tail":", and to facilitate targeted workforce downsizing and restructuring, the Chairman of the Nuclear Regulatory Commission may use funds appropriated in this Act to exercise the authority provided by section 663 of that Act with respect to employees who voluntarily separate from "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"October 7, 1998","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":". All of the requirements in "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663"},"text":"section 663 of Public Law 104–208","children":[],"tail":", except for section 663(c)(2)(D), apply to the exercise of authority under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd631006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5852/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a), (b), and (c) of this section shall apply to fiscal year 1999 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd631007-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/245/tV/s506"},"text":"Pub. L. 105–245, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1856"},"text":"112 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd631008-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd631009-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd63100a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663"},"text":"Section 663 of Public Law 104–208","children":[],"tail":", referred to in subsec. (d), is "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663"},"text":"section 663 of Pub. L. 104–208","children":[],"tail":", div. A, title I, § 101(f) [title VI], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–383, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"section 5597 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d), is ","childr