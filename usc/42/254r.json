{"tag":"section","attrib":{"id":"idb4fec71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r"},"text":null,"children":[{"tag":"num","attrib":{"value":"254r"},"text":"§ 254r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to State Offices of Rural Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fec720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the Federal Office of Rural Health Policy (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s912"},"text":"section 912 of this title","children":[],"tail":"), shall make grants to each State Office of Rural Health for the purpose of improving health care in rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may not make a grant under subsection (a) unless the State office of rural health involved agrees, with respect to the costs to be incurred in carrying out the purpose described in such subsection, to provide non-Federal contributions toward such costs in an amount equal to $3 for each $1 of Federal funds provided in the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive or reduce the non-Federal contribution if the Secretary determines that requiring matching funds would limit the State office of rural health’s ability to carry out the purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount of non-Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required in paragraph (1) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recipients of a grant under subsection (a) shall use the grant funds for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintaining within the State office of rural health a clearinghouse for collecting and disseminating information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural health care issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research findings relating to rural health care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative approaches to the delivery of health care in rural areas;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec72a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the activities carried out in the State that relate to rural health care, including providing coordination for the purpose of avoiding redundancy in such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec72b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying Federal and State programs regarding rural health, and providing technical assistance to public and nonprofit private entities regarding participation in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec72c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement regarding annual budget for office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the State involved agrees that, for any fiscal year for which the State office of rural health receives such a grant, the office operated pursuant to subsection (a) of this section will be provided with an annual budget of not less than $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec72d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain uses of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec72e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the State office of rural health involved agrees that the grant will not be expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec72f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide health care (including providing cash payments regarding such care);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to conduct activities for which Federal funds are expended—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4fec731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the State to provide technical and other nonfinancial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c/f"},"text":"section 254c(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4fec732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a memorandum of agreement entered into with the State office of rural health under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c/h"},"text":"section 254c(h) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4fec733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254q–1"},"text":"section 254q–1 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase medical equipment, to purchase ambulances, aircraft, or other vehicles, or to purchase major communications equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase or improve real property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out any activity regarding a certificate of need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities for which a State office of rural health may expend a grant under subsection (a) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying the costs of maintaining an office of rural health for purposes of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (1)(B)(iii), paying the costs of any activity carried out with respect to recruiting and retaining health professionals to serve in rural areas of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing grants and contracts to public and nonprofit private entities to carry out activities authorized in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may impose a limit of no more than 15 percent on indirect costs claimed by the recipient of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec73c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the State office of rural health involved agrees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec73d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Secretary reports or performance data containing such information as the Secretary may require regarding activities carried out under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec73e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit such a report or performance data not later than September 30 of each fiscal year immediately following any fiscal year for which the State office of rural health has received such a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec73f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless an application for the grant is submitted to the Secretary and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec740-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under subsection (a) to a State office of rural health for any fiscal year subsequent to the first fiscal year of such payments unless the Secretary determines that, for the immediately preceding fiscal year, the State office of rural health has complied with each of the agreements made by the State office of rural health under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec741-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec742-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making grants under subsection (a), there are authorized to be appropriated $12,500,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec743-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254r/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fec744-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/597/tIII/s302"},"text":"Pub. L. 101–597, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3032"},"text":"104 Stat. 3032","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIII/s301"},"text":"Pub. L. 105–392, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3585"},"text":"112 Stat. 3585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/408/s2"},"text":"Pub. L. 115–408, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5384"},"text":"132 Stat. 5384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/356/s2"},"text":"Pub. L. 117–356, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6282"},"text":"136 Stat. 6282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fec745-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fec746-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"ta