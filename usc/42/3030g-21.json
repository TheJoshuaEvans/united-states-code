{"tag":"section","attrib":{"id":"idbc580918-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030g–21"},"text":"§ 3030g–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State that establishes and operates a nutrition project under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn003305"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003305"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Title III of "},{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":", as amended, contained parts and subparts, but not chapters."}],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc580919-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the expertise of a dietitian or other individual with equivalent education and training in nutrition science, or if such an individual is not available, an individual with comparable expertise in the planning of nutritional services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc58091a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc58091b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides meals that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc58091c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the most recent Dietary Guidelines for Americans, published by the Secretary and the Secretary of Agriculture, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc58091d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to each participating older individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc58091e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimum of 33⅓ percent of the dietary reference intakes established by the Food and Nutrition Board of the National Academies of Sciences, Engineering, and Medicine, if the project provides one meal per day,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc58091f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimum of 66⅔ percent of the allowances if the project provides two meals per day, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc580920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the allowances if the project provides three meals per day, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc580921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, are adjusted to meet any special dietary needs of program participants, including meals adjusted for cultural considerations and preferences and medically tailored meals,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides flexibility to local nutrition providers in designing meals that are appealing to program participants,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages providers to enter into contracts that limit the amount of time meals must spend in transit before they are consumed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where feasible, encourages joint arrangements with schools and other facilities serving meals to children in order to promote intergenerational meal programs,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that meals, other than in-home meals, are provided in settings in as close proximity to the majority of eligible older individuals’ residences as feasible,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply ","children":[{"tag":"ref","attrib":{"idref":"fn003306"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003306"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “complies”."}],"tail":" with applicable provisions of State or local laws regarding the safe and sanitary handling of food, equipment, and supplies used in the storage, preparation, service, and delivery of meals to an older individual,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc580927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensures that meal providers solicit the advice and expertise of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc580928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dietitian or other individual described in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc580929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meal participants, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc58092a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals knowledgeable with regard to the needs of older individuals,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc58092b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that each participating area agency on aging establishes procedures that allow nutrition project administrators the option to offer a meal, on the same basis as meals provided to participating older individuals, to individuals providing volunteer services during the meal hours, and to individuals with disabilities who reside at home with older individuals eligible under this chapter,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc58092c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that nutrition services will be available to older individuals and to their spouses, and may be made available to individuals with disabilities who are not older individuals but who reside in housing facilities occupied primarily by older individuals at which congregate nutrition services are provided,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc58092d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for nutrition screening and nutrition education, and nutrition assessment and counseling if appropriate,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc58092e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages individuals who distribute nutrition services under subpart II to provide, to homebound older individuals, available medical information approved by health care professionals, such as informational brochures and information on how to get vaccines, including vaccines for influenza, pneumonia, and shingles, in the individuals’ communities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc58092f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030g–21/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where feasible, encourages the use of locally grown foods in meal programs and identifies potential partnerships and contracts with local producers and providers of locally grown foods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc580930-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s339"},"text":"Pub. L. 89–73, title III, § 339","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIII/s313"},"text":"Pub. L. 106–501, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2252"},"text":"114 Stat. 2252","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIII/s316"},"text":"Pub. L. 109–365, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2548"},"text":"120 Stat. 2548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s4/i"},"text":"Pub. L. 114–144, § 4(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/339"},"text":"130 Stat. 339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tII/s215"},"text":"Pub. L. 116–131, title II, § 215","children":[],"tail":", title VII, § 701(9), "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/259"},"text":"134 Stat. 259","children":[],"tail":", 271.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc580931-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc580932-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc580933-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s313"},"text":"Pub. L. 106–501, § 313","children":[],"tail":", which directed amendment of subpart 4 of part C of title III of the Older Americans Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/pl/89/73"},"text":"Pub. L. 89–73","children":[],"tail":") by striking section 339 and inserting this section, was executed in this subpart, which is subpart 3 of part C of title III of the Act, by repealing prior section 3030g–21, and inserting this section, to reflect the probable intent of Congress and the redesignation of subpart 4 of part C of title III of the Act as subpart 3 by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/s312/b"},"text":"Pub. L. 106–501, § 312(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc580934-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3030g–21, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s339"},"text":"Pub. L. 89–73, title III, § 339","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tIII/s317"},"text":"Pub. L. 102–375, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1241"},"text":"106 Stat. 1241","children":[],"tail":", related to compliance with dietary guidelines prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIII/s313"},"text":"Pub. L. 106–501, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2252"},"text":"114 Stat. 2252","children":[],"tail":". See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc580935-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (2)(A)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s701/9"},"text":"Pub. L. 116–131, § 701(9)","children":[],"tail":", substituted “National Academies of Sciences, Engineering, and Medicine” for “Institute of Medicine of the National Academy of Sciences”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s215"},"text":"Pub. L. 116–131, § 215","children":[],"tail":", inserted “, including meals adjusted for cultural considerations and preferences and medically tailored meals” before comma at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s4/i/1"},"text":"Pub. L. 114–144, § 4(i)(1)","children":[],"tail":", substituted “utilize” for “solicit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s4/i/2"},"text":"Pub. L. 114–144, § 4(i)(2)","children":[],"tail":", added subpar. (L)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/1"},"text":"Pub. L. 109–365, § 316(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “solicit the advice of a dietitian or individual with comparable expertise in the planning of nutritional services, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/A/i"},"text":"Pub. L. 109–365, § 316(2)(A)(i)","children":[],"tail":", amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “comply with the Dietary Guidelines for Americans, published by the Secretary and the Secretary of Agriculture,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/A/ii"},"text":"Pub. L. 109–365, § 316(2)(A)(ii)","children":[],"tail":", substituted “dietary reference intakes” for “daily recommended dietary allowances as”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/B"},"text":"Pub. L. 109–365, § 316(2)(B)","children":[],"tail":", inserted “joint” after “encourages”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/C"},"text":"Pub. L. 109–365, § 316(2)(C)","children":[],"tail":", amended subpar. (G) generally. Prior to amendment, subpar. (G) read as follows: “ensures that meal providers carry out such project with the advice of dietitians (or individuals with comparable expertise), meal participants, and other individuals knowledgeable with regard to the needs of older individuals,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/D"},"text":"Pub. L. 109–365, § 316(2)(D)","children":[],"tail":", struck out “and accompany” after “home with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(J), (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s316/2/E"},"text":"Pub. L. 109–365, § 316(2)(E)","children":[],"tail":", (F), added subpars. (J) and (K) and struck out former subpar. (J) which read as follows: “provide for nutrition screening and, where appropriate, for nutrition education and counseling.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc580936-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc580937-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Dietary Guidelines Waiver","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s732/c"},"text":"Pub. L. 116–260, div. N, title VII, § 732(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2105"},"text":"134 Stat. 2105","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dN/tVII/s732/c"},"text":"“To facilitate implementation of subparts 1 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030e"},"text":"42 U.S.C. 3030e","children":[],"tail":"] and 2 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030f"},"text":"42 U.S.C. 3030f","children":[],"tail":", 3030g] of part C of title III of the Older Americans Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030d–2"},"text":"42 U.S.C. 3030d–2","children":[],"tail":" [3030d–21] et seq.), with funds received by a State for fiscal year 2021, the Assistant Secretary for Aging may waive, but continue to make every effort practicable to encourage the restoration of, the applicable requirements for meals provided under such subparts comply [sic] with the requirements of clauses (i) and (ii) of section 339(2)(A) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030g–21/2/A"},"text":"42 U.S.C. 3030g–21(2)(A)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
