{"tag":"section","attrib":{"id":"idbc6660b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056n"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056n"},"text":"§ 3056n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6660ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the older American community service employment program described in this subchapter was established with the intent of placing older individuals in community service positions and providing job training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6660bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3056n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing older individuals in community service positions strengthens the ability of the individuals to become self-sufficient, provides much-needed support to organizations that benefit from increased civic engagement, and strengthens the communities that are served by such organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6660bc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s516"},"text":"Pub. L. 89–73, title V, § 516","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tV/s501"},"text":"Pub. L. 109–365, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2587"},"text":"120 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6660bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6660be-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc6660bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3056n, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tV/s516"},"text":"Pub. L. 89–73, title V, § 516","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tV/s501"},"text":"Pub. L. 106–501, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2287"},"text":"114 Stat. 2287","children":[],"tail":", related to definitions, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3056p/a"},"text":"section 3056p(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
