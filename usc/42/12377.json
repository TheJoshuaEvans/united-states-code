{"tag":"section","attrib":{"id":"idbf6d5e54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12377"},"text":null,"children":[{"tag":"num","attrib":{"value":"12377"},"text":"§ 12377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6d5e55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary, for each of the fiscal years 1993 and 1994, to carry out this subchapter. Sums appropriated under this subsection shall remain available until the expiration of the 1-year period beginning on the date the Conference is adjourned. New spending authority or authority to enter into contracts as provided in this subchapter shall be effective only to the extent and in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6d5e56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of unexpended funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds remaining upon the expiration of the 1-year period referred to in subsection (a) shall be returned to the Treasury of the United States and credited as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6d5e57-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s988"},"text":"Pub. L. 101–501, title IX, § 988","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1283"},"text":"104 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6d5e58-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6d5e59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6d5e5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
