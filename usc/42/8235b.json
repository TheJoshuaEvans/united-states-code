{"tag":"section","attrib":{"id":"idbe839b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8235b"},"text":"§ 8235b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for approval of plans for prototype residential energy efficiency programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each application for the approval of a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/a"},"text":"section 8235a(a) of this title","children":[],"tail":" for the establishment of a prototype residential energy efficiency program shall be submitted by a State or local government and shall include, at least—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe839b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the plan, including the provisions of the plan specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/a"},"text":"section 8235a(a) of this title","children":[],"tail":" and a description of the portion of the service area of the public utility proposing to enter into a contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/a/1"},"text":"section 8235a(a)(1) of this title","children":[],"tail":" which is designated under the contract;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the provisions of the plan specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/a"},"text":"section 8235a(a) of this title","children":[],"tail":" are to be met;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the contract to be entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/a/1"},"text":"section 8235a(a)(1) of this title","children":[],"tail":" and the manner in which the requirements of the contract contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235a/b"},"text":"section 8235a(b) of this title","children":[],"tail":" are to be met;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record of the public hearing conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8235c/a/2"},"text":"section 8235c(a)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe839b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8235b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information determined by the Secretary to be necessary to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe839b18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tII/s263"},"text":"Pub. L. 95–619, title II, § 263","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s562"},"text":"Pub. L. 96–294, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","chi