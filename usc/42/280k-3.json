{"tag":"section","attrib":{"id":"idb54b131e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"280k–3"},"text":"§ 280k–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating national oral healthcare surveillance activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b131f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PRAMS","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b1320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall carry out activities to update and improve the Pregnancy Risk Assessment Monitoring System (referred to in this section as “PRAMS”) as it relates to oral healthcare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b1321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reports and mandatory measurements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54b1322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and every 5 years thereafter, a State shall submit to the Secretary a report concerning activities conducted within the State under PRAMS."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54b1323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The oral healthcare measurements developed by the Secretary for use under PRAMS shall be mandatory with respect to States for purposes of the State reports under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b1324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this paragraph, such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b1325-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Health and Nutrition Examination Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop oral healthcare components that shall include tooth-level surveillance for inclusion in the National Health and Nutrition Examination Survey. Such components shall be updated by the Secretary at least every 6 years. For purposes of this paragraph, the term “tooth-level surveillance” means a clinical examination where an examiner looks at each dental surface, on each tooth in the mouth and as expanded by the Division of Oral Health of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b1326-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical Expenditures Panel Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the Medical Expenditures Panel Survey by the Agency for Healthcare Research and Quality includes the verification of dental utilization, expenditure, and coverage findings through conduct of a look-back analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b1327-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Oral Health Surveillance System","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54b1328-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, such sums as may be necessary for each of fiscal years 2010 through 2014 to increase the participation of States in the National Oral Health Surveillance System from 16 States to all 50 States, territories, and District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54b1329-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280k–3/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the National Oral Health Surveillance System include the measurement of early childhood caries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54b132a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4102/d"},"text":"Pub. L. 111–148, title IV, § 4102(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/552"},"text":"124 Stat. 552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54b132b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54b132c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb54b132d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
