{"tag":"section","attrib":{"id":"idbc770244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161"},"text":null,"children":[{"tag":"num","attrib":{"value":"3161"},"text":"§ 3161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc770245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a project to be eligible for assistance under section 3141 or 3149 of this title, the project shall be located in an area that, on the date of submission of the application, meets 1 or more of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low per capita income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area has a per capita income of 80 percent or less of the national average.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment rate above national average","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area has an unemployment rate that is, for the most recent 24-month period for which data are available, at least 1 percent greater than the national average unemployment rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment, underemployment, or economic adjustment problems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area is an area that the Secretary determines has experienced or is about to experience a special need arising from actual or threatened severe unemployment, underemployment, or economic adjustment problems resulting from severe short-term or long-term changes in economic conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low median household income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area has a median household income of 80 percent or less of the national average.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77024a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The area has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc77024b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a labor force participation rate of 90 percent or less of the national average; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc77024c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prime-age employment gap of 5 percent or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc77024d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expected economic dislocation and distress from energy industry transitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The area is an area that is expected to experience actual or threatened severe unemployment or economic adjustment problems resulting from severe short-term or long-term changes in economic conditions from energy industries that are experiencing accelerated contraction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc77024e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political boundaries of areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An area that meets 1 or more of the criteria of subsection (a), including a small area of poverty or high unemployment within a larger community in less economic distress, shall be eligible for assistance under section 3141 or 3149 of this title without regard to political or other subdivisions or boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc77024f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc770250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination of eligibility under subsection (a) shall be supported by the most recent Federal data available (including data available from the Bureau of Economic Analysis, the Bureau of Labor Statistics, the Census Bureau, the Bureau of Indian Affairs, or any other Federal source determined by the Secretary to be appropriate), or, if no recent Federal data is available, by the most recent data available through the government of the State in which the area is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc770251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The documentation shall be accepted by the Secretary unless the Secretary determines that the documentation is inaccurate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior designations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any designation of a redevelopment area made before the effective date of the Economic Development Administration Reform Act of 1998 shall not be effective after that effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc770253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3161/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent the Secretary includes neighboring counties and communities in an economic development district in accordance with subsection (a)(3), the Secretary shall submit to Congress, and make publicly available online, a notification describing the justification for such inclusion and detailing the economic indicators of such neighboring counties and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc770254-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIII/s301"},"text":"Pub. L. 89–136, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3607"},"text":"112 Stat. 3607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tIII/s301"},"text":"Pub. L. 108–373, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1767"},"text":"118 Stat. 1767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2225"},"text":"Pub. L. 118–272, div. B, title II, § 2225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3191"},"text":"138 Stat. 3191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc770255-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc770256-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc770257-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of the Economic Development Administration Reform Act of 1998, referred to in subsec. (d), see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc770258-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3161, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tIV/s401"},"text":"Pub. L. 89–136, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","chil