{"tag":"section","attrib":{"id":"idbfd63360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943"},"text":null,"children":[{"tag":"num","attrib":{"value":"14943"},"text":"§ 14943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; collection of fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd63361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd63362-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to agencies of the Federal Government implementing the Convention and the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63363-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63364-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd63365-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may charge a fee for new or enhanced services that will be undertaken by the Department of State to meet the requirements of this chapter with respect to intercountry adoptions under the Convention and comparable services with respect to other intercountry adoptions. Such fee shall be prescribed by regulation and shall not exceed the cost of such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63366-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees collected under paragraph (1) shall be retained and deposited as an offsetting collection to any Department of State appropriation to recover the costs of providing such services. Such fees shall remain available for obligation until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd63367-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tIV/s403"},"text":"Pub. L. 106–279, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/841"},"text":"114 Stat. 841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s211/a"},"text":"Pub. L. 107–228, div. A, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1365"},"text":"116 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/276/s3/a"},"text":"Pub. L. 112–276, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2467"},"text":"126 Stat. 2467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd63368-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd63369-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd6336a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", known as the Intercountry Adoption Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfd6336b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/276"},"text":"Pub. L. 112–276","children":[],"tail":" struck out subsec. (c). Text read as follows: “No funds collected under the authority of this section may be made available to an accrediting entity to carry out the purposes of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s211/a/1"},"text":"Pub. L. 107–228, § 211(a)(1)","children":[],"tail":", inserted “Such fees shall remain available for obligation until expended.” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s211/a/2"},"text":"Pub. L. 107–228, § 211(a)(2)","children":[],"tail":", struck out par. (3) which read as follows: “Fees authorized under this section shall be available for obligation only to the extent and in the amount provided in advance in appropriations Acts.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd6336c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd6336d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", with transition rule, see section 505(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
