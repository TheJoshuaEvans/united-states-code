{"tag":"section","attrib":{"id":"idb6ba5a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–95"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–95"},"text":"§ 300gg–95.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform fraud and abuse referral format","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall request the National Association of Insurance Commissioners to develop a model uniform report form for private health insurance issuer ","children":[{"tag":"ref","attrib":{"idref":"fn002486"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002486"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “issuers”."}],"tail":" seeking to refer suspected fraud and abuse to State insurance departments or other responsible State agencies for investigation. The Secretary shall request that the National Association of Insurance Commissioners develop recommendations for uniform reporting standards for such referrals."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6ba5a43-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2795, formerly § 2794, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6603"},"text":"Pub. L. 111–148, title VI, § 6603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/780"},"text":"124 Stat. 780","children":[],"tail":"; renumbered § 2795, "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1331/b"},"text":"Pub. L. 117–328, div. FF, title I, § 1331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5698"},"text":"136 Stat. 5698","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
