{"tag":"section","attrib":{"id":"idbea04a73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8626b"},"text":"§ 8626b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential Energy Assistance Challenge option (R.E.A.Ch.)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea04a74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Residential Energy Assistance Challenge (in this section referred to as “R.E.A.Ch.”) program is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04a75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize health and safety risks that result from high energy burdens on low-income Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent homelessness as a result of inability to pay energy bills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the efficiency of energy usage by low-income families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" target energy assistance to individuals who are most in need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04a79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04a7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the Secretary may allocate not more than 25 percent of the amount made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621/d"},"text":"section 8621(d) of this title","children":[],"tail":" for such fiscal year to a R.E.A.Ch. fund for the purpose of making incentive grants to States that submit qualifying plans that are approved by the Secretary as R.E.A.Ch. initiatives. States may use such grants for the costs of planning, implementing, and evaluating the initiative."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall reserve from any funds allocated under this subsection, funds to make additional payments to State R.E.A.Ch. programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbea04a7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have energy efficiency education services plans that meet quality standards established by the Secretary in consultation with the Secretary of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the potential for being replicable model designs for other programs.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"States shall use such supplemental funds for the implementation and evaluation of the energy efficiency education services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04a7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04a7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1995-05-31"},"text":"May 31, 1995","children":[],"tail":", the Secretary shall establish criteria for approving State plans required by subsection (a), for energy efficiency education quality standards described in subsection (b)(2)(A), and for the distribution of funds to States with approved plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the limitations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624/b"},"text":"section 8624(b) of this title","children":[],"tail":" regarding the authority of the Secretary with respect to plans, the Secretary may require a State to provide appropriate documentation that its R.E.A.Ch. activities conform to the State plan as approved by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04a81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State may designate all or part of the State, or all or part of the client population, as a focus of its R.E.A.Ch. initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04a82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04a83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State plan shall include each of the elements described in paragraph (2), to be met by State and local agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04a84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of State plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State plan shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbea04a85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that such State will deliver services through community-based nonprofit entities in such State, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarding grants to, or entering into contracts with, such entities for the purpose of providing such services and payments directly to individuals eligible for benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if a State makes payments directly to eligible individuals or energy suppliers, making contracts with such entities to administer such programs, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbea04a88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbea04a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing outreach services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbea04a8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing benefits other than payments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that, in awarding grants or entering into contracts to carry out its R.E.A.Ch. initiative, the State will give priority to organizations that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/1"},"text":"section 9902(1) of this title","children":[],"tail":", except where significant geographic portions of the State are not served by such entities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has determined have a record of successfully providing services under the Low-Income Home Energy Assistance Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive weatherization assistance program funds under part A of title IV of the Energy Conservation and Production Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6861"},"text":"42 U.S.C. 6861","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that a State may not require any such entity to operate a R.E.A.Ch. program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that, subject to subparagraph (D), each entity that receives a grant or enters into a contract under subparagraph (A)(i) will provide a variety of services and benefits, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments to, or on behalf of, individuals eligible for residential energy assistance services and benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624/b"},"text":"section 8624(b) of this title","children":[],"tail":" for home energy costs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residential energy demand management services, including any other energy related residential repair and energy efficiency improvements in coordination with, or delivered by, Department of Energy weatherization assistance programs at the discretion of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family services, such as counseling and needs assessment, related to energy budget management, payment plans, and related services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiation with home energy suppliers on behalf of households eligible for R.E.A.Ch. services and benefits;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the methodology the State and local agencies will use to determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which households will receive one or more forms of benefits under the State R.E.A.Ch. initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cases in which nonmonetary benefits are likely to provide more cost-effective long-term outcomes than payment benefits alone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such benefit required to meet the goals of the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a method for targeting nonmonetary benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the crisis and emergency assistance activities the State will undertake that are designed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discourage family energy crises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage responsible vendor and consumer behavior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04a9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide only financial incentives that encourage household payment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04a9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the activities the State will undertake to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04a9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives for recipients of assistance to pay home energy costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04aa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide incentives for vendors to help reduce the energy burdens of recipients of assistance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State will require each entity that receives a grant or enters into a contract under this section to solicit and be responsive to the views of individuals who are financially eligible for benefits and services under this section in establishing its local program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of performance goals for the State R.E.A.Ch. initiative including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbea04aa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in the energy costs of participating households over one or more fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04aa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the regularity of home energy bill payments by eligible households; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbea04aa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in energy vendor contributions towards reducing energy burdens of eligible households;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the indicators that will be used by the State to measure whether the performance goals have been achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstration that the plan is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8622"},"text":"section 8622 of this title","children":[],"tail":", paragraphs (2), (3), (4), (5), (7), (9), (10), (11), (12), (13), and (14) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624/b"},"text":"section 8624(b) of this title","children":[],"tail":", subsections (d), (e), (f), (g), (h), (i), and (j) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8624"},"text":"section 8624 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8625"},"text":"section 8625 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that benefits and services will be provided in addition to other benefit payments and services provided under this subchapter and in coordination with such benefit payments and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/e/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that no regulated utility covered by the plan will be required to act in a manner that is inconsistent with applicable regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04aaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8626b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost or function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the costs of providing services or benefits under this section shall be considered to be an administrative cost or function for purposes of any limitation on administrative costs or functions contained in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea04aab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2607B"},"text":"Pub. L. 97–35, title XXVI, § 2607B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIII/s312"},"text":"Pub. L. 103–252, title III, § 312","children":[],"ta