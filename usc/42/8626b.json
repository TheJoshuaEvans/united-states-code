":"amendments","id":"idbea04aaf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/c"},"text":"Pub. L. 105–285, § 308(c)","children":[],"tail":", substituted “For each fiscal year” for “For each of the fiscal years 1996 through 1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(E) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/d/1/A"},"text":"Pub. L. 105–285, § 308(d)(1)(A)","children":[],"tail":", redesignated subpars. (F) to (I) as (E) to (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/d/1/A"},"text":"Pub. L. 105–285, § 308(d)(1)(A)","children":[],"tail":", redesignated subpar. (J) as (I). Former subpar. (I) redesignated (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(I)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/d/1/B"},"text":"Pub. L. 105–285, § 308(d)(1)(B)","children":[],"tail":", substituted “of” for “on”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(J) to (N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/d/1/A"},"text":"Pub. L. 105–285, § 308(d)(1)(A)","children":[],"tail":", redesignated subpars. (K) to (N) as (J) to (M), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s308/d/2"},"text":"Pub. L. 105–285, § 308(d)(2)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbea04ab0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbea04ab1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s314"},"text":"section 314 of Pub. L. 103–252","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbea04ab2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation and Report on Residential Energy Assistance Challenge Option","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/tIII/s308/a"},"text":"Pub. L. 105–285, title III, § 308(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2758"},"text":"112 Stat. 2758","children":[],"tail":", provided that the Comptroller General of the United States would conduct an evaluation of the Residential Energy Assistance Challenge program described in this section, and, not later than 2 years after "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", submit to Congress a report containing the findings of the evaluation and the State evaluations described in paragraphs (1) and (2) of subsec. (b) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
