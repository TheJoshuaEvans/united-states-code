{"tag":"section","attrib":{"id":"idb4ab4ff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–14a"},"text":"§ 247b–14a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of interventions that reduce the burden and transmission of oral, dental, and craniofacial diseases in high risk populations; development of approaches for pediatric oral and craniofacial assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4ab4ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services, through the Maternal and Child Health Bureau, the Indian Health Service, and in consultation with the National Institutes of Health and the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4ab4ff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support community-based research that is designed to improve understanding of the etiology, pathogenesis, diagnosis, prevention, and treatment of pediatric oral, dental, craniofacial diseases and conditions and their sequelae in high risk populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support demonstrations of preventive interventions in high risk populations including nutrition, parenting, and feeding techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4ab4ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop clinical approaches to assess individual patients for the risk of pediatric dental disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State practice laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Treatment and other services shall be provided pursuant to this section by licensed dental health professionals in accordance with State practice and licensing laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4ab4ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–14a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section for each ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of”."}],"tail":" the fiscal years 2001 through 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4ab4ffd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXVI/s1601"},"text":"Pub. L. 106–310, div. A, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1148"},"text":"114 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4ab4ffe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4ab4fff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4ab5000-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Children’s Health Act of 2000, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
