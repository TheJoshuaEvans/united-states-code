{"tag":"section","attrib":{"id":"idbfd3e9ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922"},"text":null,"children":[{"tag":"num","attrib":{"value":"14922"},"text":"§ 14922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for accreditation and approval; role of accrediting entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd3e9bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of accrediting entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e9bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into agreements with one or more qualified entities under which such entities will perform the duties described in subsection (b) in accordance with the Convention, this subchapter, and the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14923"},"text":"section 14923 of this title","children":[],"tail":", and upon entering into each such agreement shall designate the qualified entity as an accrediting entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (1), the term “qualified entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd3e9be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit private entity that has expertise in developing and administering standards for entities providing child welfare services and that meets such other criteria as the Secretary may by regulation establish; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3e9bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a public entity (other than a Federal entity), including an agency or instrumentality of State government having responsibility for licensing adoption agencies, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfd3e9c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has expertise in developing and administering standards for entities providing child welfare services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfd3e9c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accredits only agencies located in the State in which the public entity is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfd3e9c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary may by regulation establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e9c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of accrediting entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e9c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation and approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Accreditation of agencies, and approval of persons, to provide adoption services in the United States in cases subject to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Ongoing monitoring of the compliance of accredited agencies and approved persons with applicable requirements, including review of complaints against such agencies and persons in accordance with procedures established by the accrediting entity and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Taking of adverse actions (including requiring corrective action, imposing sanctions, and refusing to renew, suspending, or canceling accreditation or approval) for noncompliance with applicable requirements, and notifying the agency or person against whom adverse actions are taken of the deficiencies necessitating the adverse action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data, records, and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Collection of data, maintenance of records, and reporting to the Secretary, the United States central authority, State courts, and other entities (including on persons and agencies granted or denied approval or accreditation), to the extent and in the manner that the Secretary requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on use of Federal funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after an accrediting entity receives Federal funding authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14943"},"text":"section 14943 of this title","children":[],"tail":", the entity shall submit a report to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd3e9c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such funding the entity received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd3e9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such funding was, or will be, used by the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for adverse action by accrediting entity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd3e9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of deficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agency or person who is the subject of an adverse action by an accrediting entity may re-apply for accreditation or approval (or petition for termination of the adverse action) on demonstrating to the satisfaction of the accrediting entity that the deficiencies necessitating the adverse action have been corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No other administrative review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An adverse action by an accrediting entity shall not be subject to administrative review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd3e9ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agency or person who is the subject of an adverse action by an accrediting entity may petition the United States district court in the judicial district in which the agency is located or the person resides to set aside the adverse action. The court shall review the adverse action in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":", and for purposes of such review the accrediting entity shall be considered an agency within the meaning of section 701 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd3e9cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of fees assessed by accrediting entities for the costs of accreditation shall be subject to approval by the Secretary. Such fees may not exceed the costs of accreditation. In reviewing the level of such fees, the Secretary shall consider the relative size of, the geographic location of, and the number of Convention adoption cases managed by the agencies or persons subject to accreditation or approval by the accrediting entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd3e9d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tII/s202"},"text":"Pub. L. 106–279, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/831"},"text":"114 Stat. 831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/276/s3/b"},"text":"Pub. L. 112–276, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2467"},"text":"126 Stat. 2467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd3e9d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd3e9d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd3e9d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a)(1), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/830"},"text":"114 Stat. 830","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfd3e9d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/276"},"text":"Pub. L. 112–276","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd3e9d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd3e9d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", with transition rule, see section 505(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
