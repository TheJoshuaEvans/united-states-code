{"tag":"section","attrib":{"id":"idbc95fc77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3617"},"text":null,"children":[{"tag":"num","attrib":{"value":"3617"},"text":"§ 3617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference, coercion, or intimidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful to coerce, intimidate, threaten, or interfere with any person in the exercise or enjoyment of, or on account of his having exercised or enjoyed, or on account of his having aided or encouraged any other person in the exercise or enjoyment of, any right granted or protected by section 3603, 3604, 3605, or 3606 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc95fc78-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s818"},"text":"Pub. L. 90–284, title VIII, § 818","children":[],"tail":", formerly § 817, "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/89"},"text":"82 Stat. 89","children":[],"tail":"; renumbered § 818 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/430"},"text":"Pub. L. 100–430","children":[],"tail":", §§ 8(1), 10, "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1625"},"text":"102 Stat. 1625","children":[],"tail":", 1635.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc95fc79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc95fc7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}