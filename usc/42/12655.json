{"tag":"section","attrib":{"id":"idbf938518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12655"},"text":null,"children":[{"tag":"num","attrib":{"value":"12655"},"text":"§ 12655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Corporation may make grants to States or local applicants and may transfer funds to the Secretary of Agriculture or to the Secretary of the Interior for the creation or expansion of full-time, part-time, year-round, or summer, youth corps programs ","children":[{"tag":"ref","attrib":{"idref":"fn004092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":" To the extent practicable, the Corporation shall apply the provisions of division C in making grants under this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf938519-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s199A"},"text":"Pub. L. 101–610, title I, § 199A","children":[],"tail":", formerly § 121, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3140"},"text":"104 Stat. 3140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s5"},"text":"Pub. L. 102–384, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1455"},"text":"106 Stat. 1455","children":[],"tail":"; renumbered § 199A and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/a"},"text":"Pub. L. 103–82, title I, § 101(a)","children":[],"tail":", (e)(1),