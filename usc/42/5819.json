{"tag":"section","attrib":{"id":"idbd5be3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5819"},"text":null,"children":[{"tag":"num","attrib":{"value":"5819"},"text":"§ 5819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on future reorganization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5be3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5819/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall transmit to the Congress as promptly as possible, but not later than ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", such additional recommendations as he deems advisable for organization of energy and related functions in the Federal Government, including, but not limited to, whether or not there shall be established (1) a Department of Energy and Natural Resources, (2) an Energy Policy Council, and (3) a consolidation in whole or in part of regulatory functions concerning energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5be3f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5819/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This report shall replace and serve the purposes of the report required by section 774(a)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn003436"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003436"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 15."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5be3f1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tI/s109"},"text":"Pub. L. 93–438, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1242"},"text":"88 Stat. 1242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5be3f2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd5be3f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd5be3f4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s774/a/4"},"text":"Section 774(a)(4) of title 15","children":[],"tail":", referred to in subsec. (b), was struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s109/a/1"},"text":"Pub. L. 94–385, title I, § 109(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1130"},"text":"90 Stat. 1130","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
