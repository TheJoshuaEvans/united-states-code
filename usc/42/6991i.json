{"tag":"section","attrib":{"id":"idbdeb04b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991i"},"text":"§ 6991i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operator training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdeb04b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", in consultation and cooperation with States and after public notice and opportunity for comment, the Administrator shall publish guidelines that specify training requirements for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons having primary responsibility for on-site operation and maintenance of underground storage tank systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons having daily on-site responsibility for the operation and maintenance of underground storage tanks systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" daily, on-site employees having primary responsibility for addressing emergencies presented by a spill or release from an underground storage tank system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines described in paragraph (1) shall take into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State training programs in existence as of the date of publication of the guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs that are being employed by tank owners and tank operators as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the high turnover rate of tank operators and other personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of improvement in underground storage tank equipment technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the businesses in which the tank operators are engaged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial differences in the scope and length of training needed for the different classes of persons described in subparagraphs (A), (B), and (C) of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Administrator determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the Administrator publishes the guidelines under subsection (a)(1), each State that receives funding under this subchapter shall develop State-specific training requirements that are consistent with the guidelines developed under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"State requirements described in paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in cooperation with tank owners and tank operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration training programs implemented by tank owners and tank operators as of ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appropriately communicated to tank owners and operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial incentive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may award to a State that develops and implements requirements described in paragraph (1), in addition to any funds that the State is entitled to receive under this subchapter, not more than $200,000, to be used to carry out the requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All persons that are subject to the operator training requirements of subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the training requirements developed under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" repeat the applicable requirements developed under subsection (b), if the tank for which they have primary daily on-site management responsibilities is determined to be out of compliance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdeb04d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement or standard promulgated by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991b"},"text":"section 6991b of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdeb04d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991i/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement or standard of a State program approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991c"},"text":"section 6991c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdeb04d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s9010"},"text":"Pub. L. 89–272, title II, § 9010","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tVI/s601/a"},"text":"Pub. L. 98–616, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3287"},"text":"98 Stat. 3287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1524/a"},"text":"Pub. L. 109–58, title XV, § 1524(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1095"},"text":"119 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdeb04d4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdeb04d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdeb04d6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", referred to in subsec. (b)(2)(C), was in the original “the date of enactment of this section”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdeb04d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “For authorization of appropriations to carry out this subchapter, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6916/g"},"text":"section 6916(g) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
