{"tag":"section","attrib":{"id":"idbd147b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165g"},"text":"§ 5165g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National veterinary emergency teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd147b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency may establish one or more national veterinary emergency teams at accredited colleges of veterinary medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd147b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A national veterinary emergency team shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd147b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deploy with a team of the National Urban Search and Rescue Response System to assist with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary care of canine search teams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locating and treating companion animals, service animals, livestock, and other animals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveillance and treatment of zoonotic diseases;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit, train, and certify veterinary professionals, including veterinary students, in accordance with an established set of plans and standard operating guidelines to carry out the duties associated with planning for and responding to major disasters and emergencies as described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State governments, Indian tribal governments, local governments, and nonprofit organizations in developing emergency management and evacuation plans that account for the care and rescue of animals and in improving local readiness for providing veterinary medical response during an emergency or major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Department of Homeland Security, the Department of Health and Human Services, the Department of Agriculture, State, local, and Indian tribal governments (including departments of animal and human health), veterinary and health care professionals, and volunteers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd147b23-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1218"},"text":"Pub. L. 115–254, div. D, § 1218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3452"},"text":"132 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd147b24-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd147b25-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd147b26-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Disaster Recovery Reform Act of 2018 and as part of the FAA Reauthorization Act of 2018, and not as part of the Robert T. Stafford Disaster Relief and Emergency Assistance Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd147b27-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd147b28-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authorities provided under div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which enacted this section, applicable to each major disaster and emergency declared by the President under "},{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202/b"},"text":"section 1202(b) of Pub. L. 115–254","children":[],"tail":", set out in an Effective Date of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd147b29-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “State” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1203"},"text":"section 1203 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
