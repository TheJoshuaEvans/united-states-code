{"tag":"section","attrib":{"id":"idbfc32090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452"},"text":null,"children":[{"tag":"num","attrib":{"value":"13452"},"text":"§ 13452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas and electric heating and cooling technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc32091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, on energy efficient natural gas and electric heating and cooling technologies for residential and commercial buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The natural gas heating and cooling program shall include activities on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thermally activated heat pumps, including absorption heat pumps and engine-driven heat pumps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other advanced natural gas technologies, including fuel cells for residential and commercial applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The electric heating and cooling program shall focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc32097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced heat pumps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thermal storage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc32099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced electric HVAC (heating, ventilating, and air conditioning) and refrigeration systems that utilize replacements for chlorofluorocarbons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3209a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc3209b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2102"},"text":"Pub. L. 102–486, title XXI, § 2102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3068"},"text":"106 Stat. 3068","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
