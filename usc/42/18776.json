{"tag":"section","attrib":{"id":"idc06a0ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776"},"text":null,"children":[{"tag":"num","attrib":{"value":"18776"},"text":"§ 18776.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of international energy data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall implement measures to expand and improve the international energy data resources of the Energy Information Administration in order to understand—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and use of energy in various countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing patterns of energy use internationally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative costs and environmental impacts of energy production and use internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for or construction of major energy facilities or infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with, and leverage the data resources of, the International Energy Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include detail on energy consumption by fuel, economic sector, and end use within countries for which data are available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect relevant measures of energy use, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emissions intensity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18776/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide tools that allow for straightforward country-to-country comparisons of energy production and consumption across economic sectors and end uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0f01-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40416"},"text":"Pub. L. 117–58, div. D, title IV, § 40416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1045"},"text":"135 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0f02-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a0f03-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06a0f04-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
