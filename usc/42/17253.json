{"tag":"section","attrib":{"id":"idc03346d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253"},"text":null,"children":[{"tag":"num","attrib":{"value":"17253"},"text":"§ 17253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geologic sequestration training and research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03346d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03346d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into an arrangement with the National Academy of Sciences to undertake a study that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03346d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defines an interdisciplinary program in geology, engineering, hydrology, environmental science, and related disciplines that will support the Nation’s capability to capture and sequester carbon dioxide from anthropogenic sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03346d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses undergraduate and graduate education, especially to help develop graduate level programs of research and instruction that lead to advanced degrees with emphasis on geologic sequestration science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03346d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops guidelines for proposals from colleges and universities with substantial capabilities in the required disciplines that seek to implement geologic sequestration science programs that advance the Nation’s capacity to address carbon management through geologic sequestration science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03346d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines a budget and recommendations for how much funding will be necessary to establish and carry out the grant program under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall transmit to the Congress a copy of the results of the study provided by the National Academy of Sciences under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this subsection $1,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03346dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03346dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a competitive grant program through which colleges and universities may apply for and receive 4-year grants for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03346de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salary and startup costs for newly designated faculty positions in an integrated geologic carbon sequestration science program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03346df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internships for graduate students in geologic sequestration science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection shall be renewable for up to 2 additional 3-year terms, based on performance criteria, established by the National Academy of Sciences study conducted under subsection (a), that include the number of graduates of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interface with regional geologic carbon sequestration partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent possible, geologic carbon sequestration science programs supported under this subsection shall interface with the research of the Regional Carbon Sequestration Partnerships operated by the Department to provide internships and practical training in carbon capture and geologic sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03346e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17253/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this subsection such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03346e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVII/s705"},"text":"Pub. L. 110–140, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1709"},"text":"121 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03346e4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03346e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03346e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
