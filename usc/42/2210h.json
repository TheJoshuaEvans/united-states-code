{"tag":"section","attrib":{"id":"idbc0bbd1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2210h"},"text":"§ 2210h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiation source protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc0bbd1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code of conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Code of Conduct” means the code entitled the “Code of Conduct on the Safety and Security of Radioactive Sources”, approved by the Board of Governors of the International Atomic Energy Agency and dated ","children":[{"tag":"date","attrib":{"date":"2003-09-08"},"text":"September 8, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiation source","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “radiation source” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Category 1 Source or a Category 2 Source, as defined in the Code of Conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other material that poses a threat such that the material is subject to this section, as determined by the Commission, by regulation, other than spent nuclear fuel and special nuclear materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall issue regulations prohibiting a person from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" exporting a radiation source, unless the Commission has specifically determined under section 2077 or 2112 of this title, consistent with the Code of Conduct, with respect to the exportation, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of the radiation source may receive and possess the radiation source under the laws and regulations of the country of the recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient country has the appropriate technical and administrative capability, resources, and regulatory structure to ensure that the radiation source will be managed in a safe and secure manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before the date on which the radiation source is shipped—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0bbd25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification has been provided to the recipient country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification has been received from the recipient country;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as the Commission determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" importing a radiation source, unless the Commission has determined, with respect to the importation, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed recipient is authorized by law to receive the radiation source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment will be made in accordance with any applicable Federal or State law or regulation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" selling or otherwise transferring ownership of a radiation source, unless the Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has determined that the licensee has verified that the proposed recipient is authorized under law to receive the radiation source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has required that the transfer shall be made in accordance with any applicable Federal or State law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall issue regulations establishing a mandatory tracking system for radiation sources in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing the tracking system under subparagraph (A), the Commission shall coordinate with the Secretary of Transportation to ensure compatibility, to the maximum extent practicable, between the tracking system and any system established by the Secretary of Transportation to track the shipment of radiation sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The tracking system under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the identification of each radiation source by serial number or other unique identifier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require reporting within 7 days of any change of possession of a radiation source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require reporting within 24 hours of any loss of control of, or accountability for, a radiation source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for reporting under subparagraphs (B) and (C) through a secure Internet connection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of a regulation issued under subsection (a) or (b) shall be punishable by a civil penalty not to exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academy of Sciences study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall enter into an arrangement with the National Academy of Sciences under which the National Academy of Sciences shall conduct a study of industrial, research, and commercial uses for radiation sources."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The study under paragraph (1) shall include a review of uses of radiation sources in existence on the date on which the study is conducted, including an identification of any industrial or other process that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses a radiation source that could be replaced with an economically and technically equivalent (or improved) process that does not require the use of a radiation source; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used with a radiation source that would pose a lower risk to public health and safety in the event of an accident or attack involving the radiation source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall submit to Congress the results of the study under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force on radiation source protection and security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established a task force on radiation source protection and security (referred to in this section as the “task force”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson of the task force shall be the Chairperson of the Commission (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The membership of the task force shall consist of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc0bbd42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Central Intelligence Agency (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Federal Bureau of Investigation (or a designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency (or a designee).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The task force, in consultation with Federal, State, and local agencies, the Conference of Radiation Control Program Directors, and the Organization of Agreement States, and after public notice and an opportunity for comment, shall evaluate, and provide recommendations relating to, the security of radiation sources in the United States from potential terrorist threats, including acts of sabotage, theft, or use of a radiation source in a radiological dispersal device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and not less than once every 4 years thereafter, the task force shall submit to Congress and the President a report, in unclassified form with a classified annex if necessary, providing recommendations, including recommendations for appropriate regulatory and legislative changes, for—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbc0bbd50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of additional radiation sources that should be required to be secured under this chapter, based on the potential attractiveness of the sources to terrorists and the extent of the threat to public health and safety of the sources, taking into consideration—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc0bbd51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radiation source radioactivity levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radioactive half-life of a radiation source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispersability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical and material form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for radioactive materials with a medical use, the availability of the sources to physicians and patients for medical treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factor that the Chairperson of the Commission determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of, or modifications to, a national system for recovery of lost or stolen radiation sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the storage of radiation sources that are not used in a safe and secure manner as of the date on which the report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications to the national tracking system for radiation sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of, or modifications to, a national system (including user fees and other methods) to provide for the proper disposal of radiation sources secured under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications to export controls on radiation sources to ensure that foreign recipients of radiation sources are able and willing to adequately control radiation sources from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc0bbd5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any alternative technologies available as of the date on which the report is submitted that may perform some or all of the functions performed by devices or processes that employ radiation sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the establishment of appropriate regulations and incentives for the replacement of the devices and processes described in subclause (I)—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbc0bbd5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with alternative technologies in order to reduce the number of radiation sources in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbc0bbd60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/vii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with radiation sources that would pose a lower risk to public health and safety in the event of an accident or attack involving the radiation source; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc0bbd61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the creation of, or modifications to, procedures for improving the security of use, transportation, and storage of radiation sources, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbc0bbd62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic audits or inspections by the Commission to ensure that radiation sources are properly secured and can be fully accounted for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the security measures by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased fines for violations of Commission regulations relating to security and safety measures applicable to licensees that possess radiation sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criminal and security background checks for certain individuals with access to radiation sources (including individuals involved with transporting radiation sources);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for effective and timely exchanges of information relating to the results of criminal and security background checks between the Commission and any State with which the Commission has entered into an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021/b"},"text":"section 2021(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances of the physical security of facilities that contain radiation sources (including facilities used to temporarily store radiation sources being transported); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbc0bbd68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/f/3/B/viii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the screening of shipments to facilities that the Commission determines to be particularly at risk for sabotage of radiation sources to ensure that the shipments do not contain explosives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0bbd69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of receipt by Congress and the President of a report under subsection (f)(3)(B), the Commission, in accordance with the recommendations of the task force, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any action the Commission determines to be appropriate, including revising the system of the Commission for licensing radiation sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210h/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that States that have entered into agreements with the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021/b"},"text":"section 2021(b) of this title","children":[],"tail":" take similar action in a timely manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc0bbd6c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 170H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s651/d/1"},"text":"Pub. L. 109–58, title VI, § 651(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/802"},"text":"119 Stat. 802","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc0bbd6d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc0bbd6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc0bbd6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(3)(B)(i), (v), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", known as the Atomic Energy Act of 1954, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc0bbd70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbc0bbd71-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator of the Federal Emergency Management Agency” substituted for “Director of the Federal Emergency Management Agency” in subsec. (f)(2)(B)(ix) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/c"},"text":"section 612(c) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":", Domestic Security. Any reference to the Administrator of the Federal Emergency Management Agency in title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
