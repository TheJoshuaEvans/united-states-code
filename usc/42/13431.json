{"tag":"section","attrib":{"id":"idbfc0d6ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431"},"text":null,"children":[{"tag":"num","attrib":{"value":"13431"},"text":"§ 13431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program direction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a 5-year program, in accordance with sections 13541 and 13542 of this title, on cost effective technologies to reduce the demand for oil in the transportation sector for all motor vehicles, including existing vehicles, through increased energy efficiency and the use of alternative fuels. Such program shall include a broad range of technological approaches, and shall include field demonstrations of sufficient scale and number in operating environments to prove technical and economic viability to meet the goals stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13401"},"text":"section 13401 of this title","children":[],"tail":". Such program shall include the activities required under sections 13432 through 13437 of this title, and ongoing activities of a similar nature at the Department of Energy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall prepare and submit to the Congress a 5-year program plan to guide activities under this part. In preparing the program plan, the Secretary shall consult with appropriate representatives of industry, utilities, institutions of higher education, Federal agencies, including national laboratories, and professional and technical societies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall solicit proposals for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Alternative fuels” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this part, the term “alternative fuels” includes natural gas, liquefied petroleum gas, hydrogen, fuels other than alcohol that are derived from biological materials, and any fuel the content of which is at least 85 percent by volume methanol, ethanol, or other alcohol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Secretary for carrying out this part, including all transportation sector energy conservation research and development (other than activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13435"},"text":"section 13435 of this title","children":[],"tail":") and all transportation sector biofuels energy systems under solar energy, $119,144,000 for fiscal year 1993 and $160,000,000 for fiscal year 1994."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Secretary for carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13435"},"text":"section 13435 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,300,000 for fiscal year 1993;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 1994;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000,000 for fiscal year 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $80,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $90,000,000 for fiscal year 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13431/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d70d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2021"},"text":"Pub. L. 102–486, title XX, § 2021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3061"},"text":"106 Stat. 3061","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
