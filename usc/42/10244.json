{"tag":"section","attrib":{"id":"idbf1c3161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244"},"text":null,"children":[{"tag":"num","attrib":{"value":"10244"},"text":"§ 10244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assessment of sites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf1c3162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Negotiator, the Secretary shall prepare an environmental assessment of any site that is the subject of negotiations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10243/a"},"text":"section 10243(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c3164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each environmental assessment prepared for a repository site shall include a detailed statement of the probable impacts of characterizing such site and the construction and operation of a repository at such site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c3165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each environmental assessment prepared for a monitored retrievable storage facility site shall include a detailed statement of the probable impacts of construction and operation of such a facility at such site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuance of an environmental assessment under subsection (a) shall be considered to be a final agency action subject to judicial review in accordance with the provisions of chapter 7 of title 5 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10139"},"text":"section 10139 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c3167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c3168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparing an environmental assessment for any repository or monitored retrievable storage facility site, the Secretary shall hold public hearings in the vicinity of such site to inform the residents of the area in which such site is located that such site is being considered and to receive their comments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c3169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At such hearings, the Secretary shall solicit and receive any recommendations of such residents with respect to issues that should be addressed in the environmental assessment required under subsection (a) and the site characterization plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10133/b/1"},"text":"section 10133(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c316a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each environmental assessment prepared under subsection (a) shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf1c316b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of sites","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf1c316c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In preparing an environmental assessment under subsection (a), the Secretary shall use available geophysical, geologic, geochemical and hydrologic, and other information and shall not conduct any preliminary borings or excavations at any site that is the subject of such assessment unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf1c316d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such preliminary boring or excavation activities were in progress on or before ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf1c316e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary certifies that, in the absence of preliminary borings or excavations, adequate information will not be available to satisfy the requirements of this chapter or any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf1c316f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10244/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No preliminary boring or excavation conducted under this section shall exceed a diameter of 40 inches.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf1c3170-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tIV/s404"},"text":"Pub. L. 97–425, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/d/tIII"},"text":"Pub. L. 100–202, § 101(d) [title III]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-104"},"text":"101 Stat. 1329–104","children":[],"tail":", 1329–121; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5041"},"text":"Pub. L. 100–203, title V, § 5041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-245"},"text":"101 Stat. 1330–245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf1c3171-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf1c3172-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf1c3173-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
