{"tag":"section","attrib":{"id":"idbf2a89b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412"},"text":null,"children":[{"tag":"num","attrib":{"value":"10412"},"text":"§ 10412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized services for abused parents and their children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2a89b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a89b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a grant program to expand the capacity of family violence, domestic violence, and dating violence service programs and community-based programs to prevent future domestic violence by addressing, in an appropriate manner, the needs of children exposed to family violence, domestic violence, or dating violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a89b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to eligible entities through the program established under paragraph (1) for periods of not more than 2 years. If the Secretary determines that an entity has received such a grant and been successful in meeting the objectives of the grant application submitted under subsection (c), the Secretary may renew the grant for 1 additional period of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall be a local agency, a nonprofit private organization (including faith-based and charitable organizations, community-based organizations, and voluntary associations), or a tribal organization, with a demonstrated record of serving victims of family violence, domestic violence, or dating violence and their children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a89bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the entity will prioritize the safety of, and confidentiality of information about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2a89bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of family violence, victims of domestic violence, and victims of dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a89be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children of victims described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a89bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the entity will provide developmentally appropriate and age-appropriate services, and culturally and linguistically appropriate services, to the victims and children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a89c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the entity will ensure that professionals working with the children receive the training and technical assistance appropriate and relevant to the unique needs of children exposed to family violence, domestic violence, or dating violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that receives a grant under this section for a family violence, domestic violence, and dating violence service or community-based program described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a89c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the funds made available through the grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2a89c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide direct counseling, appropriate services consistent with subsection (c)(2), or advocacy on behalf of victims of family violence, domestic violence, or dating violence and their children, including coordinating services with services provided by the child welfare system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a89c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide services for nonabusing parents to support those parents’ roles as caregivers and their roles in responding to the social, emotional, and developmental needs of their children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a89c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, to provide the services described in this subsection while working with such a nonabusing parent and child together; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a89c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may use the funds made available through the grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2a89c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide early childhood development and mental health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a89c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate activities with and provide technical assistance to community-based organizations serving victims of family violence, domestic violence, or dating violence or children exposed to family violence, domestic violence, or dating violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a89c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide additional services and referrals to services for children, including child care, transportation, educational support, respite care, supervised visitation, or other necessary services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a89ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity receiving a grant under this section shall submit a performance report to the Secretary at such time as shall be reasonably required by the Secretary. Such performance report shall describe the activities that have been carried out with such grant funds, contain an evaluation of the effectiveness of such activities, and provide such additional information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2a89cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s312"},"text":"Pub. L. 98–457, title III, § 312","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3503"},"text":"124 Stat. 3503","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2a89cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2a89cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf2a89ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10412, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s312"},"text":"Pub. L. 98–457, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1764"},"text":"98 Stat. 1764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s318"},"text":"Pub. L. 102–295, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/208"},"text":"106 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s408"},"text":"Pub. L. 108–36, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/827"},"text":"117 Stat. 827","children":[],"tail":", related to authority of Secretary, construction with State and local law, and funding for evaluation, monitoring, and other administrative costs, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s312"},"text":"section 312 of Pub. L. 98–457","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10411"},"text":"section 10411 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/294/s303/a"},"text":"section 303(a) of Pub. L. 100–294","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
