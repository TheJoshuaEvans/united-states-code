{"tag":"section","attrib":{"id":"idc060988c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652"},"text":null,"children":[{"tag":"num","attrib":{"value":"18652"},"text":"§ 18652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helium conservation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc060988d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to reduce the consumption of helium for Department grant recipients and facilities and encourage helium recycling and reuse. The program shall competitively award grants for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc060988e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of equipment to capture, reuse, and recycle helium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc060988f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation, maintenance, and repair of new and existing helium capture, reuse, and recycling equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609890-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helium alternatives research and development activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609891-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", and every 3 years thereafter, the Director shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report on the purchase of helium as part of research projects and facilities supported by the Department. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0609892-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of helium purchased for projects and facilities supported by Department grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609893-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-analysis for such helium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609894-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, information on whether such helium was imported from outside the United States, and if available, the country or region of the world from which the helium was imported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609895-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expected or experienced impacts of helium supply shortages or prices on the research projects and facilities supported by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0609896-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for reducing Department grant recipients’ exposure to volatile helium prices and supply shortages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609897-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under this section, the Director shall coordinate with the National Science Foundation and other relevant Federal agencies on helium conservation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609898-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program established under this section shall receive support for a period of not more than 5 years, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0609899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18652/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon expiration of any period of support of the program under this section, the Director may renew support for the program for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc060989a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s314"},"text":"Pub. L. 115–246, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10112/a"},"text":"Pub. L. 117–167, div. B, title I, § 10112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1460"},"text":"136 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
