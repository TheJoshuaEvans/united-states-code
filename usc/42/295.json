{"tag":"section","attrib":{"id":"idb5e88aec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295"},"text":null,"children":[{"tag":"num","attrib":{"value":"295"},"text":"§ 295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88aed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants or contracts to eligible entities to increase the number of individuals in the public health workforce, to enhance the quality of such workforce, and to enhance the ability of the workforce to meet national, State, and local health care needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88aee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or contract under subsection (a) an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88aef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88af0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health professions school, including an accredited school or program of public health, health administration, preventive medicine, or dental public health or a school providing health management programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88af1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic health center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88af2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88af3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate public or private nonprofit entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88af4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88af5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants or contracts under this section the Secretary may grant a preference to entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88af6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving individuals who are from disadvantaged backgrounds (including underrepresented racial and ethnic minorities); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88af7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" graduating large proportions of individuals who serve in underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88af8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under a grant or contract awarded under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88af9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of planning, developing, or operating demonstration training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88afa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88afb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trainee support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to meet the costs of projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan and develop new residency training programs and to maintain or improve existing residency training programs in preventive medicine and dental public health, that have available full-time faculty members with training and experience in the fields of preventive medicine and dental public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial assistance to residency trainees enrolled in such programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retraining of existing public health workers as well as for increasing the supply of new practitioners to address priority public health, preventive medicine, public health dentistry, and health administration needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing public health professionals for employment at the State and community levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health workforce loan repayment programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities that may produce outcomes that are consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traineeships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to amounts used under this section for the training of health professionals, such training programs shall be designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make public health education more accessible to the public and private health workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the relevance of public health academic preparation to public health practice in the future;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide education or training for students from traditional on-campus programs in practice-based sites; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop educational methods and distance-based approaches or technology that address adult learning requirements and increase knowledge and skills related to community-based cultural diversity in public health education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severe shortage disciplines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided under grants or contracts under this section may be used for the operation of programs designed to award traineeships to students in accredited schools of public health who enter educational programs in fields where there is a severe shortage of public health professionals, including epidemiology, biostatistics, environmental health, toxicology, public health nursing, nutrition, preventive medicine, maternal and child health, and behavioral and mental health professions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 765, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s105"},"text":"Pub. L. 105–392, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3553"},"text":"112 Stat. 3553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5206/a"},"text":"Pub. L. 111–148, title V, § 5206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/611"},"text":"124 Stat. 611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88b0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e88b0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e88b0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 295, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s781"},"text":"act July 1, 1944, ch. 373, title VII, § 781","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2055"},"text":"106 Stat. 2055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/12/s12/b"},"text":"Pub. L. 105–12, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-04-30"},"text":"Apr. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/29"},"text":"111 Stat. 29","children":[],"tail":", authorized grants and contracts for research on certain health professions issues, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s106/a/1"},"text":"Pub. L. 105–392, title I, § 106(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3557"},"text":"112 Stat. 3557","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 295, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s761"},"text":"act July 1, 1944, ch. 373, title VII, § 761","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1970-12-25"},"text":"Dec. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/696/s101"},"text":"Pub. L. 91–696, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2080-1"},"text":"84 Stat. 2080–1","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", title V, § 507, "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":", 692, provided Congressional declaration of purpose for former part D of this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s220/c"},"text":"Pub. L. 99–129, title II, § 220(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/544"},"text":"99 Stat. 544","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 295, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s761"},"text":"act July 1, 1944, ch. 373, title VII, § 761","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1963-10-31"},"text":"Oct. 31, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/164/tI/s101"},"text":"Pub. L. 88–164, title I, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/282"},"text":"77 Stat. 282","children":[],"tail":", related to authorization of appropriations respecting grants for construction of mental retardation facilities, prior to the general amendment of former part D of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/91/696/s101"},"text":"section 101 of Pub. L. 91–696","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 765 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294c"},"text":"section 294c of this title","children":[],"tail":" prior to the general amendment of part D of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 765 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295d"},"text":"section 295d of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/129"},"text":"Pub. L. 99–129","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 765 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295d"},"text":"section 295d of this title","children":[],"tail":" prior to the general amendment of part D of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/91/696"},"text":"Pub. L. 91–696","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5e88b0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5e88b10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5e88b11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding for Public Health Workforce","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tII/s2501"},"text":"Pub. L. 117–2, title II, § 2501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/42"},"text":"135 Stat. 42","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tII/s2501"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary of Health and Human Services (in this subtitle [subtitle F (§§ 2501, 2502) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":", enacting this note] referred to as the ‘Secretary’) for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $7,660,000,000, to remain available until expended, to carry out activities related to establishing, expanding, and sustaining a public health workforce, including by making awards to State, local, and territorial public health departments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds for Public Health Departments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available to an awardee pursuant to subsection (a) shall be used for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Costs, including wages and benefits, related to the recruiting, hiring, and training of individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as case investigators, contact tracers, social support specialists, community health workers, public health nurses, disease intervention specialists, epidemiologists, program managers, laboratory personnel, informaticians, communication and policy experts, and any other positions as may be required to prevent, prepare for, and respond to COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who are employed by—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State, territorial, or local public health department involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit private or public organization with demonstrated expertise in implementing public health programs and established relationships with such State, territorial, or local public health departments, particularly in medically underserved areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personal protective equipment, data management and other technology, or other necessary supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative costs and activities necessary for awardees to implement activities funded under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subawards from recipients of awards under subsection (a) to local health departments for the purposes of the activities funded under this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
