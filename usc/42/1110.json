{"tag":"section","attrib":{"id":"idb80f1411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110"},"text":null,"children":[{"tag":"num","attrib":{"value":"1110"},"text":"§ 1110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing between Federal accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb80f1412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary of the Treasury (after consultation with the Secretary of Labor) determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f1413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in the employment security administration account, Federal unemployment account, or extended unemployment compensation account, is insufficient to meet the anticipated payments from the account,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such insufficiency may cause such account to borrow from the general fund of the Treasury, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in any other such account exceeds the amount necessary to meet the anticipated payments from such other account,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall transfer to the account referred to in paragraph (1) from the account referred to ","children":[{"tag":"ref","attrib":{"idref":"fn002661"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002661"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “to in”."}],"tail":" paragraph (3) an amount equal to the insufficiency determined under paragraph (1) (or, if less, the excess determined under paragraph (3))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f1416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of advance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amount transferred under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f1417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as a noninterest-bearing repayable advance, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1418-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered in computing the amount in any account for purposes of the application of sections 1101(f)(2), 1102(b), and 1105(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f1419-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary of the Treasury (after consultation with the Secretary of Labor) determines that the amount in the account to which an advance is made under subsection (a) exceeds the amount necessary to meet the anticipated payments from the account, the Secretary shall transfer from the account to the account from which the advance was made an amount equal to the lesser of the amount so advanced or such excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb80f141a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IX, § 910, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/318/tV/s531/c"},"text":"Pub. L. 102–318, title V, § 531(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/316"},"text":"106 Stat. 316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb80f141b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb80f141c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb80f141d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1110, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tIX/s910"},"text":"act Aug. 14, 1935, ch. 531, title IX, § 910","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/644"},"text":"49 Stat. 644","children":[],"tail":", related to conditions of additional credit allowance. For further details, see Prior Law note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
