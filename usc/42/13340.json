{"tag":"section","attrib":{"id":"idbfbbf499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340"},"text":null,"children":[{"tag":"num","attrib":{"value":"13340"},"text":"§ 13340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-rank coal research and development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall pursue a program of research and development with respect to the technologies needed to expand the use of low-rank coals which take into account the unique properties of lignites and sub-bituminous coals, including, but not limited to, the following areas—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high value-added carbon products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel cell applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emissions control and combustion efficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal water fuels and underground coal gasification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distillates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf49f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13340/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other technologies which will assist in the development of niche markets for lignites and sub-bituminous coals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf4a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1310"},"text":"Pub. L. 102–486, title XIII, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2975"},"text":"106 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
