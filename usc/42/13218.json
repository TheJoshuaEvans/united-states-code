{"tag":"section","attrib":{"id":"idbfb4c899-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218"},"text":null,"children":[{"tag":"num","attrib":{"value":"13218"},"text":"§ 13218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb4c89a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb4c89b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb4c89c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2006-02-15"},"text":"February 15, 2006","children":[],"tail":", and annually thereafter for the next 14 years, the head of each Federal agency which is subject to this Act and Executive Order No. 13031 shall prepare, and submit to Congress, a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c89d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the compliance by such Federal agency with the alternative fuel purchasing requirements for Federal fleets under this Act and Executive Order No. 13031; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c89e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan of compliance that contains specific dates for achieving compliance using reasonable means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c89f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c8a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb4c8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information on any failure to meet statutory requirements or requirements under Executive Order No. 13031;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb4c8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfb4c8a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plan of compliance that the agency head is required to submit under Executive Order No. 13031; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfb4c8a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a plan of compliance referred to in subclause (I) does not contain specific dates by which the Federal agency is to achieve compliance, a revised plan of compliance that contains specific dates for achieving compliance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb4c8a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any related information the agency head is required to submit to the Director of the Office of Management and Budget under Executive Order No. 13031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c8a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penultimate report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penultimate report submitted under paragraph (1) shall include an announcement that the report for the next year shall be the final report submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb4c8a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public dissemination of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall be made public, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb4c8a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placing such report on a publicly available website on the Internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb4c8a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13218/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing the availability of the report, including such website address, in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb4c8aa-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIII/s310"},"text":"Pub. L. 102–486, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2874"},"text":"106 Stat. 2874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s8/a"},"text":"Pub. L. 105–388, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3481"},"text":"112 Stat. 3481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s705"},"text":"Pub. L. 109–58, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/817"},"text":"119 Stat. 817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb4c8ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb4c8ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfb4c8ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2776"},"text":"102 Stat. 2776","children":[],"tail":", known as the Energy Policy Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13201"},"text":"section 13201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order No. 13031, referred to in subsec. (b)(1), (2)(A), was Ex. Ord. No. 13031, ","children":[{"tag":"date","attrib":{"date":"1996-12-13"},"text":"Dec. 13, 1996","children":[],"tail":", 61 F.R. 66529, which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13212"},"text":"section 13212 of this title","children":[],"tail":" prior to revocation by Ex. Ord. No. 13149, § 501, "},{"tag":"date","attrib":{"date":"2000-04-21"},"text":"Apr. 21, 2000","children":[],"tail":", 65 F.R. 24610, formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13212"},"text":"section 13212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfb4c8ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a) of this section, which required the Administrator of General Services to report biennially to Congress on the General Services Administration’s alternative fueled vehicle program under the Energy Policy Act of 1992, terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, the 4th item on page 173 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfb4c8af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2006-02-15"},"text":"February 15, 2006","children":[],"tail":"” for “1 year after "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" substituted “Reports” for “General Services Admin