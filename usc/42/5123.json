{"tag":"section","attrib":{"id":"idbd0ade03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5123"},"text":null,"children":[{"tag":"num","attrib":{"value":"5123"},"text":"§ 5123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, any reference in this chapter to “State and local”, “State or local”, “State, and local”, “State, or local”, or “State, local” (including plurals) with respect to governments or officials and any reference to a “local government” in sections 5172(d)(3) and 5184 of this title is deemed to refer also to Indian tribal governments and officials, as appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd0ade04-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tI/s103"},"text":"Pub. L. 93–288, title I, § 103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1110/d"},"text":"Pub. L. 113–2, div. B, § 1110(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/49"},"text":"127 Stat. 49","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0ade05-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0ade06-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0ade07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":nul