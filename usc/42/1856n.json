{"tag":"section","attrib":{"id":"idbb817f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856n"},"text":"§ 1856n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb817f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of wildfire protection resources under a reciprocal agreement with a foreign fire organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into a reciprocal agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture or the Secretary of the Interior, in consultation with the Secretary of State, may enter into a reciprocal agreement with any foreign fire organization for mutual aid in furnishing wildfire protection resources for lands and other properties for which such Secretary or organization normally provides wildfire protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for a reciprocal agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any agreement entered into under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb817f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a waiver by each party to the agreement of all claims against every other party to the agreement for compensation for any loss, damage, personal injury, or death occurring in consequence of the performance of such agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb817f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a provision to allow the termination of such agreement by any party thereto after reasonable notice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb817f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for the reimbursement of any party thereto for all or any part of the costs incurred by such party in furnishing wildfire protection resources for, or on behalf of, any other party thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of wildfire protection resources without a reciprocal agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the absence of any agreement authorized under subsection (a), the Secretary of Agriculture or the Secretary of the Interior may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish emergency wildfire protection resources to any foreign nation when the furnishing of such resources is determined by such Secretary to be in the best interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept emergency wildfire protection resources from any foreign fire organization when the acceptance of such resources is determined by such Secretary to be in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement under agreements with Canada","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the preceding provisions of this section, reimbursement may be provided for the costs incurred by the Government of Canada or a Canadian organization in furnishing wildfire protection resources to the Government of the United States under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the memorandum entitled “Memorandum of Understanding Between the United States Department of Agriculture and Environment Canada on Cooperation in the Field of Forestry-Related Programs” dated ","children":[{"tag":"date","attrib":{"date":"1982-06-25"},"text":"June 25, 1982","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arrangement entitled “Arrangement in the Form of an Exchange of Notes Between the Government of Canada and the Government of the United States of America” dated ","children":[{"tag":"date","attrib":{"date":"1982-05-04"},"text":"May 4, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service performed under this subchapter by Federal employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any service performed by any employee of the United States under an agreement or otherwise under this subchapter shall constitute service rendered in the line of duty in such employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856n–1"},"text":"section 1856n–1 of this title","children":[],"tail":", the performance of such service by any other individual shall not make such individual an employee of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb817f1d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/428/s3"},"text":"Pub. L. 100–428, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1615"},"text":"102 Stat. 1615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tIV/s411/3"},"text":"Pub. L. 112–74, div. E, title IV, § 411(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1040"},"text":"125 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817f1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817f1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb817f20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/3/A"},"text":"Pub. L. 112–74, § 411(3)(A)","children":[],"tail":", inserted headings for subsec. (a) and pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/3/B/i"},"text":"Pub. L. 112–74, § 411(3)(B)(i)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/3/B/ii"},"text":"Pub. L. 112–74, § 411(3)(B)(ii)","children":[],"tail":", substituted “United States; and” for “United States, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/3/C"},"text":"Pub. L. 112–74, § 411(3)(C)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s411/3/D"},"text":"Pub. L. 112–74, § 411(3)(D)","children":[],"tail":", inserted subsec. heading, designated first and second sentences as pars. (1) and (2), respectively, inserted par. headings, and substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856n–1"},"text":"section 1856n–1 of this title","children":[],"tail":", the” for “The” in par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
