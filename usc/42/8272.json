{"tag":"section","attrib":{"id":"idbe8d3836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8272"},"text":null,"children":[{"tag":"num","attrib":{"value":"8272"},"text":"§ 8272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Photovoltaic energy program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established a photovoltaic energy commercialization program for the accelerated procurement and installation of photovoltaic solar electric systems for electric production in Federal facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe8d3837-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s563"},"text":"Pub. L. 95–619, title V, § 563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3280"},"text":"92 Stat. 3280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
