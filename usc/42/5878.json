{"tag":"section","attrib":{"id":"idbd63106f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5878"},"text":null,"children":[{"tag":"num","attrib":{"value":"5878"},"text":"§ 5878.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall keep the appropriate congressional committees fully and currently informed with respect to all of the Administration’s activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd631070-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438/tIII/s308"},"text":"Pub. L. 93–438, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1252"},"text":"88 Stat. 1252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd631071-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd631072-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbd631073-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Energy Research and Development Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
