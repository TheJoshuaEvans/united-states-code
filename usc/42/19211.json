{"tag":"section","attrib":{"id":"idc0844d77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211"},"text":null,"children":[{"tag":"num","attrib":{"value":"19211"},"text":"§ 19211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early-career research fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0844d78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation may establish a 2-year pilot program to make awards to highly qualified early-career investigators to carry out an independent research program at the institution of higher education or participating Federal research facility chosen by such investigator, to last for a period not greater than two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0844d79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall select recipients under subsection (a) from among citizens, nationals, and lawfully admitted permanent resident aliens of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0844d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation shall conduct program outreach to recruit fellowship applicants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0844d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from all regions of the country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0844d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from historically underrepresented populations in the fields of science, technology, engineering, and mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0844d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who graduate from or intend to carry out research at a variety of types of institutions of higher education, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0844d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically Black colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0844d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal Colleges and Universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0844d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0844d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education that are not among the top 50 institutions in annual Federal funding for research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0844d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" EPSCoR institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0844d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall give special consideration and priority to an application from an individual who graduated from or is intending to carry out research at an institution of the type specified in subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0844d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports from fellows","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the end of the pilot program under this section, each early-career investigator who receives an award under the pilot program shall submit to the Director of the National Science Foundation a report that describes how the early-career investigator used the award funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0844d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report from the Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the conclusion of the second year of the pilot program, the Director of the National Science Foundation shall submit to Congress a report that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0844d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the uses of award funds under this section and the impact of the pilot program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0844d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Statistical summary data on fellowship awardees disaggregated by race, ethnicity, sex, geography, age, years since completion of doctoral degree, and institution type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0844d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19211/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If determined effective, a plan for permanent implementation of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0844d89-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10601"},"text":"Pub. L. 117–167, div. B, title VI, § 10601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1632"},"text":"136 Stat. 1632","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
