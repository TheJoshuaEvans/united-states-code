{"tag":"section","attrib":{"id":"idc03cbde3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903"},"text":null,"children":[{"tag":"num","attrib":{"value":"17903"},"text":"§ 17903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03cbde4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on adoption of nationwide system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", and annually thereafter, the Secretary of Health and Human Services shall submit to the appropriate committees of jurisdiction of the House of Representatives and the Senate a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbde5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the specific actions that have been taken by the Federal Government and private entities to facilitate the adoption of a nationwide system for the electronic use and exchange of health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbde6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes barriers to the adoption of such a nationwide system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbde7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains recommendations to achieve full implementation of such a nationwide system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbde8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement incentive study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbde9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall carry out, or contract with a private entity to carry out, a study that examines methods to create efficient reimbursement incentives for improving health care quality in Federally qualified health centers, rural health clinics, and free clinics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbdea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Secretary of Health and Human Services shall submit to the appropriate committees of jurisdiction of the House of Representatives and the Senate a report on the study carried out under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbdeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging services technology study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbdec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall carry out, or contract with a private entity to carry out, a study of matters relating to the potential use of new aging services technology to assist seniors, individuals with disabilities, and their caregivers throughout the aging process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be studied","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbdee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbdef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for identifying current, emerging, and future health technology that can be used to meet the needs of seniors and individuals with disabilities and their caregivers across all aging services settings, as specified by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbdf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for fostering scientific innovation with respect to aging services technology within the business and academic communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbdf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developments in aging services technology in other countries that may be applied in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbdf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identification of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc03cbdf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to innovation in aging services technology and devising strategies for removing such barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc03cbdf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers to the adoption of aging services technology by health care providers and consumers and devising strategies to removing such barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbdf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"2009-02-17"},"text":"February 17, 2009","children":[],"tail":", the Secretary shall submit to the appropriate committees of jurisdiction of the House of Representatives and of the Senate a report on the study carried out under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbdf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc03cbdf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging services technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aging services technology” means health technology that meets the health care needs of seniors, individuals with disabilities, and the caregivers of such seniors and individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc03cbdf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17903/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “senior” has such meaning as specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbdf9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13113"},"text":"Pub. L. 111–5, div. A, title XIII, § 13113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/243"},"text":"123 Stat. 243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
