{"tag":"section","attrib":{"id":"idbfc8022d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556"},"text":null,"children":[{"tag":"num","attrib":{"value":"13556"},"text":"§ 13556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged business enterprises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc8022e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, the head of each agency shall provide that the obligation of not less than 10 percent of the total combined amounts obligated for contracts and subcontracts by each agency under this Act and amendments made by this Act pursuant to competitive procedures within the meaning of either division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41, or chapter 137 legacy provisions (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3016"},"text":"section 3016 of title 10","children":[],"tail":"), shall be expended either with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc8022f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns controlled by socially and economically disadvantaged individuals or women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically Black colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" colleges and universities having a student body in which more than 20 percent of the students are Hispanic Americans or Native Americans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified HUBZone small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc80233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc80234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “small business concern” has the meaning such term has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":". However, for purposes of contracts and subcontracts requiring engineering services the applicable size standard shall be that established for military and aerospace equipment and military weapons."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “socially and economically disadvantaged individuals” has the meaning such term has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"section 637(d) of title 15","children":[],"tail":" and relevant subcontracting regulations promulgated pursuant thereto."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc80236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13556/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualified HUBZone small business concern” has the meaning given that term in section 632(p) ","children":[{"tag":"ref","attrib":{"idref":"fn004178"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 15."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc80237-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXX/s3021"},"text":"Pub. L. 102–486, title XXX, § 3021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3133"},"text":"106 Stat. 3133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tVI/s604/g"},"text":"Pub. L. 105–135, title VI, § 604(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2634"},"text":"111 Stat. 2634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/j/