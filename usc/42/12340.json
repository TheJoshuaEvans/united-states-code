{"tag":"section","attrib":{"id":"idbf6aeea2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340"},"text":null,"children":[{"tag":"num","attrib":{"value":"12340"},"text":"§ 12340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation and allotment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aeea3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration on Children, Youth, and Families; State coordination; supportive services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeea4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out sections 12337 and 12338 of this title such sums as may be necessary for each of the fiscal years 1995 through 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeea5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under paragraph (1) for any fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aeea6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 percent shall be available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12315"},"text":"section 12315 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aeea7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 90 percent shall be available to carry out sections 12337 and 12338 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeea8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), from the amount available under paragraph (2)(B) for each fiscal year, a State shall be allotted an amount that bears the same ratio to the amount appropriated for such fiscal year as the population of the State that is under the age of 21 bears to the population of all States that is under the age of 21.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeea9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aeeaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B) and subject to the availability of appropriations under paragraph (1), no State shall be allotted less than $300,000 under the formula established under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aeeab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), Guam, the Virgin Islands, the Trust Territory of the Pacific Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands shall each be allotted not less than $75,000 under the formula established under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeeac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of age","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of individuals under the age of 21 in each State shall be determined by the Commissioner on the basis of the most recent data available to the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeead-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of allotted funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Commissioner determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeeae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount allotted to a State for a fiscal year under section 12337 or 12338 of this title will not be used by such State for carrying out the purpose for which such allotment was made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeeaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State has failed to qualify under the State plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12335"},"text":"section 12335 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commissioner shall make such allotment available for carrying out such purposes to other participating States in a proportional manner based on the relative population of the State of individuals under the age of 21.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeeb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s402/b/2"},"text":"Pub. L. 103–252, title IV, § 402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/673"},"text":"108 Stat. 673","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeeb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall not use in excess of 10 percent of a grant awarded under section 12338 or 12339 ","children":[{"tag":"ref","attrib":{"idref":"fn004046"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title for administrative activities at the State level."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeeb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for Indians","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall use 1 percent of the amount appropriated under this section for each fiscal year to make allotments to Indian tribes and tribal organizations (such terms having the same meaning given to such terms in section 5304(b) and (c) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 25) that submit to the Commissioner a plan that meets criteria consistent with the provisions of this part and that comply with other requirements established by the Commissioner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aeeb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this subchapter may be used to pay not more than 80 percent of the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aeeb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation, administration, and evaluation of State plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12337"},"text":"section 12337 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeeb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of comprehensive, efficient, coordinated supportive services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12338"},"text":"section 12338 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aeeb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12340/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, expansion, and operation of local family support and resource programs under section 12339 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The remaining 20 percent of such cost shall be paid by the State with funds from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aeeb7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s934"},"text":"Pub. L. 101–501, title IX, § 934","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1277"},"text":"104 Stat. 1277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s402/b"},"text":"Pub. L. 103–252, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/673"},"text":"108 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aeeb8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6aeeb9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6aeeba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12339"},"text":"Section 12339 of this title","children":[],"tail":", referred to in subsecs. (e) and (g)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIV/s401/b/1"},"text":"Pub. L. 103–252, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/672"},"text":"108 Stat. 672","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"Section 5304 of title 25","children":[],"tail":", referred to in subsec. (f), has been amended, and subsecs. (b) and (c) of section 5304 no longer define the terms “Indian tribe” and “tribal organization”. However, such terms are defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf6aeebb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252/s402/b/1"},"text":"Pub. L. 103–252, § 402(b)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out sections 12315, 12337, and 12338 of this title, $30,000,000 for fiscal year 1991 and such sums as may be necessary for fiscal years 1992, 1993, and 1994. Funds appropriated under this paragraph shall remain available for expenditure in the fiscal year succeeding the fiscal year for which such funds are appropriated.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/252/s402/b/2"},"text":"Pub. L. 103–252, § 402(b)(2)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “There are authorized to be appropriated to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12339"},"text":"section 12339 of this title","children":[],"tail":", $30,000,000 for fiscal year 1991, and such sums as may be necessary for each of the fiscal years 1992 through 1994.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aeebc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aeebd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbf6aeebe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf6aeebf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
