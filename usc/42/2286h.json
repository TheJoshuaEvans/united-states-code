{"tag":"section","attrib":{"id":"idbc17a448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286h"},"text":"§ 2286h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority of the Board to enter into contracts under this subchapter is effective only to the extent that appropriations (including transfers of appropriations) are provided in advance for such purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc17a449-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 319, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXIV/s1441/a/1"},"text":"Pub. L. 100–456, div. A, title XIV, § 1441(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2083"},"text":"102 Stat. 2083","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
