{"tag":"section","attrib":{"id":"idb66e0f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–56"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–56"},"text":"§ 300x–56.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions regarding receipt of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66e0f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–56/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66e0f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–56/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain false statements and representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not knowingly and willfully make or cause to be made any false statement or representation of a material fact in connection with the furnishing of items or services for which payments may be made by a State from a grant made to the State under section 300x or 300x–21 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66e0f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–56/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealing or failing to disclose certain events","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person with knowledge of the occurrence of any event affecting the initial or continued right of the person to receive any payments from a grant made to a State under section 300x or 300x–21 of this title shall not conceal or fail to disclose any such event with an intent fraudulently to secure such payment either in a greater amount than is due or when no such amount is due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66e0f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–56/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty for violation of prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates any prohibition established in subsection (a) shall for each violation be fined in accordance with title 18 or imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66e0f0f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1946, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s203/a"},"text":"Pub. L. 102–321, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/406"},"text":"106 Stat. 406","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
