{"tag":"section","attrib":{"id":"idbc8ed089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc8ed08a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed08b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Dwelling” means any building, structure, or portion thereof which is occupied as, or designed or intended for occupancy as, a residence by one or more families, and any vacant land which is offered for sale or lease for the construction or location thereon of any such building, structure, or portion thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed08c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Family” includes a single individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed08d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” includes one or more individuals, corporations, partnerships, associations, labor organizations, legal representatives, mutual companies, joint-stock companies, trusts, unincorporated organizations, trustees, trustees in cases under title 11, receivers, and fiduciaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed08e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “To rent” includes to lease, to sublease, to let and otherwise to grant for a consideration the right to occupy premises not owned by the occupant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed08f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Discriminatory housing practice” means an act that is unlawful under section 3604, 3605, 3606, or 3617 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, or any of the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Handicap” means, with respect to a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8ed092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physical or mental impairment which substantially limits one or more of such person’s major life activities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a record of having such an impairment, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being regarded as having such an impairment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but such term does not include current, illegal use of or addiction to a controlled substance (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Aggrieved person” includes any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8ed096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims to have been injured by a discriminatory housing practice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" believes that such person will be injured by a discriminatory housing practice that is about to occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Complainant” means the person (including the Secretary) who files a complaint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3610"},"text":"section 3610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Familial status” means one or more individuals (who have not attained the age of 18 years) being domiciled with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8ed09a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent or another person having legal custody of such individual or individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed09b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designee of such parent or other person having such custody, with the written permission of such parent or other person.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The protections afforded against discrimination on the basis of familial status shall apply to any person who is pregnant or is in the process of securing legal custody of any individual who has not attained the age of 18 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed09c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Conciliation” means the attempted resolution of issues raised by a complaint, or by the investigation of such complaint, through informal negotiations involving the aggrieved person, the respondent, and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed09d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Conciliation agreement” means a written agreement setting forth the resolution of the issues in conciliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed09e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Respondent” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc8ed09f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person or other entity accused in a complaint of an unfair housing practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc8ed0a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person or entity identified in the course of investigation and notified as required with respect to respondents so identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3610/a"},"text":"section 3610(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc8ed0a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3602/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Prevailing party” has the same meaning as such term has in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1988"},"text":"section 1988 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc8ed0a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s802"},"text":"Pub. L. 90–284, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s331"},"text":"Pub. L. 95–598, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2679"},"text":"92 Stat. 2679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s5"},"text":"Pub. L. 100–430, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1619"},"text":"102 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc8ed0a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc8ed0a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc8ed0a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/430/s5/a"},"text":"Pub. L. 100–430, § 5(a)","children":[],"tail":", substituted “3606, or 3617” for “or 3606”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s5/b"},"text":"Pub. L. 100–430, § 5(b)","children":[],"tail":", added subsecs. (h) to ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" substituted “trustees in cases under title 11” for “trustees in bankruptcy”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc8ed0a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc8ed0a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/430"},"text":"Pub. L. 100–430","children":[],"tail":" effective on 180th day beginning after "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s13/a"},"text":"section 13(a) of Pub. L. 100–430","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc8ed0a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbc8ed0a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transvestism","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/430/s6/b/3"},"text":"Section 6(b)(3) of Pub. L. 100–430","children":[],"tail":" provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/430/s6/b/3"},"text":"“For the purposes of this Act [see Short Title of 1988 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":"] as well as chapter 16 of title 29 of the United States Code ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.], neither the term ‘individual with handicaps’ nor the term ‘handicap’ shall apply to an individual solely because that individual is a transvestite.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
