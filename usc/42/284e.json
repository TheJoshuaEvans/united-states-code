{"tag":"section","attrib":{"id":"idb560962b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e"},"text":null,"children":[{"tag":"num","attrib":{"value":"284e"},"text":"§ 284e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on osteoporosis, Paget’s disease, and related bone disorders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb560962c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directors of the National Institute of Arthritis and Musculoskeletal and Skin Diseases, the National Institute on Aging, the National Institute of Dental Research, and the National Institute of Diabetes and Digestive and Kidney Diseases, shall expand and intensify the programs of such Institutes with respect to research and related activities concerning osteoporosis, Paget’s disease, and related bone disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb560962d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directors referred to in subsection (a) shall jointly coordinate the programs referred to in such subsection and consult with the Arthritis and Musculoskeletal Diseases Interagency Coordinating Committee and the Interagency Task Force on Aging Research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb560962e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information clearinghouse","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb560962f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist in carrying out the purpose described in subsection (a), the Director of NIH shall provide for the establishment of an information clearinghouse on osteoporosis and related bone disorders to facilitate and enhance knowledge and understanding on the part of health professionals, patients, and the public through the effective dissemination of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5609630-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment through grant or contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out paragraph (1), the Director of NIH shall enter into a grant, cooperative agreement, or contract with a nonprofit private entity involved in activities regarding the prevention and control of osteoporosis and related bone disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5609631-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 409A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tIII/s302"},"text":"Pub. L. 103–43, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/151"},"text":"107 Stat. 151","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/340/tI/s102"},"text":"Pub. L. 105–340, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3192"},"text":"112 Stat. 3192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/7"},"text":"Pub. L. 109–482, title I, § 103(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3687"},"text":"120 Stat. 3687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5609632-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5609633-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5609634-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated $40,000,000 for fiscal year 1994, and such sums as may be necessary for each of the fiscal years 1995 through 2003.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/340"},"text":"Pub. L. 105–340","children":[],"tail":" substituted “through 2003” for “and 1996”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5609635-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5609636-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
