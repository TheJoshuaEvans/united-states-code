{"tag":"section","attrib":{"id":"idbf01f2d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859"},"text":null,"children":[{"tag":"num","attrib":{"value":"9859"},"text":"§ 9859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f2da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child with a disability; infant or toddler with a disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “child with a disability” and “infant or toddler with a disability” have the meanings given the terms in sections 1401 and 1431 of title 20.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible child care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible child care provider” means a provider of child care services for compensation, including a provider of care for a school-age child during non-school hours, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf01f2dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed, regulated, registered, or otherwise legally operating, under State and local law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf01f2dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the State and local requirements,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"applicable to the child care services the provider provides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9859/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf01f2e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dA/tXIV/s1401"},"text":"Pub. L. 106–310, div. A, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1143"},"text":"114 Stat. 1143","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
