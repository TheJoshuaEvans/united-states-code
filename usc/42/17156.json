{"tag":"section","attrib":{"id":"idc02c1b7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156"},"text":null,"children":[{"tag":"num","attrib":{"value":"17156"},"text":"§ 17156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02c1b7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount made available for each fiscal year to carry out this part, the Secretary shall use not less than 2 percent to provide grants under this section, on a competitive basis, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government (including Indian tribes) that are not eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consortia of units of local government described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a unit of local government or consortia shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a plan of the unit of local government to carry out an activity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17154"},"text":"section 17154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02c1b82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under this section, the Secretary shall give priority to units of local government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02c1b83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in States with populations of less than 2,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02c1b84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17156/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that plan to carry out projects that would result in significant energy efficiency improvements or reductions in fossil fuel use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02c1b85-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tV/s546"},"text":"Pub. L. 110–140, title V, § 546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1673"},"text":"121 Stat. 1673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02c1b86-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02c1b87-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02c1b88-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
