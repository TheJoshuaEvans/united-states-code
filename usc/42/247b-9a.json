{"tag":"section","attrib":{"id":"idb4a8df16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–9a"},"text":"§ 247b–9a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Better diabetes care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4a8df17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Catalyst to Better Diabetes Care Act of 2009”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National diabetes report card","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Director of the Centers for Disease Control and Prevention (referred to in this section as the “Director”), shall prepare on a biennial basis a national diabetes report card (referred to in this section as a “Report Card”) and, to the extent possible, for each State.","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a8df1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Report Card shall include aggregate health outcomes related to individuals diagnosed with diabetes and prediabetes including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4a8df1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventative care practices and quality of care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4a8df1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4a8df1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Report Card that is prepared after the initial Report Card shall include trend analysis for the Nation and, to the extent possible, for each State, for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4a8df20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracking progress in meeting established national goals and objectives for improving diabetes care, costs, and prevalence (including Healthy People 2010); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4a8df21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing policy and program development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Director, shall make each Report Card publicly available, including by posting the Report Card on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of vital statistics collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Centers for Disease Control and Prevention and in collaboration with appropriate agencies and States, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4a8df25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the education and training of physicians on the importance of birth and death certificate data and how to properly complete these documents, including the collection of such data for diabetes and other chronic diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage State adoption of the latest standard revisions of birth and death certificates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4a8df27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States to re-engineer their vital statistics systems in order to provide cost-effective, timely, and accurate vital systems data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death certificate additional language","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary may promote improvements to the collection of diabetes mortality data, including the addition of a question for the individual certifying the cause of death regarding whether the deceased had diabetes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on appropriate level of diabetes medical education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4a8df2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in collaboration with the Institute of Medicine and appropriate associations and councils, conduct a study of the impact of diabetes on the practice of medicine in the United States and the appropriateness of the level of diabetes medical education that should be required prior to licensure, board certification, and board recertification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4a8df2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall submit a report on the study under paragraph (1) to the Committees on Ways and Means and Energy and Commerce of the House of Representatives and the Committees on Finance and Health, Education, Labor, and Pensions of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4a8df2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–9a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4a8df2d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10407"},"text":"Pub. L. 111–148, title X, § 10407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/976"},"text":"124 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4a8df2e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4a8df2f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4a8df30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
