{"tag":"section","attrib":{"id":"idbaaace49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397j"},"text":"§ 1397j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this division:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “abuse” means the knowing infliction of physical or psychological harm or the knowing deprivation of goods or services that are necessary to meet essential needs or to avoid physical or psychological harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult protective services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adult protective services” means such services provided to adults as the Secretary may specify and includes services such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving reports of adult abuse, neglect, or exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigating the reports described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case planning, monitoring, evaluation, and other case work and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing, arranging for, or facilitating the provision of medical, social service, economic, legal, housing, law enforcement, or other protective, emergency, or support services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caregiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “caregiver” means an individual who has the responsibility for the care of an elder, either voluntarily, by contract, by receipt of payment for care, or as a result of the operation of law, and means a family member or other individual who provides (on behalf of such individual or of a public or private agency, organization, or institution) compensated or uncompensated care to an elder who needs supportive services in any setting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct care” means care by an employee or contractor who provides assistance or long-term care services to a recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “elder” means an individual age 60 or older.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elder justice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “elder justice” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from a societal perspective, efforts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent, detect, treat, intervene in, and prosecute elder abuse, neglect, and exploitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect elders with diminished capacity while maximizing their autonomy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from an individual perspective, the recognition of an elder’s rights, including the right to be free of abuse, neglect, and exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a State or local government agency, Indian tribe or tribal organization, or any other public or private entity that is engaged in and has expertise in issues relating to elder justice or in a field necessary to promote elder justice efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exploitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exploitation” means the fraudulent or otherwise illegal, unauthorized, or improper act or process of an individual, including a caregiver or fiduciary, that uses the resources of an elder for monetary or personal benefit, profit, or gain, or that results in depriving an elder of rightful access to, or use of, benefits, resources, belongings, or assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiduciary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “fiduciary”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a person or entity with the legal responsibility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make decisions on behalf of and for the benefit of another person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act in good faith and with fairness; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a trustee, a guardian, a conservator, an executor, an agent under a financial power of attorney or health care power of attorney, or a representative payee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grant” includes a contract, cooperative agreement, or other mechanism for providing financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guardianship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “guardianship” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process by which a State court determines that an adult individual lacks capacity to make decisions about self-care or property, and appoints another individual or entity known as a guardian, as a conservator, or by a similar term, as a surrogate decisionmaker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the court-appointed surrogate decisionmaker carries out duties to the individual and the court; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the court exercises oversight of the surrogate decisionmaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of Pueblo and Rancheria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” includes any Pueblo or Rancheria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “law enforcement” means the full range of potential responders to elder abuse, neglect, and exploitation including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" police, sheriffs, detectives, public safety officers, and corrections personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical examiners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/13/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coroners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term care","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-term care” means supportive and health services specified by the Secretary for individuals who need assistance because the individuals have a loss of capacity for self-care due to illness, disability, or vulnerability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of capacity for self-care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “loss of capacity for self-care” means an inability to engage in 1 or more activities of daily living, including eating, dressing, bathing, management of one’s financial affairs, and other activities the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term care facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “long-term care facility” means a residential care provider that arranges for, or directly provides, long-term care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neglect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “neglect” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of a caregiver or fiduciary to provide the goods or services that are necessary to maintain the health or safety of an elder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nursing facility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nursing facility” has the meaning given such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r/a"},"text":"section 1396r(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of skilled nursing facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nursing facility” includes a skilled nursing facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–3/a"},"text":"section 1395i–3(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-neglect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “self-neglect” means an adult’s inability, due to physical or mental impairment or diminished capacity, to perform essential self-care tasks including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining essential food, clothing, shelter, and medical care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining goods and services necessary to maintain physical health, mental health, or general safety; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/18/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing one’s own financial affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious bodily injury","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaace7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious bodily injury” means an injury—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaaace7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving extreme physical pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving substantial risk of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving protracted loss or impairment of the function of a bodily member, organ, or mental faculty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaaace80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring medical intervention such as surgery, hospitalization, or physical rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaace81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal sexual abuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Serious bodily injury shall be considered to have occurred if the conduct causing the injury is conduct described in section 2241 (relating to aggravated sexual abuse) or 2242 (relating to sexual abuse) of title 18 or any similar offense under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “social”, when used with respect to a service, includes adult protective services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State legal assistance developer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State legal assistance developer” means an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058j"},"text":"section 3058j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Long-Term Care Ombudsman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State Long-Term Care Ombudsman” means the State Long-Term Care Ombudsman described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/a/2"},"text":"section 3058g(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaace85-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2011, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/782"},"text":"124 Stat. 782","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
