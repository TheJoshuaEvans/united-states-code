{"tag":"section","attrib":{"id":"idc029aa35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122"},"text":null,"children":[{"tag":"num","attrib":{"value":"17122"},"text":"§ 17122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc029aa36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Director and the Commercial Director, jointly and in coordination with the Advisory Committee, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aa38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey existing research and studies relating to high-performance green buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aa39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities of common interest;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and recommend a high-performance green building research plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc029aa3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies information and research needs, including the relationships between human health, occupant productivity, safety, security, and accessibility and each of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029aa3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emissions from materials and products in the building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural day lighting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ventilation choices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heating, cooling, and system control choices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moisture control and mold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, cleaning, and pest control activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acoustics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to public transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues relating to the health, comfort, productivity, and performance of occupants of the building;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aa45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promotes the development and dissemination of high-performance green building measurement tools that, at a minimum, may be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc029aa46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor and assess the life-cycle performance of facilities (including demonstration projects) built as high-performance green buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc029aa47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform life-cycle assessments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc029aa48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies and tests new and emerging technologies for high-performance green buildings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the budget and life-cycle costing functions of the Directors’ Offices under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17092/d"},"text":"section 17092(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and identify potential benefits of green buildings relating to security, natural disaster, and emergency needs of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support other research initiatives determined by the Directors’ Offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc029aa4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indoor air quality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Director, in consultation with the Administrator of the Environmental Protection Agency and the Advisory Committee, shall develop and carry out a comprehensive indoor air quality program for all Federal facilities to ensure the safety of Federal workers and facility occupants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc029aa4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during new construction and renovation of facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc029aa4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existing facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc029aa4f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s492"},"text":"Pub. L. 110–140, title IV, § 492","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1651"},"text":"121 Stat. 1651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc029aa50-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc029aa51-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc029aa52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
