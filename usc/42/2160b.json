{"tag":"section","attrib":{"id":"idbbf63953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2160b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2160b"},"text":"§ 2160b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to suspend nuclear cooperation with nations which have not ratified the Convention on the Physical Security of Nuclear Material","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may suspend nuclear cooperation under this chapter with any nation or group of nations which has not ratified the Convention on the Physical Security of Nuclear Material.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbf63954-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVI/s602"},"text":"Pub. L. 99–399, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/875"},"text":"100 Stat. 875","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbf63955-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbf63956-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"