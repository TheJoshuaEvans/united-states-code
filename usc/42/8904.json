{"tag":"section","attrib":{"id":"idbea9c030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904"},"text":null,"children":[{"tag":"num","attrib":{"value":"8904"},"text":"§ 8904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of comprehensive plan; new or existing regulatory authorities, etc., not granted or modified","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea9c031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The comprehensive plan shall be carried out during the nine fiscal years following the fiscal year in which the comprehensive plan is submitted in its final form under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8903/c/3"},"text":"section 8903(c)(3) of this title","children":[],"tail":"; and—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea9c032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out in accord with, and meet the program objectives specified in, paragraphs (1) through (11) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8903/b"},"text":"section 8903(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be managed in accord with paragraphs (12) through (14) of such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea9c034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be funded by annual appropriations, subject to annual authorizations which shall be made for each fiscal year of the program (as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8905"},"text":"section 8905 of this title","children":[],"tail":") after the submission of the Task Force progress report which under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8903/e"},"text":"section 8903(e) of this title","children":[],"tail":" is required to be submitted by January 15 of the calendar year in which such fiscal year begins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea9c035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subchapter shall be deemed to grant any new regulatory authority or to limit, expand, or otherwise modify any regulatory authority under existing law, or to establish new criteria, standards, or requirements for regulation under existing law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea9c036-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tVII/s705"},"text":"Pub. L. 96–294, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/773"},"text":"94 Stat. 773","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
