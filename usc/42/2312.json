{"tag":"section","attrib":{"id":"idbc1ed08f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2312"},"text":null,"children":[{"tag":"num","attrib":{"value":"2312"},"text":"§ 2312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc1ed090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No appropriation shall be made to carry out the provisions and purposes of this chapter unless previously authorized by legislation enacted by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc1ed091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated the sum of $518,000 at Oak Ridge, the sum of $2,215,000 at Richland and the sum of $8,719,000 at Los Alamos for construction, modification, or expansion of municipal installations and utilities authorized to be transferred pursuant to subchapters VI and VII of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc1ed092-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 11, § 118, "},{"tag":"ref","attrib":{"href":"/us/stat/69/484"},"text":"69 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/ch731"},"text":"July 25, 1956, ch. 731","children":[],"tail":", §§ 5, 6, "},{"tag":"ref","attrib":{"href":"/us/stat/70/654"},"text":"70 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/719/s24"},"text":"Pub. L. 87–719, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-28"},"text":"Sept. 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/666"},"text":"76 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/190/s4"},"text":"Pub. L. 90–190, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-14"},"text":"Dec. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/576"},"text":"81 Stat. 576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc1ed093-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc1ed094-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc1ed095-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/190"},"text":"Pub. L. 90–190","children":[],"tail":" substituted provisions prohibiting making of appropriations to carry out provisions and purposes of this chapter unless previously authorized by legislation enacted by Congress for provisions granting authority to appropriate such sums as may be necessary and appropriate to carry out provisions and purposes of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/719"},"text":"Pub. L. 87–719","children":[],"tail":" authorized an appropriation of $8,719,000 at Los Alamos and use of appropriations for utilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"da