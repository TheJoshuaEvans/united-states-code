{"tag":"section","attrib":{"id":"idbc17a44a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286h–1"},"text":"§ 2286h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of certain information to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the Board submits or transmits to the President or the Director of the Office of Management and Budget any legislative recommendation, or any statement or information in preparation of a report to be submitted to the Committees on Armed Services, Appropriations, and Energy and Commerce of the House of Representatives and the Committees on Armed Services, Appropriations, and Energy and Natural Resources of the Senate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2286e/a"},"text":"section 2286e(a) of this title","children":[],"tail":", the Board shall submit at the same time a copy thereof to such committees."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc17a44b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 320, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dC/tXXXII/s3202/a/2"},"text":"Pub. L. 103–160, div. C, title XXXII, § 3202(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1959"},"text":"107 Stat. 1959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXII/s3202/e"},"text":"Pub. L. 112–239, div. C, title XXXII, § 3202(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2220"},"text":"126 Stat. 2220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a44c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a44d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc17a44e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 320 of act ","children":[{"tag":"date","attrib":{"date":"1946-08-01"},"text":"Aug. 1, 1946","children":[],"tail":", was renumbered section 321 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2286i"},"text":"section 2286i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc17a44f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “submitted to the Committees on Armed Services, Appropriations, and Energy and Commerce of the House of Representatives and the Committees on Armed Services, Appropriations, and Energy and Natural Resources of the Senate” for “submitted to the Congress” and “such committees.” for “the Congress.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
