ail":", §§ 2(b), 5(g), "},{"tag":"date","attrib":{"date":"1967-07-01"},"text":"July 1, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/107"},"text":"81 Stat. 107","children":[],"tail":", 108; "},{"tag":"ref","attrib":{"href":"/us/pl/91/69"},"text":"Pub. L. 91–69","children":[],"tail":", §§ 3(a), 4(d), 6, 10(b), "},{"tag":"date","attrib":{"date":"1969-09-17"},"text":"Sept. 17, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/108"},"text":"83 Stat. 108","children":[],"tail":", 110, 114, related to allotments to States, providing in subsec. (a) amount of allotments, subsec. (b) reallotments, and subsec. (c) availability for grant percentage payments, and duration of project support, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tIII/s301"},"text":"Pub. L. 93–29, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/36"},"text":"87 Stat. 36","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc476754-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131"},"text":"Pub. L. 116–131","children":[],"tail":" inserted “of any age” after “an individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365"},"text":"Pub. L. 109–365","children":[],"tail":" added par. (4), redesignated pars. (2), (3), and (4) as pars. (4), (2), and (3), respectively, and moved par. (4) to end of section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" struck out par. (10) which defined “multipurpose senior center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s302"},"text":"Pub. L. 102–375, § 302","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/A"},"text":"Pub. L. 102–375, § 102(b)(3)(A)","children":[],"tail":", (B), redesignated pars. (7) and (8) as (2) and (3), respectively, and struck out former pars. (2) and (3) which defined “information and referral source” and “long-term care facility”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/A"},"text":"Pub. L. 102–375, § 102(b)(3)(A)","children":[],"tail":", struck out pars. (4) to (6) which defined “legal assistance”, “planning and service area”, and “State agency”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/B"},"text":"Pub. L. 102–375, § 102(b)(3)(B)","children":[],"tail":", redesignated pars. (7) and (8) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/A"},"text":"Pub. L. 102–375, § 102(b)(3)(A)","children":[],"tail":", struck out par. (9) which defined “older individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/A"},"text":"Pub. L. 102–375, § 102(b)(3)(A)","children":[],"tail":", struck out par. (11) which defined “focal point”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14) to (21). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s102/b/3/A"},"text":"Pub. L. 102–375, § 102(b)(3)(A)","children":[],"tail":", struck out pars. (14) to (21) which defined “abuse”, “elder abuse”, “caretaker”, “exploitation”, “neglect”, “physical harm”, “greatest economic need”, and “greatest social need”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/b/2"},"text":"Pub. L. 100–175, § 182(b)(2)","children":[],"tail":", redesignated par. (7) as (6) and struck out former par. (6) which read as follows: “The term ‘State’ means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, the Trust Territory of the Pacific Islands, and the Commonwealth of the Northern Mariana Islands.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/b/2/B"},"text":"Pub. L. 100–175, § 182(b)(2)(B)","children":[],"tail":", redesignated pars. (8) to (10) as (7) to (9), respectively. Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", §§ 136(a)(2), 182(b)(2)(B), redesignated par. (11) as (10) and inserted “(including mental health)” after “health”. Former par. (10) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/b/2/B"},"text":"Pub. L. 100–175, § 182(b)(2)(B)","children":[],"tail":", redesignated par. (12) as (11). Former par. (11) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (12), (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/b/2/B"},"text":"Pub. L. 100–175, § 182(b)(2)(B)","children":[],"tail":", which directed the redesignation of pars. (13) and (14) as (12) and (13), respectively, could not be executed because no pars. (13) and (14) had been enacted. A former par. (12) was redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":", §§ 144(a), 182(b)(2)(B), added pars. (15) to (20) and redesignated them as (14) to (19), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (20). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/b/2/B"},"text":"Pub. L. 100–175, § 182(b)(2)(B)","children":[],"tail":", (e)(1), added par. (20) and redesignated former par. (20) as (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s144/a"},"text":"Pub. L. 100–175, § 144(a)","children":[],"tail":", added par. (20)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (21). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175/s182/e/1"},"text":"Pub. L. 100–175, § 182(e)(1)","children":[],"tail":", added par. (21)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459/s302/1"},"text":"Pub. L. 98–459, § 302(1)","children":[],"tail":", substituted “employs, where feasible,” for “employs”, and inserted “to assess the needs and capacities of older individuals,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459/s302/2"},"text":"Pub. L. 98–459, § 302(2)","children":[],"tail":", substituted “legal assistance” for “legal services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459/s302/3"},"text":"Pub. L. 98–459, § 302(3)","children":[],"tail":", substituted “, and the Commonwealth of the Northern Mariana Islands” for “and the Northern Mariana Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/459/s302/4"},"text":"Pub. L. 98–459, § 302(4)","children":[],"tail":", added pars. (10) to (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/d"},"text":"Pub. L. 97–115, § 3(d)","children":[],"tail":", substituted “supportive services” for “social services” in provisions preceding subpar. (A) and in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/b/1"},"text":"Pub. L. 97–115, § 3(b)(1)","children":[],"tail":", inserted provision relating to any category of institutions regulated by a State pursuant to provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/e"},"text":"section 1382e(e) of this title","children":[],"tail":" (for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027/a/12"},"text":"section 3027(a)(12) of this title","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/b/2"},"text":"Pub. L. 97–115, § 3(b)(2)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc49b045-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbc49b046-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/175"},"text":"Pub. L. 100–175","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", except not applicable with respect to any area plan submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3026/a"},"text":"sec