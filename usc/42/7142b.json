{"tag":"section","attrib":{"id":"idbdf230ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7142b"},"text":"§ 7142b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To carry out the activities of the Museum, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf230bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accept and dispose of any gift, devise, or bequest of services or property, real or personal, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf230bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated in a written document by the person making the gift, devise, or bequest as intended for the Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf230bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be suitable and beneficial for use by the Museum;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operate a retail outlet on the premises of the Museum for the purpose of selling or distributing items (including mementos, food, educational materials, replicas, and literature) that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdf230bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant to the contents of the Museum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdf230c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informative, educational, and tasteful;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect reasonable fees where feasible and appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exhibit, perform, display, and publish materials and information of or relating to the Museum in any media or place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with guidelines approved by the Secretary, lease space on the premises of the Museum at reasonable rates and for uses consistent with such guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the proceeds of activities authorized under this section to pay the costs of the Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf230c5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tIV/s402"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title IV, § 402]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–267.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf230c6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf230c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf230c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Miscellaneous Appropriations Act, 2001, and also as part of the Consolidated Appropriations Act, 2001, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
