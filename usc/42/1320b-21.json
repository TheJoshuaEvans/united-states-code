{"tag":"section","attrib":{"id":"idb8545b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–21"},"text":"§ 1320b–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grants for work incentives assistance to disabled beneficiaries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8545b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the Commissioner may make payments in each State to the protection and advocacy system established pursuant to part C of title I of the Developmental Disabilities Assistance and Bill of Rights Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6041"},"text":"42 U.S.C. 6041","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002721"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002721"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for the purpose of providing services to disabled beneficiaries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Services provided to disabled beneficiaries pursuant to a payment made under this section may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and advice about obtaining vocational rehabilitation and employment services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocacy or other services that a disabled beneficiary may need to secure, maintain, or regain gainful employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive payments under this section, a protection and advocacy system shall submit an application to the Commissioner, at such time, in such form and manner, and accompanied by such information and assurances as the Commissioner may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the amount appropriated for a fiscal year for making payments under this section, a protection and advocacy system shall not be paid an amount that is less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a protection and advocacy system located in a State (including the District of Columbia and Puerto Rico) other than Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands, the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8545b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8545b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ⅓ of 1 percent of the amount available for payments under this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a protection and advocacy system located in Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands, $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inflation adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year in which the total amount appropriated to carry out this section exceeds the total amount appropriated to carry out this section in the preceding fiscal year, the Commissioner shall increase each minimum payment under subparagraphs (A) and (B) of paragraph (1) by a percentage equal to the percentage increase in the total amount so appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each protection and advocacy system that receives a payment under this section shall submit an annual report to the Commissioner and the Ticket to Work and Work Incentives Advisory Panel established under section 101(f) of the Ticket to Work and Work Incentives Improvement Act of 1999 on the services provided to individuals by the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this section shall be made from amounts made available for the administration of subchapter II and amounts made available for the administration of subchapter XVI, and shall be allocated among those amounts as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts allotted for payment to a protection and advocacy system under this section for a fiscal year shall remain available for payment to or on behalf of the protection and advocacy system until the end of the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8545b24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabled beneficiary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disabled beneficiary” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8545b26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a disabled beneficiary as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19/k/2"},"text":"section 1320b–19(k)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is receiving a cash payment described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or a supplementary payment described in "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/a/3"},"text":"section 212(a)(3) of Public Law 93–66","children":[],"tail":" (without regard to whether such payment is paid by the Commissioner pursuant to an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382e/a"},"text":"section 1382e(a) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212/b"},"text":"section 212(b) of Public Law 93–66","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382h/b"},"text":"section 1382h(b) of this title","children":[],"tail":", is considered to be receiving benefits under subchapter XVI of this chapter; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8545b29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is entitled to benefits under part A of subchapter XVIII of this chapter by reason of the penultimate sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"section 426(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8545b2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection and advocacy system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “protection and advocacy system” means a protection and advocacy system established pursuant to part C of title I of the Developmental Disabilities Assistance and Bill of Rights Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6041"},"text":"42 U.S.C. 6041","children":[],"tail":" et seq.)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8545b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–21/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $7,000,000 for each of the fiscal years 2000 through 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8545b2c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1150, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/170/tI/s122"},"text":"Pub. L. 106–170, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1890"},"text":"113 Stat. 1890","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/tIV"},"text":"Pub. L. 108–203, title IV","children":[],"tail":", §§ 404(b)(1), (2), 407(b), "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/526"},"text":"118 Stat. 526","children":[],"tail":", 527; "},{"tag":"ref","attrib":{"href":"/us/pl/111/63/s3"},"text":"Pub. L. 111–63, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-09-18"},"text":"Sept. 18, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2001"},"text":"123 Stat. 2001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/280/s2/b"},"text":"Pub. L. 111–280, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2903"},"text":"124 Stat. 2903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8545b2d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8545b2e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8545b2f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act, referred to in subsecs. (a) and (g)(3), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/164"},"text":"Pub. L. 88–164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-31"},"text":"Oct. 31, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/282"},"text":"77 Stat. 282","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/98/527/s2"},"text":"Pub. L. 98–527, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2662"},"text":"98 Stat. 2662","children":[],"tail":", and as further amended, which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/a"},"text":"Pub. L. 106–402, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":". Part C of the Act was classified generally to subchapter III (§ 6041 et seq.) of chapter 75 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101(f) of the Ticket to Work and Work Incentives Improvement Act of 1999, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170/s101/f"},"text":"section 101(f) of Pub. L. 106–170","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19"},"text":"section 1320b–19 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/66/s212"},"text":"Section 212 of Public Law 93–66","children":[],"tail":", referred to in subsec. (g)(2)(B), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1382"},"text":"section 1382 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8545b30-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/280"},"text":"Pub. L. 111–280","children":[],"tail":" substituted “2011” for “2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/63"},"text":"Pub. L. 111–63","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s404/b/2"},"text":"Pub. L. 108–203, § 404(b)(2)","children":[],"tail":", substituted “secure, maintain, or regain” for “secure or regain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s404/b/1"},"text":"Pub. L. 108–203, § 404(b)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The term ‘disabled beneficiary’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–19/k/2"},"text":"section 1320b–19(k)(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s407/b"},"text":"Pub. L. 108–203, § 407(b)","children":[],"tail":", substituted “2009” for “2004”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8545b31-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8545b32-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/tIV/s404/b/3"},"text":"Pub. L. 108–203, title IV, § 404(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/526"},"text":"118 Stat. 526","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/203/tIV/s404/b/3"},"text":"“The amendments made by this subsection [amending this section] shall apply with respect to payments provided after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
