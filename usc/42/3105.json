{"tag":"section","attrib":{"id":"idbc6d8cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3105"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105"},"text":"§ 3105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6d8cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the performance of, and with respect to, the functions, powers, and duties vested in him by this chapter, the Secretary shall (in addition to any authority otherwise vested in him) have the functions, powers, and duties set forth in section 1749a ","children":[{"tag":"ref","attrib":{"idref":"fn003314"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003314"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 12, except subsections (a), (c)(2), and (f) thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8cd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized, notwithstanding the provisions of section 3324(a) and (b) of title 31, to make advance or progress payments on account of any grant made pursuant to this chapter. No part of any grant authorized to be made by the provisions of this chapter shall be used for the payment of ordinary governmental operating expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8cda-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/117/tVII/s705"},"text":"Pub. L. 89–117, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/492"},"text":"79 Stat. 492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/19/s22/b"},"text":"Pub. L. 90–19, § 22(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-05-25"},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/26"},"text":"81 Stat. 26","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6d8cdb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6d8cdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc6d8cdd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1749a"},"text":"Section 1749a of title 12","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVII/s702"},"text":"Pub. L. 99–498, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1545"},"text":"100 Stat. 1545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc6d8cde-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “section 3324(a) and (b) of title 31” substituted for “section 3648 of the Revised Statutes [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":"]” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc6d8cdf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/19"},"text":"Pub. L. 90–19","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
