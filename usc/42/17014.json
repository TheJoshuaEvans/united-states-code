{"tag":"section","attrib":{"id":"idc02034c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014"},"text":null,"children":[{"tag":"num","attrib":{"value":"17014"},"text":"§ 17014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development into integrating electric vehicles onto the electric grid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02034ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a research, development, and demonstration program to advance the integration of electric vehicles, including plug-in hybrid electric vehicles, onto the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02034cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicles-to-grid integration assessment report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a report on the results of a study that examines the research, development, and demonstration opportunities, challenges, and standards needed for integrating electric vehicles onto the electric grid."}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02034cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02034cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of the use of electric vehicles to maintain the reliability of the electric grid, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02034ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of electric vehicles for demand response, load shaping, emergency power, and frequency regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for the reuse of spent electric vehicle batteries for stationary grid storage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impact of grid integration on electric vehicles, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02034d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of bi-directional electricity flow on battery degradation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implications of the use of electric vehicles for grid services on original equipment manufacturer warranties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impacts to the electric grid of increased penetration of electric vehicles, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc02034d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution grid infrastructure needed to support an increase in charging capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for integrating electric vehicles onto the distribution grid while limiting infrastructure upgrades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the changes in electricity demand over a 24-hour cycle due to electric vehicle charging behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the load increases expected from electrifying the transportation sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for customer incentives and other managed charging stations strategies to shift charging off-peak;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technology needed to achieve bi-directional power flow on the distribution grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc02034da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of smart charging techniques;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the standards needed to integrate electric vehicles with the grid, including communications systems, protocols, and charging stations, in collaboration with the National Institute for Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cybersecurity challenges and needs associated with electrifying the transportation sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the feasibility of adopting technologies developed under the program established under subsection (a) at Department facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the Vehicles-to-Grid Integration Assessment Report, the Secretary shall develop a 10-year roadmap to guide the research, development, and demonstration program to integrate electric vehicles onto the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing this report, the Secretary shall consult with relevant stakeholders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02034e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric vehicle manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public utility commissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle battery manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric vehicle supply equipment manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charging infrastructure manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02034e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall update the report required under this section every 3 years for the duration of the program under section ","children":[{"tag":"ref","attrib":{"idref":"fn004238"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004238"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) and shall submit the updated report to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02034e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the research, development, demonstration, and commercial application aims of section,","children":[{"tag":"ref","attrib":{"idref":"fn004239"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004239"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “of this section,”."}],"tail":" the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02034ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the recommendations set forth in the report in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02034eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate across all relevant program offices at the Department to achieve the goals established in this section, including the Office of Electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02034ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate with the National Laboratories to develop testing capabilities for the evaluation, rapid prototyping, and optimization of technologies enabling integration of electric vehicles onto the electric grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02034ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s137"},"text":"Pub. L. 110–140, title I, § 137","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8004/c"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2584"},"text":"134 Stat. 2584","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
