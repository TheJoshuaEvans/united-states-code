{"tag":"section","attrib":{"id":"idc06ec972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912"},"text":null,"children":[{"tag":"num","attrib":{"value":"18912"},"text":"§ 18912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06ec973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of risk","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “country of risk” means a foreign country determined by the Secretary, in accordance with subparagraph (B), to present a risk of theft of United States intellectual property or a threat to the national security of the United States if nationals of the country, or entities owned or controlled by the country or nationals of the country, participate in any research, development, demonstration, or deployment activity authorized under this division or division A or an amendment made by this division or division A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under subparagraph (A), the Secretary, in coordination with the Director of the Office of Intelligence and Counterintelligence, shall take into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent World Wide Threat Assessment of the United States Intelligence Community, prepared by the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent National Counterintelligence Strategy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec979-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered support” means any grant, contract, subcontract, award, loan, program, support, or other activity authorized under this division or division A, or an amendment made by this division or division A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec97a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “entity of concern” means any entity, including a national, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec97b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified under section 1237(b) of the Strom Thurmond National Defense Authorization Act for Fiscal Year 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Public Law 105–261","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec97c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified under section 1260H of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"10 U.S.C. 113","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec97d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the Entity List maintained by the Bureau of Industry and Security of the Department of Commerce and set forth in Supplement No. 4 to part 744 of title 15, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec97e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the list required by section 9(b)(3) of the Uyghur Human Rights Policy Act of 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/145"},"text":"Public Law 116–145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/134/656"},"text":"134 Stat. 656","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec97f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identified by the Secretary, in coordination with the Director of the Office of Intelligence and Counterintelligence and the applicable office that would provide, or is providing, covered support, as posing an unmanageable threat—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec980-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the national security of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec981-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of theft or loss of United States intellectual property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec982-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec983-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec984-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and technology risk assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec985-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and maintain tools and processes to manage and mitigate research security risks, such as a science and technology risk matrix, informed by threats identified by the Director of the Office of Intelligence and Counterintelligence, to facilitate determinations of the risk of loss of United States intellectual property or threat to the national security of the United States posed by activities carried out under any covered support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content and implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and using the tools and processes developed under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec987-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy risk-based approaches to evaluating, awarding, and managing certain research, development, demonstration, and deployment activities, including designations that will indicate the relative risk of activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec988-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess, to the extent practicable, ongoing high-risk activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec989-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an officer or employee of the Department of Energy to be responsible for tracking and notifying recipients of any covered support of unmanageable threats to United States national security or of theft or loss of United States intellectual property posed by an entity of concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec98a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider requiring recipients of covered support to implement additional research security mitigations for higher-risk activities if appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec98b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of research security training for recipients of covered support on the risks posed by entities of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec98c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The tools and processes developed under paragraph (1) shall be evaluated annually and updated as needed, with threat-informed input from the Office of Intelligence and Counterintelligence, to reflect changes in the risk designation under paragraph (2)(A) of research, development, demonstration, and deployment activities conducted by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec98d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity of concern","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec98e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no entity of concern, or individual that owns or controls, is owned or controlled by, or is under common ownership or control with an entity of concern, may receive, or perform work under, any covered support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec98f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of prohibition","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the prohibition under paragraph (1) if determined by the Secretary to be in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 2 weeks prior to issuing a waiver under subparagraph (A), the Secretary shall notify the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives of the intent to issue the waiver, including a justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On finding that any entity of concern or individual described in paragraph (1) has received covered support and has not received a waiver under paragraph (2), the Secretary shall terminate all covered support to that entity of concern or individual, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity of concern or individual identified under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06ec995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibited from receiving or participating in covered support for a period of not less than 1 year but not more than 10 years, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06ec996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instead of the penalty described in clause (i), subject to any other penalties authorized under applicable law or regulations that the Secretary determines to be in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to imposing a penalty under subparagraph (B), the Secretary shall notify the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives of the intent to impose the penalty, including a description of and justification for the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec999-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share information about the unmanageable threats described in subsection (a)(3)(E) with other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec99a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop consistent approaches to identifying entities of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec99b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applied in a manner consistent with the obligations of the United States under international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06ec99c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 240 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06ec99d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06ec99e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tools and processes developed under subsection (b)(1) and any updates to those tools and processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06ec99f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the science and technology risk matrix developed under that subsection and how that matrix has been applied;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec9a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a mitigation plan for managing risks posed by countries of risk with respect to future or ongoing research and development activities of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06ec9a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18912/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defines critical research areas, designated by risk, as determined by the Secretary.","children":[],"tail":"\n"}],"tail