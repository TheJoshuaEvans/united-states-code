{"tag":"section","attrib":{"id":"idbffc5a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16256"},"text":null,"children":[{"tag":"num","attrib":{"value":"16256"},"text":"§ 16256.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffc5a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16256/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish, within the Department of Agriculture or through an independent contracting entity, a program of education and outreach on biobased fuels and biobased products consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc5a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16256/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance programs for feedstock producers to promote producer ownership, investment, and participation in the operation of processing facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffec909-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16256/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public education and outreach to familiarize consumers with the biobased fuels and biobased products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffec90a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16256/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffec90b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s947"},"text":"Pub. L. 109–58, title IX, § 947","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/883"},"text":"119 Stat. 883","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
