{"tag":"section","attrib":{"id":"idbb888373-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862j"},"text":"§ 1862j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director for carrying out sections 2 through 4 $150,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb888374-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/476/s5"},"text":"Pub. L. 102–476, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2301"},"text":"106 Stat. 2301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10312/f/3"},"text":"Pub. L. 117–167, div. B, title III, § 10312(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1522"},"text":"136 Stat. 1522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb888375-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb888376-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb888377-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 2 through 4, referred to in text, is sections 2 to 4 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/476"},"text":"Pub. L. 102–476","children":[],"tail":", which enacted sections 1862h and 1862i of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862"},"text":"section 1862 of this title","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb888378-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Scientific and Advanced-Technology Act of 1992, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb888379-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" amended section generally. Prior to amendment, section authorized appropriations for carrying out sections 1862h to 1862j of this title for fiscal years 1992 and 1993."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
