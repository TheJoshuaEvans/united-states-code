{"tag":"section","attrib":{"id":"idb42cf8a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s217a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"217a–1"},"text":"§ 217a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committees; prohibition of consideration of political affiliations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All appointments to advisory committees established to assist in implementing the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.],"},{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" and the Comprehensive Alcohol Abuse and Alcoholism Prevention, Treatment, and Rehabilitation Act of 1970 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4541"},"text":"42 U.S.C. 4541","children":[],"tail":" et seq.], shall be made without regard to political affiliation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb42cf8a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/278/tX/s1001"},"text":"Pub. L. 94–278, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/415"},"text":"90 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/e"},"text":"Pub. L. 111–256, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-05"},"text":"Oct. 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2643"},"text":"124 Stat. 2643","children":[],"tail":".)"}],"ta