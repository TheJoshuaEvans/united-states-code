,"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb42cf8aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb42cf8ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/256"},"text":"Pub. L. 111–256","children":[],"tail":" struck out “the Mental Retardation Facilities and Community Mental Health Centers Construction Act of 1963,” after “Public Health Service Act,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
