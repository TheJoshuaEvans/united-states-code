{"tag":"section","attrib":{"id":"idb609f57d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a"},"text":null,"children":[{"tag":"num","attrib":{"value":"300a"},"text":"§ 300a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula grants to States for family planning services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb609f57e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary; prerequisites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants, from allotments made under subsection (b), to State health authorities to assist in planning, establishing, maintaining, coordinating, and evaluating family planning services. No grant may be made to a State health authority under this section unless such authority has submitted, and had approved by the Secretary, a State plan for a coordinated and comprehensive program of family planning services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb609f57f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors determining amount of State allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sums appropriated to carry out the provisions of this section shall be allotted to the States by the Secretary on the basis of the population and the financial need of the respective States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb609f580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “State” includes the Commonwealth of Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, the Virgin Islands, the District of Columbia, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb609f581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making grants under this section, there are authorized to be appropriated $10,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":"; $15,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":"; and $20,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb609f582-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title X, § 1002, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/572/s6/c"},"text":"Pub. L. 91–572, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1506"},"text":"84 Stat. 1506","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIX/s905/b/1"},"text":"Pub. L. 94–484, title IX, § 905(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2325"},"text":"90 Stat. 2325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb609f583-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb609f584-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb609f585-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/484"},"text":"Pub. L. 94–484","children":[],"tail":" defined “State” to include Northern Mariana Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb609f586-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb609f587-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of State Delivery of Services; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s931/c"},"text":"Pub. L. 97–35, title IX, § 931(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/570"},"text":"95 Stat. 570","children":[],"tail":", directed Secretary of Health and Human Services to conduct a study of possible ways of State delivery of services for which assistance is authorized by title X of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300"},"text":"42 U.S.C. 300","children":[],"tail":" et seq.] and to report to Congress on results of such study 18 months after "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb609f588-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb609f589-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
