{"tag":"section","attrib":{"id":"idb5e88b77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"295f–1"},"text":"§ 295f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Health Workforce Loan Repayment Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Public Health Workforce Loan Repayment Program (referred to in this section as the “Program”) to assure an adequate supply of, and encourage recruitment and retention of, public health professionals to eliminate critical public health workforce shortages in State, local, and Tribal public health agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to participate in the Program, an individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ead46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accepted for enrollment, or be enrolled, as a student in an accredited institution of higher education or school of public health in the final semester (or equivalent) of a program leading to a certificate or degree, including a master’s or doctoral degree, in public health, epidemiology, laboratory sciences, data systems, data science, data analytics, informatics, statistics, or another subject matter related to public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be employed by, or have accepted employment with, a State, local, or Tribal public health agency, or a related training fellowship at such State, local, or Tribal public health agency, as recognized by the Secretary, to commence upon graduation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ead46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have graduated, during the preceding 10-year period, from an accredited institution of higher education or school of public health and received a certificate or degree, including a master’s or doctoral degree, in public health, epidemiology, laboratory sciences, data systems, data science, data analytics, informatics, statistics, or another subject matter related to public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be employed by, or have accepted employment with, a State, local, or Tribal public health agency or a related training fellowship at such State, local, or Tribal public health agency, as recognized by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a United States citizen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ead473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Secretary to participate in the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ead474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute a written contract as required in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not have received, for the same service, a reduction of loan obligations under section 1087e(m), 1078–10, 1078–11, 1078–12, or 1087j of title 20.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The written contract (referred to in this section as the “written contract”) between the Secretary and an individual shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement on the part of the Secretary that the Secretary will repay on behalf of the individual loans incurred by the individual in the pursuit of the relevant degree or certificate in accordance with the terms of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement on the part of the individual that the individual will serve in the full-time employment of a State, local, or Tribal public health agency or a related fellowship program in a position related to the course of study or program for which the contract was awarded for a period of time (referred to in this section as the “period of obligated service”) of at least 3 consecutive years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement, as appropriate, on the part of the individual to relocate to a priority service area (as determined by the Secretary) in exchange for an additional loan repayment incentive amount to be determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision that any financial obligation of the United States arising out of a contract entered into under this section and any obligation of the individual that is conditioned thereon, is contingent on funds being appropriated for loan repayments under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead47b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the damages to which the United States is entitled,","children":[{"tag":"ref","attrib":{"idref":"fn002280"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002280"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" under this section for the individual’s breach of the contract; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead47c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other statements of the rights and liabilities of the Secretary and of the individual, not inconsistent with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan repayment provided for an individual under a written contract under the Program shall consist of payment, in accordance with paragraph (2), for the individual toward the outstanding principal and interest on education loans incurred by the individual in the pursuit of the relevant degree or certificate described in subsection (b)(1) in accordance with the terms of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for years served","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ead480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year of obligated service that an individual contracts to serve under subsection (c) the Secretary may pay up to $50,000 on behalf of the individual for loans described in paragraph (1). With respect to participants under the Program whose total eligible loans are less than $150,000, the Secretary shall pay an amount that does not exceed ⅓ of the eligible loan balance for each year of obligated service of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ead481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take action in making awards under this section to ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate proportion of contracts are awarded to individuals who are eligible to participate in the program pursuant to subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contracts awarded under this section are equitably distributed among—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5ead484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical regions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5ead485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local, State, and Tribal public health departments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5ead486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such public health departments under subclause (II) serving rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of providing reimbursements for tax liability resulting from payments under paragraph (2) on behalf of an individual, the Secretary shall, in addition to such payments, make payments to the individual in an amount not to exceed 39 percent of the total amount of loan repayments made for the taxable year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postponing obligated service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an individual with a contract to serve under subsection (c), the date of the initiation of the period of obligated service may be postponed as approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who fails to comply with the contract entered into under subsection (c) shall be subject to the same financial penalties as provided for under section 254","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title for breaches of loan repayment contracts under section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title. In the event that a participant fails to either begin or complete the obligated service requirement of the loan repayment contract under this section, the Secretary may waive or suspend either the unfulfilled service or the assessed damages as provided for under section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The loans eligible for repayment under this section are each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any loan for education or training for employment by a health department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any loan under part E of subchapter VI (relating to nursing student loans).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal Direct Stafford Loan, Federal Direct PLUS Loan, Federal Direct Unsubsidized Stafford Loan, or Federal Direct Consolidation Loan (as such terms are used in section 455 of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087e"},"text":"20 U.S.C. 1087e","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Federal Perkins Loan under part E of title I ","children":[{"tag":"ref","attrib":{"idref":"fn002281"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002281"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “part E of title IV”."}],"tail":" of the Higher Education Act of 1965."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other Federal loan, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5ead491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, as appropriate, establish a pilot program, to be known as the Bio-Preparedness Workforce Pilot Program, to provide for loan repayment for health professionals with expertise in infectious diseases and emergency preparedness and response activities to ensure an adequate supply of such professionals. Such program shall be administered consistent with the requirements of this section, except that, to be eligible to participate in the pilot program, an individual shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ead492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accepted for enrollment, or be enrolled, as a student in an accredited institution of higher education in the final semester (or equivalent) of a program leading to a health professions degree or certificate program relevant to such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have graduated, during the preceding 10-year period, from an accredited institution of higher education with a health professions degree or certificate program relevant to such program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ead495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be employed by, or have accepted employment with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal health care facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit health care facility that is located in a health professional shortage area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254e"},"text":"section 254e of this title","children":[],"tail":"), a frontier health professional shortage area (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p"},"text":"section 295p of this title","children":[],"tail":"), or a medically underserved community (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295p"},"text":"section 295p of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity receiving assistance under subchapter XXIV for the provision of clinical services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health program, or a facility, operated by an Indian Tribe or Tribal organization (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") or by an urban Indian organization (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another relevant entity determined appropriate by the Secretary, as a health professional with expertise in infectious diseases or emergency preparedness and response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-duplication of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the pilot program established under paragraph (1) does not unnecessarily duplicate the National Health Service Corps Loan Repayment Program, or any other loan repayment program operated by the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5ead49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5ead49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate the pilot program at the conclusion of the first cycle of recipients funded by the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5ead49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5ead49f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on the evaluation under subparagraph (A). The report shall include, at a minimum, outcomes information from the pilot program, including any impact on recruitment and retention of health professionals with expertise in infectious diseases and emergency preparedness and response activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5ead4a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report under this subparagraph shall include a recommendation by the Secretary as to whether the pilot program under this subsection should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5ead4a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295f–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $100,000,000 for each of fiscal years 2023 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5ead4a2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 776, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5204"},"text":"Pub. L. 111–148, title V, § 5204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/609"},"text":"124 Stat. 609","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2221/a"},"text":"Pub. L. 117–328, div. FF, title II, § 2221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5741"},"text":"136 Stat. 5741","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5ead4a3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5ead4a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5ead4a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (g)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Part E of ti