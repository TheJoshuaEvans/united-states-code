ext":"act July 1, 1944, ch. 373, title VII, § 771","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/290/s2/a"},"text":"Pub. L. 89–290, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1052"},"text":"79 Stat. 1052","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1968-08-16"},"text":"Aug. 16, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/490/tI/s111/a"},"text":"Pub. L. 90–490, title I, § 111(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/775"},"text":"82 Stat. 775","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-11-02"},"text":"Nov. 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/519/tI/s101/a"},"text":"Pub. L. 91–519, title I, § 101(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1343"},"text":"84 Stat. 1343","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s104/a"},"text":"Pub. L. 92–157, title I, § 104(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/443"},"text":"85 Stat. 443","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tI/s101"},"text":"Pub. L. 94–484, title I, § 101","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/stat/90/2245"},"text":"90 Stat. 2245","children":[],"tail":", authorized start-up assistance, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tV/s502"},"text":"Pub. L. 94–484, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2293"},"text":"90 Stat. 2293","children":[],"tail":", effective with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"Sept. 30, 1977","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 776 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 2692 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–111"},"text":"section 300ff–111 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 776 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 789, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295g–9"},"text":"section 295g–9 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s220/g"},"text":"Pub. L. 99–129, title II, § 220(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/544"},"text":"99 Stat. 544","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5ead4a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/10"},"text":"Pub. L. 117–328, § 2221(a)(10)","children":[],"tail":", substituted “Tribal” for “tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/1"},"text":"Pub. L. 117–328, § 2221(a)(1)","children":[],"tail":", substituted “supply of, and encourage recruitment and retention of,” for “supply of” and struck out “Federal,” before “State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/2/A"},"text":"Pub. L. 117–328, § 2221(a)(2)(A)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “be accepted for enrollment, or be enrolled, as a student in an accredited academic educational institution in a State or territory in the final year of a course of study or program leading to a public health or health professions degree or certificate; and have accepted employment with a Federal, State, local, or tribal public health agency, or a related training fellowship, as recognized by the Secretary, to commence upon graduation;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/2/B/i"},"text":"Pub. L. 117–328, § 2221(a)(2)(B)(i)","children":[],"tail":", substituted “accredited institution of higher education or school of public health” for “accredited educational institution in a State or territory” and “a certificate or degree, including a master’s or doctoral degree, in public health, epidemiology, laboratory sciences, data systems, data science, data analytics, informatics, statistics, or another subject matter related to public health” for “a public health or health professions degree or certificate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/10"},"text":"Pub. L. 117–328, § 2221(a)(10)","children":[],"tail":", substituted “Tribal public health agency or” for “tribal public health agency or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/2/B/ii"},"text":"Pub. L. 117–328, § 2221(a)(2)(B)(ii)","children":[],"tail":", struck out “Federal,” before “State,” and substituted “fellowship at such State, local, or Tribal public health agency,” for “fellowship,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/10"},"text":"Pub. L. 117–328, § 2221(a)(10)","children":[],"tail":", substituted “Tribal” for “tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/3"},"text":"Pub. L. 117–328, § 2221(a)(3)","children":[],"tail":", struck out “Federal,” before “State,” and substituted “of at least 3 consecutive years;” for “equal to the greater of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 3 years; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) such longer period of time as determined appropriate by the Secretary and the individual;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/4/A"},"text":"Pub. L. 117–328, § 2221(a)(4)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “A loan repayment provided for an individual under a written contract under the Program shall consist of payment, in accordance with paragraph (2), on behalf of the individual of the principal, interest, and related expenses on government and commercial loans received by the individual regarding the undergraduate or graduate education of the individual (or both), which loans were made for tuition expenses incurred by the individual.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/4/B"},"text":"Pub. L. 117–328, § 2221(a)(4)(B)","children":[],"tail":", designated existing provisions as subpar. (A) and inserted heading, substituted “$50,000” for “$35,000” and “$150,000” for “$105,000”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/5"},"text":"Pub. L. 117–328, § 2221(a)(5)","children":[],"tail":", substituted “with a contract to serve under subsection (c)” for “receiving a degree or certificate from a health professions or other related school”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/6"},"text":"Pub. L. 117–328, § 2221(a)(6)","children":[],"tail":", inserted at end “In the event that a participant fails to either begin or complete the obligated service requirement of the loan repayment contract under this section, the Secretary may waive or suspend either the unfulfilled service or the assessed damages as provided for under section 254"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, as appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/8"},"text":"Pub. L. 117–328, § 2221(a)(8)","children":[],"tail":", added subsecs. (g) and (h). Former subsec. (g) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s2221/a/7"},"text":"Pub. L. 117–328, § 2221(a)(7)","children":[],"tail":", (9), redesignated subsec. (g) as (i) and substituted “$100,000,000 for each of fiscal years 2023 through 2025” for “$195,000,000 for fiscal year 2010, and such sums as may be necessary for each of fiscal years 2011 through 2015”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
