{"tag":"section","attrib":{"id":"idbf44c7cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11361a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11361a"},"text":"§ 11361a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing involuntary family separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf44c7cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11361a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the expiration of the 2-year period that begins upon ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", and except as provided in subsection (b), any project sponsor receiving funds under this subchapter to provide emergency shelter, transitional housing, or permanent housing to families with children under age 18 shall not deny admission to any family based on the age of any child under age 18."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf44c7cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11361a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the requirement under subsection (a), project sponsors of transitional housing receiving funds under this subchapter may target transitional housing resources to families with children of a specific age only if the project sponsor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf44c7ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11361a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates a transitional housing program that has a primary purpose of implementing an evidence-based practice that requires that housing units be targeted to families with children in a specific age group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf44c7cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11361a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such assurances, as the Secretary shall require, that an equivalent appropriate alternative living arrangement for the whole family or household unit has been secured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf44c7d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s404"},"text":"Pub. L. 100–77, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tI/s1103"},"text":"Pub. L. 111–22, div. B, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1677"},"text":"123 Stat. 1677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf44c7d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf44c7d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf44c7d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1103"},"text":"Section 1103 of Pub. L. 111–22","children":[],"tail":", which directed amendment of subtitle A of the McKinney-Vento Homeless Assistance Act by adding this section after section 403 (as so redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1101/2"},"text":"section 1101(2) of Pub. L. 111–22","children":[],"tail":"), was executed by adding this section following section 403 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11361"},"text":"42 U.S.C. 11361","children":[],"tail":") of subtitle A of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":" (this part), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf44c7d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf44c7d5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
