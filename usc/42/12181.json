{"tag":"section","attrib":{"id":"idbf63c228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181"},"text":null,"children":[{"tag":"num","attrib":{"value":"12181"},"text":"§ 12181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf63c229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “commerce” means travel, trade, traffic, commerce, transportation, or communication—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf63c22a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among the several States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c22b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between any foreign country or any territory or possession and any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c22c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between points in the same State but through another State or foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c22d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “commercial facilities” means facilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf63c22e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are intended for nonresidential use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c22f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose operations will affect commerce.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include railroad locomotives, railroad freight cars, railroad cabooses, railroad cars described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12162"},"text":"section 12162 of this title","children":[],"tail":" or covered under this subchapter, railroad rights-of-way, or facilities that are covered or expressly exempted from coverage under the Fair Housing Act of 1968 "},{"tag":"ref","attrib":{"idref":"fn004030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand responsive system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “demand responsive system” means any system of providing transportation of individuals by a vehicle, other than a system which is a fixed route system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fixed route system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fixed route system” means a system of providing transportation of individuals (other than by aircraft) on which a vehicle is operated along a prescribed route according to a fixed schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over-the-road bus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “over-the-road bus” means a bus characterized by an elevated passenger deck located over a baggage compartment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private entity” means any entity other than a public entity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12131/1"},"text":"section 12131(1) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public accommodation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following private entities are considered public accommodations for purposes of this subchapter, if the operations of such entities affect commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf63c235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inn, hotel, motel, or other place of lodging, except for an establishment located within a building that contains not more than five rooms for rent or hire and that is actually occupied by the proprietor of such establishment as the residence of such proprietor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a restaurant, bar, or other establishment serving food or drink;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motion picture house, theater, concert hall, stadium, or other place of exhibition or entertainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an auditorium, convention center, lecture hall, or other place of public gathering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bakery, grocery store, clothing store, hardware store, shopping center, or other sales or rental establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a laundromat, dry-cleaner, bank, barber shop, beauty shop, travel service, shoe repair service, funeral parlor, gas station, office of an accountant or lawyer, pharmacy, insurance office, professional office of a health care provider, hospital, or other service establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a terminal, depot, or other station used for specified public transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a museum, library, gallery, or other place of public display or collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a park, zoo, amusement park, or other place of recreation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nursery, elementary, secondary, undergraduate, or postgraduate private school, or other place of education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c23f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a day care center, senior citizen center, homeless shelter, food bank, adoption agency, or other social service center establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/7/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a gymnasium, health spa, bowling alley, golf course, or other place of exercise or recreation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail and railroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “rail” and “railroad” have the meaning given the term “railroad” in section 20102(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Readily achievable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “readily achievable” means easily accomplishable and able to be carried out without much difficulty or expense. In determining whether an action is readily achievable, factors to be considered include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf63c243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and cost of the action needed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall financial resources of the facility or facilities involved in the action; the number of persons employed at such facility; the effect on expenses and resources, or the impact otherwise of such action upon the operation of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall financial resources of the covered entity; the overall size of the business of a covered entity with respect to the number of its employees; the number, type, and location of its facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf63c246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of operation or operations of the covered entity, including the composition, structure, and functions of the workforce of such entity; the geographic separateness, administrative or fiscal relationship of the facility or facilities in question to the covered entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified public transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specified public transportation” means transportation by bus, rail, or any other conveyance (other than by aircraft) that provides the general public with general or special service (including charter service) on a regular and continuing basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf63c248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12181/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “vehicle” does not include a rail passenger car, railroad locomotive, railroad freight car, railroad caboose, or a railroad car described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12162"},"text":"section 12162 of this title","children":[],"tail":" or covered under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf63c249-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tIII/s301"},"text":"Pub. L. 101–336, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/353"},"text":"104 Stat. 353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf63c24a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf63c24b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf63c24c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Housing Act of 1968, referred to in par. (2), probably means the Fair Housing Act, title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":", which is classified principally to subchapter I of chapter 45 (§ 3601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102/1"},"text":"Section 20102(1) of title 49","children":[],"tail":", referred to in par. (8), was redesignated section 20102(2) and a new section 20102(1) was added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/s2/b/1"},"text":"Pub. L. 110–432, div. A, § 2(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4850"},"text":"122 Stat. 4850","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (9)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf63c24d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (8), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102/1"},"text":"section 20102(1) of title 49","children":[],"tail":"” substituted for “section 202(e) of the Federal Railroad Safety Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s431/e"},"text":"45 U.S.C. 431(e)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf63c24e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf63c24f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tIII/s310"},"text":"Pub. L. 101–336, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/365"},"text":"104 Stat. 365","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/336/tIII/s310"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (b) and (c), this title [enacting this subchapter] shall become effective 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except for any civil action brought for a violation of section 303 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12183"},"text":"section 12183 of this title","children":[],"tail":"], no civil action shall be brought for any act or omission described in section 302 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12182"},"text":"section 12182 of this title","children":[],"tail":"] which occurs—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the first 6 months after the effective date, against businesses that employ 25 or fewer employees and have gross receipts of $1,000,000 or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the first year after the effective date, against businesses that employ 10 or fewer employees and have gross receipts of $500,000 or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"con