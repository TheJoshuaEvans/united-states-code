{"tag":"section","attrib":{"id":"idc030d70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233"},"text":null,"children":[{"tag":"num","attrib":{"value":"17233"},"text":"§ 17233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy storage technology and microgrid assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc030d70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d70d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural electric cooperative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency, authority, or instrumentality of a State or political subdivision of a State that sells or otherwise uses electrical energy to provide electric services for customers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d70f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization working with at least 6 entities described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy storage technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “energy storage technology” includes grid-enabled water heaters, building heating or cooling systems, electric vehicles, the production of hydrogen for transportation or industrial use, or other technologies that store energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microgrid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “microgrid” means a localized grid that operates autonomously regardless of whether the grid can operate in connection with another grid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable energy source” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s918c/a"},"text":"section 918c(a) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural electric cooperative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural electric cooperative” means an electric cooperative (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s796"},"text":"section 796 of title 16","children":[],"tail":") that sells electric energy to persons in rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a program under which the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to eligible entities under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to eligible entities under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disseminate information to eligible entities on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities described in subsections (d)(1) and (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential and existing energy storage technology and microgrid projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a cooperative agreement with an eligible entity to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d71c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d71d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to eligible entities for identifying, evaluating, designing, and demonstrating energy storage technology and microgrid projects that utilize energy from renewable energy sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d71e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d71f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use the grant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc030d721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct feasibility studies to assess the potential for implementation or improvement of energy storage technology or microgrid projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to analyze and implement strategies to overcome barriers to energy storage technology or microgrid project implementation, including financial, contracting, siting, and permitting barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct detailed engineering of energy storage technology or microgrid projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform a cost-benefit analysis with respect to an energy storage technology or microgrid project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan for both the short- and long-term inclusion of energy storage technology or microgrid projects into the future development plans of the eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase and install necessary equipment, materials, and supplies for demonstration of emerging technologies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the grant to obtain technical assistance from experts in carrying out the activities described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d728-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a grant under paragraph (1), an eligible entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d729-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement a public awareness campaign, in coordination with the Secretary, about the project implemented under the grant in the community in which the eligible entity is located, which campaign shall include providing projected environmental benefits achieved under the project, where to find more information about the program established under this section, and any other information the Secretary determines necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d72a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary, and make available to the public, a report that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc030d72b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any energy cost savings and environmental benefits achieved under the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc030d72c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the project, including quantitative assessments to the extent practicable, associated with each activity described in paragraph (3)(A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d72d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and disseminate tools and resources that will benefit other rural electric cooperatives, which may include cost calculators, guidebooks, handbooks, templates, and training courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d72e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities under this subsection shall be subject to the cost-sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d72f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d730-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (b), the Secretary may provide eligible entities with technical assistance relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc030d731-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying opportunities for energy storage technology and microgrid projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d732-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding the technical and economic characteristics of energy storage technology or microgrid projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d733-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding financing alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d734-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting and siting issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d735-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining case studies of similar and successful energy storage technology or microgrid projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d736-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing and obtaining computer software for assessment, design, and operation and maintenance of energy storage technology or microgrid systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc030d737-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding and utilizing the reliability and resiliency benefits of energy storage technology and microgrid projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d738-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" External contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary may enter into contracts with third-party experts, including engineering, finance, and insurance experts, to provide technical assistance to eligible entities relating to the activities described in such paragraph, or other relevant activities, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc030d739-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc030d73a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc030d73b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17233/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amount appropriated under paragraph (1) for each fiscal year shall be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc030d73c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3202"},"text":"Pub. L. 116–260, div. Z, title III, § 3202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2525"},"text":"134 Stat. 2525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc030d73d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc030d73e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc030d73f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
