{"tag":"section","attrib":{"id":"idbfb739e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258"},"text":null,"children":[{"tag":"num","attrib":{"value":"13258"},"text":"§ 13258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfb739e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb739ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fuel cell electric vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fuel cell electric vehicle” means an on-road or non-road vehicle that uses a fuel cell (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16152"},"text":"section 16152 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb739eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid electric vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hybrid electric vehicle” means a new qualified hybrid motor vehicle (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s30B/d/3"},"text":"section 30B(d)(3) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb739ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium- or heavy-duty electric vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medium- or heavy-duty electric vehicle” means an electric, hybrid electric, or plug-in hybrid electric vehicle with a gross vehicle weight of more than 8,501 pounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb739ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neighborhood electric vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “neighborhood electric vehicle” means a 4-wheeled on-road or nonroad vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb739ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a top attainable speed in 1 mile of more than 20 mph and not more than 25 mph on a paved level surface; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb739ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is propelled by an electric motor and on-board, rechargeable energy storage system that is rechargeable using an off-board source of electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb739f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plug-in electric drive vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “plug-in electric drive vehicle” means a vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb739f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" draws motive power from a battery with a capacity of at least 4 kilowatt-hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb739f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be recharged from an external source of electricity for motive power; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb739f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a light-, medium-, or heavy duty motor vehicle or nonroad vehicle (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550"},"text":"section 7550 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb739f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfb739f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate a credit to a fleet or covered person that is required to acquire an alternative fueled vehicle under this subchapter, if that fleet or person acquires an alternative fueled vehicle in excess of the number that fleet or person is required to acquire under this subchapter or acquires an alternative fueled vehicle before the date that fleet or person is required to acquire an alternative fueled vehicle under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfb739f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric vehicles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-01-31"},"text":"January 31, 2009","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfb739f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allocate credit in an amount to be determined by the Secretary for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb739f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acquisition of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbfb739f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hybrid electric vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfb739fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plug-in electric drive vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfb739fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fuel cell electric vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfb739fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a neighborhood electric vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbfb739fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medium- or heavy-duty electric vehicle; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb739fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment in qualified alternative fuel infrastructure or nonroad equipment, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfb739ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allocate more than 1, but not to exceed 5, credits for investment in an emerging technology relating to any vehicle described in subparagraph (A) to encourage—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfb73a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in petroleum demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb73a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technological advancement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfb73a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in vehicle emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In allocating credits under subsection (b), the Secretary shall allocate one credit for each alternative fueled vehicle the fleet or covered person acquires that exceeds the number of alternative fueled vehicles that fleet or person is required to acquire under this subchapter or that is acquired before the date that fleet or person is required to acquire an alternative fueled vehicle under such subchapter. In the event that a vehicle is acquired before the date otherwise required, the Secretary shall allocate one credit per vehicle for each year the vehicle is acquired before the required date. The credit shall be allocated for the same type vehicle as the excess vehicle or earlier acquired vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a fleet or covered person allocated a credit under this section, the Secretary shall treat the credit as the acquisition of one alternative fueled vehicle of the type for which the credit is allocated in the year designated by that fleet or person when determining whether that fleet or person has complied with this subchapter in the year designated. A credit may be counted toward compliance for only one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fleet or covered person allocated a credit under this section or to whom a credit is transferred under this section, may transfer freely the credit to another fleet or person who is required to comply with this subchapter. At the request of the fleet or person to whom a credit is transferred, the Secretary shall treat the transferred credit as the acquisition of one alternative fueled vehicle of the type for which the credit is allocated in the year designated by the fleet or person to whom the credit is transferred when determining whether that fleet or person has complied with this subchapter in the year designated. A transferred credit may be counted toward compliance for only one year. In the case of the alternative fuel provider program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13251"},"text":"section 13251 of this title","children":[],"tail":", a transferred credit may be counted toward compliance only if the requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13251/a/4"},"text":"section 13251(a)(4) of this title","children":[],"tail":" is met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfb73a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13258/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 2008 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfb73a07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tV/s508"},"text":"Pub. L. 102–486, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2897"},"text":"106 Stat. 2897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s133"},"text":"Pub. L. 110–140, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1511"},"text":"121 Stat. 1511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfb73a08-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfb73a09-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfb73a0a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s133/2"},"text":"Pub. L. 110–140, § 133(2)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s133/1"},"text":"Pub. L. 110–140, § 133(1)","children":[],"tail":", (3), redesignated subsec. (a) as (b), designated existing provisions as par. (1), inserted par. heading, and added par. (2). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s133/1"},"text":"Pub. L. 110–140, § 133(1)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and substituted “subsection (b)” for “subsection (a)”. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s133/1"},"text":"Pub. L. 110–140, § 133(1)","children":[],"tail":", redesignated subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s133/5"},"text":"Pub. L. 110–140, § 133(5)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfb73a0b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfb73a0c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
