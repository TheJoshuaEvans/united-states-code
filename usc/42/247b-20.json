{"tag":"section","attrib":{"id":"idb4adc07f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"247b–20"},"text":"§ 247b–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food safety grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4adc080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to States and Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":") to expand participation in networks to enhance Federal, State, and local food safety efforts, including meeting the costs of establishing and maintaining the food safety surveillance, technical, and laboratory capacity needed for such participation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4adc081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247b–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated $19,500,000 for fiscal year 2010, and such sums as may be necessary for each of the fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4adc082-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text