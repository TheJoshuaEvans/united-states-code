{"tag":"section","attrib":{"id":"idb610fa52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300c–14"},"text":"§ 300c–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb610fa53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", and biennially thereafter, the Secretary of Health and Human Services shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report that contains, with respect to the reporting period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb610fa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information regarding the incidence and number of sudden unexpected infant death and sudden unexpected death in childhood (including the number of such infant and child deaths that remain unexplained after investigation), including, to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb610fa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of such information by racial and ethnic group, and by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610fa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate information obtained from death scene investigations and autopsies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610fa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for reducing the incidence of sudden unexpected infant death and sudden unexpected death in childhood;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610fa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which various approaches of reducing and preventing sudden unexpected infant death and sudden unexpected death in childhood have been effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610fa59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300c–11"},"text":"section 300c–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb610fa5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300c–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “sudden unexpected infant death” and “sudden unexpected death in childhood” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300c–11"},"text":"section 300c–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb610fa5b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/273/s3"},"text":"Pub. L. 116–273, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3354"},"text":"134 Stat. 3354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb610fa5c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb610fa5d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb610fa5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Scarlett’s Sunshine on Sudden Unexpected Death Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
