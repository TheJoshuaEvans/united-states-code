{"tag":"section","attrib":{"id":"idbf879dde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12639a"},"text":"§ 12639a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civic Health Assessment and volunteering research and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf879ddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “partnership” means the Corporation, acting in conjunction with (consistent with the terms of an agreement entered into between the Corporation and the National Conference) the National Conference on Citizenship referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s150701"},"text":"section 150701 of title 36","children":[],"tail":" to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879de0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall facilitate the establishment of a Civic Health Assessment by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879de1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after identifying public and private sources of civic health data, selecting a set of civic health indicators, in accordance with subsection (c), that shall comprise the Civic Health Assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879de2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining civic health data relating to the Civic Health Assessment, in accordance with subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879de3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting related analyses, and reporting the data and analyses, as described in paragraphs (4) and (5) of subsection (d) and subsections (e) and (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879de4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of indicators for Civic Health Assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879de5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall select a set of civic health indicators that shall comprise the Civic Health Assessment. In making such selection, the partnership—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879de6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify public and private sources of civic health data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall explore collaborating with other similar efforts to develop national indicators in the civic health domain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sponsor a panel of experts, such as one convened by the National Academy of Sciences, to recommend civic health indicators and data sources for the Civic Health Assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879de9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical advice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the partnership, the Director of the Bureau of the Census and the Commissioner of Labor Statistics shall provide technical advice to the partnership on the selection of the indicators for the Civic Health Assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879dea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall periodically evaluate and update the Civic Health Assessment, and may expand or modify the indicators described in subsection (d)(1) as necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879deb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on the indicators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879dec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sponsored data collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying the civic health indicators for the Civic Health Assessment, and obtaining data for the Assessment, the partnership may sponsor the collection of data for the Assessment or for the various civic health indicators being considered for inclusion in the Assessment, including indicators related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879ded-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteering and community service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879dee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voting and other forms of political and civic engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879def-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charitable giving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879df0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connecting to civic groups and faith-based organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879df1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest in employment, and careers, in public service in the nonprofit sector or government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879df2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding and obtaining knowledge of United States history and government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879df3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social enterprise and innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879df4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data from statistical agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of the Census and the Commissioner of Labor Statistics shall collect annually, to the extent practicable, data to inform the Civic Health Assessment, and shall report data from such collection to the partnership. In determining the data to be collected, the Director and the Commissioner shall examine privacy issues, response rates, and other relevant issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879df5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To obtain data for the Civic Health Assessment, the partnership shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879df6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collected through public and private sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879df7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collected by the Bureau of the Census, through the Current Population Survey, or by the Bureau of Labor Statistics, in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879df8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demographic characteristics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall seek to obtain data for the Civic Health Assessment that will permit the partnership to analyze the data by age group, race and ethnicity, education level, and other demographic characteristics of the individuals involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879df9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other issues","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In obtaining data for the Civic Health Assessment, the partnership may also obtain such information as may be necessary to analyze—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879dfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of Internet technology in strengthening and inhibiting civic activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879dfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of specific programs in strengthening civic activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879dfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civic attitudes and activities of new citizens and immigrants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879dfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas related to civic activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879dfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879dff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall, not less often than once each year, prepare a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879e00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed data obtained under subsection (d), including data on the indicators comprising the Civic Health Assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the analyses described in paragraphs (4) and (5) of subsection (d), to the extent practicable based on the data the partnership is able to obtain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregation and presentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall, to the extent practicable, aggregate the data on the civic health indicators comprising the Civic Health Assessment by community, by State, and nationally. The report described in paragraph (1) shall present the aggregated data in a form that enables communities and States to assess their civic health, as measured on each of the indicators comprising the Civic Health Assessment, and compare those measures with comparable measures of other communities and States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall submit the report to the authorizing committees, and make the report available to the general public on the Corporation’s website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public input","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for public dialogue and input on the Civic Health Assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold conferences and forums to discuss the implications of the data and analyses reported under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteering research and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The partnership shall provide for baseline research and tracking of domestic and international volunteering, and baseline research and tracking related to relevant data on the indicators described in subsection (d). In providing for the research and tracking under this subsection, the partnership shall consider data from the Supplements to the Current Populations Surveys conducted by the Bureau of the Census for the Bureau of Labor Statistics, and data from other public and private sources, including other data collected by the Bureau of the Census and the Bureau of Labor Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact research and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The partnership shall sponsor an independent evaluation of the impact of domestic and international volunteering, including an assessment of best practices for such volunteering, and methods of improving such volunteering through enhanced collaboration among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879e0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that recruit, manage, support, and utilize volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12639a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the development, implementation, or maintenance of a Federal database of personally identifiable information on individuals participating in data collection for sources of information under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf879e0e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s179A"},"text":"Pub. L. 101–610, title I, § 179A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1608/a"},"text":"Pub. L. 111–13, title I, § 1608(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1534"},"text":"123 Stat. 1534","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf879e0f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf879e10-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf879e11-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text"