{"tag":"section","attrib":{"id":"idbfcf06fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14334"},"text":null,"children":[{"tag":"num","attrib":{"value":"14334"},"text":"§ 14334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on sale of button cell mercuric-oxide batteries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall sell, offer for sale, or offer for promotional purposes any button cell mercuric-oxide battery for use in the United States on or after ","children":[{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfcf06fe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/tII/s205"},"text":"Pub. L. 104–142, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1336"},"text":"110 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
