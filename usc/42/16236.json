{"tag":"section","attrib":{"id":"idbffa0f6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236"},"text":null,"children":[{"tag":"num","attrib":{"value":"16236"},"text":"§ 16236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development into integrating renewable energy onto the electric grid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0f6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish a research, development, and demonstration program on technologies that enable integration of renewable energy generation sources onto the electric grid across multiple program offices of the Department. The program shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecasting for predicting generation from variable renewable energy sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of cost-effective low-loss, long-distance transmission lines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of cost-effective advanced technologies for variable renewable generation sources to provide grid services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this program, the Secretary shall coordinate across all relevant program offices at the Department to achieve the goals established in this section, including the Office of Electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consider barriers to adoption and commercial application of technologies that enable integration of renewable energy sources onto the electric grid, including cost and other economic barriers, and shall coordinate with relevant entities to reduce these barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f75-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s936"},"text":"Pub. L. 109–58, title IX, § 936","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8004/b"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2583"},"text":"134 Stat. 2583","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
