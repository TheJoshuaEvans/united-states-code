{"tag":"section","attrib":{"id":"idb66b9d0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–28"},"text":"§ 300x–28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66b9d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of process for appropriate referrals for treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to individuals seeking treatment services, a funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will improve the process in the State for referring the individuals to treatment facilities that can provide to the individuals the treatment modality that is most appropriate for the individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will ensure that prevention, treatment, and recovery personnel operating in the State’s substance use disorder prevention, treatment, and recovery systems have an opportunity to receive training, on an ongoing basis, concerning—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recent trends in substance use disorders in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved methods and evidence-based practices for providing substance use disorder prevention and treatment services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance-based accountability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection and reporting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matters that would serve to further improve the delivery of substance use disorder prevention and treatment services within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of various activities and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved will coordinate prevention and treatment activities with the provision of other appropriate services (including health, social, correctional and criminal justice, educational, vocational rehabilitation, and employment services)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of a State, the Secretary may provide to a State a waiver of any or all of the requirements established in this section if the Secretary determines that, with respect to services for the prevention and treatment of substance use disorders, the requirement involved is unnecessary for maintaining quality in the provision of such services in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for acting upon request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve or deny a request for a waiver under paragraph (1) not later than 120 days after the date on which the request is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–28/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver provided by the Secretary under paragraph (1) shall be applicable only to the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66b9d1a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1928, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/396"},"text":"106 Stat. 396","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/f/2/B"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(f)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1211"},"text":"114 Stat. 1211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/e"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1230"},"text":"130 Stat. 1230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66b9d1b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb66b9d1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Subsection (d)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/f/2"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1211"},"text":"114 Stat. 1211","children":[],"tail":", provided that, effective upon publication of regulations developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/e/1"},"text":"section 300x–32(e)(1) of this title","children":[],"tail":", subsection (d) of this section is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66b9d1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66b9d1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1928 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–7"},"text":"section 300y–7 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/280"},"text":"Pub. L. 99–280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66b9d1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/e/1"},"text":"Pub. L. 114–255, § 8002(e)(1)","children":[],"tail":", struck out “(relative to fiscal year 1992)” after “State involved will improve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/e/2"},"text":"Pub. L. 114–255, § 8002(e)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “With respect to any facility for treatment services or prevention actitivities that is receiving amounts from a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":", a funding agreement for a State for a grant under such section is that continuing education in such services or activities (or both, as the case may be) will be made available to employees of the facility who provide the services or activities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/e/3"},"text":"Pub. L. 114–255, § 8002(e)(3)","children":[],"tail":", substituted “substance use disorders” for “substance abuse”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb66b9d20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb66b9d21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/f/2"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1211"},"text":"114 Stat. 1211","children":[],"tail":", provided that the amendment made by section 3303(f)(2) is effective upon the publication of the regulations developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–32/e/1"},"text":"section 300x–32(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
