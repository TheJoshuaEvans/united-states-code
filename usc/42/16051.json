t","attrib":{},"text":" an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means a program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07191-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program to improve technologies for the commercialization of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07192-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination hybrid/flexible fuel vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07193-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plug-in hybrid/flexible fuel vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07194-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall provide grants that give preference to proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07195-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve the greatest reduction in miles per gallon of petroleum fuel consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07196-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve not less than 250 miles per gallon of petroleum fuel consumption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07197-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the greatest potential of commercialization to the general public within 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall publish in the Federal Register procedures to verify—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hybrid/flexible fuel vehicle technologies to be demonstrated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0719a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that grants are administered in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0719b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 260 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", and annually thereafter, the Secretary shall submit to Congress a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff0719c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0719d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the technologies to be funded under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0719e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the feasibility of the technologies described in paragraph (2) in meeting the goals described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0719f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies applications submitted for the program that were not funded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes recommendations for Federal legislation to achieve commercialization of the technology demonstrated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section, to remain available until expended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16051/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff071a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s706"},"text":"Pub. L. 109–58, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/817"},"text":"119 Stat. 817","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
