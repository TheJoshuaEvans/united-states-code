{"tag":"section","attrib":{"id":"idc06a0edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775"},"text":null,"children":[{"tag":"num","attrib":{"value":"18775"},"text":"§ 18775.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for the modeling and forecasting of demand for minerals used in the energy sector","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06a0ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator, in coordination with the Director of the United States Geological Survey, shall develop a plan for the modeling and forecasting of demand for energy technologies, including for energy production, transmission, or storage purposes, that use minerals that are or could be designated as critical minerals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under paragraph (1) shall identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0ee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and quantity of minerals consumed, delineated by energy technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0ee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing markets for manufactured energy-producing, energy-transmission, and energy-storing equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0ee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging or potential markets for new energy-producing, energy-transmission, and energy-storing technologies entering commercialization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0ee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under subsection (a)(1) shall produce forecasts of energy technology demand—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the 1-year, 5-year, and 10-year periods beginning on the date on which development of the plan is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by economic sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to any other parameters that the Administrator, in collaboration with the Secretary of the Interior, acting through the Director of the United States Geological Survey, determines are needed for the Annual Critical Minerals Outlook.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06a0eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop the plan under subsection (a)(1) in consultation with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06a0eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary with respect to the possible trajectories of emerging energy-producing and energy-storing technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06a0eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Interior, acting through the Director of the United States Geological Survey—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06a0eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid duplicative effort; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06a0eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18775/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to align the analysis of demand with data and analysis of where the minerals are produced, refined, and subsequently processed into materials and parts that are used to build energy technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06a0ef0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIV/s40415"},"text":"Pub. L. 117–58, div. D, title IV, § 40415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1044"},"text":"135 Stat. 1044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06a0ef1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06a0ef2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06a0ef3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
