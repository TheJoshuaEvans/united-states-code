{"tag":"section","attrib":{"id":"idb6a4d633-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–131"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–131"},"text":"§ 300ff–131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infectious diseases and circumstances relevant to notification requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d634-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-30"},"text":"October 30, 2009","children":[],"tail":", the Secretary shall complete the development of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of potentially life-threatening infectious diseases, including emerging infectious diseases, to which emergency response employees may be exposed in responding to emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines describing the circumstances in which such employees may be exposed to such diseases, taking into account the conditions under which emergency response is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–131/a/3"},"text":null,"chil