{"tag":"section","attrib":{"id":"idb60c4013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–4"},"text":"§ 300b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Health Service facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program within the Service to provide voluntary testing, diagnosis, counseling, and treatment of individuals respecting genetic diseases. Services under such program shall be made available through facilities of the Service to persons requesting such services, and the program shall provide appropriate publicity of the availability and voluntary nature of such services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb60c4014-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1105, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tIV/s403/a"},"text":"Pub. L. 94–278, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/409"},"text":"90 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60c4015-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60c4016-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb60c4017-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"P