{"tag":"section","attrib":{"id":"idbf82bc15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621"},"text":null,"children":[{"tag":"num","attrib":{"value":"12621"},"text":"§ 12621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract and grant authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bc16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may, by contract or grant, provide for any public or private organization to carry out the National Civilian Community Corps program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment and facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and National Guard property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall enter into agreements, as necessary, with the Secretary of Defense, the Governor of a State, territory or commonwealth, or the commanding general of the District of Columbia National Guard, as the case may be, to utilize—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf82bc19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment of the Department of Defense and equipment of the National Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf82bc1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense facilities and National Guard facilities identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12622/c"},"text":"section 12622(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12621/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may enter into contracts or agreements for the use of other equipment or facilities to the extent practicable to train and house members of the National Civilian Community Corps and leaders of Corps units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bc1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s161"},"text":"Pub. L. 101–610, title I, § 161","children":[],"tail":", formerly § 195J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2530"},"text":"106 Stat. 2530","children":[],"tail":"; renumbered § 161 and amended