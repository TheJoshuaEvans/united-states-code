{"tag":"section","attrib":{"id":"idb5169442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"263a–1"},"text":"§ 263a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assisted reproductive technology programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5169443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", each assisted reproductive technology (as defined in section 263a–7 "},{"tag":"ref","attrib":{"idref":"fn002113"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) program shall annually report to the Secretary through the Centers for Disease Control—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pregnancy success rates achieved by such program through each assisted reproductive technology, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of each embryo laboratory (as defined in section 263a–7 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title) used by such program and whether the laboratory is certified under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–2"},"text":"section 263a–2 of this title","children":[],"tail":" or has applied for such certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5169446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pregnancy success rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5169447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1), the Secretary shall, in consultation with the organizations referenced in subsection (c), define pregnancy success rates and shall make public any proposed definition in such manner as to facilitate comment from any person (including any Federal or other public agency) during its development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5169448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the definition of pregnancy success rates, the Secretary shall take into account the effect on success rates of age, diagnosis, and other significant factors and shall include in such rates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5169449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basic live birth rate calculated for each assisted reproductive technology performed by an assisted reproductive technology program by dividing the number of pregnancies which result in live births by the number of ovarian stimulation procedures attempted by such program, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb516944a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the live birth rate per successful oocyte retrieval procedure calculated for each assisted reproductive technology performed by an assisted reproductive technology program by dividing the number of pregnancies which result in live births by the number of successful oocyte retrieval procedures performed by such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb516944b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s263a–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the definition under subsection (b), the Secretary shall consult with appropriate consumer and professional organizations with expertise in using, providing, and evaluating professional services and embryo laboratories associated with assisted reproductive technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb516944c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/493/s2"},"text":"Pub. L. 102–493, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3146"},"text":"106 Stat. 3146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb516944d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb516944e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb516944f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s263a–7"},"text":"Section 263a–7 of this title","children":[],"tail":", referred to in subsec. (a), was in the original “section 7” meaning "},{"tag":"ref","attrib":{"href":"/us/pl/102/493/s7"},"text":"section 7 of Pub. L. 102–493","children":[],"tail":", which was translated as reading section 8 to reflect the probable intent of Congress, because definitions are contained in section 8 instead of section 7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5169450-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fertility Clinic Success Rate and Certification Act of 1992, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5169451-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5169452-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Centers for Disease Control changed to Centers for Disease Control and Prevention by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312"},"text":"Pub. L. 102–531, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3504"},"text":"106 Stat. 3504","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5169453-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/493/s9"},"text":"Pub. L. 102–493, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3152"},"text":"106 Stat. 3152","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/493/s9"},"text":"“This Act [enacting this section, sections 263a–2 to 263a–7 of this title, and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":"] shall take effect upon the expiration of 2 years after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
