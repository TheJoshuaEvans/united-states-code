{"tag":"section","attrib":{"id":"idbc7bbd6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation between Federal agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to insure that all Federal programs related to areawide development are carried out in a coordinated manner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc7bbd6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary is authorized to call upon other Federal agencies to supply such statistical data, program reports, and other materials as he deems necessary to discharge his responsibilities for areawide development, and to assist the President in coordinating the areawide development efforts of all Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc7bbd6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Federal agencies which are engaged in administering programs related to areawide development, or which otherwise perform functions relating thereto, shall, to the maximum extent practicable, consult with and seek advice from all other significantly affected Federal departments and agencies in an effort to assure fully coordinated programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc7bbd6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/754/tII/s202"},"text":"Pub. L. 89–754, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1261"},"text":"80 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tVI/s602/c"},"text":"Pub. L. 90–448, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/532"},"text":"82 Stat. 532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7bbd6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7bbd70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7bbd71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" substituted “areawide” for “metropolitan” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
