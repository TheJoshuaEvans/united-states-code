{"tag":"section","attrib":{"id":"idb615dca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–20"},"text":"§ 300d–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against certain false statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb615dca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb615dca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–20/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statements or representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person may not knowingly and willfully make or cause to be made any false statement or representation of a material fact in connection with the furnishing of items or services for which payments may be made by a State from amounts paid to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb615dca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–20/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concealing or failing to disclose information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person with knowledge of the occurrence of any event affecting the right of the person to receive any payments from amounts paid to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–11/a"},"text":"section 300d–11(a) of this title","children":[],"tail":" may not conceal or fail to disclose any such event with the intent of fraudulently securing such amount."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb615dcaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty for violation of prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates a prohibition established in subsection (a) may for each violation be fined in accordance with title 18, or imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb615dcab-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1220, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/590/s3"},"text":"Pub. L. 101–590, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2925"},"text":"104 Stat. 2925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
