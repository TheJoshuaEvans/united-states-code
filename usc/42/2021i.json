{"tag":"section","attrib":{"id":"idbbde6c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021i"},"text":"§ 2021i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing review and approval","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to ensure the timely development of new low-level radioactive waste disposal facilities, the Nuclear Regulatory Commission or, as appropriate, agreement States, shall consider an application for a disposal facility license in accordance with the laws applicable to such application, except that the Commission and the agreement state ","children":[{"tag":"ref","attrib":{"idref":"fn003256"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003256"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “States”."}],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbde6c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1986-01-15"},"text":"January 15, 1986","children":[],"tail":", establish procedures and develop the technical capability for processing applications for such licenses;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbde6c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, complete all activities associated with the review and processing of any application for such a license (except for public hearings) no later than 15 months after the date of receipt of such application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbde6c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, consolidate all required technical and environmental reviews and public hearings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbde6c0c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s9"},"text":"Pub. L. 96–573, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1859"},"text":"99 Stat. 1859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbde6c0d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbde6c0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbde6c0f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Low-Level Radioactive Waste Policy Act, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
