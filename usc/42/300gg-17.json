{"tag":"section","attrib":{"id":"idb6ac0296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–17"},"text":"§ 300gg–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring the quality of care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ac0297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac0298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary, in consultation with experts in health care quality and stakeholders, shall develop reporting requirements for use by a group health plan, and a health insurance issuer offering group or individual health insurance coverage, with respect to plan or coverage benefits and health care provider reimbursement structures that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac0299-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve health outcomes through the implementation of activities such as quality reporting, effective case management, care coordination, chronic disease management, and medication and care compliance initiatives, including through the use of the medical homes model as defined for purposes of section 3602 ","children":[{"tag":"ref","attrib":{"idref":"fn002459"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002459"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Patient Protection and Affordable Care Act, for treatment or services under the plan or coverage;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac029a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement activities to prevent hospital readmissions through a comprehensive program for hospital discharge that includes patient-centered education and counseling, comprehensive discharge planning, and post discharge reinforcement by an appropriate health care professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac029b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement activities to improve patient safety and reduce medical errors through the appropriate use of best clinical practices, evidence based medicine, and health information technology under the plan or coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac029c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement wellness and health promotion activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac029d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac029e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan and a health insurance issuer offering group or individual health insurance coverage shall annually submit to the Secretary, and to enrollees under the plan or coverage, a report on whether the benefits under the plan or coverage satisfy the elements described in subparagraphs (A) through (D) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac029f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report under subparagraph (A) shall be made available to an enrollee under the plan or coverage during each open enrollment period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make reports submitted under subparagraph (A) available to the public through an Internet website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the reporting requirements under paragraph (1), the Secretary may develop and impose appropriate penalties for non-compliance with such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the reporting requirements under paragraph (1), the Secretary may provide for exceptions to such requirements for group health plans and health insurance issuers that substantially meet the goals of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac02a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wellness and prevention programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(D), wellness and health promotion activities may include personalized wellness and prevention services, which are coordinated, maintained or delivered by a health care provider, a wellness and prevention plan manager, or a health, wellness or prevention services organization that conducts health risk assessments or offers ongoing face-to-face, telephonic or web-based intervention efforts for each of the program’s participants, and which may include the following wellness and prevention efforts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac02a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Smoking cessation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Weight management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stress management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical fitness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nutrition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Heart disease prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Healthy lifestyle support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diabetes prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac02ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of Second Amendment gun rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac02ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wellness and prevention programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A wellness and health promotion activity implemented under subsection (a)(1)(D) may not require the disclosure or collection of any information relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac02ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence or storage of a lawfully-possessed firearm or ammunition in the residence or on the property of an individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful use, possession, or storage of a firearm or ammunition by an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on data collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"None of the authorities provided to the Secretary under the Patient Protection and Affordable Care Act or an amendment made by that Act shall be construed to authorize or may be used for the collection of any information relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac02b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful ownership or possession of a firearm or ammunition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful use of a firearm or ammunition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful storage of a firearm or ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on databases or data banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the authorities provided to the Secretary under the Patient Protection and Affordable Care Act or an amendment made by that Act shall be construed to authorize or may be used to maintain records of individual ownership or possession of a firearm or ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on determination of premium rates or eligibility for health insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A premium rate may not be increased, health insurance coverage may not be denied, and a discount, rebate, or reward offered for participation in a wellness program may not be reduced or withheld under any health benefit plan issued pursuant to or in accordance with the Patient Protection and Affordable Care Act or an amendment made by that Act on the basis of, or on reliance upon—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac02b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful ownership or possession of a firearm or ammunition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful use or storage of a firearm or ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac02b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on data collection requirements for individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No individual shall be required to disclose any information under any data collection activity authorized under the Patient Protection and Affordable Care Act or an amendment made by that Act relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac02b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful ownership or possession of a firearm or ammunition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac02ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawful use, possession, or storage of a firearm or ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac02bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall promulgate regulations that provide criteria for determining whether a reimbursement structure is described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac02bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–17/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which regulations are promulgated under subsection (c),","children":[{"tag":"ref","attrib":{"idref":"fn002460"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002460"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsection (d),”."}],"tail":" the Government Accountability Office shall review such regulations and conduct a study and submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report regarding the impact the activities under this section have had on the quality and cost of health care."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ac02bd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2717, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1001/5"},"text":"Pub. L. 111–148, title I, § 1001(5)","children":[],"tail":", title X, § 10101(e), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/135"},"text":"124 Stat. 135","children":[],"tail":", 884.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ac02be-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ac02bf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6ac02c0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3602 of the Patient Protection and Affordable Care Act, referred to in subsec. (a)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s3602"},"text":"section 3602 of Pub. L. 111–148","children":[],"tail":" which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305w–21"},"text":"section 1305w–21 of this title","children":[],"tail":" but the reference probably should be to section 3502 of the Act which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s256a–1"},"text":"section 256a–1 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Patient Protection and Affordable Care Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6ae72c1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10101/e"},"text":"Pub. L. 111–148, § 10101(e)","children":[],"tail":", added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ae72c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ae72c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for plan years beginning on or after the date that is 6 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004"},"text":"section 1004 of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
