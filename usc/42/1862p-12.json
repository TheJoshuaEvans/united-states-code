{"tag":"section","attrib":{"id":"idbb922145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–12"},"text":"§ 1862p–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cloud computing research enhancement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb922146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research focus area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may support a national research agenda in key areas affected by the increased use of public and private cloud computing, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" new approaches, techniques, technologies, and tools for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb922148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimizing the effectiveness and efficiency of cloud computing environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating security, identity, privacy, reliability, and manageability risks in cloud-based environments, including as they differ from traditional data centers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92214a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new algorithms and technologies to define, assess, and establish large-scale, trustworthy, cloud-based infrastructures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92214b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models and advanced technologies to measure, assess, report, and understand the performance, reliability, energy consumption, and other characteristics of complex cloud environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92214c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced security technologies to protect sensitive or proprietary information in global-scale cloud environments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb92214d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb92214e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Director shall initiate a review and assessment of cloud computing research opportunities and challenges, including research areas listed in subsection (a), as well as related issues such as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb92214f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and assurance of data that are the subject of Federal laws and regulations in cloud computing environments, which laws and regulations exist on ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misappropriation of cloud services, piracy through cloud technologies, and other threats to the integrity of cloud services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas of advanced technology needed to enable trusted communications, processing, and storage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas of focus determined appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsolicited proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may accept unsolicited proposals that review and assess the issues described in paragraph (1). The proposals may be judged according to existing criteria of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide an annual report for not less than 5 consecutive years to Congress on the outcomes of National Science Foundation investments in cloud computing research, recommendations for research focus and program improvements, or other related recommendations. The reports, including any interim findings or recommendations, shall be made publicly available on the website of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIST support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute of Standards and Technology shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with industry in the development of standards supporting trusted cloud computing infrastructures, metrics, interoperability, and assurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–12/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support standards development with the intent of supporting common goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb922158-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s524"},"text":"Pub. L. 111–358, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4018"},"text":"124 Stat. 4018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb922159-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb92215a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb92215b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb92215c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb92215d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
