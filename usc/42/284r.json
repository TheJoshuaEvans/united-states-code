{"tag":"section","attrib":{"id":"idb565519f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r"},"text":null,"children":[{"tag":"num","attrib":{"value":"284r"},"text":"§ 284r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56551a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Director of the National Institutes of Health (referred to in this section as the “Director of the National Institutes of Health”), taking into consideration the recommendations developed under section 2039,"},{"tag":"ref","attrib":{"idref":"fn002176"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall develop policies for projects of basic research funded by National Institutes of Health to assess—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56551a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant biological variables including sex, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56551a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how differences between male and female cells, tissues, or animals may be examined and analyzed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56551a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revising policies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may update or revise the policies developed under paragraph (1) as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56551a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing, updating, or revising the policies under this section, the Director of the National Institutes of Health shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56551a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb56551a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Research on Women’s Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56551a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Laboratory Animal Welfare; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb56551a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate members of the scientific and academic communities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56551a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to solicit feedback from members of the scientific and academic communities on the influence of sex as a variable in basic research, including feedback on when it is appropriate for projects of basic research involving cells, tissues, or animals to include both male and female cells, tissues, or animals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56551aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institutes of Health shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56551ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that projects of basic research funded by the National Institutes of Health are conducted in accordance with the policies developed, updated, or revised under this section, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56551ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284r/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage that the results of such research, when published or reported, be disaggregated as appropriate with respect to the analysis of any sex differences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56551ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2038/g"},"text":"Pub. L. 114–255, div. A, title II, § 2038(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1066"},"text":"130 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56551ae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56551af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb56551b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2039, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2039"},"text":"section 2039 of Pub. L. 114–255","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282"},"text":"section 282 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb56551b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the 21st Century Cures Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
