{"tag":"section","attrib":{"id":"idbcebe423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4960"},"text":null,"children":[{"tag":"num","attrib":{"value":"4960"},"text":"§ 4960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In reviewing an application for assistance under this part, the Director shall not deny such assistance to any project or program, or any public or private nonprofit organization, solely on the basis of the duration of the assistance such project, program, or organization has received under this part prior to the date of submission of the application. The Director shall grant assistance under this part on the basis of merit and to accomplish the goals of the VISTA program, and shall consider the needs and requirements of projects in existence on such date as well as potential new projects.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcebe424-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s109"},"text":"Pub. L. 93–113, title I, § 109","children":[],"tail":", formerly § 110, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tI/s103"},"text":"Pub. L. 101–204, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1812"},"text":"103 Stat. 1812","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tIII/s328"},"text":"Pub. L. 103–82, title III, § 328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/902"},"text":"107 Stat. 902","children":[],"tail":"; renumbered § 109, "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2105"},"text":"Pub. L. 111–13, title II, § 2105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1583"},"text":"123 Stat. 1583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebe425-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebe426-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbcebe427-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/s109"},"text":"section 109 of Pub. L. 93–113","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4959"},"text":"section 4959 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2104"},"text":"Pub. L. 111–13, title II, § 2104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1583"},"text":"123 Stat. 1583","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebe428-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[]