{"tag":"section","attrib":{"id":"idc00ab198-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311"},"text":null,"children":[{"tag":"num","attrib":{"value":"16311"},"text":"§ 16311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct, through the Office of Science, programs of research, development, demonstration, and commercial application in high energy physics, nuclear physics, biological and environmental research, basic energy sciences, advanced scientific computing research, and fusion energy sciences, including activities described in this part. The programs shall include support for facilities and infrastructure, education, outreach, information, analysis, and coordination activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab19a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out research, development, demonstration, and commercial application activities of the Office of Science, including activities authorized under this part (including the amounts authorized under the amendment made by section 976(b) ","children":[{"tag":"ref","attrib":{"idref":"fn004224"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004224"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and including basic energy sciences, advanced scientific and computing research, biological and environmental research, fusion energy sciences, high energy physics, nuclear physics, research analysis, and infrastructure support)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,153,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,586,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,200,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,814,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,247,000,000 for fiscal year 2