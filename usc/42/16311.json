ext":" For the science and engineering education pilot program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16323"},"text":"section 16323 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab1b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for each of fiscal years 2007 and 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab1b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab1b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated bioenergy research and development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise authorized by this section, there are authorized to be appropriated to the Secretary for integrated bioenergy research and development programs, projects, and activities, $49,000,000 for each of the fiscal years 2005 through 2009. Activities funded under this subsection shall be coordinated with ongoing related programs of other Federal agencies, including the Plant Genome Program of the National Science Foundation. Of the funds authorized under this subsection, at least $5,000,000 for each fiscal year shall be for training and education targeted to minority and socially disadvantaged farmers and ranchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab1b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s971"},"text":"Pub. L. 109–58, title IX, § 971","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/898"},"text":"119 Stat. 898","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5007"},"text":"Pub. L. 110–69, title V, § 5007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/617"},"text":"121 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s903"},"text":"Pub. L. 111–358, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4045"},"text":"124 Stat. 4045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00ab1b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00ab1b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00ab1ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsecs. (a) and (b), was in the original “this subtitle”, meaning subtitle G (§§ 971–984A) of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/898"},"text":"119 Stat. 898","children":[],"tail":", which enacted this part and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5523"},"text":"section 5523 of Title 15","children":[],"tail":", Commerce and Trade. For complete classification of subtitle G to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 976, referred to in subsecs. (b) and (c)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s976"},"text":"section 976 of Pub. L. 109–58","children":[],"tail":". Subsection (a) of section 976 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16316"},"text":"section 16316 of this title","children":[],"tail":" and subsection (b) of section 976 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5523"},"text":"section 5523 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00ab1bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" added pars. (5) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
