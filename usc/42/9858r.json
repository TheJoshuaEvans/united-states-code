{"tag":"section","attrib":{"id":"idbf01f2c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r"},"text":null,"children":[{"tag":"num","attrib":{"value":"9858r"},"text":"§ 9858r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on waiting lists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf01f2c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall conduct studies to determine, for each State, the number of families that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f2c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are eligible to receive assistance under the Child Care and Development Block Grant Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9857"},"text":"42 U.S.C. 9857","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have applied for the assistance, identified by the type of assistance requested; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been placed on a waiting list for the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f2cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall prepare a report containing the results of each study and shall submit the report to the Committee on Health, Education, Labor and Pensions of the Senate, and the Committee on Education and the Workforce of the House of Representatives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf01f2cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-11-19"},"text":"November 19, 2014","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf01f2ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every 2 years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf01f2cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9858r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “State” has the meaning given the term in section 658P of the Child Care and Development Block Grant Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858n"},"text":"42 U.S.C. 9858n","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf01f2d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186/s12"},"text":"Pub. L. 113–186, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2001"},"text":"128 Stat. 2001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf01f2d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf01f2d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf01f2d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Care and Development Block Grant Act of 1990, referred to in subsec. (a)(1), is subchapter C (§ 658A et seq.) of chapter 8 of subtitle A of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-236"},"text":"104 Stat. 1388–236","children":[],"tail":", which is classified generally to this subchapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9857/a"},"text":"section 9857(a) of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf01f2d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Child Care and Development Block Grant Act of 2014, and not as part of the Child Care and Development Block Grant Act of 1990, which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
