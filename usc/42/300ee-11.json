{"tag":"section","attrib":{"id":"idb68a96c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–11"},"text":"§ 300ee–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a96c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments for States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose described in subsection (b), the Secretary shall for each of the fiscal years 1989 through 1991 make an allotment for each State in an amount determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–17"},"text":"section 300ee–17 of this title","children":[],"tail":". The Secretary shall make payments each such fiscal year to each State from the allotment for the State if the Secretary approves for the fiscal year involved an application submitted by the State pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13"},"text":"section 300ee–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a96c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under subsection (a) for a fiscal year unless the State involved agrees to expend the payments only for the purpose of carrying out, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–12"},"text":"section 300ee–12 of this title","children":[],"tail":", public information activities with respect to acquired immune deficiency syndrome."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a96c7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2501, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3093"},"text":"102 Stat. 3093","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a96c8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a96c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb68a96ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2501 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"section 238 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
