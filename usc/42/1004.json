{"tag":"section","attrib":{"id":"idb8059ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004"},"text":null,"children":[{"tag":"num","attrib":{"value":"1004"},"text":"§ 1004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8059eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1002"},"text":"section 1002 of this title","children":[],"tail":", an individual may not be a qualified individual for any month—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8059edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that begins after the month in which the Commissioner of Social Security is notified by the Attorney General that the individual has been removed from the United States pursuant to section 1227(a) or 1182(a)(6)(A) of title 8 and before the month in which the individual is lawfully admitted to the United States for permanent residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any part of which the individual is fleeing to avoid prosecution, or custody or confinement after conviction, under the laws of the United States or the jurisdiction within the United States from which the person has fled, for a crime, or an attempt to commit a crime, that is a felony under the laws of the place from which the individual has fled, or, in jurisdictions that do not define crimes as felonies, is punishable by death or imprisonment for a term exceeding 1 year regardless of the actual sentence imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during any part of which the individual violates a condition of probation or parole imposed under Federal or State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8059ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which the individual resides in a foreign country and is not a citizen or national of the United States if payments for such month to individuals residing in such country are withheld by the Treasury Department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3329"},"text":"section 3329 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8059edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out subsection (a)(1), the Attorney General shall notify the Commissioner of Social Security as soon as practicable after the removal of any individual under section 1227(a) or 1182(a)(6)(A) of title 8.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8059ee0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VIII, § 804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/169/tII/s251/a"},"text":"Pub. L. 106–169, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-14"},"text":"Dec. 14, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1845"},"text":"113 Stat. 1845","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/tII/s203/c"},"text":"Pub. L. 108–203, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/511"},"text":"118 Stat. 511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8059ee1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8059ee2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8059ee3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior provisions, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1001"},"text":"section 1001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8059ee4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203"},"text":"Pub. L. 108–203","children":[],"tail":" substituted “or, in jurisdictions that do not define crimes as felonies, is punishable by death or imprisonment for a term exceeding 1 year regardless of the actual sentence imposed” for “or which, in the case of the State of New Jersey, is a high misdemeanor under the laws of such State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8059ee5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8059ee6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203"},"text":"Pub. L. 108–203","children":[],"tail":" effective on the first day of the first month that begins on or after the date that is 9 months after "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/s203/d"},"text":"section 203(d) of Pub. L. 108–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s402"},"text":"section 402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
