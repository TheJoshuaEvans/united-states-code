{"tag":"section","attrib":{"id":"idbe3023c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432"},"text":null,"children":[{"tag":"num","attrib":{"value":"7432"},"text":"§ 7432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean heavy-duty vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe3023c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3023c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $600,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":", to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonattainment areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $400,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":", to make awards under this section to eligible recipients and to eligible contractors that propose to replace eligible vehicles to serve 1 or more communities located in an air quality area designated pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407"},"text":"section 7407 of this title","children":[],"tail":" as nonattainment for any air pollutant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds appropriated by paragraph (1), the Administrator shall reserve 3 percent for administrative costs necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":", the Administrator shall implement a program to make awards of grants and rebates to eligible recipients, and to make awards of contracts to eligible contractors for providing rebates, for up to 100 percent of costs for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3023cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incremental costs of replacing an eligible vehicle that is not a zero-emission vehicle with a zero-emission vehicle, as determined by the Administrator based on the market value of the vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing, installing, operating, and maintaining infrastructure needed to charge, fuel, or maintain zero-emission vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development and training to support the maintenance, charging, fueling, and operation of zero-emission vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning and technical activities to support the adoption and deployment of zero-emission vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To seek an award under this section, an eligible recipient or eligible contractor shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3023d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe3023d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible contractor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible contractor” means a contractor that has the capacity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell, lease, license, or contract for service zero-emission vehicles, or charging or other equipment needed to charge, fuel, or maintain zero-emission vehicles, to individuals or entities that own, lease, license, or contract for service an eligible vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to arrange financing for such a sale, lease, license, or contract for service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit school transportation association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible vehicle” means a Class 6 or Class 7 heavy-duty vehicle as defined in section 1037.801 of title 40, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2022-08-16"},"text":"August 16, 2022","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Greenhouse gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe3023dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission vehicle","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-emission vehicle” means a vehicle that has a drivetrain that produces, under any possible operational mode or condition, zero exhaust emissions of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe3023de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any air pollutant that is listed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408/a"},"text":"section 7408(a) of this title","children":[],"tail":" (or any precursor to such an air pollutant); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe3023df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7432/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any greenhouse gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe3023e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 132, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60101"},"text":"Pub. L. 117–169, title VI, § 60101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2063"},"text":"136 Stat. 2063","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
