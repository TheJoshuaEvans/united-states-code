{"tag":"section","attrib":{"id":"idb56c7cd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7b"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b–7b"},"text":"§ 285b–7b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Federal asthma activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56c7cd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of ","children":[{"tag":"ref","attrib":{"idref":"fn002188"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002188"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" Institute shall, through the National Asthma Education Prevention Program Coordinating Committee—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56c7cd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify all Federal programs that carry out asthma-related activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, in consultation with appropriate Federal agencies and professional and voluntary health organizations, a Federal plan for responding to asthma.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7cdb-3a70-11f1-ae07-e4213316b5