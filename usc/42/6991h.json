{"tag":"section","attrib":{"id":"idbdeb04a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991h"},"text":"§ 6991h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of underground storage tanks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdeb04a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petroleum tanks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than twelve months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Administrator shall complete a study of underground storage tanks used for the storage of regulated substances defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991/7/B"},"text":"section 6991(7)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other tanks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than thirty-six months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Administrator shall complete a study of all other underground storage tanks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The studies under subsections (a) and (b) shall include an assessment of the ages, types (including methods of manufacture, coatings, protection systems, the compatibility of the construction materials and the installation methods) and locations (including the climate of the locations) of such tanks; soil conditions, water tables, and the hydrogeology of tank locations; the relationship between the foregoing factors and the likelihood of releases from underground storage tanks; the effectiveness and costs of inventory systems, tank testing, and leak detection systems; and such other factors as the Administrator deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm and heating oil tanks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than thirty-six months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", the Administrator shall conduct a study regarding the tanks referred to in subparagraphs (A) and (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6991/10"},"text":"section 6991(10) of this title","children":[],"tail":". Such study shall include estimates of the number and location of such tanks and an analysis of the extent to which there may be releases or threatened releases from such tanks into the environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the studies authorized by this section, the Administrator shall submit reports to the President and to the Congress containing the results of the studies and recommendations respecting whether or not such tanks should be subject to the preceding provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdeb04ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdeb04af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any owner or operator (excepting an agency, department, or instrumentality of the United States Government, a State or a political subdivision thereof) shall incur costs, including the loss of business opportunity, due to the closure or interruption of operation of an underground storage tank solely for the purpose of conducting studies authorized by this section, the Administrator shall provide such person fair and equitable reimbursement for such costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All claims for reimbursement shall be filed with the Administrator not later than ninety days after the closure or interruption which gives rise to the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursements made under this section shall be from funds appropriated by the Congress pursuant to the authorization contained in section 6916(g) ","children":[{"tag":"ref","attrib":{"idref":"fn003550"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003550"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdeb04b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6991h/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of judicial review, a determination by the Administrator under this subsection shall be considered final agency action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdeb04b3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s9009"},"text":"Pub. L. 89–272, title II, § 9009","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tVI/s601/a"},"text":"Pub. L. 98–616, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3287"},"text":"98 Stat. 3287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXV/s1532/b/3"},"text":"Pub. L. 109–58, title XV, § 1532(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1105"},"text":"119 Stat. 1105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdeb04b4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdeb04b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdeb04b6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6916/g"},"text":"Section 6916(g) of this title","children":[],"tail":", referred to in subsec. (f)(3), probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6916/f"},"text":"section 6916(f) of this title","children":[],"tail":" which authorizes appropriations for this subchapter. There is no subsec. (g) of section 6916."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdeb04b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1532/b/3/A"},"text":"Pub. L. 109–58, § 1532(b)(3)(A)","children":[],"tail":", substituted “6991(7)(B)” for “6991(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1532/b/3/B"},"text":"Pub. L. 109–58, § 1532(b)(3)(B)","children":[],"tail":", substituted “subparagraphs (A) and (B) of section 6991(10)” for “section 6991(1)(A) and (B)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
