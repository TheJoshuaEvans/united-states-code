{"tag":"section","attrib":{"id":"idb5b40dd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–39"},"text":"§ 290bb–39.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer-supported mental health services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b40dd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Mental Health and Substance Use, shall award grants to eligible entities to enable such entities to develop, expand, and enhance access to mental health peer-delivered services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40dd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under subsection (a) shall be used to develop, expand, and enhance national, statewide, or community-focused programs, including virtual peer-support services and technology-related capabilities, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40dda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out workforce development, recruitment, and retention activities, to train, recruit, and retain peer-support providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40ddb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building connections between mental health treatment programs, including between community organizations and peer-support networks, including virtual peer-support networks, and with other mental health support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40ddc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing stigma associated with mental health disorders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40ddd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding and improving virtual peer mental health support services, including through the adoption of technologies and capabilities to expand access to virtual peer mental health support services, such as by acquiring equipment and software necessary to efficiently run virtual peer-support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40dde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducting research on issues relating to mental illness and the impact peer-support has on resiliency, including identifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40ddf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the signs of mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40de0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available to individuals with mental illness and to their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40de1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available to help support individuals living with mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40de2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall give special consideration to the unique needs of rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40de3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b40de4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a consumer-run nonprofit organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b40de5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is principally governed by people living with a mental health condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b40de6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobilizes resources within and outside of the mental health community, which may include through peer-support networks, to increase the prevalence and quality of long-term wellness of individuals living with a mental health condition, including those with a co-occurring substance use disorder; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b40de7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe, Tribal organization, Urban Indian organization, or consortium of Tribes or Tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b40de8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–39/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $13,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b40de9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520H, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1151"},"text":"Pub. L. 117–328, div. FF, title I, § 1151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5658"},"text":"136 Stat. 5658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b40dea-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b40deb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5b40dec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290bb–39, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s520H"},"text":"act July 1, 1944, ch. 373, title V, § 520H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3211"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1203"},"text":"114 Stat. 1203","children":[],"tail":", related to improving outcomes for children and adolescents through services integration between child welfare and mental health services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9017"},"text":"Pub. L. 114–255, div. B, title IX, § 9017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1248"},"text":"130 Stat. 1248","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
