{"tag":"section","attrib":{"id":"idbf400d13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312"},"text":null,"children":[{"tag":"num","attrib":{"value":"11312"},"text":"§ 11312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf400d14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf400d15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Housing and Urban Development, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs, or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Executive Officer of the Corporation for National and Community Service, or the designee of the Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Emergency Management Agency, or the designee of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services, or the designee of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Postmaster General of the United States, or the designee of the Postmaster General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Social Security, or the designee of the Commissioner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General of the United States, or the designee of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget, or the designee of the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Faith-Based and Community Initiatives, or the designee of the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of USA FreedomCorps, or the designee of the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf400d29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/a/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn003994"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003994"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (21) has been enacted."}],"tail":" The heads of such other Federal agencies as the Council considers appropriate, or their designees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf400d2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall elect a Chairperson and a Vice Chairperson from among its members. The positions of Chairperson and Vice Chairperson shall rotate among its members on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf400d2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of its Chairperson or a majority of its members, but not less often than four times each year, and the rotation of the positions of Chairperson and Vice Chairperson required under subsection (b) shall occur at the first meeting of each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf400d2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of additional pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council shall receive no additional pay, allowances, or benefits by reason of their service on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf400d2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the Council shall report to the Chairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf400d2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tII/s202"},"text":"Pub. L. 100–77, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/486"},"text":"101 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/645/tI/s101"},"text":"Pub. L. 101–645, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4674"},"text":"104 Stat. 4674","children":[],"tail":"; "},{"ta