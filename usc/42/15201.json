{"tag":"section","attrib":{"id":"idbfdfd064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15201"},"text":null,"children":[{"tag":"num","attrib":{"value":"15201"},"text":"§ 15201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Medal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2001-09-01"},"text":"September 1, 2001","children":[],"tail":", the President may award, and present in the name of Congress, a Medal of Valor of appropriate design, with ribbons and appurtenances, to a public safety officer who is cited by the Attorney General, upon the recommendation of the Medal of Valor Review Board, for extraordinary valor above and beyond the call of duty. The Public Safety Medal of Valor shall be the highest national award for valor by a public safety officer."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdfd065-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s2"},"text":"Pub. L. 107–12, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/20"},"text":"115 Stat. 20","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdfd066-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfdfd067-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfdfd068-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/12/s1"},"text":"Pub. L. 107–12, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/20"},"text":"115 Stat. 20","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/12/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2214"},"text":"section 2214 of Title 15","children":[],"tail":", Commerce and Trade] may be cited as the ‘Public Safety Officer Medal of Valor Act of 2001’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
