{"tag":"section","attrib":{"id":"idbd2e925a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196c"},"text":null,"children":[{"tag":"num","attrib":{"value":"5196c"},"text":"§ 5196c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for construction of emergency operations centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2e925b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency may make grants to States and Indian tribal governments under this subchapter for equipping, upgrading, and constructing State, local, and Tribal emergency operations centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2e925c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5196c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Federal share of the cost of an activity carried out using amounts from grants made under this section shall not exceed 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2e925d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tVI/s614"},"text":"Pub. L. 93–288, title VI, § 614","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dC/tXXXIV/s3411/a/3"},"text":"Pub. L. 103–337, div. C, title XXXIV, § 3411(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3107"},"text":"108 Stat. 3107","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tII/s202"},"text":"Pub. L. 110–53, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/295"},"text":"121 Stat. 295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/251/s11/a"},"text":"Pub. L. 117–251, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2358"},"text":"136 Stat. 2358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2e925e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2e925f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd2e9260-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 2288 of the former Appendix to Title 50, War and National Defense, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s3412/a"},"text":"Pub. L. 103–337, § 3412(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd2e9261-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/251"},"text":"Pub. L. 117–251","children":[],"tail":" inserted “and Indian tribal governments” after “grants to States” and substituted “State, local, and Tribal” for “State and local”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Notwithstanding any other provision of this subchapter, funds appropriated to carry out this subchapter may not be used for the purpose of constructing emergency operating centers (or similar facilities) in any State unless such State matches in an equal amount the amount made available to such State under this subchapter for such purpose.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd2e9262-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd2e9263-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/251/s11/b"},"text":"Pub. L. 117–251, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2358"},"text":"136 Stat. 2358","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/251/s11/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to amounts appropriated on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd2e9264-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Non-Federal Cost Share","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dK/tIV/s419"},"text":"Pub. L. 108–7, div. K, title IV, § 419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/526"},"text":"117 Stat. 526","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dK/tIV/s419"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196c"},"text":"42 U.S.C. 5196c","children":[],"tail":", amounts provided in "},{"tag":"ref","attrib":{"href":"/us/pl/107/117"},"text":"Public Law 107–117","children":[],"tail":" [see Tables for classification] and subsequent appropriations Acts for the construction of emergency operations centers (or similar facilities) shall only require a 25 percent non-Federal cost share.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
