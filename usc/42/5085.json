{"tag":"section","attrib":{"id":"idbcf55aa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5085"},"text":null,"children":[{"tag":"num","attrib":{"value":"5085"},"text":"§ 5085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, unless enacted in express and specific limitation of the provisions of this section, funds appropriated for any fiscal year to carry out any program under this chapter or any predecessor authority shall remain available, in accordance with the provisions of this chapter, for obligation and expenditure until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcf55aa2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tV/s505"},"text":"Pub. L. 93–113, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/416"},"text":"87 Stat. 416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf55aa3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf55aa4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf55aa5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":", known as the Domestic Volunteer Service Act of 1973, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
