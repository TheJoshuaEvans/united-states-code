{"tag":"section","attrib":{"id":"idc02760ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a"},"text":null,"children":[{"tag":"num","attrib":{"value":"17113a"},"text":"§ 17113a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-emissions steel manufacturing research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02760cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this section is to encourage the research and development of innovative technologies aimed at—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the technological and economic competitiveness of industry and manufacturing in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving significant net nonwater greenhouse emissions reductions in the production processes for iron, steel, and steel mill products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercially available steelmaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercially available steelmaking” means the current production method of iron, steel, and steel mill products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical material” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606"},"text":"section 1606 of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical mineral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical mineral” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1606"},"text":"section 1606 of title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate State or Federal entity, including a federally funded research and development center of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit research institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant entity the Secretary determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership or consortium of two or more entities described in subparagraphs (A) through (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-emissions steel manufacturing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-emissions steel manufacturing” means advanced or commercially available steelmaking with the reduction, to the maximum extent practicable, of net nonwater greenhouse gas emissions to the atmosphere from the production of iron, steel, and steel mill products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall establish a program of research, development, demonstration, and commercial application of advanced tools, technologies, and methods for low-emissions steel manufacturing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (c), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate this program with the programs and activities authorized in title VI of division Z of the Consolidated Appropriations Act, 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate across all relevant program offices of the Department, including the Office of Science, Office of Energy Efficiency and Renewable Energy, the Office of Fossil Energy, and the Office of Nuclear Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage, to the extent practicable, the research infrastructure of the Department, including scientific computing user facilities, x-ray light sources, neutron scattering facilities, and nanoscale science research centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research, development, and demonstration of low-emissions steel manufacturing technologies that have the potential to increase domestic production and employment in advanced and commercially available steelmaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall develop a 5-year strategic plan identifying research, development, demonstration, and commercial application goals for the program established in subsection (c). The Secretary shall submit this plan to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategic plan submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify programs at the Department related to low-emissions steel manufacturing that support the research, development, demonstration, and commercial application activities described in this section, and the demonstration projects under subsection (h);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish technological and programmatic goals to achieve the requirements of subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include timelines for the accomplishment of goals developed under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates to plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than once every two years, the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an updated version of the plan under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02760e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established in subsection (c), the Secretary shall focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02760e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" medium- and high-temperature heat generation technologies used for low-emissions steel manufacturing, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative fuels, including hydrogen and biomass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative reducing agents, including hydrogen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable heat generation technology, including solar and geothermal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electrification of heating processes, including through electrolysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other heat generation sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carbon capture technologies for advanced and commercially available steelmaking processes, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combustion and chemical looping technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of slag to reduce carbon dioxide emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-combustion technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-combustion technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" smart manufacturing technologies and principles, digital manufacturing technologies, and advanced data analytics to develop advanced technologies and practices in information, automation, monitoring, computation, sensing, modeling, and networking to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model and simulate manufacturing production lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and communicate production line status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model, simulate, and optimize the energy efficiency of manufacturing processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" technologies and practices that minimize energy and natural resource consumption, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing products that enable reuse, refurbishment, remanufacturing, and recycling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizing waste from advanced and commercially available steelmaking processes, including through the reuse of waste as resources in other industrial processes for mutual benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing resource efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the energy efficiency of advanced and commercially available steelmaking processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02760fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" alternative materials and technologies that produce fewer emissions during production and result in fewer emissions during use, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02760fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative raw materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02760ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-performance lightweight materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276100-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutions for critical materials and critical minerals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276101-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other technologies that achieve significant carbon emission reductions in low-emissions steel manufacturing, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276102-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" high-performance computing to develop advanced materials and manufacturing processes contributing to the focus areas described in paragraphs (1) through (5), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276103-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modeling, simulation, and optimization of the design of energy efficient and sustainable products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276104-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of digital prototyping and additive manufacturing to enhance product design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276105-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing and validation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Director of the National Institute of Standards and Technology, shall support the development of standardized testing and technical validation of advanced and commercially available steelmaking and low-emissions steel manufacturing through collaboration with one or more National Laboratories, and one or more eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276106-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276107-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary, in carrying out the program established in subsection (c), and in collaboration with industry partners, institutions of higher education, and the National Laboratories, shall support an initiative for the demonstration of low-emissions steel manufacturing, as identified by the Secretary, that uses either—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276108-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276109-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of multiple technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027610a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the initiative established under paragraph (1), the Secretary shall select eligible entities to carry out demonstration projects and to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc027610b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage regional diversity among eligible entities, including participation by rural States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027610c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage technological diversity among eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027610d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that specific projects selected—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc027610e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand on the existing technology demonstration programs of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027610f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize projects that leverage matching funds from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276110-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276111-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than once every two years for the duration of the demonstration initiative under this subsection, a report describing the performance of the initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276112-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the initiative established under this subsection is terminated, an assessment of the success of, and education provided by, the measures carried out by recipients of financial assistance under the initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276113-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276114-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing U.S.A.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276115-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging the resources of relevant existing Manufacturing USA Institutes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278s/d"},"text":"section 278s(d) of title 15","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276116-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating program activities into a relevant existing Manufacturing USA Institute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276117-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a new institute focused on low-emissions steel manufacturing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276118-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17113a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall coordinate with other Federal agencies that are carrying out research and development initiatives to increase industrial competitiveness and achieve significant net nonwater greenhouse emissions reductions through low-emissions steel manufacturing, including the Department of Defense, Department of Transportation, and the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0276119-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s454A"},"text":"Pub. L. 110–140, title IV, § 454A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10751/a"},"text":"Pub. L. 117–167, div. B, title VI, § 10751(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1722"},"text":"136 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc027611a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc027611b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc027611c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title VI of division Z of the Consolidated Appropriations Act, 2021, referred to in subsec. (d)(1), is title VI of div. Z of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2552"},"text":"134 Stat. 2552","children":[],"tail":", which enacted sections 17113 and 17114 to 17115a of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6351"},"text":"section 6351 of this title","children":[],"tail":", and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113"},"text":"section 17113 of this title","children":[],"tail":". For complete classification of title VI to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
