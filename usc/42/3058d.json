{"tag":"section","attrib":{"id":"idbc68ab05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058d"},"text":"§ 3058d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional State plan requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc68ab06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible to receive an allotment under this part, a State shall include in the State plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3027"},"text":"section 3027 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc68ab07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State, in carrying out any subpart of this part for which the State receives funding under this part, will establish programs in accordance with the requirements of the subpart and this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State will hold public hearings, and use other means, to obtain the views of older individuals, area agencies on aging, recipients of grants under subchapter X, and other interested persons and entities regarding programs carried out under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State, in consultation with area agencies on aging, will identify and prioritize statewide activities aimed at ensuring that older individuals have access to, and assistance in securing and maintaining, benefits and rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State will use funds made available under this part for a subpart in addition to, and will not supplant, any funds that are expended under any Federal or State law in existence on the day before ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", to carry out each of the vulnerable elder rights protection activities described in the subpart;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the State will place no restrictions, other than the requirements referred to in clauses (i) through (iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/a/5/C"},"text":"section 3058g(a)(5)(C) of this title","children":[],"tail":", on the eligibility of entities for designation as local Ombudsman entities under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058g/a/5"},"text":"section 3058g(a)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that, with respect to programs for the prevention of elder abuse, neglect, and exploitation under subpart III of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc68ab0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in carrying out such programs the State agency will conduct a program of services consistent with relevant State law and coordinated with existing State adult protective service activities for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc68ab0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public education to identify and prevent elder abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68ab0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipt of reports of elder abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68ab10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active participation of older individuals participating in programs under this chapter through outreach, conferences, and referral of such individuals to other social service agencies or sources of assistance if appropriate and if the individuals to be referred consent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68ab11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral of complaints to law enforcement or public protective service agencies if appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc68ab12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State will not permit involuntary or coerced participation in the program of services described in subparagraph (A) by alleged victims, abusers, or their households; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc68ab13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all information gathered in the course of receiving reports and making referrals shall remain confidential except—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc68ab14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if all parties to such complaint consent in writing to the release of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68ab15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the release of such information is to a law enforcement agency, public protective service agency, licensing or certification agency, ombudsman program, or protection or advocacy system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc68ab16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/6/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon court order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc68ab17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which the State agency will carry out this subchapter in accordance with the assurances described in paragraphs (1) through (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc68ab18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privilege","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither a State, nor a State agency, may require any provider of legal assistance under this part to reveal any information that is protected by the attorney-client privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc68ab19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s705"},"text":"Pub. L. 89–73, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s701"},"text":"Pub. L. 102–375, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1273"},"text":"106 Stat. 1273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s703"},"text":"Pub. L. 106–501, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2289"},"text":"114 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc68ab1a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc68ab1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc68ab1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3058d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s706"},"text":"Pub. L. 89–73, title VII, § 706","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/459/tVII/s701"},"text":"Pub. L. 98–459, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1791"},"text":"98 Stat. 1791","children":[],"tail":", authorized appropriations for fiscal years 1985, 1986, and 1987, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s181"},"text":"Pub. L. 100–175, title I, § 181","children":[],"tail":", title VII, § 701(a), (b), "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/964"},"text":"101 Stat. 964","children":[],"tail":", 983, effective "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", with certain exceptions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s705"},"text":"section 705 of Pub. L. 89–73","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3045d"},"text":"section 3045d of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/478"},"text":"Pub. L. 95–478","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc68ab1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s703/1"},"text":"Pub. L. 106–501, § 703(1)","children":[],"tail":", inserted “each of” after “carry out”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s703/2"},"text":"Pub. L. 106–501, § 703(2)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s703/3"},"text":"Pub. L. 106–501, § 703(3)","children":[],"tail":" to (5), redesignated par. (8) as (7), substituted “paragraphs (1) through (6)” for “paragraphs (1) through (7)”, and struck out former par. (7) which required inclusion in the State plan of assurances that the State agency would make funds available to carry out subpart V, giving priority to area agencies on aging based on greatest need for funds, would require certain conditions of eligibility, would distribute eligibility information to area agencies on aging, and would submit certain reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(7)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc68ab1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc68ab1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable with respect to fiscal year 1993, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s4/b"},"text":"section 4(b) of Pub. L. 103–171","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable with respect to fiscal year 1992, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s905/b/6"},"text":"section 905(b)(6) of Pub. L. 102–375","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
