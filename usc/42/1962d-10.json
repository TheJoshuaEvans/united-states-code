{"tag":"section","attrib":{"id":"idbba9ee51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–10"},"text":"§ 1962d–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with agencies on Delmarva Peninsula study","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the study and investigation authorized by sections 1962d–7 to 1962d–11 of this title, the Secretary is authorized to cooperate with other Federal, State, and local agencies now engaged in comprehensive planning for water resource use and development in the Delmarva Peninsula area by making available to those agencies his findings and to cooperate with those agencies in the Northeastern United States Water Supply Study as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–4"},"text":"section 1962d–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba9ee52-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/618/s4"},"text":"Pub. L. 89–618, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-04"},"text":"Oct. 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/871"},"text":"80 Stat. 871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9ee53-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9ee54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9ee55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
