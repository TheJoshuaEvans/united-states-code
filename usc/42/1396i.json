n":[],"tail":" applicable to nursing facility services furnished on or after "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", without regard to whether regulations implementing such amendment are promulgated by such date, except as otherwise specifically provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r"},"text":"section 1396r of this title","children":[],"tail":", with transitional rule, see section 4214(a), (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r"},"text":"section 1396r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba60f3d3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/210"},"text":"Pub. L. 95–210","children":[],"tail":" applicable to medical assistance provided, under a State plan approved under subchapter XIX of this chapter, on and after first day of first calendar quarter that begins more than six months after "},{"tag":"date","attrib":{"date":"1977-12-13"},"text":"Dec. 13, 1977","children":[],"tail":", with exception for plans requiring State legislation, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/210/s2/f"},"text":"section 2(f) of Pub. L. 95–210","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc"},"text":"section 1395cc of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idba60f3d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null}