{"tag":"section","attrib":{"id":"idb56ec71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285c–3"},"text":"§ 285c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordinating committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56ec71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56ec71c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better coordination of the research activities of all the national research institutes relating to diabetes mellitus, digestive diseases, and kidney, urologic, and hematologic diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56ec71d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating those aspects of all Federal health programs and activities relating to such diseases to assure the adequacy and technical soundness of such programs and activities and to provide for the full communication and exchange of information necessary to maintain adequate coordination of such programs and activities;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall establish a Diabetes Mellitus Interagency Coordinating Committee, a Digestive Diseases Interagency Coordinating Committee, and a Kidney, Urologic, and Hematologic Diseases Coordinating Committee (hereafter in this section individually referred to as a “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56ec71e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; chairman; meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Committee shall be composed of the Directors of each of the national research institutes and divisions involved in research with respect to the diseases for which the Committee is established, the Division Director of the Institute for the diseases for which the Committee is established, the Under Secretary for Health of the Department of Veterans Affairs, and the Assistant Secretary of Defense for Health Affairs (or the designees of such officers) and shall include representation from all other Federal departments and agencies whose programs involve health functions or responsibilities relevant to such diseases, as determined by the Secretary. Each Committee shall be chaired by the Director of NIH (or the designee of the Director). Each Committee shall meet at the call of the chairman, but not less often than four times a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56ec71f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 429, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/843"},"text":"99 Stat. 843","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/527/s10/4"},"text":"Pub. L. 100–527, § 10(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2641"},"text":"102 Stat. 2641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/e/1"},"text":"Pub. L. 102–405, title III, § 302(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1985"},"text":"106 Stat. 1985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/362/s3"},"text":"Pub. L. 108–362, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1703"},"text":"118 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/1/H"},"text":"Pub. L. 109–482, title I, § 104(b)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3693"},"text":"120 Stat. 3693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56ec720-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56ec721-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56ec722-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out subsecs. (c) and (d) which required an annual report detailing the work of the Committee in carrying out subsec. (a) and an annual assessment on Federal pancreatic islet cell transplantation, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/362"},"text":"Pub. L. 108–362","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health of the Department of Veterans Affairs” for “Chief Medical Director of the Department of Veterans Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" substituted “Chief Medical Director of the Department of Veterans Affairs” for “Chief Medical Director of the Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb56ec723-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb56ec724-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb56ec725-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-03-15"},"text":"Mar. 15, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/527/s18/a"},"text":"section 18(a) of Pub. L. 100–527","children":[],"tail":", set out as a Department of Veterans Affairs Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
