 and Congress on administration of this part, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tIV/s403/a"},"text":"Pub. L. 94–278, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/407"},"text":"90 Stat. 407","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb60eb052-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (b)(1)(A)(iii), (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6505/a/1"},"text":"Pub. L. 119–75, § 6505(a)(1)","children":[],"tail":", (2), substituted “treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease” for “prevention and treatment of sickle cell disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6505/a/3/A"},"text":"Pub. L. 119–75, § 6505(a)(3)(A)","children":[],"tail":", substituted “make a grant to, or enter into a contract or cooperative agreement with,” for “enter into a contract with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6505/a/3/B"},"text":"Pub. L. 119–75, § 6505(a)(3)(B)","children":[],"tail":", substituted “treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease” for “prevention and treatment of sickle cell disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/s6505/a/4"},"text":"Pub. L. 119–75, § 6505(a)(4)","children":[],"tail":", substituted “$8,205,000 for each of fiscal years 2026 through 2030” for “$4,455,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/b"},"text":"Pub. L. 115–327, § 3(b)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s712/c"},"text":"section 712(c) of Pub. L. 108–357","children":[],"tail":" to this section and redesignated it as subsec. (b). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/a/1"},"text":"Pub. L. 115–327, § 3(a)(1)","children":[],"tail":", substituted “sickle cell disease” for “Sickle Cell Disease” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/a/2"},"text":"Pub. L. 115–327, § 3(a)(2)","children":[],"tail":", substituted “shall continue efforts, including by awarding grants, to develop or establish mechanisms to improve the treatment of sickle cell disease, and to improve the prevention and treatment of complications of sickle cell disease, in populations with a high proportion of individuals with sickle cell disease” for “shall conduct a demonstration program by making grants to up to 40 eligible entities for each fiscal year in which the program is conducted under this section for the purpose of developing and establishing systemic mechanisms to improve the prevention and treatment of Sickle Cell Disease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/a/3"},"text":"Pub. L. 115–327, § 3(a)(3)","children":[],"tail":", substituted “Geographic diversity” for “Grant award requirements” in heading, struck out cl. (i) designation and heading before “The Administrator shall”, and struck out cl. (ii) which related to priority in awarding grants."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/a/4"},"text":"Pub. L. 115–327, § 3(a)(4)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/327/s3/a/5"},"text":"Pub. L. 115–327, § 3(a)(5)","children":[],"tail":", substituted “$4,455,000 for each of fiscal years 2019 through 2023” for “$10,000,000 for each of fiscal years 2005 through 2009”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
