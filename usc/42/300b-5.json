{"tag":"section","attrib":{"id":"idb60c4018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–5"},"text":"§ 300b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sickle cell disease and other heritable blood disorders research, surveillance, prevention, and treatment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb60c4019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60c401a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award grants related to heritable blood disorders, including sickle cell disease, for one or more of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60c401b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To collect and maintain data on such diseases and conditions, including subtypes as applicable, and their associated health outcomes and complications, including for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60c401c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving national incidence and prevalence data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c401d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying health disparities, including the geographic distribution, related to such diseases and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c401e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the utilization of therapies and strategies to prevent complications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c401f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the effects of genetic, environmental, behavioral, and other risk factors that may affect such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60c4020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To conduct public health activities with respect to such conditions, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60c4021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing strategies to improve health outcomes and access to quality health care for the screening for, and treatment and management of, such diseases and conditions, including through public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c4022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing support to community-based organizations and State and local health departments in conducting education and training activities for patients, communities, and health care providers concerning such diseases and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c4023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting State health departments and regional laboratories, including through training, in testing to identify such diseases and conditions, including specific forms of sickle cell disease, in individuals of all ages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60c4024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and evaluation of best practices for treatment of such diseases and conditions, and prevention and management of their related complications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c4025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, award grants under this subsection to eligible entities across the United States to improve data on the incidence and prevalence of heritable blood disorders, including sickle cell disease, and the geographic distribution of such diseases and conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c4026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To seek a grant under this subsection, an eligible entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c4027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subsection, the Secretary may give priority, as appropriate, to eligible entities that have a relationship with a community-based organization that has experience in, or is capable of, providing services to individuals with heritable blood disorders, including sickle cell disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c4028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible entity” includes the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, the Federated States of Micronesia, the Republic of Marshall ","children":[{"tag":"ref","attrib":{"idref":"fn002325"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002325"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Islands, the Republic of Palau, Indian tribes, a State or local health department, an institution of higher education, or a nonprofit entity with appropriate experience to conduct the activities under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb60c4029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program for the development and establishment of systemic mechanisms for the prevention and treatment of sickle cell disease","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60c402a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct demonstration program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60c402b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, through the Bureau of Primary Health Care and the Maternal and Child Health Bureau, shall continue efforts, including by awarding grants, to develop or establish mechanisms to improve the treatment of sickle cell disease, and to improve the prevention and treatment of complications of sickle cell disease, in populations with a high proportion of individuals with sickle cell disease, including through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60eb02c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of service delivery for individuals with sickle cell disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb02d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic counseling and testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb02e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bundling of technical services related to the treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb02f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of health professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and establishing other efforts related to the expansion and coordination of education, treatment, and continuity of care programs for individuals with sickle cell disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, to the extent practicable, award grants under this section ","children":[{"tag":"ref","attrib":{"idref":"fn002326"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002326"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “this subsection”."}],"tail":" to eligible entities located in different regions of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity awarded a grant under this subsection shall use funds made available under the grant to carry out, in addition to the activities described in paragraph (1)(A), the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60eb033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To facilitate and coordinate the delivery of education, treatment, and continuity of care for individuals with sickle cell disease under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60eb034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity’s collaborative agreement with a community-based sickle cell disease organization or a nonprofit entity that works with individuals who have sickle cell disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sickle cell disease newborn screening program for the State in which the entity is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maternal and child health program under title V of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"42 U.S.C. 701","children":[],"tail":" et seq.) for the State in which the entity is located."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To train nursing and other health staff who provide care for individuals with sickle cell disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enter into a partnership with adult or pediatric hematologists in the region and other regional experts in sickle cell disease at tertiary and academic health centers and State and county health offices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and secure resources for ensuring reimbursement under the medicaid program, State children’s health insurance program, and other health programs for the treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb03a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide or coordinate services for adolescents with sickle cell disease making the transition to adult health care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb03b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coordinating center","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60eb03c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make a grant to, or enter into a contract or cooperative agreement with, an entity to serve as the National Coordinating Center for the demonstration program conducted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb03d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Coordinating Center shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60eb03e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, coordinate, monitor, and distribute data, best practices, and findings regarding the activities funded under grants made to eligible entities under the demonstration program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb03f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a model protocol for eligible entities with respect to the treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop educational materials regarding the treatment of sickle cell disease and the prevention and treatment of complications of sickle cell disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and submit to Congress a final report that includes recommendations regarding the effectiveness of the demonstration program conducted under this subsection and such direct outcome measures as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb60eb042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of health care resources utilized (such as emergency room visits, hospital visits, length of stay, and physician visits for individuals with sickle cell disease); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb60eb043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals that were tested and subsequently received genetic counseling for the sickle cell trait.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring a grant under this subsection shall submit an application to the Administrator at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb60eb046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Health Resources and Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a Federally-qualified health center, a nonprofit hospital or clinic, or a university health center that provides primary health care, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb60eb048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a collaborative agreement with a community-based sickle cell disease organization or a nonprofit entity with experience in working with individuals who have sickle cell disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb60eb049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the Administrator that either the Federally-qualified health center, the nonprofit hospital or clinic, the university health center, the organization or entity described in clause (i), or the experts described in paragraph (2)(C), has at least 5 years of experience in working with individuals who have sickle cell disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb60eb04a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally-qualified health center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federally-qualified health center” has the meaning given that term in section 1905(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396d"},"text":"42 U.S.C. 1396d","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60eb04b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–5/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection, $8,205,000 for each of fiscal years 2026 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60eb04c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1106, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/327"},"text":"Pub. L. 115–327","children":[],"tail":", §§ 2, 3, "},{"tag":"date","attrib":{"date":"2018-12-18"},"text":"Dec. 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4468"},"text":"132 Stat. 4468","children":[],"tail":", 4469; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tV/s6505/a"},"text":"Pub. L. 119–75, div. J, title V, § 6505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/693"},"text":"140 Stat. 693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60eb04d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60eb04e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"not