{"tag":"section","attrib":{"id":"idb64f145c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–25"},"text":"§ 300j–25.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drinking water fountain replacement for schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64f145d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Administrator shall establish a grant program to provide assistance to local educational agencies for the replacement of drinking water fountains manufactured prior to 1988."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f145e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded under the grant program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64f145f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used to pay the costs of replacement of drinking water fountains in schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64f1460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used to pay the costs of monitoring and reporting of lead levels in the drinking water of schools of a local educational agency receiving such funds, as determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f1461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding funds under the grant program, the Administrator shall give priority to local educational agencies based on economic need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64f1462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–25/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2019 through 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64f1463-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1465, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tII/s2006/b/1"},"text":"Pub. L. 115–270, title II, § 2006(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"