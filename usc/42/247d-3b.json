{"tag":"section","attrib":{"id":"idb4b73751-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b"},"text":null,"children":[{"tag":"num","attrib":{"value":"247d–3b"},"text":"§ 247d–3b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships for State and regional hospital preparedness to improve surge capacity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4b73752-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Preparedness and Response, shall award competitive grants or cooperative agreements to eligible entities to enable such entities to improve surge capacity and enhance community and hospital preparedness for, and response to, public health emergencies in accordance with subsection (c), including, as appropriate, capacity and preparedness to address the needs of children and other at-risk individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73753-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for an award under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73754-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b73755-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be a coalition that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4b73756-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more hospitals, at least one of which shall be a designated trauma center, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–13/c"},"text":"section 300d–13(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b73757-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more other local health care facilities, including clinics, health centers, community health centers, primary care facilities, mental health centers, mobile medical assets, or nursing homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b73758-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4b73759-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more political subdivisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4b7375a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4b7375b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more States and one or more political subdivisions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b7375c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more emergency medical service organizations or emergency management organizations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b7375d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare, in consultation with the Chief Executive Officer and the lead health officials of the State, District, or territory in which the hospital and health care facilities described in subparagraph (A) are located, and submit to the Secretary, an application at such time, in such manner, and containing such information as the Secretary may require; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b7375e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b7375f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a/b/1"},"text":"section 247d–3a(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b73760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application at such time, in such manner, and containing such information as the Secretary may require, including the information or assurances required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a/b/2"},"text":"section 247d–3a(b)(2) of this title","children":[],"tail":" and an assurance that the State will adhere to any applicable guidelines established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An award under subsection (a) shall be expended for activities to achieve the preparedness goals described under paragraphs (1), (3), (4), (5), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b"},"text":"section 300hh–1(b) of this title","children":[],"tail":" with respect to all-hazards, including chemical, biological, radiological, or nuclear threats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under subsection (a), the Secretary shall give preference to eligible entities that submit applications that, in the determination of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b73764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will enhance coordination—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4b73765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among the entities described in subsection (b)(1)(A)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b73766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among one or more facilities in a regional health care emergency system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3c"},"text":"section 247d–3c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b73767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between such entities and the entities described in subsection (b)(1)(A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b73768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, in the coalition described in subsection (b)(1)(A), a significant percentage of the hospitals and health care facilities within the geographic area served by such coalition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b73769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under subsection (a), the Secretary shall give preference to eligible entities that, in the determination of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b7376a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include one or more hospitals that are participants in the National Disaster Medical System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b7376b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in a geographic area that faces a high degree of risk, as determined by the Secretary in consultation with the Secretary of Homeland Security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b7376c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a significant need for funds to achieve the preparedness and response goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b/3"},"text":"section 300hh–1(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b7376d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency of planned activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a cooperative agreement to an eligible entity described in subsection (b)(1) unless the application submitted by the entity is coordinated and consistent with an applicable State All-Hazards Public Health Emergency Preparedness and Response Plan and relevant local plans, as determined by the Secretary in consultation with relevant State health officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b7376e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A political subdivision shall not participate in more than one coalition described in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b7376f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local response capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall, to the extent practicable, ensure that activities carried out under an award under subsection (a) are coordinated with activities of relevant local Metropolitan Medical Response Systems, local Medical Reserve Corps, the local Cities Readiness Initiative, and local emergency plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b73771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coalitions consisting of one or more eligible entities under this section may, to the extent practicable, collaborate with other coalitions consisting of one or more eligible entities under this section for purposes of national coordination and collaboration with respect to activities to achieve the preparedness and response goals described under paragraphs (1), (3), (4), (5), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b"},"text":"section 300hh–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives an award under this section shall maintain expenditures for health care preparedness at a level that is not less than the average level of such expenditures maintained by the entity for the preceding 2 year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b73774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit the use of awards under this section to pay salary and related expenses of public health and other professionals employed by State, local, or tribal agencies who are carrying out activities supported by such awards (regardless of whether the primary assignment of such personnel is to carry out such activities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance and accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of section 247d–3a(g), (i), (j), and (k) of this title shall apply to entities receiving awards under this section (regardless of whether such entities are described under subsection (b)(1)(A) or (b)(2)(A)) in the same manner as such requirements apply to entities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a"},"text":"section 247d–3a of this title","children":[],"tail":". In submitting reports under this paragraph, a coalition shall include information on the progress that the coalition has made toward the implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3c"},"text":"section 247d–3c of this title","children":[],"tail":" (or barriers to progress, if any). A coalition described in subsection (b)(1)(A) shall make such reports available to the lead health official of the State in which such coalition is located."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b73777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting goals of National Health Security Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall implement objective, evidence-based metrics to ensure that entities receiving awards under this section are meeting, to the extent practicable, the applicable goals of the National Health Security Strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1"},"text":"section 300hh–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4b73778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4b73779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b7377a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3c"},"text":"section 247d–3c of this title","children":[],"tail":", in accordance with subparagraph (B), there is authorized to be appropriated $385,000,000 for each of fiscal years 2019 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b9a77b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amounts for regional systems","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4b9a77c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), of the amount appropriated under subparagraph (A) for a fiscal year, the Secretary may reserve up to 5 percent for the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3c"},"text":"section 247d–3c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b9a77d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation contingent on continued appropriations for this section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for fiscal year 2019 or a subsequent fiscal year, the amount appropriated under subparagraph (A) is such that, after application of clause (i), the amount remaining for the purpose of carrying out this section would be less than the amount available for such purpose for the previous fiscal year, the amount that may be reserved under clause (i) shall be reduced such that the amount remaining for the purpose of carrying out this section is not less than the amount available for such purpose for the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4b9a77e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to reserve amounts under clause (i) shall expire on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b9a77f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amounts for partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to making awards described in paragraph (3), the Secretary may reserve from the amount appropriated under paragraph (1)(A) for a fiscal year and not reserved for the purpose described in paragraph (1)(B)(i), an amount determined appropriate by the Secretary for making awards to entities described in subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b9a780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards to States and political subdivisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b9a781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated for a fiscal year under paragraph (1)(A) and not reserved under paragraph (1)(B)(i) or (2), the Secretary shall make awards to entities described in subsection (b)(2)(A) that have completed an application as described in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b9a782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the amount of an award to each entity described in subparagraph (A) in the same manner as such amounts are determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a/h"},"text":"section 247d–3a(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4b9a783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of cooperative agreement funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4b9a784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided to an eligible entity under a cooperative agreement under subsection (a) for a fiscal year and remaining unobligated at the end of such year shall remain available to such entity for the next fiscal year for the purposes for which such funds were provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4b9a785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–3b/j/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds contingent on achieving benchmarks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The continued availability of funds under subparagraph (A) with respect to an entity shall be contingent upon such entity achieving the benchmarks and submitting the pandemic influenza plan as required under subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4b9a786-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 319C–2, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s131/a"},"text":"Pub. L. 107–188, title I, § 131(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/624"},"text":"116 Stat. 624","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tIII/s305"},"text":"Pub. L. 109–417, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2861"},"text":"120 Stat. 2861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/85/tXI/s1104/1"},"text":"Pub. L. 110–85, title XI, § 1104(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-27"},"text":"Sept. 27, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/975"},"text":"121 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tII"},"text":"Pub. L. 113–5, title II","children":[],"tail":", §§ 202(c)(2), 203(c), "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/175"},"text":"127 Stat. 175","children":[],"tail":", 176; "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tII"},"text":"Pub. L. 116–22, title II","children":[],"tail":", §§ 201(b), 202(c), (e), 203(c), (e)(2), "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/908-910"},"text":"133 Stat. 908–910","children":[],"tail":", 914.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4b9a787-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4b9a788-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4b9a789-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/1"},"text":"Pub. L. 116–22, § 202(c)(1)","children":[],"tail":", inserted “, acting through the Assistant Secretary for Preparedness and Response,” after “The Secretary” and substituted “preparedness for, and response to, public health emergencies in accordance with subsection (c)” for “preparedness for public health emergencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/2/A"},"text":"Pub. L. 116–22, § 202(c)(2)(A)","children":[],"tail":", substituted “coalition that includes” for “partnership consisting of” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/2/B"},"text":"Pub. L. 116–22, § 202(c)(2)(B)","children":[],"tail":", (C), added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s203/e/2"},"text":"Pub. L. 116–22, § 203(e)(2)","children":[],"tail":", added cl. (ii) and redesignated former cl. (ii) as (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/3/A"},"text":"Pub. L. 116–22, § 202(c)(3)(A)","children":[],"tail":", substituted “coalition” for “partnership” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/3/B"},"text":"Pub. L. 116–22, § 202(c)(3)(B)","children":[],"tail":", substituted “preparedness and response” for “medical preparedness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/4"},"text":"Pub. L. 116–22, § 202(c)(4)","children":[],"tail":", substituted “coalition” for “partnership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/5"},"text":"Pub. L. 116–22, § 202(c)(5)","children":[],"tail":", substituted “Coalitions” for “Partnerships” and “coalitions” for “partnerships” and inserted “and response” after “preparedness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s203/c"},"text":"Pub. L. 116–22, § 203(c)","children":[],"tail":", inserted “In submitting reports under this paragraph, a coalition shall include information on the progress that the coalition has made toward the implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3c"},"text":"section 247d–3c of this title","children":[],"tail":" (or barriers to progress, if any).” after “under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a"},"text":"section 247d–3a of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/c/6"},"text":"Pub. L. 116–22, § 202(c)(6)","children":[],"tail":", substituted “A coalition” for “An entity” and “such coalition” for “such partnership”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s201/b"},"text":"Pub. L. 116–22, § 201(b)","children":[],"tail":", substituted “section 247d–3a(g), (i), (j), and (k)” for “section 247d–3a(g), (i), and (j)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/e/1"},"text":"Pub. L. 116–22, § 202(e)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “For purposes of carrying out this section, there is authorized to be appropriated $374,700,000 for each of fiscal years 2014 through 2018.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/e/2"},"text":"Pub. L. 116–22, § 202(e)(2)","children":[],"tail":", substituted “paragraph (1)(A) for a fiscal year and not reserved for the purpose described in paragraph (1)(B)(i)” for “paragraph (1) for a fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s202/e/3"},"text":"Pub. L. 116–22, § 202(e)(3)","children":[],"tail":", substituted “paragraph (1)(A) and not reserved under paragraph (1)(B)(i) or (2)” for “paragraph (1) and not reserved under paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/1"},"text":"Pub. L. 113–5, § 203(c)(1)","children":[],"tail":", inserted “, including, as appropriate, capacity and preparedness to address the needs of children and other at-risk individuals” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/2"},"text":"Pub. L. 113–5, § 203(c)(2)","children":[],"tail":", substituted “centers, community health centers, primary” for “centers, primary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/3"},"text":"Pub. L. 113–5, § 203(c)(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “An award under subsection (a) shall be expended for activities to achieve the preparedness goals described under paragraphs (1), (3), (4), (5), and (6) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–1/b"},"text":"section 300hh–1(b) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/4"},"text":"Pub. L. 113–5, § 203(c)(4)","children":[],"tail":", added subsec. (g) and struck out former subsec. (g). Prior to amendment, text read as follows: “An eligible entity shall, to the extent practicable, ensure that activities carried out under an award under subsection (a) are coordinated with activities of relevant local Metropolitan Medical Response Systems, local Medical Reserve Corps, the Cities Readiness Initiative, and local emergency plans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/5"},"text":"Pub. L. 113–5, § 203(c)(5)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s202/c/2/A"},"text":"Pub. L. 113–5, § 202(c)(2)(A)","children":[],"tail":", substituted “(i), and (j)” for “(j), and (k)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/6/A"},"text":"Pub. L. 113–5, § 203(c)(6)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “For the purpose of carrying out this section, there is authorized to be appropriated $474,000,000 for fiscal year 2007, and such sums as may be necessary for each of fiscal years 2008 through 2011.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s202/c/2/B"},"text":"Pub. L. 113–5, § 202(c)(2)(B)","children":[],"tail":", substituted “247d–3a(h)” for “247d–3a(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/c/6/B"},"text":"Pub. L. 113–5, § 203(c)(6)(B)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (j)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/85"},"text":"Pub. L. 110–85","children":[],"tail":" substituted “section 247d–3a(i)” for “section 247d–3a(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/417"},"text":"Pub. L. 109–417","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section consisted of subsecs. (a) to (i) relating to partnerships for community and hospital preparedness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
