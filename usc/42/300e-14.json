{"tag":"section","attrib":{"id":"idb6267e72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"300e–14"},"text":"§ 300e–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6267e73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall periodically review the programs of assistance authorized by this subchapter and make an annual report to the Congress of a summary of the activities under each program. The Secretary shall include in such summary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6267e74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of each grant, contract, loan, or loan guarantee made under this subchapter in the period covered by the report and a list of the health maintenance organizations which during such period became qualified health maintenance organizations for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e–9"},"text":"section 300e–9 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267e75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statistics and other information reported in such period to the Secretary in accordance with section 300e(c)(11) ","children":[{"tag":"ref","attrib":{"idref":"fn002340"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002340"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267e76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" findings with respect to the ability of the health maintenance organizations assisted under this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6267e77-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate on a fiscally sound basis without continued Federal financial assistance,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e78-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/c"},"text":"section 300e(c) of this title","children":[],"tail":" respecting their organization and operation,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e79-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide basic and supplemental health services in the manner prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/b"},"text":"section 300e(b) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include indigent and high-risk individuals in their membership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide services to medically underserved populations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6267e7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" findings with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6267e7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of distinct categories of health maintenance organizations in comparison with each other,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health maintenance organizations as a group in comparison with alternative forms of health care delivery, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6267e7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact that health maintenance organizations, individually, by category, and as a group, have on the health of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6267e80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300e–14/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Management and Budget may review the Secretary’s report under subsection (a) before its submission to the Congress, but the Office may not revise the report or delay its submission, and it may submit to the Congress its comments (and those of other departments or agencies of the Government) respecting such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6267e81-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIII, § 1315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/222/s2"},"text":"Pub. L. 93–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-29"},"text":"Dec. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/933"},"text":"87 Stat. 933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6267e82-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6267e83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb6267e84-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/c/11"},"text":"Section 300e(c)(11) of this title","children":[],"tail":", referred to in subsec. (a)(2), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/c/9"},"text":"section 300e(c)(9) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s942/d/1"},"text":"Pub. L. 97–35, title IX, § 942(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/574"},"text":"95 Stat. 574","children":[],"tail":", and redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/c/8"},"text":"section 300e(c)(8) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/100/517/s5/b"},"text":"Pub. L. 100–517, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2579"},"text":"102 Stat. 2579","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
