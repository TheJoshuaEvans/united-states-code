{"tag":"section","attrib":{"id":"idb5655174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q"},"text":null,"children":[{"tag":"num","attrib":{"value":"284q"},"text":"§ 284q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pain research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5655175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research initiatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5655176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH is encouraged to continue and expand, through the Pain Consortium, an aggressive program of basic and clinical research on the causes of and potential treatments for pain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than annually, the Pain Consortium, in consultation with the Division of Program Coordination, Planning, and Strategic Initiatives, shall develop and submit to the Director of NIH recommendations on appropriate pain research initiatives that could be undertaken with funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282a/c/1"},"text":"section 282a(c)(1) of this title","children":[],"tail":" for the Common Fund or otherwise available for such initiatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “Pain Consortium” means the Pain Consortium of the National Institutes of Health or a similar trans-National Institutes of Health coordinating entity designated by the Secretary for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5655179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Pain Research Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb565517a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and as necessary maintain a committee, to be known as the Interagency Pain Research Coordinating Committee (in this section referred to as the “Committee”), to coordinate all efforts within the Department of Health and Human Services and other Federal agencies that relate to pain research."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb565517b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb565517c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of the following voting members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb565517d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 7 voting Federal representatives appoint ","children":[{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “appointed”."}],"tail":" by the Secretary from agencies that conduct pain care research and treatment."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb565517e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 additional voting members appointed under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb565517f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall include additional voting members appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5655180-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 non-Federal members shall be appointed from among scientists, physicians, and other health professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5655181-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members shall be appointed from members of the general public, who are representatives of leading research, advocacy, and service organizations for individuals with pain-related conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655182-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall include such nonvoting members as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655183-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting members of the Committee shall select a chairperson from among such members. The selection of a chairperson shall be subject to the approval of the Director of NIH.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655184-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet at the call of the chairperson of the Committee or upon the request of the Director of NIH, but in no case less often than once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655185-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5655186-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a summary of advances in pain care research supported or conducted by the Federal agencies relevant to the diagnosis, prevention, treatment, and management of pain and diseases and disorders associated with pain, including information on best practices for the utilization of non-pharmacologic treatments, non-addictive medical products, and other drugs or devices approved or cleared by the Food and Drug Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5655187-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify critical gaps in basic and clinical research on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5655188-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the symptoms and causes of pain, including the identification of relevant biomarkers and screening models and the epidemiology of acute and chronic pain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5655189-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis, prevention, treatment, and management of acute and chronic pain, including with respect to non-pharmacologic treatments, non-addictive medical products, and other drugs or devices approved or cleared by the Food and Drug Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb565518a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk factors for, and early warning signs of, substance use disorders in populations with acute and chronic pain; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb565518b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make recommendations to the Director of NIH—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb565518c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the activities of the National Institutes of Health and other Federal agencies are free of unnecessary duplication of effort;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb565518d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how best to disseminate information on pain care and epidemiological data related to acute and chronic pain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb565518e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on how to expand partnerships between public entities and private entities to expand collaborative, cross-cutting research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb565518f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that recommendations and actions taken by the Director with respect to the topics discussed at the meetings described in paragraph (4) are included in appropriate reports to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5655190-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284q/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the necessity of the Committee at least once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5655191-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 409J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4305/b"},"text":"Pub. L. 111–148, title IV, § 4305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/585"},"text":"124 Stat. 585","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVII/s7042"},"text":"Pub. L. 115–271, title VII, § 7042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4016"},"text":"132 Stat. 4016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5655192-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5655193-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5655194-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7042/1/A"},"text":"Pub. L. 115–271, § 7042(1)(A)","children":[],"tail":", substituted “treatment, and management of pain and diseases and disorders associated with pain, including information on best practices for the utilization of non-pharmacologic treatments, non-addictive medical products, and other drugs or devices approved or cleared by the Food and Drug Administration” for “and treatment of pain and diseases and disorders associated with pain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7042/1/B"},"text":"Pub. L. 115–271, § 7042(1)(B)","children":[],"tail":", substituted “on—” and cls. (i) to (iii) for “on the symptoms and causes of pain;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7042/1/C"},"text":"Pub. L. 115–271, § 7042(1)(C)","children":[],"tail":", added subpar. (C) and struck out former subpars. (C) to (E) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) make recommendations to ensure that the activities of the National Institutes of Health and other Federal agencies are free of unnecessary duplication of effort;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) make recommendations on how best to disseminate information on pain care; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) make recommendations on how to expand partnerships between public entities and private entities to expand collaborative, cross-cutting research.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/s7042/2"},"text":"Pub. L. 115–271, § 7042(2)","children":[],"tail":", (3), added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
