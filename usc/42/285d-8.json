{"tag":"section","attrib":{"id":"idb57137fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d–8"},"text":"§ 285d–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile arthritis and related conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57137fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion and coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute, in coordination with the Director of the National Institute of Allergy and Infectious Diseases, shall expand and intensify the programs of such Institutes with respect to research and related activities concerning juvenile arthritis and related conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57137fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directors referred to in subsection (a) shall jointly coordinate the programs referred to in such subsection and consult with the Arthritis and Musculoskeletal Diseases Interagency Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57137ff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 442A, as added "},{"tag":"ref","attrib":{"href":"/us/p