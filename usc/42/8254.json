{"tag":"section","attrib":{"id":"idbe885599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254"},"text":null,"children":[{"tag":"num","attrib":{"value":"8254"},"text":"§ 8254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and use of life cycle cost methods and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe88559a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of life cycle cost methods and procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Director of the Office of Management and Budget, the Secretary of Defense, the Director of the National Institute of Standards and Technology, and the Administrator of the General Services Administration, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe88559b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish practical and effective present value methods for estimating and comparing life cycle costs for Federal buildings, using the sum of all capital and operating expenses associated with the energy system of the building involved over the expected life of such system or during a period of 40 years, whichever is shorter, and using average fuel costs and a discount rate determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88559c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and prescribe the procedures to be followed in applying and implementing the methods so established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe88559d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of life cycle cost methods and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe88559e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The design of new Federal buildings, and the application of energy conservation measures to existing Federal buildings, shall be made using life cycle cost methods and procedures established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88559f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In leasing buildings for its own use or that of another agency, each agency shall, after ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", fully consider the efficiency of all potential building space at the time of renewing or entering into a new lease."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8855a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8254/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use in non-Federal structures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available information to the public on the use of life cycle cost methods in the construction of buildings, structures, and facilities in all segments of the economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8855a1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s544"},"text":"Pub. L. 95–619, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3277"},"text":"92 Stat. 3277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/615/s2/a"},"text":"Pub. L. 100–615, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-05"},"text":"Nov. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3186"},"text":"102 Stat. 3186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s152/d"},"text":"Pub. L. 102–486, title I, § 152(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2845"},"text":"106 Stat. 2845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s441"},"text":"Pub. L. 110–140, title IV, § 441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1623"},"text":"121 Stat. 1623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8855a2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8855a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8855a4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" substituted “40” for “25”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s152/d/1"},"text":"Pub. L. 102–486, § 152(d)(1)","children":[],"tail":", substituted “National Institute of Standards and Technology” for “National Bureau of Standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/s152/d/2"},"text":"Pub. L. 102–486, § 152(d)(2)","children":[],"tail":", substituted “agency shall, after "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", fully consider the efficiency of all potential building space at the time of renewing or entering into a new lease.” for “agency shall give appropriate preference to buildings which minimize life cycle costs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/615"},"text":"Pub. L. 100–615","children":[],"tail":" amended section generally, substituting provisions relating to establishment and use of life cycle cost methods and procedures for provisions defining terms (1) Secretary, (2) life cycle cost, (3) preliminary energy audit, (4) energy survey, (5) Federal building, (6) construction, and (7) energy performance target."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe8855a5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe8855a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
