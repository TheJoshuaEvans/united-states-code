{"tag":"section","attrib":{"id":"idc00ab0a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b"},"text":null,"children":[{"tag":"num","attrib":{"value":"16298b"},"text":"§ 16298b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High efficiency turbines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab0a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for Fossil Energy (referred to in this section as the “Secretary”), shall establish a multiyear, multiphase program (referred to in this section as the “program”) of research, development, and technology demonstration to improve the efficiency of gas turbines used in power generation systems and aviation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support first-of-a-kind engineering and detailed gas turbine design for small-scale and utility-scale electric power generation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high temperature materials, including superalloys, coatings, and ceramics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved heat transfer capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing technology required to construct complex 3-dimensional geometry parts with improved aerodynamic capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combustion technology to produce higher firing temperature while lowering nitrogen oxide and carbon monoxide emissions per unit of output;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced controls and systems integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced high performance compressor technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validation facilities for the testing of components and subsystems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include technology demonstration through component testing, subscale testing, and full-scale testing in existing fleets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include field demonstrations of the developed technology elements to demonstrate technical and economic feasibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess overall combined cycle and simple cycle system performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase fuel flexibility by enabling gas turbines to operate with high proportions of, or pure, hydrogen or other renewable gas fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance foundational knowledge needed for low-emission combustion systems that can work in high-pressure, high-temperature environments required for high-efficiency cycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase operational flexibility by reducing turbine start-up times and improving the ability to accommodate flexible power demand; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any other elements necessary to achieve the goals described in subsection (c), as determined by the Secretary, in consultation with private industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in phase I, to develop a conceptual design of, and to develop and demonstrate the technology required for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab0ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advanced high efficiency gas turbines to achieve, on a lower heating value basis—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00ab0bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combined cycle efficiency of not less than 65 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00ab0bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a simple cycle efficiency of not less than 47 percent; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation gas turbines to achieve a 25 percent reduction in fuel burn by improving fuel efficiency to existing best-in-class turbo-fan engines; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in phase II, to develop a conceptual design of advanced high efficiency gas turbines that can achieve, on a lower heating value basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00ab0bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combined cycle efficiency of not less than 67 percent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00ab0c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a simple cycle efficiency of not less than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a goal described in paragraph (1) has been achieved, the Secretary, in consultation with private industry and the National Academy of Sciences, may develop additional goals or phases for advanced gas turbine research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab0c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance, including grants, to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall solicit proposals from industry, small businesses, universities, and other appropriate parties for conducting activities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting proposed projects to receive financial assistance under this subsection, the Secretary shall give special consideration to the extent to which the proposed project will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab0c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate the creation or increased retention of jobs in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab0c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and enhance technology leadership in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide financial assistance under this subsection on a competitive basis, with an emphasis on technical merit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab0c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance provided under this subsection shall be subject to the cost sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab0ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab0cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s969B"},"text":"Pub. L. 109–58, title IX, § 969B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4005/a"},"text":"Pub. L. 116–260, div. Z, title IV, § 4005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2542"},"text":"134 Stat. 2542","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
