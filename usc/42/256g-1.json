{"tag":"section","attrib":{"id":"idb5083c83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"256g–1"},"text":"§ 256g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program to increase access to dental health care services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5083c84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5083c85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to award grants to 15 eligible entities to enable such entities to establish a demonstration program to establish training programs to train, or to employ, alternative dental health care providers in order to increase access to dental health care services in rural and other underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative dental health care providers” includes community dental health coordinators, advance practice dental hygienists, independent dental hygienists, supervised dental hygienists, primary care physicians, dental therapists, dental health aides, and any other health professional that the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeframe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration projects funded under this section shall begin not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and shall conclude not later than 7 years after "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5083c89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5083c8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education, including a community college;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally qualified health center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Health Service facility or a tribe or tribal organization (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or county public health clinic, a health facility operated by an Indian tribe or tribal organization, or urban Indian organization providing dental services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public hospital or health system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be within a program accredited by the Commission on Dental Accreditation or within a dental education program in an accredited institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5083c93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant under this section shall be in an amount that is not less than $4,000,000 for the 5-year period during which the demonstration project ","children":[{"tag":"ref","attrib":{"idref":"fn002102"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002102"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “is” probably should appear."}],"tail":" being conducted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5083c94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursement of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5083c95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary may disperse to any entity receiving a grant under this section not more than 20 percent of the total funding awarded to such entity under such grant, for the purpose of enabling the entity to plan the demonstration project to be conducted under such grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5083c96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent disbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remaining amount of grant funds not dispersed under subparagraph (A) shall be dispersed such that not less than 15 percent of such remaining amount is dispersed each subsequent year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity receiving a grant under this section shall certify that it is in compliance with all applicable State licensing requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall contract with the Director of the Institute of Medicine to conduct a study of the demonstration programs conducted under this section that shall provide analysis, based upon quantitative and qualitative data, regarding access to dental health care in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification regarding dental health aide program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prohibit a dental health aide training program approved by the Indian Health Service from being eligible for a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5083c9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s256g–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5083c9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 340G–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5304"},"text":"Pub. L. 111–148, title V, § 5304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/621"},"text":"124 Stat. 621","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
