{"tag":"section","attrib":{"id":"idc08907b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251"},"text":null,"children":[{"tag":"num","attrib":{"value":"19251"},"text":"§ 19251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08907b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy, acting through the National Science and Technology Council, shall establish or designate an interagency working group to coordinate the activities specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group shall be composed of the following members (or their designees), who may be organized into subcommittees, as appropriate:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Economic Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other Federal officials as the Director of the Office of Science and Technology Policy considers appropriate, including members of the National Science and Technology Council Committee on Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group shall seek to ensure that the activities of different Federal agencies enhance and complement, but, as appropriate, do not duplicate, efforts being carried out by another Federal agency, with a focus on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The activities of the National Science Foundation Technology, Innovation, and Partnerships Directorate in the key technology focus areas, such as within the Regional Innovation Engines under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19108"},"text":"section 19108 of this title","children":[],"tail":" and test beds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s19110"},"text":"section 19110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The activities of the Department of Commerce under this division, including regional technology hubs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a"},"text":"section 3722a of title 15","children":[],"tail":", as added by section 10621, the Manufacturing USA Program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278s/b/1"},"text":"section 278s(b)(1) of title 15","children":[],"tail":", and the Hollings Manufacturing Extension Partnership ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"15 U.S.C. 278k","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The activities of the Department of Energy in the key technology focus areas, including at the national laboratories, and at Federal laboratories, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3703"},"text":"section 3703 of title 15","children":[],"tail":", and facilities and user facilities operated in partnership with such national laboratories or the Department of Energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other program that the Director of the Office of Science and Technology Policy determines involves research and development with respect to the key technology focus areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08907c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08907ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an initial review of Federal programs and resources with respect to the key technology focus areas identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19107/a/2"},"text":"section 19107(a)(2) of this title","children":[],"tail":", in order to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc08907cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess current level of efforts and characterize existing research infrastructure, as of the date of the review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential areas of overlap or duplication with respect to the key technology focus areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc08907cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential cross-agency collaborations and joint funding opportunities; and ","children":[{"tag":"ref","attrib":{"idref":"fn004403"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004403"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report regarding the review described in subparagraph (A) to Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08907cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek stakeholder input and recommendations in the course of such review; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08907d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ","children":[{"tag":"ref","attrib":{"idref":"fn004404"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004404"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “shall” probably should not appear."}],"tail":" carry out the annual reviews and updates required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s19107/e"},"text":"section 19107(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08907d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19251/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any conflicts between Federal agencies arise while carrying out the activities under this section, the President shall make the final decision regarding resolution of the conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08907d2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10651"},"text":"Pub. L. 117–167, div. B, title VI, § 10651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1682"},"text":"136 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc08907d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc08907d4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc08907d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This division, referred to in subsec. (c)(2), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1399"},"text":"136 Stat. 1399","children":[],"tail":", which enacted this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of div. B to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18901"},"text":"section 18901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10621, referred to in subsec. (c)(2), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10621"},"text":"section 10621 of Pub. L. 117–167","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
