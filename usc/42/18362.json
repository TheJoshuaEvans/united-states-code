{"tag":"section","attrib":{"id":"idc056fc1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18362"},"text":null,"children":[{"tag":"num","attrib":{"value":"18362"},"text":"§ 18362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement of Space Shuttle orbiters and transition of Space Shuttle program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc056fc1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall retire the Space Shuttle orbiters pursuant to a schedule established by the Administrator and in a manner consistent with provisions of this chapter regarding potential requirements for contingency utilization of Space Shuttle orbiters for ISS requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc056fc1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of workforce and assets in follow-on Space Launch System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc056fc1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of vehicle assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Administrator shall, to the maximum extent practicable, utilize workforce, assets, and infrastructure of the Space Shuttle program in efforts relating to the initiation of a follow-on Space Launch System developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18322"},"text":"section 18322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc056fc1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the workforce, assets, and infrastructure not utilized as described in paragraph (1), the Administrator shall work closely with other departments and agencies of the Federal Government, and the private sector, to divest unneeded assets and to assist displaced workers with retraining and other placement efforts. Amounts authorized to be appropriated by section 101(2)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn004355"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004355"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be available for activities pursuant to this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc056fc1f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tVI/s602"},"text":"Pub. L. 111–267, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2828"},"text":"124 Stat. 2828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc056fc20-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc056fc21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc056fc22-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101(2)(B), referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tI/s101/2/B"},"text":"Pub. L. 111–267, title I, § 101(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2809"},"text":"124 Stat. 2809","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
