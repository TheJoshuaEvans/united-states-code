{"tag":"section","attrib":{"id":"idc019089e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532"},"text":null,"children":[{"tag":"num","attrib":{"value":"16532"},"text":"§ 16532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear science talent expansion program for institutions of higher education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc019089f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the decline in the number of and resources available to nuclear science programs at institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number of graduates with degrees in nuclear science, an area of strategic importance to the economic competitiveness and energy security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of nuclear science","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “nuclear science” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear chemistry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio chemistry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health physics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, in accordance with this section, a program to expand and enhance institution of higher education nuclear science educational capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear science program expansion grants for institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award up to 3 competitive grants for each fiscal year to institutions of higher education that establish new academic degree programs in nuclear science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating grants under this subsection, the Secretary shall give priority to proposals that involve partnerships with a National Laboratory or other eligible nuclear-related entity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria for a grant awarded under this subsection shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential to attract new students to the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic rigor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to offer hands-on learning opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may be up to 5 years in duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $1,000,000 for each year of the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that receives a grant under this subsection may use the grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit and retain new faculty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop core and specialized course content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaboration between faculty and researchers in the nuclear science field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support outreach efforts to recruit students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear science competitiveness grants for institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award up to 5 competitive grants for each fiscal year to institutions of higher education with existing academic degree programs that produce graduates in nuclear science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Criteria for a grant awarded under this subsection shall be based on the potential for increasing the number and academic quality of graduates in the nuclear sciences who enter into careers in nuclear-related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection may be up to 5 years in duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education that receives a grant under this subsection shall be eligible for up to $500,000 for each year of the grant period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01908be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education that receives a grant under this subsection may use the grant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of graduates in nuclear science that enter into careers in the nuclear science field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the teaching of advanced nuclear technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggressively pursue collaboration opportunities with industry and National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bolster or sustain nuclear infrastructure and research facilities of the institution of higher education, such as research and training reactors or laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide tuition assistance and stipends to undergraduate and graduate students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01908c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01908c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear science program expansion grants for institutions of higher education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc01908c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,500,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,500,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16532/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,500,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc01908c9-3a70-11f1-ae07-e4213316