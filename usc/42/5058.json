{"tag":"section","attrib":{"id":"idbcf55a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5058"},"text":null,"children":[{"tag":"num","attrib":{"value":"5058"},"text":"§ 5058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no payment for supportive services or reimbursement of out-of-pocket expenses made to persons serving pursuant to subchapter II of this chapter shall be subject to any tax or charge or be treated as wages or compensation for the purposes of unemployment, temporary disability, retirement, public assistance, workers’ compensation, or similar benefit payments, or minimum wage laws. This section shall become effective with respect to all payments made after ","children":[{"tag":"date","attrib":{"date":"1973-10-01"},"text":"October 1, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcf55a18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tIV/s418"},"text":"Pub. L. 93–113, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/413"},"text":"87 Stat. 413","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/143/s18/a/2"},"text":"Pub. L. 96–143, § 18(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-13"},"text":"Dec. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1083"},"text":"93 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s24"},"text":"Pub. L. 98–288, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/196"},"text":"98 Stat. 196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf55a19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf55a1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf55a1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" inserted “workers’ compensation,” after “public assistance,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143"},"text":"Pub. L. 96–143","children":[],"tail":" substituted “subchapter II of this chapter” for “subchapters II and III of this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
