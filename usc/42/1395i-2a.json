{"tag":"section","attrib":{"id":"idb8a56088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395i–2a"},"text":"§ 1395i–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hospital insurance benefits for disabled individuals who have exhausted other entitlement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a56089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a5608a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained the age of 65;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a5608b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a5608c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been entitled to benefits under this part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"section 426(b) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5608d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a5608e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues to have the disabling physical or mental impairment on the basis of which the individual was found to be under a disability or to be a disabled qualified railroad retirement beneficiary, or (ii) is blind (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s416/i/1"},"text":"section 416(i)(1) of this title","children":[],"tail":"), but"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5608f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose entitlement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"section 426(b) of this title","children":[],"tail":" ends due solely to the individual having earnings that exceed the substantial gainful activity amount (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s423/d/4"},"text":"section 423(d)(4) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a56090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not otherwise entitled to benefits under this part,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be eligible to enroll in the insurance program established by this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a56091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a56092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual may enroll under this section only in such manner and form as may be prescribed in regulations, and only during an enrollment period prescribed in or under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a56093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual’s initial enrollment period shall begin with the month in which the individual receives notice that the individual’s entitlement to benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"section 426(b) of this title","children":[],"tail":" will end due solely to the individual having earnings that exceed the substantial gainful activity amount (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s423/d/4"},"text":"section 423(d)(4) of this title","children":[],"tail":" and shall end 7 months later."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a56094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be a general enrollment period during the period beginning on January 1 and ending on March 31 of each year (beginning with 1990).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a56095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a56096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period (in this subsection referred to as a “coverage period”) during which an individual is entitled to benefits under the insurance program under this part shall begin on whichever of the following is the latest:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a56097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who enrolls under subsection (b)(2) before the month in which the individual first satisfies subsection (a), the first day of such month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a56098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who enrolls under subsection (b)(2) in the month in which the individual first satisfies subsection (a), the first day of the month following the month in which the individual so enrolls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a56099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who enrolls under subsection (b)(2) in the month following the month in which the individual first satisfies subsection (a), the first day of the second month following the month in which the individual so enrolls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5609a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who enrolls under subsection (b)(2) more than one month following the month in which the individual first satisfies subsection (a), the first day of the third month following the month in which the individual so enrolls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5609b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an individual who enrolls under subsection (b)(3), the July 1 following the month in which the individual so enrolls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a5609c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual’s coverage period under this section shall continue until the individual’s enrollment is terminated as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a5609d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As of the month following the month in which the Secretary provides notice to the individual that the individual no longer meets the condition described in subsection (a)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5609e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As of the month following the month in which the individual files notice that the individual no longer wishes to participate in the insurance program established by this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a5609f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As of the month before the first month in which the individual becomes eligible for hospital insurance benefits under section 426(a) or 426–1 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a560a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As of a date, determined under regulations of the Secretary, for nonpayment of premiums.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The regulations under subparagraph (D) may provide a grace period of not longer than 90 days, which may be extended to not to exceed 180 days in any case where the Secretary determines that there was good cause for failure to pay the overdue premiums within such 90-day period. Termination of coverage under this section shall result in simultaneous termination of any coverage affected under any other part of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a560a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsections (h), (i), and (m) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395p"},"text":"section 1395p of this title","children":[],"tail":" apply to enrollment and nonenrollment under this section in the same manner as they apply to enrollment and nonenrollment and special enrollment periods under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–2"},"text":"section 1395i–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a560a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of premiums","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a560a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a560a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premiums for enrollment under this section shall be paid to the Secretary at such times, and in such manner, as the Secretary shall by regulations prescribe, and shall be deposited in the Treasury to the credit of the Federal Hospital Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a560a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a560a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clause (ii), such premiums shall be payable for the period commencing with the first month of an individual’s coverage period and ending with the month in which the individual dies or, if earlier, in which the individual’s coverage period terminates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a560a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such premiums shall not be payable for any month in which the individual is eligible for benefits under this part pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"section 426(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a560a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395i–2a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsections (d) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–2"},"text":"section 1395i–2 of this title","children":[],"tail":" (relating to premiums) shall apply to individuals enrolled under this section in the same manner as they apply to individuals enrolled under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a560a9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1818A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6012/a/2"},"text":"Pub. L. 101–239, title VI, § 6012(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2161"},"text":"103 Stat. 2161","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tIV/s4008/m/3/C"},"text":"Pub. L. 101–508, title IV, § 4008(m)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-54"},"text":"104 Stat. 1388–54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dCC/tI/s120/a/2/C/i"},"text":"Pub. L. 116–260, div. CC, title I, § 120(a)(2)(C)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2954"},"text":"134 Stat. 2954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a560aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a560ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a560ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “subsections (h), (i), and (m) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395p"},"text":"section 1395p of this title","children":[],"tail":"” for “subsections (h) and (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395p"},"text":"section 1395p of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4008/m/3/C/i"},"text":"Pub. L. 101–508, § 4008(m)(3)(C)(i)","children":[],"tail":", inserted “for enrollment under this section” after “Premiums”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s4008/m/3/C/ii"},"text":"Pub. L. 101–508, § 4008(m)(3)(C)(ii)","children":[],"tail":", struck out subpar. (C) which read as follows: “For purposes of applying "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r/g"},"text":"section 1395r(g) of this title","children":[],"tail":" and section 59B(f)(1)(B)(i) of the Internal Revenue Code of 1986, any reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–2"},"text":"section 1395i–2 of this title","children":[],"tail":" shall be deemed to include a reference to this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a560ad-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a560ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6012/b"},"text":"Pub. L. 101–239, title VI, § 6012(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2163"},"text":"103 Stat. 2163","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/tVI/s6012/b"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i–2"},"text":"section 1395i–2 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":"], but shall not apply so as to provide for coverage under part A of title XVIII of the Social Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.] for any month before July 1990.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
