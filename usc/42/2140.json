{"tag":"section","attrib":{"id":"idbbecc3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2140"},"text":null,"children":[{"tag":"num","attrib":{"value":"2140"},"text":"§ 2140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions from license requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be deemed—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbecc3c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a license for (1) the processing, fabricating, or refining of special nuclear material, or the separation of special nuclear material, or the separation of special nuclear material from other substances, under contract with and for the account of the Commission; or (2) the construction or operation of facilities under contract with and for the account of the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbecc3c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a license for the manufacture, production, or acquisition by the Department of Defense of any utilization facility authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2121"},"text":"section 2121 of this title","children":[],"tail":", or for the use of such facility by the Department of Defense or a contractor thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbecc3c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 110, as added "},{"tag":"ref",