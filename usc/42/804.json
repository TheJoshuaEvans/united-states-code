{"tag":"section","attrib":{"id":"idb7fe7254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804"},"text":null,"children":[{"tag":"num","attrib":{"value":"804"},"text":"§ 804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coronavirus capital projects fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fe7255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $10,000,000,000, to remain available until expended, for making payments to States, territories, and Tribal governments to carry out critical capital projects directly enabling work, education, and health monitoring, including remote options, in response to the public health emergency with respect to the Coronavirus Disease (COVID–19).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe7257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount appropriated under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fe7258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall pay $100,000,000 to each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe7259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall pay $100,000,000 of such amount in equal shares to the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, the Republic of the Marshall Islands, the Federated States of Micronesia, and the Republic of Palau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe725a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall pay $100,000,000 of such amount in equal shares to Tribal governments and the State of Hawaii (in addition to the amount paid to the State of Hawaii under subparagraph (A)), of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7fe725b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $50,000 shall be paid to each Tribal government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe725c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $50,000, and not more than $200,000, shall be paid to the State of Hawaii for the exclusive use of the Department of Hawaiian Home Lands and the Native Hawaiian Education Programs to assist Native Hawaiians in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe725d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fe725e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amount of the appropriation under subsection (a) that remains after the application of paragraph (1), the Secretary shall make payments to States based on population such that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7fe725f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of such amount shall be allocated among the States based on the proportion that the population of each State bears to the population of all States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe7260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of such amount shall be allocated among the States based on the proportion that the number of individuals living in rural areas in each State bears to the number of individuals living in rural areas in all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fe7261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of such amount shall be allocated among the States based on the proportion that the number of individuals with a household income that is below 150 percent of the poverty line applicable to a family of the size involved in each State bears to the number of such individuals in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fe7262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the allocations to be made to each State under subparagraph (A), the Secretary of the Treasury shall use the most recent data available from the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a process of applying for grants to access funding made available under section (b) not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fe7264-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fe7265-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7266-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, and Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fe7267-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s804/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal government” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s802/g"},"text":"section 802(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fe7268-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title VI, § 604, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9901/a"},"text":"Pub. L. 117–2, title IX, § 9901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/233"},"text":"135 Stat. 233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fe7269-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7fe726a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7fe726b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 804, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tVI/s604"},"text":"act Aug. 14, 1935, ch. 531, title VI, § 604","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tIII/s302"},"text":"Pub. L. 92–603, title III, § 302","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1484"},"text":"86 Stat. 1484","children":[],"tail":", which provided for notification to States and termination of payments in case of noncompliance with laws or State plan, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/93/647"},"text":"Pub. L. 93–647","children":[],"tail":", §§ 3(b), 7(b), "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2349"},"text":"88 Stat. 2349","children":[],"tail":", 2351."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
