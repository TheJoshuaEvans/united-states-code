{"tag":"section","attrib":{"id":"idb51dc116-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s270"},"text":null,"children":[{"tag":"num","attrib":{"value":"270"},"text":"§ 270.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarantine regulations governing civil air navigation and civil aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Surgeon General is authorized to provide by regulations for the application to air navigation and aircraft of any of the provisions of sections 267 to 269 of this title and regulations prescribed thereunder (including penalties and forfeitures for violations of such sections and regulations), to such extent and upon such conditions as he deems necessary for the safeguarding of the public health.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb51dc117-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 367, "},{"tag":"ref","attrib":{"href":"/us/stat/58/706"},"text":"58 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51dc118-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb51dc119-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb51dc11a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb51dc11b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb51dc11c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Surgeon General abolished by section 3 of Reorg. Plan No. 3 of 1966, eff. ","children":[{"tag":"date","attrib":{"date":"1966-06-25"},"text":"June 25, 1966","children":[],"tail":", 31 F.R. 8855, "},{"tag":"ref","attrib":{"href":"/us/stat/80/1610"},"text":"80 Stat. 1610","children":[],"tail":", and functions thereof transferred to Secretary of Health, Education, and Welfare by section 1 of Reorg. Plan No. 3 of 1966, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"section 202 of this title","children":[],"tail":". Office of Surgeon General reestablished within the Office of the Assistant Secretary for Health, see Notice of Department of Health and Human Services, Office of the Assistant Secretary for Health, "},{"tag":"date","attrib":{"date":"1987-03-30"},"text":"Mar. 30, 1987","children":[],"tail":", 52 F.R. 11754."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
