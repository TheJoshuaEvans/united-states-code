{"tag":"section","attrib":{"id":"idbcebe412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4958"},"text":null,"children":[{"tag":"num","attrib":{"value":"4958"},"text":"§ 4958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on funds appropriated for grants and contracts for direct cost of supporting volunteers in programs or projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcebe413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of funds appropriated for the purpose of this part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5081"},"text":"section 5081 of this title","children":[],"tail":", not more than 30 percent for the fiscal year ending "},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":", and for each fiscal year thereafter, may be obligated for the direct cost of supporting volunteers in programs or projects carried out pursuant to grants and contracts made under section 5042(12) "},{"tag":"ref","attrib":{"idref":"fn003381"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003381"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebe414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No funds shall be obligated under this part pursuant to grants or contracts made after ","children":[{"tag":"date","attrib":{"date":"1979-12-13"},"text":"December 13, 1979","children":[],"tail":", for new projects for the direct cost of supporting volunteers unless the recipient of each such grant or contract has been selected through a competitive process which includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcebe415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4958/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public announcements of the availability of funds for such grants or contracts, general criteria for the selection of new recipients, and a description of the application process and the application review process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebe416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4958/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that each applicant for any such grant or contract identify, with sufficient particularity to assure that the assignments of volunteers under such grants and contracts will carry out the purpose of this part, the particular poverty or poverty-related problems on which the grant or contract will focus, and any such grant or contract shall specifically so identify such problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcebe417-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s108"},"text":"Pub. L. 93–113, title I, § 108","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/293/s4/a/1"},"text":"Pub. L. 94–293, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-27"},"text":"May 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/525"},"text":"90 Stat. 525","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/143/s4"},"text":"Pub. L. 96–143, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-13"},"text":"Dec. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1075"},"text":"93 Stat. 1075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s8"},"text":"Pub. L. 98–288, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/191"},"text":"98 Stat. 191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tVII/s703"},"text":"Pub. L. 101–204, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1821"},"text":"103 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebe418-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebe419-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcebe41a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5042"},"text":"Section 5042 of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII/s203/b"},"text":"Pub. L. 103–82, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/892"},"text":"107 Stat. 892","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebe41b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" substituted “30 percent” for “16 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288/s8/1"},"text":"Pub. L. 98–288, § 8(1)","children":[],"tail":", (2), substituted “1984” for “1977”, and struck out “During the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"—(1) in no event may in excess of $5,800,000 be used pursuant to grants and contracts under this part for the direct cost of supporting such volunteers; and (2) funds obligated pursuant to such grants and contracts for such cost may be used to support no greater number of years of volunteer service than the number of such years supported during the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", pursuant to grants and contracts for such cost.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288/s8/3"},"text":"Pub. L. 98–288, § 8(3)","children":[],"tail":", struck out “human, social, or environmental” after “poverty-related”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143/s4"},"text":"Pub. L. 96–143, § 4","children":[],"tail":", designated existing provisions as subsec. (a) and, in subsec. (a) as so designated, substituted “16” for “20”, inserted “During the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"”, and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/143/s4/b"},"text":"Pub. L. 96–143, § 4(b)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcebe41c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcebe41d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/293/s4/c"},"text":"Pub. L. 94–293, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-27"},"text":"May 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/526"},"text":"90 Stat. 526","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/293/s4/c"},"text":"“The amendments made by subsection (a) and subsection (b) of this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5042"},"text":"section 5042 of this title","children":[],"tail":"] shall be effective on "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", and shall not apply to any agreement for the assignment of volunteers entered into before such date during the period of any such agreement.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
