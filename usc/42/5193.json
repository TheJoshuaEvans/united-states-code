{"tag":"section","attrib":{"id":"idbd206270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193"},"text":null,"children":[{"tag":"num","attrib":{"value":"5193"},"text":"§ 5193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd206271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share for assistance provided under this subchapter shall be equal to not less than 75 percent of the eligible costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd206272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on amount of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd206273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), total assistance provided under this subchapter for a single emergency shall not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitation described in paragraph (1) may be exceeded when the President determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd206275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued emergency assistance is immediately required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a continuing and immediate risk to lives, property, public health or safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd206277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary assistance will not otherwise be provided on a timely basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd206278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5193/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the limitation described in paragraph (1) is exceeded, the President shall report to the Congress on the nature and extent of emergency assistance requirements and shall propose additional legislation if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd206279-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tV/s503"},"text":"Pub. L. 93–288, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s107/a"},"text":"Pub. L. 100–707, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4707"},"text":"102 Stat. 4707","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
