ended "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV"},"text":"Pub. L. 99–570, title IV","children":[],"tail":", §§ 4004(a), 4007, "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-109"},"text":"100 Stat. 3207–109","children":[],"tail":", 3207–115, which related to peer review of biomedical and behavioral research and development grants, was renumbered section 504 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–3"},"text":"section 290aa–3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 506 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s224"},"text":"section 224 of this title","children":[],"tail":", was successively renumbered by subsequent acts, and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238c"},"text":"section 238c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb59e8a22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “2023 through 2027” for “2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/1"},"text":"Pub. L. 114–255, § 9001(1)","children":[],"tail":", substituted “substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/2/A"},"text":"Pub. L. 114–255, § 9001(2)(A)","children":[],"tail":", substituted “substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/2/B"},"text":"Pub. L. 114–255, § 9001(2)(B)","children":[],"tail":", substituted “a substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/3/A"},"text":"Pub. L. 114–255, § 9001(3)(A)","children":[],"tail":", substituted “substance use disorder” for “substance abuse disorder”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/3/B/i"},"text":"Pub. L. 114–255, § 9001(3)(B)(i)","children":[],"tail":", substituted “a substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/3/B/ii"},"text":"Pub. L. 114–255, § 9001(3)(B)(ii)","children":[],"tail":", substituted “substance use disorder” for “substance abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9001/4"},"text":"Pub. L. 114–255, § 9001(4)","children":[],"tail":", substituted “$41,304,000 for each of fiscal years 2018 through 2022” for “, $50,000,000 for fiscal year 2001, and such sums as may be necessary for each of the fiscal years 2002 and 2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" amended section catchline and text generally, substituting present provisions for provisions, in subsec. (a), authorizing Secretary to make grants for benefit of homeless individuals through the Administrator of Substance Abuse and Mental Health Services Administration, in subsec. (b), relating to preferences for grants to entities providing integrated primary health, substance abuse, and mental health services, in subsec. (c), relating to services for certain individuals, in subsec. (d), relating to 5-year grants with renewals, and in subsec. (e), authorizing appropriations for fiscal years 1993 and 1994."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/400"},"text":"Pub. L. 106–400","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11311"},"text":"section 11311 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" amended section generally, substituting provisions relating to grants for benefit of homeless individuals for provisions relating to alcohol abuse and alcoholism demonstration projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":" added subsec. (c), redesignated former subsec. (c) as (d), and substituted “subsection (a) or (c)” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb59e8a23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb59e8a24-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interagency Council on the Homeless changed to United States Interagency Council on Homelessness by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dG/tII/s216"},"text":"Pub. L. 108–199, div. G, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/394"},"text":"118 Stat. 394","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb59e8a25-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
