{"tag":"section","attrib":{"id":"idb59e8a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–5"},"text":"§ 290aa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for the benefit of homeless individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59e8a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants, contracts and cooperative agreements to community-based public and private nonprofit entities for the purposes of providing mental health and substance use disorder services for homeless individuals. In carrying out this section, the Secretary shall consult with the Interagency Council on the Homeless ","children":[{"tag":"ref","attrib":{"idref":"fn002220"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002220"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":", established under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11311"},"text":"section 11311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e8a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, and cooperative agreements under subsection (a), the Secretary shall give a preference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59e8a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that provide integrated primary health, substance use disorder, and mental health services to homeless individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that demonstrate effectiveness in serving runaway, homeless, and street youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that have experience in providing substance use disorder and mental health services to homeless individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that demonstrate experience in providing housing for individuals in treatment for or in recovery from mental illness or a substance use disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities that demonstrate effectiveness in serving homeless veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e8a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for certain individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants, contracts, and cooperative agreements under subsection (a), the Secretary shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59e8a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the provision of services under such subsection to homeless individuals who are suffering from a substance use disorder and are not suffering from a mental health disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59e8a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make payments under subsection (a) to any entity that has a policy of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59e8a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluding individuals from mental health services due to the existence or suspicion of a substance use disorder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59e8a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a policy of excluding individuals from substance use disorder services due to the existence or suspicion of mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e8a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of the awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No entity may receive a grant, contract, or cooperative agreement under subsection (a) for more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59e8a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $41,304,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb59e8a1d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 506, formerly § 512, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/509/tII/s206/a"},"text":"Pub. L. 98–509, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2361"},"text":"98 Stat. 2361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s613/a"},"text":"Pub. L. 100–77, title VI, § 613(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/524"},"text":"101 Stat. 524","children":[],"tail":"; renumbered § 506 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s106"},"text":"Pub. L. 102–321, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/334"},"text":"106 Stat. 334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3202"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1190"},"text":"114 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9001"},"text":"Pub. L. 114–255, div. B, title IX, § 9001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1234"},"text":"130 Stat. 1234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1211"},"text":"Pub. L. 117–328, div. FF, title I, § 1211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5661"},"text":"136 Stat. 5661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote