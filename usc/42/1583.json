{"tag":"section","attrib":{"id":"idbb350c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1583"},"text":null,"children":[{"tag":"num","attrib":{"value":"1583"},"text":"§ 1583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redetermination of demountable housing as temporary or permanent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any housing classified, prior to ","children":[{"tag":"date","attrib":{"date":"1950-04-20"},"text":"April 20, 1950","children":[],"tail":", by the Secretary of Housing and Urban Development as demountable, the Secretary of Housing and Urban Development shall, as soon as practicable but not later in any event than "},{"tag":"date","attrib":{"date":"1950-12-31"},"text":"December 31, 1950","children":[],"tail":", and after consultation with the communities affected, redetermine (taking into consideration local standards and conditions) whether such housing is of a temporary or permanent character, and after such redetermination shall dispose of such housing in accordance with the provisions of this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb350c24-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-28/ch688/s7"},"text":"June 28, 1948, ch. 688, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-04-20/ch94"},"text":"Apr. 20, 1950, ch. 94","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/64/59"},"text":"64 Stat. 59","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb350c25-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb350c26-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb350c27-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
