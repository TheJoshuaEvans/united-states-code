{"tag":"section","attrib":{"id":"idbc31e261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991g"},"text":"§ 2991g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc31e262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency which receives financial assistance under this subchapter shall keep such records as the Commissioner may prescribe, including records which fully disclose the amount and disposition by that agency of such financial assistance, the total cost of the project in connection with which such financial assistance is given or used, the amount of that portion of the cost of the project supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e263-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of any agency which receives financial assistance under this subchapter that are pertinent to the financial assistance received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e264-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s809"},"text":"Pub. L. 88–452, title VIII, § 809","children":[],"tail":", formerly § 808, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2325"},"text":"88 Stat. 2325","children":[],"tail":"; renumbered § 809, "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV/s502/3"},"text":"Pub. L. 100–175, title V, § 502(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/973"},"text":"101 Stat. 973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/9"},"text":"Pub. L. 102–375, title VIII, § 822(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1298"},"text":"106 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e265-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc31e266-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc31e267-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/s809"},"text":"section 809 of Pub. L. 88–452","children":[],"tail":" was renumbered section 810 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2991h"},"text":"section 2991h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc31e268-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":" substituted “Commissioner” for “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
