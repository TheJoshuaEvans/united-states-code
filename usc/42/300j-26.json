{"tag":"section","attrib":{"id":"idb64f1467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–26"},"text":"§ 300j–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of testing laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall assure that programs for the certification of testing laboratories which test drinking water supplies for lead contamination certify only those laboratories which provide reliable accurate testing. The Administrator (or the State in the case of a State to which certification authority is delegated under this subsection) shall publish and make available to the public upon request the list of laboratories certified under this subsection.","children":[{"tag":"ref","attrib":{"idref":"fn002354"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002354"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section.”"}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb64f1468-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/572/s4"},"text":"Pub. L. 100–572, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2889"},"text":"102 Stat. 2889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb64f1469-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb64f146a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb64f146b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Lead Contamination Control Act of 1988, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
