{"tag":"section","attrib":{"id":"idbaad3ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397l"},"text":"§ 1397l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and support of elder abuse, neglect, and exploitation forensic centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Attorney General, shall make grants to eligible entities to establish and operate stationary and mobile forensic centers, to develop forensic expertise regarding, and provide services relating to, elder abuse, neglect, and exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stationary forensic centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make 4 of the grants described in subsection (a) to institutions of higher education with demonstrated expertise in forensics or commitment to preventing or treating elder abuse, neglect, or exploitation, to establish and operate stationary forensic centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ee4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mobile centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make 6 of the grants described in subsection (a) to appropriate entities to establish and operate mobile forensic centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ee5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3ee6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of forensic markers and methodologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall use funds made available through the grant to assist in determining whether abuse, neglect, or exploitation occurred and whether a crime was committed and to conduct research to describe and disseminate information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forensic markers that indicate a case in which elder abuse, neglect, or exploitation may have occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methodologies for determining, in such a case, when and how health care, emergency service, social and protective services, and legal service providers should intervene and when the providers should report the case to law enforcement authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of forensic expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section shall use funds made available through the grant to develop forensic expertise regarding elder abuse, neglect, and exploitation in order to provide medical and forensic evaluation, therapeutic intervention, victim support and advocacy, case review, and case tracking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Attorney General, shall use data made available by grant recipients under this section to develop the capacity of geriatric health care professionals and law enforcement to collect forensic evidence, including collecting forensic evidence relating to a potential determination of elder abuse, neglect, or exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2011, $4,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2012, $6,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397l/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2013 and 2014, $8,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3ef0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2031, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/790"},"text":"124 Stat. 790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
