{"tag":"section","attrib":{"id":"idb42cf8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s217b"},"text":null,"children":[{"tag":"num","attrib":{"value":"217b"},"text":"§ 217b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to regulations, volunteer and uncompensated services may be accepted by the Secretary, or by any other officer or employee of the Department of Health and Human Services designated by him, for use in the operation of any health care facility or in the provision of health care.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb42cf8ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 223, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/174/s6"},"text":"Pub. L. 90–174, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-05"},"text":"Dec. 5, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/539"},"text":"81 Stat. 539","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2008/h"},"text":"Pub. L. 103–43, title XX, § 2008(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/212"},"text":"107 Stat. 212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb42cf8ae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb42cf8af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"