{"tag":"section","attrib":{"id":"idbe64a1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7651l"},"text":null,"children":[{"tag":"num","attrib":{"value":"7651l"},"text":"§ 7651l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General compliance with other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as expressly provided, compliance with the requirements of this subchapter shall not exempt or exclude the owner or operator of any source subject to this subchapter from compliance with any other applicable requirements of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe64a1a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title IV, § 413, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tIV/s401"},"text":"Pub. L. 101–549, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2625"},"text":"104 Stat. 2625","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
