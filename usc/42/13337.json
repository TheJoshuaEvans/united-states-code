{"tag":"section","attrib":{"id":"idbfbbf48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337"},"text":null,"children":[{"tag":"num","attrib":{"value":"13337"},"text":"§ 13337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metallurgical coal development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfbbf48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish a research, development, demonstration, and commercial application program on metallurgical coal utilization for the purpose of developing techniques that will lead to the greater and more efficient utilization of the Nation’s metallurgical coal resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfbbf48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The program referred to in subsection (a) shall include the use of metallurgical coal—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a boiler fuel for the purpose of generating steam to produce electricity, including blending metallurgical coal with other coals in order to enhance its efficient application as a boiler fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an ingredient in the manufacturing of steel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13337/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a source of pipeline quality coalbed methane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf490-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1307"},"text":"Pub. L. 102–486, title XIII, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2975"},"text":"106 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
