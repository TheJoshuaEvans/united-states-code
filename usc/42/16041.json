{"tag":"section","attrib":{"id":"idbff07154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041"},"text":null,"children":[{"tag":"num","attrib":{"value":"16041"},"text":"§ 16041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear facility and materials security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff07155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (2) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal security coordinators","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Nuclear Regulatory Commission (referred to in this section as the “Commission”) shall assign a Federal security coordinator, under the employment of the Commission, to each region of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal security coordinator shall be responsible for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff0715a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicating with the Commission and other Federal, State, and local authorities concerning threats, including threats against such classes of facilities as the Commission determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0715b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring such classes of facilities as the Commission determines to be appropriate to ensure that they maintain security consistent with the security plan in accordance with the appropriate threat level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0715c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the coordination of security measures among the private security forces at such classes of facilities as the Commission determines to be appropriate and Federal, State, and local authorities, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0715d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Backup power for certain emergency notification systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any licensed nuclear power plants located where there is a permanent population, as determined by the 2000 decennial census, in excess of 15,000,000 within a 50-mile radius of the power plant, not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission shall require that backup power to be available for the emergency notification system of the power plant, including the emergency siren warning system, if the alternating current supply within the 10-mile emergency planning zone of the power plant is lost."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0715e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (d) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0715f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulations; waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (3) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Commission, after consultation with States and other stakeholders, shall issue final regulations establishing such requirements as the Commission determines to be necessary to carry out this section and the amendments made by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations shall include a definition of the term “discrete source” for purposes of paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating regulations under paragraph (1),","children":[{"tag":"ref","attrib":{"idref":"fn004203"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004203"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparagraph (A),”."}],"tail":" the Commission shall, to the maximum extent practicable—"}],"tail":null},{"tag":"clause","attrib":{"id":"idbff07166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use model State standards in existence on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of byproduct material","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “byproduct material” has the meaning given the term in paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0716a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To facilitate an orderly transition of regulatory authority with respect to byproduct material, the Commission, in issuing regulations under subparagraph (A), shall prepare and publish a transition plan for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff0716b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that have not, before the date on which the plan is published, entered into an agreement with the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021/b"},"text":"section 2021(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0716c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that have entered into an agreement with the Commission under that section before the date on which the plan is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0716d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The transition plan under clause (ii) shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff0716e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the conditions under which a State may exercise authority over byproduct material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0716f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of the Commission that any agreement covering byproduct material, as defined in paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":", entered into between the Commission and a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021/b"},"text":"section 2021(b) of this title","children":[],"tail":" before the date of publication of the transition plan shall be considered to include byproduct material, as defined in paragraph (3) or (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":", if the Governor of the State certifies to the Commission on the date of publication of the transition plan that—"}],"tail":null},{"tag":"item","attrib":{"id":"idbff07170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has a program for licensing byproduct material, as defined in paragraph (3) or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":", that is adequate to protect the public health and safety, as determined by the Commission; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbff07171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/C/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State intends to continue to implement the regulatory responsibility of the State with respect to the byproduct material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of radiopharmaceuticals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating regulations under subparagraph (A), the Commission shall consider the impact on the availability of radiopharmaceuticals to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physicians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patients the medical treatment of which relies on radiopharmaceuticals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07175-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07176-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Commission may grant a waiver to any entity of any requirement under this section or an amendment made by this section with respect to a matter relating to byproduct material (as defined in paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":") if the Commission determines that the waiver is in accordance with the protection of the public health and safety and the promotion of the common defense and security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07177-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07178-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may not grant a waiver under subparagraph (A) with respect to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff07179-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement under the amendments made by subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0717a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter relating to an importation into, or exportation from, the United States for a period ending after the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0717b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter for a period ending after the date that is 4 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff0717c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall terminate any waiver granted to a State under subparagraph (A) if the Commission determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff0717d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has entered into an agreement with the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021/b"},"text":"section 2021(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0717e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement described in subclause (I) covers byproduct material (as described in paragraph (3) or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0717f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16041/e/5/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program of the State for licensing such byproduct material is adequate to protect the public health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07180-3a70-11f1-ae07-e4213316b5f