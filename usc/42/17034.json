{"tag":"section","attrib":{"id":"idc0203538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034"},"text":null,"children":[{"tag":"num","attrib":{"value":"17034"},"text":"§ 17034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cellulosic ethanol and biofuels research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc020353a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an 1890 Institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"section 7601 of title 7","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020353b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part B institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":") (commonly referred to as “Historically Black Colleges and Universities”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020353c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal college or university (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020353d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Hispanic-serving institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a"},"text":"section 1101a(a) of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020353e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make cellulosic ethanol and biofuels research and development grants to 10 eligible entities selected by the Secretary to receive a grant under this section through a peer-reviewed competitive process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc020353f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that is selected to receive a grant under subsection (b) shall collaborate with 1 of the Bioenergy Research Centers of the Office of Science of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to make grants described in subsection (b) $50,000,000 for fiscal year 2008, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0203541-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s230"},"text":"Pub. L. 110–140, title II, § 230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1536"},"text":"121 Stat. 1536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0203542-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0203543-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0203544-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
