{"tag":"section","attrib":{"id":"idb52031b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b"},"text":null,"children":[{"tag":"num","attrib":{"value":"274b"},"text":"§ 274b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions respecting grants and contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52031b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made under this part or contract entered into under section 274 or 274a of this title unless an application therefor has been submitted to, and approved by, the Secretary. Such an application shall be in such form and shall be submitted in such manner as the Secretary shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52031b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special considerations and priority; planning and establishment grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52031b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A grant for planning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s273/a/1"},"text":"section 273(a)(1) of this title","children":[],"tail":" may be made for one year with respect to any organ procurement organization and may not exceed $100,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52031b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s273/a/2"},"text":"section 273(a)(2) of this title","children":[],"tail":" may be made for two years. No such grant may exceed $500,000 for any year and no organ procurement organization may receive more than $800,000 for initial operation or expansion."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52031b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants or contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s273/a/3"},"text":"section 273(a)(3) of this title","children":[],"tail":" may be made for not more than 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52031ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of grant amount; terms of payment; recordkeeping; access for purposes of audits and examination of records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5227bab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine the amount of a grant or contract made under section 273 or 274a of this title. Payments under such grants and contracts may be made in advance on the basis of estimates or by the way of reimbursement, with necessary adjustments on account of underpayments or overpayments, and in such installments and on such terms and conditions as the Secretary finds necessary to carry out the purposes of such grants and contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5227bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each recipient of a grant or contract under section 273, 274, or 274a of this title shall keep such records as the Secretary shall prescribe, including records which fully disclose the amount and disposition by such recipient of the proceeds of such grant or contract, the total cost of the undertaking in connection with which such grant or contract was made, and the amount of that portion of the cost of the undertaking supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5227bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access for the purpose of audit and examination to any books, documents, papers, and records of the recipient of a grant or contract under section 273, 274, or 274a of this title that are pertinent to such grant or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Transplant center” and “organ” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5227bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “transplant center” means a health care facility in which transplants of organs are performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “organ” means the human kidney, liver, heart, lung, pancreas, and any other human organ (other than corneas and eyes) specified by the Secretary by regulation and for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274a"},"text":"section 274a of this title","children":[],"tail":", such term includes bone marrow."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5227bb2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 374, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/507/tII/s201"},"text":"Pub. L. 98–507, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2345"},"text":"98 Stat. 2345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tIV/s402/b"},"text":"Pub. L. 100–607, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3114"},"text":"102 Stat. 3114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/616/tII/s203"},"text":"Pub. L. 101–616, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3284"},"text":"104 Stat. 3284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/14/s3/2"},"text":"Pub. L. 118–14, § 3(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-22"},"text":"Sept. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/69"},"text":"137 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5227bb3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5227bb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5227bb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 374 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", added by "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch907/s1"},"text":"act Aug. 3, 1956, ch. 907, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/961"},"text":"70 Stat. 961","children":[],"tail":", which related to acceptance and administration of gifts to National Library of Medicine and to establishment of memorials to donors, was renumbered section 384 and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s278"},"text":"section 278 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/b"},"text":"Pub. L. 99–158, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/879"},"text":"99 Stat. 879","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5227bb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/14"},"text":"Pub. L. 118–14","children":[],"tail":" substituted “section 273, 274, or 274a” for “section 273 or 274a” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/616/s203/1"},"text":"Pub. L. 101–616, § 203(1)","children":[],"tail":", substituted “No grant may be made under this part” for “No grant may be made under section 273 or 274a of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/616/s203/2"},"text":"Pub. L. 101–616, § 203(2)","children":[],"tail":", redesignated par. (2) as (1) and substituted “section 273(a)(1)” for “section 273”, struck out former par. (1) which set forth factors in considering applications for section 273 grants, redesignated par. (3) as (2) and substituted “section 273(a)(2)” for “paragraphs (2) and (3) of section 273(a)”, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/616/s203/3"},"text":"Pub. L. 101–616, § 203(3)","children":[],"tail":", inserted “or contract” after “grant” wherever appearing and “and contracts” after “grants” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" substituted “paragraphs (2) and (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s273/a"},"text":"section 273(a) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s273"},"text":"section 273 of this title","children":[],"tail":" for the establishment, initial operation, or expansion of organ procurement organizations”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
