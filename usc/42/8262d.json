{"tag":"section","attrib":{"id":"idbe8ac7c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262d"},"text":null,"children":[{"tag":"num","attrib":{"value":"8262d"},"text":"§ 8262d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy audit teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe8ac7c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assemble from existing personnel with appropriate expertise, and with particular utilization of the national laboratories, and make available to all Federal agencies, one or more energy audit teams which shall be equipped with instruments and other advanced equipment needed to perform energy audits of Federal facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe8ac7ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8262d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall also assist in establishing, at each site that has utilized an energy audit team, a program for monitoring the implementation of energy efficiency improvements based upon energy audit team recommendations, and for recording the operating history of such improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8ac7cb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s158"},"text":"Pub. L. 102–486, title I, § 158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2857"},"text":"106 Stat. 2857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8ac7cc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8ac7cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8ac7ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
