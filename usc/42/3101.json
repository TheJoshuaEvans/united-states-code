{"tag":"section","attrib":{"id":"idbc6d8cc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3101"},"text":null,"children":[{"tag":"num","attrib":{"value":"3101"},"text":"§ 3101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to assist and encourage the communities of the Nation fully to meet the needs of their citizens by making it possible, with Federal grant assistance, for their governmental bodies (1) to construct adequate basic water and sewer facilities needed to promote the efficient and orderly growth and development of our communities, (2) to construct neighborhood facilities needed to enable them to carry on programs of necessary social services, and (3) to acquire, in a planned and orderly fashion, land to be utilized in the future for public purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc6d8cc3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/117/tVII/s701"},"text":"Pub. L. 89–117, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/489"},"text":"79 Stat. 489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/tVI/s603/a"},"text":"Pub. L. 90–448, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/533"},"text":"82 Stat. 533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6d8cc4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6d8cc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc6d8cc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448"},"text":"Pub. L. 90–448","children":[],"tail":" substituted “in the future for public purposes” for “in connection with the future construction of public works and facilities” in cl. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc6d8cc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbc6d8cc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/431/s1"},"text":"Pub. L. 91–431, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-06"},"text":"Oct. 6, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/886"},"text":"84 Stat. 886","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/431/s1"},"text":"“That this Act [amending sections 3102 and 3108 of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3108"},"text":"section 3108 of this title","children":[],"tail":"] may be cited as the ‘Emergency Community Facilities Act of 1970’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
