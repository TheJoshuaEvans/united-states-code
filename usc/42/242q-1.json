{"tag":"section","attrib":{"id":"idb495cba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"242q–1"},"text":"§ 242q–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb495cbaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb495cbab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Surgeon General of the Public Health Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Planning and Evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute on Aging, and the Directors of such other agencies of the National Institutes of Health as the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of the Administration on Aging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Food and Drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Health of the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the the ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Substance Abuse and Mental Health Services Administration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Social Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Agency for Healthcare Research and Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two Members of the House of Representatives appointed by the Speaker of the House in consultation with the Minority Leader, and two members of the Senate appointed by the Majority Leader in consultation with the Minority Leader, not more than one of whom from each body shall be members of the same political party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" three members of the general public, to be appointed by the Secretary, that shall include one representative each from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb495cbb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit group representing older Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb495cbb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private voluntary health organization concerned with the health problems affecting older Americans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb495cbba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/a/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization concerned with research related to the health and independence of older Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cbbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through either the Assistant Secretary for Health or the Director of the National Institute on Aging, shall serve as the Chair of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cbbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Task Force shall constitute a quorum, and a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cbbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall meet periodically at the call of the Chair, but in no event less than twice each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb495cbbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb495cbbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Task Force who are not regular full-time employees of the United States Government shall, while attending meetings and conferences of the Task Force or otherwise engaged in the business of the Task Force (including traveltime), be entitled to receive compensation at a rate fixed by the Secretary, but not exceeding the rate specified at the time of such service under GS–18 of the General Schedules established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb495cbc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s242q–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business on the business of the Task Force, members of such Task Force may be allowed travel expenses, including per diem in lieu of subsistence, as is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons employed intermittently in the Government service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb495cbc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/557/tIII/s302"},"text":"Pub. L. 101–557, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2769"},"text":"104 Stat. 2769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s161"},"text":"Pub. L. 102–321, title I, § 161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/375"},"text":"106 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/405/tIII/s302/e/1"},"text":"Pub. L. 102–405, title III, § 302(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1985"},"text":"106 Stat. 1985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/b/2"},"text":"Pub. L. 106–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/e/6/D"},"text":"Pub. L. 108–173, title IX, § 900(e)(6)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2373"},"text":"117 Stat. 2373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb495cbc2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb495cbc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb495cbc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Home Health Care and Alzheimer’s Disease Amendments of 1990, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb495cbc5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":" substituted “Director of the Agency for Healthcare Research and Quality” for “Administrator for Health Care Policy and Research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/405"},"text":"Pub. L. 102–405","children":[],"tail":" substituted “Under Secretary for Health of the Department of Veterans Affairs” for “Chief Medical Director of the Department of Veterans Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" substituted “Substance Abuse and Mental Health Services Administration” for “Alcohol, Drug Abuse and Mental Health Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb495cbc6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb495cbc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb495cbc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
