{"tag":"section","attrib":{"id":"idbd1df04b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5185"},"text":null,"children":[{"tag":"num","attrib":{"value":"5185"},"text":"§ 5185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency communications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized during, or in anticipation of, an emergency or major disaster to establish temporary communications systems and to make such communications available to State and local government officials and other persons as he deems appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd1df04c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s418"},"text":"Pub. L. 93–288, title IV, § 418","children":[],"tail":", formerly § 415, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/158"},"text":"88 Stat. 158","children":[],"tail":"; renumbered § 418, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/j"},"text":"Pub. L. 100–707, title I, § 106(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df04d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df04e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd1df04f-3a70-11f1-ae07-e4213316b5fa"},"text":n