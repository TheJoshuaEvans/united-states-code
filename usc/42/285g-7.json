{"tag":"section","attrib":{"id":"idb575f333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"285g–7"},"text":"§ 285g–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child health research centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall develop and support centers for conducting research with respect to child health. Such centers shall give priority to the expeditious transfer of advances from basic science to clinical applications and improving the care of infants and children.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f334-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 452C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tX/s1021"},"text":"Pub. L. 103–43, title X, § 1021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/167"},"text":"107 Stat. 167","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
