{"tag":"section","attrib":{"id":"idbfb00d0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13109"},"text":null,"children":[{"tag":"num","attrib":{"value":"13109"},"text":"§ 13109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator $8,000,000 for each of the fiscal years 1991, 1992, and 1993 for functions carried out under this chapter (other than State Grants),","children":[{"tag":"ref","attrib":{"idref":"fn004151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" and $8,000,000 for each of the fiscal years 1991, 1992, and 1993, for grant programs to States issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13104"},"text":"section 13104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfb00d0f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVI/s6610"},"text":"Pub. L. 101–508, title VI, § 6610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-327"},"text":"104 Stat. 1388–327","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
