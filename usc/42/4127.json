":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/377"},"text":"Pub. L. 106–377","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"September 30, 2000","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/74"},"text":"Pub. L. 106–74","children":[],"tail":" substituted “2000” for “1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":" substituted “1999” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/65"},"text":"Pub. L. 105–65","children":[],"tail":" substituted “such sums as may be necessary through "},{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", for studies under this chapter” for “for studies under this chapter not to exceed $36,283,000 for fiscal year 1990, and such sums as may be necessary for fiscal year 1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":", which directed amendment of first sentence by substituting “such sums as may be necessary through "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":" for studies under this chapter.” for “this subsection” and all that follows, could not be executed because phrase “this subsection” does not appear in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/137"},"text":"Pub. L. 101–137","children":[],"tail":" substi