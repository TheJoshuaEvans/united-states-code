usc/t42/s4054"},"text":"section 4054 of this title","children":[],"tail":" which have been made from such fund; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcb9d78a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4127/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinsurance claims paid under the excess loss reinsurance coverage provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4055"},"text":"section 4055 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcb9d78b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4127/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such other payments as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb9d78c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All such funds shall be available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcb9d78d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4127/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary through the date specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4026"},"text":"section 4026 of this title","children":[],"tail":", for studies under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcb9d78e-3