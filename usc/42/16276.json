{"tag":"section","attrib":{"id":"idc0013b54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16276"},"text":null,"children":[{"tag":"num","attrib":{"value":"16276"},"text":"§ 16276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security of nuclear facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a research and development program on cost-effective technologies for increasing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16276/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of nuclear facilities from natural phenomena; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16276/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security of nuclear facilities from deliberate attacks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0013b57-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s956"},"text":"Pub. L. 109–58, title IX, § 956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/888"},"text":"119 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/f"},"text":"Pub. L. 115–248, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3157"},"text":"132 Stat. 3157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0013b58-3a