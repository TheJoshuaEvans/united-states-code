{"tag":"section","attrib":{"id":"idb5d5785a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y"},"text":null,"children":[{"tag":"num","attrib":{"value":"292y"},"text":"§ 292y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d5785b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall from time to time set dates by which schools must file applications for Federal capital contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5785c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent reduction in allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the total of the amounts requested for any fiscal year in such applications exceeds the amounts appropriated under this section for that fiscal year, the allotment to the loan fund of each such school shall be reduced to whichever of the following is the smaller: (A) the amount requested in its application; or (B) an amount which bears the same ratio to the amounts appropriated as the number of students estimated by the Secretary to be enrolled in such school during such fiscal year bears to the estimated total number of students in all such schools during such year. Amounts remaining after allotment under the preceding sentence shall be reallotted in accordance with clause (B) of such sentence among schools whose applications requested more than the amounts so allotted to their loan funds, but with such adjustments as may be necessary to prevent the total allotted to any such school’s loan fund from exceeding the total so requested by it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5785d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of excess funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds available in any fiscal year for payment to schools under this subpart which are in excess of the amount appropriated pursuant to this section for that year shall be allotted among schools in such manner as the Secretary determines will best carry out the purposes of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5785e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of installments to schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Allotments to a loan fund of a school shall be paid to it from time to time in such installments as the Secretary determines will not result in unnecessary accumulations in the loan fund at such school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d5785f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of funds returned to Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure for Federal capital contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292s/b/5"},"text":"section 292s(b)(5) of this title","children":[],"tail":", any amounts from student loan funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q"},"text":"section 292q of this title","children":[],"tail":" that are returned to the Secretary by health professions schools shall be expended to make Federal capital contributions to such funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described in paragraph (1) that are returned to the Secretary shall be obligated before the end of the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in making contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making Federal capital contributions to student loans funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q"},"text":"section 292q of this title","children":[],"tail":" for a fiscal year from amounts described in paragraph (1), the Secretary shall give preference to health professions schools of the same disciplines as the health professions schools returning such amounts for the period during which the amounts expended for such contributions were received by the Secretary. Any such amounts that, prior to being so returned, were available only for the purpose of loans under this subpart to individuals from disadvantaged backgrounds shall be available only for such purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d57863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for certain medical schools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d57864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making Federal capital contributions to student loan funds established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292q"},"text":"section 292q of this title","children":[],"tail":" by schools of medicine or osteopathic medicine, there is authorized to be appropriated $10,000,000 for each of the fiscal years 1994 through 1996."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d57865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d57866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), the Secretary may make a Federal capital contribution pursuant to paragraph (1) only if the school of medicine or osteopathic medicine involved meets the conditions described in subparagraph (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s292s/b/2"},"text":"section 292s(b)(2) of this title","children":[],"tail":" or the conditions described in subparagraph (C) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d57867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292y/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subparagraph (A), the conditions referred to in such subparagraph shall be applied with respect to graduates of the school involved whose date of graduation occurred approximately 3 years before June 30 of the fiscal year preceding the fiscal year for which the Federal capital contribution involved is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d57868-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 735, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2021"},"text":"106 Stat. 2021","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/a/1"},"text":"Pub. L. 102–531, title III, § 313(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2014/d"},"text":"Pub. L. 103–43, title XX, § 2014(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/217"},"text":"107 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s134/c"},"text":"Pub. L. 105–392, title I, § 134(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3578"},"text":"112 Stat. 3578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d57869-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d5786a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d5786b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 735 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294h"},"text":"section 294h of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5d5786c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":" reenacted heading without change and amended text of par. (2) generally. Prior to amendment, text read as follows: “Amounts described in paragraph (1) that are returned to the Secretary before the fourth quarter of a fiscal year shall be obligated before the end of such fiscal year, and may not be obligated before the fourth quarter. For purposes of the preceding sentence, amounts returned to the Secretary during the last quarter of a fiscal year are deemed to have been returned during the first three quarters of the succeeding fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" inserted designations for cls. (A) and (B) in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5d5786d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5d5786e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/c"},"text":"Pub. L. 102–531, title III, § 313(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/531/tIII/s313/c"},"text":"“The amendments described in this section [amending this section and sections 293j, 293","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 294n, 295j, 295"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 295n, 295"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 296k, and 298b–7 of this title, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s297j"},"text":"section 297j of this title","children":[],"tail":", redesignating subpart IV of part B of subchapter VI of this chapter as subpart III, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s295k"},"text":"section 295k of this title","children":[],"tail":"] are made, and take effect, immediately after the enactment of the bill, H.R. 3508, of the One Hundred Second Congress ["},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
