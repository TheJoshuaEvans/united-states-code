{"tag":"section","attrib":{"id":"idbd716865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232"},"text":null,"children":[{"tag":"num","attrib":{"value":"6232"},"text":"§ 6232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part and part C:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd716866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/5/A"},"text":"Pub. L. 106–469, title I, § 103(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2029"},"text":"114 Stat. 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “importer” means any person who owns, at the first place of storage, any petroleum product imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/5/A"},"text":"Pub. L. 106–469, title I, § 103(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2029"},"text":"114 Stat. 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “interest in land” means any ownership or possessory right with respect to real property, including ownership in fee, an easement, a leasehold, and any subsurface or mineral rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “readily available inventories” means stocks and supplies of petroleum products which can be distributed or used without affecting the ability of the importer or refiner to operate at normal capacity; such term does not include minimum working inventories or other unavailable stocks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “refiner” means any person who owns, operates, or controls the operation of any refinery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/5/A"},"text":"Pub. L. 106–469, title I, § 103(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2029"},"text":"114 Stat. 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “related facility” means any necessary appurtenance to a storage facility, including pipelines, roadways, reservoirs, and salt brine lines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Reserve” means the Strategic Petroleum Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71686f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “storage facility” means any facility or geological formation which is capable of storing significant quantities of petroleum products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd716870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6232/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Strategic Petroleum Reserve” means petroleum products stored in storage facilities pursuant to this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd716871-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tI/s152"},"text":"Pub. L. 94–163, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/882"},"text":"89 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/383/s6/a/1"},"text":"Pub. L. 101–383, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-15"},"text":"Sept. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/729"},"text":"104 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/469/tI/s103/5"},"text":"Pub. L. 106–469, title I, § 103(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2029"},"text":"114 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd716872-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd716873-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd716874-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/5/A"},"text":"Pub. L. 106–469, § 103(5)(A)","children":[],"tail":", struck out par. (1) which read as follows: “The term ‘Early Storage Reserve’ means that portion of the Strategic Petroleum Reserve which consists of petroleum products stored pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6235"},"text":"section 6235 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/5/A"},"text":"Pub. L. 106–469, § 103(5)(A)","children":[],"tail":", struck out par. (3) which read as follows: “The term ‘Industrial Petroleum Reserve’ means that portion of the Strategic Petroleum Reserve which consists of petroleum products owned by importers or refiners and acquired, stored, or maintained pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6236"},"text":"section 6236 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/5/A"},"text":"Pub. L. 106–469, § 103(5)(A)","children":[],"tail":", struck out par. (7) which read as follows: “The term ‘Regional Petroleum Reserve’ means that portion of the Strategic Petroleum Reserve which consists of petroleum products stored pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6237"},"text":"section 6237 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/469/s103/5/B"},"text":"Pub. L. 106–469, § 103(5)(B)","children":[],"tail":", struck out “; such term includes the Industrial Petroleum Reserve, the Early Storage Reserve, and the Regional Petroleum Reserve” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/383"},"text":"Pub. L. 101–383","children":[],"tail":" inserted “and part C” after “this part”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
