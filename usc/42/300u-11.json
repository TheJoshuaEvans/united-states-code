{"tag":"section","attrib":{"id":"idb65d45c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"300u–11"},"text":"§ 300u–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention and Public Health Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb65d45c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to establish a Prevention and Public Health Fund (referred to in this section as the “Fund”), to be administered through the Department of Health and Human Services, Office of the Secretary, to provide for expanded and sustained national investment in prevention and public health programs to improve health and help restrain the rate of growth in private and public sector health care costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d45ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated, and appropriated, to the Fund, out of any monies in the Treasury not otherwise appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb65d45cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2010, $500,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2012 through 2017, $1,000,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2018, $900,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2019, $900,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2020 and 2021, $950,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2022 and 2023, $1,000,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2024 and 2025, $1,300,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2026 and 2027, $1,525,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2028 and 2029, $1,725,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb65d45d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2030 and each fiscal year thereafter, $2,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d45d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall transfer amounts in the Fund to accounts within the Department of Health and Human Services to increase funding, over the fiscal year 2008 level, for programs authorized by the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.], for prevention, wellness, and public health activities including prevention research, health screenings, and initiatives, such as the Community Transformation grant program, the Education and Outreach Campaign Regarding Preventive Benefits, and immunization programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb65d45d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300u–11/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee on Appropriations of the Senate and the Committee on Appropriations of the House of Representatives may provide for the transfer of funds in the Fund to eligible activities under this section, subject to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb65d45d7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4002"},"text":"Pub. L. 111–148, title IV, § 4002","children":[],"tail":", title X, § 10401(b), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/541"},"text":"124 Stat. 541","children":[],"tail":", 974; "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tIII/s3205"},"text":"Pub. L. 112–96, title III, § 3205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/194"},"text":"126 Stat. 194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tV/s5009"},"text":"Pub. L. 114–255, div. A, title V, § 5009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1197"},"text":"130 Stat. 1197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/96/dC/tI/s3103"},"text":"Pub. L. 115–96, div. C, title I, § 3103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-22"},"text":"Dec. 22, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2049"},"text":"131 Stat. 2049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tXII/s53119"},"text":"Pub. L. 115–123, div. E, title XII, § 53119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/308"},"text":"132 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tVII/s7701/c"},"text":"Pub. L. 117–328, div. FF, title VII, § 7701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5966"},"text":"136 Stat. 5966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb65d45d8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb65d45d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb65d45da-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb65d45db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb65d45dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s7701/c/1"},"text":"Pub. L. 117–328, § 7701(c)(1)","children":[],"tail":", substituted “$1,525,000,000;” for “$1,800,000,000; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s7701/c/2"},"text":"Pub. L. 117–328, § 7701(c)(2)","children":[],"tail":", added par. (9) and struck out former par. (9) which read as follows: “for fiscal year 2028 and each fiscal year thereafter, $2,000,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s7701/c/3"},"text":"Pub. L. 117–328, § 7701(c)(3)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(4) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" added pars. (4) to (9) and struck out former pars. (4) to (9) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) for fiscal year 2019, $800,000,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) for each of fiscal years 2020 and 2021, $800,000,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) for fiscal year 2022, $1,250,000,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) for fiscal year 2023, $1,000,000,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) for fiscal year 2024, $1,700,000,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(9) for fiscal year 2025 and each fiscal year thereafter, $2,000,000,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/96/s3103/1"},"text":"Pub. L. 115–96, § 3103(1)","children":[],"tail":", substituted “fiscal year 2018” for “each of fiscal years 2018 and 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/96/s3103/3"},"text":"Pub. L. 115–96, § 3103(3)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/96/s3103/2"},"text":"Pub. L. 115–96, § 3103(2)","children":[],"tail":", (4), redesignated par. (4) as (5) and substituted “$800,000,000” for “$1,000,000,000”. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/96/s3103/2"},"text":"Pub. L. 115–96, § 3103(2)","children":[],"tail":", (5), redesignated par. (5) as (6) and substituted “$1,250,000,000” for “$1,500,000,000”. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/96/s3103/2"},"text":"Pub. L. 115–96, § 3103(2)","children":[],"tail":", redesignated pars. (6) to (8) as (7) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s5009/1"},"text":"Pub. L. 114–255, § 5009(1)","children":[],"tail":", substituted “$900,000,000” for “$1,250,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s5009/2"},"text":"Pub. L. 114–255, § 5009(2)","children":[],"tail":", substituted “$1,000,000,000” for “$1,500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s5009/3"},"text":"Pub. L. 114–255, § 5009(3)","children":[],"tail":", added pars. (5) to (8) and struck out former par. (5) which read as follows: “for fiscal year 2022, and each fiscal year thereafter, $2,000,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96"},"text":"Pub. L. 112–96","children":[],"tail":" added pars. (2) to (5) and struck out former pars. (2) to (6) which appropriated amounts for fiscal years 2011 through 2015 and each fiscal year thereafter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10401/b"},"text":"Pub. L. 111–148, § 10401(b)","children":[],"tail":", substituted “research, health screenings, and initiatives” for “research and health screenings” and “Regarding Preventive” for “for Preventive”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb65fb6dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb65fb6de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Website","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dH/tII/s219"},"text":"Pub. L. 115–31, div. H, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/541"},"text":"131 Stat. 541","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/31/dH/tII/s219"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish a publicly accessible Web site to provide information regarding the uses of funds made available under section 4002 of the Patient Protection and Affordable Care Act of 2010 (‘ACA’) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300u–11"},"text":"42 U.S.C. 300u–11","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to funds provided under section 4002 of the ACA, the Secretary shall include on the Web site established under subsection (a) at a minimum the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of each transfer of funds under section 4002(c), a statement indicating the program or activity receiving funds, the operating division or office that will administer the funds, and the planned uses of the funds, to be posted not later than the day after the transfer is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification (along with a link to the full text) of each funding opportunity announcement, request for proposals, or other announcement or solicitation of proposals for grants, cooperative agreements, or contracts intended to be awarded using such funds, to be posted not later than the day after the announcement or solicitation is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of each grant, cooperative agreement, or contract with a value of $25,000 or more awarded using such funds, including the purpose of the award and the identity of the recipient, to be posted not later than 5 days after the award is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report detailing the uses of all funds transferred under section 4002(c) during the fiscal year, to be posted not later than 90 days after the end of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to awards made in fiscal years 2013 through 2017, the Secretary shall also include on the Web site established under subsection (a), semi-annual reports from each entity awarded a grant, cooperative agreement, or contract from such funds with a value of $25,000 or more, summarizing the activities undertaken and identifying any sub-grants or sub-contracts awarded (including the purpose of the award and the identity of the recipient), to be posted not later than 30 days after the end of each 6-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present the information required in subsection (b)(1) on a single webpage or on a single database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all information required in this section is directly accessible from the single webpage or database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all information required in this section is able to be organized by program or State.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dH/tII/s220"},"text":"Pub. L. 114–113, div. H, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2622"},"text":"129 Stat. 2622","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dG/tII/s218"},"text":"Pub. L. 113–235, div. G, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2488"},"text":"128 Stat. 2488","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dH/tII/s218"},"text":"Pub. L. 113–76, div. H, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/385"},"text":"128 Stat. 385","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tII/s220/a"},"text":"Pub. L. 112–74, div. F, title II, § 220(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1085"},"text":"125 Stat. 1085","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
