{"tag":"section","attrib":{"id":"idbc2140d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332"},"text":"§ 2332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities; uniformity; preferences; impairment of rights","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall establish, by rule or regulation, a detailed system of reasonable and fair priority rights applicable to the sale of Government-owned property to private purchasers at each community. The priorities shall—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc2140da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be uniform in each class or subclass of property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give such preference to occupants and project-connected persons and to incoming employees of the Commission, of a contractor, or of a licensee as the Commission finds necessary or desirable, giving due consideration to the following factors:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc2140dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The retention and recruitment of personnel essential to the atomic energy program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2140dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minimization of dislocations within the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2140de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expeditious accomplishment of the disposal program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc2140df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The desirability of encouraging private firms to locate or remain in the community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give the occupant of a Government-owned single family house, and the senior occupant of a duplex house, at least ninety days in which to exercise the first right of priority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit persons who have formerly been occupants, project-connected persons, or inhabitants of the community, upon application therefor, to have such priority as the Commission finds to be fair and equitable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc2140e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not impair any rights, including purchase rights, conferred by existing leases and covenants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc2140e3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-04/ch543"},"text":"Aug. 4, 1955, ch. 543","children":[],"tail":", ch. 4, § 42, "},{"tag":"ref","attrib":{"href":"/us/stat/69/475"},"text":"69 Stat. 475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc2140e4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc2140e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc2140e6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of this title. See also Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
