{"tag":"section","attrib":{"id":"idbce4b7fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4852b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4852b"},"text":"§ 4852b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National consultation on lead-based paint hazard reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Secretary shall consult on an ongoing basis with the Administrator of the Environmental Protection Agency, the Director of the Centers for Disease Control, other Federal agencies concerned with lead poisoning prevention, and the task force established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4852a"},"text":"section 4852a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce4b7fb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1016"},"text":"Pub. L. 102–550, title X, § 1016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3909"},"text":"106 Stat. 3909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce4b7fc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce4b7fd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbce4b7fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in tex