{"tag":"section","attrib":{"id":"idbed25826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628"},"text":null,"children":[{"tag":"num","attrib":{"value":"9628"},"text":"§ 9628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State response programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbed25827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed25828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed25829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may award a grant to a State or Indian tribe that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed2582a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a response program that includes each of the elements, or is taking reasonable steps to include each of the elements, listed in paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2582b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a party to a memorandum of agreement with the Administrator for voluntary response programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed2582c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants by States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed2582d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or Indian tribe may use a grant under this subsection to establish or enhance the response program of the State or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2582e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the uses under clause (i), a State or Indian tribe may use a grant under this subsection to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed2582f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capitalize a revolving loan fund for brownfield remediation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9604/k/3"},"text":"section 9604(k)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25830-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase insurance or develop a risk sharing pool, an indemnity pool, or insurance mechanism to provide financing for response actions under a State response program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25831-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist small communities, Indian tribes, rural areas, or disadvantaged areas in carrying out activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9604/k/7/A"},"text":"section 9604(k)(7)(A) of this title","children":[],"tail":" with respect to brownfield sites."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25832-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small communities, Indian tribes, rural areas, and disadvantaged areas","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed25833-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To make grants to States or Indian tribes under clause (ii)(III), the Administrator may use, in addition to amounts available to carry out this subsection, not more than $1,500,000 of the amounts made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9604/k/7"},"text":"section 9604(k)(7) of this title","children":[],"tail":" in each fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25834-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant made under subclause (I) may be not more than $20,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25835-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in other grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may, at the request of a State or Indian tribe, include a grant under this clause in any other grant to the State or Indian tribe made under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25836-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subparagraph:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed25837-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disadvantaged area” means a community with an annual median household income that is less than 80 percent of the statewide annual median household income, as determined by the President based on the latest available decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small community” means a community with a population of not more than 15,000 individuals, as determined by the President based on the latest available decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The elements of a State or Indian tribe response program referred to in paragraph (1)(A)(i) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed2583a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely survey and inventory of brownfield sites in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed2583b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Oversight and enforcement authorities or other mechanisms, and resources, that are adequate to ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed2583c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a response action will—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed2583d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect human health and the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed2583e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted in accordance with applicable Federal and State law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2583f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the person conducting the response action fails to complete the necessary response activities, including operation and maintenance or long-term monitoring activities, the necessary response activities are completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed25840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Mechanisms and resources to provide meaningful opportunities for public participation, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed25841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public access to documents that the State, Indian tribe, or party conducting the cleanup is relying on or developing in making cleanup decisions or conducting site activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior notice and opportunity for comment on proposed cleanup plans and site activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a mechanism by which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed25844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person that is or may be affected by a release or threatened release of a hazardous substance, pollutant, or contaminant at a brownfield site located in the community in which the person works or resides may request the conduct of a site assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate State official shall consider and appropriately respond to a request under subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed25846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for approval of a cleanup plan, and a requirement for verification by and certification or similar documentation from the State, an Indian tribe, or a licensed site professional to the person conducting a response action indicating that the response is complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $50,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed25848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement in cases of a release subject to State program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed25849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed2584a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B) and subject to subparagraph (C), in the case of an eligible response site at which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed2584b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a release or threatened release of a hazardous substance, pollutant, or contaminant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2584c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person is conducting or has completed a response action regarding the specific release that is addressed by the response action that is in compliance with the State program that specifically governs response actions for the protection of public health and the environment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President may not use authority under this chapter to take an administrative or judicial enforcement action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9606/a"},"text":"section 9606(a) of this title","children":[],"tail":" or to take a judicial enforcement action to recover response costs under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9607/a"},"text":"section 9607(a) of this title","children":[],"tail":" against the person regarding the specific release that is addressed by the response action."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed2584d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may bring an administrative or judicial enforcement action under this chapter during or after completion of a response action described in subparagraph (A) with respect to a release or threatened release at an eligible response site described in that subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed2584e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State requests that the President provide assistance in the performance of a response action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2584f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines that contamination has migrated or will migrate across a State line, resulting in the need for further response action to protect human health or the environment, or the President determines that contamination has migrated or is likely to migrate onto property subject to the jurisdiction, custody, or control of a department, agency, or instrumentality of the United States and may impact the authorized purposes of the Federal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after taking into consideration the response activities already taken, the Administrator determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed25851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a release or threatened release may present an imminent and substantial endangerment to public health or welfare or the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional response actions are likely to be necessary to address, prevent, limit, or mitigate the release or threatened release; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator, after consultation with the State, determines that information, that on the earlier of the date on which cleanup was approved or completed, was not known by the State, as recorded in documents prepared or relied on in selecting or conducting the cleanup, has been discovered regarding the contamination or conditions at a facility such that the contamination or conditions at the facility present a threat requiring further remediation to protect public health or welfare or the environment. Consultation with the State shall not limit the ability of the Administrator to make this determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed25854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitations on the authority of the President under subparagraph (A) apply only at sites in States that maintain, update not less than annually, and make available to the public a record of sites, by name and location, at which response actions have been completed in the previous year and are planned to be addressed under the State program that specifically governs response actions for the protection of public health and the environment in the upcoming year. The public record shall identify whether or not the site, on completion of the response action, will be suitable for unrestricted use and, if not, shall identify the institutional controls relied on in the remedy. Each State and tribe receiving financial assistance under subsection (a) shall maintain and make available to the public a record of sites as provided in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed25855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPA notification","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed25856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an eligible response site at which there is a release or threatened release of a hazardous substance, pollutant, or contaminant and for which the Administrator intends to carry out an action that may be barred under subparagraph (A), the Administrator shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed25857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State of the action the Administrator intends to take; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed25858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbed25859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wait 48 hours for a reply from the State under clause (ii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbed2585a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State fails to reply to the notification or if the Administrator makes a determination under clause (iii), take immediate action under that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2585b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 48 hours after a State receives notice from the Administrator under clause (i), the State shall notify the Administrator if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbed2585c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release at the eligible response site is or has been subject to a cleanup conducted under a State program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbed2585d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State is planning to abate the release or threatened release, any actions that are planned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed2585e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate Federal action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may take action immediately after giving notification under clause (i) without waiting for a State reply under clause (ii) if the Administrator determines that one or more exceptions under subparagraph (B) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed2585f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date of initiation of any enforcement action by the President under clause (ii), (iii), or (iv) of subparagraph (B), the President shall submit to Congress a report describing the basis for the enforcement action, including specific references to the facts demonstrating that enforcement action is permitted under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbed25861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs incurred prior to limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) precludes the President from seeking to recover costs incurred prior to ","children":[{"tag":"date","attrib":{"date":"2002-01-11"},"text":"January 11, 2002","children":[],"tail":", or during a period in which the limitations of paragraph (1)(A) were not applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbed25862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on agreements between States and EPA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbed25863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifies or otherwise affects a memorandum of agreement, memorandum of understanding, or any similar agreement relating to this chapter between a State agency or an Indian tribe and the Administrator that is in effect on or before ","children":[{"tag":"date","attrib":{"date":"2002-01-11"},"text":"January 11, 2002","children":[],"tail":" (which agreement shall remain in effect, subject to the terms of the agreement); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbed25864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the discretionary authority of the President to enter into or modify an agreement with a State, an Indian tribe, or any other person relating to the implementation by the President of statutory authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection applies only to response actions conducted after ","children":[{"tag":"date","attrib":{"date":"2001-02-15"},"text":"February 15, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbed25866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Federal laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects any liability or response authority under any Federal law, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbed25867-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter, except as provided in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25868-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed25869-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed2586a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Toxic Substances Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"15 U.S.C. 2601","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbed2586b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9628/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbed2586c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510/tI/s128"},"text":"Pub. L. 96–510, title I, § 128","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/118/tII/s231/b"},"text":"Pub. L. 107–118, title II, § 231(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-11"},"text":"Jan. 11, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2375"},"text":"115 Stat. 2375","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dN"},"text":"Pub. L. 115–141, div. N","children":[],"tail":", §§ 14(a), 15, "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1058"},"text":"132 Stat. 1058","children":[],"tail":", 1059.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbed2586d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbed2586e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbed2586f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1)(A), (B), (2)(B)(i) and (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", known as the Comprehensive Environmental Response, Compensation, and Liability Act of 1980, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Solid Waste Disposal Act, referred to in subsec. (c)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272"},"text":"Pub. L. 89–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/997"},"text":"79 Stat. 997","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2795"},"text":"90 Stat. 2795","children":[],"tail":", which is classified generally to chapter 82 (§ 6901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"section 6901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Toxic Substances Control Act, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469"},"text":"Pub. L. 94–469","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":", which is classified generally to chapter 53 (§ 2601 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Safe Drinking Water Act, referred to in subsec. (c)(5), is title XIV of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1660"},"text":"88 Stat. 1660","children":[],"tail":", which is classified generally to subchapter XII (§ 300f et seq.) of chapter 6A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbed4a160-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s14/a/1"},"text":"Pub. L. 115–141, § 14(a)(1)","children":[],"tail":", added subcl. (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s14/a/2"},"text":"Pub. L. 115–141, § 14(a)(2)","children":[],"tail":", added cls. (iii) and (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s15"},"text":"Pub. L. 115–141, § 15","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out this subsection $50,000,000 for each of fiscal years 2002 through 2006.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
