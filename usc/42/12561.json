 C (§ 1087–51 et seq.) of subchapter IV of chapter 28 of Title 20, Education. Section 443 of the Act was transferred from "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2753"},"text":"section 2753 of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–53"},"text":"section 1087–53 of Title 20","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf748a59-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s118"},"text":"section 118 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12551"},"text":"section 12551 of this title","children":[],"tail":" prior to the general amendment of part I of this division by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s118"},"text":"section 118 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12531"},"text":"section 12531 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf748a5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/1"},"text":"Pub. L. 111–13, § 1202(b)(1)","children":[],"tail":", inserted “through service-learning” after “community service programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/2/A"},"text":"Pub. L. 111–13, § 1202(b)(2)(A)","children":[],"tail":", substituted “consortium” for “combination” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/2/B"},"text":"Pub. L. 111–13, § 1202(b)(2)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/2/C/i"},"text":"Pub. L. 111–13, § 1202(b)(2)(C)(i)","children":[],"tail":", substituted “institutions of higher education and their faculty” for “teachers at the elementary, secondary, and postsecondary levels” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/2/C/ii"},"text":"Pub. L. 111–13, § 1202(b)(2)(C)(ii)","children":[],"tail":", substituted “curricula of the institution to strengthen the instructional capacity of teachers to provide service-learning at the elementary and secondary levels;” for “education of the institution; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/2/C/iii"},"text":"Pub. L. 111–13, § 1202(b)(2)(C)(iii)","children":[],"tail":", (iv), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1202/b/3"},"text":"Pub. L. 111–13, § 1202(b)(3)","children":[],"tail":"–(5), added subsecs. (c) to (h), redesignated former subsec. (f) as (i), and struck out former subsecs. (c), (d), (e), and (g) which related to Federal share of the cost, grant application, applicant priority, and definition of “student”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf748a5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf748a5c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf748a5d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
