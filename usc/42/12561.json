{"tag":"section","attrib":{"id":"idbf721a16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561"},"text":null,"children":[{"tag":"num","attrib":{"value":"12561"},"text":"§ 12561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher education innovative programs for community service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf721a17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this part to expand participation in community service by supporting innovative community service programs through service-learning carried out through institutions of higher education, acting as civic institutions to meet the human, educational, environmental, or public safety needs of neighboring communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation, in consultation with the Secretary of Education, is authorized to make grants to, and enter into contracts with, institutions of higher education (including a consortium of such institutions), and partnerships comprised of such institutions and of other public or private nonprofit organizations, to pay for the Federal share of the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721a19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enabling such an institution or partnership to create or expand an organized community service program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engenders a sense of social responsibility and commitment to the community in which the institution is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides projects for participants, who shall be students, faculty, administration, or staff of the institution, or residents of the community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution or partnership may coordinate with service-learning curricula being offered in the academic curricula at the institution of higher education or at 1 or more members of the partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting student-initiated and student-designed community service projects through the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strengthening the leadership and instructional capacity of institutions of higher education and their faculty, with respect to service-learning, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including service-learning as a key component of the preservice teacher curricula of the institution to strengthen the instructional capacity of teachers to provide service-learning at the elementary and secondary levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including service-learning as a component of other curricula or academic programs (other than education curricula or programs), such as curricula or programs relating to nursing, medicine, criminal justice, or public policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the faculty of the institution to use service-learning methods throughout their curriculum;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the integration of community service carried out under the program into academic curricula, including integration of clinical programs into the curriculum for students in professional schools, so that students can obtain credit for their community service projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplementing the funds available to carry out work-study programs under part C of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2751"},"text":"42 U.S.C. 2751","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn004055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to support service-learning and community service through the community service program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the service infrastructure within institutions of higher education in the United States through the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the training of teachers, prospective teachers, related education personnel, and community leaders in the skills necessary to develop, supervise, and organize service-learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal, State, and local contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of carrying out a program for which assistance is provided under this part may not exceed 50 percent of the total cost of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing for the remaining share of the cost of carrying out such a program, each recipient of a grant or contract under this part—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf721a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for such share through a payment in cash or in kind, fairly evaluated, including facilities, equipment, or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for such share through State sources or local sources, including private funds or donated services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer may waive the requirements of paragraph (1) in whole or in part with respect to any such program for any fiscal year if the Corporation determines that such a waiver would be equitable due to a lack of available financial resources at the local level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a grant or enter into a contract under this part, an institution or partnership shall prepare and submit to the Corporation, an application at such time, in such manner, and containing such information and assurances as the Corporation may reasonably require, and obtain approval of the application. In requesting applications for assistance under this part, the Corporation shall specify such required information and assurances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application submitted under paragraph (1) shall contain, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf721a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the placement of a participant, the applicant will consult with the appropriate local labor organization, if any, representing employees in the area who are engaged in the same or similar work as that proposed to be carried out by such program, to prevent the displacement and protect the rights of such employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will comply with the nonduplication and nondisplacement provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":" and the notice, hearing, and grievance procedures required by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12636"},"text":"section 12636 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other assurances as the Chief Executive Officer may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, in making grants and entering into contracts under subsection (b), the Corporation shall give special consideration to applications submitted by, or applications from partnerships including, institutions serving primarily low-income populations, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721a35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alaska Native-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Asian American and Native American Pacific Islander-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically black colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native American-serving, nontribal institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Hawaiian-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Predominantly black institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribally controlled colleges and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community colleges serving predominantly minority populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf721a3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants and entering into contracts under subsection (b), the Corporation shall take into consideration whether the applicants submit applications containing proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf721a3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the commitment of the institution of higher education involved, other than by demonstrating the commitment of the students, to supporting the community service projects carried out under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the manner in which the institution will promote faculty, administration, and staff participation in the community service projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the manner in which the institution will provide service to the community through organized programs, including, where appropriate, clinical programs for students in professional schools and colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe any partnership that will participate in the community service projects, such as a partnership comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf721a43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf721a45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local government agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity that serves or involves school-age youth, older adults, or low-income communities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf721a48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf721a49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a student organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department of the institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf721a4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of faculty comprised of different departments, schools, or colleges at the institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate community involvement in the development of the proposal and the extent to which the proposal will contribute to the goals of the involved community members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a commitment to perform community service projects in underserved urban and rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe research on effective strategies and methods to improve service utilized in the design of the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify that the institution or partnership will use the assistance provided through the grant or contract to strengthen the service infrastructure in institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to projects involving delivery of services, specify projects that involve leadership development of school-age youth; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf721a51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/f/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the needs that the proposed projects are designed to address, such as housing, economic development, infrastructure, health care, job training, education, crime prevention, urban planning, transportation, information technology, or child welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal work-study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under this part, an institution of higher education shall demonstrate that it meets the minimum requirements under section 443(b)(2)(A) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2753/b/2/A"},"text":"42 U.S.C. 2753(b)(2)(A)","children":[],"tail":") "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" relating to the participation of students employed under part C of title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2751"},"text":"42 U.S.C. 2751","children":[],"tail":" et seq.) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (relating to Federal Work-Study "},{"tag":"ref","attrib":{"idref":"fn004056"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" programs) in community service activities, or has received a waiver of those requirements from the Secretary of Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12511"},"text":"section 12511 of this title","children":[],"tail":", as used in this part, the term “student” means an individual who is enrolled in an institution of higher education on a full- or part-time basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf748a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12561/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service educational award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participant in a program funded under this part shall be eligible for the national service educational award described in division D, if the participant served in an approved national service position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf748a55-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"