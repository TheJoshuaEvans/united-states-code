{"tag":"section","attrib":{"id":"idb6e7ab7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–62"},"text":null,"children":[{"tag":"num","attrib":{"value":"300mm–62"},"text":"§ 300mm–62.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6e7ab7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–62/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a fund to be known as the World Trade Center Health Program Supplemental Fund (referred to in this section as the “Supplemental Fund”), consisting of amounts deposited into the Fund under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e7ab7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–62/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury not otherwise appropriated, there is appropriated for fiscal year 2023 $1,000,000,000, for deposit into the Supplemental Fund, which amounts shall remain available through fiscal year 2032.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e7ab7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–62/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited into the Supplemental Fund under subsection (b) shall be available, without further appropriation and without regard to any spending limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300mm–61/c"},"text":"section 300mm–61(c) of this title","children":[],"tail":", to the WTC Program Administrator as needed at the discretion of such Administrator, for carrying out any provision in this title, including sections 300mm–2 and 300mm–51(c) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6e7ab7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300mm–62/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any unobligated amounts that remain in the Supplemental Fund on ","children":[{"tag":"date","attrib":{"date":"2032-09-30"},"text":"September 30, 2032","children":[],"tail":", shall be deposited into the Treasury as miscellaneous receipts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6e7ab80-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXXIII, § 3352, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tVII/s7701/a"},"text":"Pub. L. 117–328, div. FF, title VII, § 7701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5965"},"text":"136 Stat. 5965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tIV/s6411/c/1"},"text":"Pub. L. 119–75, div. J, title IV, § 6411(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/689"},"text":"140 Stat. 689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6e7ab81-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6e7ab82-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6e7ab83-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" substituted “Any unobligated amounts” for “Any amounts”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
