{"tag":"section","attrib":{"id":"idbdb43d63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626"},"text":null,"children":[{"tag":"num","attrib":{"value":"6626"},"text":"§ 6626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group on inclusion in STEM fields","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdb43d64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Science and Technology Policy, in collaboration with Federal departments and agencies, shall establish an interagency working group to compile and summarize available research and best practices on how to promote diversity and inclusions in STEM fields and examine whether barriers exist to promoting diversity and inclusion within Federal agencies employing scientists and engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb43d65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group shall be responsible for reviewing and assessing research, best practices, and policies across Federal science agencies related to the inclusion of individuals identified in sections 1885a and 1885b of this title in the Federal STEM workforce, including available research and best practices on how to promote diversity and inclusion in STEM fields, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb43d66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies providing flexibility for scientists and engineers that are also caregivers, particularly on the timing of research grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies to address the proper handling of claims of sexual harassment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies to minimize the effects of implicit bias and other systemic factors in hiring, promotion, evaluation and the workplace in general; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other evidence-based strategies that the working group considers effective for promoting diversity and inclusion in the STEM fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb43d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder input","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities under section (b), the working group shall solicit and consider input and recommendations from non-Federal stakeholders, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdb43d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council of Advisors on Science and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally funded and non-federally funded researchers, institutions of higher education, scientific disciplinary societies, and associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry, including small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally funded research and development centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-governmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdb43d71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other members of the public interested in promoting a diverse and inclusive Federal STEM workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb43d72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2017-01-06"},"text":"January 6, 2017","children":[],"tail":", and periodically thereafter, the working group shall publish a report on the review and assessment under subsection (b), including a summary of available research and best practices, any recommendations for Federal actions to promote a diverse and inclusive Federal STEM workforce, and updates on the implementation of previous recommendations for Federal actions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdb43d73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6626/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interagency working group established under subsection (a) shall terminate on the date that is 10 years after the date that it is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdb43d74-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s308"},"text":"Pub. L. 114–329, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3011"},"text":"130 Stat. 3011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdb43d75-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdb43d76-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdb43d77-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the National Science and Technology Policy, Organization, and Priorities Act of 1976 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbdb43d78-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbdb43d79-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"section 2 of Pub. L. 114–329","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s"},"text":"section 1862s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
