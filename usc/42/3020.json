{"tag":"section","attrib":{"id":"idbc44f684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020"},"text":null,"children":[{"tag":"num","attrib":{"value":"3020"},"text":"§ 3020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc44f685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of affording adequate notice of funding available under this chapter, appropriations under this chapter are authorized to be included in the appropriation Act for the fiscal year preceding the fiscal year for which they are available for obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc44f686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to effect a transition to the advance funding method of timing appropriation action, subsection (a) shall apply notwithstanding that its initial application will result in the enactment in the same year (whether in the same appropriation Act or otherwise) of two separate appropriations, one for the then current fiscal year and one for the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc44f687-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s209"},"text":"Pub. L. 89–73, title II, § 209","children":[],"tail":", formerly § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/29/tII/s201/c"},"text":"Pub. L. 93–29, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-03"},"text":"May 3, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/36"},"text":"87 Stat. 36","children":[],"tail":"; renumbered § 209 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s2/e/2"},"text":"Pub. L. 97–115, § 2(e)(2)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1596"},"text":"95 Stat. 1596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc44f688-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc44f689-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc44f68a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/s209"},"text":"section 209 of Pub. L. 89–73","children":[],"tail":" was renumbered section 208 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3019"},"text":"section 3019 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc44f68b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s2/i"},"text":"Pub. L. 97–115, § 2(i)","children":[],"tail":", substituted “subsection (a) shall apply” for “the amendment made by subsection (a) shall apply”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
