{"tag":"section","attrib":{"id":"idb6ac028b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–16"},"text":"§ 300gg–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on discrimination in favor of highly compensated individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ac028c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan (other than a self-insured plan) shall satisfy the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s105/h/2"},"text":"section 105(h)(2) of title 26","children":[],"tail":" (relating to prohibition on discrimination in favor of highly compensated individuals)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac028d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac028e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain rules to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Rules similar to the rules contained in paragraphs (3), (4), and (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s105/h"},"text":"section 105(h) of title 26","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac028f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly compensated individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “highly compensated individual” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s105/h/5"},"text":"section 105(h)(5) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ac0290-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2716, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1001/5"},"text":"Pub. L. 111–148, title I, § 1001(5)","children":[],"tail":", title X, § 10101(d), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/135"},"text":"124 Stat. 135","children":[],"tail":", 884.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ac0291-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ac0292-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6ac0293-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10101/d"},"text":"Pub. L. 111–148, § 10101(d)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—The plan sponsor of a group health plan (other than a self-insured plan) may not establish rules relating to the health insurance coverage eligibility (including continued eligibility) of any full-time employee under the terms of the plan that are based on the total hourly or annual salary of the employee or otherwise establish eligibility rules that have the effect of discriminating in favor of higher wage employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—Subsection (a) shall not be construed to prohibit a plan sponsor from establishing contribution requirements for enrollment in the plan or coverage that provide for the payment by employees with lower hourly or annual compensation of a lower dollar or percentage contribution than the payment required of similarly situated employees with a higher hourly or annual compensation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ac0294-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ac0295-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for plan years beginning on or after the date that is 6 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004"},"text":"section 1004 of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
