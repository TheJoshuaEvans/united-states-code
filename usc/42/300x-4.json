{"tag":"section","attrib":{"id":"idb666e2db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–4"},"text":"§ 300x–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb666e2dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State plan by mental health planning council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" to a State only if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e2dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–1/a"},"text":"section 300x–1(a) of this title","children":[],"tail":" with respect to the grant and the report of the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–52/a"},"text":"section 300x–52(a) of this title","children":[],"tail":" concerning the preceding fiscal year has been reviewed by the State mental health planning council under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–3"},"text":"section 300x–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State submits to the Secretary any recommendations received by the State from such council for modifications to the plan (without regard to whether the State has made the recommended modifications) and any comments concerning the annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb666e2df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort regarding State expenditures for mental health","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb666e2e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" is that the State involved will maintain State expenditures for community mental health services at a level that is not less than the average level of such expenditures maintained by the State for the 2-year period preceding the fiscal year for which the State is applying for the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exclude from the aggregate State expenditures under subsection (a), funds appropriated to the principle agency for authorized activities which are of a non-recurring nature and for a specific purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e2e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, upon the request of a State, waive the requirement established in paragraph (1) in whole or in part if the Secretary determines that extraordinary economic conditions in the State in the fiscal year involved or in the previous fiscal year justify the waiver ","children":[{"tag":"ref","attrib":{"idref":"fn002388"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002388"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for action upon request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve or deny a request for a waiver under this paragraph not later than 120 days after the date on which the request is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A waiver provided by the Secretary under this paragraph shall be applicable only to the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb666e2e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance by State","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb666e2e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb666e2e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" to a State for a fiscal year, the Secretary shall make a determination of whether, for the previous fiscal year, the State maintained material compliance with the agreement made under paragraph (1). If the Secretary determines that a State has failed to maintain such compliance, the Secretary shall reduce the amount of the allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for the State for the fiscal year for which the grant is being made by an amount equal to the amount constituting such failure for the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb666e2e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that has failed to comply with paragraph (1) and would otherwise be subject to a reduction in the State’s allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" may, upon request by the State, in lieu of having the amount of the allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for the State reduced for the fiscal year of the grant, agree to comply with a negotiated agreement that is approved by the Secretary and carried out in accordance with guidelines issued by the Secretary. If a State fails to enter into or comply with a negotiated agreement, the Secretary may take action under this paragraph or the terms of the negotiated agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb666e2ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–4/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information to the secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x"},"text":"section 300x of this title","children":[],"tail":" for a fiscal year only if the State involved submits to the Secretary information sufficient for the Secretary to make the determination required in subparagraph (A)(i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb666e2eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1915, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s201/2"},"text":"Pub. L. 102–321, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/383"},"text":"106 Stat. 383","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3204/b"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3204(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1193"},"text":"114 Stat. 1193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8001/d"},"text":"Pub. L. 114–255, div. B, title VIII, § 8001(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1228"},"text":"130 Stat. 1228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb666e2ec-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6