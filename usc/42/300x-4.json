","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–3"},"text":"section 300x–3 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300x–4a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIX/s1916A"},"text":"act July 1, 1944, ch. 373, title XIX, § 1916A","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2036"},"text":"Pub. L. 100–690, title II, § 2036","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4202"},"text":"102 Stat. 4202","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s2/m"},"text":"Pub. L. 101–93, § 2(m)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/608"},"text":"103 Stat. 608","children":[],"tail":", related to group homes for recovering substance abusers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb666e2ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8001/d/1"},"text":"Pub. L. 114–255, § 8001(d)(1)","children":[],"tail":", designated existing provisions as subpar. (A) and inserted heading, substituted “paragraph (1) in whole or in part if” for “paragraph (1) if” and “State in the fiscal year involved or in the previous fiscal year justify the waiver” for “State justify the waiver.”, and added subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8001/d/2/A"},"text":"Pub. L. 114–255, § 8001(d)(2)(A)","children":[],"tail":", designated existing provisions as cl. (i), inserted subpar. (A) and cl. (i) headings, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8001/d/2/B"},"text":"Pub. L. 114–255, § 8001(d)(2)(B)","children":[],"tail":", inserted heading and substituted “subparagraph (A)(i)” for “subparagraph (A)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3204/b/1"},"text":"Pub. L. 106–310, § 3204(b)(1)","children":[],"tail":", inserted “and the report of the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–52/a"},"text":"section 300x–52(a) of this title","children":[],"tail":" concerning the preceding fiscal year” after “to the grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3204/b/2"},"text":"Pub. L. 106–310, § 3204(b)(2)","children":[],"tail":", inserted “and any comments concerning the annual report” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310/s3204/c"},"text":"Pub. L. 106–310, § 3204(c)","children":[],"tail":", added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
