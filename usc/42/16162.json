{"tag":"section","attrib":{"id":"idbff79e04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16162"},"text":null,"children":[{"tag":"num","attrib":{"value":"16162"},"text":"§ 16162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology transfer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Secretary shall carry out programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16162/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the transfer of critical hydrogen and fuel cell technologies to the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16162/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate wider application of those technologies in the global market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16162/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the exchange of generic, nonproprietary information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16162/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess technical and commercial viability of technologies relating to the production, distribution, storage, and use of hydrogen energy and fuel cells.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79e09-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVIII/s818"},"text":"Pub. L. 109–58, title VIII, § 818","children":[],"tail":", formerly § 813, "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/855"},"text":"119 Stat. 855","children":[],"tail":"; renumbered § 818, "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40314/1"},"text":"Pub. L. 117–58, div. D, title III, § 40314(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1008"},"text":"135 Stat. 1008","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
