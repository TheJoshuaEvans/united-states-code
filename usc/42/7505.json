{"tag":"section","attrib":{"id":"idbe34df98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7505"},"text":null,"children":[{"tag":"num","attrib":{"value":"7505"},"text":"§ 7505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental Protection Agency grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe34df99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan revision development costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make grants to any organization of local elected officials with transportation or air quality maintenance planning responsibilities recognized by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7504/a"},"text":"section 7504(a) of this title","children":[],"tail":" for payment of the reasonable costs of developing a plan revision under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe34df9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount granted to any organization under subsection (a) shall be 100 percent of any additional costs of developing a plan revision under this part for the first two fiscal years following receipt of the grant under this paragraph, and shall supplement any funds available under Federal law to such organization for transportation or air quality maintenance planning. Grants under this section shall not be used for construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe34df9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title I, § 175, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tI/s129/b"},"text":"Pub. L. 95–95, title I, § 129(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/749"},"text":"91 Stat. 749","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
