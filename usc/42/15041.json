{"tag":"section","attrib":{"id":"idbfdd5e9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15041"},"text":null,"children":[{"tag":"num","attrib":{"value":"15041"},"text":"§ 15041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this part is to provide for allotments to support a protection and advocacy system (referred to in this part as a “system”) in each State to protect the legal and human rights of individuals with developmental disabilities in accordance with this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfdd5e9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s141"},"text":"Pub. L. 106–402, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1712"},"text":"114 Stat. 1712","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
