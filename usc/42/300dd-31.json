{"tag":"section","attrib":{"id":"idb6884d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–31"},"text":null,"children":[{"tag":"num","attrib":{"value":"300dd–31"},"text":"§ 300dd–31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for anonymous testing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to the States for the purpose of providing opportunities for individuals—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6884d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–31/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undergo counseling and testing with respect to the etiologic agent for acquired immune deficiency syndrome without being required to provide any information relating to the identity of the individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6884d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300dd–31/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undergo such counseling and testing through the use of a pseudonym.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6884d60-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIV, § 2431, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s211"},"text":"Pub. L. 100–607, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3090"},"text":"102 Stat. 3090","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
