{"tag":"section","attrib":{"id":"idb52c18fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"280b–4"},"text":"§ 280b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study conducted by the Centers for Disease Control and Prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52c18fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services acting through the National Center for Injury Prevention and Control at the Centers for Disease Control ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":" Prevention shall make grants to entities, including domestic and sexual assault coalitions and programs, research organizations, tribal organizations, and academic institutions to support research to examine prevention and intervention programs to further the understanding of sexual and domestic violence by and against adults, youth, and children."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c18fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The research conducted under this section shall include evaluation and study of best practices for reducing and preventing violence against adults, youth, and children addressed by the strategies included in Department of Health and Human Services-related provisions ","children":[{"tag":"ref","attrib":{"idref":"fn002131"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “of”."}],"tail":" this title,"},{"tag":"ref","attrib":{"idref":"fn002132"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" including strategies addressing underserved communities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c18fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be authorized to be appropriated to carry out this title ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":" $1,000,000 for each of fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52c18ff-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIV/s402"},"text":"Pub. L. 109–162, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3023"},"text":"119 Stat. 3023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/1