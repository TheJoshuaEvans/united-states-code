{"tag":"section","attrib":{"id":"idb6647155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"300w–8"},"text":"§ 300w–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty for false statements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whoever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6647156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully makes or causes to be made any false statement or representation of a material fact in connection with the furnishing of items or services for which payment may be made by a State from funds allotted to the State under this part, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6647157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300w–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having knowledge of the occurrence of any event affecting his initial or continued right to any such payment conceals or fails to disclose such event with an intent fraudulently to secure such payment either in a greater amount than is due or when no such payment is authorized,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $25,000 or imprisoned for not more than five years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6647158-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1909, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s901"},"text":"Pub. L. 97–35, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/542"},"text":"95 Stat. 542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6647159-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb664715a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb664715b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s901"},"text":"section 901 of Pub. L. 97–35","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300w"},"text":"section 300w of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
