{"tag":"section","attrib":{"id":"idbb8fafe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862o–7"},"text":"§ 1862o–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyberinfrastructure","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to continue and expand efforts to ensure that research institutions throughout the Nation can fully participate in research programs of the Foundation and collaborate with colleagues throughout the Nation, the Director, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":", shall develop and publish a plan that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb8fafe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–7/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the current status of broadband access for scientific research purposes at institutions in EPSCoR-eligible States, at institutions in rural areas, and at minority serving institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb8fafe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862o–7/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines actions that can be taken to ensure that such connections are available to enable participation in those Foundation programs that rely heavily on high-speed networking and collaborations across institutions and regions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb8fafe8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7020"},"text":"Pub. L. 110–69, title VII, § 7020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/685"},"text":"121 Stat. 685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb8fafe9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb8fafea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb8fafeb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Act, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb8fafec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb8fafed-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/s7001"},"text":"section 7001 of Pub. L. 110–69","children":[],"tail":", set out as a note under section 1862"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
