{"tag":"section","attrib":{"id":"idc067c4d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753"},"text":null,"children":[{"tag":"num","attrib":{"value":"18753"},"text":"§ 18753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil nuclear credit program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc067c4d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified nuclear reactor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “certified nuclear reactor” means a nuclear reactor that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competes in a competitive electricity market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified under subsection (c)(2)(A)(i) to submit a sealed bid in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “credit” means a credit allocated to a certified nuclear reactor under subsection (e)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c4de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a civil nuclear credit program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate nuclear reactors that are projected to cease operations due to economic factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allocate credits to certified nuclear reactors that are selected under paragraph (1)(B) of subsection (e) to receive credits under paragraph (2) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c4e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c4e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be certified under paragraph (2)(A)(i), the owner or operator of a nuclear reactor that is projected to cease operations due to economic factors shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be appropriate, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on the operating costs necessary to make the determination described in paragraph (2)(A)(ii)(I), including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c4e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average projected annual operating loss in dollars per megawatt-hour, inclusive of the cost of operational and market risks, expected to be incurred by the nuclear reactor over the 4-year period for which credits would be allocated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any private or publicly available data with respect to current or projected bulk power market prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out-of-market revenue streams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations and maintenance costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital costs, including fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational and market risks;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the potential incremental air pollutants that would result if the nuclear reactor were to cease operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" known information on the source of produced uranium and the location where the uranium is converted, enriched, and fabricated into fuel assemblies for the nuclear reactor for the 4-year period for which credits would be allocated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed plan to sustain operations at the conclusion of the applicable 4-year period for which credits would be allocated—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c4ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without receiving additional credits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the receipt of additional credits of a lower amount than the credits allocated during that 4-year credit period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall accept applications described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the date that is 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than every year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c4f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments from State programs","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of a nuclear reactor that receives a payment from a State zero-emission credit, a State clean energy contract, or any other State program with respect to that nuclear reactor shall be eligible to submit an application under subparagraph (A) with respect to that nuclear reactor during any application period beginning after the 120-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted by an owner or operator described in clause (i) with respect to a nuclear reactor described in that clause shall include all projected payments from State programs in determining the average projected annual operating loss described in subparagraph (A)(i)(I), unless the credits allocated to the nuclear reactor pursuant to that application will be used to reduce those payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c4f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination to certify","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c4f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c4f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the applicable date under subparagraph (B) of paragraph (1), the Secretary shall determine whether to certify, in accordance with clauses (ii) and (iii), each nuclear reactor for which an application is submitted under subparagraph (A) of that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall only certify a nuclear reactor under clause (i) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c4fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after considering the information submitted under paragraph (1)(A)(i), the Secretary determines that the nuclear reactor is projected to cease operations due to economic factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after considering the estimate submitted under paragraph (1)(A)(ii), the Secretary determines that pollutants would increase if the nuclear reactor were to cease operations and be replaced with other types of power generation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c4fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Nuclear Regulatory Commission has reasonable assurance that the nuclear reactor—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc067c4fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will continue to be operated in accordance with the current licensing basis (as defined in section 54.3 of title 10, Code of Federal Regulations (or successor regulations) ","children":[{"tag":"ref","attrib":{"idref":"fn004374"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004374"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a second closing parenthesis."}],"tail":" of the nuclear reactor; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc067c4fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/ii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poses no significant safety hazards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c4ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to certify a nuclear reactor under clause (i), the Secretary shall give priority to a nuclear reactor that uses, to the maximum extent available, uranium that is produced, converted, enriched, and fabricated into fuel assemblies in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each application received under paragraph (1)(A), the Secretary shall provide to the applicable owner or operator, as applicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of the certification of the applicable nuclear reactor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice that describes the reasons why the certification of the applicable nuclear reactor was denied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bidding process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Secretary shall establish a deadline by which each certified nuclear reactor shall submit to the Secretary a sealed bid that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the price per megawatt-hour of the credits desired by the certified nuclear reactor, which shall not exceed the average projected annual operating loss described in subsection (c)(1)(A)(i)(I); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a commitment, subject to the receipt of credits, to provide a specific number of megawatt-hours of generation during the 4-year period for which credits would be allocated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The deadline established under paragraph (1) shall be not later than 30 days after the first date on which the Secretary has made the determination described in paragraph (2)(A)(i) of subsection (c) with respect to each application submitted under paragraph (1)(A) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2209"},"text":"section 2209 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c50a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the heads of applicable Federal agencies, establish a process for evaluating bids submitted under subsection (d)(1) through an auction process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c50b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select certified nuclear reactors to be allocated credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c50c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (f)(2), on selection under paragraph (1), a certified nuclear reactor shall be allocated credits for a 4-year period beginning on the date of the selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c50d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall use the amounts made available for credits under this section to allocate credits to as many certified nuclear reactors as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c50e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c50f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of a certified nuclear reactor may seek to recertify the nuclear reactor in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary may not allocate any credits after ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 4-year period beginning on the date on which a certified nuclear reactor first receives a credit, the Secretary shall periodically audit the certified nuclear reactor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, by regulation, provide for the recapture of the allocation of any credit to a certified nuclear reactor that, during the period described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminates operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not operate at an annual loss in the absence of an allocation of credits to the certified nuclear reactor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to ensure that any confidential, private, proprietary, or privileged information that is included in a sealed bid submitted under this section is not publicly disclosed or otherwise improperly used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-01-01"},"text":"January 1, 2024","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a report with respect to the credits allocated to certified nuclear reactors, which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the credits in avoiding air pollutants while ensuring grid reliability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a quantification of the ratepayer savings achieved under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c51a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations to renew or expand the credits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c51b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18753/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $6,000,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc067c51c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40323"},"text":"Pub. L. 117–58, div. D, title III, § 40323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1019"},"text":"135 Stat. 1019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc067c51d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc067c51e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc067c51f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
