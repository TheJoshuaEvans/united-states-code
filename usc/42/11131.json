{"tag":"section","attrib":{"id":"idbf38e228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131"},"text":null,"children":[{"tag":"num","attrib":{"value":"11131"},"text":"§ 11131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requiring reports on medical malpractice payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity (including an insurance company) which makes payment under a policy of insurance, self-insurance, or otherwise in settlement (or partial settlement) of, or in satisfaction of a judgment in, a medical malpractice action or claim shall report, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134"},"text":"section 11134 of this title","children":[],"tail":", information respecting the payment and circumstances thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e22a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be reported","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information to be reported under subsection (a) includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e22b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of any physician or licensed health care practitioner for whose benefit the payment is made,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e22c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e22d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name (if known) of any hospital with which the physician or practitioner is affiliated or associated,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e22e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the acts or omissions and injuries or illnesses upon which the action or claim was based, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e22f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary determines is required for appropriate interpretation of information reported under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions for failure to report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any entity that fails to report information on a payment required to be reported under this section shall be subject to a civil money penalty of not more than $10,000 for each such payment involved. Such penalty shall be imposed and collected in the same manner as civil money penalties under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"section 1320a–7a of this title","children":[],"tail":" are imposed and collected under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on treatment of small payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall study and report to Congress, not later than two years after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":", on whether information respecting small payments should continue to be required to be reported under subsection (a) and whether information respecting all claims made concerning a medical malpractice action should be required to be reported under such subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e232-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s421"},"text":"Pub. L. 99–660, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3788"},"text":"100 Stat. 3788","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
