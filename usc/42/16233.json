{"tag":"section","attrib":{"id":"idbffa0f4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233"},"text":null,"children":[{"tag":"num","attrib":{"value":"16233"},"text":"§ 16233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-cost renewable hydrogen and infrastructure for vehicle propulsion","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a research, development, and demonstration program to determine the feasibility of using hydrogen propulsion in light-weight vehicles and the integration of the associated hydrogen production infrastructure using off-the-shelf components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify universities and institutions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0f52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expertise in researching and testing vehicles fueled by hydrogen, methane, and other fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expertise in integrating off-the-shelf components to minimize cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within 2 years can test a vehicle based on an existing commercially available platform with a curb weight of not less than 2,000 pounds before modifications, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0f55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates solely on hydrogen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifies as a light-duty passenger vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16233/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses hydrogen produced from water using only solar energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f58-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s933"},"text":"Pub. L. 109–58, title IX, § 933","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/872"},"text":"119 Stat. 872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
