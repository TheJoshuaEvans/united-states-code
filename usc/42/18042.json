{"tag":"section","attrib":{"id":"idc04b14d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042"},"text":null,"children":[{"tag":"num","attrib":{"value":"18042"},"text":"§ 18042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal program to assist establishment and operation of nonprofit, member-run health insurance issuers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc04b14d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b14d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to carry out the purposes of this section to be known as the Consumer Operated and Oriented Plan (CO–OP) program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of the CO–OP program to foster the creation of qualified nonprofit health insurance issuers to offer qualified health plans in the individual and small group markets in the States in which the issuers are licensed to offer such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b14d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans and grants under the CO–OP program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b14d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide through the CO–OP program for the awarding to persons applying to become qualified nonprofit health insurance issuers of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans to provide assistance to such person in meeting its start-up costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to provide assistance to such person in meeting any solvency requirements of States in which the person seeks to be licensed to issue qualified health plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for awarding loans and grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding loans and grants under the CO–OP program, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b14da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the recommendations of the advisory board established under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to applicants that will offer qualified health plans on a Statewide basis, will utilize integrated care models, and have significant private support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that there is sufficient funding to establish at least 1 qualified nonprofit health insurance issuer in each State, except that nothing in this clause shall prohibit the Secretary from funding the establishment of multiple qualified nonprofit health insurance issuers in any State if the funding is sufficient to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States without issuers in program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no health insurance issuer applies to be a qualified nonprofit health insurance issuer within a State, the Secretary may use amounts appropriated under this section for the awarding of grants to encourage the establishment of a qualified nonprofit health insurance issuer within the State or the expansion of a qualified nonprofit health insurance issuer from another State to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b14df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require any person receiving a loan or grant under the CO–OP program to enter into an agreement with the Secretary which requires such person to meet (and to continue to meet)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04b14e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement under this section for such person to be treated as a qualified nonprofit health insurance issuer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04b14e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirements contained in the agreement for such person to receive such loan or grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of Federal funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement shall include a requirement that no portion of the funds made available by any loan or grant under this section may be used—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04b14e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for carrying on propaganda, or otherwise attempting, to influence legislation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04b14e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for marketing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" Nothing in this clause shall be construed to allow a person to take any action prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/29"},"text":"section 501(c)(29) of title 26","children":[],"tail":"."}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a person has failed to meet any requirement described in clause (i) or (ii) and has failed to correct such failure within a reasonable period of time of when the person first knows (or reasonably should have known) of such failure, such person shall repay to the Secretary an amount equal to the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc04b14e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 110 percent of the aggregate amount of loans and grants received under this section; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc04b14e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the aggregate amount of loans and grants received under this section for the period the loans or grants were outstanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" The Secretary shall notify the Secretary of the Treasury of any determination under this section of a failure that results in the termination of an issuer’s tax-exempt status under section 501(c)(29) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for awarding loans and grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not later than ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", award the loans and grants under the CO–OP program and begin the distribution of amounts awarded under such loans and grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of loans and grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", and prior to awarding loans and grants under the CO–OP program, the Secretary shall promulgate regulations with respect to the repayment of such loans and grants in a manner that is consistent with State solvency regulations and other similar State laws that may apply. In promulgating such regulations, the Secretary shall provide that such loans shall be repaid within 5 years and such grants shall be repaid within 15 years, taking into consideration any appropriate State reserve requirements, solvency regulations, and requisite surplus note arrangements that must be constructed in a State to provide for such repayment prior to awarding such loans and grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory board under this paragraph shall consist of 15 members appointed by the Comptroller General of the United States from among individuals with qualifications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395b–6/c/2"},"text":"section 1395b–6(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules relating to appointments","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b14ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual appointed under subparagraph (A) shall meet ethics and conflict of interest standards protecting against insurance industry involvement and interference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The original appointment of board members under subparagraph (A)(ii) shall be made no later than 3 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the advisory board shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay and reimbursement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc04b14f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation for members of advisory board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), a member of the advisory board may not receive pay, allowances, or benefits by reason of their service on the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc04b14f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall receive travel expenses, including per diem in lieu of subsistence under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall apply to the advisory board, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory board shall terminate on the earlier of the date that it completes its duties under this section or ","children":[{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b14f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified nonprofit health insurance issuer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b14f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified nonprofit health insurance issuer” means a health insurance issuer that is an organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is organized under State law as a nonprofit, member corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially all of the activities of which consist of the issuance of qualified health plans in the individual and small group markets in each State in which it is licensed to issue such plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets the other requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain organizations prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization shall not be treated as a qualified nonprofit health insurance issuer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization or a related entity (or any predecessor of either) was a health insurance issuer on ","children":[{"tag":"date","attrib":{"date":"2009-07-16"},"text":"July 16, 2009","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization is sponsored by a State or local government, any political subdivision thereof, or any instrumentality of such government or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b14fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization shall not be treated as a qualified nonprofit health insurance issuer unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b14fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governance of the organization is subject to a majority vote of its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b14ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its governing documents incorporate ethics and conflict of interest standards protecting against insurance industry involvement and interference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b1500-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in regulations promulgated by the Secretary, the organization is required to operate with a strong consumer focus, including timeliness, responsiveness, and accountability to members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Profits inure to benefit of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization shall not be treated as a qualified nonprofit health insurance issuer unless any profits made by the organization are required to be used to lower premiums, to improve benefits, or for other programs intended to improve the quality of health care delivered to its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State insurance laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization shall not be treated as a qualified nonprofit health insurance issuer unless the organization meets all the requirements that other issuers of qualified health plans are required to meet in any State where the issuer offers a qualified health plan, including solvency and licensure requirements, rules on payments to providers, and compliance with network adequacy rules, rate and form filing rules, any applicable State premium assessments and any other State law described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18044/b"},"text":"section 18044(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State insurance reforms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization shall not be treated as a qualified nonprofit health insurance issuer unless the organization does not offer a health plan in a State until that State has in effect (or the Secretary has implemented for the State) the market reforms required by part A of title XXVII of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"42 U.S.C. 300gg","children":[],"tail":" et seq.] (as amended by subtitles A and C of this Act)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of private purchasing council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Qualified nonprofit health insurance issuers participating in the CO–OP program under this section may establish a private purchasing council to enter into collective purchasing arrangements for items and services that increase administrative and other cost efficiencies, including claims administration, administrative services, health information technology, and actuarial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council may not set payment rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The private purchasing council established under paragraph (1) shall not set payment rates for health care facilities or providers participating in health insurance coverage provided by qualified nonprofit health insurance issuers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued application of antitrust laws","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b1508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the application of the antitrust laws to any private purchasing council (whether or not established under this subsection) or to any qualified nonprofit health insurance issuer participating in such a council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b1509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, the term “antitrust laws” has the meaning given the term in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of title 15","children":[],"tail":". Such term also includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of title 15","children":[],"tail":" to the extent that such section 45 applies to unfair methods of competition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b150a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No representative of any Federal, State, or local government (or of any political subdivision or instrumentality thereof), and no representative of a person described in subsection (c)(2)(A), may serve on the board of directors of a qualified nonprofit health insurance issuer or with a private purchasing council established under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b150b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b150c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc04b150d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in any negotiations between 1 or more qualified nonprofit health insurance issuers (or a private purchasing council established under subsection (d)) and any health care facilities or providers, including any drug manufacturer, pharmacy, or hospital; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc04b150e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or maintain a price structure for reimbursement of any health benefits covered by such issuers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b150f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as authorizing the Secretary to interfere with the competitive nature of providing health benefits through qualified nonprofit health insurance issuers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby appropriated, out of any funds in the Treasury not otherwise appropriated, $6,000,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc04b1512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc04b1513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the General Accountability Office shall conduct an ongoing study on competition and market concentration in the health insurance market in the United States after the implementation of the reforms in such market under the provisions of, and the amendments made by, this Act. Such study shall include an analysis of new issuers of health insurance in such market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc04b1514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18042/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall, not later than December 31 of each even-numbered year (beginning with 2014), report to the appropriate committees of the Congress the results of the study conducted under paragraph (1), including any recommendations for administrative or legislative changes the Comptroller General determines necessary or appropriate to increase competition in the health insurance market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc04b1515-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1322"},"text":"Pub. L. 111–148, title I, § 1322","children":[],"tail":", title X, § 10104("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/187"},"text":"124 Stat. 187","children":[],"tail":", 902; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/282"},"text":"Pub. L. 117–286, § 4(a)(282)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4337"},"text":"136 Stat. 4337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc04b1516-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc04b1517-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc04b1518-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (c)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Part A of title XXVII of the Act is classified generally to part A (§ 300gg et seq.) of subchapter XXV of chapter 6A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subtitles A and C of this Act, referred to in subsec. (c)(6), are subtitles A (§§ 1001–1004) and C (§§ 1201–1255), respectively, of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 154. Subtitle A enacted sections 300gg–11 to 300gg–19, 300gg–93, and 300gg–94 of this title, transferred sections 300gg–4 to 300gg–7 and 300gg–13 of this title to sections 300gg–25 to 300gg–28 and 300gg–9 of this title, respectively, amended sections 300gg–11, 300gg–12, and 300gg–21 to 300gg–23 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":". Subtitle C enacted subchapter II of this chapter and sections 300gg to 300gg–2 and 300gg–4 to 300gg–7 of this title, transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":", amended sections 300gg–1 and 300gg–4 of this title, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":". For complete classification of subtitles A and C to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (i)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc04b1519-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1322"},"text":"section 1322 of Pub. L. 111–148","children":[],"tail":". Subsec. (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1322"},"text":"section 1322 of Pub. L. 111–148","children":[],"tail":" amended sections 501, 4958, and 6033 of Title 26, Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc04b151a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5 shall apply to the advisory board, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":"” for “The Federal Advisory Committee Act (5 U.S.C. App.) shall apply to the advisory board, except that section 14 of such Act” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10104"},"text":"Pub. L. 111–148, § 10104","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc04b151b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc04b151c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consumer Operated and Oriented Plan Program Contingency Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVI/s644"},"text":"Pub. L. 112–240, title VI, § 644","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2362"},"text":"126 Stat. 2362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/240/tVI/s644"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services shall establish a fund to be used to provide assistance and oversight to qualified nonprofit health insurance issuers that have been awarded loans or grants under section 1322 of the Patient Protection and Affordable Care Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18042"},"text":"42 U.S.C. 18042","children":[],"tail":") prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer and Rescission.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From the unobligated balance of funds appropriated under section 1322(g) of the Patient Protection and Affordable Care Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18042/g"},"text":"42 U.S.C. 18042(g)","children":[],"tail":"), 10 percent of such sums are hereby transferred to the fund established under subsection (a) to remain available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided for in paragraph (1), amounts appropriated under section 1322(g) of the Patient Protection and Affordable Care Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18042/g"},"text":"42 U.S.C. 18042(g)","children":[],"tail":") that are unobligated as of the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"] are rescinded.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
