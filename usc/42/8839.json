{"tag":"section","attrib":{"id":"idbea776d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839"},"text":null,"children":[{"tag":"num","attrib":{"value":"8839"},"text":"§ 8839.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Energy from Municipal Waste","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea776d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment in Department of Energy; appointment of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established within the Department of Energy an Office of Energy from Municipal Waste (hereinafter in this section referred to as the “Office”) to be headed by a Director, who shall be appointed by the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea776da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the function of the Office to perform—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea776db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research, development, demonstration, and commercialization activities authorized under this subchapter (including those authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8837"},"text":"section 8837 of this title","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea776dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other duties relating to the production of energy from municipal waste as the Secretary of Energy may assign to the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea776dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations respecting implementation of functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out functions tranferred ","children":[{"tag":"ref","attrib":{"idref":"fn003855"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003855"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “transferred”."}],"tail":" or assigned to the Office, the Secretary of Energy shall consult with the Administrator of the Environmental Protection Agency, the Secretary of Commerce, and the heads of such other Federal agencies, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea776de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8839/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of related functions and personnel from Department of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the transfer to the Office of the functions relating to, and personnel of the Department who are responsible for the administration of, programs in existence on ","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", which relate to the research, development, demonstration, and commercialization of technologies for the recovery of energy from municipal waste."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea776df-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s239"},"text":"Pub. L. 96–294, title II, § 239","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/704"},"text":"94 Stat. 704","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
