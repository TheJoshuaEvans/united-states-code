{"tag":"section","attrib":{"id":"idbe0eb9d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–15"},"text":"§ 7385s–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0eb9d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of Labor an office to be known as the “Office of the Ombudsman” (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the Office shall be the Ombudsman. The individual serving as Ombudsman shall be either of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0eb9d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer or employee of the Department of Labor designated by the Secretary for purposes of this section from among officers and employees of the Department who have experience and expertise necessary to carry out the duties of the Office specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual employed by the Secretary from the private sector from among individuals in the private sector who have experience and expertise necessary to carry out the duties of the Office specified in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Office shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0eb9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide information on the benefits available under this part and part B and on the requirements and procedures applicable to the provision of such benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide guidance and assistance to claimants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make recommendations to the Secretary regarding the location of centers (to be known as “resource centers”) for the acceptance and development of claims for benefits under this part and part B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out such other duties with respect to this part and part B as the Secretary shall specify for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take appropriate actions to ensure the independence of the Office within the Department of Labor, including independence from other officers and employees of the Department engaged in activities relating to the administration of the provisions of this part and part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0eb9e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than July 30 each year, the Ombudsman shall submit to Congress a report on activities under this part and part B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under paragraph (1) shall set forth the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0eb9e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and types of complaints, grievances, and requests for assistance received by the Ombudsman under this part and part B during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb9e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the most common difficulties encountered by claimants and potential claimants under this part and part B during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The first report under paragraph (1) shall be the report submitted in 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb9e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the submission to Congress of the annual report under paragraph (1), the Secretary shall submit to Congress in writing, and post on the public Internet website of the Department of Labor, a response to the report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0eb9e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a statement of whether the Secretary agrees or disagrees with the specific issues raised by the Ombudsman in the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb9e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary agrees with the Ombudsman on those issues, describes the actions to be taken to correct those issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb9e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary does not agree with the Ombudsman on those issues, describes the reasons the Secretary does not agree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor and the Secretary of Health and Human Services shall each undertake outreach to advise the public of the existence and duties of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb9ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–15/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute for Occupational Safety and Health Ombudsman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties of the Ombudsman under this section, the Ombudsman shall work with the individual employed by the National Institute for Occupational Safety and Health to serve as an ombudsman to individuals making claims under part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0eb9eb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3686"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3686]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2185"},"text":"118 Stat. 2185","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXI/s3116"},"text":"Pub. L. 110–181, div. C, title XXXI, § 3116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/578"},"text":"122 Stat. 578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXI/s3142/a"},"text":"Pub. L. 111–84, div. C, title XXXI, § 3142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2715"},"text":"123 Stat. 2715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXI/s3141/b"},"text":"Pub. L. 113–291, div. C, title XXXI, § 3141(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3899"},"text":"128 Stat. 3899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXI/s3134/a"},"text":"Pub. L. 116–92, div. C, title XXXI, § 3134(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1958"},"text":"133 Stat. 1958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXI/s3145"},"text":"Pub. L. 116–283, div. C, title XXXI, § 3145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4387"},"text":"134 Stat. 4387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0eb9ec-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0eb9ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe0eb9ee-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out subsec. (h) which read as follows: “Effective "},{"tag":"date","attrib":{"date":"2020-10-28"},"text":"October 28, 2020","children":[],"tail":", this section shall have no further force or effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3134/a/1"},"text":"Pub. L. 116–92, § 3134(a)(1)","children":[],"tail":", added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3134/a/2"},"text":"Pub. L. 116–92, § 3134(a)(2)","children":[],"tail":", substituted “2020” for “2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3141/b/1/A"},"text":"Pub. L. 113–291, § 3141(b)(1)(A)","children":[],"tail":", substituted “July 30” for “February 15”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3141/b/1/B"},"text":"Pub. L. 113–291, § 3141(b)(1)(B)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3141/b/2"},"text":"Pub. L. 113–291, § 3141(b)(2)","children":[],"tail":", substituted “2019” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s3142/a/1"},"text":"Pub. L. 111–84, § 3142(a)(1)","children":[],"tail":"–(3), inserted “and part B” after “this part” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s3142/a/4"},"text":"Pub. L. 111–84, § 3142(a)(4)","children":[],"tail":", (5), added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2012-10-28"},"text":"October 28, 2012","children":[],"tail":"” for “on the date that is 3 years after "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe0eb9ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe0eb9f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXI/s3142/b"},"text":"Pub. L. 111–84, div. C, title XXXI, § 3142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2716"},"text":"123 Stat. 2716","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dC/tXXXI/s3142/b"},"text":"“Except as specifically provided in subsection (g) of section 3686 of the Energy Employees Occupational Illness Compensation Program Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7385s–15/g"},"text":"42 U.S.C. 7385s–15(g)","children":[],"tail":"], as amended by subsection (a) of this section, nothing in the amendments made by such subsection (a) shall be construed to alter or affect the duties and functions of the individual employed by the National Institute for Occupational Safety and Health to serve as an ombudsman to individuals making claims under subtitle B of the Energy Employees Occupational Illness Compensation Program Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384"},"text":"42 U.S.C. 7384","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
