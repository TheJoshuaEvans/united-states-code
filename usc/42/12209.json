{"tag":"section","attrib":{"id":"idbf66335a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209"},"text":null,"children":[{"tag":"num","attrib":{"value":"12209"},"text":"§ 12209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instrumentalities of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Government Accountability Office, the Government Publishing Office, and the Library of Congress shall be covered as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf66335b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights and protections under this chapter shall, subject to paragraph (2), apply with respect to the conduct of each instrumentality of the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf66335c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of remedies and procedures by instrumentalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief official of each instrumentality of the Congress shall establish remedies and procedures to be utilized with respect to the rights and protections provided pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf66335d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief official of each instrumentality of the Congress shall, after establishing remedies and procedures for purposes of paragraph (2), submit to the Congress a report describing the remedies and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf66335e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of instrumentalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “instrumentality of the Congress” means the following:,","children":[{"tag":"ref","attrib":{"idref":"fn004038"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" the Government Accountability Office, the Government Publishing Office, and the Library of Congress,."},{"tag":"ref","attrib":{"idref":"fn004038"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf66335f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of employment rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"section 2000e–16 of this title","children":[],"tail":" shall be available to any employee of an instrumentality of the Congress who alleges a violation of the rights and protections under sections 12112 through 12114 of this title that are made applicable by this section, except that the authorities of the Equal Employment Opportunity Commission shall be exercised by the chief official of the instrumentality of the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf663360-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of rights to public services and accommodations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"section 2000e–16 of this title","children":[],"tail":" shall be available to any qualified person with a disability who is a visitor, guest, or patron of an instrumentality of Congress and who alleges a violation of the rights and protections under sections 12131 through 12150 of this title or section 12182 or 12183 of this title that are made applicable by this section, except that the authorities of the Equal Employment Opportunity Commission shall be exercised by the chief official of the instrumentality of the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf663361-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12209/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall alter the enforcement procedures for individuals with disabilities provided in the General Accounting Office Personnel Act of 1980 and regulations promulgated pursuant to that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf663362-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tV/s510"},"text":"Pub. L. 101–336, title V, § 510","children":[],"tail":", formerly § 509, "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/373"},"text":"104 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/tIII/s315"},"text":"Pub. L. 102–166, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1095"},"text":"105 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII"},"text":"Pub. L. 104–1, title II","children":[],"tail":", §§ 201(c)(3), 210(g), "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/8"},"text":"109 Stat. 8","children":[],"tail":", 16; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; renumbered § 510, "},{"tag":"ref","attrib":{"href":"/us/pl/110/325/s6/a/2"},"text":"Pub. L. 110–325, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-25"},"text":"Sept. 25, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3558"},"text":"122 Stat. 3558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf663363-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf663364-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf663365-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The General Accounting Office Personnel Act of 1980, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/191"},"text":"Pub. L. 96–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-02-15"},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/27"},"text":"94 Stat. 27","children":[],"tail":", which was classified principally to section 52–1 et seq. of former Title 31, and which was substantially repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", and reenacted by the first section thereof principally in subchapters III (§ 731 et seq.) and IV (§ 751 et seq.) of chapter 7 of Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf663366-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/s510"},"text":"section 510 of Pub. L. 101–336","children":[],"tail":" was renumbered section 511 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12210"},"text":"section 12210 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf687c57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in introductory provisions and in par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/F"},"text":"Pub. L. 104–1, § 201(c)(3)(F)","children":[],"tail":", amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/A"},"text":"Pub. L. 104–1, § 201(c)(3)(A)","children":[],"tail":", struck out subsecs. (a) and (b) which related to coverage of Senate and House of Representatives with respect to bans on employment discrimination and other discriminatory practices against individuals with disabilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/B"},"text":"Pub. L. 104–1, § 201(c)(3)(B)","children":[],"tail":", substituted “The General Accounting Office, the Government Printing Office, and the Library of Congress shall be covered as follows:” for subsec. (c) heading and designated subsec. (c) as entire section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/C"},"text":"Pub. L. 104–1, § 201(c)(3)(C)","children":[],"tail":", struck out at end “Such remedies and procedures shall apply exclusively, except for the employees who are defined as Senate employees, in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1201/c/1"},"text":"section 1201(c)(1) of title 2","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/D"},"text":"Pub. L. 104–1, § 201(c)(3)(D)","children":[],"tail":", struck out “the Architect of the Capitol, the Congressional Budget Office” after “the following:”, inserted “and” before “the Library of Congress”, and struck out “the Office of Technology Assessment, and the United States Botanic Garden” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/D"},"text":"Pub. L. 104–1, § 201(c)(3)(D)","children":[],"tail":", which in part directed the substitution of “the term ‘instrumentality of the Congress’ means” for “the instrumentalities of the Congress include”, was executed by making the substitution for “instrumentalities of the Congress include” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/E"},"text":"Pub. L. 104–1, § 201(c)(3)(E)","children":[],"tail":", added par. (5). Former par. (5) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s210/g"},"text":"Pub. L. 104–1, § 210(g)","children":[],"tail":", which directed amendment of this section by adding par. (6), was executed by adding par. (6) after par. (5) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3/E"},"text":"Pub. L. 104–1, § 201(c)(3)(E)","children":[],"tail":", redesignated par. (5) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s315/1"},"text":"Pub. L. 102–166, § 315(1)","children":[],"tail":", redesignated par. (6) as (2) and struck out former par. (2) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Application to Senate employment","children":[],"tail":".—The rights and protections provided pursuant to this chapter, the Civil Rights Act of 1990 (S. 2104, 101st Congress), the Civil Rights Act of 1964 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"42 U.S.C. 2000a","children":[],"tail":" et seq.], the Age Discrimination in Employment Act of 1967 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"29 U.S.C. 621","children":[],"tail":" et seq.], and the Rehabilitation Act of 1973 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.] shall apply with respect to employment by the United States Senate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s315/1"},"text":"Pub. L. 102–166, § 315(1)","children":[],"tail":", redesignated par. (7) as (3), substituted “(2)(A)” for “(2) and (6)(A)” and “(2)” for “(3), (4), (5), (6)(B), and (6)(C)”, and struck out former par. (3) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Investigation and adjudication of claims","children":[],"tail":".—All claims raised by any individual with respect to Senate employment, pursuant to the Acts referred to in paragraph (2), shall be investigated and adjudicated by the Select Committee on Ethics, pursuant to S. Res. 338, 88th Congress, as amended, or such other entity as the Senate may designate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s315/1"},"text":"Pub. L. 102–166, § 315(1)","children":[],"tail":", struck out pars. (4) and (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ","children":[{"tag":"inline","attrib":{},"text":"Rights of employees","children":[],"tail":".—The Committee on Rules and Administration shall ensure that Senate employees are informed of their rights under the Acts referred to in paragraph (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ","children":[{"tag":"inline","attrib":{},"text":"Applicable Remedies","children":[],"tail":".—When assigning remedies to individuals found to have a valid claim under the Acts referred to in paragraph (2), the Select Committee on Ethics, or such other entity as the Senate may designate, should to the extent practicable apply the same remedies applicable to all other employees covered by the Acts referred to in paragraph (2). Such remedies shall apply exclusively.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s315/1"},"text":"Pub. L. 102–166, § 315(1)","children":[],"tail":", redesignated pars. (6) and (7) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166/s315/2"},"text":"Pub. L. 102–166, § 315(2)","children":[],"tail":", inserted “, except for the employees who are defined as Senate employees, in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1201/c/1"},"text":"section 1201(c)(1) of title 2","children":[],"tail":"” after “shall apply exclusively”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf687c58-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbf687c59-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in introductory provisions and par. (4) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf687c5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s201/c/3"},"text":"section 201(c)(3) of Pub. L. 104–1","children":[],"tail":" effective 1 year after "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1311/e"},"text":"section 1311(e) of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1/s210/g"},"text":"section 210(g) of Pub. L. 104–1","children":[],"tail":" effective 1 year after transmission to Congress of study under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of Title 2","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1331/i/2"},"text":"section 1331(i)(2) of Title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf687c5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/166"},"text":"Pub. L. 102–166","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-11-21"},"text":"Nov. 21, 1991","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/166/s402"},"text":"section 402 of Pub. L. 102–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1981"},"text":"section 1981 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
