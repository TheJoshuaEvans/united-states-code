{"tag":"section","attrib":{"id":"idbda5e58b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6398"},"text":null,"children":[{"tag":"num","attrib":{"value":"6398"},"text":"§ 6398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any authorization of appropriations in this Act, or in any amendment to any other law made by this Act, for the fiscal year 1976 shall be deemed to include an additional authorization of appropriations for the period beginning ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", in amounts which equal one-fourth of any amount authorized for fiscal year 1976, unless appropriations for the same purpose are specifically authorized in a law hereinafter enacted."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbda5e58c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tV/s528"},"text":"Pub. L. 94–163, title V, § 528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/964"},"text":"89 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda5e58d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda5e58e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbda5e58f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163"},"text":"Pub. L. 94–163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/871"},"text":"89 Stat. 871","children":[],"tail":", known as the Energy Policy and Conservation Act, which is classified principally to this chapter (§ 6201 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
