{"tag":"section","attrib":{"id":"idc06c7fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831"},"text":null,"children":[{"tag":"num","attrib":{"value":"18831"},"text":"§ 18831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for energy efficiency improvements and renewable energy improvements at public school facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c8000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c8001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fueled vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative fueled vehicle” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13211"},"text":"section 13211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fueled vehicle infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative fueled vehicle infrastructure” means infrastructure used to charge or fuel an alternative fueled vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a consortium of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 local educational agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c8006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations that have the knowledge and capacity to partner and assist with energy improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for-profit organizations that have the knowledge and capacity to partner and assist with energy improvements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community partners that have the knowledge and capacity to partner and assist with energy improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c800a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy improvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy improvement” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c800b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any improvement, repair, or renovation to a school that results in a direct reduction in school energy costs, including improvements to the envelope, air conditioning system, ventilation system, heating system, domestic hot water heating system, compressed air system, distribution system, lighting system, power system, and controls of a building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c800c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any improvement, repair, or renovation to, or installation in, a school that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c800d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leads to an improvement in teacher and student health, including indoor air quality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c800e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieves energy savings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c800f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any improvement, repair, or renovation to a school involving the installation of renewable energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the installation of alternative fueled vehicle infrastructure on school grounds for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c8011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclusive use of school buses, school fleets, or students; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c8012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general public; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or lease of alternative fueled vehicles to be used by a school, including school buses, fleet vehicles, and other operational vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High school","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high school” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local educational agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonprofit organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described in section 501(c)(3) of the Internal Revenue Code of 1986 and exempt from tax under section 501(a) of such Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mutual or cooperative electric company described in section 501(c)(12) of such Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnering local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnering local educational agency”, with respect to an eligible entity, means the local educational agency participating in the consortium of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c801a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award competitive grants to eligible entities to make energy improvements in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c801b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c801c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring a grant under this section shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c801d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The application submitted under paragraph (1) shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c801e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A needs assessment of the current condition of the school and school facilities that would receive the energy improvements if the application were approved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c801f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A draft work plan of the intended achievements of the eligible entity at the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the energy improvements that the eligible entity would carry out at the school if the application were approved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the capacity of the eligible entity to provide services and comprehensive support to make the energy improvements referred to in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the expected needs of the eligible entity for operation and maintenance training funds, and a plan for use of those funds, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the expected energy efficiency, energy savings, and safety benefits of the energy improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cost estimate of the proposed energy improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of other resources that are available to carry out the activities for which grant funds are requested under this section, including the availability of utility programs and public benefit funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c8026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c8027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to an eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has renovation, repair, and improvement funding needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c802a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, as determined by the Secretary, serves a high percentage of students, including students in a high school in accordance with paragraph (2), who are eligible for a free or reduced price lunch under the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c802b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partnering local educational agency of which is designated with a school district locale code of 41, 42, or 43, as determined by the National Center for Education Statistics in consultation with the Bureau of the Census; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c802c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that leverages private sector investment through energy-related performance contracting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c802d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High school students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of students in a high school, the percentage of students eligible for a free or reduced price lunch described in paragraph (1)(B)(i) shall be calculated using data from the schools that feed into the high school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c802e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The competitive criteria used by the Secretary to award grants under this section shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c802f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extent of the disparity between the fiscal capacity of the eligible entity to carry out energy improvements at school facilities and the needs of the partnering local educational agency for those energy improvements, including consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current and historic ability of the partnering local educational agency to raise funds for construction, renovation, modernization, and major repair projects for schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the partnering local educational agency to issue bonds or receive other funds to support the current infrastructure needs of the partnering local educational agency for schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bond rating of the partnering local educational agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The likelihood that the partnering local educational agency or eligible entity will maintain, in good condition, any school and school facility that is the subject of improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential energy efficiency and safety benefits from the proposed energy improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c8035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c8036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this subsection, an eligible entity receiving a grant under this section shall use the grant amounts only to make the energy improvements described in the application submitted by the eligible entity under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving a grant under this section may use not more than 5 percent of the grant amounts for operation and maintenance training for energy efficiency and renewable energy improvements, such as maintenance staff and teacher training, education, and preventative maintenance training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party investigation and analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving a grant under this section may use a portion of the grant amounts for a third-party investigation and analysis of the energy improvements carried out by the eligible entity, such as energy audits and existing building commissioning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving a grant under this section may use not more than 3 percent of the grant amounts to develop a continuing education curriculum relating to energy improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c803a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition in contracting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an eligible entity receiving a grant under this section uses grant funds to carry out repair or renovation through a contract, the eligible entity shall be required to ensure that the contract process—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c803b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through full and open competition, ensures the maximum practicable number of qualified bidders, including small, minority, and women-owned businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c803c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gives priority to businesses located in, or resources common to, the State or geographical area in which the repair or renovation under the contract will be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c803d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and publish guidelines and best practices for activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c803e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under this section shall submit to the Secretary, at such time as the Secretary may require, a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c803f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the grant funds for energy improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost savings realized by those energy improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of any third-party investigation and analysis conducted relating to those energy improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any utility programs and public benefit funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c8043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the use of performance tracking for energy improvements, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c8044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Energy Star program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c8045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/i/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Green Building Council Leadership in Energy and Environmental Design (LEED) green building rating system for existing buildings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c8046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18831/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $500,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c8047-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40541"},"text":"Pub. L. 117–58, div. D, title V, § 40541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1071"},"text":"135 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c8048-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc06c8049-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc06c804a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (a)(7), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in subsec. (d)(1)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c804b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c804c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
