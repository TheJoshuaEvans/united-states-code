{"tag":"section","attrib":{"id":"idc03347ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17301"},"text":null,"children":[{"tag":"num","attrib":{"value":"17301"},"text":"§ 17301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on market manipulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is unlawful for any person, directly or indirectly, to use or employ, in connection with the purchase or sale of crude oil ","children":[{"tag":"ref","attrib":{"idref":"fn004271"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004271"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" gasoline or petroleum distillates at wholesale, any manipulative or deceptive device or contrivance, in contravention of such rules and regulations as the Federal Trade Commission may prescribe as necessary or appropriate in the public interest or for the protection of United States citizens."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc03347ef-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s811"},"text":"Pub. L. 110–140, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1723"},"text":"121 Stat. 1723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03347f0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc03347f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc03347f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
