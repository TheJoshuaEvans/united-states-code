{"tag":"section","attrib":{"id":"idbda373c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6374b"},"text":"§ 6374b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fuels bus program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbda373c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with the Administrator of the Environmental Protection Agency and the Administrator of the National Highway Traffic Safety Administration, shall, beginning in the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", assist State and local government agencies in the testing in urban settings of buses capable of operating on alternative fuels for the emissions levels, durability, safety, and fuel economy of such buses, comparing the different types with each other and with diesel powered buses, as such buses will be required to operate under Federal safety and environmental standards applicable to such buses for the model year 1991. To the extent practicable, testing assisted under this section shall apply to each of the various types of alternative fuel buses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda373c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for the period encompassing the fiscal years ending ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", a total of $2,000,000 to carry out the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbda373c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6374b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Bus” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “bus” means a vehicle which is designed to transport 30 individuals or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbda373ca-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s400CC"},"text":"Pub. L. 94–163, title III, § 400CC","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/494/s4/a"},"text":"Pub. L. 100–494, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-14"},"text":"Oct. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2445"},"text":"102 Stat. 2445","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIV/s402/1"},"text":"Pub. L. 102–486, title IV, § 402(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2875"},"text":"106 Stat. 2875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbda373cb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbda373cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbda373cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" substituted “alternative fuels” for “alcohol and buses capable of operating on natural gas” and “each of the various types of alternative fuel buses” for “both buses capable of operating on alcohol and buses capable of operating on natural gas”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
