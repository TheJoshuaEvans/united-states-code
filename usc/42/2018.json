{"tag":"section","attrib":{"id":"idbbd73fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2018"},"text":null,"children":[{"tag":"num","attrib":{"value":"2018"},"text":"§ 2018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect the authority or regulations of any Federal, State, or local agency with respect to the generation, sale, or transmission of electric power produced through the use of nuclear facilities licensed by the Commission: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this section shall not be deemed to confer upon any Federal, State, or local agency any authority to regulate, control, or restrict any activities of the Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbd73fd6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 271, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/960"},"text":"68 Stat. 960","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/135"},"text":"Pub. L. 89–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-24"},"text":"Aug. 24, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/551"},"text":"79 Stat. 551","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"}