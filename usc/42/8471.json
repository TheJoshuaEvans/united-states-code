{"tag":"section","attrib":{"id":"idbe991f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8471"},"text":null,"children":[{"tag":"num","attrib":{"value":"8471"},"text":"§ 8471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on environmental requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe991f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with applicable environmental requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8374"},"text":"section 8374 of this title","children":[],"tail":", nothing in this chapter shall be construed as permitting any existing or new electric powerplant to delay or avoid compliance with applicable environmental requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe991f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local environmental requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any new or existing facility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is subject to any prohibition under this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is also subject to any requirement of any local environmental requirement which may be stricter than any Federal or State environmental requirement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the existence of such local requirement shall not be construed to affect the validity or applicability of such prohibition to such facility, except to the extent provided under section 8322(b) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8352/b"},"text":"section 8352(b) of this title","children":[],"tail":"; and the existence of such prohibition shall not be construed to preempt such local requirement with respect to that facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe991f42-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVII/s761"},"text":"Pub. L. 95–620, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3345"},"text":"92 Stat. 3345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/23"},"text":"Pub. L. 100–42, § 1(c)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/314"},"text":"101 Stat. 314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe991f43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe991f44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe991f45-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe991f46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42"},"text":"Pub. L. 100–42","children":[],"tail":" struck out “or major fuel-burning installation” after “powerplant”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
