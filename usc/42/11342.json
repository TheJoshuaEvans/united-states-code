{"tag":"section","attrib":{"id":"idbf4256d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11342"},"text":null,"children":[{"tag":"num","attrib":{"value":"11342"},"text":"§ 11342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of interest earned","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Interest accrued on the balance of any grant to the National Board shall be available to the National Board for reallocation, and total administrative costs shall be determined based on total amount of funds available, including interest and any private contributions that are made to the National Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf4256d3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIII/s312"},"text":"Pub. L. 100–77, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/492"},"text":"101 Stat. 492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
