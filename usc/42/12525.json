{"tag":"section","attrib":{"id":"idbf7219cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525"},"text":null,"children":[{"tag":"num","attrib":{"value":"12525"},"text":"§ 12525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7219cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications to Corporation for allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12524"},"text":"section 12524 of this title","children":[],"tail":", a State, acting through the State educational agency, territory, or Indian tribe shall prepare and submit to the Corporation an application at such time and in such manner as the Chief Executive Officer may reasonably require, and obtain approval of the application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523"},"text":"section 12523 of this title","children":[],"tail":" shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal for a 3-year plan promoting service-learning, which shall contain such information as the Chief Executive Officer may reasonably require, including how the applicant will integrate service opportunities into the academic program of the participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about the criteria the State educational agency, territory, or Indian tribe will use to evaluate and grant approval to applications submitted under subsection (b), including an assurance that the State educational agency, territory, or Indian tribe will comply with the requirement in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12526/a"},"text":"section 12526(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances about the applicant’s efforts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf7219d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that students of different ages, races, sexes, ethnic groups, disabilities, and economic backgrounds have opportunities to serve together;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7219d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any opportunities for students, enrolled in schools or programs of education providing elementary or secondary education, to participate in service-learning programs and ensure that such service-learning programs include opportunities for such students to serve together;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7219d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve participants in the design and operation of the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7219d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote service-learning in areas of greatest need, including low-income or rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf7219d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise integrate service opportunities into the academic program of the participants; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the applicant will comply with the nonduplication and nondisplacement requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12637"},"text":"section 12637 of this title","children":[],"tail":" and the notice, hearing, and grievance procedures required by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12636"},"text":"section 12636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7219d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to State, territory, or Indian tribe for assistance to carry out school-based service-learning programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7219da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7219db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified organization, Indian tribe, territory, local educational agency, for-profit business, private elementary school or secondary school, or institution of higher education that desires to receive financial assistance under this subpart ","children":[{"tag":"ref","attrib":{"idref":"fn004053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this part”."}],"tail":" from a State, territory, or Indian tribe for an activity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a/1"},"text":"section 12523(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnership described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a/2"},"text":"section 12523(a)(2) of this title","children":[],"tail":" that desires to receive such assistance from a State, territory, or Indian tribe for an activity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a/2"},"text":"section 12523(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a/3"},"text":"section 12523(a)(3) of this title","children":[],"tail":" that desires to receive such assistance from a State, territory, or Indian tribe for an activity described in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entity or partnership described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12523/a/4"},"text":"section 12523(a)(4) of this title","children":[],"tail":" that desires to receive such assistance from a State, territory, or Indian tribe for an activity described in such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7219df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entity that desires to receive such assistance from a State, territory, or Indian tribe for an activity described in section 12521(a)(5) ","children":[{"tag":"ref","attrib":{"idref":"fn004054"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall prepare, submit to the State educational agency for the State, territory, or Indian tribe, and obtain approval of, an application for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7219e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12525/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such application shall be submitted at such time and in such manner, and shall contain such information, as the agency, territory, or Indian tribe may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7219e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s113"},"text":"Pub. L. 101–610, title I, § 113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1201"},"text":"Pub. 