{"tag":"section","attrib":{"id":"idb856a4bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320c–1"},"text":"§ 1320c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of quality improvement organization","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The term “quality improvement organization” means an entity which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb856a4bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able, as determined by the Secretary, to perform its functions under this part in a manner consistent with the efficient and effective administration of this part and subchapter XVIII;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb856a4bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least one individual who is a representative of health care providers on its governing body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb856a4be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–1/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least one individual who is a representative of consumers on its governing body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb856a4bf-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1152, as added "},{"tag":"ref","attrib":{"