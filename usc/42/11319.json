I of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11311"},"text":"42 U.S.C. 11311","children":[],"tail":" et seq.) shall continue in effect, notwithstanding section 209 of such Act [this section], through the earlier of: (1) the date specified in section 106 of this division ["},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"Sept. 30, 2007","children":[],"tail":"]; or (2) the date of the enactment into law of an authorization Act relating to the McKinney-Vento Homeless Assistance Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf400d97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Extension of Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/494/s3"},"text":"Pub. L. 101–494, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1185"},"text":"104 Stat. 1185","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/400/s2"},"text":"Pub. L. 106–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1675"},"text":"114 Stat. 1675","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/400/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If upon enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":"], section 209 of the McKinney-Vento Homeless Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11319"},"text":"42 U.S.C. 11319","children":[],"tail":") provides for the termination of the Interagency Council on the Homeless on "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"October 31, 1990","children":[],"tail":", then notwithstanding such section, the Interagency Council on the Homeless shall cease to exist, and the requirements of title II of the McKinney-Vento Homeless Assistance Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11311"},"text":"42 U.S.C. 11311","children":[],"tail":" et seq.] shall terminate, on "},{"tag":"date","attrib":{"date":"1990-11-30"},"text":"November 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If upon enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-10-31"},"text":"Oct. 31, 1990","children":[],"tail":"] such section 209 provides for termination of the Council (referred to in subsection (a)) on a date other than "},{"tag":"date","attrib":{"date":"1990-10-31"},"text":"October 31, 1990","children":[],"tail":", this section shall not apply. This section shall not apply with respect to any amendment to section 209 of the McKinney-Vento Homeless Assistance Act made after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
