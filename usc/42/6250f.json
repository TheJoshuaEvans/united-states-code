{"tag":"section","attrib":{"id":"idbd7622d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6250f"},"text":null,"children":[{"tag":"num","attrib":{"value":"6250f"},"text":"§ 6250f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on amount of petroleum distillate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6250"},"text":"section 6250 of this title","children":[],"tail":", for fiscal year 2012 and hereafter, the [Northeast Home Heating Oil] Reserve shall contain no more than 1 million barrels of petroleum distillate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd7622d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dB/tIII"},"text":"Pub. L. 112–74, div. B, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/869"},"text":"125 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7622d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7622d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd7622d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development and Related Agencies Appropriations Act, 2012, and also as part of the Consolidated Appropriations Act, 2012, and not as part of the Energy Policy and Conservation Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
