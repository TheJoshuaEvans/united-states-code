{"tag":"section","attrib":{"id":"idbdf230ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7142a"},"text":"§ 7142a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of American Museum of Science and Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf230ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Museum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf230af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as the “American Museum of Science and Energy”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be the official museum of science and energy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf230b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Museum is deemed to be a reference to the “American Museum of Science and Energy”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf230b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property of the United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf230b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The name “American Museum of Science and Energy” is declared the property of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Museum shall have the sole right throughout the United States and its possessions to have and use the name “American Museum of Science and Energy”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf230b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7142a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not be construed to conflict or interfere with established or vested rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf230b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tIV/s401"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title IV, § 401]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–266.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf230b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf230b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf230b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Miscellaneous Appropriations Act, 2001, and also as part of the Consolidated Appropriations Act, 2001, and not as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
