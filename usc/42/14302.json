{"tag":"section","attrib":{"id":"idbfcf0689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302"},"text":null,"children":[{"tag":"num","attrib":{"value":"14302"},"text":"§ 14302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf068a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf068b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Button cell","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “button cell” means a button- or coin-shaped battery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf068c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easily removable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “easily removable”, with respect to a battery, means detachable or removable at the end of the life of the battery—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf068d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a consumer product by a consumer with the use of common household tools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf068e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a retailer of replacements for a battery used as the principal electrical power source for a vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf068f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mercuric-oxide battery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mercuric-oxide battery” means a battery that uses a mercuric-oxide electrode.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rechargeable battery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rechargeable battery”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf0691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means 1 or more voltaic or galvanic cells, electrically connected to produce electric energy, that is designed to be recharged for repeated uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf0692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any type of enclosed device or sealed container consisting of 1 or more such cells, including what is commonly called a battery pack (and in the case of a battery pack, for the purposes of the requirements of easy removability and labeling under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14322"},"text":"section 14322 of this title","children":[],"tail":", means the battery pack as a whole rather than each component individually); but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf0693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfcf0694-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lead-acid battery used to start an internal combustion engine or as the principal electrical power source for a vehicle, such as an automobile, a truck, construction equipment, a motorcycle, a garden tractor, a golf cart, a wheelchair, or a boat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfcf0695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lead-acid battery used for load leveling or for storage of electricity generated by an alternative energy source, such as a solar cell or wind-driven generator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfcf0696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a battery used as a backup power source for memory or program instruction storage, timekeeping, or any similar purpose that requires uninterrupted electrical power in order to function if the primary energy supply fails or fluctuates momentarily; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfcf0697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/5/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rechargeable alkaline battery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rechargeable consumer product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rechargeable consumer product”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf0699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a product that, when sold at retail, includes a regulated battery as a primary energy supply, and that is primarily intended for personal or household use; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf069a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a product that only uses a battery solely as a source of backup power for memory or program instruction storage, timekeeping, or any similar purpose that requires uninterrupted electrical power in order to function if the primary energy supply fails or fluctuates momentarily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf069b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulated battery","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “regulated battery” means a rechargeable battery that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfcf069c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a cadmium or a lead electrode or any combination of cadmium and lead electrodes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfcf069d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains other electrode chemistries and is the subject of a determination by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14322/d"},"text":"section 14322(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf069e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remanufactured product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “remanufactured product” means a rechargeable consumer product that has been altered by the replacement of parts, repackaged, or repaired after initial sale by the original manufacturer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf069f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/s3"},"text":"Pub. L. 104–142, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1329"},"text":"110 Stat. 1329","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
