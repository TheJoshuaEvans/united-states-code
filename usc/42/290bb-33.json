{"tag":"section","attrib":{"id":"idb5af529c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–33"},"text":"§ 290bb–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student suicide awareness and prevention training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5af529d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–32"},"text":"section 290bb–32 of this title","children":[],"tail":", the Secretary shall give priority to applications under such section from a State educational agency, local educational agency, or Tribal educational agency, submitted directly or through a State or Indian Tribe, for funding for activities in secondary schools, where such agency has implemented, or includes in such application a plan to implement, a student suicide awareness and prevention training policy, which may include applicable youth suicide early intervention and prevention strategies implemented through "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–36"},"text":"section 290bb–36 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5af529e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and implementing a school-based student suicide awareness and prevention training policy in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af529f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with stakeholders (including principals, teachers, parents, local Tribal officials, and other relevant experts) and, as appropriate, utilizing information, models, and other resources made available by the Suicide Prevention Technical Assistance Center authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–34"},"text":"section 290bb–34 of this title","children":[],"tail":" in the development of the policy under paragraph (1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and reporting information in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In giving priority to applicants as described in subsection (a), the Secretary shall, as appropriate, take into consideration the incidence and prevalence of suicide in the applicable jurisdiction and the costs of establishing and implementing, as applicable, a school-based student suicide awareness and prevention training policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based student suicide awareness and prevention training policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A school-based student suicide awareness and prevention training policy implemented pursuant to subsection (a)(1) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5af52a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be evidence-based;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be culturally- and linguistically-appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide evidence-based training to students in grades 6 through 12, in coordination with school-based mental health resources, as applicable, regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5af52a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide prevention education and awareness, including associated risk factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5af52a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods that students can use to seek help; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5af52a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student resources for suicide awareness and prevention; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for periodic retraining of such students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information and reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State educational agency, local educational agency, and Tribal educational agency that receives priority to implement a new training policy pursuant to subsection (a)(1) shall report to the Secretary the following aggregated information, in a manner that protects personal privacy, consistent with applicable Federal and State privacy laws:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5af52ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of trainings conducted, including the number of student trainings conducted, and the training delivery method used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of students trained, disaggregated by age and grade level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of help-seeking reports made by students after implementation of such policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evidence-based program availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate with the Secretary of Education and the Secretary of the Interior to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5af52af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available the policies established by State educational agencies, local educational agencies, and Tribal educational agencies pursuant to this section and the training that is available to students and teams pursuant to such policies, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290dd–2a"},"text":"section 290dd–2a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and disseminate best practices on student suicide awareness and prevention training policies, including through the Suicide Prevention Technical Assistance Center authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–34"},"text":"section 290bb–34 of this title","children":[],"tail":", as applicable, to State educational agencies, local educational agencies, and Tribal agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", the Secretary shall report to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives the number of recipients of funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–32"},"text":"section 290bb–32 of this title","children":[],"tail":" who have implemented training policies described in subsection (a)(1) and a summary of the information received under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5af52b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5af52b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “evidence-based” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “local educational agency” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State educational agency” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5af52b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–33/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Tribal educational agency” has the meaning given to the term “tribal educational agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7452"},"text":"section 7452 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5af52b7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/100/s2/a"},"text":"Pub. L. 117–100, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/44"},"text":"136 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5af52b8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5af52b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5af52ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 290bb–33, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s520B"},"text":"act July 1, 1944, ch. 373, title V, § 520B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10410/b"},"text":"Pub. L. 111–148, title X, § 10410(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/984"},"text":"124 Stat. 984","children":[],"tail":", related to national centers of excellence for depression, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9017"},"text":"Pub. L. 114–255, div. B, title IX, § 9017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1248"},"text":"130 Stat. 1248","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 290bb–33, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tV/s520B"},"text":"act July 1, 1944, ch. 373, title V, § 520B","children":[],"tail":", formerly title XXIV, § 2441, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s211"},"text":"Pub. L. 100–607, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3092"},"text":"102 Stat. 3092","children":[],"tail":"; renumbered title V, § 520B, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s118/a"},"text":"Pub. L. 102–321, title I, § 118(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/348"},"text":"106 Stat. 348","children":[],"tail":", 349, related to demonstration projects for individuals with positive test results, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3201/b/2"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3201(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1190"},"text":"114 Stat. 1190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5af52bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5af52bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/100/s3"},"text":"Pub. L. 117–100, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/46"},"text":"136 Stat. 46","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/100/s3"},"text":"“The amendment made by this Act [enacting this section] shall apply only with respect to applications for assistance under section 520A of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290bb–32"},"text":"42 U.S.C. 290bb–32","children":[],"tail":") that are submitted after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
