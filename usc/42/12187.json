{"tag":"section","attrib":{"id":"idbf6632cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12187"},"text":null,"children":[{"tag":"num","attrib":{"value":"12187"},"text":"§ 12187.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions for private clubs and religious organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall not apply to private clubs or establishments exempted from coverage under title II of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000"},"text":"42 U.S.C. 2000","children":[],"tail":"–a(e)) ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"42 U.S.C. 2000a","children":[],"tail":" et seq.] or to religious organizations or entities controlled by religious organizations, including places of worship."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf6632cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336/tIII/s307"},"text":"Pub. L. 101–336, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/363"},"text":"104 Stat. 363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6632ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf6632cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf6632d0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail"