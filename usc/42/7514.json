{"tag":"section","attrib":{"id":"idbe3e7c96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7514"},"text":null,"children":[{"tag":"num","attrib":{"value":"7514"},"text":"§ 7514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan submission deadlines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe3e7c97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State containing an area designated or redesignated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407/d"},"text":"section 7407(d) of this title","children":[],"tail":" as nonattainment with respect to the national primary ambient air quality standards for sulfur oxides, nitrogen dioxide, or lead subsequent to "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", shall submit to the Administrator, within 18 months of the designation, an applicable implementation plan meeting the requirements of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe3e7c98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States lacking fully approved State implementation plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State containing an area designated nonattainment with respect to national primary ambient air quality standards for sulfur oxides or nitrogen dioxide under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7407/d/1/C/i"},"text":"section 7407(d)(1)(C)(i) of this title