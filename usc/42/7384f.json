{"tag":"section","attrib":{"id":"idbe09febc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384f"},"text":"§ 7384f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislative proposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe09febd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legislative proposal required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2001-03-15"},"text":"March 15, 2001","children":[],"tail":", the President shall submit to Congress a proposal for legislation to implement the compensation program. The proposal for legislation shall include, at a minimum, the specific recommendations (including draft legislation) of the President for the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09febe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of compensation and benefits, including lost wages, medical benefits, and any lump-sum settlement payments, to be provided under the compensation program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09febf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any adjustments or modifications necessary to appropriately administer the compensation program under part B.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether to expand the compensation program to include other illnesses associated with exposure to toxic substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether to expand the class of individuals who are members of the Special Exposure Cohort (as defined in section 7384","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(14) of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe09fec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of potential covered employees and required amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall include with the proposal for legislation under subsection (a) the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe09fec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the number of covered employees that the President determines were exposed in the performance of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe09fec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate, for each fiscal year of the compensation program, of the amounts to be required for compensation and benefits anticipated to be provided in such fiscal year under the compensation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe09fec5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3613"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3613]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–498.)"}],"tail":"\n"}],"tail":null}
