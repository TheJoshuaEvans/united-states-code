{"tag":"section","attrib":{"id":"idbf06d4f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906"},"text":null,"children":[{"tag":"num","attrib":{"value":"9906"},"text":"§ 9906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments and payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf06d4f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments in general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, from the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/a"},"text":"section 9903(a) of this title","children":[],"tail":" for each fiscal year that remains after the Secretary makes the reservations required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/b"},"text":"section 9903(b) of this title","children":[],"tail":", allot to each State (subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9911"},"text":"section 9911 of this title","children":[],"tail":") an amount that bears the same ratio to such remaining amount as the amount received by the State for fiscal year 1981 under section 2808 "},{"tag":"ref","attrib":{"idref":"fn003918"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003918"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title bore to the total amount received by all States for fiscal year 1981 under such section, except—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d4f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that no State shall receive less than ¼ of 1 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/a"},"text":"section 9903(a) of this title","children":[],"tail":" for such fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d4f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments in years with greater available funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d4f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), if the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/a"},"text":"section 9903(a) of this title","children":[],"tail":" for a fiscal year that remains after the Secretary makes the reservations required in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/b"},"text":"section 9903(b) of this title","children":[],"tail":" exceeds $345,000,000, the Secretary shall allot to each State not less than ½ of 1 percent of the amount appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/a"},"text":"section 9903(a) of this title","children":[],"tail":" for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of fiscal year 1990 levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply with respect to a fiscal year if the amount allotted under subsection (a) to any State for that year is less than the amount allotted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9903/a/1"},"text":"section 9903(a)(1) of this title","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":") to such State for fiscal year 1990."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount allotted under paragraph (1) to a State for a fiscal year shall be reduced, if necessary, so that the aggregate amount allotted to such State under such paragraph and subsection (a) does not exceed 140 percent of the aggregate amount allotted to such State under the corresponding provisions of this chapter for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d4fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to eligible States for the allotments described in subsections (a) and (b). The Secretary shall make payments for the grants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6503/a"},"text":"section 6503(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf06d4fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “State” does not include Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf06d4fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s675B"},"text":"Pub. L. 97–35, title VI, § 675B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2730"},"text":"112 Stat. 2730","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf06d4fd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf06d4fe-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf06d4ff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2808"},"text":"Section 2808 of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s683/a"},"text":"Pub. L. 97–35, title VI, § 683(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/519"},"text":"95 Stat. 519","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf06d500-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9906, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s677"},"text":"Pub. L. 97–35, title VI, § 677","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/516"},"text":"95 Stat. 516","children":[],"tail":", contained nondiscrimination provisions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
