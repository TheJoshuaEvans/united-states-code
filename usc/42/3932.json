{"tag":"section","attrib":{"id":"idbc9d2949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3932"},"text":null,"children":[{"tag":"num","attrib":{"value":"3932"},"text":"§ 3932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc9d294a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be created a private corporation for profit (hereinafter in this chapter referred to as the “corporation”). The corporation will not be an agency or establishment of the United States Government. The corporation shall be subject to the provisions of this chapter and, to the extent consistent with this chapter, to the District of Columbia Business Corporation Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc9d294b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of additional corporations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the President finds it in the national interest to do so, he may cause the creation of an additional corporation or additional corporations to carry out the purposes of this chapter. All the provisions of this chapter shall thereupon become applicable to each such corporation, and to the limited partnership formed by it pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3937"},"text":"section 3937 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc9d294c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of corporations and organization of other partnerships, joint ventures, or associations by private persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to preclude private persons from creating other corporations and organizing other partnerships, joint ventures, or associations for the purposes set forth in this chapter as the purposes of the corporation and the partnership described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3937"},"text":"section 3937 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc9d294d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tIX/s902"},"text":"Pub. L. 90–448, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/547"},"text":"82 Stat. 547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc9d294e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc9d294f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc9d2950-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The District of Columbia Business Corporation Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-06-08/ch269"},"text":"act June 8, 1954, ch. 269","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/179"},"text":"68 Stat. 179","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
