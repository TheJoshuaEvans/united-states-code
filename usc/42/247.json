{"tag":"section","attrib":{"id":"idb49f6932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247"},"text":null,"children":[{"tag":"num","attrib":{"value":"247"},"text":"§ 247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assisting veterans with military emergency medical training to meet requirements for becoming civilian health care professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49f6933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49f6934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a program, in consultation with the Secretary of Labor, consisting of awarding demonstration grants to States to streamline State requirements and procedures in order to assist veterans who held certain military occupational specialties related to medical care or who have completed certain medical training while serving in the Armed Forces of the United States to meet certification, licensure, and other requirements applicable to civilian health care professions (such as emergency medical technician, paramedic, licensed practical nurse, registered nurse, physical therapy assistant, or physician assistant professions) in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49f6935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the eligible military occupational specialties or training courses and the assistance required as described in paragraph (1), the Secretary shall consult with the Secretary of Defense, the Secretary of Veterans Affairs, and the Assistant Secretary of Labor for Veterans’ Employment and Training, and shall collaborate with the initiatives carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4114"},"text":"section 4114 of title 38","children":[],"tail":" and sections 1142 through 1144 of title 10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49f6936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received as a demonstration grant under this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49f6937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and implement a plan to streamline State requirements and procedures as described in subsection (a), including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49f6938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the extent to which the requirements for the education, training, and skill level of civilian health care professions (such as emergency medical technicians, paramedics, licensed practical nurses, registered nurses, physical therapy assistants, or physician assistants) in the State are equivalent to requirements for the education, training, and skill level of veterans who served in medical related fields while a member of the Armed Forces of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49f6939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying methods, such as waivers, for veterans who served in medical related fields while a member of the Armed Forces of the United States to forgo or meet any such equivalent State requirements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49f693a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary to meet workforce shortages or address gaps in education, training, or skill level to meet certification, licensure or other requirements applicable to becoming a civilian health care professional (such as an emergency medical technician, paramedic, licensed practical nurse, registered nurse, physical therapy assistant, or physician assistant professions) in the State, develop or expand career pathways at institutions of higher education to support veterans in meeting such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49f693b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the completion of the demonstration program under this section, the Secretary shall submit to Congress a report on the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49f693c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No additional funds are authorized to be appropriated for the purpose of carrying out this section. This section shall be carried out using amounts otherwise available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49f693d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration program under this section shall not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49f693e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tI/s105"},"text":"Pub. L. 114–198, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/701"},"text":"130 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb49f693f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb49f6940-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb49f6941-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 247, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s315"},"text":"act July 1, 1944, ch. 373, title III, § 315","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1988-10-04"},"text":"Oct. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/471/s1"},"text":"Pub. L. 100–471, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2284"},"text":"102 Stat. 2284","children":[],"tail":", which related to grants for treatment drugs for acquired immune deficiency syndrome, ceased to exist "},{"tag":"date","attrib":{"date":"1989-03-31"},"text":"Mar. 31, 1989","children":[],"tail":", pursuant to subsec. (d) thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 247, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s315"},"text":"act July 1, 1944, ch. 373, title III, § 315","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/626/tII/s203"},"text":"Pub. L. 95–626, title II, § 203","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3578"},"text":"92 Stat. 3578","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1979-07-10"},"text":"July 10, 1979","children":[],"tail":", "},{"tag":"r