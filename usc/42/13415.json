{"tag":"section","attrib":{"id":"idbfc0d6ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415"},"text":null,"children":[{"tag":"num","attrib":{"value":"13415"},"text":"§ 13415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midcontinent Energy Research Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc0d6ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that petroleum resources in the midcontinent region of the United States are very large but are being prematurely abandoned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the efficiency of petroleum recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase ultimate petroleum recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delay the abandonment of resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish the Midcontinent Energy Research Center (referred to in this section as the “Center”) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research in petroleum geology and engineering focused on improving the recovery of petroleum from existing fields and established plays in the upper midcontinent region of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the results of the research described in paragraph (1) are transferred to users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc0d6f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc0d6f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting research under this section, the Center shall, to the extent practicable, cooperate with agencies of the Federal Government, the States in the midcontinent region of the United States, and the affected industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc0d6f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research programs conducted by the Center may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfc0d6f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data base development and transfer of technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d6f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservoir management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d6fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservoir characterization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d6fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced recovery methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfc0d6fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13415/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of new technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc0d6fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXX/s2015"},"text":"Pub. L. 102–486, title XX, § 2015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3060"},"text":"106 Stat. 3060","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
