{"tag":"section","attrib":{"id":"idbf3d9c55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11262"},"text":null,"children":[{"tag":"num","attrib":{"value":"11262"},"text":"§ 11262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Center for Health Services Research and Health Care Technology Assessment shall disseminate the results of research conducted under this part to appropriate professional entities and to the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbf3d9c56-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s935"},"text":"Pub. L. 99–660, title IX, § 935","children":[],"tail":", formerly § 948, "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3812"},"text":"100 Stat. 3812","children":[],"tail":"; renumbered § 935, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/c/2/B"},"text":"Pub. L. 100–607, title I, § 142(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
