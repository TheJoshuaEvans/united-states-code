{"tag":"section","attrib":{"id":"idbd086d67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h"},"text":null,"children":[{"tag":"num","attrib":{"value":"5116h"},"text":"§ 5116h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd086d68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community referral services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community referral services” means services provided under contract or through interagency agreements to assist families in obtaining needed information, mutual support and community resources, including respite care services, health and mental health services, employability development and job training, and other social services, including early developmental screening of children, through help lines or other methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based and prevention-focused programs and activities to prevent child abuse and neglect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community-based and prevention-focused programs and activities designed to strengthen and support families to prevent child abuse and neglect” includes organizations such as family resource programs, family support programs, voluntary home visiting programs, respite care programs, parenting education, mutual support programs, and other community programs or networks of such programs that provide activities that are designed to prevent or respond to child abuse and neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Respite care services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “respite care services” means short term care services, including the services of crisis nurseries, provided in the temporary absence of the regular caregiver (parent, other relative, foster parent, adoptive parent, or guardian) to children who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd086d6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in danger of child abuse or neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd086d6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have experienced child abuse or neglect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd086d6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have disabilities or chronic or terminal illnesses.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such services shall be provided within or outside the home of the child, be short-term care (ranging from a few hours to a few weeks of time, per year), and be intended to enable the family to stay together and to keep the child living in the home and community of the child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd086d6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tII/s208"},"text":"Pub. L. 93–247, title II, § 208","children":[],"tail":", formerly § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s121"},"text":"Pub. L. 104–235, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3087"},"text":"110 Stat. 3087","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tI/s129"},"text":"Pub. L. 108–36, title I, § 129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/817"},"text":"117 Stat. 817","children":[],"tail":"; renumbered § 208 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI"},"text":"Pub. L. 111–320, title I","children":[],"tail":", §§ 139, 141, "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3481"},"text":"124 Stat. 3481","children":[],"tail":", 3482.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd086d6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd086d70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd086d71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s208"},"text":"section 208 of Pub. L. 93–247","children":[],"tail":" was renumbered section 207 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5116g"},"text":"section 5116g of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s208"},"text":"section 208 of Pub. L. 93–247","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5116g"},"text":"section 5116g of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/s401/a"},"text":"Pub. L. 103–252, § 401(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd086d72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/1"},"text":"Pub. L. 111–320, § 139(1)","children":[],"tail":", (2), redesignated par. (2) as (1) and struck out former par. (1). Prior to amendment, text of par. (1) read as follows: “The term ‘children with disabilities’ has the same meaning given the term ‘child with a disability’ in section 1401(3) or ‘infant or toddler with a disability’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1432/5"},"text":"section 1432(5) of title 20","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/2"},"text":"Pub. L. 111–320, § 139(2)","children":[],"tail":", redesignated par. (3) as (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/2"},"text":"Pub. L. 111–320, § 139(2)","children":[],"tail":", (3)(A), redesignated par. (5) as (3) and inserted “, including the services of crisis nurseries,” after “short term care services” in introductory provisions. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/3/B"},"text":"Pub. L. 111–320, § 139(3)(B)","children":[],"tail":", substituted “child abuse or neglect” for “abuse or neglect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/3/C"},"text":"Pub. L. 111–320, § 139(3)(C)","children":[],"tail":", substituted “have disabilities or chronic or terminal illnesses.” for “have disabilities, chronic, or terminal illnesses.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/320/s139/2"},"text":"Pub. L. 111–320, § 139(2)","children":[],"tail":", redesignated par. (5) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s129/a"},"text":"Pub. L. 108–36, § 129(a)","children":[],"tail":", substituted “given the term ‘child with a disability’ in section 1401(3) or ‘infant or toddler with a disability’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1432/5"},"text":"section 1432(5) of title 20","children":[],"tail":"” for “given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1401/a/2"},"text":"section 1401(a)(2) of title 20","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36/s129/b"},"text":"Pub. L. 108–36, § 129(b)","children":[],"tail":", added par. (3) and struck out former pars. (3) and (4), which related, respectively, to family resource and support programs and outreach services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd086d73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd086d74-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/s3"},"text":"section 3 of Pub. L. 93–247","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"section 5101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
