{"tag":"section","attrib":{"id":"idb54b12f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"280j–3"},"text":"§ 280j–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality improvement program for hospitals with a high severity adjusted readmission rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54b12f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54b12f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall make available a program for eligible hospitals to improve their readmission rates through the use of patient safety organizations (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299b–21/4"},"text":"section 299b–21(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible hospital defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible hospital” means a hospital that the Secretary determines has a high rate of risk adjusted readmissions for the conditions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/q/8/A"},"text":"section 1395ww(q)(8)(A) of this title","children":[],"tail":" and has not taken appropriate steps to reduce such readmissions and improve patient safety as evidenced through historically high rates of readmissions, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54b12fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall utilize appropriate risk adjustment measures to determine eligible hospitals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54b12fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280j–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As determined appropriate by the Secretary, eligible hospitals and patient safety organizations working with those hospitals shall report to the Secretary on the processes employed by the hospital to improve readmission rates and the impact of such processes on readmission rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54b12fc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399KK, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3025/b"},"text":"Pub. L. 111–148, title III, § 3025(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/412"},"text":"124 Stat. 412","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
