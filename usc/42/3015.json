{"tag":"section","attrib":{"id":"idbc42850f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015"},"text":null,"children":[{"tag":"num","attrib":{"value":"3015"},"text":"§ 3015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and donations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc428510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary may accept, use, and dispose of, on behalf of the United States, gifts or donations (in cash or in kind, including voluntary and uncompensated services or property), which shall be available until expended for the purposes specified in subsection (b). Gifts of cash and proceeds of the sale of property shall be available in addition to amounts appropriated to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc428511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of gifts and donations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gifts and donations accepted pursuant to subsection (a) may be used either directly, or for grants to or contracts with public or nonprofit private entities, for the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc428512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The design and implementation of demonstrations of innovative ideas and best practices in programs and services for older individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc428513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning and conduct of conferences for the purpose of exchanging information, among concerned individuals and public and private entities and organizations, relating to programs and services provided under this chapter and other programs and services for older individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc428514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development, publication, and dissemination of informational materials (in print, visual, electronic, or other media) relating to the programs and services provided under this chapter and other matters of concern to older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc428515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall establish written guidelines setting forth the criteria to be used in determining whether a gift or donation should be declined under this section because the acceptance of the gift or donation would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc428516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably upon the ability of the Administration, the Department of Health and Human Services, or any employee of the Administration or Department, to carry out responsibilities or official duties under this chapter in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc428517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3015/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or the appearance of integrity of programs or services provided under this chapter or of any official involved in those programs or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc428518-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tII/s204"},"text":"Pub. L. 89–73, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tII/s202/2"},"text":"Pub. L. 106–501, title II, § 202(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2230"},"text":"114 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc428519-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc42851a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc42851b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attr