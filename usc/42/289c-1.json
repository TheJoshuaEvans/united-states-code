{"tag":"section","attrib":{"id":"idb58d994c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"289c–1"},"text":"§ 289c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative use of certain health services research funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that amounts made available under subparts 14, 15 and 16 of part C for health services research relating to alcohol abuse and alcoholism, drug abuse and mental health be used collaboratively, as appropriate, and in consultation with the Agency for Healthcare Research and Quality.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb58d994d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 494A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s125"},"text":"Pub. L. 102–321, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/366"},"text":"106 Stat. 366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2016/c"},"text":"Pub. L. 103–43, title XX, § 2016(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/218"},"text":"107 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1062/b"},"text":"Pub. L. 104–66, title I, § 1062(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/720"},"text":"109 Stat. 720","children":[],"tail":"; "