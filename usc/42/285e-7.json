{"tag":"section","attrib":{"id":"idb573a85c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–7"},"text":"§ 285e–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse on Alzheimer’s Disease","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573a85d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; purpose; duties; publication of summary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall establish the Clearinghouse on Alzheimer’s Disease (hereinafter referred to as the “Clearinghouse”). The purpose of the Clearinghouse is the dissemination of information concerning services available for individuals with Alzheimer’s disease and related dementias and their families. The Clearinghouse shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573a85e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile, archive, and disseminate information concerning research, demonstration, evaluation, and training programs and projects concerning Alzheimer’s disease and related dementias; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573a85f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually publish a summary of the information compiled under paragraph (1) during the preceding 12-month period, and make such information available upon request to appropriate individuals and entities, including educational institutions, research entities, and Federal and public agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee for information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clearinghouse may charge an appropriate fee for information provided through the toll-free telephone line established under subsection (a)(3).","children":[{"tag":"ref","attrib":{"idref":"fn002192"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002192"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (a)(3) has been enacted."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summaries of research findings from other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute, the Director of the National Institute of Mental Health, and the Director of the National Center for Health Services Research and Health Care Technology Assessment shall provide to the Clearinghouse summaries of the findings of research conducted under part D.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb573a862-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445E, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s951"},"text":"Pub. L. 99–660, title IX, § 951","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3813"},"text":"100 Stat. 3813","children":[],"tail":"; renumbered § 445E of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/a"},"text":"Pub. L. 100–607, title I, § 142(a)","children":[],"tail":", (d)(4), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":", 3058.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a863-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a864-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb573a865-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part D, referred to in subsec. (c), probably means part D of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3808"},"text":"100 Stat. 3808","children":[],"tail":", which is classified to subchapter IV (§ 11251 et seq.) of chapter 118 of this title. Prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", this section was part of title IX of "},{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb573a866-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11281"},"text":"section 11281 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a867-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/a"},"text":"Pub. L. 100–607, § 142(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11281"},"text":"section 11281 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/4/A"},"text":"Pub. L. 100–607, § 142(d)(4)(A)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/4/B"},"text":"Pub. L. 100–607, § 142(d)(4)(B)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging” and “part D” for “part E”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
