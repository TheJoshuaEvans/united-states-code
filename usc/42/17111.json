{"tag":"section","attrib":{"id":"idc024f001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111"},"text":null,"children":[{"tag":"num","attrib":{"value":"17111"},"text":"§ 17111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future of industry program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc024f002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024f003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024f004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an energy-intensive industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national trade association representing an energy-intensive industry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting on behalf of 1 or more energy-intensive industries or sectors, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024f007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy-intensive industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “energy-intensive industry” means an industry that uses significant quantities of energy as part of its primary economic activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024f008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology, including data centers containing electrical equipment used in processing, storing, and transmitting digital information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer product manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f00a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f00b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" materials manufacturers, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc024f00c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aluminum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f00d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f00e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forest and paper products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f00f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" metal casting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" glass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" petroleum refining;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mining; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024f013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water and wastewater treatment facilities, including systems that treat municipal, industrial, and agricultural waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other energy-intensive industries, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024f016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedstock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “feedstock” means the raw material supplied for use in manufacturing, chemical, and biological processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024f017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “partnership” means an energy efficiency partnership established under subsection (c)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024f018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the energy-intensive industries program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024f019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program under which the Secretary, in cooperation with energy-intensive industries and national industry trade associations representing the energy-intensive industries, shall support, research, develop, and promote the use of new materials processes, technologies, and techniques to optimize energy efficiency and the economic competitiveness of the United States’ industrial and commercial sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024f01a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024f01b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program, the Secretary shall establish energy efficiency partnerships between the Secretary and eligible entities to conduct research on, develop, and demonstrate new processes, technologies, and operating practices and techniques to significantly improve the energy efficiency of equipment and processes used by energy-intensive industries, including the conduct of activities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024f01c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the energy efficiency of industrial processes and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f01d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, develop, and demonstrate advanced technologies capable of energy intensity reductions and increased environmental performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024f01e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of the processes, technologies, and techniques described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027601f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Partnership activities eligible for funding under this subsection include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" feedstock and recycling research, development, and demonstration activities to identify and promote—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0276021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for meeting industry feedstock requirements with more energy efficient and flexible sources of feedstock or energy supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to develop and deploy technologies that improve the quality and quantity of feedstocks recovered from process and waste streams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0276023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other methods using recycling, reuse, and improved industrial materials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research to develop and demonstrate technologies and processes that utilize alternative energy sources to supply heat, power, and new feedstocks for energy-intensive industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research to achieve energy efficiency in steam, power, control system, and process heat technologies, and in other manufacturing processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" industrial and commercial energy efficiency and sustainability assessments to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0276027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist individual industrial and commercial sectors in developing tools, techniques, and methodologies to assess—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0276028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unique processes and facilities of the sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0276029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy utilization requirements of the sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc027602a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of new, more energy efficient technologies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc027602b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct energy savings assessments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027602c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of technologies and innovations that would significantly improve the energy efficiency and utilization of energy-intensive commercial applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027602d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027602e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc027602f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for funding under this subsection, a partnership shall submit to the Secretary a proposal that describes the proposed research, development, or demonstration activity to be conducted by the partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After reviewing the scientific, technical, and commercial merit of a proposals ","children":[{"tag":"ref","attrib":{"idref":"fn004249"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004249"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" submitted under subparagraph (A), the Secretary shall approve or disapprove the proposal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of funding under this subsection shall be on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0276032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall require cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award competitive grants for innovative technology research, development and demonstrations to universities, individual inventors, and small companies, based on energy savings potential, commercial viability, and technical merit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0276034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0276035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0276036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $184,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $190,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $196,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0276039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $202,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027603a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $208,000,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc027603b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027603c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available under paragraph (1), not less than 50 percent shall be used to pay the Federal share of partnership activities under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc027603d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17111/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate efforts under this section with other programs of the Department and other Federal agencies to avoid duplication of effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail"