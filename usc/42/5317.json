{"tag":"section","attrib":{"id":"idbd4687e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5317"},"text":null,"children":[{"tag":"num","attrib":{"value":"5317"},"text":"§ 5317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation of superseded or inactive programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to transfer the assets and liabilities of any program which is superseded or inactive by reason of this chapter to the revolving fund for liquidating programs established pursuant to title II of the Independent Offices Appropriation Act, 1955 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/83/428"},"text":"Public Law 83–428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/68/272"},"text":"68 Stat. 272","children":[],"tail":", 295) ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701g–5"},"text":"12 U.S.C. 1701g–5","children":[],"tail":"]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd4687e5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tI/s117/b"},"text":"Pub. L. 93–383, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s204/k/2"},"text":"Pub. L. 98–479, title II, § 204(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2233"},"text":"98 Stat. 2233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4687e6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd468